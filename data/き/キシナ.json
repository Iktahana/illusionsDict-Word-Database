    "definitions": [
      {
        "index": 1,
        "gloss": "on one's way somewhere",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　田口は、今、こゝへ来しなにメリケン兵の警戒隊に喧嘩を吹っかけられた、と告げた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも月の十日と二十日は琴平の縁日で、中門を出入する人の多少は通るが、実、平常、此町に用事のある者でなければ余り人の往来しない所である。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹三郎は、初めて、幹太郎とすゞと、幹太郎の妻のトシ子を内地からつれて来しなに、もう、早速、一封度ずつ、三人に、肌身につけて上陸するように強いた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨は落ちて来しなに、空中の有毒瓦斯を溶解して来る。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はここに来しなであった。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当時、府立の一中は築地の河岸、今日の東京劇場所在地に移っていたので、麹町に住んでいる私は毎日この堀ばたを往来しなければならなかった。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠一は実家と角川家との間を往来しながら、熱心に飛騨の古い歴史を研究して、飛騨判官の伝記及び彼と蒙古との関係を明白にすべく努めていた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の弱い者は夜になると酒屋の附近から芳三を葬ってある寺の墓地附近を往来しなかった。",
              "citation": {
                "source": "餅を喫う",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、吉弥もまた僕の心眼を往来しなくなった。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この童と女の子と、道連れとは見えねば、童の入るを待ちて、これをしほに、女の子は来しならむとおもはれぬ。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「汝あに最初に生れたる人ならんや、山よりも前に出来しならんや云々」とあるは、神の世界創造に当ってその相談相手たりし天使ならんやとの意を伝うる語である。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "風流な家に住んで現代を誹謗して鹿を馬だと言おうとする人間に阿る者がある」　とお言いになって、報復の手の伸びて来ることを迷惑に思う人たちは警戒して、もう消息を近来しなくなった。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "この名あるより鼠の嫁入りという諺は出で来しなるべし。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "大菱屋から拐引を言い立てられたら、あるいは殿様の御身分にかかわるようなことが出来しないとも限らない。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って私の心の働きは二つの極の間を往来しなければならない。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シーボルトが若し渡来しなかったら、日本の蘭学や本草学はアレ程に発達しなかったであろうし。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生往来しない仲でも、僅か二年か三年に一遍ぐらいしか会わないでも、昔し親しくした間柄は面と対った時にいい知れないなつかしさがある。",
              "citation": {
                "source": "鴎外博士の追憶",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃から私とは段々疎遠となって余り往来しなくなったゆえ、その頃からの緑雨の晩年期については殆んど何にも知らない。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の手の見まわりについているはずの敬四郎がいつのまにか八丁堀へ引き揚げてきたとみえて、何を騒いでいるのか、そのお組屋敷のあたりは、小者たちがざわざわと去来しながら、不思議な人だかりでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしが奥様のお使さえ勤めなければ、こんなことも出来しなかったのでございましょう。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当時、府立の一中は築地の河岸、今日の東京劇場所在地に移っていたので、麹町に住んでいる私は毎日この堀端を往来しなければならなかった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、人間の運命はわからないもので、小鉄はここで生みの親にめぐり逢わなかったら、不幸の死を招くようなことも出来しなかったかも知れなかったんですが、どうも仕方がありません。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "迂濶に騒ぎ立てては、その共謀者を取り逃がすばかりか、玉太郎の身に禍いするような事が出来しないとも限らない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "河豚太鼓",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、友江さんは、精神に異常を来しながらも、信之の沢に対する心持を感知したと見え、はげしい嫉妬にかられては、沢の頸筋をつかんで殴ることさえ屡々ありました。",
              "citation": {
                "source": "暴風雨の夜",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車の通らないのが何よりだ（わがまゝな私を許していたゞきたい）、福島町に入るまではバスもタクシーもトラツクも往来しなかつた。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に十日ほど前もぶらりと這入って来て、子供――パブスト氏には七、八つの女の児がある――の頭を撫でたり、アムステルダムの新聞を読んだりして帰って行ったから、ことによるとまた今日あたりひょうぜんと入来しないともいえない。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、繁殖しないものから由来しながら、永遠に繁殖するという謎である。",
              "citation": {
                "source": "博多にて",
                "author": "AT HAKATA",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事も因縁時節である、因縁が熟さなければ、時節が到来しなければ何事も実現するものではない。",
              "citation": {
                "source": "『鉢の子』から『其中庵』まで",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "顧ふに、彼こそ「若い人に同情心は不足勝なものです」と言はれる場合の、その「若い人」である……）　扨、私は近代病者の一例を御紹介するが、その前に一言前置きしなければならない。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は私を龍宮へ連れて行くなどと大法螺を吹いて、私と對等の附合ひをしようとたくらんでゐるらしいが、もういい、私には何もかもよくわかつてゐるのだから、あまり惡あがきしないでさつさと海の底のお前の住居へ歸れ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
