  {
    "uuid": "2f599d95-2b3e-5b7e-bf5d-355260db1fc1",
    "entry": "起業家",
    "reading": {
      "primary": "きぎょうか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "entrepreneur",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三村は千万長者といわれ、三十七八年の戦争の時、ぼろ船を買い占めて儲けたのは異数で、大抵各方面への投資と土地で築きあげた身上であり、自身に経営している産業会社というようなものはなく、起業家というより金貸しと言った方が適当であった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタンフォード大学で教えていたフレデリック・ターマンは、優秀な卒業生を起業家として育て、産学協同の核として大学の周辺に配しておきたいと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "起業家の夢の時代であった。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
