[
  {
    "uuid": "3dde435a-2560-5ba1-bc9d-bfb1e85e026d",
    "entry": "旭光",
    "reading": {
      "primary": "きょっこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rays of the rising sun",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夜明けの静寂の中、神々しい旭光が空をオレンジ色に染め始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わあ、見て！今日の旭光は本当にきれい！」と、子供が窓に駆け寄った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "一日を始める前に、バルコニーで温かい旭光を浴びるのが日課だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "寺院の屋根に差し込む旭光が、荘厳な雰囲気を一層引き立てていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "第五回　「ピアノ」と拳鬪船中の音樂會――鵞鳥聲の婦人――春枝夫人の名譽――甲板の競走――相撲――私の大閉口――曲馬師の虎　翌朝、銅鑼の鳴る音に驚き目醒めたのは八｜時三十｜分で、海上の旭光は舷窓を透して鮮明に室内を照して居つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "旭光新聞などは四方に訪問記者を走らせて、名流の談話、殊に婦人達の談話を聴取させて、之を毎日の紙上に発表した。",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "旭光一射霜を払いて、水仙たちまち凜とせり。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "棚びく雲があれば雲のふちを色どり、金粉をはじく金色の征矢を放ち、東天は俄かに青緑の空と、くれないの旭光とで絢爛を現出するのであった。",
              "citation": {
                "source": "窓",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが夜明けとなれば既に暁闇と旭光の織り出す絢爛は消え、一気に一音の合図と一緒かのように、視界は隅なき明るさに明け放たれるのであった。",
              "citation": {
                "source": "窓",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "戀の使者には思念をこそ、思念は殘る夜の影を遠山蔭に追退ける旭光の速さよりも十｜倍も速いといふ。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れ渡った晩秋の旭光がウラウラと山懐の大邸宅を照し出すと、黄色い支柱を並べた外廊下に、白い人影が二つほど歩みあらわれた。",
              "citation": {
                "source": "白菊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十一年旭光照波元日の夜明の伊豆の海のほとり、大なる浴室の此処彼処、うす闇の中に人々の白き人魚の肌。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀さんもおいで」　姉と娘との間に立ッて、自分は外庭の方へ廻ッて往ッたが、見つけた、向うの垣根の下に露を含んで、さも美しく、旭光に映じて咲いていた卯の花を見つけた。",
              "citation": {
                "source": "初恋",
                "author": "矢崎嵯峨の舎",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ空気中に塵毛の多く浮かびおるは、晴天の朝、旭光の戸隙に入るときにたやすく見るべし。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "東天一帯ようやく紅色を呈し、四面なお暗黒の間にありて、ひとり旭光の遠く雪峰に映じて、銀色を反射するありさまは、実に筆紙のよく尽くすところにあらず。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶏声残月暁天晴、霞気浮紅日欲生、四面冥濛人未起、雪峰独帯旭光明。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "晨起遠望するに、渺茫無涯の海天、断雲日面をおおい、その間隙より旭光の放射せるを見るは、すこぶる壮快なり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "残月の喜望峰上のあかつき、風冷ややかな大西洋上の秋、旭光は虹を作って雨の来たるを知り、星影が水にうつって波の静かなるを見る。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に、吉山旭光老が鈴木小春浦の使で金十円の無心だ、仕方ない持たしてやる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど花頂山や如意ヶ｜岳などの東山一帯の線が、暁空にくっきり浮き出して、紅の旗みたいな雲の裂け目から、旭光が縦横に走って見えたが、往来へ出て、北山西山のほうをみると、京の町や加茂の水は、まだ仄ぐらい残月の下に眠っていた。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛沫に旭光が映して、磯は金色に煙っていた。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "燦々と、その旌旗や甲かぶとに旭光がきらめいて、群集は眼もくらむような心地に打たれた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ今朝の雲霧を破って、洋々と中天にのぼる旭光を満顔にうけて独り甚だ心は楽しむかのように見えただけである。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い海気に滲んだ橙色の旭光を船底から上に仰ぐと、後醍醐は、待ちきれぬもののように、乾魚俵の間からお身を起した。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
