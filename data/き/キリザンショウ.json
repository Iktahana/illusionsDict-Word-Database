          "literary": [
            {
              "text": "それに浅草で買つた切山椒などがあつた。",
              "citation": {
                "source": "或売笑婦の話",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋江抽斎は楊庵の来る毎に、例も三百文の切山椒を饗した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "三百文の切山椒は飯櫃の蓋に盛り上げる程あつたさうである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月十九日べったら市の日には店へ青竹にて手すりを拵らえ、客をはかって紅白の切山椒を売りはじめます。",
              "citation": {
                "source": "大丸呉服店",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階の梯子段の下に三人車座になって御酒を飲んでいる侍は、其の頃｜流行った玉紬の藍の小弁慶の袖口がぼつ／＼いったのを着て、砂糖のすけない切山椒で、焦茶色の一本独鈷の帯を締め、木刀を差して居るものが有ります。",
              "citation": {
                "source": "菊模様皿山奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊手の代りに笹枝に芋を貫いたのと切山椒を買って美佐子のお土産にし、熊手は鷲神社でそれぞれが買った。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
