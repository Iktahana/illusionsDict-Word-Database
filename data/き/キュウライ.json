[
  {
    "uuid": "9b827965-7363-5fc4-9b30-b462b7454a28",
    "entry": "旧来",
    "reading": {
      "primary": "きゅうらい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
        "名詞",
