      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "traditional",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その頃、此の国の自由詩と称するものは、多くは旧来の形式を完全に脱して居ない、極めて幼稚な口調本位のものであつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "電気のごときも近来量子的のものと考えられる以上は、例えば静電気分布に関する旧来の理論も畢竟一種の統計的の意味しかないようになって来る。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "心着けば旧来し方にはあらじと思う坂道の異なる方にわれはいつかおりかけいたり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何をして居た、旧来は。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘はそれを見送るように、真うしろに旧来た方、男に背を向けてぞ立ちたる。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "逢魔ヶ時を、慌しく引き返して、旧来た橋へ乗る、と、（きりりりり）　と鳴った。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから直にお葉の行方を追う意であろう、彼は旧来し方へ直驀地に駈けて行った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那に於ても日本に於ても、国情の著るしい欧風化は、もはや旧来の慣習を許さぬだらう。",
              "citation": {
                "source": "家庭の痛恨",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んや向後の作物が旧来の傾向を繰返して満足せぬ限り、時と、場合と、作家の性癖と、発展の希望とによって生面を開きつつ推移する限り、何派、何主義と云う思いも寄らぬ名が続々出て来るのが当然である。",
              "citation": {
                "source": "高浜虚子著『鶏頭』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "心着けば旧来し方にはあらじと思ふ坂道の異なる方にわれはいつかおりかけゐたり。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴は、旧来た黍がらの痩せた地蔵の姿して、ずらりと立並ぶ径を見返り、「もっと町の方へ引越して、軒へ瓦斯燈でも点けるだよ、兄哥もそれだから稼ぐんだ。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝはや藪の中央ならむと旧来し方を振返れば、真昼は藪に寸断されて点々星に髣髴たり。",
              "citation": {
                "source": "妖怪年代記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　高坂は旧来た方を顧みたが、草の外には何もない、一歩前へ花売の女、如何にも身に染みて聞くように、俯向いて行くのであった。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早や、旧来た瓦斯に頬冠りした薄青い肩の処が。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は一転して旧来の迷夢を攪破したるボルテイアとなり、バイロンとなり、ゴヱテとなり、カアライルとなり、自由神学派となり、唯心的傾向となりて、今日に至るまでの思想界の変遷はおもしろきこと限りなし。",
              "citation": {
                "source": "各人心宮内の秘宮",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅若というのは梅津の一字を残し、若の一字を附け加えて芸名とし、旧来の梅津家の伝統と区別して華やかに披露をしたところから起った家名らしく、今の梅若家の祖先であるという。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに一人の名人があって、能楽はかくあるべきものと信じて苦心研鑽をして来た結果、前途に疑いもない大光明を認め、遂に一流の開祖となって旧来の各流と相対峙し、弟子を養い、流風を宣揚するとする。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その養子が家元の見込通りに相当の天分を持った児であるとすれば、必然的に旧来の型なるものに疑問を起して、自分の個性もしくは哲学から出直して、研究のやり直しをはじめる。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「男性の貞操に関する法律」が婦人議会で可決されて、婦人の司法官に依ってビシビシ執行されない限り、一般の男性は依然として旧来の道徳と習慣の中に活躍するものと考えるのが至当でありましょう。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "峠に残った一軒家が、それであると聞くまでは、あるいは先達とともに、旧来た麓へ引返そうかとも迷ったのである。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "良ありて渠の身を起し、旧来し方に皈るを見るに、その来りし時に似もやらで、太く足許の※きたりき。",
              "citation": {
                "source": "黒壁",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＳｏｌａｒｉｓとＯＳ／２は、カスタム・アプリケーション中心の旧来の大型文化を直接継承する形で。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧来の陋習を破ったらどうだというんだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ人間が人間の肉を食っているんだが、それがなくなるためには、あらゆる旧来の陋習が破らるべきなんだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、この本の著者が、何の躊躇も無く、片端から旧来の思想を破壊して行くがむしゃらな勇気である。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつとリアリズムの守り手として、旧来の絵画上の諸秩序の打ちこはし手として吉原の創造性を発揮してもらひたいし、若い後進のためにリアリズムの基本的方向を示してやるべきだ。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "▼何故高沖氏は、旧来の世界観にとつて代るものが神話であつて、世界観でないなどと言はないで、神話と称する『新しい世界観』だと言ふことができないのか――、高沖氏の世界観否定の理由は『普遍的世界概念の成立しないところに世界を総体的に理解するところの「世界」観の成立しよう筈がない――』といふ。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが藍丸王は旧来の白髪小僧の通り白痴で呑気でだんまりであった。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は旧来からこの家の、可愛い可愛い美紅姫。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると今までの藍丸王はいつの間にか見すぼらしい乞食の白髪小僧の姿に変って終って、緑色の房々した髪の毛も旧来の通り雪のように白くなっていた。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
