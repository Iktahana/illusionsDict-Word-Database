          "literary": [
            {
              "text": "が、やがて椅子を離れてしょんぼり着物を着初めた。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを清さんはたいへん嬉しがって、お正月から着初めました。",
              "citation": {
                "source": "死因の疑問",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼と存じまして、先生と呼んだんで、根が小心者なので、呼び方から、おッかなびっくり、然し今日は二十三年の一月二日、大変よい日と思いましたのは、書きぞめの日だからであります。",
              "citation": {
                "source": "机と布団と女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "老しづかなるは二日も同じこと梳きぞめや眦をつと引きゆがめ十二月六日　玉藻吟行会。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "友ちゃんもきのう届いた机で達ちゃんへの速達のかきぞめをいたしました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
