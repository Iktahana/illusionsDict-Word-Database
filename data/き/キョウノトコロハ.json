[
  {
    "uuid": "13462880-ae8d-52f1-a650-230e5c5a7d0b",
    "entry": "今日のところは",
    "reading": {
      "primary": "きょうのところは",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
      "ctype": null,
