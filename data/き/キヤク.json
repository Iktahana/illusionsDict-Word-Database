    "definitions": [
      {
        "index": 1,
        "gloss": "irreducible",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "くまでやほうきやくわなどを長屋のすみへかたづけている。",
              "citation": {
                "source": "告げ人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも精々十圓位の物しきやくれないのでせう。",
              "citation": {
                "source": "身上話",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫を御こしなされ度、兄さんまでひきやくに御おくりなされ度候。",
              "citation": {
                "source": "手紙",
                "author": "慶応元年九月か　坂本乙女あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時、二人づれの、見まひきやくが、びやうゐんへ来た時、源八栗のしるしを、見てゐた一人が、「このゑに、かいてある、人のかほは、もうりい博士そつくりですね。",
              "citation": {
                "source": "源八栗",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡弓ひきやくざ仲間奴。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは一日こしかけにこしをかけて木ぐつにするけやきやくるみの木をけずっていた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
