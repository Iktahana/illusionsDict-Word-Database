          "standard": [
            {
              "text": "物語のクライマックスで、主人公はついに狂王と直接対決した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "伝説に語られる狂王の暴政は、今も人々の記憶に刻まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ゲームの中で、狂王が支配する城を攻略するのが最終目標だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "狂念慾火を煽りて霊台に及ぼさば悔ゆともまた効なかるべし、伝へ云ふ古の狂王が一炬に聖殿を燼きて、冥界のなやみとこしへなるに似たらば、そは悲しき極みなり。",
              "citation": {
                "source": "抒情詩に就て",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
