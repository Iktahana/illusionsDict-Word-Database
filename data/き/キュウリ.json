    "definitions": [
      {
        "index": 1,
        "gloss": "cucumber (Cucumis sativus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "早生の節成胡瓜は、六七枚の葉が出る頃から結顆しはじめるが、ある程度実をならせると、まるでその使命をはたしてしまったかのように、さっさと凋落して行ってしまう。",
              "citation": {
                "source": "短命長命",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、若くて完成して、そして速かに世を去って行った何人かの作家たちと、この桃や胡瓜のことを思い合せて興味深く感じるのである。",
              "citation": {
                "source": "短命長命",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そう、胡瓜をやって？",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その剥げた薄い膳には干した川魚を煮た椀と幾片かの酸えた塩漬けの胡瓜を載せていた。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "呆気に取られて見る見る内に、下の方から縮みながら、ぶくぶくと太って行くのは生血をしたたかに吸込むせいで、濁った黒い滑らかな肌に茶褐色の縞をもった、疣胡瓜のような血を取る動物、こいつは蛭じゃよ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "手には三四本ほど、熟し切らない胡瓜を持つて居た。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "札幌の貧民窟と云はれるその界隈で流行り出した赤痢と云ふ恐ろしい病気の事を薄々気味悪くは思ひながら、お末は力三の手から真青な胡瓜を受取つた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めは何んとも思はなかつたが、それが二度三度と続けて来ると突然今日食べた胡瓜の事を思ひ出した。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "心の中には、どうかして胡瓜を食べたのを隠して居る償ひをしようと云ふ気がつきまとつて居た。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ニヤニヤとまた笑ったが、胡瓜の化けたらしい曲った刀が、剥きづらかったか、あわれ血迷って、足で白刃を、土間へ圧当て蹈延ばして、反を直して、瞳に照らして、持直す。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "水を汲む、胡瓜を刻む。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "苹果や梨やまるめろや胡瓜はだめだ、すぐ枯れる、稲や薄荷やだいこんなどはなかなか強い、牧草なども強いねえ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡瓜揉みを命じたところが、怪し気な女が出て来て大皿の中にチョッピリ盛り付けたのが、驚くなかれ代価四十銭。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「焼酎でも結構結構」と、焼酎五、六合に胡瓜の漬物を出して貰い、まだ一缶残っておった牛肉の缶詰を切って、上戸は焼酎をグビリグビリ、下戸は仕方がないので、牛肉ムシャムシャ、胡瓜パクパク。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "漬物は五、六杯お代りをすれば、もう一家中にあるだけ尽く平げてしまったので、今度は生の胡瓜に塩をつけて丸噛り。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼酎と胡瓜は尽く吐き出したが、同時に食った牛肉は不思議にも出て参らず、胃の腑もなかなか都合好く出来たものかな。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗て近所の女房たちと一しよに、茄子や胡瓜の籠をしよつて町へ売りに行つたとき、監獄と云ふものを態々見物に行つたことがあつた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕顏には、豆府かな――茄子の苗や、胡瓜の苗、藤豆、いんげん、さゝげの苗――あしたのおつけの實は……昭和六年八月",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡瓜ならば日野川の河童が噛ろう、もっての外な、汚穢うて汚穢うて、お腰元たちが掃除をするに手が懸って迷惑だ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私……もう、やがて、船の胡瓜も出るし、お前さんの好きなお香々をおいしくして食べさせて誉められようと思ったけれど、……ああ何も言うのも愚痴らしい。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "麓の里道、其石段まで、爪さきあがりの二町ばかりがほど、背戸の花、屋根の草相交り、茄子の夕日、胡瓜の風、清き流颯と走りて、処々水の隅に、柄長き柄杓を添へたるも、なか／＼の風情に候。",
              "citation": {
                "source": "逗子より",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "辛子菜の香味、茄子の色彩、胡瓜の快活、糸菜の優美、――しかし私はどちらかといえば、粕漬の濃厚よりも浅漬の淡白を好いている。",
              "citation": {
                "source": "漬物の味〔扉の言葉〕",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "約をふんで、樹明君がやつてきた、鮹と胡瓜とを持つて。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔬菜の手入れ、トマトと茄子とは上出来、胡瓜と大根とは不出来、しかし、楽在其中で、趣味第一、実用第二である。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "……午後は畑を中耕施肥した、トマトよ、茄子よ、胡瓜よ、伸びよ、ふとれよ、実れよ（人間はヱゴイストですね！",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もかも生きてゐる、……とつく／″＼思ふ、畑を手入れしてゐる時に殊にこの感が深い（胡瓜の蔓など実に不可思議である）。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明君を学校に訪ねて、胡瓜と玉葱とを貰うて戻る。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "・炎天のましたをアスフアルトしく・胡瓜の手と手と握りあつた炎天　七月九日晴、晴れるにきまつてゐる、晴れなければならないのだ！",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "・山の鴉はけふも朝からないてゐる・手紙焼き捨てるをお湯が沸いた・風の枯木をひらふては一人戻るなり、水を汲み胡瓜を切り御飯を炊く、いやはや忙しいことである、独居は好きだけれど寂しくないこともない、たゞ酒があつて慰めてくれる、南無日本酒如来である。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのよく日、町の子の克巳は、なすや、きゅうりや、すいかを、どっさりおみやげにもらって、町の家に帰っていったのでした。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
