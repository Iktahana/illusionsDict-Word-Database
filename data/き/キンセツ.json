[
  {
    "uuid": "5c51399a-0108-5577-9bab-c7f2ec4d22e0",
    "entry": "近接",
    "reading": {
      "primary": "きんせつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
