    "definitions": [
      {
        "index": 1,
        "gloss": "proximity",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その語をフランスが輸入して、次第に趣味についての 〔e'le'gant〕 に近接する意味に変えて用いるようになった。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分に近接している「町風」は「いき」として許されるが、自分から疎隔している「屋敷風」は不意気である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸体を回想として近接の過去にもち、あっさりした浴衣を無造作に着ているところに、媚態とその形相因とが表現を完うしている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "僥倖に鏡を見る時、後に近接曲者映りて、さてはと用心したればこそ身を全うし得たるなれ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "医学士は取るとそのまま、靴音軽く歩を移してつと手術台に近接せり。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "氣と血と相離れぬ中が生で、氣と血と相別るゝが死なのである位だから、氣と血とは實に相近接密着して居るのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "気と血とが相離れない状態が生で、気と血とが相別れるのが死であるくらいだから、気と血とは実に相近接密着しているのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "英國ガ印度ヲ牛馬視シテ己ヲ利シツツアル現状ガ正義ニ非ザル如ク、日本及ビ近接ノ亞細亞七億ノ民族ヨリ濠洲ヲ封鎖シツツアル現状ハ同一ナル不義ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "夷※の館山（素藤の居城）というは今も同じ地名の布施村や国府台に近接する立山であろう。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "沼南にはその後段々近接し、沼南門下のものからも度々噂を聞いて、Ｙに対する沼南の情誼に感奮した最初の推服を次第に減じたが、沼南の百の欠点を知っても自分の顔へ泥を塗った門生の罪過を憎む代りに憐んで生涯面倒を見てやった沼南の美徳に対する感嘆は毫も減ずるものではない。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、文三が作者自身の性格の一部を極端に誇張して作為したのが争われないと同様に、作者に近接する人物の性格の一部をモデルとしたに違いなかろうが、二葉亭はお政や昇については何にも咄さなかった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "現場近接　海底へ下りたワーナー博士一行十名は人員点検をして異状のないことを確かめた上で、一団となって進発した。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "三名は、装置と共にここに残留し、残りの七名はこれから前進して振動源に近接する。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにおいて善の概念は美の概念と近接してくる。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡そ此等の地名は、韓國の古史にも多く見えず、見えたるも、兒林が爾陵に作らるゝなど、反て日本紀と三國志との近接せるに似ざるを證するに過ぎざるに、日本紀と三國志との符合は、以て日本紀の作者が、已に三國志若くは魏略の類を見たりしことを推知すべし。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "小間物屋の紅勘と近接した横丁には「みめより」という汁粉屋がある。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "名高かった店などの印象",
                "note": "青空文庫"
              }
            },
            {
              "text": "東亞連盟運動は、世界のあらゆる民族の間に正しき協和を樹立するため、その基礎的團結として、まづ地域的に近接し且つ比較的共通せる文化内容をもつ東亞諸民族相携えて民族平等なる平和世界を建設せんと努力したるもの、支那事変や大東亞戰爭には全力をあげて反對したのである。",
              "citation": {
                "source": "新日本の進路",
                "author": "石原莞爾將軍の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "イ、一七五六年　墺国の外交は着々成功し露、スウェーデン、索（ザクセン）、巴等の諸邦をその傘下に糾合し得たるに対し、大王は英国と近接した。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが墺将ダウンが近接し来たり、巧みに大王の攻囲を妨げるので大王は止むなく手兵を率いてこれに迫り、六月十八日コリン附近でダウンの陣地を攻撃した。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは陸前の登米、本吉、気仙の諸郡から、陸中の東磐井、江刺（以上旧仙台領）、その他これらの地方に近接した地方にわたって行なわれている竈神とて粘土や木刻の円眼船口形の怪奇な面を家々の竈前の柱に掛けておく風習があることである。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "と同時に肉体の温みを感じ合ふくらゐに近接してゐた一人の青年の顔を振顧つた。",
              "citation": {
                "source": "復讐",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
