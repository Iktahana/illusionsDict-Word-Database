        "examples": {
          "standard": [
            {
              "text": "ハイキング中に、足元でひっそりと咲く可憐な絹蘭を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この時期の草原には、小さくて白い絹蘭の花が点々と咲き、絨毯のようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "絹蘭は、手入れの行き届いた芝生よりも、少し荒れた場所に群生していることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「見て、こんなところに絹蘭が！初めて見たよ」と友人が指差した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "雲介が住みあらしたる家なれば河原乞食や跡にきぬらん　奇人ではあったけれども、あまり世間からは好かれていなかったようだ。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
