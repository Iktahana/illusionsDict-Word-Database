    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "important part (to listen to)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「このジャズナンバーの聴きどころは、中盤で入るトランペットの即興ソロなんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "若き天才指揮者の大胆な解釈が光る第3楽章こそが、今回の演奏会の最大の聴きどころと言える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "オペラの聴きどころをまとめた解説パンフレットを読んでから鑑賞すると、より深く物語に没入できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "贔屓役者が出て来たり、いはゆる「見せ場」「聴きどころ」といふやうなところへ来ると、あちこちで、「好々」と声がかゝる。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
