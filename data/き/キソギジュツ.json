        "examples": {
          "standard": [
            {
              "text": "最新の応用技術も、結局は基礎技術の積み重ねだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "職人は、どんなに経験を積んでも基礎技術の習得を怠らない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この製品の開発には、画期的な基礎技術が使われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スポーツの練習では、反復によって基礎技術を体に染み込ませる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "パーソナルコンピューター誕生のための基礎技術として、マイクロコンピューターは不可欠です。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "針金に情報を書き込むワイヤーメモリーを用い、記憶させた検査のためのプログラムをデコーダーを使って読み出すＩＣテスターの頭脳の開発にあたった後藤は、意識しないうちにコンピューターの基礎技術を身につけていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなると、やはり自分でも少し描いて見たくなって、とうとう墨色の科学的研究に関する基礎技術の練習を始めることになったわけである。",
              "citation": {
                "source": "南画を描く話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
