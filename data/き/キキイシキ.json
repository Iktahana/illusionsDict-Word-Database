        "examples": {
          "standard": [
            {
              "text": "若者の間にも、将来に対する危機意識が薄れているわけではない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "企業は常に市場の変化に対する危機意識を持つべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の危機意識の高さが、チームを最悪の事態から救った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "マルチメディアや光ファイバー・ネットワークによって、あすにも紙と活字の本がなくなるかもしれないといった危機意識の盛りあげ方は、ちょっと古いのではないか。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大型コンピューターのメーカー、特にその中でも世界市場を独占的に押さえていたＩＢＭなどでは、最初は歯牙にもかけなかったパーソナルコンピューターが急成長していくのを見て大変な危機意識を持ったのではないかなどと、私はついいらぬ邪推をしてしまいます。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
