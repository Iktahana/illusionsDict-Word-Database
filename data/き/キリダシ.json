    "definitions": [
      {
        "index": 1,
        "gloss": "pointed knife",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "木彫りの細部を仕上げるために、職人は特製の切り出しを使った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "キャンプで、焚き火の準備のために小枝を削るのに切り出しナイフが役立った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この革細工用の切り出しは、切れ味が良くて狙った通りに革をカットできるんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "その頃では神棚の燈明を点すのにマッチは汚れがあるというのでわざわざ燧で火を切り出し、先ずホクチに点火しておいてさらに附け木を燃やしその焔を燈心に移すのであった。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ一つの石塊を切り出し、運搬し、そうしてかつぎ上げるのは容易でない。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "農夫などにはまだ燧袋で火を切り出しているのがあった。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とうとうある日、俊は相手の気持を損じやしないか、顔色を見い見い、茶目らしい話しッぷりで切り出した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」山崎は冗談のように切り出した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一畝、十二円六十銭で買った畠を、坪、二円三十銭で切り出して来た。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地を売ッ払ッて仕末をつけてしまうように、無遠慮な調子で切り出した。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "材木の切り出し作業や製紙工場の光景でも、ちょっと簡単な地図でも途中に插入して具体的の位置所在を示しならびに季節をも示してくれたら、興味も効能も幾層倍するであろう。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたら堂脇が案外やさしい声で、「失礼ながらどちらでご勉強です、たいそうおみごとだが」と切り出した。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝三郎夫婦が部屋に戻って来たのを機会に政江は切り出した。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と私は切り出した。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで……』『ロマンティストの友情にかけて――』と私は、おそるおそる切り出した。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど山姥がもう少しで上がるところで、銀子はざっと稽古をしてもらい、三味線を傍へおくかおかぬに、いきなり切り出してみた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　銀子は切り出した。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、……」　とすぐに切り出し、「このノートは、しばらく貸していただけませんか」「ええ、どうぞ」「このひとは、まだ生きているのですか？",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は男に、「それで、結婚のお話は」　ともう判り切って仕舞ったことを形式的に切り出した。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋雄がわたしの状態の粗筋を病歴のようにおまえに話し聴かして呉れたのち、わたしはいよ／＼おまえに会って話を切り出した。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからある海草の茎で火切臼と火切杵という物をこしらえて、それをすり合わせて火を切り出して、建御雷神に向かってこう言いました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　なんと答えようかと、私はすこしく考えていると、奥さんの方から切り出しました。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "御退屈なら伯父が帰るまでに一ツ謡って見ましょうか」　と切り出した。",
              "citation": {
                "source": "謡曲黒白談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（主人ともいろいろ相談致しましたが、こちらはどちらでもよろしいんですけれども、貴女が非常にご希望のようですから……）という切り出しだった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "新子は、わびしい気がしながらも、「美和子のことなんでございますが……」と、話を切り出した。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "君ひとつレコード歌手にならんかね」会うなり、矢野は事務的な口調で切り出した。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺言ったて、馬の耳さ念仏だから……」　祖父はこう切り出して松三の顔を見、菊枝の表情に見入り……。",
              "citation": {
                "source": "緑の芽",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "話をどう切り出したらいいだろう？",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある朝、私の部屋にやってきて、いきなり話を切り出しました。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と切り出して、『モウソンでもらえるのはほんの二〇〇なのですけれど、モウソンはしっかりしています。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と出し抜けに大佐は切り出した。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕のうちの近くなら洪積と沖積があるきりだしずっと簡単だ。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中畑というのにも僕は一度あってるきりだし、世間さまに云わせたら、僕が君をなんとかしてケチをつけたい破目に居そうにみえるのではないかしら。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
