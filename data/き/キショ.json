    "definitions": [
      {
        "index": 1,
        "gloss": "rare book",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すると胸にどんぐりのきしょうをつけた白い小さな狐の子が立って居て云いました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ぶん殴るぜ、こんちきしょう。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おや、笑ったな、ちきしょうめ、あたしの手紙を軽蔑したな、そうよ、どうせ、あたしは下手よ、おっちょこちょいの化け猫ですよ、あたしの手紙の、深いふかあい、まごころを蹂躙するような悪漢は、のろって、のろって、のろい殺してやるから、そう思え！",
              "citation": {
                "source": "律子と貞子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はははは、ちきしょうめ。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほうい、ちきしょう。",
              "citation": {
                "source": "のら犬",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "元日から店びらきしょ思て、そら天手古舞しましたぜ」　場所がいいのか、老舗であるのか、安いのか、繁昌していた。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええ、ちきしょう、鴨の尻、夜が来る。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ひきしょびくじょッ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちきしょう、人をぶちゃァがったな。",
              "citation": {
                "source": "やどなし犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "拾っていくうちに、「はてな、ちきしょう、おつなところで止まっておりますぜ」　てっきり表を町のほうへでも落ち延びたろうと思われたのに、足跡はぐるりと住まいのまわりを半分回って、ぴたり、そこの縁の下のところでとぎれました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おお、つめてえ、ちきしょう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "おついたちの赤のご飯をいただいたのはおとついだから、ええと――ちきしょう、三日なら三日といやいいんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちきしょう、あの手この手を出しやがらあ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "気に入ったかね」「ちきしょう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちきしょう、雨が小降りになりやがった。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと足先にもう――」「あげてきたか」「いいえ、あの変な落としまゆの女を締めあげてね、下手人のどろも吐かし、ありかも突き止めて、今のさっきしょっぴきに出かけたというんですよ」「ほほう、そうかい」　驚くかと思いのほかに、ゆうぜんたるものでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "二番目にドアをくぐった慶一のうしろから、秋本が、「あ、ちきしょう、おれ、二番」　といったとき、はじめて、慶一はなにをいっているのかが理解できた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちきしょう――さすがの大将も、この雨は予算に入れなかったわい」と人夫は呟いた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ないといいながら三枚がところ、心あたりがあるというちきしょう本当に張り倒してやるかな。",
              "citation": {
                "source": "染吉の朱盆",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肝臓の悪い肉体なんか、ちきしょう、打っちゃってしまえ。",
              "citation": {
                "source": "怒りの虫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちきしょう、僕は悲しいんだ。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "十号ガスのピストルは、ことごとく地上に落ち、帽子のきしょうも、金ボタンも、みんなとけて落ちるのであった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランプをおいたテーブルの前に、三つのイスをならべ、ちがった色でクラブの頭文字のＰ、Ｃ、二つの大きな字をぬいつけた四つの白いきしょうが用意されました。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "今後七時、四人の会員は、クラブ室にのぼっていき、くびに、きしょうをまきつけ、ものものしい態度で席につきました。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちきしょう、このばちあたりめが、とうとうみつけたぞ。",
              "citation": {
                "source": "赤ずきんちゃん",
                "author": "ROTKAPPCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "善ニョムさんは、まったく狂人のように怒り出して、畑の隅へ駈けて行くと天秤棒をとりあげて犬の方へ駈けていった「ち、ちきしょうめ！",
              "citation": {
                "source": "麦の芽",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ど、どちきしょめ！",
              "citation": {
                "source": "麦の芽",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳子　……ええい、ちきしょ！",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "省三　ちきしょう、だまれ！",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だまれ、ちきしょう！",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
