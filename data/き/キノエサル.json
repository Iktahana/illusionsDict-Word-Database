        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "十七年（甲申）　一八八四○四月、新富座の一番目に「二代源氏誉身換」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿三日、甲申、晩頭雪降る、夜に入つて尺に満つ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七年甲申、三十八歳。",
              "citation": {
                "source": "能久親王年譜",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その壬申よりわが元仁元年甲申にいたるまで、二千一百八十三歳なり。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭軒には自家の「甲申元旦作」よりして外、別に「恭奉々忘老至。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「和伊沢信恬甲申元日韻。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは唯此に由つて蘭軒が甲申の正月元日にも又友を会して詩を賦したことを知るのみである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "又此年甲申八月十七日後に茶山が蘭軒に寄せた尺牘がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "是は甲申中秋の月が照すに及ばなかつた黄葉村舎牀頭の小珠の何物なるかを究めむがためである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲申の七月は小であつたから、発病より死に至るまでは陰暦の五十一時間である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その市に上つたのは恐くは甲申の春であらう。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは上の甲申旺秋後の茶山の書牘を引くに当つて、其全文を写し出した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "余語氏は此年甲申の武鑑に、「余語古庵、寄合御医師、五百石、本郷御弓町」の一人が見えてゐるのみである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」わたくしは今「慊堂日暦」を閲して、纔に甲申の歳に至つてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "知る所の最後の訪問は甲申二月五日である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その甲申の歳に神辺にゐた子彦なることは復疑を容れない。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは偶松崎慊堂文政甲申の日暦を閲して、「十五日（六月）晴、熱、都下祭山王、結綵六十余車、扮戯女舞数十百輩、満城奔波如湧」の文が目に留まつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "七年甲申　平八郎三十二歳。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "之を詰れば則ち曰、「甲申乙酉に（明の亡びたる〔二字欠〕の末年なり。",
              "citation": {
                "source": "八宝飯",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋甲申（西暦一六四四）以來。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "六甲は甲子、甲戌、甲申などの甲の六日を指している。",
              "citation": {
                "source": "古代東洋への郷愁",
                "author": "――『仙書参同契』の解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち、「五月｜庚辰朔｜甲申、吉野宮に幸したまふ。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉均は十七年の甲申の変によって朴泳考とともにわが国に亡命し、爾来十星霜落※流離の身を岩田周作という仮名にかくれてわが有志の保護のもとにあった。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
