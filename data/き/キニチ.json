    "definitions": [
      {
        "index": 1,
        "gloss": "anniversary of a person's death (on which Buddhist commemorative rites, etc. are performed)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "慧鶴は頼まれた橘屋の祖先の忌日に読経に行き、食事の施しを受けて帰った。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "忌日忌日の法事も若いのに似合わず念入りに執行って、村中の仁義｜交誼を怠らない気ぶりを見せた。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから世人は子規の忌日を糸瓜忌と称え、子規自身の事を糸瓜仏となづけて居る。",
              "citation": {
                "source": "『我輩は猫である』中篇自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三日、辛卯、鴨社の氏人菊大夫長明入道、雅経朝臣の挙に依りて、此間下向し、将軍家に謁し奉ること度々に及ぶと云々、而るに今日幕下将軍の御忌日に当り、彼の法花堂に参り、念誦読経の間、懐旧の涙頻りに相催し、一首の和歌を堂の柱に注す、草モ木モ靡シ秋ノ霜消テ空キ苔ヲ払フ山風同年。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "余所へおよめに往った方が一人残っていなすって、忌日には来られます。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏の忌日にいい功徳をしたと、三右衛門はよろこんで帰った。",
              "citation": {
                "source": "鯉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ旧門下で小謡組であった佐藤文次郎氏が毎年忌日忌日に参詣するほか、藤原宏樹氏、柴藤精蔵氏が時折参詣するばかりで、正月の元旦に梅を持って参詣に行く事にきめていた筆者もその後怠り勝ちになって、勝手な時や序の時に立寄って拝む位の不孝さに陥っていた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "忌日にさきだって、紫野大徳寺の天祐和尚が京都から下向する。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国ではこの尊者の忌日、七月二十五日に牡蠣を食えば年中金乏しからずとて、価を吝まずこの日売り初めの牡蠣を食い、牡蠣料理店大いに忙し。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも仏教に梵教の諸天を入れたごとく、キリスト教に欧州在来の諸神を尊者化して入れたので、ついに年中尊者の忌日を絶やさず、万の事物に守護の尊者を欠くなきに至った。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタリーの百姓、これを熱愛の象とし、彼得尊者特に好むとて、その忌日（六月廿九日）をカーネーション日と称ふ。",
              "citation": {
                "source": "きのふけふの草花",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかもこの日はお二代台徳院殿様、すなわち前将軍｜秀忠公のご忌日に当たるところから、例年のごとく将軍家の増上寺お成りがあるため、お城内も沿道もたいへんな騒ぎでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう直ぐに父の四十九日の忌日が来る。",
              "citation": {
                "source": "父を売る子",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の三年忌日である。",
              "citation": {
                "source": "冬の風鈴",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "オリンピック記七月廿四日　芥川忌日に飛行機で発つ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃は忌日が来ようが盂蘭盆が来ようが誰一人来る者もない。",
              "citation": {
                "source": "墓",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "後世では狩人はそれを年に一度十二月の十二日だけを祭日にするようになり、またそれが後世に移って十二月十二日にはいっさい山入りできぬ日、この日に山へいったら禍いがあるというような狩人ばかりではなく農家一般の山に対する忌日のような形になった（２）。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち祭日を兼ねた忌日である。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "来月の初めには父の忌日が来る。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十二　八月に入って泉太や繁の母親の忌日が来た。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔うて乱れて、何が母の忌日だ、地下の母は泣いたらう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "・朝からふりとほして杉の実の雨・雨の椿の花が花へしづくして・こゝにふきのとうがふたつ　　　亡母忌日二句追加・おもひでは菜の花のなつかしさ供へる・ひさびさ袈裟かけて母の子として　三月十二日まことに春寒である、霜がふつて氷が張つてゐる、小雨さへふりだした。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにこの忌日を太陽暦に引き直せば西洋紀元千七百八十四年一月十六日金曜日に当るとぞ。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "此頃は忌日が来ようが盂蘭盆が来ようが誰一人来る者も無い。",
              "citation": {
                "source": "墓",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "お会式　毎年陰暦十月十三日、祖師日蓮の忌日を卜して執行の法会をお会式とはいい、宗徒は又おめいこうとて本山に参籠する。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "数年前に大槻如電さんが浅草｜北清島町報恩寺内専念寺にある重兵衛の墓に詣でて、忌日に墓に来るものは河竹新七一人だということを寺僧に聞いた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年の抽斎が忌日の頃であった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も尚ほ憐れな女の顏が眼のさきにちらつく。",
              "citation": {
                "source": "少年の悲哀",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "今もなお、哀れな女の顔が目のさきにちらつく。",
              "citation": {
                "source": "少年の悲哀",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを一口飲んだ時の頬の筋肉の動きにちょっと説明のできない真実味があると思った。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
