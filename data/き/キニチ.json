  {
    "uuid": "4254b99a-cf1e-51c2-b08e-f0587af83c5c",
    "entry": "帰日",
    "reading": {
      "primary": "きにち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "returning to Japan",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今も尚ほ憐れな女の顏が眼のさきにちらつく。",
              "citation": {
                "source": "少年の悲哀",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "今もなお、哀れな女の顔が目のさきにちらつく。",
              "citation": {
                "source": "少年の悲哀",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを一口飲んだ時の頬の筋肉の動きにちょっと説明のできない真実味があると思った。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはこの映画を見たときにちょっとそう思ったことである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそもう誰か田舎女をめとって、と考えた事もありましたが、白足袋や主婦の一日始まりぬ、そのあなたの美しいまぼろしが、いつも眼さきにちらついていながら、田舎女の、のろくさいおかみさん振りを眺めて暮すのは、あんまりみじめです。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中は気を利かしたつもりか、食品の皿を運んで来たときにちょっと愛想を振りまくのほかは、あとは影を潜めています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺青の夜の薄あかり、ほんにゆかしい歌麿の舟のけしきにちりかかる。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "団扇片手のうしろつきつんと澄ませど、あのやうに舟のへさきにちりかかる。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスクリームひえびえとふくむ手つきにちりかかる。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときにちょうどひどい大雨がざあざあ降っておりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その石橋を渡った時、派手な裾捌きにちらちらと、かつ散る紅、かくるる黒髪、娘は門を入ったのである。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつと強い言ひ方をすれば彼は戦争をしない武人が好きにちがひない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "）そんな日の私に最も毒なあの生々しい亜鉛板がザラザラと眼の先きにちらついて私は、思はず唇を閉ぢて頤を襟に埋めた。",
              "citation": {
                "source": "悪筆",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく西洋の絵にある悪魔を模したもので、念のため、わきにちゃんとデビルと仮名が振ってある。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう場合の伊豆守様だよ」「大きにちげえねえや。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹刀だこの当たっているほど武道熱心な者が、見るとおり両刀は腰にしたままで、鯉口さえ切るひまもなくあっさりやられているところを見ると、この下手人はじつに容易ならぬ腕ききにちがいなかったからです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳴れど起こせど、散るは桜、花のふぶきにちらりもぞりとあごをまさぐって、見向きもしないのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "子だぬきにちゃらっぽこやられたんじゃござんすまいね」「なにッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうとき、時間はいみじくも停止して、さまざまな過去の断片が彼女の眼さきにちらついたのではあるまいか。",
              "citation": {
                "source": "吾亦紅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ときにちょっとここにお邪魔をしていいですか」　と、ハバノフ特使は傍の籐椅子を指さした。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "と訊かれたときにちらと兆した、そして餘りの恐ろしさにむりやりに心の隅の方へおしやつて、事もなげなふうをよそほつてゐたその不安が、新たな強い力で今つきあげて來たのである。",
              "citation": {
                "source": "盲目",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまた苦痛をこらへる呻きにちかい聲を聞かなければならぬ夜もあつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "發病した最初の日に見た、老いた母の、洗濯に濡れた、赤い、皹割れた手が何かにつけて目先きにちらついてならなかつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロドス（Rhodos）島ではこの星が最も高く上ったときにちょうど地平線上に来る。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "初学の人山川草木を目のさきにちよつと浮べたるのみにて已に句を為す、故にその句は平凡に非ざれば疎豪なり。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一句として面白き句は水うちそゝぐ進物の鯛裂けやすき糸の乱れの古袴妻を奪ひ行く夜半の暗きにちら／＼と雪降る竹の伏見道なく／＼も棺を出だす暮の月　などなるべし。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは降機のときにちょっと唾を飲みこんでもよろしい。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "などいふことを聽くと、もう、さういふ石や金屬のにほひが鼻さきにちらついて來る。",
