[
  {
    "uuid": "55daaf96-b10f-514f-a112-13c86bb34615",
    "entry": "虚字",
    "reading": {
      "primary": "きょじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "kanji representing verb or adjective",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「美しい」の「美」や「速い」の「速」は虚字にあたる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "文法を学ぶ上で、虚字の役割を理解することは重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この単語は、虚字に助動詞が付いて活用する形だね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "辞書で調べると、「晴」のような漢字は虚字として分類されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "歌よみは古来助辞を濫用致し候様、宋人の虚字を用いて弱き詩を作るに一般に御座候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡兆の句複雑というほどにはあらねど、また洒堂らと一般、句々材料充実して、かの虚字をもって斡旋する芭蕉流とはいたく異なり。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、句調のたるむこと一概には言ひ尽されねど、普通に分りたる例を挙ぐれば虚字の多きものはたるみやすく、名詞の多き者はしまりやすし。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "虚字とは第一に「てには」なり。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌よみは古来助辞を濫用致し候様、宋人の虚字を用ゐて弱き詩を作ると一般に御座候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌よみは古來助辭を濫用致し候樣宋人の虚字を用ゐて弱き詩を作るに一般に御座候。",
              "citation": {
                "source": "歌よみに與ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡兆の句複雑といふほどにはあらねど、また洒堂らと一般、句々材料充実して、彼の虚字を以て斡旋する芭蕉流とはいたく異なり。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "「りにけり」というように虚字の長くなった場合は特に「や」「かな」に近い働きをいたします。",
              "citation": {
                "source": "俳句とはどんなものか",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、宿の梅折取るほどになりにけり　　蕪村というような句は「宿の梅折取るほどになり……」という一個の概念をそのあとの虚字によって力強く読者の頭に運ぶのであります。",
              "citation": {
                "source": "俳句とはどんなものか",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　まっさおなきょじんは、おそろしい声でそういうと、耳までさけた口をぱっくりあけました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいては、おとなの三ばいもあるきょじんです。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガスがはいるにしたがって、ビニールのまじんはふくれあがり、しまいには、おとなの三ばいもあるきょじんになってしまったのでした。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
