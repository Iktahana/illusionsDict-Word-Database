        "examples": {
          "standard": [
            {
              "text": "ITカンファレンスの冒頭で、CEOによる基調演説が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「これより、本大会の基調演説を開始いたします。皆様ご着席ください」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は基調演説の中で、持続可能な社会の実現に向けた新しいビジョンを提示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "基調演説の内容が非常に刺激的だったので、その後の議論が活発になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "アイゼンハワーの指名はまだきまっておらず、マッカーサーの基調演説の内容もまだ報道されていなかった時だと思う。",
              "citation": {
                "source": "夢",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夢にシカゴの大統領指名大会とかマッカーサーの基調演説とかが反映していることは明らかであろう。",
              "citation": {
                "source": "夢",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその基調演説が行なわれる前であったということも重要な関係を持っているであろう。",
              "citation": {
                "source": "夢",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
