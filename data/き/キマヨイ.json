        "examples": {
          "standard": [
            {
              "text": "大事な決断を迫られて、ちょっと気迷いしてしまっているんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "進路について、先生に相談したら、色々アドバイスくれて気迷いが晴れたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しいプロジェクトの話は魅力的だけど、今の仕事もあるし、少し気迷い中。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ありふれた強盗、強姦、殺人事件にばかりぶつかって最初から犯人のアタリを附けてかかる流儀に慣れ切っている草川巡査は、この事件に限って、実際、暗黒の中を手探りで行くような気迷いを感じながら、駐在所を出たものであった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに一方、葉茶屋の方は既に荒ぼりが済んでいる所でありますから、今、どっちへ取り掛かって好いか気迷いがしてどっちにも取り掛かることが出来ないのでありました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "好き狆のモデルを得たはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "船乗は迷信深いものだから、つまらぬ気迷いを起さねばいいがと案じていると、果して伊豆柿崎の三郎助という水夫が、端舟を捨ててやらなかったので、要吉の怨みで船がひき戻されたのにちがいない、死んだものの思いのかかった端舟だから、この際、どうでも捨ててもらわねばならぬと、血相変えて強談にかかった。",
              "citation": {
                "source": "重吉漂流紀聞",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれが二度目の攻撃的攻撃に移ろうかどうかと気迷いしているうちに、敵は新たな“｜切り返し”の手を考え出した。",
              "citation": {
                "source": "墓地展望亭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "臨床の実際において気迷いし不安だろう。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "お延のこんな心持も、つい今し方、この山荘へ捕われて来た、新九郎の姿を見てから起った浮気性の気迷いであるから。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　という気迷いにとらわれて、自身は徐州の城へ帰ってしまった。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
