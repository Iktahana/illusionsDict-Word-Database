    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cap (hat)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "文士といふ、ハンデキャップをつけて、政治上経済上の闘争に、さ迷ひ込まれては、お互に迷惑だ。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンディキャップの数で等級別に並べてあるそうだが、やはり上手な人の数が少なくて、上手でない人の数が多いから不思議である。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これができるとできないとで決闘の際に大きなハンディキャップの開きがありそうである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　ロスチャイルド　この映画はなにしろ取り扱っている物語の背景の大きさというハンディキャップを持っている。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに、頭の悪い監督の作った映画では、ちょんまげのかつらをかぶって、そうして、舞台ですると同じようなグロテスクなメーキャップにいろどった顔を、遠慮なくクローズアップに映写する。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡瀬は、代数の計算と下手な機械のダイヤグラムとが一面に書きつづられているフールス・キャップ四枚を自分の前において、イーグル鉛筆を固く握りしめながら新井田氏に項式の説明を試みているのだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜘の巣にでも悩まされたように母が娘を振り離そうとするのを、スカルキャップを被った小柄な父は、読みかけていた新聞紙をかいやって鉄縁の眼鏡越しに驚いて眺めていた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "記録者はフールスキャップに忙しくペンを走らせた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "未醒子の漫画では、吾輩群を抜いて一着のように描いてあるが、その実津川子と同着、シカモ吾輩は裸一貫、津川子には重い荷物のハンデキャップが付いている。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一に僕の人生の出発点からして、捨子という、悲運なハンディキャップがついているんです。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんは、人間にハンデキャップを認めていないらしい。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "病躯の文章とそのハンデキャップに就いて　確かに私は、いま、甘えている。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は、ハンデキャップを認めません。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ぼくは直ちに職場に組織を作り、キャップとなり、仕事を終えると、街で上の線と逢い、きっ茶店で、顔をこわばらせて、秘密書類を交換しました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白いブラウスとキャップを身につけて。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座式のハイカラさが大阪では受けるのだと思ったのは、まだいい方で、たいていは外国映画のメーキャップを模倣し、エキゾチシズムとはアイシャドウを濃くして、つけ睫毛を太くすることだと考えたので、グロテスクな効果だけ残って、失敗した。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "維新後、日本民族は再び海外発展を開始したが、三百年のハンディキャップが、いかに我々にとつて、不利であつたか、しみ／″＼と感ぜられてゐる。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、このハンディキャップを克服して、邁進する点に於て、日本人は先祖に劣らざる勇気を発揮すべきだと思ふ。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の血の中に、祖先の天才的な力を目覚まして、鎖国が生んだハンディキャップを克服し、邁進して行くべきである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも……朝になると、まぁとにかく一度行ってみるくらいはしてみようと、そう決心しましてね、インクの小瓶と鵞ペン、フールスキャップ判の紙を七枚買って、ポープス・コートへ出向いたんです。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "フールスキャップの代金も相当かさんできてましたからね。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "顎のあたりに結わえてあったものというのは、いつものナイトキャップがないのでそのかわりに頭から巻きつけておいた絹のハンケチなのであった。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの、その、「先輩」というハンデキャップは、殆ど暴力と同じくらいに荒々しいものである。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "金持の子というハンデキャップに、やけくそを起していたのだ。",
              "citation": {
                "source": "東京八景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大観といふハンディキャップなしに周囲のものと較べてみたらよい。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちにしろ、彼は好きなようにやるんだから」　長田は鏡を開いて、バイタリスをとりだし、キャップをあけながら、こんどは慶一を見てこたえた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういうことなのか、教えてくれるまでは、ぜったいにイヤだ」　ちょっと慶一を見かえしただけで、高志はあっさりあきらめ、「まあ、いいか」　といって、リポート用紙を開き、万年筆のキャップをとった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビーチボーイズがフェイドアウトして、ベレー帽をかぶり、妙なメーキャップをした長田を、下からあおったショット。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロが払底してるんだ」「兵隊、売春婦、どっちの話だよ」　じぶんのキャップを調節しながら、慶一がいう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃紺のキャップをかぶった令子は、不可解なくらいにリビドーを刺激する。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
