[
  {
    "uuid": "d8cb0a55-f1d3-5c94-ba33-51c835bd88ca",
    "entry": "九拝",
    "reading": {
      "primary": "きゅうはい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
