    "definitions": [
      {
        "index": 1,
        "gloss": "cast (of a film, play, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それからもう一つのおもしろみの原因は登場するキャストの選定によって現わされた人間の定型の真実さにある。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうそうオールスターキャストというだろう。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "オールスターキャストというのがつまりそれだ。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅井朝倉を退治した信長は、此一戦大事と見てオールスター・キャストで来ているのである。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この問題は、そもそもプロレタリア前衛の文学作品を評価する際にあたっての疑問を、告白の形で私が提出したのであるが、種々様々な意味にとられて、ついに、文学一般の問題であるかのような姿を帯びて、論壇のオール・スター・キャストの入り乱れての論戦をまきおこした。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に思うと、前者はエインス・ウォルスの小説「ウィンゾル・キャストル」で、後者は例の「ハムレット」であったらしい。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "人工骨など医療用セラミックスの製造と販売にあたるニューメディカルと、人工宝石のクレサンベールの二つの子会社を設立してセラミックスのあらたな応用分野を開こうと試みる一方で、宝石用台座の加工にあたる日本キャストと、通信、音響、事務機器メーカーのサイバネット工業に資本参加していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなキャストだから、もちろん本当の歌劇上演とはいえないのです。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミス・キャストだという批評、宣伝倒れだという悪口、珍らしく知的な感じだという同情的な見方、素直で大胆なところが有望という苦しい褒め方などが、僕の眼にとまりました。",
              "citation": {
                "source": "あるニュウ・フェイスへの手紙",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（その意味では、山本富士子はミスキャストだが）しかし、この映画はその有り得ない嘘の話からそもそも始まっているので、これをとがめたならば、この話は崩れてしまう。",
              "citation": {
                "source": "映画界・小言幸兵衛",
                "author": "―泥棒しても儲ければよいは困る※―",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう場合に検察の権化のような真名古に一役買わせることは何としてもミスキャストだから、警察当局が真名古を出し抜いて逸早く状況を整備してしまったのは一面無理もない処置だったのである。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「月は上りぬ」はぜいたくなキャストで撮るつもりだ。",
              "citation": {
                "source": "性格と表情",
                "author": "小津安二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五光くらいのキャストでネ。",
              "citation": {
                "source": "性格と表情",
                "author": "小津安二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの日、来月の公演のキャストを内部で決めたんですけど、須野がマリをキャストから落したんです」「へえ、そいつは知っていない」私はふと、保井にくどく理由をたずねていた須野の顔を目にうかべた。",
              "citation": {
                "source": "演技の果て",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "メイル・キャスト用に支給されたアロハ・シャツの復刻版が、十二枚セットで箱入りで出てもいるのよ」「それは知らなかったです」「モンゴメリー・クリフトが、最後に打たれて死ぬでしょう。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月二十七日（金曜）　座へ来ると、渡辺が次の「新婚旅行」の役が嫌だとモメてゐる、結局ふり代へておさまったが、何しろ配役を川口が自分の考へばかりで、定めちまふからミスキャストが尽きないのである。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月十四日（火曜）　十一時から稽古だが、かなり早く浅草迄来てしまひ、大勝館へ入る、「夜間飛行」の後半、オールスターキャストだ、ジョンバリが肥ったのは驚く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひる終って、大勝館へ、白十字で食事して行くと、おめあての「ワンダバー」“Wonder Bar”のつまらぬこと、豪華キャストと、映画ならではのレヴィウシーンがいゝだけ、つまらんので出ちまった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャストは学生が失敗、老の声で成っちゃゐない、之は参った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の東宝はオールスターキャストで、今日の初日が六分の入りだった由。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "話してるうちに、ＰＣＬも一つ大作品を作らにゃいかん、デミル張りで菊池氏の「人妻読本」をオールスターキャストでやったら――と思ひついたので、これは明日森氏に話さう。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、今日中には、喜劇まつりを下りるか、ダブルキャストにするか、尻のダブる三日間を代役にするか定めたいと言ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャストも知らずに来たのだが、鶴丸睦彦・久野四郎なんてのがゐて、やあ／＼。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「女優物語」を、十二月は東宝劇場へ持って来るらしいが、越路以外は全部キャスト変更ときいたので。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
