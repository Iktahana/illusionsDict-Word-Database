        "examples": {
          "standard": [
            {
              "text": "不発弾の安全な処理のため、人里離れた海岸で計画的な起爆作業が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「カウントダウン開始、3、2、1、起爆！」の合図とともに、古い煙突が崩れ落ちた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "静まり返った実験室に、小型爆薬が起爆する乾いた破裂音が響き渡った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ダイナブックが起爆剤となって、各社はいっせいに小型マシンの開発に血道を上げた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "散らかり放題散らかった部屋で西がいじくり回していたのは、地殻変動の起爆剤だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "普及の起爆剤となった新しい表示形式では、自分のページからリンクと呼ばれる連携の絆を、他人のページに張れる。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あと一つ部品があれば街でもぶっ飛ばすニトロコルダイト爆弾を造れるよ」「あと一つとは何だい」「起爆装置だ」「どんなものがいいんだ」「アメリカの時計なら何でもいい。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一方法として、案出されたものが、金持ちのご隠居や若だんなたちを相手のいんちきばくちで、いんちきの裏には同じ切支丹伴天連の催眠の術が潜んでいたことはもちろんでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いんちきばくち勝ち抜き秘法」　と、そういう文字が読まれたからです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぺらぺらとまくった拍子に、そのいんちきばくち必勝秘伝書の中から、ひらひらと下に舞い落ちただれかの書面らしい紙片がありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふとんを売っ払って金をつくって、このいんちきばくちの勝ち抜き秘伝書をとっくり覚え込んでから、千葉のおしろうとだんなをむくどりにしようと出かけていったにちげえねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの物置き小屋がいんちきばくちの開帳場にちげえねえから、しりごみしていずと乗り込みな」　押し入ろうとしたせつな！",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっとこりゃひひじじいと相談して、まんまとここへおびきよせてから、いんちきばくちのわなにしかけ、若後家のおかみさんをものにしようとしたにちげえねえからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いんちきばくちのいかさま師が使う仕掛けのコロじゃねえかよ」「へえ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の年寄りだっても、いんちきばくちのいかさま師がいねえとはかぎらねえんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "おめえは行くえ知れずのばあさんだろうとかなんとかさっき啖呵をきったようだが、あの女の亭主野郎、すなわちこの懐中しているさいころの持ち主、詳しくいえばいんちきばくちうちの玉ころがし屋に縁のある野郎だよ」「かなわねえな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、眼のとおり、一見していんちきばくちのいかさま師と思われる遊び人ふうの男をおなわにしていたものでしたから、あば敬の鼻の高いこと、高いこと。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士男はもう一度｜壁に耳をつけたが、その後せきばくとしてなんの音もない。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく、グロース、ウエップ、イルコックの三名も、いまとおく左門洞の楽園をはなれて、ひとりせきばくたる、この樹下に横臥するとき、さきにこの樹下にねむりし人をおもい、左門洞のことを思えば、その心の奥に一まつのくゆるがごとき、うらむがごとき、一種の念のきざすのを禁じることができようか。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、おおかた「せきばく」でも運ぶのであろう。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
