[
  {
    "uuid": "9689d5e4-c79c-53fd-b6ad-aad2182dfd18",
    "entry": "聞かす",
    "reading": {
      "primary": "きかす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
