        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そんな毒瓦斯は、吸着剤の活性炭と中和剤の曹達石灰とを通せば遮られるし、ゴム衣ゴム手袋ゴム靴で結構避けられます。",
              "citation": {
                "source": "毒瓦斯発明官",
                "author": "――金博士シリーズ・５――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに一番細かい炭素粉といえば、工業方面で吸着剤に使っている活性炭などが最適であろう。",
              "citation": {
                "source": "硯と墨",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アドソルビンという腸内の殺菌吸着剤が三共にあるかしらとも考えて居ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
