[
  {
    "uuid": "a14b3145-c707-5894-b446-bf188cb1fe41",
    "entry": "急遽",
    "reading": {
      "primary": "きゅうきょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
