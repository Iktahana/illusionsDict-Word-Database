        "examples": {
          "standard": [
            {
              "text": "相手の油断を虚に乗じて、奇襲をかける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、人の良さを虚に乗ずるような人間ではない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "会議での議論の隙を虚に乗ずるように、彼は核心を突く発言をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "その躊躇している虚に乗ずるように、色々な記憶が現れて来る。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜に入って一際高くなった、早川の水の音が、純一が頭の中の乱れた情緒の伴奏をして、昼間感じたよりは強い寂しさが、虚に乗ずるように襲って来る。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "営利主義が道徳と結ぶのは、この虚に乗ずるより外はないのである。",
              "citation": {
                "source": "空地利用",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "営利主義が「道徳」と結ぶのは、この虚に乗ずるよりほかはありません。",
              "citation": {
                "source": "文化とは",
                "author": "――力としての文化　第一話",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
