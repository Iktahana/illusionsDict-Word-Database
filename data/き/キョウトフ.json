    "definitions": [
      {
        "index": 1,
        "gloss": "Kyoto Prefecture (Kinki area)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "丹後といへば、いまの京都府の北部である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丹後の国は、いまの京都府の北部であるが、あの辺の人は、この時代に津軽へ来たら、ひどいめに遭はなければならなかつたわけである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都府立京都第一中学校を昨年卒業し、来年、三高文丙か、早稲田か、大阪薬専かへ行くつもりです。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "管野すが子は齡卅歳、生れは京都府葛野郡朱雀野村である、春に秋に歌に好く詩に好いこの歴史的匂ひある村に生れた一女性は、小學校を出で世の鹽にもまれる樣になると、種々數奇の運命に弄ばれた、多少の「文字ある女」に能くある慣として、すが子は澤山の男にも關係したし、多くの文學的書籍にも讀み耽つた。",
              "citation": {
                "source": "日本無政府主義者陰謀事件經過及び附帶現象",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "私と庄亮とはＯ氏やＡ博士やＨ君夫妻を向う斜めに見わたせる、船舶課側の窓際のクッションに凭れる、末席の方だが、このテエブルには若い船医や京都府の警部さんのＡ君やと大概は同席である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "警部のＡさん京都府だ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧畜家のＨ、麦酒会社のＦ、印旛沼開墾の庄亮、京都府警部のＡ、それに私がその前の椅子に腰を下ろしていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治になって、槇村京都府知事が疏水工事を起して、琵琶湖の水を京に引いてきた。",
              "citation": {
                "source": "身投げ救助業",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ロボット流行時代であるが、京都府宮津中学校の四年生岡山大助君という少年が今度、人造犬を発明した、これは犬の腹中に電話器、モートル、電磁石、高圧器、真空管、スピーカー等を材料にして、でっちあげた機械がしかけてあるので、大助君の先生も手伝った。",
              "citation": {
                "source": "人造物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夏醍醐に遊んでゐると、その頃の京都府知事大森｜鍾一氏が山へ上つて来た。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大森氏が京都府知事時代に管内の郡部を巡視中、時々持合せの葉巻が切れる事がある。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて京都府庁の大きな門の前まで来た。",
              "citation": {
                "source": "勇子",
                "author": "一つの追憶",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の京都ホテルのある場所に、京都府立画学校が設けられてありましたので、早速そこに入りました。",
              "citation": {
                "source": "画筆に生きる五十年",
                "author": "――皇太后陛下御下命画に二十一年間の精進をこめて上納――",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三回勧業博覧会は東京で開催されたが、まず私ども京都画壇では京都中の出品をその前年の明治二十二年十二月に京都府庁内で府庁の手によって展覧に供され、やがてそれを一まとめにして東京に荷送りしたもので、出品の人選はそれぞれの師が自分の弟子たちのなかから自由にえらんだものである。",
              "citation": {
                "source": "最初の出品画",
                "author": "――四季美人図――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「京都府巡査に任命する。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都府警察学校初任科に入校を命ずる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "深草で電車を降り、観光客とは逆に進行方向右に折れると、竜谷大学と向かい合って京都府警察学校がある。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、京都府の農業改良普及員を務めていた和田儀一は、担当地域の台風による被害調査にさっそくおもむいた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日洋服を着て書類を入れた風呂敷｜包を小脇に挾んで、洋杖を突いて、京都府下の富豪や寺院をてくてくと歴訪する。",
              "citation": {
                "source": "蓬生",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お濱さんの父は、もと越前の藩士で今は京都府の勧業課長を勤めて居る。",
              "citation": {
                "source": "蓬生",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の話ながら、予の父は明治維新の直後、王政復古の恩沢を国民に如実に示す方法の一つは、国民の健康を保護して安堵せしむるにありと考へ、明治六年に今の京都府立病院を全国に率先して創立し、内外の医家を聘して診療に当らしめたのであつた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち奈良朝に於て種芸、種智、悲田、施療の諸院を開きたる例に則り、諸種の新しき施設を先づわが京都府より試みんとし、府の大参事植村正直氏を初め、友人金閣寺住職伊藤貫宗、銀閣寺住職佐佐間雲巖諸氏に議りて、その協賛を得つ。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "之より先き人智を開発するは古道にのみ由るべからず、宜しく西洋の新智識を布くべしとなし、率先して洋服を著け、神戸居留の外人に交りて舎密（物理、化学）の学を研究せしが、明石博高氏と共に京都府庁に舎密局を設くるに尽力し、局の嘱托となり、府下の諸鉱山を巡囘ｚして鉱石の分析を試みぬ。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "父はまた明治四年より病院の創立に志し、伊藤貫宗、稻葉宙方、佐佐間雲巖諸氏と共に、京都府下に於る各宗の寺院を勧誘して出資せしめ、明治六年十一月一日に到りて英国の医師を主任とし開業式を行へり。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上舎密局、小学校、病院、博覧会、鉱泉場等は、全国に於て京都府の率先して施設する所、また京都府下に養蚕、製茶を奨励し、洋薬、石油等を販売せるは、実に父を以て嚆矢とする所なり。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さはれ父が京都に於ける公共事業に絶縁しつる後も、新思想の有力者つぎつぎに起りて、我国の新事業は常に京都府民によりて先鞭を著けらるるの観ありしは、時運の到ると共に他人に由りて父の志の大成せられつるとも謂ふべきか。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは一九二六年に於ける奈良縣か京都府か大阪府か知らないが有識階級の夫人たちである。",
              "citation": {
                "source": "奈良二題",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "次で京都府立醫學校（今の府立醫科大學）に入學三十二年卒業、後東京に出て傳染病研究所東京外國語學校獨逸語學科に學んだ。",
              "citation": {
                "source": "「孔雀船」解説",
                "author": "中山省三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "てんのうの　おつかい　一休さんは　やましろのくに（いまの、きょうとふ）たまぎむら　と　いう　ところに、しゅうおんあん　と　いう　小さな　いおりを　たててもらって　すんで　いました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
