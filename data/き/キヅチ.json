        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "椅子に腰かけている両足の蹠を下から木槌で急速に乱打するように感じた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "木槌で舞台を打つ合図の音が一つ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（木槌の音三｜下四｜下）上首の一人　――粥に十の利あり、飯には三｜徳六｜味。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手ぬぐい地の肌着から黒い胸毛を現わしてたくましい腕に木槌をふるうている。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は更に土間へおりて新しい草鞋の紐を通して小さな木槌で其草鞋をとん／＼と叩いて呉れた。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして口に水をふくんで、それを霧打ちにして、藁を木槌で打つた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々、フト木槌がとまつた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "座長（木槌を叩きて）「諸君、静粛に願いまする。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではこれより改めて開会とします……」　長官｜木槌を叩く。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉の木槌型の頭は虎斑で、シラクモが蔓つてゐた。",
              "citation": {
                "source": "創作生活にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "長柄の木槌で氷を叩きながら、十数人の男が一列横隊をつくつて向うへ進む。",
              "citation": {
                "source": "諏訪湖畔冬の生活",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二度目にさう呼ばれた時に私は、木槌で胸を打たれたやうに吃驚りして「はアい！",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、まだ鉄砲も火薬もない当時のこととて、百姓どもが壁を叩いて野禽を追ふのに使つた、木槌の音よりも大きく彼の耳に響いたものぢや。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんまりで袋物の細工をして、時折トントンと小さい木槌の音をたてるばかりだった。",
              "citation": {
                "source": "テンコツさん一家",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "……養育料払う金もねえもん」「……木槌野郎！",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に、降矢木算哲……熊城の持った木槌が軽く打ち下されて、胴体にジグザグの罅が入った。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一駅前の寛城子駅まで長春の赤木槌右衛門氏がわざわざ出迎へられた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は木槌をふりあげて棟木をうちおさめた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その視線が、以前は金槌のようだったのに今では木槌のようだと、立川はへんなことを感じました。",
              "citation": {
                "source": "落雷のあと",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり大きな音を立てると、近所に憚られるので、小さな木槌を添えておいた。",
              "citation": {
                "source": "蔵の二階",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "古くから山地の農民の間に実用されて来たように、おばあさんはその黄色な染料を山の小梨に取ることから、木槌で皮を砕き、日に乾し、煎じて糸を染めるまで、そういうことをよく知っていた。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初、木槌で叩くと、刃針が血管の上を滑ってしまう。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だからお前は妙痴奇林の唐変木の木槌頭のおたんちんだってんだ。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "海へ帰る女",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより山とは言うべくもないが、高いところなら猫の額でも山という名をつけたがるのが万事に大袈裟な江戸者の癖で、御他聞に洩れず半ば塵埃捨場のこの小丘も、どうやら見ようによってはそうも見えるというので、一般には木槌山として通っていた。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "無明の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここへ差しかかった土佐犬甚右衛門、背ろの三人を呼ぶように、さてはまた誰かに合図でもするかのように、一声高だかと遠吠えしたかと思うと、木槌の柄を作して二、三間突き出ている土手の蔭へ走り込んだ。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "無明の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　二　八丁堀海老床の露地の奥、気の早い江戸っ児のなかでもいなせを誇る連中が集っている合点長屋、その一棟に朱総を預る名代の岡っ引釘抜藤吉、乾児勘弁勘次に葬式彦兵衛、この三人が今夜の暴風雨を衝いて犬を追い慕って張出し埋地は木槌山まで出向いて来たについては、そこにただならぬ曰くがあるはず。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "無明の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "釘抜藤吉、無理にも最初の見得を守り立てて、乾児を励ましてここまで来た木槌山。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "無明の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜更けて帰宅る金貸し老爺、何しに町筋を外れて木槌山のかげへ立寄ったろう？",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "無明の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「木槌山の柳の下に、矢尻で掘ったこの印しがあったけのう。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "無明の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "木槌山の柳の下に、五万何ぼも咲えてたじゃねえか。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "無明の夜",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
