        "examples": {
          "standard": [
            {
              "text": "「そんな無謀な計画を本気で進めるつもりか？ おい、お前、気は確かか？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はショックで放心状態で座り込んでいたが、こちらの呼びかけに応じたので気は確かなようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おいおい、昼間からそんな高い酒を注文するなんて、気は確かなのかい？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「こんな嵐の中を小さなボートで漕ぎ出すなんて、あいつ、気は確かじゃないぞ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それは気を確固にする道であるから、そうすれば気は確かになって散ることが無くなる。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "金右衛門は見るからに頑丈そうな男で、傷が案外に浅かった為でもあろう、顔の色は蒼ざめているが、気は確かであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奇特な事ぢや、病気は確かに癒りますぞ。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫂は気は確かなものであった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "地獄の空気は確かに死んでるに違ひ無い。",
              "citation": {
                "source": "墓",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "その若い男は、卓の男がまだ笑っているのを見ると、自分もにこにこしながら、「気は確かかな。",
              "citation": {
                "source": "六月",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔ってもね、気は確かよ。",
              "citation": {
                "source": "高尾ざんげ",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……君、気は確かだろうネ。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "気は確かだ」「ほほう。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも気は確かだった。",
              "citation": {
                "source": "白日夢",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえ、気は確かかえ。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "スペードの女王",
                "note": "青空文庫"
              }
            },
            {
              "text": "君、気は確かだろうね。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれをやっていると気は確かに落ちつく」　と千吉君は、やっている以上、何か効験を探し出さなければならない。",
              "citation": {
                "source": "好人物",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "観音様を拝んでいるうちに、結構な智恵が浮ばないとも限らない」「ヘエ、――大丈夫ですか、親分」「気は確かだ、安心するがいい。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "黒い巾着",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもまだ気は確かなまま、もがき、泣き叫び、逃げようとしても、どうにもならないむごたらしい死様を、自分もしなければならないのだと、彼女は、思った。",
              "citation": {
                "source": "日は輝けり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に西の空の雲気は確かにわざわいのきざしをあらわしているのだ。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は冷血にスミスを殺した上、その死体を小脇にかかえて、また外に降りて来たんじゃ」「師父」とアンガスは棒立になった、「あなたは気は確かですか。",
              "citation": {
                "source": "見えざる人",
                "author": "THE INVISIBLE MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは気は確かなんだよ」こう、じっと、妙にきまじめな色さえ浮かべて、弟の顔を見つめながら、ドミトリイ・フョードロヴィッチが言った。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔は血みどろになっていたけれど気は確かで、むさぼるようにドミトリイのわめき声に耳をそばだてていた。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "意味のない戦いなんて私は嫌だ」「陛下、気は確かですか」「確かだとも。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いきなり涼しい風が出てきたわ」「空気は確かに冷えるのですけれど、気密性はゼロに近いような造りの建物ですから、冷やす端から外へ逃げていきます」　間取りを見たいと言う恵子に、川島はぜんたいを案内した。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "このときはたしか僕達のやつてゐた「青空」が出たか出かけのときで、隨分以前の話である。",
              "citation": {
                "source": "淺見淵君に就いて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ケリムは、最初六ぴきはたしかにゐると言つた手まへ上、そのまゝ引つこんでしまふわけにはいきません。",
              "citation": {
                "source": "蛇つかひ",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私の受けた苦痛は、そのときはたしかに実際に埋葬された苦痛とまったく同じものであった。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一時前に私が出るときはたしかにみさをは生きていました。",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつきはたしかに空腹でもあつた。",
              "citation": {
                "source": "黄昏の堤",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはさつきはたしかずつと自分の部屋にいたといわれたようでしたが」「そうでございます。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴァッヘルの如きはたしかに殺人狂の一人であろう。",
              "citation": {
                "source": "殺人狂の話",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠色の襟卷きはたしか五圓足らずでずつと以前に長野の洋品店で買つたものだつたが、あの頃は何でも安かつた……。",
              "citation": {
                "source": "雨",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしてわが国の浄土宗は、もし美術史家のいうごとくに日本美術に影響を与えたものとすれば、美術以外文学の方面にも、相当な影響のあって然るべきはずで、実隆の文学のごときはたしかにその実例を示すものであろう。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            }
          ]
        }
