        "examples": {
          "standard": [
            {
              "text": "新聞の求人広告を見て、応募する会社をいくつか選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ウェブサイトに掲載された求人広告には、具体的な業務内容が詳しく書かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "魅力的な求人広告を出すことで、優秀な人材が集まりやすくなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして求人広告に応募して手紙を出したくてもその切手もまた切手を貼る封筒もなくなってしまったんです。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「求人広告を出したら、やって来たんです。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりあえず出版社に入ればライターになる段取りが見えるだろうと考え、求人広告を見つけては履歴書を送りました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌年のはじめには、再びインドへ行くための費用を稼ごうと、コンピューターゲームで急成長していたアタリ社の求人広告に応募した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "急成長を遂げていた化粧品会社、ノエビアの求人広告を見た藤井は、染み付いてきた大阪ローカルのにおいを洗い落とそうかとしゃれて、履歴書を送ってみた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お望みは……」　牛太郎のような番頭にきかれて、まず私はかたずを呑んで、商品のような求人広告のビラを見上げた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学生だった彼は、アルバイトのついでに本が読めるのをたのしみに、「好文社」の求人広告をみて入った。",
              "citation": {
                "source": "十三年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
