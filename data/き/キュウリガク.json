        "examples": {
          "standard": [
            {
              "text": "江戸後期には、オランダから伝わった窮理学が盛んに学ばれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "福沢諭吉は、西洋の窮理学を日本に紹介した一人である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "当時の知識人たちは、蘭書を通じて窮理学の知識を吸収した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "これらへはまず翻訳書を教え、地理・歴史・窮理学・脩心学・経済学・法律学これらの順序をおい原書を翻訳せざるべからず。",
              "citation": {
                "source": "学校の説",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五、窮理学　窮理学とて、理窟ばかり論じ、押えどころなき学問にはあらず。",
              "citation": {
                "source": "学校の説",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、前条の外に、化学、天文学等、種々の科目あれども、窮理学の中に属するものなれば別に掲げず。",
              "citation": {
                "source": "学校の説",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃物理のことを窮理学といっていた。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第一部　牧野富太郎自叙伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "その学科の中には窮理学（今の物理学）、地理学、天文学、経済学、人身生理学、西洋算術などがあった。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第二部　混混録",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
