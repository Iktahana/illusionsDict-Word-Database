[
  {
    "uuid": "fc3308f3-e800-5099-91aa-a3fde35bc6a6",
    "entry": "器楽",
    "reading": {
      "primary": "きがく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "instrumental music",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "中学校の器楽クラブでは、バイオリンやチェロなどの楽器を通じてアンサンブルの奥深さを学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "今回の音楽祭では、合唱の他に本格的な器楽演奏のプログラムも多数用意されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は歌うことよりも、フルートやクラリネットといった器楽の繊細な音色に強く惹かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "バロック時代から古典派にかけて、器楽は宮廷文化の中で独自の発展を遂げていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "リズムについていえば、伴奏器楽がリズムを明示し、唄はそれによってリズム性を保有するのであるが、わが国の音楽では多くの場合において唄のリズムと伴奏器楽のリズムとが一致せず、両者間に多少の変位が存在するのである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の民衆音楽中でも、歌詞を主としない、純粋な器楽に近いものとしての三曲のごときも、その表現せんとするものがしばしば自然界の音であり、また楽器の妙音を形容するために自然の物音がしばしば比較に用いられる。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……私はあらゆるものから学んだ、ヴァイオリニストからも、唱歌者からも、器楽者からも。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」鼓器楽手、「わたしは知ってますがね、どうも鼓器だけぢゃ仕方ないでせう。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」鼓器楽手「リヅムといってたゞかうですよ。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてかの地で聞く機会の多いオペラのアリアや各種器楽のレコードを集めて、それを研究し修練してわびしいひとり居の下宿生活を慰めていた。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると十二時頃まで、奇妙な支那の歌声や、器楽の音なぞが、チイチイガアガア鳴り響くのであったが、それに気が付くたんびに村の人々は顔を見合わせた。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "白日の光の水脈に、わが恋の器楽の海に。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "新人の悲哀は古い詠嘆の絃にのぼせて象徴の世界を観照すべくあまりに複雑であり深刻であり而かも而かも傷ましいほど痛烈である、わが友よ、古い器楽の悲哀を知れ。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってその専門とする器楽の演出の、能のリズムに対するタッチが必然的に洗練され、且つ高められて来た事は云うまでもない。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁や中将も出て来て高欄に背中を押しつけながらまた熱心に器楽の合奏を始めた。",
              "citation": {
                "source": "源氏物語",
                "author": "花宴",
                "note": "青空文庫"
              }
            },
            {
              "text": "階段の所に声のよい若い殿上人たちの集められたのが、器楽のあとを歌曲に受け、「青柳」の歌われたころはもう塒に帰っていた鶯も驚くほど派手なものになった。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代の人はあまり琴の器楽を好まなくなって、弾き手も少なくなったためか、珍しく身にしむように思って、中将は相手の絃の音を聞いた。",
              "citation": {
                "source": "源氏物語",
                "author": "手習",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前よりも一層詩的な歌曲、詩的な歌劇、一層詩的な器楽（その中には標題または次第書に掲げた特殊の事件や概念的に確定された複雑な情緒を描出する標題音楽も多く含まれている）が作られたのである。",
              "citation": {
                "source": "総説　西洋音楽史の時代",
                "author": "乙骨三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この期に現われた「印象派」は同じく『標題』ある器楽を書くにしても、精細に概念的に確定された特殊の事件や複雑な情緒の描写などを好まず、外界の刺激によって生じた刹那の印象や、瞬間的に移って行く夢幻的な気分を表わそうと努めたのである。",
              "citation": {
                "source": "総説　西洋音楽史の時代",
                "author": "乙骨三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、それは、きん坊とあんぽんたんだけで、あとの人は普通に、器楽の方を主にして教えはしたが、二人の子供は歌の方が三日、琴の方は一日で自分から弾けてしまった。",
              "citation": {
                "source": "神田附木店",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて演劇は綜合芸術であるが、殊に組踊りはおぺらの様なもので、沖縄の演劇・舞踊・歌謡・器楽の類を全部とり込んでゐるので、それが幾組か連続的に行はれるのである。",
              "citation": {
                "source": "組踊りの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "役者の身振りや表情などでは、こちらへ影響するものがあるまいけれども、器楽や舞踊には、必、影響するところ多からうと考へるのである。",
              "citation": {
                "source": "組踊りの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "両方ともに、舞を持つて居るが、雅楽は器楽が主で、大歌は声楽が大部分である。",
              "citation": {
                "source": "万葉集のなり立ち",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中には、千秋万歳系統のほかひの芸は勿論、神楽の才の男の態、呪師・田楽側の奇術や、器楽もあれば、狂言があり、散楽伝来の演劇がゝつたものもあり、同じ筋の軽業の類もある。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、後はなにがなんだか、破れかえるような騒ぎで、合唱も器楽も揉み消されてしまった。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "器楽の演奏を聴けば、そのことがもっとはっきりわかる筈です。",
              "citation": {
                "source": "あるニュウ・フェイスへの手紙",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝塚少女歌劇養成会の教育方法は、すべて東京音楽学校の規則にのっとり、入学資格だけは小学校修業十五歳以下の少女にかぎり、修業年限を三年とし、その間に器楽、唱歌、和洋舞踊、歌劇を教授するものであって、我が国でもはじめての試みであった。",
              "citation": {
                "source": "宝塚生い立ちの記",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "水泳場の仮舞台で初公演　さきに募集した第一、二期生達は、舞台に必要な基本的演技、すなわち声楽、器楽、和洋舞踊、その他全般にわたって約九ヶ月の間熱心に養成された。",
              "citation": {
                "source": "宝塚生い立ちの記",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし日本に器楽が発達したならば、踊りはそれと結びついたであろう。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、すずしい風がでてきたので、一ぴきがくしゃめをしてめをさましました。",
              "citation": {
                "source": "あし",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ふにこの苗は、いつかは私どものくらい心に生生とした芽を生やすときがくるであらう。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊びにはおのずから遊びの終わるときがくるものだが、最後にツルと林太郎とふたりで花をかくし私がひとりおにになった。",
              "citation": {
                "source": "花をうめる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからしてこれはモウじきに出版するときがくるだろうと思って待っておった。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "民主主義の潮流に逆行する現在のファッショ的存在は、全世界の民主主義を愛する人により徹底的に糺弾され断罪されるときがくるだろうということを私はいいたい。",
              "citation": {
                "source": "それに偽りがないならば",
                "author": "――憲法の規定により国民の名において裁判する――鈴木裁判長",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
