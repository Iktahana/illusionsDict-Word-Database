        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "脳梗塞の後遺症として、記憶障害などの器質性精神障害が残ることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "腹痛を訴えていたが、検査の結果、潰瘍などの器質性の異常は見つからなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "器質性の不眠は、身体的な病気や薬の影響によって引き起こされる場合が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "医師は「器質性の疾患は否定されました」と告げ、心因性の可能性を示唆した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ライトビールの導入は酔っ払いを減らしただけではなく、肝臓、胃、心臓、動脈の器質性疾患を減少させた。",
              "citation": {
                "source": "簡約医学史",
                "author": "A Concise History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "器質性の病気では実際のところ役に立たない。",
              "citation": {
                "source": "簡約医学史",
                "author": "A Concise History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒステリー性の個人ははっきりとした器質性の障害が無いのに突然に耳が聞こえなくなったり目が見えなくなったり足が不自由になったりして不愉快な現実を避けている。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし器質性疾患が暗示によって治ることも否定できない。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗示その他の心理療法によって神経性の病気だけでなくある種の器質性の病気も治らないまでも好転することを現代における経験が示した。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
