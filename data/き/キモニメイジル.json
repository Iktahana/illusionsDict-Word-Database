        "examples": {
          "standard": [
            {
              "text": "先生の「努力は決して裏切らない」という言葉は、私の肝に銘じている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今回の失敗を肝に銘じて、二度と同じ過ちを繰り返さないようにしようと心に誓った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "先輩からの厳しい忠告を肝に銘じ、今後の行動に活かしていくつもりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの時の屈辱を肝に銘じ、いつか必ずリベンジを果たすと決めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "こんなにはっきり肝に銘じるところ、やっぱり昔あれだけひどく患ったききめなり。",
              "citation": {
                "source": "日記",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            }
          ]
        }
