[
  {
    "uuid": "69cec3bd-f406-5c18-b81e-9b126174c41c",
    "entry": "驚嘆",
    "reading": {
      "primary": "きょうたん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
