    "definitions": [
      {
        "index": 1,
        "gloss": "air supply port",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "エアコンの給気口から冷たい風が吹き出してくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "部屋の給気口が埃で詰まっていて、空気がこもっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新築の家では、各部屋に適切な位置に給気口が設置されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼の部屋の空気は外から間断なく取り込まれ、フィルターで漉されたのち熱交換装置をとおり、間取りのなかのさまざまな部分の給気口から流れ出ていた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして給気口とは別に吸気口があり、そこからは間取りのなかの空気がくみ出されては、常に建物の外へ吐き出されていた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
