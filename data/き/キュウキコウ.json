        "examples": {
          "standard": [
            {
              "text": "車のボンネットにある吸気口は、エンジンの冷却に役立つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "掃除機の吸気口にゴミが詰まって、吸引力が落ちた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "潜水艦の吸気口は、緊急時には自動で閉鎖される設計だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
