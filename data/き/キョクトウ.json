[
  {
    "uuid": "0a832945-c5f5-5590-ab13-10e21d94b206",
    "entry": "極東",
    "reading": {
      "primary": "きょくとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
