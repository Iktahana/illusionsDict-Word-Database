          "literary": [
            {
              "text": "光線が絹ごしされているみたい」　と私は、はしゃいで言った。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇のいろはおのづから濃くなつたけれども、西方の空には、まだ淡黄の光を再び絹ごしにしたやうないろが、澄み切つた蒼い空のいろにまじつて残つてゐる。",
              "citation": {
                "source": "接吻",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆腐のごときは殊に舌ざわりが大切だから、生で食う時には絹ごしがいいが、煮て食う場合には、むしろ普通の豆腐がいい。",
              "citation": {
                "source": "美味放談",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
