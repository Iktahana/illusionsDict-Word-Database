        "examples": {
          "standard": [
            {
              "text": "政府は、経済危機突破のために新たな対策を発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このプロジェクトの成功は、まさに危機突破の証だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "被災地への迅速な支援は、危機突破の第一歩となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "チーム一丸となって、この難局を乗り越え、危機突破を目指そう！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "去年から度々危機突破資金をとっても、決してそれは、気ちがいじみた物価に追いつかない苦しさで、骨身にしみてわかっています。",
              "citation": {
                "source": "メーデーと婦人の生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこういう見方が、現在の国情の一側面を幾分でも表しているものであったならば、危機突破策の一要素は極めて明かである。",
              "citation": {
                "source": "硝子を破る者",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
