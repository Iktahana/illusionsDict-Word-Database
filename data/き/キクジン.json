        "examples": {
          "standard": [
            {
              "text": "「この反物、光の当たり方で麹塵に見えたり青みがかって見えたり、本当に不思議な色だね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "麹塵色の着物に身を包んだ彼女は、落ち着いた大人の上品な色香を漂わせていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "平安時代から愛されてきた麹塵は、植物の生命力を感じさせる深みのある緑色だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
