        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この人は年はまだ二十四であったが、なかなかの利け者で、商売上の掛け引き万端、それはきびきびしたものであった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "店初まっての大作をしたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "政界と財界の利け者達が、數珠つなぎになつた事件が起り、笹沼氏の名もそのなかにあつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "保護者といふのは、その頃の社交界に利け者のサウザンプトン伯爵だつた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "利け者だった祖父の名を取って付けたのである。",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮎の産地のことなどには、あまり関心を持たない――ほんとうは、知っているべき筈なのだが――大日本料理人組合連合会の三宅孤軒君も、一昨年越後からの帰りに後閑で、キネマ界の利け者野中康弘君の友釣りでとった鮎をご馳走になって、その味と香気と肉の舌離れのあざやかさに驚いたのであった。",
              "citation": {
                "source": "水と骨",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達の級の利け者であった近松という男生徒が、加藤清正と木山弾正と組討して、崖から落ちている場面の絵を描いて、皆に見せびらした。",
              "citation": {
                "source": "戦争雑記",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "「平次か、御苦労であったな」　若いが南北町奉行四十六騎の与力の中でも、第一番の利け者といわれた笹野新三郎は、緊張しきったうちにも、愛想よく平次を迎えました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も主人の島五六郎は、大奧の利け者で、祿高三百石、役高五百石、合せて八百石に過ぎませんが、權勢は遙かに數千石取の大身を凌駕し、用人風情の川前市助までが、同行の御家人、少々人間が甘さうではあるが、五十石取の千本金之丞を頤で使ひまくりさうにするのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美女罪あり",
                "note": "青空文庫"
              }
            },
            {
              "text": "金座の御金改役後藤庄三郎の片腕と言はれた利け者で、元は吹屋町で手前吹をして居りましたが、後、御藤庄三郎の配下になつて、その辣腕を勘定奉行に認められて居たのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "和蘭カルタ",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙波興業株式会社の若い取締役で、利け者と評判を取った男ですが、打ち見たところは、思想家などによくある、少しばかり皮肉な感じのする、聰明そうな好い男です。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第七夜　歓楽の夢魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あっ、旦那、こんなところへ」「いや、お祭の様子を見に来ると、なにか騒ぎがあると言う話を聞いたが、どうしたのだ、一体」　それは、平次のためには、大事の上役で、その頃｜吟味与力の利け者、笹野新三郎だったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "赤い紐",
                "note": "青空文庫"
              }
            },
            {
              "text": "吟味与力で、南の利け者、笹野新三郎の前へ出ると、例の十五両包を出して一伍一什を報告したものです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "八人芸の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "金座の御金改役後藤庄三郎の片腕と言われた利け者で、元は吹屋町の手前吹をしておりましたが、後、後藤庄三郎の配下になって、その辣腕を勘定奉行に認められていたのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "和蘭カルタ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この警戒陣の本部は、同じ池の端のそばや田毎に置いて、同心中の利け者、伊藤治太夫が全体への号令を掛けました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "猿回し",
                "note": "青空文庫"
              }
            },
            {
              "text": "中年者の分別を何処か置き忘れたような、上品な邪念の無い顔を見ると、これが老中筆頭の利け者で、日本国中を顧上らせた、天保改革の主とはどうしても思えません。",
              "citation": {
                "source": "礫心中",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何に利け者のＳ大尉が聯隊本部に頑張つてゐたからとて、自分の成績が抜群であり、自分の教育する部下が優良兵であり、模範兵となつたならばどうにもなりはしないだらう。",
              "citation": {
                "source": "怒れる高村軍曹",
                "author": "新井紀一",
                "note": "青空文庫"
              }
            },
            {
              "text": "升蔵は当時名題下の利け者、踊にかけては立者も及ばぬ腕前であった。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小兵者ながら、なかなか利け者。",
              "citation": {
                "source": "上杉謙信",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く　兄達は胡桃を食らふ塗籠の小さきけものの類に君呼ぶ沙川の大方しみて海に出づ外へ流るる我が涙ほど　遠浅の沙浜を歩いてゐると川の水の大部分は沙にしみ込みその末が僅に海に落ちるのを渡ることがよくある。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "王さまは、一ぴきけものをみつけて、むちゅうで追って行きました。",
              "citation": {
                "source": "六羽の白鳥",
                "author": "グリム兄弟　Bruder Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "この憎むべきけもの（無理にもそれをけものと云えるとすれば）が、いろいろこうした恐ろしいことをやっている最中に、ちょうどビレラフォンが、その国の王様を訪ねてやって来ました。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
