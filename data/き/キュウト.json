  {
    "uuid": "24bb1f9d-649b-590c-b473-bf7894f26ca2",
    "entry": "旧図",
    "reading": {
      "primary": "きゅうと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
