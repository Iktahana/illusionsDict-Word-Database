[
  {
    "uuid": "b2ca6c4b-973f-54e4-998c-8e1535e7faa4",
    "entry": "却下",
    "reading": {
      "primary": "きゃっか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rejection",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "が審理の結果、同会社の煙突から出る煤煙は十分な設備によって清められたものであって、そんなに害毒を生ずるような悪い煙でないという事になり、この訴訟は却下になったそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもそれが却下されそうな形勢にあるということも、銀子は倉持から聞いていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもこの臆説は不幸にしてたちまち却下された。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はここでついでに言うが、法廷が証拠にならないものとして却下するもののなかには、知者にとって最上の証拠になるものがずいぶんたくさんある。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "以後、強訴するに於ては、屹度曲事たるべし』とて、願書を却下したるは、實に以外也。",
              "citation": {
                "source": "宗吾靈堂",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "兇行に関しては雄太郎君と郵便屋との二人の目撃者があったし、死因が単純明瞭で一目刺殺である事は疑いない事実と判定された為め、女の死体は間もなく却下になった。",
              "citation": {
                "source": "石塀幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初弁護士の話では、裁判所側はリヨンの方やその他いろんな方面を取調べなければならんので、公判までにはまだ一、二カ月かかるだろうということだったが、予審の日に弁護士が保釈を請求して、いろいろ判事と懇談の末、保釈は却下されることとなってその代りすぐ公判を開くことに話がついた。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十年ごろ、美術学校や早大慶大が女子本科生入学許可の方針をきめたが、それは却下された。",
              "citation": {
                "source": "女性の歴史の七十四年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、圧制者であるウィルヘルム二世は、労働者である織匠たちの生活の辛苦と、そこから解放を求めた闘いを題材とするこの全く新しい版画集に、賞を与える決議を却下した。",
              "citation": {
                "source": "ケーテ・コルヴィッツの画業",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "願書は人数が定まっているからと云うので、そのまま却下せられた。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい素子としてのトランジスターの実用性確認と、大容量の磁気コアメモリーのテストを公式な提案理由としてかかげたＴＸ―１プロジェクトを、研究所の上層部は却下した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＢＭのエンジニアは、最下位機種を八ビットのチップを使って作ろうとして悪戦苦闘した経験を持っており、二度と悪夢を体験しようなどと思ってはいなかった、というサムズの主張を入れて、著者はマイクロソフト側の主張を却下した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体型のプランは却下されたが、処理速度と信頼性を高め、小型化を徹底するという狙いからＡＳＩＣを積極的に活用するという松本の提案は生き残った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ一人の弁護士がその女の良人が在廷してゐるから呼び出していろいろ家庭の事情などを調べて欲しいと云ふ申請がありましたが勿論この申請は却下されました。",
              "citation": {
                "source": "ある女の裁判",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私はその却下を当然だと思ひました。",
              "citation": {
                "source": "ある女の裁判",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "裁判長は合議の末頭蓋骨の鑑定、調書の取寄せ、神戸牧師以下八名の証人の喚問等を許可し、他は却下して閉廷した。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十三年の劈頭一月七日、先年押詰って出した保釈願に対する却下書が配布された。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右申請中庄司利喜太郎、戸塚新蔵を証人として訊問し其余は却下す。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "主文本件忌避の申立は之を却下す。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大団円　支倉が最後の手段として試みた忌避の申立は見事に却下されて、即日その決定書が送達されたが、支倉は果してどう云う態度に出たであろうか。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が大正十一年の七月に最後の大審院で元右衞門の請求は却下否決された。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "所がツネの方から更に之を大審院に持出して、大正十一年の七月に大審院では今度は前判決をひつくり返して、元右衞門の請求は却下するといふことになり、つまりツネは廢嫡されないと云ふ判決を下しました。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔五〕月初旬に大審院上告が却下された。",
              "citation": {
                "source": "年譜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮から、病状鑑定の申請したが、その必要を認めず、と却下。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "不穏当を理由として却下されること四度、修正には女王も意見を出すといふ念入りな段取りを経て、やつと上演許可になつた。",
              "citation": {
                "source": "演劇と政治",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の請願が遂に却下されたと云ふやうなことを新聞で見ましたが、詰り爾う云ふ運動をすると云ふことも孔教を一つの宗教として觀る所から出て居るのであります。",
              "citation": {
                "source": "支那人心の新傾向",
                "author": "狩野直喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の友人の死体が見つかった時刻には、私がオークニー諸島に居たことが証明されたので、大陪審（十二名ないし二十三名から成り、小陪審の手に移る前に告訴状の審査をするもの―訳註）がこの告訴を却下し、この町へ来てから二週間後には、私は監獄から釈放された。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "この正己が山林事件に関係し始めたのは、第二回目の人民の請願も「書面の趣、聞き届けがたく候事」として、山林局木曾出張所から却下されたと聞いた明治十四年七月のころからである。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "早稻田の藤井（新一・米国憲法学者）という人の学位請求は、却下されたそうだ。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
