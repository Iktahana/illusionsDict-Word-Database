    },
    "definitions": [
      {
        "index": 1,
        "gloss": "church history",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大学のゼミで、初期キリスト教の教会史について発表する予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この古い本には、中世ヨーロッパの教会史における重要な出来事が詳細に記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "教皇庁の歴史学者は、最新の資料に基づいて教会史の再検討を始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、日本におけるキリスト教伝来とその後の教会史に特に興味を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "聖ビーダは「イギリス教会史」にヴォルティガーは困ってサクソンの首長であるヘンギストとホルサを尋ねて援助を要請したと書いている。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "（c）教会史は、暴君が良心に対してたくらんださまざまな凌辱に対して死をもって自らをまもった信心の篤い婦人たちの、そういう実例を数多く尊げにかかげている。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
