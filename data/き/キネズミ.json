          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "公園の木に木鼠がちょこまかと登っていくのが見えて、思わず足を止めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冬眠前の木鼠が、せっせと木の実を地面に埋めている姿は微笑ましい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あ、見て！木鼠がしっぽをフワフワさせてる！」と子供が指差してはしゃいでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "森の奥深く、木の洞からひょっこり顔を出した木鼠がいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "訓導宮沢賢治早くもひとり雪をけりはるかの吹雪をはせ行くは木鼠捕りの悦治なり三人ひとしくはせたちて多吉ぞわらひ軋るとき寅は溜りに倒れゐし赤き毛布にくるまりて風くるごとに足小刻むは十にたらざる児らなれや吹雪きたればあとなる児急ぎて前にすがりつゝ一列遠くうすれ行く",
              "citation": {
                "source": "訓導",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木鼠が鑛物的な音を立てゝ大きな樹幹を縱横に駈け※つてゐる。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの峠には、木鼠胴六といって、名高い石川五右衛門の一の子分が山賊となって、山塞にとじこもり、旅人を見れば、剥ぎ取って、殺してしまいます」「何ッ！",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざ尋常に……」と、例によって、奇妙な名乗りをあげながら、木鼠胴六の山塞へ、樊※の如き恰好で乱入して行った。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗と脂がアバタの穴についたその寝顔は、いかにも醜悪であったから、木鼠胴六は、「何てきたねえアバタ面だ」　と、ペッペッと唾を吐き散らし、わざとらしく嘔吐を催した振りをしながら、佐助の懐中をさぐったが、鐚一文も出て来なかったので、呆れかえってしまった。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何刻かの後、楓は木鼠胴六の前で知っているだけの舞いを、全部舞っていた。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、彼は初めて白洲に引きすえられていた盗賊の木鼠長吉を見たのである。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、仲間で木鼠ともむささびとも仇名をとっていた。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、隠徳の相と盗心の相とは、両立するものと見え、木鼠長吉は、改心しなかった。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "越前は、木鼠長吉を再び笞刑に処した。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　四十雀、蛙、カナリヤ、梟、山鳩、木鼠、虻やら、甲虫、蚊など、どれも得意の話ぶりでしたが、おしやべり上手の野牛には、どうしてもかなひません。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉助氏咳して、目覚めておる様子なれば、問いて見たるに、木鼠なりといえり。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "その多くの汚い眼の中に、壁の際の、そこには、木鼠の生皮が竹釘で打付けてある、その上部の穴からして、ジッとこちらを凝視している一つの眼。",
              "citation": {
                "source": "壁の眼の怪",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "実悪・花車形而も同時に璃寛は、早瀬伊織・桜丸・梅王・神谷｜転・放駒長吉・木鼠忠五郎など、魁車の役どころでもあり、亦彼の将来をも示してもゐる様な芸境を見せた。",
              "citation": {
                "source": "街衢の戦死者",
                "author": "――中村魁車を誄す――",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二の精霊　アポロー殿が上機嫌になりゃ私共までいや、世の中のすべてのものが上機嫌じゃがその中にたった一つ嬉しがりもせず笑いもせなんだものがあると気がるなあの木鼠奴が通りすがりの木の枝からわしに声をかけおった。",
              "citation": {
                "source": "葦笛（一幕）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "休んで木を見あげると、木鼠がガサガサと木を登って遊んでいた。",
              "citation": {
                "source": "春の上河内へ",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず彼女は、白繻子の訪問服の上から木鼠の毛皮外套を着て、そして、スキイを履いた。",
              "citation": {
                "source": "踊る地平線",
                "author": "白い謝肉祭",
                "note": "青空文庫"
              }
            },
            {
              "text": "動物園に行くと沢山飼ってあるあの縞栗鼠、私はそれを単に木鼠だと思っておりましたが、それが沢山おりました。",
              "citation": {
                "source": "木曾御岳の話",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを木鼠がさかんに上ったり下ったりしている。",
              "citation": {
                "source": "木曾御岳の話",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだものの方は、普通は木鼠であるが、昨日の朝などは、突然、野兎が一匹、ひょっくり顔を出して、小鳥たちの仲間に入って、パン屑を拾い出したのには、一寸驚いた。",
              "citation": {
                "source": "シカゴの雉子",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その点については、公園内の木鼠や雀の例で、既によく言われているとおりである。",
              "citation": {
                "source": "シカゴの雉子",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この森の感じを一層強めるものは、木鼠と小鳥たちである。",
              "citation": {
                "source": "ウィネッカの秋",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木鼠は、多分原始林時代から居残ったものであろうが、もうすっかり人間に馴れて、餌をやると、つい目と鼻のところまでやってくる。",
              "citation": {
                "source": "ウィネッカの秋",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝少し早めに家を出た時などは、鋪装道路の両側に並び立っている立木の根本に、木鼠がとんきょうな顔をして控えているのによく会う。",
              "citation": {
                "source": "ウィネッカの秋",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車が走っている鋪装道路の上を、木鼠が長い尾をひきながら、ちょこちょこと走っている景色は、映画で見るアメリカ風景とは大分ちがっているが、これもまたアメリカなのである。",
              "citation": {
                "source": "ウィネッカの秋",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわてたのは承知の由公で、剣の下を木鼠のように走り廻り、「親分、こうわけの解らねえ斬り合いも、めったにござんせんぜ。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "木鼠小僧はやはり許してもらいたいのである。",
              "citation": {
                "source": "銭形平次打明け話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕物小説はこうして生れ、こうして発達した、捕物小説の世界では、偽善者は深酷に罰せられるが、木鼠小僧は大手を振ってのさばり返っている。",
              "citation": {
                "source": "銭形平次打明け話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠小僧もそれであり、木鼠小僧のように、人名辞書にまで何ぺージか費やされているものもある。",
              "citation": {
                "source": "江戸の昔を偲ぶ",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
