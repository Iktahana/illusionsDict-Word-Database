        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれども俄かにカムパネルラのお父さんがきっぱり云ひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「久」と「具」とは、きっぱり二つに分れず、或る場合は一つにしたと見なければならぬことになります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし「月」のキには「伎」「企」「枳」などは用いず、「雪」のキには「紀」「奇」などは用いないというように、きっぱり二つの類に分れている。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹が「お帰り下さいまし」ときっぱり断わる。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は『松葉屋』や『庄屋』がその同類として引き込みに手を廻して来るのを、きっぱりとはねつけた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、山崎はきっぱり云った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が決して欲しなかったこの戦争が来ると――君の国や名は問う要がない――君をしかと握っていた怖しい運命は、きっぱりその仮面を脱ぎ捨てゝ、喧嘩好きな複雑な正体を現わしたのだ。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども俄かにカムパネルラのお父さんがきっぱり云いました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」にこりともせず、きっぱり頭を横に振った。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、わるい人であろうか、それを、きっぱり否定できるほど私には自信が無かった。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は力を感じたので、その二匹の馬が私をすぐ身近に放置してきっぱりと問題外にしている無礼に対し、不満を覚える余裕さえなかった。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "松吉は目をひらくと、きっぱり、「もどろう、そろそろいこう。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもにわかにカムパネルラのお父さんがきっぱり言いました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "可いよ、明日母上が来たら私がきっぱりお謝絶するから。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "母があれはおぬいではありませんときっぱり人々にいっていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ困るな、そうまじめに出られちゃ……あなたは今の話で涙が出るといいましたが、……あなたにもそんな経験があったんですか」「いいえ」　おぬいはここぞと思って、きっぱりと答えた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即座に、「いいえ」　と答えた彼女の答えは、少しの隠しだてもなく、きっぱりとしたものだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "慧鶴は普通な人情よりこういう超人性を帯びた片輪な性情については生れ付きの察しと同情を持っていて、それが随分自分に不利益を持ち来すこともあるので、振切ろうと歯噛みはするがどうにもきっぱり振り切れなかった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と女の兄は、いつものおだやかな顔に凜々しい色を見せてきっぱり言った。",
              "citation": {
                "source": "窓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、眉を開いてきっぱりという。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして殊にあやしいことは小屋がきっぱりうしろの崖にくっついて建ててあっておまけにその崖が柔らかな岩をわざと切り崩したものらしかった。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど緋縮緬のと並んでいた、そのつれかとも思われる、大島の羽織を着た、丸髷の、脊の高い、面長な、目鼻立のきっぱりした顔を見ると、宗吉は、あっと思った。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方を抱いて、ちゃんと起きて、居直って、あいそづかしをきっぱり言って、夜中に直ぐに飛出して、溜飲を下げてやろうと思ったけれど……どんな発機で、自棄腹の、あの人たちの乱暴に、貴方に怪我でもさせた日にゃ、取返しがつかないから、といま胸に手を置いて、分別をしたんですよ。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう人が何と言いましょうと、旦那さんのお言ばかりで、どんなに、あの人から責められましても私はきっぱりと、心中なんか厭だと言います。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とお澄がきっぱり言った。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "中肉で、脚のすらりと、小股のしまった、瓜ざね顔で、鼻筋の通った、目の大い、無口で、それで、ものいいのきっぱりした、少し言葉尻の上る、声に歯ぎれの嶮のある、しかし、気の優しい、私より四つ五つ年上で――ただうつくしいというより仇っぽい婦人だったんです。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（――かなしいなあ――）　お雪さんは、その、きっぱりした響く声で。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　と、きっぱりと、投上げるように、ご新姐が返事をすると、（あああ、銭にはならずか――食おう。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
