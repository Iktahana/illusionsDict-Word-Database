    "definitions": [
      {
        "index": 1,
        "gloss": "parasite",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "釣り上げた魚に寄生虫がいて、ちょっと食べる気が失せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "飼っている犬が最近痩せてきたので、もしかしたら寄生虫がいるのかもしれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この植物は他の木に寄生虫のように絡みついて成長する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔のSF映画で、宇宙寄生虫が人間に乗り移る話があったな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その雌の体内で外套膜腔の中に奇妙な細長い虫のようなものが見出された事があるので、昔は一種の寄生虫だろうと考えられていた。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "長年猫を飼っているが、こんな寄生虫を見るのははじめてのことである。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はそんな人もないであろうが、しかしよく考えてみると、こうした気分は実を言うとあらゆる芸術批評家の腹の底のどこかにややもすると巣をくいたがる寄生虫のようなものである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は現代社会の堕落層に住む寄生虫である。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は一見仲よく暮らしているように見えながら、親子は親子で、夫婦は夫婦で相喰み、不潔物に発生する黴菌や寄生虫のように、女の血を吸ってあるく人種もあって、はかない人情で緩和され、繊弱い情緒で粉飾された平和の裡にも、生存の闘争はいつ止むべしとも見えないのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "冒険、神秘、怪奇、変態心理、等々々の名を冠らせ得る小説は、探偵小説界の外道、寄生虫でしか在り得ない。",
              "citation": {
                "source": "探偵小説の真使命",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "専門教育をお受けになったくせに、よくこんな寄生虫的な生活がお出来になるのですね。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "猴が躁ぐと馬用心して気が張る故健やかだと聞いたが、馬の毛中の寄生虫を捫る等の益もあらんか。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の文人は最早社会の寄生虫では無い、食客では無い、幇間では無い。",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦令石橋を叩いて理窟を拈る頑固党が言の如く、文学者を以て放埓遊惰怠慢痴呆社会の穀潰し太平の寄生虫となすも、兎に角文学者が天下の最幸最福なる者たるに少しも差閊なし。",
              "citation": {
                "source": "為文学者経",
                "author": "三文字屋金平",
                "note": "青空文庫"
              }
            },
            {
              "text": "君達は、あのフィラリヤって言う寄生虫のために淋巴管が閉塞がれて、淋巴の欝積を来した場合だとか、或は又、一寸した傷口から連鎖状球菌の浸入に依って、浮腫性の病後に続発的に現れる象皮病――って奴を知ってるかい？",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "生き残った人間と、わずかの家畜と寄生虫とだけが地底にもぐりこんで種を全うした。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどこれは寄生虫でないから害はない。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はもう、実際人として尊敬するには塵ほどの価値もないような女が、只、風俗を利用し、婦人を冷遇する男子は、紳士として扱われないと云う異性の弱点につけ込んで、放縦な、贅沢な寄生虫となっている厭わしさを見抜いています。",
              "citation": {
                "source": "男女交際より家庭生活へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "魂を激しい愛――愛と云うものを理解した愛――でインスパイアしてくれるどころか、只怠いくつな寄生虫となって、無表情の顔を永遠の墓場まで並べて行かなければならない――。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来秋の野良仕事はまことにいそがしい、その間をぶらつく私は恥づかしかつた、私はまつたく不生産的人間だ、社会の寄生虫だ！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "脳のなかに寄生虫が一杯ゐたわけなのです」　ふと私は自分の脳に何か暗い影が横切るやうな気持だつたが、恰度そこへＳが帰つて来た。",
              "citation": {
                "source": "二つの死",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロバーツはこれを拒否し、彼らを寄生虫と罵った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が水や日光について心配したり、寄生虫を相手に争ったり、霜を恐れたり、芽の出ようがおそい時は心配し、葉に光沢が出て来ると有頂天になって喜ぶ様子をうかがっているのは楽しいものである。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "全日本人の生活の一表現である政治を党人と称する彼ら少数の階級の利福の具に供して暴横邪曲を恥とせぬ国民の寄生虫であると思っている。",
              "citation": {
                "source": "鏡心灯語　抄",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手が誰であろうと、たとえ、金肥りの社会的寄生虫であろうと、利益の尻尾にくいこむダニであろうと……これは島村さんの言葉だが……何だっていいじゃないですか。",
              "citation": {
                "source": "別れの辞",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「南京虫其他寄生虫の無之事を証明候也」という珍妙なもので、某アパートの主人の名前に捺印がしてあった。",
              "citation": {
                "source": "浅間噴火口",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こういう食物は、寄生虫の伝説さえなければ、日本の文学者にも好かれそうだ。",
              "citation": {
                "source": "秦の憂愁",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "地所を売った封鎖の金を内密に現金に代えたり、野崎さんに物乞いをしたり、謂わば寄生虫みたいな生活ではないか。",
              "citation": {
                "source": "波多野邸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつぞや、あなたは、田島章吾さんのことを、社会の寄生虫とか蛆虫とか仰言いましたけれど、それも、言葉通りにお考えなすっているのではございますまい。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう騒ぎのあとで、猫は虫下しの薬をのみ、寄生虫が果して出たかどうかは分らないが、まもなく回復した。",
              "citation": {
                "source": "蔵の二階",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "何物をも生産することなしに、他人の懐を当にして生活する寄生虫の文化である。",
              "citation": {
                "source": "吾等の使命",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚の生肉には例の寄生虫が沢山いる。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
