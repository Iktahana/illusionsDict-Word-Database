        "examples": {
          "standard": [
            {
              "text": "新しいソフトウェアの使い方を学ぶために、まず教則本（きょうそくぼん）を熟読した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この教則本（きょうそくぼん）には、基本的な操縦方法が詳しく書かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "運転免許試験の合格には、この教則本（きょうそくぼん）の隅々まで理解することが不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "もっともだれに教わるのでもなく全くの独習で、ただ教則本のようなものを相手にして、ともかくも音を出すまねをしていたに過ぎなかった。",
              "citation": {
                "source": "二十四年前",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケーベルさんに笑われた九円のヴァイオリンは、とうの昔にこわれてしまったが、このごろ思い出してまた昔の教則本をさらっている。",
              "citation": {
                "source": "二十四年前",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、口惜しさのあまり座敷に転がつて、教則本を頼りに水泳の練習をしたり、庭先きの小さな池にタラヒを浮べて憧れを満足させた。",
              "citation": {
                "source": "秋晴れの日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちにはベビイ・オルガン一台あるきりで其で教則本をあげた。",
              "citation": {
                "source": "親子一体の教育法",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり、ベビイ・オルガンで教則本の三分の一ほどやったのであった。",
              "citation": {
                "source": "きのうときょう",
                "author": "――音楽が家庭にもたらすもの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューター関係の書籍を発行するダイマックス社という出版社を起こした彼は、ベーシックの教則本を作り、マシンに関する本を刊行するという条件でＤＥＣからＰＤＰ―８と端末を借り入れた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めて母上と行ったとき、あの部屋、教則本、ヴェートウヴェンのソナタ。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子に教則本を教えた婦人ピアニストはウィーンで自殺した。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのベビー・オルガンで伸子は教則本を習いはじめた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピアノのおいてある、そこで伸子が教則本をひきはじめた洋間に、手軽なベッドをおいて、川辺みさ子は、伸子がその部屋に入って行ったときは、うしろのカーテンをひいて、ほの暗くしたなかに横たわっていた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめベビーオルガンで教則本やっていてあとでピアノを買って貰った。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃は子供でも大人の教則本、それから練習用の『チェルニー』という本をつかいました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "教皇大使、ま、普通に言えば主任司祭様だけど、彼は二人がいつまでも教則本の聖なる法規を放っておいて、中身のない遊びの法規に熱中するようなら、彼等を破門にすると脅すの。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
