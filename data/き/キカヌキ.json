    },
    "definitions": [
      {
        "index": 1,
        "gloss": "unruly (e.g. of a child)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あの新人は、きかぬ気だが仕事はできる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女のきかぬ気な性格が、かえって魅力的に映ることもある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃はきかぬ気で、いつも親を困らせていたそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "きかぬ気で敏捷だった。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きかぬ気の宰八、紅の鋏を押立て、「お前様もまた、馬鹿だの、仁右衛門だの、坊様だの、人大勢の時に、よく今夜来さしった。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな宿にも盆栽の数鉢はある、鳳仙花、唐辛、蘭、万年草など、おしやべりの、きかぬ気の小娘の丹青だ、日本人はうれしいなと思ふ。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご承知のやうに、アルテミスは月の女神で、額には青白い三日月が輝き、さうして敏捷できかぬ気で、一口で言へばアポロンをそのまま女にしたやうな神である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポローニヤスの娘として、恥ずかしからぬ智慧も、きかぬ気もございます。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "維幾も常陸介、子息為憲もきかぬ気の若者、官権実力共に有る男だ。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "監物は藩主の一族で三万石の領地を受けて、藩の家老格に取扱われている者であったが、至って片意地の強いきかぬ気の男であったから、村役人の家の怪異なども別に気に懸けなかったが、それでも心の何処かに一点のしみを残していた。",
              "citation": {
                "source": "不動像の行方",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きかぬ気らしい張りのある眼や、唇元や、背の高い、つんとした貴族的な態度までが、路子の言葉を裏づけているような気さえした。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこのほうは前のきじ毛に比べると恐ろしく勇敢できかぬ気の子猫であった。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこのきかぬ気の勇敢な子猫に対して何かしら今までついぞ覚えなかった軽い親しみあるいは愛着のような心持ちを感じた。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人をくったような年増女の顔、すました女学生の顔、子供を負ったどっかにきかぬ気の見えるお媽さんのような顔ばかりで、彼の望んでいる顔は見当らなかった。",
              "citation": {
                "source": "女の首",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きかぬ気の彼は、必死の覚悟でその酒宴に連なった。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしいちばん末妹であり美しい若いきかぬ気の女神であったということには変りない。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだもいいし、話しっぷりもしっかりしているし、いかにもきかぬ気らしいところも見えた。",
              "citation": {
                "source": "続獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "前夜、久しぶりで晴ればれした顔で牀の上に起きなおって、「もう、大ぶんに快いから、きょうは一枚縫い上げるよ」　と、きかぬ気をみせて、絽縮緬の座敷着を手にとっていたが、片袖を縫いかけて、針をおいた。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその腰元の歩みぶりや、すべての挙止が、あまりにきかぬ気の貞奴まるだしであったのが物足りなかった。",
              "citation": {
                "source": "マダム貞奴",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこしでも家のものに余裕を与えたいと思うこころと、身をくだすせつなさをかくして、きかぬ気から、「好きだからなりたい」といって、きく人の心をいためない用心をしてまで身を金にかえようとしていた。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川時代、下町のきかぬ気の女が芸者になったわけだ。",
              "citation": {
                "source": "日記",
                "author": "一九二四年（大正十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "見とうない、見せておくれやすな」　婆さんは一人で、きかぬ気らしく頭振りを振りながら言い続けるのである。",
              "citation": {
                "source": "霜凍る宵",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "きかぬ気の爺さんで、死ぬるまで※に世話はかけぬと婆さんに云い云いしたが、果して何人の介抱も待たず立派に一人で往生した。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "両国の停車場で、彼等は古びた中折帽を阿弥陀にかぶった、咽喉に汚れた絹ハンカチを巻いた、金歯の光って眼の鋭い、癇癪持らしい顔をした外川先生と、強情できかぬ気らしい、日本人の彼等よりも却てヨリ好き日本語をつかうＦ女史に会った。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時彼は湘南の老父に此爺さんの噂をしたら父は少し考えて、待てよ、其は昔関寛斎と云った男じゃないかしらん、長崎で脚疾の治療をしてもらったことがある、中々きかぬ気の男で、松本良順など手古摺って居た、と云った。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも美人だが、いかにもきかぬ気の、気象のはげしさが人相にうかがわれる娘。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の視力の鈍い、どこかきかぬ気らしい、白蝋の面のようなその顔は、涙にふさわしくなかった。",
              "citation": {
                "source": "溺るるもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "西山のごん八さんも、きかぬ気の人でしたから、東山から、いぢわるを、しかけられると、だまつては、ゐませんでした。",
              "citation": {
                "source": "にらめつくらの鬼瓦",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、なかなかきかぬ気の子供は、それがために、けっして泣き出すようなことがなかったのです。",
              "citation": {
                "source": "角笛吹く子",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじいさんは、まだ、きかぬ気の、がんこそうな体を揺すって、日に焼けた顔で、笑いながら、「なに、かえって、一人というものは、いいものだ、気楽でな。",
              "citation": {
                "source": "銅像と老人",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに、強いきかぬ気の若者でも、これを乗り切ることはできまい。",
              "citation": {
                "source": "海の踊り",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤五郎は、きかぬ気らしく太い眉をピクリと動かして、「それがどうしたとおっしゃるんです」「どうしたもこうしたもねえ。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "永代経",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅の精よりかも遥かに威厳があり、何所やらどっしりと、きかぬ気性を具えているようでございました。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
