[
  {
    "uuid": "07da3ecd-8cf8-5247-8844-29983a5e180a",
    "entry": "きかぬ気",
    "reading": {
      "primary": "きかぬき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
      "ctype": null,
