    "uuid": "4411843e-947d-531d-b293-4f60f9f0b9f9",
    "entry": "胸膜",
    "reading": {
      "primary": "きょうまく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pleura",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」彼は、リザ・リーブスカヤのことを思い出して、どぎまぎして「胸膜炎で施療に来て居るからそれで知っとるんです。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸膜炎で、たき出した番茶のような水を、胸へ針を突っこんで汲み取る患者も、トラホーム・パンヌスも、脚のない男も一つの病室にごた／＼入りまじった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸膜炎で二三日前まで病院にいましたの」「そうかい。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴も兵営で功七級を夢みたが胸を突かれ胸膜炎になって除隊になった。",
              "citation": {
                "source": "アンチの闘士",
                "author": "今村恒夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはSantsiaoとして知られ、腹膜または胸膜のことであろう。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "部位が変わると、肺炎、胸膜炎、てんかん、胃、肝臓、脾臓の病気、などなどとなった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "肺炎と胸膜炎、肺結核に似た肺の慢性疾患があった。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
