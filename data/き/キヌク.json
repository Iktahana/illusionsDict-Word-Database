[
  {
    "uuid": "7d356ee7-55c9-52d0-880e-35635a62e18f",
    "entry": "気抜く",
    "reading": {
      "primary": "きぬく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-カ行"
      ],
      "ctype": null,
