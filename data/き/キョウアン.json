    "definitions": [
      {
        "index": 1,
        "gloss": "lesson or teaching plan",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
