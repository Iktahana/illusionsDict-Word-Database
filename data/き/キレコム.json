          "literary": [
            {
              "text": "その日の夕方も、まだ日の高いうちに、野崎島をめぐって神之浦へ切れ込むと、そこへ山のような和蘭陀船が一艘｜碇泊って、風待ちをしているのが眼に付いた。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じクレヴァスと云った所で万古の堅氷に、電光のように切れ込む裂目である。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じクレヴァスと言ったところで万古の堅氷に、電光のように切れ込む裂目である。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
