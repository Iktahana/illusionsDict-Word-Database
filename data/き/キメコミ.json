        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祖母は趣味で木目込みを習っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この木目込みの技術は、江戸時代から伝わる伝統工芸です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は木目込みの職人を目指して修行中だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "金看板のむっつり屋をきめこみながら、じろりと伝六に流し目をくれただけで、依然あごひげを抜いては探り、探ってはまた抜いていましたので、伝六はますますじれ上がって、いっそうつんけんといいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "コックスのほうは深尾がおぼえているものときめこみ、長い脛を倒すようにして椅子に掛けると、まだ少年の悌のある優しい口元に微笑をうかべながら、勢いこんでしゃべりだした。",
              "citation": {
                "source": "三界万霊塔",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいか、現におめえは、おいらの預けたその箱をさらって、ドロンをきめこみ、いいか、一目山随徳寺と――」「うめえうそをつくなあ！",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "市ノ瀬牧人は、もう、夫人とその息子とを案内してワラビ狩りに行くものとひとりぎめにきめこみ、あの山この山の春めいたすがた、若草の緑によみがえる小みちのかず／＼を、たのしく頭のなかに想いえがいていた。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "先月下旬のこととか、この猫、同家の芋畑に遊びいたるを長右衛門ふと見ると、不思議なる腰つきして立ち上がり、芋の葉を取り、しばらくなめつつありしが、間もなくこれを頭にかぶりてチンチンをきめこみ、おどり戯れおり。",
              "citation": {
                "source": "おばけの正体",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなら、いッそ気楽でいいが」と、ここに花和尚魯智深は、ここの大地主にでもなったような気で持ち前の“野性の自適”をきめこみだした。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その行家は、墨股敗戦の尻ぬぐいを、こんどは、義仲の陣へもちこんで“木曾殿の居候”をきめこみます。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
