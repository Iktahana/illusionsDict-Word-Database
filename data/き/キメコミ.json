        "examples": {
          "standard": [
            {
              "text": "歌舞伎役者が木目込みを施した顔で舞台に現れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その役の木目込みは、複雑で時間がかかる作業だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔の文献には、木目込みの技法について詳しく記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
