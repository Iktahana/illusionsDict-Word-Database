        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は、人生における共時性の現れに常に注意を払っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "偶然の一致とは思えない、不思議な共時性を感じることがよくある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ユングが提唱した共時性の概念は、多くの人々に影響を与えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「まさに今、あなたが話そうとしていたことを考えていたんだ！」と、友人は共時性に驚いた様子だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
