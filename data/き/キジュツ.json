      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "previously mentioned",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "既述のごとく、箇々の語のような、意味を有する言語単位の外形は、以上のような音または音韻の一つで成立つかまたは二つ以上結合して成立つものであるが、その場合に、或る音は語頭、すなわち語の最初にしか用いられないとか、または語尾、すなわち語の最後にしか用いられないとかいうようなきまりがあることがある。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは既述竜の話中に図に出したインドのコブラ・デ・カペロ（帽蛇）に酷似るが喉後の眼鏡様の紋なし。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "帽蛇は今も梵名ナーガで専ら通りおり、那伽は漢訳仏典の竜なる由は既述竜の話で繰り返し述べた。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが少年が目にし耳にした説明は既述した通りである。",
              "citation": {
                "source": "無法な火葬",
                "author": "VIOLENT CREMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関を上つて左手が笹田執事の室、反対に右側が応接間であることは既述の通り。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "既述の通り湯は浴槽に八分目位はいつている。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初江の死体が現場にそのまま残つていなかつたことについて、警部がかなりがつかりしたらしいのは既述の通りだけれども、この点については、藤枝も余程残念だつたらしい。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "記事はいずれも確定的で伊達正男が自白したということを記してあること既述の通りである。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに書いてあつた内容は既述の通りである。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "上村源之丞座の由來に就いては既述の通り吉井太郎氏が發表されたやうなことが座元の人々に依つて傳へられてゐる以外に明確な資料は得られない。",
              "citation": {
                "source": "淡路人形座訪問",
                "author": "竹内勝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此名代部・子代部の伝承をある点まで集成したらしいのが、既述の海語部である。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、米国文庫が、公立図書館と相待て発達し、相待てその用を完くしつつあること、前項既述のごとし。",
              "citation": {
                "source": "米国巡回文庫起源及び発達",
                "author": "佐野友三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学的精神の涵養のごときは、これを一時の急に向って行なおうとすることは到底不可能であり、それが長い歴史的過程を必要とするのは既述のごとくであることから見て、我々は何よりもまずこの点に重きを置かねばならなかったのであろう。",
              "citation": {
                "source": "社会事情と科学的精神",
                "author": "石原純",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがなかなかにこの国衙が納まらぬので文明十八年にこれを幕府に訴えたこと既述のとおりであるが、その時には有利な裁訴を得たけれど、土岐氏の方からして奉書遵行の請文を出さぬ。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ブラウンのモデルになつたジョン・オコナー師は見るからに俊敏聡明な人で、その点をチェスタートンが意識して正反対の風貌に作り上げたことは「秘密」の解説で既述したとおりであるが、コウモリ傘と茶色の紙包みはやはりオコナー師が実際に持つて歩いていたそうである）。",
              "citation": {
                "source": "ブラウン神父総説",
                "author": "村崎敏郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "既述のように、家具その他の動かせる物は一つもなかった。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　彼の出生・死亡の年代、並びに出生地は既述の通り。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして既述のように、印象は自己に類似する観念より以外の観念を引き起すことができないのである。",
              "citation": {
                "source": "人間本性論（人性論）",
                "author": "A Treatise of Human Nature",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ちそれは、既述のような特定の仕方で「感覚」に影響を及ぼす、二つの事物の一つの特性なのである。",
              "citation": {
                "source": "人間本性論（人性論）",
                "author": "A Treatise of Human Nature",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、その全体系は、全く理解不能であり、既述の諸原理と同じく、依然として、自然の諸原理に由来するのである。",
              "citation": {
                "source": "人間本性論（人性論）",
                "author": "A Treatise of Human Nature",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、想像において諸観念に結合を与え得る最適な性質は、既述の三つの関係（類似・近接・因果性）なのである。",
              "citation": {
                "source": "人間本性論（人性論）",
                "author": "A Treatise of Human Nature",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は、本論考の既述部分を例証し確証するであろう。",
              "citation": {
                "source": "人間本性論（人性論）",
                "author": "A Treatise of Human Nature",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめに、既述の通り彼らはしばしば外国と結託する。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この家の入口をはいったとき、ちんどん屋のすがたがぼうっときえていって、せいようあくまがあらわれ、それがくびばかりになったのは、一まいガラスのドアをかがみに使ったきじゅつだよ。",
              "citation": {
                "source": "まほうやしき",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
