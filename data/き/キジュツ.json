  {
    "uuid": "8cdf7d28-d84d-50ac-b97a-4add2bea5ced",
    "entry": "既述",
    "reading": {
      "primary": "きじゅつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
