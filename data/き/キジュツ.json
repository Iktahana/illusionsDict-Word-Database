    "definitions": [
      {
        "index": 1,
        "gloss": "magic",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "奇術が何とか座にかかっているのを見にゆこうかと言っていたのを、峻がぽっと出てしまったので騒いでいたのである。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり読者の錯覚、認識不足を利用して読者を魅了すればよいので、この点奇術や魔術と同様である。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう意味ではそのころに見た松旭斎天一の西洋奇術もまた同様な効果があったかもしれないのである。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それはばけもの奇術でございましょう。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばけもの奇術師が、よく十二三位までの女の子を、変身術だと申して、ええこんどは犬の形、ええ今度は兎の形などと、ばけものをしんこ細工のように延ばしたり円めたり、耳を附けたり又とったり致すのをよく見受けます。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年の調べでは、奇術を職業にしますものは、五十九人となって居りますが、只今は大分減ったかと存ぜられます。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして検事の案内で、まっすぐに奇術大一座のある処に参りました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇術は今や丁度まっ最中です。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはむかし奇術師のテジマアに　おれの妹をさらわれていた。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その奇術師のテジマアのところで　おれの妹はスタアになっていた。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おきなぐさはその変幻の光の奇術の中で夢よりもしずかに話しました。",
              "citation": {
                "source": "おきなぐさ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「南京出刃打の見世物が、奇術にまじって、劇場に掛ったんだよ。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "文學の作家が、その作品の準備された「覺え書」を公開するのは、奇術師が手品の種を見せるやうなものだ。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "筏師はあたかも水を踏んで素足でつつ走る奇術師のやうだ。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文献としては、石渡賢八郎編の『西洋奇術狐狗狸怪談』と骨皮道人著の『狐狗狸と理解』の二書があるが、皆明治二十年｜比の刊行である。",
              "citation": {
                "source": "狐狗狸の話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って彼のニッカーボッカーを穿いた両脚は勝手に動いて奇術師のようにふらふら調子を取りながら時々小石や小径のふちの雑草の根本に躓ずいて妙に曲る。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人で劇作家で、作曲もしバンドの指揮もし、デザインをやるという奇術師のようなジャン・コクトオですら、小説を書けば極くあたり前の紋切型の小説を書いている。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある街の辻に古くから立つてゐる円筒状の黒い広告塔に、折々、西洋奇術の貼札が紅いへらへら踊の怪しい景気をつけるほかには、よし今のやうに、アセチリン瓦斯を点け、新たに電気燈をひいて見たところで、格別、これはという変化も凡ての沈滞から美しい手品を見せるやうに容易く蘇らせる事は不可能であらう。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その伯父は目下奇術師で、朝野の紳士を散々飜弄した揚句、行衛を晦ましている毒婦、雲月斎｜玉兎女史とくっ付き合って、目下、銀座のどこかで素晴らしい人肉売買をやっている事を私はチャント知っている。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならずその辛棒の甲斐がありまして、脱獄してから一個月目に、新旭川附近の只ある村外れで、彼女が私に暗示していた、小さな奇術劇団の辻ビラがブラ下っているのを発見しました時の、私の喜びはドンナでしたろう。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "初講義の挨拶を兼ねての、総論的序説と云うよりもそれはむしろ、怖ろしい奇術の前口上を聞いているようで、私は背中の辺をぞくぞくと銀線のようなものの走るのを感じた。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――咲いている花を蕾として認めさせようという、彼の魔術、彼の奇術。",
              "citation": {
                "source": "仮装観桜会",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昨夜、あなたのお兄さんから戴いた金が、別に盗賊も入ったようにもないのに、そっくりなくなったのです、どうしたのでしょう」　倉知夫人の詞は如何にも正義が、奇術的な詐欺をはたらいたと云わないばかりの詞であった。",
              "citation": {
                "source": "白っぽい洋服",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝに一の奇術あり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが此詞は果して座客をして耳を※てしめ、人々は爭ひ進みて、願はくはその奇術を見ることを得んと云へり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々よ、我詞は戲言にあらず、人々は再び其品を得給ふまじといふに、滿座の客は、さもあらばあれ君が奇術こそ見まほしけれと、金銀、指環、鎖の類を堆く卓上に積みたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍服着たる一老人、若しその奇術奇ならざるときは、われは我が「ヅカアチイ」二個（約三圓三十八錢）を取り返すことを得んかといひしに、ポツジヨは我に代りて、若し疑はしとおもひ給はゞ、夥伴に入り給はでもあるべきにと答へぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして素晴らしい奇蹟が、すぐ眼の前に待ちもうけてゐるかのやうに、水島の眼はちかちかと忙しく光り、また隠れてゐた天才的なものが、いつぺんに顕はれてきたかのやうに、彼は調子づいた奇術師に等しい活動館での接吻がなによりそれを物語つてゐた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この家の入口をはいったとき、ちんどん屋のすがたがぼうっときえていって、せいようあくまがあらわれ、それがくびばかりになったのは、一まいガラスのドアをかがみに使ったきじゅつだよ。",
              "citation": {
                "source": "まほうやしき",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
