[
  {
    "uuid": "80c74242-95e4-5da8-84cd-a7f4fa11124c",
    "entry": "近刊",
    "reading": {
      "primary": "きんかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
