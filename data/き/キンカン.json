    },
    "definitions": [
      {
        "index": 1,
        "gloss": "forthcoming publication",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（明治四十一年五月一日『東京朝日新聞』）　　　　　　　　　七十六　　　　　　空中の巡査　近刊の某地学雑誌に上のような表題を掲げて鳥類の保護を論じている人がある。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは竜舌蘭の厚い葉の汁から製するそうで、近刊の某誌によれば次のような方法によるという。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその巻頭に掲載された和辻哲郎氏の「風土の現象」と題する所説と、それを序編とする同氏の近刊著書「風土」における最も独創的な全機的自然観を参照されたい。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして近刊の天文の雑誌を調べてみるとそれが火星だという事がすぐに判った。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような珍しい現象の記録をそれが消えない今のうちに収集しておくのは、切手やマッチのレッテルの収集よりは有意義であろうと思っていたが、近刊の板垣鷹穂氏著「芸術的現代の諸相」の中に、このような収集の一部が発表されているのを見てなるほどと思うのであった。",
              "citation": {
                "source": "カメラをさげて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「青猫」はイマヂスムの詩集でなく、近刊の詩集「氷島」と共に、私にとつての純一な感傷を歌つた詩集であつた。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "健脳な読者の中には、ずっと昔、自分と室生犀星等が結束した詩の雑誌「感情」の予告に於て、本書の近刊広告が出ていたことを知ってるだろう。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれでも、近く出そうという下心だけは残っていたので、「近代風景」その他の雑誌で、しばしばこの『自由詩の原理』を近刊すべく、読者に約束したりした。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　近刊の雑誌「東炎」に志田素楓氏が、芭蕉の古池の句の外国語訳を多数に収集紹介している。",
              "citation": {
                "source": "俳諧瑣談",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに出口米吉君の近刊『日本生殖器崇拝略説』に『日本書紀通証』から孫引きされた『扶桑拾遺集』に、〈源順、庚申｜待夜、伊勢斎宮に侍りて、和歌を奉る、小序に曰く、掛麻久毛畏幾大神、怜礼登毛、愛美幸賜天牟〉とある由。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "花咲爺の咄は誰も知る通り、犬に情け厚かった老爺はその犬の灰で枯木に花を咲かせて重賞され、犬に辛かった親仁はそれを羨んで灰を君公の眼に入れて厳罰された次第を述べたのだが、近刊佐々木喜善君の『江刺郡昔話』に出でいる灰蒔き爺の話は教科書に載ったものとは異態で、田舎びたるだけこの話の原始的のものたるを示す。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも大杉は改造社とアルスから近刊する著書の校正や書足しの原稿に忙殺されていたのだそうだ。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "――嘘のやうだが、これは近刊の英字雑誌に載つてゐる真実の事実談である。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍らしい広告７・28（夕）　倫敦タイムスの近刊号人事欄に次のやうな広告が載つてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "文芸全書（早稲田から近刊の筈）英文、言語学、生理学（いずれも理化科学叢書の）、科学と革命（平民科学叢書の）、ワイニフンド・スティブン著、フランス小説家。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "４　言葉の感覚――近刊『ですぺら』の広告文に私は『ですぺら』といったってアンペラやウスッペラの親類ではない――と書いた。",
              "citation": {
                "source": "惰眠洞妄語",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "（七月四日）五十四○近刊の『ホトトギス』第五巻第九号の募集俳句を見るに、鳴雪、碧梧桐、虚子共に選びしうちに着つゝなれし菖蒲重や都人　　　　朧月堂とある。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "（七月二十一日）七十一○近刊の雑誌『宝船』に甘酒屋打出の浜に卸しけり　　　　青々といふ句があるのを碧梧桐が賞讃して居つた。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "近刊の新聞雜誌中、論ずべき文少からざるべし。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の放浪記が一冊にまとまって、改造社から近刊されます。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これについては一条忠衛さんが近刊の『六合雑誌』で「夫婦の扶養義務について」と題して書かれた所と全く同感です。",
              "citation": {
                "source": "平塚さんと私の論争",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ジアン・コクトオ抄」を近刊する。",
              "citation": {
                "source": "新人紹介",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、近刊豫告には「地の糧」などと竝んでノヴァリスの「青い花」が出てゐる。",
              "citation": {
                "source": "色褪せた書簡箋に",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "近刊拙著詩文集はその方式でやることになっている。",
              "citation": {
                "source": "書籍の風俗",
                "author": "恩地孝四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この武士をエビスということにつきて、近刊の文学士菊池仁齢氏著『奈良平安時代の奥羽経営』（『奉公叢書』第二編）には、はなはだ簡単に左のごとく説明せり。",
              "citation": {
                "source": "武士を夷ということの考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがスタンレイ・ロージャースの近刊『太平洋』によると、一八六七年で、船は「コロラド」である。",
              "citation": {
                "source": "咸臨丸その他",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこが深田氏の『わが山々』という近刊の登山記録集が、清新で面白い所以である。",
              "citation": {
                "source": "登山趣味",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して此の土俗はアイヌには近年まで實行されてゐて、二三の書物にも載せてあるが、今は近刊の「アイヌの足跡」から抄録する。",
              "citation": {
                "source": "安達ヶ原の鬼婆々異考",
                "author": "中山太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、今日、英國近刊のある怪奇小説集の一篇を讀んだ。",
              "citation": {
                "source": "奇怪な客",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年『面とペルソナ』を書いた時にはすぐにも刊行されそうな話だったので、「近刊」として付記しておいたが、それからもう一年以上になる。",
              "citation": {
                "source": "能面の様式",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
