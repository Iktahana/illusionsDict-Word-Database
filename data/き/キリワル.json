        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もろぐるまが終るとまた縫い合わせて首のないまま直立させ、背骨を切り割る。",
              "citation": {
                "source": "せいばい",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりでぶつぶついっていると、空の一方から虚空を切り割るような爆音が遠雷のようにころげてきた。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ひきりわるく振返つた。",
              "citation": {
                "source": "水源を思ふ",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「ああ、あの、だめなことがわかっていながら、思いきりわるくまだやっている人のうちの方ですかい。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のかぜは、はっきりわるくもならないで、長くかかって心持わるいのね、いやね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "首をかしげつつ私は、思いきりわるく描き改めた。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は、どうひいき目にも、馬とは見えぬ雪の中の山肌を、思いきりわるく見返りながら、うかぬ心を抱いて森上へ戻った。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
