        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "我々の新戦略は、競合他社の動向を分析した上で策定された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「競合他社よりも一歩先を行くために、我々はイノベーションを加速させる必要がある。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの製品、競合他社も似たようなものを出してるらしいよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "競合他社との提携により、新たな市場を開拓する可能性もある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ＰＣ―９８０１が市場を独占しはじめた段階で、いくつかの競合他社は互換機によって対抗する可能性を繰り返し検討した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "競合他社を出し抜くために、母国の合衆国を含む全世界の大英王国を破滅させかねない。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
