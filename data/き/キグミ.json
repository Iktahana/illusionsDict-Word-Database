    "definitions": [
      {
        "index": 1,
        "gloss": "attitude",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ええ、今の謡の、気組みと、その形。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人とも中年近いので、もう二三年もして子供が出来ないなら、何とか法律上の手続をとつて、ひろ子を養女にするか、自分たちが養父母に直るかしたい気組みである。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちはお前、河岸で一番首を討取る気組みで、佳いものを仕入れてよ、一ツおいしく食わせてやろうと、汗みずくで駈附けるんだ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この出船の時の人々の気組み働きは、だれにでも激烈なアレッグロで終わる音楽の一片を思い起こさすだろう。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでは一つこの意気組みで会を起そうではないか。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "彫工会の成り立ちについて",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、生活問題としても、はっきりそれをとりあげる気組みは持っていないと見られる。",
              "citation": {
                "source": "一九三七年十二月二十七日の警保局図書課のジャーナリストとの懇談会の結果",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "という、気組みの引立ちが欠けている観がある。",
              "citation": {
                "source": "一連の非プロレタリア的作品",
                "author": "――「亀のチャーリー」「幼き合唱」「樹のない村」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合、松田氏は、自身の創作的態度をますます今日の現実の核心に触れ、作品を通じて更に現実に働きかえす力をもつものとするよう、階級的な作家として必要な鍛練を自身に課す気組みにおいて云っておられるのは明らかなことと思う。",
              "citation": {
                "source": "見落されている急所",
                "author": "――文学と生活との関係にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今夜は一つお願いがあって参りました」　そういう私の意気組みが平生と違っていたと見え、「そうですか、何かむずかしいことですか」と氏はほほ笑んでいられた。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "馬専門の彫刻家のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "「老いて楽をしようと思えば若いうち蟻のように働け」「圧しつけられてこそ味の出る沢庵」と、搾取と闘おうとするわれわれの当然の意気組みをそらすような一番始末にいけない「諦め」でフぬけとなるよう、塩梅しているところは巧なものである。",
              "citation": {
                "source": "『キング』で得をするのは誰か",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この窮屈な文章が藤村の気組みの反映、或は堂々さとして現代の人々に尊敬されることに、現代文学の貧弱さ、同時に健康な若い文学的反抗心のよわさ、確信あり自信ある発展的・前進的活躍がないフラフラ雰囲気に飽きた一般人をその窮屈さも或る快感として把えるところとなっている。",
              "citation": {
                "source": "「夜明け前」についての私信",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの十頁の紙にどれ丈けの尊いものが費されてあるかを思ひますと涙せずにはゐられません、両氏の強いあの意気組みと尊い熱情に私は人しれず尊敬の念を捧げてゐた一人で御座います。",
              "citation": {
                "source": "編輯室より（一九一四年一一月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、私はわけもなくその気組みに圧される想ひで、黙つて了つた。",
              "citation": {
                "source": "大凶の籤",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は集めんとする気組みに倦怠を感じてしまふのである。",
              "citation": {
                "source": "続野人生計事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "云わば彼の心もちは強敵との試合を目前に控えた拳闘家の気組みと変りはない。",
              "citation": {
                "source": "お時儀",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "無表情ながら何んとなく、負惜しみを云ったってやはり恰好はつけただろうと冠せる気組みも見え、矢代は答えに窮して黙った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その姿は何処か滑稽な中に、真剣な意気組みもあるものだつた。",
              "citation": {
                "source": "庭",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから卒業したての学生の意気組みと職業的良心と云うものは素晴らしいものだ。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この意気組みと職業的良心が誠に貴い所で、之を善用し活用すれば大したものになるのだが、悲しい事には官庁でも会社でも組織に欠陥がある為に、素直にそれを受け入れる事が出来ない。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼には意気組みの素晴らしいものがあると同時に、十分な職業的良心を持っていた事と私は信じる事が出来る。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夏、原の端れの黒っぽい家々の一軒では、自然のうつりかわりなんぞに気を奪われている暇はないというように殺気だった意気組みで、姉さんかぶりに上っぱり姿の女も交えた数人の男が、トラックのまわりにたかって盛に襤褸のあげおろしをやっていた。",
              "citation": {
                "source": "朝の風",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も見ていないような虚ろな視界に、黒々とした阿賀妻の気組みを読み取った。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、その気組みだけは誰にも劣らぬと思っている。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはやむを得ない運命でありますが、苟くも外国人にも窺はれる所は悉看破するだけの気組みを持たなければなりません。",
              "citation": {
                "source": "文芸鑑賞講座",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ爰では、熱心な傍観者が、日本国中の手のとゞく限りの民俗芸術を、真の意味に於て自分の実証的態度を鍛錬する気組みで見て歩いた、さういつた態度を離さないで、今度も見せて貰つた其感想を記録して置きたいと思ふのである。",
              "citation": {
                "source": "感謝すべき新東京年中行事",
                "author": "――第四回郷土舞踊と民謡の会・批判――",
                "note": "青空文庫"
              }
            },
            {
              "text": "左団次一座のかうした気組みは、若い彼に影響せぬ訣もなし、又其を望んで東上したはやり気の彼であつてみれば、有頂天になる程緊張したその舞台生活は察しることが出来る。",
              "citation": {
                "source": "街衢の戦死者",
                "author": "――中村魁車を誄す――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなり一撃くらわして、相手がよろめきながら、呆気にとられて、まだ喧嘩の気組みにならない先に、すっと引上げるんです。",
              "citation": {
                "source": "女と帽子",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――つまり、洋々たる前途を望む雄大な気概なぞといふものがあつて、そこで第一の人物を訪ねるときの道々の気持なぞといふものもつひ鼻唄がとびだすほどの言ひやうもなく爽快なもので、戦前すでに敵を呑む痛快無類な気組みなども充分持ち合はしてゐるものである。",
              "citation": {
                "source": "金談にからまる詩的要素の神秘性に就て",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "言ふまでもなく戦前すでに大敵を呑んだ壮烈な気組みで、誰の目にも颯爽として第一の人物邸へ乗りこんだのである。",
              "citation": {
                "source": "金談にからまる詩的要素の神秘性に就て",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、気組みがちがう。",
              "citation": {
                "source": "女剣士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
