        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「うーん、技術的には素晴らしいんだけど、商品としての企画性が足りなくて売り出し方に困るね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "今回の新商品は、SNSでの拡散を最初から計算に入れた企画性の高さが評価されてヒットした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「君のアイデアは面白いけど、もう少し市場のニーズを汲み取った企画性が欲しいところだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "採用面接では、これまでの活動を通じて培われた企画性と実行力が問われることになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "技法上の強いリアリスティックな構成力、企画性がこの製作者の発展の契機となっているのである。",
              "citation": {
                "source": "「愛怨峡」における映画的表現の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近におけるわが国の都市の膨脹はまつたくその企画性を無視したものである。",
              "citation": {
                "source": "都市文化の危機",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その配列の対比性、階調性はフィルムのモンタージュと同じ様に、新しきリアリズムのもつ企画性である。",
              "citation": {
                "source": "「壇」の解体",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことにまでアメリカ人一流の企画性が現れているのは面白いことですね」「そうなんだよ。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
