        "examples": {
          "standard": [
            {
              "text": "映画「ジュラシック・パーク」は、恐竜時代の世界をリアルに再現していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もし恐竜時代にタイムスリップしたら、どんな動物がいるんだろう？」と、友人と話した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "小学生の息子は、恐竜時代の生き物たちに強い興味を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "地層から発見された化石は、恐竜時代の地球の姿を教えてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "恐竜時代にこの恐るべき石造建築を立ち上げ、住まいしたものどもは恐竜どころか、確かにずっと悪いものだった。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
