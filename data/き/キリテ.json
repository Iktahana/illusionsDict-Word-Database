        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一面に燃えた雑草の中に立って、思い切り手を振った。",
              "citation": {
                "source": "快走",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も見る人がない…………よし…………思い切り手足を動かしてやろう…………道子は心の中で呟いた。",
              "citation": {
                "source": "快走",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「袈裟がけならば、切り手は二本差しだな」「へ……？",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "切り手は、おまえの判じ文にこっちがあぶなくなったとあったその相手に相違ねえが、そいつはだれだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "切り手と掬い手とは異わなければならない。",
              "citation": {
                "source": "天主閣の音",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺の切り手をひっ外し、足音も立てずに逃げるとは？",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんでも生残った人の話に、その晩はひでえ闇夜で、また、其奴等というのがひでえ切り手で、その仁なんども、直ぐ後を歩いていた者がバッサリやられるまで知らなかったそうな。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前の智惠ぢやあるまい」「霍亂になる菓子を捨る位の智惠はあるよ」「よし／＼、お前は思ひの外悧口さうだ、がこれは隱し切れる事ぢやないよ」　平次はそれつ切り手を引きました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "御落胤殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう具合に何遍か上げたり沈めたりしてよくその死を見届けてから、首を切り手足を切り、五体放れ放れにして流してしまって、首だけこっちに取って来るのです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "屍体の首を切り手を切り足を切り、みんな切り放して流すです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんでも生き残った人の話に、その晩はひでえ闇夜で、また、其奴等と言うのがひでえ切り手で、その仁なんども、すぐ後ろ手を歩いていた者がバッサリやられるまで知らなかったそうな。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「成程な」　平次はそれつ切り手拭を返して、番所の中へ入りました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "玉の輿の呪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――しかしですな」　と、助九郎は膝をすすめ、「どうして、あんな柔軟な細枝の切り口を見て、非凡な切り手ということが貴君には分りましたか。",
              "citation": {
                "source": "宮本武蔵",
                "author": "水の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五日、朝、雨気ありたれども思いきりて出づ。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く寡うございます」　倉皇入来れる内儀は思ひも懸けず富山を見て、「おや、此方にお在あそばしたのでございますか」　彼は先の程より台所に詰きりて、中入の食物の指図などしてゐたるなりき。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨はびしょびしょと降りしきりて昼でも薄ら寒い日なり。",
              "citation": {
                "source": "慈悲心鳥",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕空虹の環横にきりて、遠雲がくれにわたる鳥の身がろき翼も捨てなましや、眞玉をのべたるかの腕に、物もひ煩らふ額をよせて、樂しき夢路をたどりえなば。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "汐は今満ちきりて溢るるばかりだ。",
              "citation": {
                "source": "句合の月",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "母はガラス戸に窓掛を掩ひ、襖を尽くしめきりて去る。",
              "citation": {
                "source": "明治卅三年十月十五日記事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "菫は相撲取花といひて、花と花とうち違ひ、それを引ききりて首のもげたるよと笑ふなり。",
              "citation": {
                "source": "わが幼時の美感",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "「時は五月十日の夜、月山の端にかげくらく、池に蛙の声しきりて、燈影しば／＼風にまたゝくところ、坐するものは」と若い文学界の誰彼の姿をも日記にかいている。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そはとにかくに前の歌の結句といひこの歌の結句といひ思ひきりて佶屈に詠まるる処を見れば作者も若返りていはゆる新派の若手と共に走りツこをもやらるる覚悟と見えて勇ましとも勇ましき事なり。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨は今朝よりふりしきりてやまず。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "白雲や青葉若葉の三十里　山を下れば驟雨颯然とふりしきりて一重の菅笠に凌ぎかね終に馬籠駅の一旅亭にかけこむ。",
              "citation": {
                "source": "かけはしの記",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ中に、優なるは上田君ぞかし、これもこの頃打しきりてとひ来る。",
              "citation": {
                "source": "樋口一葉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗出の木目の立た高からぬ塀にかゝりて、盛はさぞと思はるゝ櫻の大木、枝ふりといゝ物好な一構、門の折戸片々いつも内より開かれて、づうと玄關迄御影の敷石、椽無の二枚障子いつも白う、苔井のきわの柿の木に唯一ツ、光程じゆくした實の重さうに見へる、右の方は萩垣にしきりて茶庭ら敷折々琴の昔のもるゝもゆかし。",
              "citation": {
                "source": "うづみ火",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "宅をしめきりてあがっておるそうでござります。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "天地｜有情の夕まぐれわが驂鸞の夢さめて鳳樓いつか跡もなく花もにほひも夕月もうつゝは脆き春の世や岑上の霞たちきりて縫へる仙女の綾ごろも袖にあらしはつらくとも「自然」の胸をゆるがして響く微妙の樂の聲その一音はこゝにあり。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "束髪の前髪をきりて、ちぢらしたるを、隆き額の上にて二つに分けたり。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もろこし我朝に、もろもろの医者達の出し申さるる薬礼の礼にもあらず……ただ病気全快の節は十八文と申して、滞りなく支払するぞと思ひきりて掛るほかには別の仔細候はず。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
