    "definitions": [
      {
        "index": 1,
        "gloss": "sympathizer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「その政治運動の共鳴者たちは、各地で集会を開いていた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「彼女は、長年、動物保護活動の熱心な共鳴者だった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「作家は、自身の作品の共鳴者たちからの手紙に感謝していた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この芸術祭は、地域住民やアーティストの共鳴者たちが支えている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "けれども私共は、始から「思想のための友人」もしくばその共鳴者ではなかつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "書くことによってせめて、共鳴者を、私のほか一人でも増して置き度い。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大杉の思想の共鳴者でなくともその悲惨な運命には同情せずにはいられなかった。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、畢竟は談理を好む論理遊戯から愛読したので、理解者であったが共鳴者でなかった。",
              "citation": {
                "source": "二葉亭追録",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして工場内の労働者はそのビラが工場内でどのような反響を起したか、何人の共鳴者があったかを、その晩の研究会での報告者の役目をつとめる。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、今日の工場内の動揺に対して、次にはどういう形で更にアジテエションが与えられねばならぬか、新たに出来た工場内の共鳴者は逃がさず捕えて、どんな風に組織を進めてゆくか……等、集会は全く活気を呈するに至るだろう……。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに関して、某紙上に共鳴者が現れたことは、作者のよろこびとするところであった。",
              "citation": {
                "source": "『十八時の音楽浴』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の社会は、言葉の完全な意味でのブルジョア革命を経ていないという一応は尤もな理由から、このグループの「近代」の主張はある程度の共鳴者をもっている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に、美人というものの標準から見れば、日本美人は到底、西洋美人の敵でないという議論は、よく洋画家なぞが口にするところで、自分も固くそう信じているのであるが、不思議にも今まで、あまり共鳴者がないばかりでなく、西洋かぶれの候のと烈しい反対を喰った事さえある。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "近年は碧梧桐氏がいわゆる新傾向の俳句を始めてなかなか多くの共鳴者を得ているが、一体五七五調の俳句と異った口調では誰れも知る如く、芭蕉の頃の「虚栗」蕪村の頃の柴田麦水を中心とした「新虚栗」もあったのみならず、子規氏生前の我々の中でも、一時は随分試みたのであった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、トルストイの思想は若干の共鳴者を出しはしたが、それは彼が、優れた芸術家であつたと同時に、偉大な人格を背景としてゐたからである。",
              "citation": {
                "source": "新劇界の分野",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイルランド劇も多くの共鳴者をもつた。",
              "citation": {
                "source": "対話させる術",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃では表現派が多少の模倣者乃至共鳴者を生んだことは明かな事実である。",
              "citation": {
                "source": "過渡時代",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は先づ機会ある毎に自分の意見を発表し、有力な共鳴者の出現を待つてゐるのである。",
              "citation": {
                "source": "新劇運動の一考察",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜ先生かと申しますと、彼は一流のファシズムを信奉しており、その共鳴者が七人いました。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも法本の事務所に働いている人たちは七人の共鳴者のうちの何人かですから、彼も八人目の共鳴者になってその事務所で働かせてもらいたい下心によるもののようでしたが、法本は彼を共鳴者と認めてくれぬ由です。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇宙戦争の共鳴者　帆村荘六に対するよくない評判が、だんだんとこの村にも、隣村にも強くなっていった。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つてサンヂカリズムの共鳴者であるのみならず、モスコオの国際労働組合と気脈を通ずる連中である。",
              "citation": {
                "source": "劇場と作者",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなわからずやのお父さんなら、私は破門せられても、大阪市民のために、賀川さんの味方の一人に加えてもらって、空中征服運動に参加したいと言われるのです」「フム、それでは私に一人の共鳴者が出来たわけですね」　そう言うて賀川市長は得意になった。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、彼は既に、共鳴者の一人をふとした機会に、某大学の文科生のうちに発見し、それ以来、互に往復して、運動のプランを練り、同志の糾合を目論んだ。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "特にヴィンデルバントの場合は有名だろう（彼の宗教的価値である「聖なるもの」は多くの共鳴者を有っている。",
              "citation": {
                "source": "認識論とは何か",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは私の共鳴者――よりよい私自身――私のよき天使だ。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "持たぬ者の悩みは、お仲間が最大多数であって、同情の分量もまたそれに比例して大きいが、持てる者の悩みは、その共鳴者が少ないだけ、理解者も、同情者も、少ないと言わなければならないのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は与八が居村から得た最初の共鳴者であった。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "本年二月頃から漸く獲得して来た三千四千という共鳴者の大部分が、予防命令以後はそれで事件が解決したかのように離れてしまったうえに、今はまた同志も歯の欠けるように減って、本当に一心同体となって働くもの僅かに三四人となった。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "「名前は言えぬが、軍にはちゃんと、枢要の地位にある人で、わしらの共鳴者がおったのだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
