        "examples": {
          "standard": [
            {
              "text": "ツバメは毎年同じ巣に戻ってくる、強い帰巣本能を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「おい、あんな遠くからよく帰ってこれたな。さすがに帰巣本能がすごいんだな、お前は。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "飼い主が変わっても、元の家を目指す猫の帰巣本能に驚かされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "家出本能のようなものもあれば、帰巣本能のようなものもあるんだね。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠告に従って、ここへ舞い戻ったのはたぶん動物の帰巣本能のようなものだと思います。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
