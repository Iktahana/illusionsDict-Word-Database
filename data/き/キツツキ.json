    "definitions": [
      {
        "index": 1,
        "gloss": "woodpecker",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝早くから、庭の木できつつきが幹を叩く音が聞こえた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "きつつきの鳴き声は、森に響き渡っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供向けの絵本に、きつつきの絵が描いてあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "縁前のついその森に、朽木を啄む啄木鳥の、青げら、赤げらを二｜羽視ながら、寒いから浴衣の襲着で、朝酒を。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "落葉が朽ちるのか、根が水を吸うのか、巻き葉が拡がるのか、虫がささやくのか、風が渡るのか、その静かな音、音ある静かさの間に啄木鳥とむささびがかっかっと聞こえ、ちちと聞こえる声を立てる。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何所かで啄木鳥が木をつゝいてゐる。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四隣は氣味の惡い程物靜で、たゞ車輪の輾る音と、折ふし寂寞とした森林の中から、啄木鳥がコト／＼と、樹の幹を叩く音とが際立つて聽ゆるのみであつたが、鐵車は進み進んで、今や唯ある深林の邊に差掛つた時、日出雄少年は急に私の袖を引いた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸の影に居て、啄木鳥のやうに叩くものはたれ？",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その木の皮を石で叩きつぶすと、いい匂がしたので、大人たちが、ひるねをしてゐるひるさがりなど、三人で、まるで啄木鳥のやうに、木の幹をコツコツと叩いてゐたりしました。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞け、今、巷に喘げる塵の疾風よせ来て、若やぐ生命の森の精の聖きを攻むやと、終日、啄木鳥、巡りて警告夏樹の髄にきざむ。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "古人、之を「啄木鳥の戦法」と云った。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち啄木鳥が、木中の虫を捕えるとき、穴と反対の側をコツコツと啄き、虫をおどろかして穴から出たところを喰べようと云うのである。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、啄木鳥に穴の底を叩かれて、ノコノコ這い出すような謙信ではなかった。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "穴中の虫は、啄木鳥の叩くを待たず自ら躍り出でて信玄を襲わんと云うのである。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅に姿を見せて飛ぶは鴨樫鳥に啄木鳥位ゐのもので、その他はたゞ其處此處に微妙な音色を立てゝゐるのみで、見渡す限りたゞ青やかな森である。",
              "citation": {
                "source": "鳳來寺紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし守屋大連は神道を頑守して仏教を亡ぼさんとし、自戮せられて啄木鳥となり、天王寺の伽藍を啄き散らせしというが、和歌山県当局は何の私怨もなきに、熊楠が合祀に反対するを悪み、十八昼夜も入監せしめたから、天、白蟻を下し、諸処を食い散らされたものと見える。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "廂の上に立つた桐の木へ啄木鳥が一羽飛んで来た。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "其朝もさういふ心持で啄木鳥に見入つたのであつた。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "威勢のいゝ啄木鳥は赤い腹を出したり黒い脊を見せたりしてぼく／＼と幹をつゝいて居る。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてたいへん慌てながら、傍に化粧をしてゐた、おめかし屋のイソクソキ（啄木鳥のこと）にむかつて、『さあ、母さんの病気です。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからと言ふものは、雀は清浄な米や粟を、啄木鳥は、腐れた木から虫を探して喰べるやうになりました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず啄木鳥に命じ探偵せしめた。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "有明月の影もまだ明らかな暁に其処に入つてゆけば折々啄木鳥の鋭い姿と声とに出会ふ。",
              "citation": {
                "source": "沼津千本松原",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯んな薄暗がりの鳥屋のやうな屋根裏で、鴉の羽音に驚いて奇声をあげたり、脚踏みをする鳥共の中で、むつくりとしてゐる私の有様は啄木鳥とも木兎とも云ひやうもなく、てもなくあたりの標本類の一種と見違へる――と唱と柚太は薄気味悪るがつた。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "お糸雑木林の啄木鳥は杉の枯れ木を啄いて啼いた杉の枯れ木を啄木鳥は無性　やたらに啄いて啼いた掛けた襷の解けたも知らず涙うかべてお糸は見てた。",
              "citation": {
                "source": "別後",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "羅馬人は啄木鳥の肉を食することを禁じた。",
              "citation": {
                "source": "毒と迷信",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "神を怖れなかつたソクラテスも、女の舌だけは身慄ひして怖がつたといふが、その女のなかで一番皮肉な、啄木鳥のやうな舌を持つてゐるのが婆芸者といふ一階級である。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その木の皮を石でたたきつぶすと、いいにおいがしたので、おとなたちが、昼ねをしている昼さがりなど、三人で、まるできつつきのように、木のみきをコツコツとたたいていたりしました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゅッと一｜閃、細身の銀蛇が月光のもとに閃めき返るや一緒で、すでにもう怪しの男の頤先に、ぐいと短く抉った刀疵が、たらたら生血を噴きつつきざまれていたので、「痛えッ、疑ぐり深けえ殿様だな」　不意を衝かれて男が言い叫んでいましたが、主水之介が言ったごとく、どうも少し気にかかる奴でした。",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゅッと一閃、細身の銀蛇が月光のもとに閃めき返るや一緒で、すでにもう怪しの男の頤先に、ぐいと短く抉った刀疵が、たらたら生血を噴きつつきざまれていたので、「痛えッ、疑ぐり深けえ殿様だな」　不意を衝かれて男が言い叫んでいましたが、主水之介が言ったごとく、どうも少し気にかかる奴でした。",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "・手と手　　　妙な握手・夾竹桃・泰山木・藪柑子・かなめの芽　――　――・ひよどり・頬白・きつつき・ひたき・みそさゞい　――　――　六月十五日　雨。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりきいてゐてきつつき　思案にあまって、山路をさまようて、聞くともなく、そして見るともなく、啄木鳥に出逢ったのであった。",
              "citation": {
                "source": "『鉢の子』から『其中庵』まで",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "すずめときつつき　むかし、すずめがせっせと鏡に向かって、おはぐろをつけていますと、おかあさんが死んだという知らせが来ました。",
              "citation": {
                "source": "物のいわれ",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
