        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "りんとして、この世のものとも思えぬ気品がある。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことの貴族には、このやうな無邪気なつくろはぬ気品があるものだ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "純粋に日本の寂びと気品がある。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、お前はそうしていると、蒼ざめていて、気品がある。",
              "citation": {
                "source": "春は馬車に乗って",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "新村教授は本を読む画家の代表として富岡鉄斎をあげて、あの人の画には気品があるといつたさうだが、よしんば気品はあるにしても、鉄斎の画には画家の敏感が少しも出てゐない。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし武劇の名人となると、やはりこう云う離れ業以外に、何処か独得な気品がある。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "とげとげしくて増上の気配があるから、そこに行くと家持の歌の方は一段と大きく且つ気品がある。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "純白な気品があるやうだつた。",
              "citation": {
                "source": "女体",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、川の上流水温の低い荒瀬に棲む、胸に吸盤のない鰍は四季通じて、骨がやわらかく肉に気品がある。",
              "citation": {
                "source": "香魚と水質",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこか犯しがたい気品がある、それでいて、どうにでもしてそれを手折って、ちょっと人に見せたいような、いじらしい風情をした花だ。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "白痴美というのかも知れぬが、口数少く表情に乏しいから、神様の一族のような気品がある。",
              "citation": {
                "source": "神サマを生んだ人々",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "男役について云えば、春日野や神代の現す男性には気品がある。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「写真版では、うまみがよくわからんが、気品があるだろう……。",
              "citation": {
                "source": "町の真理",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "憂愁の底に一種をかし難い気品がある。",
              "citation": {
                "source": "三つの挿話",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "高さ一尺四、五寸の、上のこんもりひらいた壺で、眼識ないものが見たのでは、ただのうすぎたない瀬戸ものだが、焼きといい、肌といい、薬のぐあいといい、さすが蔵帳の筆頭にのっている大名物だけに、神韻人に迫る気品がある。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "細田｜栄之――あれはさすがに出がお旗本の歴々だけあって、女郎をかかしてもなんでも、ずっと気品があるが、そうかといって、大所帯向きのおかみさんにするには痛痛し過ぎる――といってまた、並大抵のものが妾にしては位負けがする……そんなら勝川派はどうだね、何といっても春章はたしかなものだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "みちりやの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "メアリはなんてりりしく、気品があるのだろう。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "説明の文章が文学的に気品がある上に、少女たちの顔つきや、服装も清楚で気もちがいいのである。",
              "citation": {
                "source": "宮崎の町",
                "author": "中村地平",
                "note": "青空文庫"
              }
            },
            {
              "text": "お通には、気品があるが、冷たい美だ。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "国広、康継、虎徹、水心子、それから近頃の直胤――なんどにも劣らぬ作だ』『いやいや、そんな新刀鍛冶の作振とは、懸け離れて、室町、鎌倉期あたりの古人の名作へさえ迫るほどな所がある』『何しても、格が高い、気品がある。",
              "citation": {
                "source": "山浦清麿",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父義朝にどこか似て、より以上、気品がある。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
