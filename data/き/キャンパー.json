        "examples": {
          "standard": [
            {
              "text": "最近は道具にこだわらず、最低限の装備で静かな山を楽しむソロキャンパーが増えているらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "キャンプ場に到着すると、手慣れた様子のキャンパーたちが手際よくタープを設営していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "本格的なキャンパーたちは、自分たちで薪を割り、直火ではなく焚き火台を使って暖をとる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「キャンプ道具のことなら彼に聞け」と言われるほど、彼は知識も経験も豊富なベテランキャンパーだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "キャンパーが、林のなかに、勝手にテントを張る。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
