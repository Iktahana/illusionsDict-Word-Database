    "definitions": [
      {
        "index": 1,
        "gloss": "(being in) hot pursuit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "予は病院の長い、さうして靜かな夜を想像して、一人當分の間其處にこの生活の急追を遁れることが出來ると思つた。",
              "citation": {
                "source": "第十八號室より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして田牧の北方附近にいたるや高坂弾正の急追をうけこれに応戦した。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが彼がだまっていたのは、却って彼の図太さの証拠であると課長は判断してこういう場合にいつも用いる、息をもつかせぬ「急追法」をとった。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「艦隊ハ午後九時二十分北緯四十度東経百三十七度ノ洋上ニ於テ、高度約二千｜米ヲ保チ、南東ニ飛行中ノ敵超重爆撃機四機ヲ発見セリ、直チニ艦上機ヲ以テ急追攻撃セシメタルモ、天暗ク敵影ヲ逸スルオソレアリ」　これで敵機の強さがわかった。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし、あの虹の告げ口だけは、どうすることも出来ません」と法水はさらに急追を休めず、凄気を双眼に泛べて云い放った。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、法水はさらに急追を休めず、「いやどうして、それこそ｜正確な中庸な体系――なんですよ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その夕からはじまった急追を手はじめにして、彼の神経は、あの不思議な三角形――艇長・シュテッヘ大尉・維納の鉄仮面と、この三つを繋ぐ直線の上ではたらきはじめた。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　第二号は、卓上の報告に眼を走らせながら、急追求を緩めない。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "艦隊の速力減じ、急追撃できぬのが残念。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "○○部隊の左翼は○○河の渡河を終り、対岸の敵を急追中であります。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "100429急追せられたるも、奇跡的幸運により、　暗号文は本日完全に獏鸚せり。",
              "citation": {
                "source": "獏鸚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "友軍戦闘機は、これを急追中であります。",
              "citation": {
                "source": "空の悪魔（ラヂオ・ドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、宮奈良へ落ち給う、という情報を掴んだ六波羅では、ただちに追って討ちとれと、大将軍に左兵衛督知盛、頭中将重衡、薩摩守忠度、侍大将に上総守忠清、飛騨守景家を始めとした軍勢二万八千余騎が木幡山を越えて急追した。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第四巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹄の音どうどうと急追する景家は、やがて光明山の鳥居付近でおよそ三十騎ばかり宮を守ってひたすら落ちる一群を見つけた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第四巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、伯爵の急追にかかるとたちまち、チノコは窮し、苦しまぎれに、いうことが裏返ったり、矛盾したりし始めた。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "チロオヌは押し返され、追撃され、急追され、和を提議し、そして降参した。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていよいよ、敵の急追迫るや、ふたたび密かに城を脱して、兵庫の浜から船で海上へ逃げ、毛利家の水軍に投じて、援けを乞うた。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しても、逃げる敵は道を選ばないので、急追した義経のほうも、八方へ分裂して、京都へはいった。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「討ちもらすな」「ひとりも城戸の内へ生かして帰すな」　急追して熄まない源氏の人々は口々にそう云い合った。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも敵は、地理に明るいし、急追、また急追の気負いをゆるめない。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらかたの者は、そこを占拠するや否、なだれを打って麓へ退いた明智勢を急追していた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、用い馴れた十文字の槍をふるい、目ぼしき敵を三名まで引っかけて突き伏せたが、そのたびに、徒歩の家来、堤五兵衛、松田又市、柿権八などを顧みて、「いまの首を取れ」　と、いいつけ、自身はなお、寸間の時も惜しんで急追をつづけていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたがたその城庫には多量な矢石火薬の蓄蔵も必至と見られたので、「まず、城下を焼け」　と命じ、目前に敵府へ迫りながら、敢えて急追の体を見せなかった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "――予は、丑の刻（翌二十日午前二時）より、玄蕃の急追撃にかからん。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜半過ぎからは、いとど中天に冴えて見えた二十日月は、佐久間勢の退路も扶けていたが、急追撃を思う秀吉｜麾下の将士にとってもまた絶好な明るさだった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "卯の刻（午前六時）頃――一斉にまた急追にかかった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「打ちもらすな」　と、追撃して来た徳川勢も、そこの川原まで来ると、内藤四郎左衛門の一手が、横列を作って、各※、槍の柄を横にならべ、「止まれッ」「止まり召されっ」「長追いは相成らぬと、御本陣からの命でござるぞ」「長追いは無用」　と、口々に云って、この急追して来た怒濤をあとへ押しもどした。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "袁紹は勢いに乗じて急追撃に移ったが、五里余りも来たかと思うと、突如、山峡の間から、一｜彪の軍馬が打って出て、「待ちうけたり袁紹。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ぞ」　曹操の急追に、山兵の死骸は、谷をうずめ、峰を紅く染めた。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
