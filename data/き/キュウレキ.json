    "definitions": [
      {
        "index": 1,
        "gloss": "Japan's old (lunisolar) calendar",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "肺結核でそこに転地しているある人を見舞いに行って一晩泊まった時がちょうど旧暦の盆の幾日かであった。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "市民の生活といっても、当時交通不便にして、富士登山が容易でなかったために、旧暦の六月｜朔日には、市中と郊外にある富士山の形に擬えた小富士や、富士権現を勧請した小社に、市民が陸続参詣した。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧暦｜十六夜の月が赤く森から出る。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが旧暦だと朝晩はぐっと冷えて来るんですがね」　老人は又むかしのお月見のはなしを始めた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　旧暦のお正月の頃で、港町の雪道は、何か浮き浮きした人の往き来で賑わっていた。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　旧暦六月二十六日の晩でした。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　旧暦六月二十六日の晩でした。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旧暦八月十七日の晩、おらは酒のんで早く寝た。",
              "citation": {
                "source": "ざしき童子のはなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――夜泣松の枝へ、提灯を下げまして、この……旧暦の霜月、二十七日でござりますな……真の暗やみの薄明に、しょんぼりと踞んでおります。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "重兵衛　旧暦の十三夜ですよ。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年甲　その男は東京の日本橋で稲川という酒屋の息子だが、先月の十七日、旧暦の十五夜の晩に、なじみのカフェーの女給を向嶋へ連れ出して、ピストルで撃ち殺したんだ。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　旧暦に依る此土地では、正月は恰も大雪の最中である。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあいだに夏も過ぎ、秋が来て、旧暦では秋の終りという九月になった。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃はまだ旧暦の秋もおいおいに暮れかかって、深川には時雨めいた空が幾日もつづいた。",
              "citation": {
                "source": "深川の老漁夫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧暦のお正月だといふのに、百姓は田を耕やしたり、畑を打つたり、洗濯をしたり、大根を刻んだりしてゐる、こゝにも農村窮乏の色が見えるといへるだらう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程考へてみれば、朔といふ字は、元来旧暦の暦から取つた字であるから、今の新暦しか知らない若い人には、平常慣れない怪異な文字であるかも知れない。",
              "citation": {
                "source": "名前の話",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "閏のあった年で、旧暦の月が後れたせいか、陽気が不順か、梅雨の上りが長引いて、七月の末だというのに、畳も壁もじめじめする。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧暦は盂蘭盆の十五日、ちょうど今夜は満月である。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨイヨイヨイのヨイヨイヨイだ」　この夜こそ旧暦の盂蘭盆であった。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さっきの話は旧暦の除夜だったと君は云ったから、丁度今日が七回忌だ。",
              "citation": {
                "source": "鼠坂",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧暦の三月であるから、ひとえの桜はもう花ざかりで、上野から浅草へまわる人跫のしげき時節である。",
              "citation": {
                "source": "異妖編",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵の地方はそうであるが、ここらも町は新暦、近在は旧暦を用いているので、その頃はちょうど旧盆に相当して、近在は盆踊りで毎晩賑わっていた。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことで暇取って大森を出た二挺の駕籠が今や鈴ヶ森に近くなった頃には、旧暦の九月の日は早くも暮れかかって、海辺のゆう風が薄寒く身にしみた。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　三月といっても旧暦だから、陽気はすっかり春めいていた。",
              "citation": {
                "source": "鯉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は旧暦の七月二十六夜だ。",
              "citation": {
                "source": "月の夜がたり",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん考えてみると、それが一年に一度、しかも旧暦の八月十五夜に限られていて、当夜が雨か曇りかの場合には姿をみせない。",
              "citation": {
                "source": "月の夜がたり",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年は信州の雪も例年より早く解けて、旧暦三月末の木曾路はすっかり春めいていた。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧暦の十月であるから、この頃の朝は寒い。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年の五月はとかく陰り勝ちで、新暦と旧暦を取り違えたのではないかと思われるような五月雨めいた日が幾日もつづいた。",
              "citation": {
                "source": "有喜世新聞の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
