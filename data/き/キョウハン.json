[
  {
    "uuid": "8040682f-93b9-56de-b73e-c7ae94f3f004",
    "entry": "共犯",
    "reading": {
      "primary": "きょうはん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "complicity",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は強盗事件の共犯として逮捕された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "共犯者の一人が証拠隠滅を図っているらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "主犯格は逮捕されたが、共犯者の行方はまだ掴めていない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "共犯といっても、役割や関与の度合いによって罪は異なる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "共犯嫌疑者田代公吉は弁護士梅島君のところに、不都合にも、「かくまわれ」ていて、そうして懸命に彼の社長殿と夕刊嬢とを捜している。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために、逮捕せられ、あらゆるひどい拷問に付せられたが、共犯者を白状しなかった。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが自らの身の上に及んで来て、共犯者だと云はれて、否応なしに令状を執行されて、極重悪人の罪名を附せられた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "たといどんな理由にもせよ、共犯の疑なぞかけられて巻き込まれたりしては大変だと考えました。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "御前様が押し切ろうとしている、あるいは共犯のインド人からすぐにでも通りにいた警察がやってくると聞いていたのかもしれぬ。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "家のなかへは共犯者が案内しました。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事をやり終えると急いで逃げて、玄関は共犯者に内側から閂をかけてもらった、というわけです。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし彼が自ら来なくとも、共犯者を送り込んでこよう。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの老婆は共犯者に相違ない。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "指輪を肌身離さず、やつとその共犯者を二大陸にわたって追いかけ、ついに捕まえました。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何者ですか、広告を受けて指輪を取りに来たあの共犯者は。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "共犯者の髪の色を見て思いついたに相違ない。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "懸賞金を発表している公告のなかには、共犯者であっても、仲間にそむいて証人として出頭する者は、完全に無罪とするということが約束されていた。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな懸賞金がかけられ、また自己の犯罪を自白して共犯証拠を出す者は完全に無罪にされる、というような事情の下にあって、下等な悪党の一団の誰かが、あるいはどんな団体の人間だってそのなかの誰かが、もうとっくに共犯者を密告していないということは、ちょっとでも想像できないことだよ。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれも共犯者であるらしいことは御用聞きも薄々察したであろうが、密告の功によって彼は自由に土地を立ち退くことが黙許された。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪い弟を持った為に、本家は飛んだ迷惑、思えば気の毒でした」「そうすると、黒松という弟子も共犯ですね」「師匠の指図で忌とも云えなかったのでしょう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "薄雲の碁盤",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は共犯者を作りたくなかったのである。",
              "citation": {
                "source": "東京八景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実情を知りながら送金したとなれば、兄たちは、後々世間の人から、私の共犯者のように思われるだろう。",
              "citation": {
                "source": "東京八景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰が主犯で、誰が共犯か？",
              "citation": {
                "source": "石塀幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋森家の双生児と殺された女との醜関係から、警察が双生児に持たせた犯罪の痴情的動機を、僕は逆にそうして極めて自然に、女の夫である戸川弥市に持たせたまでさ」「じゃあいったい、もう一人の共犯者は？",
              "citation": {
                "source": "石塀幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "共犯なんて始めからないよ」「待って下さい。",
              "citation": {
                "source": "石塀幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の云うその共犯者はあの石塀の奇蹟と非常に深い関係があるんだ。",
              "citation": {
                "source": "石塀幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "金貸しが不徳だというなら、金貸しから金を借りる者も共犯者のわけだ。",
              "citation": {
                "source": "或る探訪記者の話",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「滝口君にしても、大森君にしても――」　と、共犯格と見なされている奴の名をあげた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うるさい、おまえは共犯だ」「共犯てなによ、人殺しなら、まだしてないわよ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえも慶一の共犯か」　高志はぶっきらぼうにいって、令子と、そのブルーの包みを見くらべている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高飛び、素早い逃走、共犯者なし、貴族趣味――こういったやり口が、ミスター・ヴァレンタインを罪からうまく逃れる男として、有名にさせたのだ。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "独房――「No. 19.」　共犯番号「セ」の六十三号。",
              "citation": {
                "source": "独房",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
