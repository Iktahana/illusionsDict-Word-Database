          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いっそまた鳥羽へ行って、あの巌に掴まって、（こいし、こいし、）と泣こうか知らぬ、膚の紐になわつけて、海へ入れられるが気安いような、と島も海も目に見えて、ふらふらと月の中を、千鳥が、冥土の使いに来て、連れて行かれそうに思いました。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたは二晩ほどお休みになりませんね」　とホームズは彼独特の気安い愛想のよい調子で云った。",
              "citation": {
                "source": "黄色な顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京では女ひとりの所帯はたいへん気安いとかいいますから……」　予は突然打ち消して、「とんでもないことです。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃ東京では針仕事のできる人なら身一つを過ごすくらいはまことに気安いには相違ないですが、あなたは身分ということを考えねばなりますまい。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　父と愛子との問題もあつたには違ひないが、一年休んでゐるうちに彼自身学校が厭になつて、もつと気安い世間並の生活に取りつかうとしたことは明らかであつた。",
              "citation": {
                "source": "歯痛",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "結句船の中の人たちから度外視されるのを気安い事とまでは思わないでも、葉子はかかる結果にはいっこう無頓着だった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は結局それを気安い事にして、その新聞を持ったまま、自分の部屋に帰った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "信一郎は結局それを気安いことに思った。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "信一郎は結局それを気安いことに思つた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は彼は社長につれ立つて、乗馬を見に丹後の方へ行つてゐたので、土井は結局気安い思ひで、独りでぶら／＼町へ出て行つた。",
              "citation": {
                "source": "閾",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "展開されゆく道中の景色を楽しく語合うことも出来ますし、それに一人旅のような無意味な緊張を要しないで気安い旅が出来るように思います。",
              "citation": {
                "source": "愛と平和を理想とする人間生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "登記万端のことなど店のものにいい附けますから」というような至極自由な話、私もこれならば気安いと思いました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "初めて家持ちとなったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はひとり北へ、途中行乞しつゝ高鍋まで、一時過ぎに着く、二時間ばかり行乞、此宿をたづねて厄介になる、聞いた通りに、気安い、気持よい宿である。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿はよくない、たゞ気安いのが何よりだ、アグラをかいて飲んだ、酒はよかつた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "お土産は小雑魚よりも浅蜊、蛤の類、手に手に破れ網の古糸をすき直して拵えたらしい提げものに一ぱいを重そうにして、これ留守居や懇意へのすそ頒け、自分は喰べずとも綺麗さっぱり与ってしまった方が結句気安いようで、疲れて寝る臥床の中に、その夜の夢は一入平和である。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "遮莫、物に執着するはかれらの最も潔しとせぬところ、さればぞ初袷の二日三日を一年の栄えとして、さて遂には裸一貫の気安い夏をも送るのである。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそ宣り出て討たれようか、その方がどんなに気安いかしれない。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この世かぎりでない契りをおささやきになるのを聞いていて、思いがけず結ばれた人とはいえ、かえってあの冷静なふうの中納言を良人にしたよりはこの運命のほうが気安いと女王は思っているのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "総角",
                "note": "青空文庫"
              }
            },
            {
              "text": "中納言が主人がたの座敷に住んでいて、どの女房をも気安いふうに呼び使い、みずから指図をしながら宮へ朝餐を差し上げたりさせるのを御覧になって、恋人を失ったあとのこの人の生活を気の毒にもお思いになり、趣のあることとも御覧になった。",
              "citation": {
                "source": "源氏物語",
                "author": "総角",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして結局夜遊びから自宅へ帰って来た男のような、気安い歩調でつかつかと隣室へ入って行った。",
              "citation": {
                "source": "空家",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ、妻と二人で飢えた方が、どんなにか気安いのだ。",
              "citation": {
                "source": "朝夕",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "富岡はさつさと、湯気のたちこめてゐる湯殿へ這入つて行つたが、六七人の老若もみわけがたい男女が、タイル張りの広い浴槽にはいつてゐる賑やかさに気安いものを感じた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かしらほっとしたような気安い気持になって、いきなり男の胸に顔を埋めてしまった。",
              "citation": {
                "source": "橋",
                "author": "池谷信三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大工の棟梁――」「心得ほどのことならば――」と、それはどこにでも居ると云う気安い返事であった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは国に居た時に、朝起きても筆、夜が更けても筆、祭も、日曜も、春秋も、休む間無しに筆とつて、小鳥に餌をば遣るやうな気安い時を持たなんだ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは何か云つてゐた、気が狂ふので無いか知ら……どうして気安いことがあろ、ああ、気に掛る、気に掛る、子供の事が又しても……せはしい日本の日送りも心ならずに執る筆も、身の衰へも、わが髪の早く落ちるも皆子ゆゑ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にまた気安い軽蔑を感じた。",
              "citation": {
                "source": "春",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "（父母もなければ兄弟もなく、親戚もないということが、こんな場合にはかえって気安い）　しかし時にはそういうことが、寂しみとなって感ずることもあった。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "所の郷士千村家からお信乃という格好の妻も迎え、今年三才になる男の子まで儲けて、気安い身分となっていた。",
              "citation": {
                "source": "稚子法師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はただ彼女の身の周囲から出る落ちついた、気安い、おとなしやかな空気を愛したのである。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
