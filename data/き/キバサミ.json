        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "庭師の父は、仕事が終わると必ず木鋏のヤニを落とし、丁寧に油を差して手入れを欠かさない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「いいかい、木鋏は枝の付け根に刃を当てて、引き切るように使うんだ」とコツを教わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長年使い込まれた木鋏の持ち手には、使う人の手の形に合わせて独特の艶が出ている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "途端にチヤキ／＼木鋏の音がする。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとうに、いい住居、あんた一人じゃあ、勿体ないようねえ」　かの女はそういいながら、うっかりしたことを云い過ぎたと、むす子の顔をみると、むす子は歯牙にかけず、晴々と笑っていて、「いいものを見せましょうか」と、台所から一挺日本の木鋏を持ち出した。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は脊が高かつたから、踏臺なしに、ぱちんぱちんと植木鋏で葡萄のふさを摘んだ。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "片手には、頑丈な、錆の出た、木鋏を構えている。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し彼女は、右手に、鋭利な大型の木鋏を握って、すっぽんが首を出すのを待たなければならなかった。",
              "citation": {
                "source": "指",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はその首を木鋏で切断した。",
              "citation": {
                "source": "指",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "土掻や、木鋏や、鋤鍬の仕舞われてある物置にお島はいつまでも、めそめそ泣いていて、日の暮にそのまま錠をおろされて、地鞴ふんで泣立てたことも一度や二度ではなかったようである。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭に鍔広の帽子を被って、背中に山や沼を吹き越して来る涼風を受けながら、調子付いてショキリショキリと木鋏を動して居ると、誰か彼方の畑道を廻って来た人がある。",
              "citation": {
                "source": "麦畑",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は「今日は、なかなか暑うございますねと声をかけて、片手に木鋏を下げ、片手で顔の前に下った帽子の鍔を持上げた。",
              "citation": {
                "source": "麦畑",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "縫台の上の竹筒に挿した枝に対い、それを断り落す木鋏の鳴る音が一日していた。",
              "citation": {
                "source": "洋灯",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ古い問の代りに新らしい問を芽ぐませる木鋏の役にしか立たぬものである。",
              "citation": {
                "source": "少年",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬丁のオカドが右手に木鋏を持つて、そのそばに立つてゐる。",
              "citation": {
                "source": "「追憶」による追憶",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "西の端に唯一本｜木鋏を免れた其杉苗が、今は高さ二丈五尺、幹の太さは目通り一尺五寸六分になりました。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ははははは」　「まるで※駝師でね、木鋏は放しませんよ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "加藤の伯父さんは相変わらず木鋏が手を放れ申すまじきか。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ははははは」「まるで※駝師でね、木鋏は放しませんよ。",
              "citation": {
                "source": "小説　不如帰",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "久保田さんは小さな木鋏を取ってきて、植込の枯枝を切ったりなんかしながら、朝食までの時間を庭で過した。",
              "citation": {
                "source": "人の国",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、日記をもとの場所へしまひ、木鋏をもつて庭へ降りた。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、片手に木鋏を持ち、片手にいく本かの山百合を提げた斎木素子であつた。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿な事ぢやねえ、娘の敵を討つんだ、退いてくれ」　腰から拔いた植木鋏を當座の武器に、新助目がけて振り冠つたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死の矢文",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰が斯んな事をした」　死骸の側に投り出されたのは、使ひ古した植木鋏が一挺、碧血に染んで、この下手人を物話つて居さうです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死の矢文",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな事だらうと思つたから、神田からひと飛にやつて來たよ」「有難てえ、親分」「どんな事があつたんだ」「松五郎が、お通夜に來た新助を、木戸のところで植木鋏で突き殺したんで――」「そんな馬鹿なことがあるものか」　平次もすつかり面喰つた樣子です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死の矢文",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘三は二梃の鎌に同じ二丁の木鋏に砥石を當てては、これが女房かといふ顏附で、ミツの肌脱ぎを客觀的に折々打ち眺めた。",
              "citation": {
                "source": "神のない子",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿な事じゃねえ、娘の敵を討つんだ、退いてくれ」　腰から抜いた植木鋏を当座の武器に、新助目がけて振りかぶったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死の矢文",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　その晩、お通夜へ行ったはずの新助が、木戸の外で、植木鋏で喉を突かれて死んでいたのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死の矢文",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰がこんな事をした」　死骸の側に投り出されたのは、使い古した植木鋏が一挺、碧血に染んで、この下手人を物語っていそうです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死の矢文",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾時独武者、杖をわきばさみ、兜を脱いで、「ええ、何んですかな、」と曖昧。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
