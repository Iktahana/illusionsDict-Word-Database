[
  {
    "uuid": "f98382b4-5b7e-54a4-9254-243b8745a252",
    "entry": "器械体操",
    "reading": {
      "primary": "きかいたいそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
