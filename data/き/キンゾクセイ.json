[
  {
    "uuid": "8f21ae46-d8f2-5d78-b3a4-ffafd4014ea0",
    "entry": "金属製",
    "reading": {
      "primary": "きんぞくせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
