    "definitions": [
      {
        "index": 1,
        "gloss": "canary (esp. the island canary, Serinus canaria)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
