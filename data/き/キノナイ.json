    "definitions": [
      {
        "index": 1,
        "gloss": "indifferent",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ああ、そう」と、彼はスマホから目を離さずに気のない返事をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "何度熱心に誘っても、彼女は気のない素振りを見せるばかりで一向に興味を示さない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "準備不足なのが丸わかりな、気のないプレゼンにガッカリしたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ふーん、勝手にすれば」なんて、そんな気のない言い方しなくてもいいじゃない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "佐竹は立ったまま、老人のように生気のない声でぼそぼそ私に話しかけたのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が這入つた時、教師達は誰も話をしてはゐなかつたが、それと知ると其処にゐた全部の者は一斉に、不馴れな人間に対する心意気のない、畏敬の表情を作つて差向けてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして学校に来ては、愛顔の好い教師程気になつた、邪気のない生徒程、その顔を見れば憎らしく感じた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "人気のない深夜の町を、ひとり足音高く通って行く。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち例へば「古池」といふ言葉は、日本人の連想からは直ちに古い寺院の池や、庭園などにある閑雅で苔むした小さな溜水の池をイメーヂするが、温気のない西洋にはそんな古池が無いのであるから、西洋人のこの語から連想するイメーヂは、アルプスやスヰスの山中などにある、青明に澄んだ大きな湖水であるだろう。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーテンを上げて覗いてみると、人気のない深夜の裏通りを一台の雪橇が辷って行く、と思う間もなく、もう町のカーヴを曲って見えなくなってしまった。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「揃って帰っちまやがったじゃないか」　コーターマスターは、コムパスを力委せに蹴飛ばしながら、「サア」と、気のない返事をした。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人間の心が蒸発して霞になりそうな日だね」と言ったら、一｜間ばかりあとを雪駄を引きずりながら、大儀そうについて来た妻は、エヽと気のない返事をして無理に笑顔をこしらえる。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなら何度やっても同じことなのだ」　仕事であれ、男女の間柄であれ、混り気のない没頭した一途な姿を見たいと思う。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "米八が『春色恵の花』のうちで「そんな色気のないものをたべて」と貶した「附焼団子」は味覚の効果をほとんど味覚だけに限っている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし白粉気のない顔の表情はどこかそこらの高等女学校生徒などと比べては年の割にふけて見えるのである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも色のさえない元気のない面長なお松の顔は深く自分の頭に刻まれた。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何にも元気のない風で夜のせいか顔色も青白く見えた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互に気のない風はしていても、手にせわしい仕事のあるばかりに、とにかく思い紛らすことが出来た。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは藁苞のような恰好をした白鳥が湿り気のない水に浮んでいたり、睡蓮の茎ともあろうものが蓮のように無遠慮に長く水上に聳えている事もある。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "よにもさびしい私の人格が、おほきな声で見知らぬ友をよんで居る、わたしの卑屈な不思議な人格が、鴉のやうなみすぼらしい様子をして、人気のない冬枯れの椅子の片隅にふるえて居る。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎を恐るわたしは田舎をおそれる、田舎の人気のない水田の中にふるへて、ほそながくのびる苗の列をおそれる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはいつでも、人気のない寂しい海岸を歩きながら、遠い都の雑閙を思ふのがすきだ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小初は気のない顔をして少しずつ集って来る生徒達に応待していたが、助手格の貝原が平気な顔で見張船の用意に出かけたりする働き振りに妙な抵抗するような気持が出て、不自然なほど快活になった。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍医は、診断にやって来る兵士が、どれもこれも哀れげな元気のない顔をしているのを見た。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、後年の自然主義作家としての飾気のない、ぶっきら棒な、それでいて熱情的な文章は、この通信に、既に特色を現わしている。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "くずれた壁の下にこおろぎが鳴いて、火の気のない空家は薄ら寒かった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村は、軽い元気のない咳をした。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二｜馬路通りに、乱れた、元気のない、跛をひくような蹄の音がひびいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝床はもう一組おなじ炬燵に敷いてあったが、旅僧はこれには来らず、横に枕を並べて、火の気のない臥床に寝た。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と一向気のない、空で覚えたような口上。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "座にその鰯の臭気のない内、言わねばならぬ事がある……「あの、平さん。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "背には綿の厚い、ふっくりした、竪縞のちゃんちゃんを着た、鬱金木綿の裏が見えて襟脚が雪のよう、艶気のない、赤熊のような、ばさばさした、余るほどあるのを天神に結って、浅黄の角絞の手絡を弛う大きくかけたが、病気であろう、弱々とした後姿。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "永久性と落着きのないのは、この辺の天然の反対である。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は何か知ら落ち着きのない樣子で、テエブルを挾んで私と向ひ合せに腰を降したが、直ぐまた立ち上つた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
