[
  {
    "uuid": "3447aeb8-1207-545c-9564-b3e4990f32b2",
    "entry": "謹慎",
    "reading": {
      "primary": "きんしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
