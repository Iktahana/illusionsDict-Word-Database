        "examples": {
          "standard": [
            {
              "text": "「先生、今日の聖書のお話、すごく面白かった！」と子供たちが目を輝かせていた。教会学校の先生冥利に尽きるね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "教会学校では、聖書の話だけでなく、歌やゲームを通して神の愛を学ぶ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供たちは教会学校で聖書を学んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "教会学校の子供たちが、自分たちで作った飾りで教会を彩った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "爾来卅年ばかり兼三は教頭を勤めていたが、かような教会学校では老後を保護してくれる見込もないので、遂に東京に帰って来て他に生計を求めたけれどやはり適当な事業もないので、旧友の押川方義氏や上代益男氏等の周旋に依って、更に布哇へ移住し、児童に日本語を教える学校の教師となった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            }
          ]
        }
