    "definitions": [
      {
        "index": 1,
        "gloss": "chance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新しい趣味を始める切っ掛けになったのは、友人の誘いだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その出会いが、彼女の人生を大きく変える切っ掛けとなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "些細な一言が喧嘩の切っ掛けになることもある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は病気を切っ掛けに健康に気を遣うようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それが切っ掛けで腹膜になり、大学病院へ入院した。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "見せかけはそうでも、しかし、肩に手をのせただけで冴子を帰したのは、やはり内気だったからだ、いい子になろうとしていたとも言えるが、しかし、肩にのせた手をすぐはなしてしまい、ぐいと引き寄せる切っ掛けを、ついに作れなかったというのは、インテリらしい気の弱さだろう。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "切っ掛けさえあれば、平気で悪い子にもなれるのだ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "冴子の言葉が、途端に切っ掛けを与えてくれたからだ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日はそんなに引きとめないということをほのめかして、冴子に安心を与えようとしたのか、それとも、二時に出掛けるという嘘が、明日冴子と会っている時の信吉自身に、何かの切っ掛けか口実を与えてくれることに、期待を掛けたのか。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かの拍子に、裾が乱れて浅黒い脛がちらと見えた、それが切っ掛けで、口説いて、というより殆んど行動に訴えたら、脆かった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "千恵造の出奔を切っ掛けとして、児子家は以後多事多端であった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、ひとり、庄屋の娘で、楓というのが、歌のたしなみがあって、返歌をしたのが切っ掛けで、やがてねんごろめいて、今宵の氏神詣りにも、佐助は楓を連れ出していたのだ。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐伯のいう切っ掛けとはこの時に掴んだものだろうか。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉妹もふだんから西山を可愛がっているので、傍へ寄って何か話しているうちに、どういう切っ掛けで何を言い出したのか知りませんが、要するに西山がふたりの娘にむかって、突然に淫らなことを言い出したんです。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かの切っ掛けを見付けて、ひと思いに切り付ける工夫をしなければならないと思った。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう、鳥にとってはおそらく生れて以来かつて経験した事のない異常な官能行使の要求に応じるに忙しくて、身に迫る危険を自覚し、そうして逃走の第一歩を踏出すだけの余裕もきっかけもないのであろう。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の祖神が没くなるとまもなく子が無いことを託っていた筑波の岳神夫妻の間にこれをきっかけに男女五人ほどのこどもができた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と叫んだのをきっかけに、平土間の群衆騒然たり。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "中津の掠奪が市街戦のきっかけとなった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそのうちに何かのきっかけで「Ａの気持もよくわかっていると云うのならなぜ此方を骨折ろうとしないんだ」という言葉を聞きました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたあとで、テナシティのデッキの上から「あしたは出帆だ」とどなるのをきっかけに、画面の情調が大きな角度でぐいと転回してわき上がるように離別の哀愁の霧が立ちこめる。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャンスという異国語はこの場合、日本に於いて俗に言われる「ひょんな事」「ふとした事」「妙な縁」「きっかけ」「もののはずみ」などという意味に解してもよろしいかと思われるが、私の今日までの三十余年間の好色生活を回顧しても、そのような事から所謂「恋愛」が開始せられた事は一度も無かった。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝てもさめても、れいの「性的煩悶」ばかりしている故に、そんな「もののはずみ」だの「きっかけ」だのでわけもなく「恋愛関係」に突入する事が出来るのかも知れないが、しかし心がそのところに無い時には、「きっかけ」も「妙な縁」もあったものでない。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくの如く、心に色慾の無い時には、「きっかけ」も「もののはずみ」も甚だ白々しい結果に終るものなのである。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめから、そのつもりで両方が虎視眈々、何か「きっかけ」を作ろうとしてあがきもがいた揚句の果の、ぎごちないぶざまな小細工に違いないのだ。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "心がそのところにあらざれば、脚がさわったって頬がふれたって、それが「恋愛」の「きっかけ」などになる筈は無いのだ。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一夜に三つも四つも「妙な縁」やら「ふとした事」やら「思わぬきっかけ」やらが重って起っても、一向に恋愛が成立しなかった好例として、次のような私の体験を告白しようと思うのである。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その要件の話がすんだあとで、いろいろ雑談をしているうちに、どういうきっかけであったか、先生が次の間からヴァイオリンを持ち出して来られた。",
              "citation": {
                "source": "田丸先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「日本服を改良しましょう、すぐしましょう」と書いた旗が、どういうきっかけだったか、その瞬間に柿江の眼にまざまざと映って、それが見る間に煙のようにたなびいて消えていった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなむずかしい計算をしなければこれは分らないのですか」　と新井田氏がそのきっかけをさらって口を入れた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小母さんはそのきっかけにおぬいさんに何かいおうとしたらしかったが、思い返したか、心｜許なげな眼つきでその後姿を目送しただけで何もいわなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファニーは前から戸の間ぎわまで来ていたのにきっかけを待って出てこなかったのだと知った私は、ちょっと勝手が違うような心持ちがした。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめ先生にひどく楯を突いた生徒が、何かのきっかけでうって変った仲好しになり、卒業後も永く交際を続けて行く例など、案外たくさん聞くことです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（目※連の再度の言葉をきっかけに、阿難、娘に取り縋られたまま、宙釣りになって空中へ上って行く。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
