  {
    "uuid": "879ac9bc-b318-5c4f-ae90-a082cebe630e",
    "entry": "希望的",
    "reading": {
      "primary": "きぼうてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
