          "literary": [
            {
              "text": "共産なんて文字に世間の人達が、そんなにまで気を病むなんて、妙なものですな。",
              "citation": {
                "source": "私有農場から共産農団へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがこうした純然たるジェスチュアや服装について気を病むのも、決して単に風紀問題としてではないのである。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "……前から気を病むに及ぶものか。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう気を病むな、鬱するな。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
