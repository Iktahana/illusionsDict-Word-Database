[
  {
    "uuid": "0c603930-9330-50b6-bf50-ed4b9f835022",
    "entry": "極小",
    "reading": {
      "primary": "きょくしょう",
      "alternatives": [
        "ごくしょう"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
