[
  {
    "uuid": "c8097a39-624a-59e1-b7a5-bd7209d9fd30",
    "entry": "傷つける",
    "reading": {
      "primary": "きずつける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
