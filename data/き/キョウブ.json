          "literary": [
            {
              "text": "船越村は釜石の北方約二十キロの地峡部にある村である。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでにわかに思い立って、きょうぶらりとやってきたが、はたしてこのさわぎ……」　小文治は居士の話にいろいろな疑念をはさんだ。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また京の鞍馬山から武州まで、きょうぶらりとやってきたというのも、自分の聞きちがいのような気がした。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
