        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "科学がキャピタリズムやミリタリズムやないしボルシェヴィズムの居候になっているうちは、まあ当分見込がなさそうに思われる。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時代の有様は、法王の圧迫、キャピタリズムの圧迫と代っては居るけれども――地獄天国の感と自由人、自由社会対誤れる文明、コンマアシャリズム――となっては居るが、根源の、よきもの、愛、神の正しさを追求する魂の方向に変りはない。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本勉強　○労働組合法案　○小作法案について、　キャピタリズムの国の教育家の位置。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に、海外ニュースにミリタリズムやキャピタリズムの映画にストーシュカ〔たたく音〕を入れたのなど、どうしてエイゼンシュテインのおかめとまけぬ皮肉さだ。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャピタリズムの生命を延ばせば延ばす程、失業と貧困とは彼等に蔽いかぶさって来る。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャピタリズムが一つの資本主義であると同じ意味で、ジャーナリズムは一つのイズム・主義だと云ったような、妙な錯覚か愚にもつかぬ洒落かに之は相応しているのだ。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化帝国の文学主義というキャピタリズムにとって、本能的に恐れを催させるものだ。",
              "citation": {
                "source": "ひと吾を公式主義者と呼ぶ",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
