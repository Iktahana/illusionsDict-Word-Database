    "definitions": [
      {
        "index": 1,
        "gloss": "being struck with awe",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこで震の大象伝にも、君子以て恐懼修省すとある。",
              "citation": {
                "source": "震は亨る",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐懼修省の工夫が有れば、以て宗廟社稷を守り、以て祭主と為るべきである。",
              "citation": {
                "source": "震は亨る",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "震前の一般社会の一切の事象を観るに、実に欠けてゐたものは、恐懼修省の工夫であつた。",
              "citation": {
                "source": "震は亨る",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝに於て恐懼修省することを為せば、実に幸である。",
              "citation": {
                "source": "震は亨る",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ恐懼修省の工夫を為すべきである。",
              "citation": {
                "source": "震は亨る",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "冤に泣く民の一人にても存在すると云ふことは聖代の歴史の一大汚辱なりとして恐懼自戒措く能はざる人人である。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、僕の最も暗黒時代で、未だ一家を支へるだけの腕はなし、頭は固らず、讀んで修養すべき書物はなし、不安恐懼に滿ちた生活をして居た。",
              "citation": {
                "source": "自傳",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "震たゞ恐懼して落涙｜止まらざるあるのみ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は恐懼て日光を見ず、もし強いて戸を開きて光明その膚に一注せば、渠は立処に絶して万事｜休まむ。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夜、無禮講とて御手づから御酒賜ることしきりなれば、初めはひたに恐懼しまつりたれども、後には陶然として、わが歌謠など御耳に入れ奉りぬ。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夜、無礼講とて御手づから御酒賜ることしきりなれば、初めはひたに恐懼しまつりたれども、後には陶然として、わが歌謡など御耳に入れ奉りぬ。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐懼した慶喜は、勘定奉行に命じて、直ちに五万両を朝廷に奉つてゐるのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "神社はもっとも皇族に関係深ければ一切保存して徐々に詮議すべきに、無茶苦茶に乱滅しおわるは、あたかも皇族華冑の遺跡が分からぬうちに乱滅するは結句厄介払いというように相聞こえ、まことに恐懼憤慨の至りなり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とも仰せがないので、僧都は進んで秘密をお知らせ申し上げたことを御不快に思召すのかと恐懼して、そっと退出しようとしたのを、帝はおとどめになった。",
              "citation": {
                "source": "源氏物語",
                "author": "薄雲",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴婦人もはや返さんとするとともに恐懼は忽ちその心を襲へり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内せい」　心得て六兵衛が恐懼しながら導いていったところは、ガヤガヤと黒集りになって人々が打ち騒いでいる奥庭先です。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも主侯自ら腰を低めて恐懼措く能わないといったように、倉皇としながら小走りに、近よると、釣りの御前の遙かうしろに膝をこごめて、最上級の敬語と共に呼びかけました。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は堪えがたい恐懼と煩悶とにひと月あまりをかさねた末に、彼は更に最後の審判をうけるべく怖ろしい決心を固めた。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁は恐懼のあまりに病いを獲て死んだ。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "輟耕録",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは思考す、而して其思想を定かならぬ恐懼の語に述ぶ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "心配、恐懼、喜悦、感慨、希望等に悩まされて従来の病体ますます神経の過敏を致し日来睡眠に不足を生じ候次第愚とも狂とも御笑い可被下候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐懼である、悚然として粟を肌に吹く要素になる。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、陛下には、いろいろこの彫刻の急所々々を御下問になるので、岡倉校長は、一々お答えを申し上げたが、実に御下問の条々が理に叶って尋常のお尋ねではないので、岡倉校長は恐懼致されたと、後に承ったことで御座いました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "木彫の楠公を天覧に供えたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "心配、恐懼、喜悦、感慨、希望等に悩まされて従来の病体益※神経の過敏を致し、日来睡眠に不足を生じ候次第、愚とも狂とも御笑ひ可被下候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "心配、恐懼、喜悦、感慨、希望等に惱まされて從來の病體益※神經の過敏を致し日來睡眠に不足を生じ候次第愚とも狂とも御笑ひ可被下候。",
              "citation": {
                "source": "歌よみに與ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "この御下命を得ました当時は、皇太后陛下がまだ皇后陛下でいらせられた際のことであり、考えてみますと、筆者の私としましても深い感慨に打たれまして、まことに恐懼の念に堪えないしだいでございます。",
              "citation": {
                "source": "あゝ二十年",
                "author": "――やっと御下命画を完成した私のよろこび――",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何にも明治聖帝としては、畏れ多いことながら、わが御身にひきかけ給うて、千萬無量の御實感、御感慨であつたらうと、文字を拾ひ讀んでゐるうちに、おのづと瞼がほてつて、それこそムシケラにも價しない自分如きに相應しからぬが、私はたうとう恐懼の涙を堰止め得なかつた。",
              "citation": {
                "source": "滑川畔にて",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだろうな、きょうくりあげて、乃武江にそのお宿下がりをもらうわけにいくまいかな」「え？",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "明の癖で、彼女の上へ目を注ぎながら、彼女を通してそのもっと向うにあるものを見つめているような眼つきを肩の上に感じながら……　しかし、そんな明の眼つきがきょうくらい遠くのものを見ている事はなかった。",
              "citation": {
                "source": "菜穂子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしゃきょうくらい、恥をかいたこたァありゃしない。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
