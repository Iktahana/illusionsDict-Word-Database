    "definitions": [
      {
        "index": 1,
        "gloss": "second month of the lunar calendar",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今年｜如月、紅梅に太陽の白き朝、同じ町内、御殿町あたりのある家の門を、内端な、しめやかな葬式になって出た。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「ええ、私あの時の事を思出したの、短刀で、ここを切られた時、」……　と、一年おいて如月の雪の夜更けにお染は、俊吉の矢来の奥の二階の置炬燵に弱々と凭れて語った。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は貴下が七歳の年紀、お傍に居たお友達……過世の縁で、恋しう成り、いつまでも／＼、御一所にと思ふ心が、我知らず形に出て、都の如月に雪の降る晩。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「三映キネマの如月真弓という女優だよ。",
              "citation": {
                "source": "殺人迷路",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの、鍋からさらさらと立った湯気も、如月の水を渡る朝風が誘ったので、霜が靡いたように見えた、精進腹、清浄なものでしょう。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "如月十九日の日がまともにさして、土には泥濘を踏んだ足跡も留めず、さりながら風は颯々と冷く吹いて、遥に高い処で払をかける。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅梅の咲く頃なれば、かくまでの雪の状も、旭とともに霜より果敢なく消えるのであろうけれど、丑満頃おいは都のしかも如月の末にあるべき現象とも覚えぬまでなり。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これさえ夢のごときに、胸を轟かせながら、試みに叩いたが、小塚原あたりでは狐の声とや怪しまんと思わるるまで、如月の雪の残月に、カンカンと響いたけれども、返事がない。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "旗艦「山城」が、一等巡洋艦「鳥海」「高雄」「摩耶」「愛宕」航空母艦「赤城」以下、第十駆逐隊「狭霧」「漣」「暁」を随へ、仄かなる春の霞みが岬の彼方に煙り初めたとは云へ、未だ如月の夢深い曙の波を蹴立てゝ、威風堂々、○○方面を指して遠洋航海の碇を巻いたのは、あの翌朝のことであつた。",
              "citation": {
                "source": "緑の軍港",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの聴衆は荒涼たる如月の宵に三時間も打ち震へながら、この天才の光耀赫々たる狂想に耳を傾けたのです。",
              "citation": {
                "source": "『ユリイカ』挿話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "うめの花はつはつ咲けるきさらぎはものぞおちゐぬわれのこころに梅の花さかり久しみ下｜褪せつ雪降りつまばかなしかるらむ梅の花褪するいたみて白雪の降れよと待つに雨降りにけりうめの花あせつつさきて如月はゆめのごとくになか過ぎにけり　これらはその次の集『朝の歌』に出てゐる。",
              "citation": {
                "source": "樹木とその葉",
                "author": "野蒜の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "弥生来にけり、如月は風もろともに、けふ去りぬ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "彌生來にけり、如月は風もろともに、けふ去りぬ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "旗艦「山城」が、一等巡洋艦「鳥海」「高雄」「摩耶」「愛宕」航空母艦「赤城」以下、第十驅逐隊「狹霧」「漣」「曉」を隨へ、仄かなる春の霞みが岬の彼方に煙り初めたとは云へ、未だ如月の夢深い曙の波を蹴立てゝ、威風堂々、○○方面を指して遠洋航海の碇を卷いたのは、あの翌朝のことであつた。",
              "citation": {
                "source": "緑の軍港",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　有王が、故主の俊寛を尋ねて、都からはるばると九｜国に下り、そこの便船を求めて、硫黄商人の船に乗り、鬼界ヶ島へ来たのは、文治二年の如月半ばのことだった。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "北村小松、如月敏、山上伊太郎というような人たちはいずれも過去においては代表的な映画脚本作家であつたが、現在においては申し合わせたように転職あるいはそれに近いことをやつている。",
              "citation": {
                "source": "雑文的雑文",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸田露伴校閲としてある岩波文庫本の李太白詩選を見ると、越女詞五首の第五を、鏡湖水如月　　　　鏡湖、水月の如し、耶溪女如雪　　　　耶渓、女雪の如し。",
              "citation": {
                "source": "閑人詩話",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "如月の後に改まつた同じ年の一月　今だに西班牙といふ國の正體が掴めない。",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "◆第二参考　青黛山如月寺縁起　　　　　　　（開山｜一行上人手記）　　　　　　　――註――同寺は姪浜町二十四番地に在り。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "遂に其の奇特に感じ、荷笈下向して住職となり、寺号を青黛山如月寺と名付く。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一念称名声　功徳万世伝　青黛山寺鐘　迎得真如月　なほ六美女は当時十八歳なりしが、かねてより六字の名号を紙に写すこと三万葉に及びしを、当来の参集に頒ちしに、三日に足らずして悉くせりといふ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "延宝七年七月七日一行しるす◆第三参考　野見山法倫氏談話　▼聴取日時　前同日午後三時頃　▼聴取場所　如月寺｜方丈に於て　▼同席者　野見山法倫氏（同寺の住職にして当時七十七歳。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（その他略）◆備考　（Ａ）如月寺の本尊｜弥勒菩薩の座像を調査するに、頭大にして身小さく、形相怪異にして、後光も無く偏袒もせず。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "古蹟調査に名を藉りたＷが如月寺の和尚に取り入って縁起文を盗み写している間に、同じようにして和尚の信用を得たＭは、問題の御本尊の弥勒様の首を引抜いて見るといった調子で、グングンと求心的に肉迫して行くと実に意外千万な事実を発見した。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち如月寺の縁起文の中では、呉虹汀の手で焼棄てられた事になっている絵巻物が、実は焼棄てられていなかった……ツイこの間まで御本尊の胴体の中に厳存していたのみならず、それを最近になって何者かが発見して、どこかへスッパ抜きに持って行ってしまっているに相違ない事実が発見されたのだ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……なぞと独りで北叟笑みながら、Ｔ子にも内証でコッソリ姪の浜へ来て、如月寺の本堂へ忍び込んで、御本尊の首を抜いてみると……。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……というのは女としては珍らしい冴えた頭脳を持っているＴ子がもし、Ｍの行衛不明と、如月寺の絵巻物の紛失事件を綜合して考えた場合には、遅かれ早かれ或る恐ろしい、一つの疑いに直面るにきまっている。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "返へらざる世を悲しめば如月の磯辺の雪も度を超えて降る　早春大磯に滞在中、雪の余り降らない暖かい大磯には珍しい大雪が偶※降り出した。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "疑問の洋装の女が、三映キネマの如月真弓！",
              "citation": {
                "source": "殺人迷路",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東行西行雲悠々」といふ漢詩を、昔の或る人が和訳して「きさらぎ、やよひ、日のどか。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
