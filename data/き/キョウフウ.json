[
  {
    "uuid": "b5cbf7a4-a47a-5546-984d-675458c0cd6c",
    "entry": "京風",
    "reading": {
      "primary": "きょうふう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
