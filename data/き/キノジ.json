        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蓋し鮎鰯鰰等の字と同じく我が邦人の製にかゝるものにて、喜の字にきすのきの音あるに縁りて以て創め作りしなるべし。",
              "citation": {
                "source": "鼠頭魚釣り",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「新吉、宗太郎、竹造、源助、与之助、巳太郎の六人でござります」　喜七はおろか、喜の字のついた名も、七の字のついた名まえすらもないのでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "七十七の喜の字のお祝いを致されおめでたい事どすと喜んで居りました。",
              "citation": {
                "source": "栖鳳先生を憶う",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "神田紺屋町に鉄物問屋を出して、屋号を日野屋といい、商標には井桁の中に喜の字を用いた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく書かない振事劇を書いて、喜の字のお祝いにデジケートすることで、もとよりこれは「燦々会」同志の労をかりて、先生に読んで頂くばかりでなく見ていただく心組みだったのだ。",
              "citation": {
                "source": "古い暦",
                "author": "――私と坪内先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀糸を束ねた白髪、飛瀑を見るごとき白髯、茶紋付に紺無地｜甲斐絹の袖なしを重ねて、色｜光沢のいい長い顔をまっすぐに、両手を膝にきちんとすわっているところ、これで赤いちゃんちゃんこでも羽織れば、老いて愚に返った喜の字の祝いのようで、まるで置き物かなんぞのように至極穏当な好々爺としか見えない。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蔭で喜の字屋のお咲坊は近頃泣きの涙で」「何んだえ、それは」「隣町の――と言つたところで、此塾とは背中合せの綿摘の師匠の妹で」「それが狩屋さんと何うしたので」「良い仲でしたよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "軍學者の妾",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃は喜の字屋のお咲坊と誰知らぬ者も無い中になつて居る癖に、お照の阿魔が此處へ入つて來ると箸まめにちよつかいを出して、滅茶々々に絡みつかれるから、動きが取れやしませんや。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "軍學者の妾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は喜の字屋へ參りました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "軍學者の妾",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏木戸を開けると、喜の字屋は鼻の先だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "軍學者の妾",
                "note": "青空文庫"
              }
            },
            {
              "text": "平次はそれから直ぐ、春名塾の裏口を出て、隣町の喜の字屋といふのに行つて見ました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "軍學者の妾",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴木春信が好んで描いた綿摘み、それは言ふまでもなく、江戸時代の私娼の一つで、狩屋三郎の懇ろにして居るお咲といふのは、喜の字屋の師匠の妹で、二十二三であつたにしても、相當顏の良い姐御だつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "軍學者の妾",
                "note": "青空文庫"
              }
            },
            {
              "text": "教へてやらう」　平次は八五郎と一緒に裏へ出ると、眞つ直ぐに喜の字屋へ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "軍學者の妾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが狩屋三郎は近頃先生の妾に乘替へて、喜の字屋へ寄りつかなくなつた。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "軍學者の妾",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲間の參會で、金杉橋の『喜の字』で飮んで、遲くなつてから、ブラブラ戻りました」「刻限は？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美女を洗ひ出す",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲間の参会で、金杉橋の『喜の字』で飲んで、遅くなってから、ブラブラ戻りました」「刻限は？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "美女を洗い出す",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたも広いところをみて、しっかり面白い小説をかいて下さい」　いつか伸子に反物をおくってくれた老母は、じき喜の字の祝いで別荘に暮している。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっかさんあいにく出かけたごんだ」「今日はお祖母さまに用があったの」「さあ、おしき」　祖母は、自分の喜の字の祝のとき貰った厚い緞子の座蒲団を火鉢の向う側に置いた。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘三郎が五十一の年、多吉は喜の字の祝を済ませて死んだ、多吉は死ぬときに、自分が与石の家から持ってきた田地の二町歩を勘三郎へ与えて逝ったが、その後べつに名を書換えるでもなく、ずるずるに多吉の長男のもののまま終ってしまった。",
              "citation": {
                "source": "藪落し",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "斬り取り強盗や、しばつきのじんぎと言ふ方法を以てして、危急を逃れた昔の無頼漢と択ぶ所のない方法をとつた。",
              "citation": {
                "source": "手習鑑雑談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "このときのじっけんでは、アンモニア水をつくれたものの、かたまらず、かんぜんなろしゃになりませんでしたし、あまりくさいので、いったんうちきることにしました。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのために、仮装した子供たちが、めいめい贈り物を手にしているし、笛吹きのじいさんが、いま吹きはじめるところなの。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A DOG OF FLANDERS",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、彼の動きのじゃまはしないで、ときどき遠くのほうからステッキの尖端でその方向転換の動作の指揮を取るような恰好をするのだった。",
              "citation": {
                "source": "変身",
                "author": "DIE VERWANDLUNG",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそれよりうまかったのは、鹿島入りから炭焼きのじいさんが持って来たという、生の椎たけであった。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「待て、涌谷は出てまいるだろうな」　――涌谷さまはもうお着きのじぶんと存じますが。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきのじいさんではありません。",
              "citation": {
                "source": "怪人と少年探偵",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかでタバコをすっている労働者は、道のほうをむいていましたから、さっきのじいさんが、外を通れば気がついたはずです。",
              "citation": {
                "source": "探偵少年",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきのじいさんが、あやしいぞっ。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつ、さっきのじいさんに、ばけていたんじゃないかな。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "懐中電灯の光がかすかにてらす、むこうの木の間を、さっきのじいさんが走っていました。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
