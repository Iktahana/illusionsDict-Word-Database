        "examples": {
          "standard": [
            {
              "text": "政府は帰国者の社会復帰を支援している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "全ての帰国者は2週間の隔離期間を経なければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "帰国者同士が経験を共有するための定期的な会合を開いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最新の報告書によると、帰国者の数が増加しているそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その上、新帰国者の彼にとっては、環境もすべて新奇に感ぜられました。",
              "citation": {
                "source": "白蛾",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを帰国者が持ってきた。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            }
          ]
        }
