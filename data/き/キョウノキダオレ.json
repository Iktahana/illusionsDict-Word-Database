        "examples": {
          "standard": [
            {
              "text": "「私、京の着倒れみたいで、給料入るとすぐ服買っちゃうんだよね！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「京の着倒れ、大阪の食い倒れ」って言うけど、あれって本当なのかな？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "最新のデザイナーズブランドに身を包んだ彼女は、まさに「京の着倒れ」を体現していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「京の着倒れ、大阪の食い倒れ」　というが京大阪の咄家は、昔から着物に金を掛ける。",
              "citation": {
                "source": "噺家の着物",
                "author": "三代目　三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "『京の着倒れ大阪の食い倒れ』というほどだから、此処へ来たら食う方は諦めるんだね。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
