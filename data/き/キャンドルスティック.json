        "examples": {
          "standard": [
            {
              "text": "「株価チャートをキャンドルスティック（ローソク足）で表示すると、値動きの勢いが分かりやすい。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「古い洋館の壁に、一対のキャンドルスティックが固定されていた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「テーブルに置かれた一本のキャンドルスティックが、部屋をほのかに照らしている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「トレードの基本として、まずはキャンドルスティックの見方を覚える必要がある。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この年の八月二十九日、キャンドルスティック・パークの二塁後方につくられた特設ステージに、カメラをもってあがり、他の三人だけではなく、腕を思いきり伸ばして、自分自身のビートルとしての最後のステージ姿を撮ったとき、たぶん、ジョンもそのことを知っていたのではないだろうか。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "上に私の真鍮のキャンドルスティックが飾ってあるのもよく調和している。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
