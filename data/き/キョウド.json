[
  {
    "uuid": "4417a209-589b-5ab4-8158-b4f21864c536",
    "entry": "強度",
    "reading": {
      "primary": "きょうど",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
