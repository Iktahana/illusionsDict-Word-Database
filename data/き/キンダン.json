[
  {
    "uuid": "36b51ed2-9374-5f74-ad2f-b2942f21be0d",
    "entry": "禁断",
    "reading": {
      "primary": "きんだん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
