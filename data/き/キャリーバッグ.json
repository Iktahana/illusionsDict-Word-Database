        "examples": {
          "standard": [
            {
              "text": "「石畳の道だとキャリーバッグの車輪が立てる音が響いて、少し周りの目が気になっちゃうね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "LCCの機内持ち込み制限に引っかからないよう、一回り小さなサイズのキャリーバッグを新調した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ねえ、そのキャリーバッグ、ストッパー付いてる？ 電車の中で転がっていきそうで怖いんだけど」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "駅の階段でキャリーバッグを持ち上げるのに苦労していたら、通りすがりの人が手伝ってくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
