    },
    "definitions": [
      {
        "index": 1,
        "gloss": "existing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自ら進んで伝統の上に位置を占めることがむしろ既存伝統の棄却を完からしめることになるのだ。",
              "citation": {
                "source": "英国メーデーの記",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中に刷ったんだが、面白かったな」　こうして官民の組織に加え、庶民のあいだでも手軽な印刷機として広がっていった謄写版は、大正に入ると既存の印刷業の裾野に新たな層を生み出していきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "現状を見れば、生まれ落ちた電子本はもっぱら、既存の流通ルートに載ろうと努めている。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "共に既存の秩序意識を問い直そうとする二つの流れの中で、印刷術は大きな役割を演じました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "既存のパーソナルコンピューター用ソフトをぶちまけるトッテン社長のアシストは、日本の三千六百万人のデスクワーカー、二千四百万人の学生、児童、四千万人の主婦、つごう一億人を市場としうる商品にアプリケーションを大化けさせることを目指す。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが何はともあれ、既存の概念を打ち壊す秩序紊乱者の脳天気ぶりは、ええやないかええやないか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "既存のソフトウエア業界をけさ切りにして登場したアシストを持ち上げた結果、オレのところにも当時多少冷たい風が吹いてきた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本質的には異種格闘技戦をコンピューターのあらゆる領域に挑もうとするサンは、こと日本に限れば、既存のコンピューター業界のネットワークを最大限生かしながら賢く日本市場への定着を目指している『いい子』に見える。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてパーソナルコンピューターと真っ向う勝負を挑むこうしたマシンを気合いを込めてぶつけるにあたっては、日本サンは既存のコンピューターの階層構造にうまく折り合いを付けるいい子では、もはやいられなくなるだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりあえず既存の枠組みの中ではもっとも小規模なミニコンピューターを使って、人が物事を考えるための環境作りを目指した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "平安は既存の事体の調節的持続であり、進歩は既存の事体の建設的破棄である。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち知識も道徳も既存の経験に基いて組み立てられたもので、それがそのまま役立つためには、私の生活が同一軌道を繰り返し繰り返し往来するのを一番便利とする。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつとも役人や法律家にいわせれば、映画の場合も既存の著作権法に準じて判定すればいいというかもしれないが、それは映画というものの本質や形態を無視した空論にすぎない。",
              "citation": {
                "source": "著作権の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「文学者や思想家が、既存の社会通念に無批判に服従することでのみ仕事をすべきだとする考えは、人類に進歩があるべきであるならば、有害な考えである。",
              "citation": {
                "source": "人間性・政治・文学（１）",
                "author": "――いかに生きるかの問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "既存の社会通念を批評し訂正するという思想家や芸術家の働きが、現在の文化を形成して来たのである」と。",
              "citation": {
                "source": "人間性・政治・文学（１）",
                "author": "――いかに生きるかの問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「既存の社会通念」の内容は複雑広汎であるけれども、既存の社会通念の一つとして、「既存の文学というものについての通念」があり、また他の一つとして「政治というものについての既存の通念」もあることは否定できない。",
              "citation": {
                "source": "人間性・政治・文学（１）",
                "author": "――いかに生きるかの問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうに予感されるこの推移と変革の過程では、一九四五年八月からのち、日本の文学評論の上に活溌に云われはじめた「後進日本」の知性を制約している社会条件の解剖さえも、「既存の通念」の一つと化しはじめている。",
              "citation": {
                "source": "人間性・政治・文学（１）",
                "author": "――いかに生きるかの問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして現實的なものに就いては、いはばその現存在が同時に既存在の意味を含んでゐるのである。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニイチェが、「現存在はただ一の間斷なき既存在である、自己自身を否定し、食ひ盡し、自己自身に矛盾することによつて生きる物である。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼によれば Existenzial が Dasein（現存在）に對する關係は Kategorie が Vorhandensein（既存在）に對する關係の如きものである＊。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "基礎經驗はその本來の性格として既存のロゴスをもつて救濟され、止揚され得ぬものである、したがつてそれはそれの存在に於て不安であるであらう。",
              "citation": {
                "source": "唯物史観と現代の意識",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校に通ったり会社で働いたりと、既存の組織、既存の社会の中にあって、Ｚ革命を目指す。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間から身体の構造が遠ざかるに従ってだんだん意識が薄くなるかどうかそれは少しもわかりませんがとにかくわれわれは植物を食べるときそんなにひどく煩悶しません。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはときどきそんなことを思った。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが思い切って弾き出して見ると、じきそんな気持ちは消えた。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く立派な馬でも飼うようになって……」　父親の伝平は、ときどきそんなことを言うのであった。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がそれを聞かしてくれたときそんなに強い印象を受けたのは、おそらく、その詩の意味の底の神秘的な流れのなかに、アッシャー自身が彼の高い理性がその王座の上でぐらついていることを十分に意識しているということを、私が初めて知ったように思ったからであろう。",
              "citation": {
                "source": "アッシャー家の崩壊",
                "author": "THE FALL OF HOUSE OF USHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "今どきそんな古い手を食ってたまるものか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿母さんがさっきそんなことを云っていました」「なにしろ、頭が重いから」と、紋作は気のないように云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "今どきそんな古手を食うものか。",
              "citation": {
                "source": "真鬼偽鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
