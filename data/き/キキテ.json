[
  {
    "uuid": "f8f92601-978a-5d1b-9395-d8c6f4637225",
    "entry": "聞き手",
    "reading": {
      "primary": "ききて",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
