      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hearer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ちょっと僕にも、などと、ひとりで弱っている姿を見ると、聞き手のほうでも、いい加減じれったくなって来る。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おらあ黙って聞き手になるから」「どうも相済みません」「済むも済まねえもあるもんか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は、わたしが聞き手にまわりました。",
              "citation": {
                "source": "人形つかい",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにまた、堀木と附合って救われるのは、堀木が聞き手の思惑などをてんで無視して、その所謂｜情熱の噴出するがままに、（或いは、情熱とは、相手の立場を無視する事かも知れませんが）四六時中、くだらないおしゃべりを続け、あの、二人で歩いて疲れ、気まずい沈黙におちいる危懼が、全く無いという事でした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このまえも、年の暮の事でしてね、お互いもう、目が廻るくらいいそがしいのに、いつも、年の暮をねらって、こんな事をやられたひには、こっちの命がたまらない」　ヒラメの話の聞き手になっているのは、京橋のバアのマダムでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞き手は一人もない。",
              "citation": {
                "source": "鈴木三重吉宛書簡―明治三十九年",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　聞き手の私が確答し得なかつたのは勿論でした。",
              "citation": {
                "source": "処女時代の追憶",
                "author": "断片三種",
                "note": "青空文庫"
              }
            },
            {
              "text": "容貌を語ることに依って、その主人公に肉体感を与え、また聞き手に、その近親の誰かの顔を思い出させ、物語全体に、インチメートな、ひとごとでない思いを抱かせることができるものです。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、恐らく四人の聞き手はさう思つてゐたでせう。",
              "citation": {
                "source": "Ｓ中尉の話",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞き手の僕自身さへ身につまされて、何だかセンチメンタル――さうだ、さう云ふ言葉があつたね。",
              "citation": {
                "source": "Ｓ中尉の話",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、その大家族の一人一人に就いて多少の誇張をさえまぜて、その偉さ、美しさ、誠実、恭倹を、聞き手があくびを殺して浮べた涙を感激のそれと思いちがいしながらも飽くことなくそれからそれと語りつづけるに違いない。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、聞き手はついにたまりかねて、「なるほど君は幸福だ。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかしいのは、シャクの方でも（あるいは、シャクに宿る霊共の方でも）多くの聞き手を期待するようになったことである。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も熱心なシャクの聞き手までが。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "をかしいのは、シャクの方でも（或ひは、シャクに宿る靈共の方でも）多くの聞き手を期待するやうになつたことである。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、そのような推理をしておいて、その筋の真ん中を少し向こうへやって、聞き手にその始まりと結論だけを見せようものなら、人をあっと言わせることができるわけだが、まあ、ほんのこけおどしだ。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボブ・ディランの歌は聞き手の想像力の光を受けて初めて輝くダイヤモンド型構造を持っているが、この映画にもそんな臭いがある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「食うことと、生殖することだけで活動してるから、それで蠢動してるというのかい」今度は小倉が皮肉な聞き手になった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことは、話し手も、聞き手も、その話のあとで、きっと妙なさびしい気に落ち入るものだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌い手のからだにさわるという意味か、聞き手のからだにさわるという意味か、はっきりしない。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だめですね』などと言ってまた『いい聞き手のおいでになった時にはもっとうんと弾いてお聞かせなさい』こんな嫌味なことを言うと、女は作り声をして『こがらしに吹きあはすめる笛の音を引きとどむべき言の葉ぞなき』などと言ってふざけ合っているのです。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その折、語り手が申しますのに、これから先うっかりとこの怪談を人に語らば、話し手に禍いがかかるか、聞き手の身に禍いが起るか、いずれにしても必ずともに何ぞ怪しい祟りがあるゆえ気をつけいと、気味のわるい念を押しましたゆえ。",
              "citation": {
                "source": "十万石の怪談",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の聞き手は身体をむずむずと動かした。",
              "citation": {
                "source": "鉄の規律",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の代表的大衆紙巻煙草）をふかしながらときどきうなずきつつ、主として聞き手に回っているようである。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうか、砕氷船か」　聞き手の両人は、目を瞠った。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何時も彼等の朗かな合唱の聞き手であるだけだ。",
              "citation": {
                "source": "くもり日つゞき",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞き手の受け取り方ひとつによつては、それらは有益でないことはなかつた。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもあらばあれ、われこの翁を懐う時は遠き笛の音ききて故郷恋うる旅人の情、動きつ、または想高き詩の一節読み了わりて限りなき大空を仰ぐがごとき心地す」と。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁解の言葉連ねたもうな、二郎とてもわれとても貴嬢が弁解の言葉ききて何の用にかせん。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとの申さるるをききてよめる。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
