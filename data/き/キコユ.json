    "definitions": [
      {
        "index": 1,
        "gloss": "to be heard",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "震動の筋肉感や、耳に聞こゆる破壊的の音響や、眼に見える物体の動揺転落する光景などが最も直接なもので、これには不可抗的な自然の威力に対する本能的な畏怖が結合されている。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "長さよりも幅の方が長い橋にさしかかったから、幸いとその欄に倚っかかって疲れきった足を休めながら二人は噴煙のさまのさまざまに変化するをながめたり、聞くともなしに村落の人語の遠くに聞こゆるを聞いたりしていた。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "梢をわたる風の音遠く聞こゆ、ああこれ武蔵野の林より林をわたる冬の夜寒の凩なるかな。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "野末はるかに百舌鳥のあわただしく鳴くが聞こゆ。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "中流より石級の方を望めば理髪所の燈火赤く四囲の闇を隈どり、そが前を少女の群れゆきつ返りつして守唄の節合わするが聞こゆ。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の西端に寺ありてゆうべゆうべの鐘はここより響けど、鐘｜撞く男は六十を幾つか越えし翁なれば力足らず絶えだえの音は町の一端より一端へと、おぼつかなく漂うのみ、程近き青年が別荘へは聞こゆる時あり聞こえかぬる時も多かり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　この時、夜ふけ、遠き林をわたる風の音の幽かに聞こゆるのみ、四辺は寂として声なし。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "日夜の哭啾聞こえざるに聞こゆ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸外にて戸をたたく音聞こゆ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処ともなく機織の音聞こゆ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と聞こゆるは寝惚れたる女の声なり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポ……ポ……という音の底にどことなく聞こゆる余韻……。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "南無三膝を立直し、立ちもやらず坐りも果てで、魂宙に浮く処に、沈んで聞こゆる婦人の声、「山田山田」と我が名を呼ぶ、※呀と頭を掉傾け、聞けば聞くほど判然と疑も無き我が名の山田「山田山田」と呼立つるが、囁く如く近くなり、叫ぶが如くまた遠くなる、南無阿弥陀仏コハ堪らじ。",
              "citation": {
                "source": "妖怪年代記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "内より女の声聞こゆ。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪の音、恋えば聞ゆる、聞こゆればその音の忍び入るお菓子の花の形に。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋳金家、蒔絵師などこそ、且つ世に聞こゆれ。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この世の人々が全く窮するに至って、茫然自失｜為す所を知らざる時、エホバの声は預言者の口を通して聞こゆるものである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "船人もたれを恋ふるや大島のうら悲しくも声の聞こゆる来し方も行方も知らぬ沖に出でてあはれ何処に君を恋ふらん　海の景色を見てはこんな歌も作っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏道仏心｜弥陀の極意はこのひとまくらのうちにありといわぬばかりで名人は、求道弘法の経巻を頭の下にしながら、おりから聞こゆるお山の鐘を夢の国への道案内に、すやすやと心よいいびきをたてはじめました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞こゆるものとては遠くを流るる谷川の音。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠光は頼長が腹心の侍で、宇治と京とのあいだを絶えず往来して、およそ眼に入るもの、聞こゆるもの、大小となく主人に一いち報告する一種の物聞きの役目を勤めていた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "差俯向いて「私が……わるう御座ンした……」「そうお云いなさると、さも私が難題でもいいだしたように聞こゆるけれども、なにもそう遁げなくッてもいいじゃないか？",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "折々｜颯と吹く風につれて犬の吠ゆる声谷川の響にまじりて聞こゆるさえようようにうしろにはなりぬ。",
              "citation": {
                "source": "旅の旅の旅",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳樹屯に帰れば近衛師団は上陸して金州地方に舎営せりと聞こゆ。",
              "citation": {
                "source": "従軍紀事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖より呼ばわる声聞こゆ。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時｜雷のとどろくごとく山の鳴動聞こゆ。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十八回一　万像は育つといへど　ここのみは育つものなし　春の来て明るしといへど　ここのみは黄泉なる姿　岩窪に水を湛へて　龕の灯のともしく映る　人の住む岩窟ならぬに　鑿の音しかも聞こゆれ　野の小鳥訪ひしことなし　野の獣訪ひしことなし　面造る女ぞ一人　籠らうよ謹みにつつ「伴源之丞様と園女様？",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと口に自由といえば我儘のように聞こゆれども、決して然らず。",
              "citation": {
                "source": "中津留別の書",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "太鼓は座につき、早や笛きこゆ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（空ざまに取って照らすや、森々たる森の梢一処に、赤き光｜朦朧と浮き出づるとともに、テントツツン、テントツツン、下方かすめて遥にきこゆ）……見えたか。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
