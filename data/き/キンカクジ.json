    "definitions": [
      {
        "index": 1,
        "gloss": "Kinkakuji (temple in Kyoto)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
