        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "通りすがりの旅人が金閣寺を見物しようとするには案内の小僧は甚だ重宝なものであるが、本当に自分の眼で充分に見物しようとするには甚だ不都合なものである。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒谷とか金閣寺とかいう所へ行くと、案内の小僧さんが建築の各部分の什物の品々の来歴などを一々説明してくれる。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒谷や金閣寺の案内の小僧でも、始めてあの建築や古器物に接した時にはおそらくさまざまな深い感興に動かされたに相違ない。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "京の金閣寺をごらうじましたか、で見ぶつをしたばかり。",
              "citation": {
                "source": "鳥影",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "○六月、市川九蔵は七代目市川団蔵と改名し、明治座に出勤して「金閣寺」の松永大膳を勤む。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居でする金閣寺の雪姫、あの芝居の真似事をいたしまして、わたくしがお姫様の姿で桜の木にくくり付けられて、足の爪先で鼠をかきますと、たくさんの鼠がぞろぞろと出て来て、わたくしの縄を食い切るのでございます。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "義満の金閣寺に真似て、銀閣を東山に建てたが、費用が足りなくて銀が箔れなかったなど、有名な話である。",
              "citation": {
                "source": "応仁の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者が金閣寺を、後者が銀閣寺を建てたのが、日本建築史の標本として残つてゐるくらゐが、せめてもの功績である。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十三間堂、金閣寺、両本願寺の屋根も見ず知らず、五条、三条も分らずに、およそ六日ばかりの間というもの、鴨川の花の廓に、酒の名も、菊、桜。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都を二人で見物して歩きました時に、智恩院とか、銀閣寺とか、金閣寺とかに廻りました。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも彼に限る役があるので、明治二十四年正月の歌舞伎座では、福助の雪姫、菊五郎の木下藤吉郎で、金閣寺の松永大膳をつとめた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "靜岡にも居た事があるらしく、雨の糸の木隱に白い日に金閣寺を見たといふから、京都にも行つたのであらう。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "静岡にも居た事があるらしく、雨の糸の木隠に白い日に金閣寺を見たといふから、京都にも行つたのであらう。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "鷹ヶ峯、庵、光悦寺、金閣寺、酔つぱらうて、仙酔楼居へ自働車で送られる。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "母堂や白峰氏の案内で、四条や三条、御所や嵐山、清水、金閣寺、祇園の都踊りなども見たが、京都で遊ぶには私の気分はすこしあわただし過ぎたし、懐中も寂しすぎたのである。",
              "citation": {
                "source": "佗しい放浪の旅",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がもし、急に明日から金閣寺で暮すという身分にでもなったとしたら、私は直ちにパンタロンは紙屑屋へ売飛ばして衣冠束帯で身を固めるであろう。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち奈良朝に於て種芸、種智、悲田、施療の諸院を開きたる例に則り、諸種の新しき施設を先づわが京都府より試みんとし、府の大参事植村正直氏を初め、友人金閣寺住職伊藤貫宗、銀閣寺住職佐佐間雲巖諸氏に議りて、その協賛を得つ。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤松に蔽われている笠を伏せたような形が、その趣きが、京都の金閣寺の背景である同じ呼び名の衣笠山によく似ている。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　京都の金閣寺や銀閣寺のやうな名刹に行くと、そこには必ず案内役の坊さん達が居て、宝物やなんかの説明をしてくれる。",
              "citation": {
                "source": "実物と模型",
                "author": "相馬御風",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹿苑院金閣寺、いつかその辺りも通ってしまった。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどこの頃のことである、鹿苑院金閣寺、そこから離れた森林の中に、一人の女が坐っていた。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、故人松本幸四郎が近年演じた金閣寺の松永大膳の、背継ぎ台に昇つて、薙刀を頭上に横へて、所謂大入の見得をした姿である。",
              "citation": {
                "source": "花の前花のあと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "論より証拠、それに対立してゐる吉右衛門の寂しく見えること――たとひ吉右衛門が残つても、これでは事実、もう金閣寺の舞台は見られなくなる。",
              "citation": {
                "source": "花の前花のあと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "金閣寺の舞台は、大膳ばかりで出来るものではない。",
              "citation": {
                "source": "花の前花のあと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺町では寺に降り、三条では橋に降り、祇園では桜に降り、金閣寺では松に降る。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日嵐山、金閣寺を見物して、クラシックの匂いを慕って奈良に回ったが綺羅粉黛人跡繁くして駄目であった。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "八坂の塔だの、東寺の塔だの、知恩院だの、金閣寺だの銀閣寺だのがきらきらと映ります。",
              "citation": {
                "source": "私の生ひ立ち",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇治、鳳凰堂、平等院、宇治川花屋敷、佐久間象山遭難地、加茂川、本能寺、御所、烏丸通、堀川、嵐山電車、仁和寺の山、塔、如意輪観音、大竹林、隠窟、臨済宗大本山天龍寺、保津川、桂川、金閣寺（鹿苑院）、大極殿（平安神宮）。",
              "citation": {
                "source": "つゆじも",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、いって、つぎの日　さっそく　あんこくじに　つかいを　よこして、「あす　小ぞうの　しゅうけんを　つれて　きんかくじに　きなさい。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしみつ公は　そのころ　あたまを　そって　ぶつもんにはいり、天山と　いいましたが、きんかくじを　たて、そこに　すんで　いたのでした。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
