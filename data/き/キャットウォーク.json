        "examples": {
          "standard": [
            {
              "text": "劇場の舞台裏にあるキャットウォークは、照明機材の調整に使われているんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "点検のために橋の裏側のキャットウォークを通ったんだけど、高くて足がすくんだよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あのビルの外壁を掃除している人たち、どうやってあんな細いキャットウォークを歩いているんだろう？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
