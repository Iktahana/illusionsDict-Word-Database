[
  {
    "uuid": "64f45fb6-4734-5646-8e3a-8c16fda337ec",
    "entry": "着流し",
    "reading": {
      "primary": "きながし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
