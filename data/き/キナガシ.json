      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dressing in kimono without hakama (for a man)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "中折帽に着流しでゴム靴をはいて、そしてひどく考え込んだような風でゆっくり歩いて来る姿をはっきり覚えているように思うのであるが、しかし、これはよくある覚えちがいであるかもしれない。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "着流しもいれば背広服もいる。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "服装は赫い短靴を埃まみれにしてホームスパンを着ている時もあれば、少し古びた結城で着流しのときもある。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "争議が解決した後も、いっその事思い切って従業員の制服を全廃して思い思いの背広服ないし和服着流しにする事を電気局に建言したらどうかと思ってみたのであった。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の犠牲は三十恰好の商人風の男で、なんでも茶がかった袷の着流しに兵児帯をしめていたように思う。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねくたれた寝衣を着流したような人の行列がぞろぞろあの狭い入口を流れ込んでいた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは余談であるが、一、二年前のある日の午後煙草を吹かしながら銀座を歩いていたら、無帽の着流し但し人品｜賤しからぬ五十恰好の男が向うから来てにこにこしながら何か話しかけた。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには寒空に無帽の着流し、足駄ばき、あごの不精ひげに背の子等は必要で有効な道具立てでなければならない。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は絹のものを、ぞろりと着流してフェルト草履をはき、ステッキを振り廻して歩く事が出来ないたちなので、その絹のものも、いきおい敬遠の形で、この一、二年、友人の見合いに立ち合った時と、甲府の家内の里へ正月に遊びに行った時と、二度しか着ていない。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どう考えても、絹ものをぞろりと着流し、フェルト草履、ステッキ、おまけに白足袋という、あの恰好は私には出来そうもないのである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中央によろめき出た万延寺の和尚は、さすがに商売柄、着流しの上に略袈裟を掛けていた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この家の主人、黒田藩のお目付役、当時蔵元屋の娘胴切り事件のお係りとなっている松倉十内国重は、縁側に座布団と煙草盆を置いて、小倉袖、着流しのまま威儀を正した。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "服装なども無頓着であったらしく、よれよれの和服の着流しで町を歩いている恰好などちょっと高等学校の先生らしく見えなかったという記憶がある。",
              "citation": {
                "source": "埋もれた漱石伝記資料",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大概洋服でなければ羽織袴を着た人たちのなかで芥川君の着流しの姿が目に立った。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "方角をかえて河岸通へ、しかものそのそと着流しのぐなりとした、角帯のずれた結目をしゃくって行く。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "輪曲ねて突込んだ婀娜な伊達巻の端ばかり、袖を辷って着流しの腰も見えないほどしなやかなものである。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "廂髪に結つて羽織を着流したすらりとした肩付は、商売人ではない。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうは資本が続かないからと、政治家は、セルの着流しです。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間ほど前、土地の旅館の息子がぞろりとお召の着流しで来て、白い絹の襟巻をしたまま踊って行ったきり、誰も来なかった。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　鶴雄が世界文学社の扉を押してはいると、窓側に立って、煙草を吹かしながら、寺町通りを見下していた長身、長髪、着流しの三十四五の男がふと振り向いた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "和服の着流しに総しぼりの帯、素足に革の草履――という身なりは、どこか遊び人風めいていたが、存外律義そうな顔立ちで、「腹が空いてるのンか」　と、きいた声は、女のように優しかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく眼を定めてみると、それは平凡な白地のワンピースを着流した令嬢であった。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と私は田舎の或るひとに書いて送り、そうして、私もやっぱり何の変るところも無く、久留米絣の着流しに二重まわしをひっかけて、ぼんやり東京の街々を歩き廻っていた。",
              "citation": {
                "source": "メリイクリスマス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ東京では、まだ空襲は無かったが、しかし既に防空服装というものが流行していて、僕のように和服の着流しにトンビをひっかけている者は、ほとんど無かった。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "和服の着流しでコンクリートのたたきに蹲っていると、裾のほうから冷気が這いあがって来て、ぞくぞく寒く、やりきれなかった。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪を長く伸ばして、脊広、或いは着流し、およそ学生らしくない人たちばかりであったが、それでも皆、早稲田の文科生であったらしい。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋い市楽の着物の着流しで袂に胃腸の持薬をしじゅう入れているといった五十男だった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒っぽい絽の羽織の着流し姿で小さいケースを携げて居る。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして間もなく戦いが終り、私は和服の着流しで故郷の野原を、五歳の女児を連れて歩きまわったりなど出来るようになった。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人相だってよくないし、服装だって、和服の着流しで、だらしがない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
