        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "朝が来て――つぎの日のことだ――ニール・オキャリーは起き上がった。",
              "citation": {
                "source": "ニール・オキャリー",
                "author": "NEIL O’CARREE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつはニール・オキャリーにあいさつした。",
              "citation": {
                "source": "ニール・オキャリー",
                "author": "NEIL O’CARREE",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍋を火にかけ、ニール・オキャリーにたずねた。",
              "citation": {
                "source": "ニール・オキャリー",
                "author": "NEIL O’CARREE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニール・オキャリーに向かって、これでじゅうぶんかとたずねた。",
              "citation": {
                "source": "ニール・オキャリー",
                "author": "NEIL O’CARREE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニール・オキャリーが赤毛の男を雇ったところまで来ると、男は言った。",
              "citation": {
                "source": "ニール・オキャリー",
                "author": "NEIL O’CARREE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はじめておまえに会ったのはここだったな」「そうだな」とニール・オキャリーは答えて、「おう、金をどうわけようか」と言った。",
              "citation": {
                "source": "ニール・オキャリー",
                "author": "NEIL O’CARREE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニール・オキャリーは馬に乗って家に向かった。",
              "citation": {
                "source": "ニール・オキャリー",
                "author": "NEIL O’CARREE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニール・オキャリーは群れをまとめようとした。",
              "citation": {
                "source": "ニール・オキャリー",
                "author": "NEIL O’CARREE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニール・オキャリーは扉を開けさせまいとした。",
              "citation": {
                "source": "ニール・オキャリー",
                "author": "NEIL O’CARREE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニール・オキャリーは捕まえられた。",
              "citation": {
                "source": "ニール・オキャリー",
                "author": "NEIL O’CARREE",
                "note": "青空文庫"
              }
            },
            {
              "text": "王さまはニール・オキャリーにそれをやった。",
              "citation": {
                "source": "ニール・オキャリー",
                "author": "NEIL O’CARREE",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゅうぶんだから、これいじょうは一ペニーだっていらないとニール・オキャリーは言った。",
              "citation": {
                "source": "ニール・オキャリー",
                "author": "NEIL O’CARREE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれたちが仲たがいしたのはここだったな」「そのとおり、ここだとも」ニール・オキャリーは答えた。",
              "citation": {
                "source": "ニール・オキャリー",
                "author": "NEIL O’CARREE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その正統者をラハーキャリーといって、今でもその家は立派に残って居る。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭上の棚を開いて平たい紙包みを取り出し、シートの下からキャリーオン・バッグを引っぱり出した。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ザッツ・ホワイ・アイ・キャリー・ゼム」「きれいです」「赤が素晴らしい。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
