        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "また、午後から雨になる、風になるという気象庁を信用して、舟宿と友だちを断わり、家にいると曇っていた空模様がだんだん明るくなり、いい天気になる。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼まれた仕事を断わって、今さら伺いますともいえず、そうかといって気象庁から損害賠償もとれず、知らぬ人にそんな話もできない。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "気象庁の予報より確かにあたる。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "永井荷風氏の日記には、長年の天気が書いてあったが、それが気象庁の天気とぴったり合っていたというからおもしろい。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に気象庁へいき、午後三時のニュース用の天気図を受取った。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
