        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝早く、庭で雉鳩が「デデッポー」と鳴いているのが聞こえた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "電線に止まっている雉鳩が、遠くを見つめていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "近所の森で、つがいの雉鳩が巣作りをしているのを見かけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "雉鳩の声の微かに聞える退屈なベンチでした。",
              "citation": {
                "source": "亜剌比亜人エルアフイ",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしわたしは一匹の猟犬と一頭の栗毛の馬と一羽の雉鳩とをうしない、今でもその行方をさがしている。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "その蓋には羽づくろいをする二羽の雉鳩が描かれていた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「蓋の上に二羽の雉鳩がいるやつでしたか？",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
