    "definitions": [
      {
        "index": 1,
        "gloss": "women's pavilion (of the inner Heian palace)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
