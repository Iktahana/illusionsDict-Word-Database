    },
    "definitions": [
      {
        "index": 1,
        "gloss": "joint translation (translation carried out by more than one person)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "久保勉、阿部次郎両氏の名共訳に感謝した。",
              "citation": {
                "source": "五月のはじめ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "川口篤、河盛好蔵、杉捷夫、本田喜代治の共訳で、誰がどのやうな分担をしたのかさつぱり判らないが、たかだか六百数十頁の本を四人で突つき合ふといふ、共訳の意義が奈辺にあるか、これまたわからなくなる。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方なしに、その日と翌日の二日は、ホテルの一室に引っこんで、近く共訳で出すある本の原稿を直して暮した。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "野枝さんは殺される少し以前に、アルスから出た大杉君と共訳のファーブルの自然科学をまこと君に送ってくれた。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "（淀野・佐藤共訳）　これは、マルセル・プルーストの小説「失いし時を索めて」の一節である。",
              "citation": {
                "source": "現代小説展望",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（森田草平ほか五氏共訳）　これは「ユリシーズ」の一節である。",
              "citation": {
                "source": "現代小説展望",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "戯曲の翻訳と云へば、外国に行く前、太宰施門氏とエルヴイユウのものを共訳したことがあるきりである。",
              "citation": {
                "source": "芝居と僕",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "堺も、はじめは、増税反対の社説をかいたり、幸徳秋水と共訳の『共産党宣言』の翻訳をのせて、ぶちこまれたりしていたが、根が小悧口者だから、俗化してしまった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の多くもない翻訳の中で今思いだしても、あんなものを訳さなければよかったと思うのは、鈴木信太郎君と共訳したポール・ジェラルディーの『愛する』である。",
              "citation": {
                "source": "銷夏漫筆",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
