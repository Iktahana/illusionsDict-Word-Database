    "definitions": [
      {
        "index": 1,
        "gloss": "unable to stomach",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "団子の二串やそこら、くれてやってもいいのだが、おれはどうもきさまの物言いが気に食わないのでな。",
              "citation": {
                "source": "祭の晩",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へん、気に食わない奴だ。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "年にも似合わず、人の欠点を横からにらんでいて、自分の気に食わないことがあると、何も言わないで、親にでも強く当る。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し気に食わないことがあると、誰にでも喧嘩を売った。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "剛坂金蔵、名前からして何だか物々しくきこえるが、忠実で善良で非常にやかましい老人で、少しでも気に食わないことがあると、だれかれの容赦なしに睨み付ける。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "……どだい俺からいわせると御用という文字が気に食わない。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしただその数をたのみにしているところ、また自分よりも他人をたのみにしているところなどが、どうも気に食わない。",
              "citation": {
                "source": "鎖工場",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は、あとで、同志の人たちに迷惑を及ぼしたくないと考えて、そうやってわざとグルウプから除外されようとしているのだろうが、僕は、そのちっぽけな心遣いが気に食わないのだ。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "べつに何がどうしたというわけでもないが、ただ朝夕その遣り方のすべてが気に食わないのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、雨が降っても風邪を引いても犬が吠えても、何かすこしでも気に食わないことがあると、早速この象形物を突き出して「ふぃが・ど・であぼ！",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供たちは何かの感覚で先生の匂いを嗅ぎ分け、気に食わないと勉強する気になれないのだ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時のことですが、私の親戚で、ひとりなかなかよくゴテる叔父がおって、私が画学校に通うことを非常に嫌い、というより、母が私を許して絵の学校へやっていることが気に食わない。",
              "citation": {
                "source": "最初の出品画",
                "author": "――四季美人図――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「日頃お前と仲のよい、そのため俺には気に食わない、小姓頭の式部のことだ」「おお式部様！",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "愈支那は気に食わない。",
              "citation": {
                "source": "長江游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが作り声は気に食わないねえ。",
              "citation": {
                "source": "天主閣の音",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの男の眼付き、気に食わないよ。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤シャツは声が気に食わない。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "馴染の芸者がはいってくると、入れ代りに席をはずして、逃げるなんて、どこまでも人を胡魔化す気だから気に食わない。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体茶人の持ってる道具ほど気に食わないものはない。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その雑誌を見るのも気に食わないわ。",
              "citation": {
                "source": "一人舞台",
                "author": "ストリンドベルヒ　August Strindberg",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が一ツ気に食わないのは、ちかごろ潜在意識ということで、人間の心をむやみやたらに割りきりすぎるということです。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その三　精神病診断書",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、彼女が妙テコレンな夢をえがいて、それに甘えて死ぬことはまた可なりかも知れないが、甘え方が気に食わないんだよ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し気に食わないことがあるとすぐに、「馘や」　と怒鳴った。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "別品には相違ないが、己には気に食わない。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "8085あの不機嫌な親爺には、人間世界の全体のする事が、いつも気に食わない。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――が、菱川がいったのでは……天下にかれの最も気に食わない菱川のそういったのでは金札でも鉄札……飲めばいゝんだろう、飲んだら不思議はねえんだろう。",
              "citation": {
                "source": "春泥",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一太郎太郎と呼捨てに書いとくのが気に食わない。",
              "citation": {
                "source": "いたずら小僧日記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は穏かではないけれど、少くとも、道に外れたことをする人間じゃない」「初めから気に食わない野郎だと思っていたが、それが通じたんだろう。",
              "citation": {
                "source": "首切り問答",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来の客に対して、どうも気に食わない、気に食わないと、仏頂寺らが口癖のように言っている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴慕の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
