          "standard": [
            {
              "text": "事件の裁定は、最終的に宮廷裁判所の判断に委ねられることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "宮廷裁判所の判決は絶対であり、誰も逆らうことはできなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は宮廷裁判所の書記として、記録の管理を担当していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そのような環境の中に幼時を経た頭の鋭い感傷的な性格のロオルは、僅か十五の年、宮廷裁判所の判事である貴族出のベルニィと結婚させられた。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "星法院（枢密院議員と少数の法官をもって構成する宮廷裁判所）の審問が、彼女の心づもりだった。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
