    "definitions": [
      {
        "index": 1,
        "gloss": "to rip off a coupon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は商談で、絶好のタイミングで相手の懐に入り込み、見事に切符を切った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "難しいプロジェクトだったが、部長が陣頭指揮を執り、あっという間に切符を切ってくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今回のテスト、みんな苦戦してたけど、私は過去問をしっかりやってたから、サクッと切符を切ったよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "車掌が切符を切る時にも、こっちを見ていてぼんやりして何か車掌に云われていた位だった。",
              "citation": {
                "source": "途上の犯人",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々のことを思い出して頂戴と云ったような、そんな優しい眼であったけれど、九太は一足飛びに他人になったような、云えば、電車の車掌が切符を切るような顔色で、「度々、まさ子の名で電話をかけちゃ困るじゃないか」と叱った。",
              "citation": {
                "source": "帯広まで",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて然らば自分の特殊な能力は入院後だうであつたかと言へば、病院は鉄道の駅ではないから自分はもとよりパンチを所有する筈がないし、かりにパンチがあつたとしても患者を乗客に仕立てて切符を切るといふわけにはいかない。",
              "citation": {
                "source": "盗まれた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車に乗って切符を切る段になると小川君の病院が分らない。",
              "citation": {
                "source": "好人物",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
