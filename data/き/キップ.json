  {
    "uuid": "2ce2bb80-c9ff-5f98-9017-5eaa687d53a2",
    "entry": "気っ風",
    "reading": {
      "primary": "きっぷ",
      "alternatives": [
        "キップ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "character",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この気っ風と強さはどこから来るんだ。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな熱に浮かされたような書きっぷりでいいものだろうか？",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英雄の最後でも画くようなそういう書きっぷりにはいささか辟易したが、とにかく三造はすぐに洗足の伯父の家へ行った。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "むっつりの右門はね、むだ責めむだ口はでえきれえ、意気ときっぷで名を売った江戸まえの男のつもりだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなきっぷのいいおだんなを、なんだってまた江戸の女の子がいつまでもひとりでおくんだろうな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "この字の書きっぷりじゃ、きっと大べっぴんですぜ」「うるさいよ」「え……？",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「江戸っ子はもち屋までがいいきっぷをしているから、うれしくなるんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっしゃくやしくなりました……だんなも江戸っ子ならば、江戸っ子の職人がどんなきっぷのもんだか、よく胸に手をおいて考えてみておくんなさいまし……」　訴えるようにいった伊三郎の目には、恨めしげな露の光すらも見えました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "造りもちまちまっとしてかわいらしかったが、きっぷも子どもみてえなやつだったですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこれをを探せというような書きっぷりであった。",
              "citation": {
                "source": "暗号数字",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、個人的なものの考え方で、すべての毀誉褒貶を皆自分のこやしとして、自分が正しいと思う方へひたすら伸びてゆくこと、そして、よかれあしかれ自分の生きっぷりと、そこから生れる仕事で批評をつき抜いて行くこと、それを心がけとしてやっていた。",
              "citation": {
                "source": "近頃の感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、きっと、もっと簡明な書きっぷりで書くことを。",
              "citation": {
                "source": "若者の言葉（『新しきシベリアを横切る』）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなと同じ仕事着を着て頭をきっちり赤い布でしばって、穿いている黒靴こそ、醋酸をのんで倒れたとき、穿いていたままだが、顔つきと云い歩きっぷりと云い、これは別人だ。",
              "citation": {
                "source": "「インガ」",
                "author": "――ソヴェト文学に現れた婦人の生活――",
                "note": "青空文庫"
              }
            },
            {
              "text": "モダン娘ルミの歩きっぷりを、飄々などと形容するのは妙なようだけれど、事実その姿は、まるで風に送られて来るかのように、変に緩漫な、それでいて、一刻も早く此処へ着こうとする激しい気力を感ずるような足取りなのであった。",
              "citation": {
                "source": "脳波操縦士",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぷきっぷきっと固いくちばしを鳴しながら、「そうだね。",
              "citation": {
                "source": "梟の大旅行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "梟はそう云って、ぷきっぷきっとくちばしを鳴らしました。",
              "citation": {
                "source": "梟の大旅行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨にひまな芸者達はまどから千世子の様子をのぞいては大股にシュッシュッと歩くのを見て、「色気がないネエ」と云ったり、「あれが東京の歩きっぷりなんさ」と云ったりして居た。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "駒下駄を一足一足ふみしめてる歩きっぷりが、身体から酔がさめて頭にまだ酔が残ってる中途半端なものだった。",
              "citation": {
                "source": "溺るるもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしまたお仙と連れ添うようなら、早速習って拍子木叩き、幕の引きっぷり口上の述べ方、首尾よく務めて幕内となり、それで食って行きますな」「でもし妾と連れ添うようなら？",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩きっぷりまでハムレットだ、やっぱり本を持ってね。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父つぁんのしじゅうおっしゃる、嬉しいきっぷ、こころ意気とやらいうものは、いったいどこにあるのでございましょう。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "てきをたいじて　かえりはうきっぷ　せがれよ　えらいぞ　ジャバウォクたおした　きょうはめでたいな　ふつかわらい　ぐつころトウヴが　うぬるではすった　あわるボロゴウヴ　じめレイスがののしつ　全員が急いで立ち去り、アリスはひとり残される。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはいいが、歩きっぷりがすこぶる妙なので。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "蠑※",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは急いできっぷを買うと、構内のさわがしいなかで、ここに詰めている例のホテル会社の社員を物色した。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、これからどこへ行くつもりなの」「どこへ行くといって当はないんだ」「どうもお前さんは、口の利きっぷりやなにかがおかしな人だよ、心持に毒のなかりそうな人だよ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "女子と小人の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊太夫はお角のきっぷを愛して、かなりの信用と、贔屓を払っている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一も二もなく雲助のきっぷに惚れ込んだ道庵が、ここで彼等の溢れ者をすっかりかり集めて、大盤振舞をした上に、明日はこの勢いで関ヶ原合戦の大模擬戦を行って見せるのだという。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽっとり者の方でも、この高山の土臭いのや、郡代官のギコチないのより、口当りだけでも、きっぷのいい江戸ッ子気取りの兄さんを用いてみたい心意気があったものと見える。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一にも二にもお角さんのきっぷに信頼してしまって、あの女なら、場合によって百や二百のあぶく銭を投げ出すなんぞは何でもない――とタカを括り過ぎたのかも知れません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、その泣き方は、芸者や遊女としての泣き方ではなく、子供の駄々をこねる泣きっぷりと同じようなものでした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            }
          ]
