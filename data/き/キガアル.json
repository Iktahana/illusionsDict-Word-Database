[
  {
    "uuid": "ec2f657a-0623-58e5-9c1f-3a66c554c13b",
    "entry": "気がある",
    "reading": {
      "primary": "きがある",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ラ行-不規則"
