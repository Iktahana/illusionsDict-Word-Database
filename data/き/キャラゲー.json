    "definitions": [
      {
        "index": 1,
        "gloss": "video game featuring characters from a manga, anime, movie, etc.",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「原作のファンだから買ったけど、このキャラゲーは格闘ゲームとしての完成度も意外と高いよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "好きなアニメがキャラゲー化されると聞いて、どんなジャンルのゲームになるのか期待が膨らむ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "往年の名作マンガが、最新技術を駆使したキャラゲーとしてスマホアプリで復活した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 2,
        "gloss": "video game in which the characters are the main focus",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "システムはシンプルだが、個性的で魅力的な登場人物が多いので、まさに良質なキャラゲーと言える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ストーリーよりも、推しキャラとの親密度を上げることに情熱を注いでしまうのがキャラゲーの醍醐味だよね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "育成要素が充実しているこの作品は、キャラクターを愛でるのが好きな人向けのキャラゲーだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
