        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　山の家のそばには、キャンプ場が出来ると共に、貸ボートが数隻並んだ。",
              "citation": {
                "source": "山吹の花",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年ぐらい前に切り倒して、キャンプ場にしたらしいの」　女は酒に口をつけた。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「キャンプ場の近くでね」「あいも勝気過ぎって、不幸な女でな」「泊って、女中の産地らしいですね」「そや昔の話ですよ。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "高原のキャンプ場へ、ぼくたちは一泊のツーリングにいこうとしている。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "目ざすキャンプ場へは、もっと近道があるのだが、遠まわりをしている。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくがかつて走った道路のさまざまな記憶のなかから、キャンプ場とのかねあいのうえで、この道路を選んだ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この林のなかに点在するキャンプ場の本拠となる事務所や国民宿舎、それに、小さな牧場や温泉もある。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "このキャンプ場では、自然を保護するため、バンガローはなく、テントの貸し出しも、やっていない。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、キャンプ場に入った。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくたちがいるキャンプ場は、その観光地から山ひとつへだてた裏側にあたる。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
