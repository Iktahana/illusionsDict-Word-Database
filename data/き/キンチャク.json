    "definitions": [
      {
        "index": 1,
        "gloss": "drawstring purse",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "残りは巾着へ、チャラ／＼と云うも冬の音なり。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には閻魔の巾着、浦島の火打箱などといういかがわしいものもあるにはあるのである。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　呼ばれて振り返った巾着切跡見ず三次。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｔ「年は若いが跡見ず三次」（Ｏ・Ｌして）Ｔ「江戸で名うての巾着切です」Ｓ＝町角　角を曲って三次やって来た。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次が浪人に、Ｔ「此奴は巾着切ですよ」　と言う。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹が三次に、Ｔ「巾着切って嫌ですわね」　と言う。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝坊フト思い出した様に、Ｔ「おじちゃんは巾着切だね」　と訊く。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑って、Ｔ「そうだ日本一の巾着切だ」　と威張って見せた。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「巾着切のおじちゃん遊ぼうよ」　これには流石の三次も面喰らった。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「姉ちゃん昨日の巾着切のおじちゃんだよ」　お絹が、えッと驚いた。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「俺は巾着切」　と言って、Ｔ「あんな堅気の娘さんに……」　と言って、Ｔ「俺の様なやくざ者が惚れるのは間違いだ」　泌々と独り言。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺はやくざな巾着切だ」　と言って、Ｔ「それに引換えお前は立派な堅気な娘さん」　と言って涙ぐむ。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お小夜がせせら笑って、Ｔ「御冗談でしょう」　なにッと主膳、Ｔ「如何にもあたしァおさらばお小夜ッてしがねえ巾着切サ」　と言って、Ｔ「連判状とか何とか言う」　と言われて主膳ナニッと顔色変えた。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "可愛い男を忍ばしてあるから、巾着の底を掃いてせいぜいの御馳走をしているんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "喧嘩か巾着切りでしょう」「そんなことかも知れねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "其後親戚のものから、これを腰にさげて居れば犬が怖れて寄つかぬというて、大きな豹だか虎だかの皮の巾着を貰ったので、それを腰にぶらぶらと下げて歩いたが、何だか怪しいものをさげて居た為めででもあったかして犬は猶更吠えつくようで、しばしば柳屋の前では閉口しました。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しまた可笑しかったのは、其巾着をさげて机の前に坐って手習をして居ると、女の人達が起ったり坐ったりする時に、動もすると知らずに踏みつける、すると毛がもじゃもじゃとするのでキャッといって驚く。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬に吠えられるのは怖かったが、これはまた非常に可笑しく思ったから今以て思い出して独り興ずる折もある位で、本宅を捜したらまだ其大巾着がどこかにあるだろうと思います。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "金目の懸った宝なんざ、人が大切がって惜しむもので、歩るくにも坐るにも腰巾着につけていようが、鎖を下ろしておこうが、土の中へ埋めてあろうが、私等が手にゃあお茶の子さ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……少しばかり巾着から引だして、夫人にすゝむべく座布團を一枚こしらへた。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、細流は、これから流れ、鳥居は、これから見え、町もこれから賑かだけれど、俄めくらと見えて、突立った足を、こぶらに力を入れて、あげたり、すぼめたりするように、片手を差出して、手探りで、巾着ほどな小児に杖を曳かれて辿る状。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは風情じゃ……と居士も、巾着じめの煙草入の口を解いて、葡萄に栗鼠を高彫した銀｜煙管で、悠暢としてうまそうに喫んでいました。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あえて世間をどうしようなぞという野心は無さそうに見えたのに――　お供の、奴の腰巾着然とした件の革鞄の方が、物騒でならないのであった。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきから何だか邪魔だと思ったら、あたしの帯にしっかりと獅噛み付いて、これが本当の腰巾着というんだね。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人はこの時大変こわい顔をしましたが、何も知らずに羽子をついている美代子さんのすぐうしろに来て、小さな金襴の巾着をポケットから出してその口を拡げながら、「オーチンパイパイ」　と云いました。",
              "citation": {
                "source": "クチマネ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人は又ニヤリと笑ってあたりを見まわしましたが、そのまま巾着の口を閉じて懐中へしまって、反物を担いで今度は隣家の門口へ行って知らぬ顔で、「けんとんけんちゅう入りまションか」　と呼びました。",
              "citation": {
                "source": "クチマネ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前に最前の支那人が汚いシャツ一枚になって腕まくりをして、巾着の口を開いて中をのぞきながら、「メーチュンライライ」　と云いますと、一人の女の児が見事な洋服を来たままヒョイと机の上に飛び出しました。",
              "citation": {
                "source": "クチマネ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人はニヤニヤ笑って巾着の口を閉じながら、「お嬢さん。",
              "citation": {
                "source": "クチマネ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして巾着の口を開きながらこう云いました。",
              "citation": {
                "source": "クチマネ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "オーチンパイパイ」　女の児が泣く泣く口真似をすると思うと、見る間に巾着の中に消え込みました。",
              "citation": {
                "source": "クチマネ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
