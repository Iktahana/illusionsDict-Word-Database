    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sharpness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
