[
  {
    "uuid": "a9ec4ccc-0e03-5d9c-88ec-528664da3ec9",
    "entry": "切れ味",
    "reading": {
      "primary": "きれあじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
