          "literary": [
            {
              "text": "品は初一念を翻さずに、とう／＼二十で情交を結んだ綱宗が七十二の翁になつて歿するまで、忠実に仕へて、綱宗が歿した時尼になつて、浄休院と呼ばれ、仙台に往つて享保元年に七十八歳で死んだ。",
              "citation": {
                "source": "椙原品",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "致方がないので、その近くの歯科をたづねると、いづれも休院か廃院の有様であつた。",
              "citation": {
                "source": "三年",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            }
          ]
        }
