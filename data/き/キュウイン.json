[
  {
    "uuid": "1b9cae2f-20a6-5b4a-8d42-790f8f83a5a9",
    "entry": "吸引",
    "reading": {
      "primary": "きゅういん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
