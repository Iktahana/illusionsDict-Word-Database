        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "登山やハイキングなぞの流行といふこともそんな風なことかも知れぬ。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "講談社がキングという雑誌を復活させたという新聞広告を見て、私は列国の教養人に対し、冷汗をかきました。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした作曲は、流行小唄としてたしかに新しい創造であり、エポツクメーキングのものかも知れないのである。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは流行唄としての新しいエポツクメーキングであるか知れない。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "イギリスのブルウストッキングであるということだけは、間違いないようだ。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の住居は東京の、井の頭公園の裏にあるのだが、日曜毎に、澤山のハイキングの客が、興奮して、あの邊を歩き※つてゐる。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の草原であるが、それでも、ハイキングの服裝凜々しい男女の客は、興奮してゐる。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が美味しい美味しいと、そのお魚フライを食べてゐると、やがてツカツカと、白い大きい※ーレをかぶり、青い洋服に薄い焦茶のストッキングをはいた、大きなアメリカの小母さんが這入つて来ました。",
              "citation": {
                "source": "夜汽車の食堂",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "○折角ハイキングに行っても、帰って来て是非銀座へ寄らねば何となく物足り無い。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また最近にタイムス週刊の画報に出た、彼がキングス・カレッジで講演をしている横顔もちょっと変っている。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "キングは名代を遣わして参列させ、その他ケンブリッジ大学や王立協会の主要な人々も会葬し、荘園の労働者は寺の門前に整列した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると太田ミサコは、ソファに片脚あげて、ストッキングを結んだ華美な薔薇の花模様の結び目をゆるめると、「いくら破廉恥でも淫売婦の逢い曳じゃないのよ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹の皮のはられた藍色の壁に向って、スモオキングを着た男たちが、自分の影にむかって挨拶をしていた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お嬢さん、クッキングですか」　普通の人の背では届かぬアパートの部屋の窓の硝子戸の隙から、帽子の下の及川の正しく並んだ眼が覗いていました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃の青年男女はそんなことを叫ぶ代りに直ちに実行に移して、大空の下、大地の上を、天幕旅行にハイキングに、登山にスキーに、競走に水泳に、ドライヴに乗馬に、積極的に自然へ向って飛び出して行きます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第六七課　光明中のハイキング　米国の詩人ホイットマンが、動物を詠んだものの中にこういうのがあります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃、ハイキングが流行ります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは誰でも、光明のハイキング倶楽部の会員であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は、ちょっと思いついた特色ある二人を挙げただけでありますが、実はこの事実を信ずる人も信じない人も、みな光明中のハイキングをなしつつあるのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ蚊帳なしで寝られたのはよかつた、蚤の多いのには閉口した、古いキングを読んだり隣家のレコードの唄を聞いたり、――これもボクチン情調だ。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど入笠山あたりのハイキングから帰って来たらしい、加世子の従兄と登山仲間の友人とが、裏の井戸端で体をふいているところだったが、加世子が見つけて、縁端へ出て言葉を交している工合が、どうもそうらしいので、均平も何か照れくさい感じでそのまま女中の案内で二階の加世子の部屋へ通った。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわんや近頃流行のハイキングなんかという、颯爽たる風情の歩き様をするのではない。",
              "citation": {
                "source": "秋と漫歩",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥棒　Ｇメン、アルカポネ、キングコング、のらくろ伍長、江戸ツ子健ちやん、すゝめフクちやん、まだいろいろある。",
              "citation": {
                "source": "ラムプの夜",
                "author": "――学芸会のための一幕劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日には、高尾山へ、以上の四人で冬のハイキングを決行した。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "和服の裾から白いストッキングをはいているのが見える。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "イギリスのブルウストツキングであるといふことだけは、間違ひないやうだ。",
              "citation": {
                "source": "音について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学の講師か何かやつてゐる浪漫派の一友人が、ハイキングの途中、私の宿に立ち寄つて、そのときに、ふたり二階の廊下に出て、富士を見ながら、「どうも俗だねえ。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或晩、それは欧洲の気候の内、一番よい五月の末頃、アグネスの入会して居る欧洲ハイキング・クラブの会員である巴里のイボギンヌから誘い状が届いた。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
