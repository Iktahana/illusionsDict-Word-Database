        "examples": {
          "standard": [
            {
              "text": "サッカー選手は力強いキックでボールをゴールに蹴り込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は焦ってしまい、相手に無謀なキックをしてファウルを取られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「痛い！今、後ろからキックされた！」と少年が泣き出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ダンスのパフォーマンスで、彼女は高く足を上げるキックを披露した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」　四郎とかん子とは小さな雪沓をはいてキックキックキック、野原に出ました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐は可笑しそうに口を曲げて、キックキックトントンキックキックトントンと足ぶみをはじめてしっぽと頭を振ってしばらく考えていましたがやっと思いついたらしく、両手を振って調子をとりながら歌いはじめました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キック、キック、トントン。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キック、キック、キック、キック、トントントン。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　キック、キック、トントン。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キック、キック、キック、キックトントントン。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キックキックトントンキックキックトントン　凍み雪しんこ、堅雪かんこ、　　　　　野原のまんじゅうはぽっぽっぽ　酔ってひょろひょろ太右衛門が　　　　　去年、三十八たべた。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キックキックキックキックトントントン　写真が消えました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
