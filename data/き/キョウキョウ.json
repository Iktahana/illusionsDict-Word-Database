[
  {
    "uuid": "a9417ee0-7b6e-5497-af57-26f287c030e6",
    "entry": "京響",
    "reading": {
      "primary": "きょうきょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
