        "examples": {
          "standard": [
            {
              "text": "未払い家賃が続いたため、大家さんから強制処分を通告されたんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "裁判所の決定により、滞納した税金に対する財産の強制処分が執行されたらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "『これは最終警告です。期限までに従わない場合、法的な強制処分となります』と担当者は厳しく伝えていたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "之は念の為に云っておくが起訴前の強制処分で、刑事訴訟法第二百五十五条によるのだ。",
              "citation": {
                "source": "殺人迷路",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "強制処分は予審判事の命令によって行われ、まもなく小夜子の死亡の原因についても調査その他が遂行されました。",
              "citation": {
                "source": "死者の権利",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三好　強制処分になる迄は居る。",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
