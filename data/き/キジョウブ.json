        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はどんな危険な任務にも気丈夫に立ち向かう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "病と闘う彼女の気丈夫な姿に、多くの人が感動した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの人は、いざという時に頼りになる、本当に気丈夫な性格だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
