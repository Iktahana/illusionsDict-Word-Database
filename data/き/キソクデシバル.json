        "examples": {
          "standard": [
            {
              "text": "新しい寮生活は多くの規則で縛られており、最初は息苦しく感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "監督は選手たちを厳しすぎる規則で縛るのではなく、自主性を重んじる方針だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "組織は個人の自由を必要以上に規則で縛るべきではない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "とくに寮では、きみたちを規則で縛るようなことはしたくない。",
              "citation": {
