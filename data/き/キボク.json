    },
    "definitions": [
      {
        "index": 1,
        "gloss": "tortoise-shell divination (in ancient China and Japan)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "播磨守泰親は陰陽博士安倍晴明が六代の孫で、天文｜亀卜算術の長として日本国に隠れのない名家である。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "播磨守泰親は陰陽博士安倍晴明が六代の孫で、天文亀卜算術の長として日本国に隠れのない名家である。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「亀卜祭文（釈紀引用亀兆伝）」には、太詔戸命の名が見え、亀兆伝註には、亀津比女命の又の名を天津詔戸太詔戸命として居る。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ふに、亀津比女命は固より亀卜の神であらう。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀卜の神にして、壱岐の海部の卜部の祀つた亀津比女が何故祝詞と関係をもつかと言ふ問ひは、祝詞と占ひとの交渉の説明を求めることになる。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀卜・鹿卜では、灼き出されて罅入つた町形の事だ。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "卜部等が亀卜を灼くにも、中臣太詔詞を言ひ祓へ反覆して、町形の出現を待つのであつた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "「亀卜祭文」と言ふは、亀卜の亀のした覆奏の形式の変形と見るべきもので、此に対しての呪言を求めれば、中臣太詔詞の外はない。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀卜の亀の精霊が、太詔戸命では訣らぬ事である。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "「亀卜祭文」なども、神祇官の卜部等の唱へ出したものであらう。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "此等の海部の内、亀卜に達したものが、陰陽寮にも兼務する事になつたものと見える事は、後代の事実から推論せられる。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "此とて、所謂｜秀手の占へと称せられた亀卜に熟した、壱岐の海部の後と言ふことが出来ないもので、やはり、近代の移住と言ふべきであらう。",
              "citation": {
                "source": "雪の島",
                "author": "熊本利平氏に寄す",
                "note": "青空文庫"
              }
            },
            {
              "text": "悠紀・主基の二个国は、何時頃から定められたか訣らぬが、近代は、亀卜で定められる。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかにシナにては亀卜の法があるも、わが国にては今日これを用うるものはない。",
              "citation": {
                "source": "迷信解",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつ、卜筮は易筮にせよ亀卜にせよ、その種のなんたるを問わず、今日まで民間に伝わるものは、すべて非道理的のものにして、学術上、論ずべき価値あるものにあらず。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれの精神がすみきらないで、遠知の術のできないときは、この亀卜という占いをたてて見るのが常であった。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方角は、果心居士の亀卜がしめしたところであるが、この占いがあたるか否か。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お師匠さまがつらつら亀卜の卦面を案じまするに、すなわち、――富岳ニ鳳雛生マレ、五｜湖ニ狂風生ジ、喬木十｜悪ノ罪ヲ抱イテ雷ニ裂カル――とござりましたそうです」「なになに？",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも鞍馬の上から加茂の競馬を見るようにな」「して、いつこの武州へ」「ゆうべ、なにげなくれいの亀卜の易をこころみたところが、どうもはなはだおもしろくない卦面のしらせじゃ。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀卜の易とはなにか？",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんならそのときぼくはお客様になっていってもいいだろう。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときぼくらはひどい仕事をしたほかに、どうしてそれに追い付くか。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときぼくはネリちゃん。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「故郷なんてものは、泣きぼくろみたいなものさ。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」この友人の右の眼の下には、あずき粒くらいの大きな泣きぼくろが在るのだ。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑いが止まるとあなたは直ぐ、真紅な顔になって、部屋に帰ってしまいましたが、そのときぼくがあなたを撲りつけたい腹立たしさで、一隅から笑いもせずに睨みつけていたのを御存知ですか。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと冬になったら、もとの巣がこいしくなって帰ってくるよ、そのときぼくらはあたたかい心をもってむかえてやればいい」「そうだ、ぼくはあまりに考えすぎていた」「ハハハ、これでどうやら過敏症も全快らしいね、おめでとう」　とゴルドンがほがらかに笑った。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときぼくは、自分の健康がもうとりかえしのつかない程そこなわれているのに気がついた。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきぼくが、ニセの針目博士にここへつれこまれるのを小杉少年が見ていて、いそいで検事に知らせたのでしょう。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきぼくが見たとき、カンバスの下から出ているあの浮標のうえに、たしか、その黒いバラのしるしのあるのをみとめました」　この話は、大佐をおどろかした。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
