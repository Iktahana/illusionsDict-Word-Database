        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "殊に時候が夏だけに気味が悪い。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は巡査が変に気味が悪い。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべ釣って来たのは雄の鯉で、その雌が取り返しに来たんじゃあるめえかな」「返してやったからいいようなものだが、なんだか気味が悪いね」「どうも変だな」　と、藤吉は今更のように表をみかえった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか気味が悪いので、家主もとうとうその家を取り毀してしまったそうですよ」",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "俄に外の音はやみ、淵の底のやうにしづかになってしまって気味が悪いくらゐです。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（あれ、気味が悪いよ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おお、薄気味が悪いねえ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あゝ、美しさに気味が悪い。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの手すりの上をすべって行くゴムの帯もなんだか蛇のようで気味が悪いと言った人もある。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分ながら少し、気味が悪い。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わからんかね」「でも、ちょっとポチが見えなくなると、ポチはどこへ行ったろう、どこへ行ったろう、と大騒ぎじゃないの」「いなくなると、いっそう薄気味が悪いからさ、僕に隠れて、ひそかに同志を糾合しているのかもわからない。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "俄に外の音はやみ、淵の底のようにしずかになってしまって気味が悪いくらいです。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は思わず、『母上如何か仕て居なさるよ、気を附けんと……』　里子は不安心な顔をして、『私｜真実に気味が悪いわ。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "怨霊が私に乗移って居るから気味が悪いというのでしょう。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは気味が悪いでしょうよ。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも僕のしたことを誰も気のついた様子がないので、気味が悪いような、安心したような心持ちでいました。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校に行ったらみんなが遠くの方から僕を見て「見ろ泥棒の※つきの日本人が来た」とでも悪口をいうだろうと思っていたのにこんな風にされると気味が悪い程でした。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と遮って上げた手の、仔細なく動いたのを、嬉しそうに、少年の肩にかけて、見直して呼吸をついて、「銑さん、お止しなさいお止しなさい、気味が悪いから、ね、お止しなさい。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「沢山よ、銑さん、私はもう、」「いえ、まあ、どっちが気味が悪いんですね。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛虫は気味が悪い、けれども怪いものでも何でもない。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何、寒くはないです、寒いどころではないですが、貴女、裾が濡れましたで、気味が悪いでありましょう。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いえ、もう潮に濡れて気味が悪いなぞと、申されます身体ではありません。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "真似はせずとも可い事を、鱗焼は気味が悪い。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "串戯じゃあない、気味が悪いや、そういってお前放さしてくんな。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝さんお聞き、蛇がその累々した鱗を立てるのを見ると気味が悪いだろう、何さ、恐くはないまでも、可い心持はしないもんだ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体こんなにおれの悪口をよろこんで笑ふのはみんなが一人も密造をしてゐないのか、それともおれの心底がわかってゐるのか、どうも気味が悪い、よしもう一つだけ山をかけて見ようと思って最後にコップの水を一口のんでできる丈け落ち着いて斯う云ひました。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "森の中はまっくらで気味が悪いようでした。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに私だって気味が悪い。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "女もうっかりしたように、「ざぶり、ざぶりと、横瀬を打って気味が悪い。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "外出好の綾子夫人が一室にのみ垂込めて、「ぱっとしては気味が悪い、雨戸を開け勿。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
