        "examples": {
          "standard": [
            {
              "text": "「各支店でバラバラだった顧客管理の手法を共通化して、業務の効率を上げよう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「よし、似たような機能を持つ関数を共通化して、ソースコードをスッキリさせたぞ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「部品の共通化を進めたおかげで、今回の新製品は製造コストを大幅に抑えられた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "すなわち昔は、その役々によって色々の扮装をしたものが、舞台効果を主として洗練されて行くうちに、次第に単純化され共通化されてしまったもので、現在でも、そうした方向にドシドシ進化しつつある。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ＤＯＳ／Ｖによるソフトの共通化を目指して参画したが、この一年なんら成果は得られなかった」とあった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＪＳ―ＷＯＲＤをきっかけとしてジャストシステムと提携したアスキーは、ＫＴＩＳをマルチプランをはじめとする同社のアプリケーションに組み込んで、変換モジュールを共通化することのメリットをすでに実証していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
