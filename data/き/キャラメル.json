    "definitions": [
      {
        "index": 1,
        "gloss": "caramel (soft candy)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
