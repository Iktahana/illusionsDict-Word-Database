        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　局へ内地の新聞を読みに来ている、二三人の居留民が、好奇心に眼を光らせて受付の方へやって来た。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はそのことのために、居留民団で会議を開いた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家も、安楽椅子も、飾つきの卓も、蓄音機も、骨董や、金庫も、すべて、ナラズ者の南兵の掠奪に蹂躪されてしまうだろうと居留民たちは考えさせられた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人だけ離れ島に取り残されたように心細くなっていた居留民は、なつかしさをかくすことが出来なかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お、お、お……」　この感情は、露わに表現しないにしろ、迎えに出揃った居留民達のどの胸にも、浸潤しているところのものだった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの居留民達は、自分達の家とは反対の方向へ列をなして去って行く軍隊を、なつかしげに、いつまでも立って見送っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、おとなの居留民達は、出兵請求の決議にかけずりまわり、一ツ一ツ印を集め、懇願書を出して、折角やってきて貰ったなつかしい兵士が、自分達のちっぽけな家とはかけ離れた、工場や銀行の守備に赴くのを、はたして、ペテンにひっかゝったように、憤ろしく、意外に感じなかっただろうか？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、居留民保護の名で、盲腸炎の小母を見舞に帰るひまもなくせき立てられて、あわたゞしく、こゝまでやって来た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "居留民は、この守備区域内へやって来いというのだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "居留民保護という段になりゃ、ベタ金だって、タンツボだって、働きに変りはねえからな。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君ハ、日本居留民ノ生命ヲ保護スルタメニ来タノデアルカ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "居留民ノ財産ヲ守ルタメニ来タノデアルカ？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思イ見ヨ、諸君ハ、現ニ、商埠遙ニ散在シテイル貧窮セル居留民達ノ生命ヲモ財産ヲモ保護シテハイナイノデアル。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君ハ、居留民ノ生命財産ノ保護、国旗ノ尊厳トイウガ如キ言葉ニ迷ワサレテハナラヌ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は、居留民の生命財産の保護に命をかけている。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……実際居留民の保護だけなら、何故、こんな不便な、きたないマッチ工場の南京虫がうようよしている寄宿舎に入れて置くかね？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校だって、居留民団だって、ＫＳ倶楽部だって、もっときれいな、大きい建物がいくらでもあるんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャムなどには、寛永の頃には、日本の居留民が、八千人居ると云はれた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "居留民はそこにおける地位、財産を守ろうとする一致した目標をもってがんばっている。",
              "citation": {
                "source": "明日の言葉",
                "author": "――ルポルタージュの問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハルビン総領事川上俊彦、日本人居留民会会長河井松之助、満鉄代理店日満商会主、他二三。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人側は居留民会役員、満鉄代理店日満商会員、各団体代表者、一般出迎人。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢口の松村領事が居留民を引上させたのは大早計であつたと云ふ批難が上海では行はれて居る。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "上海、香港、新嘉坡、何れの日本居留民中にあつても公共的の事業に物質上の基礎となつて居る者は常に彼等では無いか。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わずかに町々を回って歩くのは、町内のものが各自に組織した自警団と、外国軍艦から上陸させた居留民保護の一隊とがあるだけだった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし早く帝に拝謁することがかなわないならすみやかに浪華の地を退きたい、そして横浜にある居留民の保護に当たりたい一同の希望であると。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく、その日が来たら、居留民を保護する暇なぞは日本新政府の力にもなくなろう。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "小田原から神奈川の宿まで動いた時の東海道軍の前には、横浜居留民を保護するために各国連合で組織した警備兵があらわれたとある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍部のこの監視振りは併し、上海に於ける日本人居留民にそのまま反映した。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした云わば居留民的ショーヴィニズムとは関係なく日本は東洋の平和のために、忍ぶべからざる行為をも忍んで遂行したのだ、ということを忘れてはならないのだ。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍部のこの監視振りは併し、上海に於ける日本人居留民にそのまま反映している。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
