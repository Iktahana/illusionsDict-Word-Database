        "examples": {
          "standard": [
            {
              "text": "二社は、新製品開発のために、緊密な協力関係を構築した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "国際連合は、平和と安全のために加盟国との協力関係を維持している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このプロジェクトを通して、両国間に新たな協力関係が生まれました」と、大使は語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、子供の学校行事に積極的に参加し、学校との協力関係を深めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "今や激しい急流となりはじめたパーソナルコンピューターをめぐるうねりは、無秩序であらかじめ予想することなどとてもできなかった錯綜した協力関係の中で、増幅されていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロコピウスの目を通してユスティアヌスの治世を研究すると、帝国を崩壊に導いた三要素の協力関係を極めて鮮明に得ることができる。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が我々と協力関係にある中国軍人とも、行程の間で出会う山地の住民とも諍いを起こさないだろう点も承知している。",
              "citation": {
                "source": "西洋科学は素晴らしい",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
