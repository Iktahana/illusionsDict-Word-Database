[
  {
    "uuid": "362c28c3-4cf4-5144-8970-c8e57554af58",
    "entry": "享有",
    "reading": {
      "primary": "きょうゆう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
