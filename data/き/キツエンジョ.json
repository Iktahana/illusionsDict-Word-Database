        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "駅前の喫煙所は、いつも多くのサラリーマンで賑わっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "オフィスビルの裏手に、仮設の喫煙所が設置された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "指定された喫煙所以外での喫煙は、罰金の対象となる場合がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "待ち合わせまで少し時間があったので、喫煙所で一服した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして前甲板の喫煙所で団長ワーナー博士に二人を紹介した。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "北京のように公許の阿片喫煙所はないが、平庚五里の遊里はなかなか明朗である。",
              "citation": {
                "source": "北京・青島・村落",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺はおとなしくその狭い喫煙所の方へ行った。",
              "citation": {
                "source": "神棚",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五人の者が喫煙所へはいって来た。",
              "citation": {
                "source": "神棚",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は立上って、喫煙所から出で、活動小屋から外に出てしまった。",
              "citation": {
                "source": "神棚",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿片喫煙所へばかり案内したがっている。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "サン・ティアサント街の一｜珈琲店とマテュラン・サン・ジャック街のセー・ビヤール喫煙所とは、学生らの集合所となっていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ヴォージラール会堂の鐘が一時を報じた時、アンジョーラはリシェフー喫煙所に達した。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
