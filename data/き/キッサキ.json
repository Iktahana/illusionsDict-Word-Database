    "definitions": [
      {
        "index": 1,
        "gloss": "point (of a sword, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
