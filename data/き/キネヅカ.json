        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "餅つき大会で、彼は力強く杵柄を握り、見事なリズムで餅をついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖父が手作りした杵柄は、長年の使用で手のひらにしっくりと馴染んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古民具店の隅に、煤けているけれど頑丈そうな杵柄が置かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "あれそれと小田原をやってる処へ、また竜川とかいう千破矢の家の家老が貴方、参ったんだそうで、御主人の安否は拙者がか何かで、昔取った杵柄だ、腕に覚えがありますから、こりゃ強うがす、覚悟をして石滝へ入ろうとすると、どうでございましょう。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と昔取りたる杵柄にて柔術も少々心得たれば、や、と附入りて、えい、といいさま、一人を担いで見事に投げる。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "印刷は無論ただ同然で引き受けてやったし、記事もおれが昔取った杵柄で書いてやった。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな為事は昔取った杵柄で、梅なんぞが企て及ばぬ程迅速に、しかも周密に出来る筈のお玉が、きょうは子供がおもちゃを持って遊ぶより手ぬるい洗いようをしている。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐れ入りまするが手前も昔取った杵柄……思い寄りも御座いまするでこの場はお任かせ下されませい。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り、土地柄が悪く、性質の良くない酒呑み同志が喧嘩をはじめたりして、柳吉はハラハラしたが、蝶子は昔とった杵柄で、そんな客をうまくさばくのに別に秋波をつかったりする必要もなかった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "死人の後家彼僧主を頼み、僧主官許を得て、今は回教僧だが昔取つた杵柄と丹誠を凝し、上帝に祈る事僅かに數分、爾時尸肉忽ち落ち失せ白骨のみ存つた。",
              "citation": {
                "source": "詛言に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒吉は、昔とった杵柄の、源二郎爺に呼吸を教わりながら、いよいよ恐ろしい曲芸の稽古にとりかかった。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "古し取たる杵柄の、覚束なくも奏でけるに、黄金丸も興に入りて、病苦もために忘れけり。",
              "citation": {
                "source": "こがね丸",
                "author": "巌谷小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後叔父は臼に撲たれ、他は木から落猿となつて、この山に漂泊ひ来つ、金眸大王に事へしなれど、むかし取たる杵柄とやら、一束の矢｜一張の弓だに持たさば、彼の黄金丸如きは、事もなく射殺してん。",
              "citation": {
                "source": "こがね丸",
                "author": "巌谷小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "あら、昔とった杵柄に、都鳥の一曲ですって、冗談じゃありませんよ。",
              "citation": {
                "source": "みやこ鳥",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その道にかけては、わたしも昔取った杵柄で、今の人たちがやるのを見ていると、間緩くて腹が立ってたまりません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔取った杵柄とでもいおうか、調べ方は手堅くて早く、屈んだかと思うと背伸びをした。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らくの間お前さんが番頭の代りを勤めて、この事を誰にも氣取られないやうにして貰ひたいが、何うだらう」「へエ／＼」「それ、番臺から流しの合圖だ、頼んだよ」「へエ――」　亭主は泣き出しさうな顏をして着物を脱ぐと、それでも昔取つた杵柄、すつかり三助になり濟して店の方へ出て行きました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "人肌地藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう殺傷事件の外交をするような若い記者ではありませんが、眼と鼻の間で起った事件というと、昔取った杵柄で、さすがに猛烈な職業意識が働きかけます。",
              "citation": {
                "source": "悪魔の顔",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙子は床の上へ半身起き直って、覚束ない手付き乍ら、昔取った杵柄で、何んかを吟み乍ら暫らくは器用に羽子を突いて居りましたが、「あッ」不意に大きい声を出します。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第二夜　匂う踊り子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくの間お前さんが番頭の代りを勤めて、この事を誰にも気取られないようにして貰いたいが、どうだろう」「ヘエヘエ」「それ、番台から流しの合図だ、頼んだよ」「ヘエ――」　亭主は泣き出しそうな顔をして着物を脱ぐと、それでも昔取った杵柄、すっかり三助になりすまして店の方へ出て行きました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人肌地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに昔取った杵柄で、腰がしゃんと極まって、少しの危なげもないばかりでなく、時々、あっと思うような離れ技を演ずる。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔取った杵柄で、今でも社のチームの投手を承わっている。",
              "citation": {
                "source": "善根鈍根",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハッハヽヽ」「…………」「しかし昔取った杵柄だから、材料さえあれば書けるだろう？",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事探しは、昔取った杵柄へ当然行き着く。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんの、藤判官だといって、高が青侍の四人や五人、わたしだって、昔とったきねづかさ。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
