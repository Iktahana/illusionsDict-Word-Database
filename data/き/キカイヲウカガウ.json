        "examples": {
          "standard": [
            {
              "text": "ライバルが油断して隙を見せるのを、彼は虎視眈々と機会をうかがっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「よし、部長の機嫌が良くなる機会をうかがって、この企画書を出してみよう」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "投資家たちは、市場が冷え込んだタイミングで買い支える機会をうかがっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "都へ帰れば機会をうかがうことができる。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "とともに、丹下左膳という人間の腕前が、いかにものすごいか、それが知れたのですから、それはウッカリ手出しはできないと、一同策をねり、議をこらして、機会をうかがうことになる。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
