        "examples": {
          "standard": [
            {
              "text": "人類が狩猟採集生活を送っていたのは、主に旧石器時代のことだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "旧石器時代の人々は、洞窟の壁に美しい絵を描いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域の地層からは、旧石器時代後期の生活痕跡が見つかっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "小学校の授業で、旧石器時代から縄文時代への文化の変化について学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私はこの問題の概略、即ち旧石器時代、新石器時代、青銅時代、鉄時代と、ラボックが定限した欧洲の四つの時代に就て語り、次にステーンストラップがバルティック沿岸の貝墟でした仕事を話し、最後に大森の貝塚のことを話した。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧石器時代から新石器時代への転換期に文明史における最大の１歩が起きた。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "住居　旧石器時代の人たちは洞穴に避難所を求めた。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
