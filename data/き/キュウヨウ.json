[
  {
    "uuid": "b72c60ff-31b7-5312-98e3-2e5e25daebe5",
    "entry": "休養",
    "reading": {
      "primary": "きゅうよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
