      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "machine-made",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この陶器は、手作りの風合いを出すためにあえて機械製に見えないように工夫されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今日の日本では、ほとんどの工業製品が機械製で大量生産されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、機械製ではなく、職人の手で作られた家具を好んで購入する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "機械製だからといって品質が低いわけではなく、むしろ均一性が保たれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "……今時の映画と来たら、単なる機械製産品以外の何者でもあり得ない。",
              "citation": {
                "source": "十年後の映画界",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそも文明の進み分業の行わるるに従い、機械的｜大仕掛の製造盛んに行われ、低廉なる価格を以て、能く人々の要に応じ得べきに至るといえども、元来機械製造のものたる、千篇一律風致なく神韻を欠くを以て、単に実用に供するに止まり、美術品として愛翫措く能わざらしむる事なし。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この海のない国は、温泉の中に機械製の波を起し、磯に打ち上げる波頭を想像しつつ抜き手を切って喜び勇んでいる。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、他の一面に近頃ではいろいろの軍需工場に多数の女が働いているし、その農村の工業化の問題においても、専門家大河内子爵は、機械製造工程の発達した現在にあっては、安い賃銀の農村の娘が、たやすく、自動車の部分品をも作り得るから、農村工業化の強味はそういうところにもあると新聞に意見を発表している。",
              "citation": {
                "source": "今日の文化の諸問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この言い草はわれわれ日本人には不思議に響くけれど、機械製品に飽きている向こうの連中にはこの上なく有難いとみえて、ことに亜米利加人なんか「｜手作り」とさえ聞けば、どんなに桁はずれな高値をも即座に肯定して、随喜の涙とともに否応なしに買い取って行く。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その本国の日本には、何からかにまで石や鉄で作らなければ文明と思わず、しかも機械製でなければ承知しないで、それをもって西洋風だと信じている感ちがいの亜流者が多いから笑わせる。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三〇年ころ、ソヴェト市民はドイツから機械工をよんで、精密機械製作について学ばなければならなかった。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロストフ市の郊外に新しくプロレタリア文化の壮麗な城のような「セルマシストロイ」（農業機械製造）の大工場都市がある。",
              "citation": {
                "source": "五ヵ年計画とソヴェト同盟の文化的飛躍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハレは昔は鹽と大學で聞こえた町だつたが、今は砂糖と機械製造で有名である。",
              "citation": {
                "source": "キフホイザー",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿六の投書熱のせいではなく、小資本の悲劇であるが、機械製の支那ソバが大量にでまわるようになって、その方が安いから売れなくなったのである。",
              "citation": {
                "source": "人生案内",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には手打ちの支那ソバはさすがに味が別だと云ってヒイキにしてくれる店もあるが、そういう店に限って日に十ぐらいしかでない喫茶店なぞで、大口は味より安値でみんな機械製の方へ転向してしまったから日に三十ぐらいがせいぜいということになってしまった。",
              "citation": {
                "source": "人生案内",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は勿論一個の機械製作者の立場として、一刻も早く完全な車を祖國の地上を走らせ度いと日夜念願致して居るのであります。",
              "citation": {
                "source": "ボデー意匠審査会　美術の粹を蒐め獨特の形態美へ",
                "author": "――豐田常務の挨拶――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで単に八十五名の人間が各々五〇｜磅すなわち一年につき、四、二五〇｜磅の費用で雇われ、そしてこの機械を売ったためにこれらの人々に前払された労賃以上に生ずる七五〇｜磅が、機械製造者の資本の利潤を構成していると仮定せよ。",
              "citation": {
                "source": "経済学及び課税の諸原理",
                "author": "PRINCIPLES OF POLITICAL ECONOMY AND TAXATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、プラスチック（飛行機の耐破ガラス）、爆薬製のフェノール、アセトン、トルオール、戦略的軽金属のマグネシウム、現在、生産高七千六百万円程度の工作機械製造を、十六年には二億円に拡充する飛躍的な目標をたて、あらゆる方面へ原料輸入の触手を伸ばしていた。",
              "citation": {
                "source": "川波",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "機械製品が冷やかであり潤いのないのはここに起因する。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして機械製品の目標は手工品の模倣に止まるではないか。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは機械製品に美を盛って行かねばならぬ。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "機械製品にも特殊な美があることを否定することはできない。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが今日まで機械製品で手工品の美を越え得たものは一つもない。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして機械製造におけるよりも手工製作において、より多く仕事への幸福を感ずるであろう。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなる機械製品が手工品の美を越え得たろうか。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは機械製品において醜き作のあまりにも多くに接し、かつはその労働が単なる苦痛に終ることを経験し過ぎている。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "問　機械製品にもっと美を盛ることは可能ではないか。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "機械製品を美しくするためには、もっと人間さが活かされねばならない。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって現状のままで機械製品に美を加えようとするのは無理がはなはだ多い。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして今のままなら民藝は廃れ、粗笨な機械製品のみふえ、独り個人的作品のみがわずかに骨董的意義で存続するに過ぎなくなるであろう。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "商品たることと機械製品たることとは密接に関係する。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一口にいえば、機械製のものにはまがいものが多いのです。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうことが禍いして、機械製品には良いものが少くなってきました。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
