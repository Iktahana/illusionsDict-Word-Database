[
  {
    "uuid": "171f89b0-f063-5087-b4e5-24622ce36fd1",
    "entry": "機械製",
    "reading": {
      "primary": "きかいせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
