        "examples": {
          "standard": [
            {
              "text": "「痛いっ！指切っちゃった」「待ってて、今救急箱持ってくるから！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古い救急箱を開けたら、中に入っていた消毒液の期限がとっくに切れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "キャンプに行くなら、絆創膏や包帯を入れた救急箱は必須アイテムだね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "会社の各フロアには、赤い十字マークがついた救急箱が設置されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "まだ食事が、始められて間もなく、チーフメートは、ボーイに「救急箱」を持たせて、「大急ぎ」で駆け込んで来た。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤十字のついた救急箱を持って歩かねばならぬ。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
