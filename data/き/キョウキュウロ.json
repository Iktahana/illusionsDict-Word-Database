        "examples": {
          "standard": [
            {
              "text": "戦時中、物資を運ぶ供給路は常に敵の攻撃目標となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "山間部の集落にとって、この細い道は唯一の生活物資の供給路だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "宇宙ステーションへの供給路が確保され、長期滞在が可能になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "最後にして最悪、主要供給路であるテムズ川が、現存人間の記憶でたった一回、グリニッジの川下で凍ってしまった。",
              "citation": {
                "source": "四日白魔",
                "author": "THE FOUR WHITE DAYS",
                "note": "青空文庫"
              }
            }
          ]
