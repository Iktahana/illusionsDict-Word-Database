        "examples": {
          "standard": [
            {
              "text": "「おっと、仕事の話の前に、まずは久闊を叙することにしましょう。お久しぶりです」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "疎遠になっていた親戚と電話越しに久闊を叙し、今度の正月の集まりについて相談した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "格式高い場では、久闊を叙する言葉選び一つにもその人の教養が表れるものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "だから実は、彼に敬意を表する気持ちよりも、久闊を叙する気持ちから、ウイスキーをふるまってやったものらしい。",
              "citation": {
                "source": "失われた半身",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "清川は久闊を叙すると、いきなり今日自分が法律家として出た公判廷の模様について話し出した。",
              "citation": {
                "source": "正義",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
