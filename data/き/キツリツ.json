    "definitions": [
      {
        "index": 1,
        "gloss": "standing tall",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その彼の威力ある屹立は、だからいつも人々のブツブツいふ聲でその脚もとを洗はれてゐた。",
              "citation": {
                "source": "詩集『戰爭』",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は此時まで殆んど喪心の有樣で、甲板の一端に屹立つた儘、此慘憺たる光景に眼を注いで居つたが、ハツと心付いたよ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と私は眞赤になつて仁王の如く屹立つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "身長七｜尺に近く、灰色の毛は針の如く逆立ち、鋭き爪を現はして、スツと屹立つた有樣は、幾百十年の星霜を此深林に棲暮したものやら分らぬ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "屏風岩の上を二十ヤードばかり進むと、正面に壁のやうに屹立つたる大巖石の中央に、一個の鐵門があつて、其鐵門の前には、武裝せる當番の水兵が嚴肅に立つて居つたが、大佐等の姿を見るより、恭しく敬禮を獻げた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "大佐一顧軍刀の鞘を拂つて、屹と屹立つ司令塔上、一｜令忽ち高く、本艦々上戰鬪喇叭鳴る、士官の肩章閃めく、水兵其配置に就く、此時、既に早し、既に遲し、海賊船から打出す彈丸は雨か、霰か。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とお丹が座を示せば、老婦人の前に光子を押据え、牛頭馬頭左右に屹立せり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには理智と数学で固まっている、氷づけの結晶した「純美」があり、大理石によって刻まれた造型美術が、立体結晶の冷酷さで屹立している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒々と屹立するピラミツドの頂点辺りに一際大きく光つてゐたのは古代埃及人が一番尊敬した天狼星でもあらうか。",
              "citation": {
                "source": "星",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、島の中央に巍然として屹立する・蝙蝠模様で飾られた・反り屋根の大集会場を造ったのも、島民一同の自慢の種子である蛇頭の真赤な大戦舟を作ったのも、凡て此の大｜支配者の権勢と金力とである。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ本堂と覚しき多角形の広間の、ひと側の中央に漢字で彫った法句経の石碑が床の上に屹立して礼拝の標的を示している。",
              "citation": {
                "source": "褐色の求道",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "流を挾んで、一大巖のとして屹立するものあり。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく眼の前に屹立っている長崎随一の支那貿易商、福昌号の裏口に在る地下室の小窓から臭って来ることがわかった。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "はるか遠くに私は、チュードル風の煙突の屹立している、古い灰色の建物をチラチラと見たが、しかしその自転車乗りの姿は、濃い灌木の蔭になってしまって、もう見ることは出来なかった。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "路は上りになって、クルックスベリーの丘の肩のところに行ったら、我々は老樫樹の中から屹立している、厳めしい廃院を見た。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち我々の馬車の両側には、英国の特有の田園が展開し、方々に散在している田舎家は、今日の殷盛な人口を思わせ、またあっちにもこっちにも、大きな四角な塔の教会が、平原の地平線の上に屹立し、緑の濃い風景、――と、昔の東部アングリアの、光栄と殷盛を想わしめるものであった。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "二本の黒々と屹立する峰が、頭上の闇のなかでおぼろに見えている。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆん手の方は巖石屹立したる伊太利の西岸にして、所々に大なる洞穴あり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "五六｜本屹立した樅の木は引つ扱いた樣な梢が相倚つて、先刻から明かるい光を厭ふ踊子を掩うて一｜杯に陰翳を投げて居たのであるが、凝然とした靜かな月が幾らか首を傾けたと思つたら樅の梢の間から少し覗いて、踊子が形づくつて居る輪の一｜端をかつと明かるくした。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "九十九谷にては見えざりし鋸山、こゝに來れば、近く屹立せるを見る。",
              "citation": {
                "source": "鹿野山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "路を北條に取り、神郡村を通りこせば、筑波山直ちに面に當りて屹立す。",
              "citation": {
                "source": "春の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "最早そこにはあの屹立つた岩石もなかつた。",
              "citation": {
                "source": "山間の旅舎",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とばかり兵卒の木像のやうに屹立しました。",
              "citation": {
                "source": "青白き公園",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "燐寸の棒を折つた様に胴と脚とが殆ど直角に屹立して、臀を中心にしたそれは弥次郎兵衛の通りに二三回フワフワとぎつこんばつたんをした。",
              "citation": {
                "source": "坂道の孤独参昧",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、私は二分間ばかり振り向かずに其儘屹立します。",
              "citation": {
                "source": "砂浜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも林子平の伝記や功績を記したもので、立派な瓦家根の家の中に相対して屹立している。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも茫々たる大海のうちに屹立しているので、その眼界はすこぶる闊い、眺望雄大と云ってよい。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）あたかもギリシャ彫刻にある『大言家の像』のように屹立して、両手を拡げて海の歌をうたった。",
              "citation": {
                "source": "吊籠と月光と",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "が私は、わざと直ぐには振り返らずに、尚も凝つと屹立してゐたのであります。",
              "citation": {
                "source": "晩春の健康",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "林の中ほどにではなく、ずつと端の方に、他の小木から離れて屹立してゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
