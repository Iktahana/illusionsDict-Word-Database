[
  {
    "uuid": "327661e9-f712-5882-aed1-e4ff2659d959",
    "entry": "決める",
    "reading": {
      "primary": "きめる",
      "alternatives": [
        "キメる"
      ],
      "is_heteronym": false
    },
    "grammar": {
