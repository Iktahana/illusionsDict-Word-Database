    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to decide",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "明日の会議の議題を、今晩中に決めておきたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は留学先をアメリカに決めたそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "どのレストランに行くか、まだ決めていないんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「週末、どこ行く？」「うーん、まだ決めてないな。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "えいツ、なるままだと、肚を決めるこそ人間本懐なのである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、一つの国家と、その向う側の国家とで勝手に決める問題だ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを同じ音に発音したか違った音に発音したかということは、我々は予め決めることは出来ないのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは皆一々違った音をあらわしたとは思われませんが、とにかく文字は皆違っているのですから、その中のどれだけが同じ音で、どれだけが互いに違った音であるか、そういうようなことは予め決める訳には行かない。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろわれわれはこの現象がどうして発生したかを研究し、またその将来がどうなるであろうかということを考察した上で、これに対する各自の態度を決めるのが合理的ではないかと思われるのである。",
              "citation": {
                "source": "俳句の型式とその進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父がいくら強情を張ったところで、二人がゆくえ不明になったのは争われない事実で、駈落ちか怪談か、二つに一つと決めるよりほかはないのでございます。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "題を決めるのに一日、構想を考えるのに一日、たのまれてから書き出すまでに二日しか費さなかったぐらいだから、安易な態度ではじめたのだが、八九回書き出してから、文化部長から、通俗小説に持って行こうとする調子が見えるのはいかん、調子を下すなと言われたので、決然として、この作品に全精力を打ちこむ覚悟をきめた。",
              "citation": {
                "source": "文学的饒舌",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもおたかにしてみれば、誰をかたづけるなどとはっきり決めることは何かおそろしく、強いていえば、どちらも小柄だという点で義枝をとひそかに希ってはいたものの、さすがにそれとはいい出せなかった。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年はいつの間にか自分は孤独だと決めることによって涙を流しまたその涙をひそかに愉しんでいた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "教えられた臙脂の風呂敷包と非常に背が高くてスマートだという目印でそれと分り、何が樟蔭第一の美人だ、笑わせると思ったが、しかし大袈裟に大阪中の中学生達の憧れの的だと騒がれている点を勘定にいれて、美人だと決めることにした。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時に、自力で起ちあがる腹を決めるのが、夙くから世間へ放り出されて、苦しんで来た彼女の強味で、諦めもよかったが、転身にも敏捷であった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もお嬢さんが結婚するんじゃありゃしまいし、はっきり決める手はないじゃないか。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでくじをひいて、火をつけに行くものを決めることになりました。",
              "citation": {
                "source": "赤い蝋燭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし間もなく、「こんどの村会で、村に電燈を引くかどうかを決めるだげな」という噂をきいたときには、巳之助は脳天に一撃をくらったような気がした。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉は全敗に終らせたくない意地から、舟を今日までかかったことのない場処へ持って行って、「かし」を決めるのに慎重な態度を取りながら、やがて、　「旦那、竿は一本にして、みよしの真正面へ巧く振込んで下さい」と申しました。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙がぼくを決める。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでわたくしも、「それだけ聞いとけば――」　と、あとは言葉を霞ませながら、何か深く心に決めるものがありました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "気に入るかどないか知らんけど、結婚いうもんは本人同志が決めるもんと違う。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、丸亀へ帰る途々、叔父叔母に叱られるという気持で心が暗かったが、ふと丸亀から逐電しようと、心を決めると、ほっとした。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "教えられた臙脂の風呂敷と非常に背が高くてスマートだという目印でそれと分り、何がＳ女学校第一の美人だ、笑わせよると思ったが、しかしおおげさに大阪じゅうの中学生の憧れの的だと憧れている点を勘定に入れて、美人だと決めることにした。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "単に髪が白いというだけのことで、それが山岸に祟っている怪しい女であるなどと一途に決めるわけにはいきません。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "当人が承知なら決める、いやならば断わる。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "同氏の宅で明後日、王と落合うことに決める。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、丸亀へ帰る途々、叔父叔母に叱られるという気持で心が暗かったが、ふと丸亀から逐電しようと心を決めると、ほッとした。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の方は急を要する場合だし何時まで待つてもゐられないから、三田村の「あんな奴と共同で云々」のそのあんな奴に、私は私の最初の計画通り相談することに肚をきめる。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "具体的なことがらについては、君と相談のうえできめるつもりであるが、僕のプランとしては、輸出むきの雑誌にしたい。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "詳しいことは忘れたが、何でも庄屋になる人と猟師（加八という名になっている）になる人の外に、狸や猪や熊や色々の動物になる人を籤引きできめる。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それでは大学入学の資格はどうしてきめるかとの問に対して、「偶然に支配されるような火の試練でなく、一体の成績によればいい。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それであるから片仮名でもやはり昔の言語の音を知ろうという場合には、字の違いがすなわち音の違いと考えることは出来ないのであって、これとこれとが同じ音であるということは予めきめる訳には行かないのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故「介」はどちらの類に属するかきめることが出来ないので、どちらに属するとしても二つずつの例外が出来るのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to clinch (a victory)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "最終回、彼は見事なホームランで試合を決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "重要な局面で、彼は冷静にゴールを決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大事なプレゼンで契約を決めることができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あのラストパスが、チームの勝利を決めたね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "to persist in doing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は一度やると決めたら、最後までやり通す人だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "毎日ジョギングすると決めて、もう3ヶ月続いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今度のプロジェクトは、絶対成功させると決めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は目標を決めたら、何があっても諦めない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 4,
        "gloss": "to always do",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はいつも出かける前に鏡で髪形を決める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この店はいつ行っても、料理の味がしっかり決まっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あのピアニストの演奏は、毎回音が美しく決まっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は毎朝コーヒーを飲むと決めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 5,
        "gloss": "to take for granted",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は周りの手助けを、当たり前のように決めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "親の愛情を、いつの間にか決めてしまっていたことに気づいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の優しさを当然のことだと決めてしまい、反省している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 6,
        "gloss": "to dress up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今夜のパーティーのために、彼女はいつもよりおしゃれを決めてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "デートだからって、そんなに決めてこなくてもいいのに。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は大事な商談の日は、スーツをばっちり決めていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "成人式で久しぶりに着物を決めて、気分が良かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 7,
        "gloss": "to carry out successfully (a move in sports, a pose in dance, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "スケート選手は、ジャンプの着氷を完璧に決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "難しいダンスのステップを、彼は何度も練習して決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "空手の型で、最後のポーズを美しく決めることができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "狙い澄ましたフリーキックが、ゴールネットに突き刺さり見事に決まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 8,
        "gloss": "to immobilize with a double-arm lock (in sumo, judo, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "相手の動きを封じるため、完璧に腕を固めて決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "柔道の試合で、一瞬の隙をついて相手を決めて一本勝ちを収めた。",
              "citation": {
