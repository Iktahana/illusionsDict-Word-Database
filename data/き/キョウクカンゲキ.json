        "examples": {
          "standard": [
            {
              "text": "偉大な芸術家のパフォーマンスに、観客は恐懼感激していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "災害から奇跡的に生還した人々の体験談は、聞く者の心を恐懼感激させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "初めて宇宙から地球を見た宇宙飛行士は、言葉にできない恐懼感激を覚えたそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "恩師の長年の尽力と、その成果を目の当たりにして、我々は恐懼感激した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "清盛の脳のめぐりの良さも知らず、乗船の一同、恐懼感激して、一きれの魚を味ったに違いない。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
