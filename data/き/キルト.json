    "definitions": [
      {
        "index": 1,
        "gloss": "quilt",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "君チャンハ急ニ、キャットサケンデ、ハネオキルト、ソトヘトビ出シタ。",
              "citation": {
                "source": "テガミ",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰にキルトというものを着けている。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩くたびにキルトの襞が揺れて、膝と股の間がちらちら出る。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、　ふくやさんが　目ざめると、　まず　目に　とびこんできたのが、　パッチワークキルトの上に　のった、　さくらんぼ色の　きぬの　より糸　１かせ、　そして　ベッドわきに　立っていたのが、　ばつのわるそうな　シンプキン！",
              "citation": {
                "source": "グロスターのふくやさん",
                "author": "THE TAILOR OF GLOUCESTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年前ノ出来事ガマルデ新シイ事実ノヨウニ感ゼラレ、興味津々盡キルトコロヲ知ラナイ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "………雨ノ日ハ手足ノ工合ノ悪サガ一層ヒドク、雨ガ降リ出ス前ノ日アタリカラ豫感ガアルノダガ、今日ハ朝起キルトキカラ手ノ痺レ加減モ脚ノ浮腫ミ加減モ縺レ加減モ甚ダシイ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕ハ先刻カラ或ル計画ガ心ニ浮カビツツアッタノデ、内心ハ木村ガ帰ッテクレルガ今夜コソ実行デキルト思イ、ソノ期待デ興奮シタ。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
