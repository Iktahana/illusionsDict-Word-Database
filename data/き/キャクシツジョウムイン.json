        "examples": {
          "standard": [
            {
              "text": "飛行機に乗り込むと、温かい笑顔の客室乗務員が出迎えてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "緊急時の対応について、客室乗務員が丁寧に説明してくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長時間のフライトでも、客室乗務員のおかげで快適に過ごせたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「お飲み物はいかがですか？」と、客室乗務員がカートを押して通路を回ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼らは皆、プロフェッショナルな客室乗務員だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
