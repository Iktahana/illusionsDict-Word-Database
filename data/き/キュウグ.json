        "examples": {
          "standard": [
            {
              "text": "弓道場には、様々な種類の弓具が整然と並べられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい弓具を買うために、アルバイトでお金を貯めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "弓具の手入れは、弓道の基本中の基本だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遠的競技では、特別な弓具が必要になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "大勢の門下を連れ、厳しい弓具や物々しい騎馬旅装を引っ提げて、権門を叩いて、射芸の宣布に努めて諸国を歩いたとある。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
