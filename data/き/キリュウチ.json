          "literary": [
            {
              "text": "私は点呼の訓練は寄留地の分会で受けたが、点呼は本籍地で受けねばならなかった。",
              "citation": {
                "source": "髪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、僕の寄留地などもこの際きめて置いたら都合がよかろう。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼出しの件は寄留地簡閲点呼参会願の手続きを怠つた為め本年度点呼不参者の一人としてであつた。",
              "citation": {
                "source": "煤煙の臭ひ",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏山号の着せし岸は植民州と名づけ、外国人の寄留地にして洋館並立す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
