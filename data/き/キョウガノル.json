        "examples": {
          "standard": [
            {
              "text": "最初は退屈そうだったけど、ゲームを始めたら急に興が乗ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しい趣味でも始めてみようか。何か、やってるうちに興が乗るものがあればいいな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "会議の序盤はなかなか進まなかったが、議論が深まるにつれて皆の興が乗ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ことに鯉坂君のごときは、研究に興が乗ると、昼夜の別なく熱中するのですから、細君が若しあったとしたら、随分迷惑をするにちがいありません。",
              "citation": {
                "source": "新案探偵法",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして興が乗ると、即席の五題話など始めるかまたはいたづら描きを始めるのである。",
              "citation": {
                "source": "岸田劉生の日本画",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴衣の彼女は興が乗ると踊りを披露するという。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
