    "definitions": [
      {
        "index": 1,
        "gloss": "whitewashing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼等は皆、その中では真剣になつて人生と取組み合ひ全力を出しきつて文学と四つ角力をとつてるのに、詩や俳句を作る時は、乙に気取つた他所行きの風流気を出し、小手先の遊び芸として、綺麗事に戯むれてゐるといふ感じがする。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、客は上布の着物を着ていても釣ることが出来ます訳で、まことに綺麗事に殿様らしく遣っていられる釣です。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹に何か買ってやるのを、キッカケに、新子に新しい着物を買おう、そうすれば自然でいいと、万事綺麗事好みの前川らしい考えが、胸の中に浮んで来た。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は百姓になつてまる一年だが、彼の百姓は世間一般の百姓に較べて、まだまるで綺麗事だつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし庸三は綺麗事で済まされないことも感じていたので、目を瞑るよりほかなかった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「商売が商売だから、どうせそう綺麗事に行きゃしない。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "綺麗事じゃ金は儲からない。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上｜卓子に並ぶ器物は、綺麗事が看板の一品香でも、日本の洋食屋と選ぶ所はない。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に、兎角綺麗事になりたがる嫌ひのある此作者としては、きび／＼と力に充ちてゐる事も感歎に値する。",
              "citation": {
                "source": "貝殼追放",
                "author": "「八千代集」を讀む",
                "note": "青空文庫"
              }
            },
            {
              "text": "綺麗事でもない芥を洗ひ棄てなくては、本流の煩ひになる。",
              "citation": {
                "source": "見ものは合邦辻",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、せいぜい三津五郎とさとらせたいというのだから、万事芝居がかりに、輪をかけた綺麗事でゆく。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "小鰭の鮨",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻から提灯なんか出してさ、狸ならもう少し綺麗事にするものよ、――もう辰刻過ぎぢやないの、ちよいと八さんてば」　何と言ふ惱ましさ、窓から入る秋の朝陽が、暫らくクワツと赤くなつたほどの情景です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "謎の鍵穴",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しその驚きはどれだけの期間に彼女に持續されるものか、私は少女も十五くらゐになれば大膽不敵な考へ事をするものだ、私が青年の頃に考へたことは常にばかばかしい綺麗事であつた。",
              "citation": {
                "source": "渚",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "見破ることの出來ない處にゐたから綺麗事は綺麗事にしか見えなかつた。",
              "citation": {
                "source": "渚",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し假りに彼女がさういふ綺麗事で男にうはべをうまく、つくろつてゐながら實際は男とくつついてもよい、寧ろくつついて見たいといふ考へを持つことは、男には出來ない想像であつた。",
              "citation": {
                "source": "はるあはれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻から提灯なんか出してさ、狸ならもう少し綺麗事にするものよ、――もう辰刻（八時）過ぎじゃないの、ちょいと八さんてば」　何という悩ましさ、窓から入る秋の朝陽が、しばらくカッと赤くなったほどの情景です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "謎の鍵穴",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶汲み女は三人、小體な暮しですが、銅壺に往來の人間の顏が映らうといふ綺麗事に客を呼んで横網に貸家が三軒と、洒落た住宅まで建てる勢ひだつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お秀の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶汲み女は三人、小体な暮しですが、銅壺に往来の人間の顔が映ろうという綺麗事に客を呼んで横網に貸家が三軒と、洒落た住宅まで建てる勢いだったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お秀の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "別府に、冬を半月ほど暮していた間、晩になると河豚をたのしんだが、味もよし、女中のあしらいも綺麗事で、東京に近ごろ殖えたのとは比較にならない。",
              "citation": {
                "source": "河豚",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "世事の憂いこと醜いこと、すべてを忘れて、一｜刻でも半夜でも、綺麗事につつまれて、さらりと屈託を捨てて来るのがあの遊廓でござりまするがの。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、一旦「外面」となると、快活で愛想がよく、不景気のフの字も見せず、万事いやな顔などせずきれいごとで行こうという、お嬢さまの圭子だった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "様々の、情熱を失った道義観やきれいごとの底を割って人間のぎりぎりの姿を露呈させよ、という。",
              "citation": {
                "source": "人間の結婚",
                "author": "――結婚のモラル――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日物わかりのよいとされている女の先生などでも、その生活への感情は案外にひ弱くて、所謂いい生活というものの絵図が水っぽいきれいごとだけで、塗りあげられていて、子供の心が直感した生活のそんなユーモアもわからないということが一つ。",
              "citation": {
                "source": "子供の世界",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イヤこれは助高屋ものできれいごとだと思つたら、ごみと枯ツ葉で、梅幸が世話物でつかひさうだ。",
              "citation": {
                "source": "狂言の買冠",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "きれいごとでない形。",
              "citation": {
                "source": "日記",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そりゃ今までの帳面が、どうもきれいごとにいかんというのは、俺が悪いと言えば、悪いさ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その意味では、ひろ子が重吉に示す生活感情も計らぬきれいごととなっているとも思えた。",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "口さきでのきれいごとは誰にも通用しはしないのだから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀（太原にいてかえったの）がなかなか写真上手で、まだきれいごとですが、なかなかセンスのある作品を作って面白うございます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――柳町なんかは一流とかなんとかいってさ、いやにお高くとまってきれいごとな遊びしかさせやしないさ、そこへいくとあたいたちはみえも気取りもありやしない、脂の乗ったこってりしたところをそれこそ食傷するほど……」　わあっと笑って叩いたり叫んだり、障子が音をたてるような騒ぎが起った。",
              "citation": {
                "source": "契りきぬ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
