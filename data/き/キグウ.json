[
  {
    "uuid": "9a5c2028-1c7f-5ea1-8c3c-3e6507c207ea",
    "entry": "奇遇",
    "reading": {
      "primary": "きぐう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞-の形容詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "unexpected meeting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一方ではまた「経国美談」「佳人之奇遇」のごとき、当時では最も西洋臭くて清新と考えられたものを愛読し暗唱した。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「佳人の奇遇」の第一ページを暗唱しているものの中に自分もいたわけである。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫻木海軍大佐との奇遇。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、一旦は其奇遇に驚いたが、今は其んなことを詮議する場合でない。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うん」　鶴雄が坐ると、「奇遇ね」　弓子の声はもう懐かしそうだった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇遇だね」　小沢も微笑を泛べて、「――さっきはどうも……」　と、言った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "第八章奇怪なる新内語りと奈落で奇遇すること。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治初年の、佳人之奇遇、経国美談などを、古本屋から捜して来て、ひとりで、くすくす笑いながら読んでいる。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな奇遇の可能を作者自身が、まじめに信じてゐなければいけないのだ。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな奇遇の可能を作者自身が、まじめに信じていなければいけないのだ。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、松島の奇遇に依って、のんきに結ばれた周さんと私の交友にも、時々へんな邪魔がはいったと前に書いたが、その不愉快な介入者が、まことに早く思いがけない方面からあらわれたのである。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たけの事さへ無かつたら、私はこの幼馴染との奇遇をよろこび、あの新宅にもきつと立寄らせていただき、ゆつくり中里の話でも伺つたのに違ひないが、何せ一刻を争ふみたいに意味も無く気がせいてゐたので、「ぢや、また。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、糸七の遠い雪國の其の小提灯の幽靈のふ場所が小玉小路、斷然話によそへて拵へたのではない、とすると、蛙に因んで顯著なる奇遇である。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし、奇遇でしたね」　と、思わず白崎は言った。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議だ――奇遇だ……」「イヤ。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇遇じゃないのです。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "心から手を取り合って奇遇を喜び合うのであった。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「金の脇立物、朱漆の具足の士と槍を合せたが、その武者振見事であった」と語った処が、その武者が主人の河内であることが判り、互に奇遇を嘆じたと云う話がある。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "節子「昨日汽車の中でお眼に掛って、今日また奈良でお会いするなんて、本当に奇遇ですわ」庄平（稍や冷淡に）「僕は、昨日昭南島で会うた男に、今日ジャワで会うたという経験がありますがね」節子「これから、どちらへ？",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　すると話し相手は、「奇遇だな。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はそれを不思議な奇遇のやうに喜んだ。",
              "citation": {
                "source": "追憶",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾等は夫婦たること既に三年、今ヱネチアに至る途上、再び此島に遊びて、昔日奇遇の蹟を問はんとするなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿屋に歸り、折柄の自動車に飛び乘り、長篠に出で、折角の奇遇をこのまゝ別るゝも辛く、其處より二三驛｜上手の湯谷温泉まで行つて共にゆつくり話さうといふことになり、電車に乘つた。",
              "citation": {
                "source": "梅雨紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、糸七の遠い雪国のその小提灯の幽霊のう場所が小玉小路、断然話によそえて拵えたのではない、とすると、蛙に因んで顕著なる奇遇である。",
              "citation": {
                "source": "遺稿",
                "author": "遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は既にその奇遇に驚き、またこの憐れなる人の身の上に泣きてありしが、かくてあるべきならねば、他の囚徒と共にいろいろと慰めつつ、この上は一日も早く出獄して良人や子供の菩提を弔い給えなど力を添えつ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどもこの後相見んことは何日をも計られざるに、願うては神の力も及ぶまじき今日の奇遇を仇に、余所ながら見て別れんは本意無からずや。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "人にも知られず、我身一つの恥辱ならんには、この面に唾吐るるも厭はじの覚悟なれど奇遇は棄つるに惜き奇遇ながら、逢瀬は今日の一日に限らぬものを、事の破を目に見て愚に躁るべきや。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」って　プー「へえ　おもしろいね　きぐうだね　いっしょに行こう」って　言うんだよ「いっしょに行こう」って　プーのやつ「２×11は？",
              "citation": {
                "source": "ぼくら　ふたり",
                "author": "US TWO",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
