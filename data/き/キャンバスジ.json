        "examples": {
          "standard": [
            {
              "text": "このバックパックは厚手のキャンバス地で作られているから、岩場に擦れてもびくともしない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「汚れが目立ちにくい色のキャンバス地を選んで、オリジナルのエプロンを縫ってみたよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "雨の日でも気にせず履けるよう、キャンバス地のスニーカーに防水スプレーを念入りにかける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "使い込むほどに柔らかく手に馴染んでくるのが、キャンバス地ならではの大きな魅力だ。",
              "citation": {
                "source": "幻辭AI",
