    "definitions": [
      {
        "index": 1,
        "gloss": "to cut off",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "盲腸という無用の長物に似た神秘のヴェールを切り取る外科手術！",
              "citation": {
                "source": "好奇心",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここン所坂野医院大繁昌だね」　坂野はにやりと木崎の顔を見ながら、ケースの中からヒロポンのアンプルを取り出し、アンプル・カッターを当てて廻すと、まるで千切り取るように二つに割った。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "獣は運ぶには手に余るほどの図体があったため、ハンターは仕方なく片脚と脇腹の部分だけを切り取ることにした。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑には其の時麥が青く生えて居たが、それでも持主は畑が減るだけ田の面積が増す理由なのと、土の分量も格別の事でないのとで切り取ることを否まなかつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「切り取る」と一口に言っても、普通の土ではなく、堅緻な岩であった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "鞭で打つのだ、耳を半分切り取ることだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついに腿の肉を切り取るに及び牛夥しく血を出して死す。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちの一箱を年に一度ずつ石からおろして蜂のために蜜を切り取るといっていた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "家中の者の腕っききばかりをねらって、その右腕をのみ切り取るという点は、いかにも不思議に思えば思えないこともありませんでしたが、なにしろたくさんある流儀のことでしたから、考えようによれば剣法の中にだって右腕ばかりを切るというような一派が全然ないとは保証できなかったからです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "「幼いものをつまずかすのは、老人の足を切り取るよりも、もっと悪い事だ。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "愈よ心臓があらわれると、今度はそれを切り取るのだが、そのまゝメスをあてゝは出血のために手術が出来なくなるから、大静脈、大動脈、肺静脈、肺動脈等の大血管を悉く糸をもってしばり、然る後にメスを以てそれ等の大血管を切り離すのだ。",
              "citation": {
                "source": "恋愛曲線",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "精々まずい芝居の部分を鋏で切り取るくらいの芸当しか監督にはできない。",
              "citation": {
                "source": "雑文的雑文",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "肋を切り取る無気味の音が、ひとしきり部屋の中へ響いたが、やがて左右十本の肋骨が、血にまみれながら、抜き取られた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは一枝一条もみだりに切り取る事をしないで、おのが心に描く美的配合を目的に注意深く選択する。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは、もし絶対に必要の度を越えて万一切り取るようなことがあると、これを恥とした。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "すてて仕舞えば一部から切り取るので、心は、大きくなる要に迫られない。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "其うちの一箱を年に一度づゝ石から卸して蜂の為に蜜を切り取ると云つてゐた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "足の蹠の胼胝を丹念に鋏で切り取るのだ。",
              "citation": {
                "source": "公孫樹",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　父にとっては、蹠の胼胝を切り取ることは、髪を刈ったり入浴したりすることなんかよりも、もっと精神を爽快になすかのようだった。",
              "citation": {
                "source": "公孫樹",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにまた、切り取る皮は散らさないで、下に敷いた新聞紙の中にまとめなければならないので、それが切る者には一苦労だった。",
              "citation": {
                "source": "公孫樹",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを切り取ると、両手ですくいあげられるほどの僅かな分量のものでしかなかった。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "『八犬伝』とか『巡島記』とか、馬琴の大部のものが多いのですが、それには大抵一冊に二、三個所ずつ絵があるのを、必ず一個所は上手に切り取るので、その頃そんな本の表紙は、浅草紙のようで厚いのに色紙が張ってあるのですから、半紙の薄い中身は糊で附ければ跡はわからなかったそうです。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　なお、此処の中に生えて居た樹木は若く、太いのでもステッキ程度であって、全部草刈鎌で切り取ることのできるていどであった。",
              "citation": {
                "source": "あの世の入口",
                "author": "――いわゆる地獄穴について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみはぼくの身の上を案じているのだ」「マチア、それを言わないでくれ」「きみはいつか、ぼくまでが代のはらってない品物の正札を切り取るようなことになるといけないと心配しているのだ」「マチア、マチア、よしたまえ」「ねえ、きみがぼくのために心配するなら、ぼくはきみのために心配する。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "金十郎はこの子は眼鼻立が良いから育て甲斐があるだらう――と言つたさうで」「赤ん坊の紋服の紋を見なかつたらうか」「女中が切り取る時チラと見たさうです、――恐ろしく珍らしい紋だつたと言ひますよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "二つの刺青",
                "note": "青空文庫"
              }
            },
            {
              "text": "「眞つ晝間で軸から切り取る隙がないとすると、長いまゝで持ち出したことになるが、誰かそんなことに眼が屆かなかつたでせうか」　平次は丁寧に問ひ返しました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "名畫紛失",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔓を鎌で舟に引き寄せて、右の拇指の爪を非常に長く伸ばしていてヌルヌルの新芽を人差指の上にのせて切り取るのである。",
              "citation": {
                "source": "探訪深泥池の蓴菜",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "切り取る前後の苦痛には、パビナールなどが使用されるのだ。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "色とりどりのレザリアムが目まぐるしく変化を続け、ステージを様々な角度から切り取るように照射したり暗闇の中に隠したりした。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "影男は、それに捺印して、その一枚を切り取ると、実印と小切手帳と万年筆を良斎のふところにねじこみ、また細引きを厳重に縛りなおして、身動きもできないようにしたうえ、手ぬぐいを取り出して、さるぐつわまではめてしまった。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
