    "definitions": [
      {
        "index": 1,
        "gloss": "moving picture",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "戦前の人々は、キネマを娯楽の中心として、上映を心待ちにしていたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この古い雑誌には、往年のキネマスターたちの華やかな写真が満載だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼らの世代にとって、キネマは夢と希望を与えてくれる存在だったに違いない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "昭和十年の目出度き春を迎えるに際しましてキネマ旬報誌に折入って懇願致したい事があります。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の町には名物の瑪瑙細工やら牛の角細工を並べた店ばかり連なって、こういう所にはおきまりのキネマが自働ピアノで客を呼んでいました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和九年六月、キネマ旬報）　　　　　六　バンジャ　映画「バンジャ」を見た。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は、キネマ俳優であった。",
              "citation": {
                "source": "あさましきもの",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう新聞広告がなくなっても、芝居やキネマの観客が減る心配はないという事は保証ができる。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和七年十一月、キネマ旬報）",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ところで、話ちがいますけど、貴方キネマスターで誰がお好きですか？",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "キネマの女優になったのか」「うん。",
              "citation": {
                "source": "兵士と女優",
                "author": "オン・ワタナベ（渡辺温）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして鼻歌を唄い唄い二階に上って、煙草の烟と、小説と雑誌と、キネマの筋書の世界に寝ころんだ。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校の帰り、目黒キネマに寄って、「進め竜騎兵」を見て来た。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日も、佐渡情話とか言う浪花節のキネマを見て、どうしてもがまんができず、とうとう大声をはなって泣きだして、そのあくる朝、厠で、そのキネマの新聞広告を見ていたら、また嗚咽が出て来て、家人に怪しまれ、はては大笑いになって、もはや二度と、キネマへ連れて行けぬという家人の意見でございました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間も店の小僧に『キネマ・ファンたあ何の事かいなア』て聞かれましたけに、西洋の長唄の先生の事じゃろうて教えておきましたれア違いますそうで。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "キネマ・ファンちう者は日本にも居るそうで。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでの話でっけどな、うちの経営者が△△キネマを買収する計画を樹てていますねん。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりやな、あんたは△△キネマの舞台挨拶にでも出るのや思てくれはったら、よろしおまんねん」　こうした嘘八百のことを佐古は前後四、五回にわたって、徐々に彼女に説明したのだ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「三映キネマの如月真弓という女優だよ。",
              "citation": {
                "source": "殺人迷路",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃアなんだな、あのこの間殺された宮部京子と同じ三映キネマの女優だったんだな。",
              "citation": {
                "source": "殺人迷路",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の書生は今の青年がオペラやキネマへ入浸ると同様に盛んに寄席へ通ったもので、寄席芸人の物真似は書生の課外レスンの一つであった。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "駿河台の暗ぼったい旗本屋敷の長屋から移転したので、タシカ今の神田キネマの辺であった。",
              "citation": {
                "source": "美妙斎美妙",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "キネマや、喫茶店や、汁粉屋へ入ることを雁江は慣れた。",
              "citation": {
                "source": "滑走",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京キネマの女優山上みさをもこのアパートの止宿人の一人であった。",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　村井保の証言　村井｜保は、映画雑誌、シネマ時報の編集主任で、年齢は三十四歳、雑誌記事のことで、東京キネマのスタジオへ出入りしているうちに山上みさをと知り合いになり、半年ほど前から彼女と情事関係をむすんでいたものである。",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　松木久作の証言　○○製菓会社常務取締役松木久作は、年齢五十歳のでっぷり太った紳士で、つい一ヶ月前から、東京キネマの重役某の紹介で山上みさをのパトロンとなっていたのである。",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "植田欣子は山上みさをとほぼ同年輩でやはり、東京キネマの女優である。",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "年はおない年でしたけれど、わたしが、世話をしてあの人を、東京キネマへ入れた関係もあり、あの人はわたしのことを、ねえさんといって何でも、わたしにだけはうちあけて相談してくれていました。",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月一日よりジャッキイ・クウガン　街の子　　　　　　　　　　　　　　　キネマ館にてと書いてあるのです。",
              "citation": {
                "source": "街の子",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、お姉様とならいいって」「じゃ、行ってあげるわ」「うれしいな、これからすぐですよ」　春太郎は、お姉様につれられて、キネマ館へゆきました。",
              "citation": {
                "source": "街の子",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「キネマ会社の技師諸君、失望したでしょうね、大写は！",
              "citation": {
                "source": "奥さんの家出",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "cinema",
