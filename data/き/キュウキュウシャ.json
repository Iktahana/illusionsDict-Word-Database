        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところが、それから二三日たって、宮川は真白な救急車にはこばれて、黒木博士の病院へかえって来た。",
              "citation": {
                "source": "脳の中の麗人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "白塗りの救急車で、押しかけて搬びこんだのが外ならぬヒルミ夫人の外科病院だった。",
              "citation": {
                "source": "ヒルミ夫人の冷蔵鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "救急車のサイレンを唸らせ、猛烈な速力で走り去る音が、いつまでも、きこえた。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それはどうも……後ほど、あらためて……（受話器をおいて、広廊に戻ってくる）検証がすんで、遺体を救急車で送ったそうです……そちらへ着くころだといってました。",
              "citation": {
                "source": "喪服",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くから救急車のサイレンの音が聞え、だんだん近くなり、間もなく、門のあるあたりでとまる。",
              "citation": {
                "source": "喪服",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "救急車で聖路加へ運ばれ、意識不明のまま二十五日の払暁まで保っていたが、間もなく苦しみだし、七時ごろ息をひきとった。",
              "citation": {
                "source": "雲の小径",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "マトレスの古いのを一枚借りだすのがやっとのことでした」「医者がついているのか」「医者も救急車も、一時間ほど前にひきあげました」　主任の額に暗い稲妻のようなものが走った。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "救急車の警鈴が鳴り、間もなく鐵格子に掴まつてゐた人々はその場から去りはじめた。",
              "citation": {
                "source": "末野女",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "どもりながら、むしろ喜悦に満ちた声で、「そ、それよりも、救急車を早く呼んで来い。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて救急車がサイレンを鳴らしながら、舗装路をまっしぐらに近づいて来た。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は失神したまま、救急車に運び込まれた。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "救急車の男がするどい声で、運転手に救急指定病院の名を告げる。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "救急車はＵターンして、速力を上げて走り去った。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "病院の名は、救急車の男が言ったのを、メモして置いた」「何故そんなことをするんだね」「僕は見たことの続きやつながりを知りたかったんだ。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、救急車が呼ばれ、死体が運び出されたが、それとひきちがいに、ひとりの妙な男が、一同の集まっている庭のほうへ、のこのことはいってきた。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "救急車のサイレンが、遠くに聞こえた。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "救急車が呼ばれ、出動し、正月の町を走り、ホテルに到着した。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "救急車は呼んである。",
              "citation": {
                "source": "最愛の君",
                "author": "Ｈ・ビーム・パイパー　H. Beam Piper",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、諸君、あれは救急車だ」と訂正した。",
              "citation": {
                "source": "最愛の君",
                "author": "Ｈ・ビーム・パイパー　H. Beam Piper",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこのお巡りさん、大至急、救急車だ。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
