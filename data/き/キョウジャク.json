[
  {
    "uuid": "9b190d0c-cf15-5ae5-be0e-263f5ee9af8c",
    "entry": "強弱",
    "reading": {
      "primary": "きょうじゃく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
