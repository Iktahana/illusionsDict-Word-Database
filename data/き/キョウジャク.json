  {
    "uuid": "ef418a8a-92b3-5a7c-ac71-c65cc77a9264",
    "entry": "怯弱",
    "reading": {
      "primary": "きょうじゃく",
      "alternatives": [
        "きょじゃく"
      ],
      "is_heteronym": false
    },
    "grammar": {
