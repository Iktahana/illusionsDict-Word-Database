[
  {
    "uuid": "6cf08626-f030-5f76-9f76-e7244ca068a9",
    "entry": "及第",
    "reading": {
      "primary": "きゅうだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
