    "definitions": [
      {
        "index": 1,
        "gloss": "to relax one's mind",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
