      {
        "index": 1,
        "gloss": "sweet dumpling made with mochi flour and (sometimes) millet flour (famous product of Okayama)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
