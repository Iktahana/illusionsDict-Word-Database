[
  {
    "uuid": "b2f0f31a-949b-5331-92c2-f78a67cac695",
    "entry": "極める",
    "reading": {
      "primary": "きわめる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to carry to extremes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "真夏の伊香保は、自然としても初夏のそれに劣るが、何しろ悪いことは、文字の通りの意味で雑鬧混雑を極めることである。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私としてもあなたのようにあの方をいい方だとばかり極めるわけにはいかないと思うところもあるのだけれども、星野さんがおっしゃってくださるのだから私は信じていていいと思います。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この不思議な意図も慧鶴青年の胸に蓄えられたまま、人間慾と超人慾とのごちゃごちゃに混った青年慧鶴は、清水と富士をあとに残し、何事かを極める為に美濃ノ国へ旅立ったのである。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それは一般の人々の人生の方向を極める時の役には立たないと思います。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでにこないだも東の紙屋の若い奴が、桜木町である女と出来合って、意気事を極めるちゅうから、癪に障ってな、いろいろ験べたが何事もないで、為方がない、内に居る母親が寺｜参をするのに木綿を着せて、汝が傾城買をするのに絹を纏うのは何たることじゃ、という廉をもって、説諭をくらわした。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "加之も先方から真白昼押掛けて来て、平気でお出でお出でを極めるとは、図迂図迂しい奴、忌々しい奴と、市郎は惘れを通り越して、稍勃然とした。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "寿命は自分の極めるものでないから、固より予測は出来ない。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "駄目な男というものは、幸福を受取るに当ってさえ、下手くそを極めるものである。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりもまず、科学の威力に依って民衆を覚醒させ、之を導いて維新の信仰にまで高めるのでなければ、いかなる手段の革命も困難を極めるに違いない。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "真面目な人が、へんに思いつめた揚句で書くと、あんな工合に書体も奇怪な金釘流になり易いものだし、また文章も、下手くそを極めるもののようである。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お山参詣と言つて、毎年陰暦七月二十八日より八月一日に到る三日間、津軽の霊峰岩木山の山頂奥宮に於けるお祭りに参詣する人、数万、参詣の行き帰り躍りながらこのまちを通過し、まちは殷賑を極める。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少いものが、不精を極めるな。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘には、惚れてる奴が居ますから、その料簡次第で御話を取極める、と云うに、不思議はありますまい。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかだか堰でめだかを極めるか、古川の浅い処で、ばちゃばちゃと鮒を遣るだ。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし実は席を極めるのに困りました。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "荘先生がそなたの我儘を見に来たと云われたのは却ってそなたののびのびして生きて居られる様子を快哉に感じられ「道」を極める荘先生に好い影響さえお与え申したのだ。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "細い手で受け取った鏡を、京子は朝日にかざしてきらりと光らせ、傍の者を眩しがらせてから、も一度、朝陽の在所を見極める。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしとにかく烈しく夫に打っ附かったって駄目だから、よそうと云うことだけは極めることが出来た。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "極めるとなると、なんだか自分で自分を縛るやうな心持がして不愉快である。",
              "citation": {
                "source": "長谷川辰之助",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに人の成功が、どれ丈生れついて、どれ丈人のお蔭で出來たかといふことは、どんなえらい學者でも極めることは出來ないのだ。",
              "citation": {
                "source": "半日",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "參謀本部の二十萬分の一の分圖であれば、何處へ泊つて何處へ出るといふことが、大抵は大なる間違なく極めることが出來る。",
              "citation": {
                "source": "旅行に就いて",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝はドロンを極めるというのがこの連中の定型と聞いた……歎かわしい奴輩ではある……。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがシャーロック・ホームズは、心のなかにわだかまる問題があると、何日も、いや何週間も休みなく、そいつをひっくり返しては事実を再び並び替え、隅から隅までじっくり眺め回して、そいつを見極めるか、検討材料が不十分だとわかるかするまで起き続ける、そんな人間だった。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "探偵術に最重要なのは、数ある事実から周辺のものと本質とを見極める能力です。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "六郎は曲物と思ったので、己の体を見せないようにと、ちょと己を見返って、それが木立の陰になっているのを見極めると、急いで雨戸の方へ眼をやった。",
              "citation": {
                "source": "頼朝の最後",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちと処方外の療治だがね、同じ葡萄酒でも薬局で喇叭を極めると、何となく難有味が違って、自ら精神が爽快になります。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大概のことは気にもかけなかったが、婆さん貧病は治して貰った、我が朝の、耆婆扁鵲と思う人を、藪はちと気になったから、山の井さんを何だ、と思うと極めるとね。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いけ年を仕って何も万八を極めるにゃ当りません。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」後日、内弟子に極める時元老が聞いた――「坊主、修業をして、舞台へ浪が出せるかな。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の胸臆は明白に私の前に展開せられて時としては無遠慮を極めることがある。",
              "citation": {
                "source": "二人の友",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
