        "examples": {
          "standard": [
            {
              "text": "この建物は古いので、強電と弱電のケーブルが同じ配管を通っている箇所があるらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "工場設備のメンテナンスを行うため、強電の専門知識を持つ電気主任技術者を募集している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「その赤いケーブルは強電だから、絶対に素手で触るなよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "データセンターを設計する際は、情報通信を扱う弱電と、電力を供給する強電の系統を完全に分離する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "つまりヘビサイド層の強電気が敵軍の上に浴びせかかる。",
              "citation": {
                "source": "発明小僧",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
