[
  {
    "uuid": "62a3c29c-caa4-54e7-9b84-ba9ccc419894",
    "entry": "仇敵",
    "reading": {
      "primary": "きゅうてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
