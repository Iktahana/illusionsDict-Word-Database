    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bitter enemy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "耶蘇、日本の敵です』と、至るところで彼は耶蘇教を罵り、その宣教師を仇敵のごとく憎んでいる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "仇敵に非ず債鬼に非ず「見よ！",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕等はツバぜり合ひの刀の下で、永久に默笑し合つてる仇敵である。",
              "citation": {
                "source": "悲しき決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は特にその最も仇敵である楠正成を愛敬し、常に左右に語つて「正成こそは我を知る唯一の知己」と話して居た。",
              "citation": {
                "source": "足利尊氏",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正成ばかりでなく、新田一族に對しても、決して仇敵としての憎しみを持たなかつた。",
              "citation": {
                "source": "足利尊氏",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は仇敵同士だが兄弟の様に仲がいいのである。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "文六尚も苦しそうに、Ｔ「未だ、仇敵に　廻り逢わざるに　路用の金子は　尽き果てて」　殿様聞くより「アイヤＴ「皆迄申すな　泣けて来る」　と文六の手を握って、Ｔ「辛いで　あろう喃」　と言って、老臣を振り返って、それッと言う。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、父や自分の仇敵である都会文化の猛威に対して、少しも復讐の気持が起らず、かえって、その逞ましさに慄えて魅着する自分は、ひょっとして、大変な錯倒症の不良｜娘なのではあるまいか。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから彼はいちいち几帳面に仇敵に、それ相応の復讐を遂げ、自分はわざと恋人の兄の刃にかかって死にます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからわたしは今はもう、お前達に感謝こそすれ、仇敵と思う心は毛頭もない筈ではないか。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "下枝が死を宣告され、仇敵の手には死なじとて、歎き悶ゆる風情を見て、咄嗟に一の奇計を得たり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……憎ければとて、浅ましければとて、気障なればとて、たとい仇敵なればと申して、約束はかえられませぬ、誓を破っては相成りませぬ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを娘と知っていたら、いや、その時だって気が付いたら、按摩が親の仇敵でも、私あ退治るんじゃなかったんだ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は、私の仇敵を、ひしと抱擁いたします。",
              "citation": {
                "source": "鬱屈禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "言はばニイチェは、師匠の仇敵を討つた勇士のやうなものである。",
              "citation": {
                "source": "ニイチェに就いての雑感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度彼女等は、昔の草双紙に物語られてる、仇敵討ちの武士みたいなものである。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その若く悲しい武士たちは、何時、何處で、如何にして※り逢ふかも解らない仇敵を探して、あてもなく國國を彷徨ひ歩き、偶然の奇蹟を祈りながら、生涯を疲勞の旅に死んでしまふ。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから尚ヘルンは、かかる神神を泥靴で蹴り、かかる信仰を讒罵し、かかる善良な人人を誘惑して、キリスト教の僞善と惡魔を教へようとする外人宣教師を、仇敵のやうに痛罵してゐる。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（封建時代とはちがつた仕方で、今の資本主義の世の中にも、孝子の仇敵討ちがふだんに行はれて居ることを知るべきである。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に自分は長い間、日本の文壇を仇敵視し、それの憎悪によって一貫して来た。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士の家のしきたりでは、兄さんが殺されると、弟が兄さんの仇敵を討たねばならないのだつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふわけで、その弟は仇敵を討つための旅をしてゐたのである。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、仇敵はどこに何をしてゐるのか解らなかつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "沢山の人の中から一人の仇敵を探しだすのは、骨の折れる仕事だつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大勢の人の中に、もしかすると探してゐる仇敵がゐるかも知れない、とその武士は思つた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "仇敵にいつめぐりあへるのだらう。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
