    "definitions": [
      {
        "index": 1,
        "gloss": "religious oath in writing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
