        "examples": {
          "standard": [
            {
              "text": "「この車のボディは、まるで鏡面仕上げで、自分の姿がはっきり映るよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「高級家具の木材には、手間のかかる鏡面仕上げが施されている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「磨き上げられたステンレスの流し台は、鏡面仕上げでピカピカだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「時計のベゼル部分に、精密な鏡面仕上げがされているのがわかる。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このレンズの表面は、極めて高い精度の鏡面仕上げがされている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "鏡面仕上げの球体が、周囲のものを反射させながら動いていくグラフィックスの作成には、膨大な計算が必要だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
