        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "五十年配の品のいゝ老婦人が出て来て、すぐ奥へ引つこんだが、思ひがけなく着物姿の背の高い富岡がのつそり玄関へ出て来た。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "早苗が片側開きの格子戸に手をかけると、着物姿の笹原がすぐ出て來て、「よく判りましたねえ、どうぞむさくるしい處ですけれどお上り下さい」　と氣安く云つてくれた。",
              "citation": {
                "source": "風媒",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "服装は田舎者丸出しの着物姿だった。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第一部　牧野富太郎自叙伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのガスをひるすてきな音も聞えなかったし、着物姿で、素足に古びた雪駄をはいていた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "話をしようや、相談ってなんだい」　ここの勤めは相当もうながいはずの女は、着物姿を見ている分にはいかにも吉原のおいらんだが、床の中で抱くと、ついこの間まで田圃で働いていたような固くしまった肉づきをしていて、その野生的な感じが俺の気に入ったのだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物姿の彼女は、片手に太刀を一本だけ持ち、悪の敵陣へと乗り込んでいく。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物姿で斬りまくる一連の映画で、西本美佐子の人気は決定的となった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらわれるときと去るときは、かならず着物姿だった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "女将だという着物姿の女性があらわれた。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりはかならずお客さんが来る、というほうに私が賭けて」「勝ちましたね」「今日は最初のお客さん」　カウンターの奥にとどまっている、叔母さんという着物姿の女性が、彼にそう言った。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして着物姿の初老の女性に用件を伝えた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
