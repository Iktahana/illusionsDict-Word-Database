          "literary": [
            {
              "text": "彼女はこの若者が持つ一種の強運のようなものに愛着を抱いていたのだ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は私は理屈もなしに貴方の途轍もない強運にすがったのです。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "国王の蒸発です」「アホの強運だな。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "強運で全身が震える様子は、極悪人が馬鹿な陪審員により無罪放免されたかのようだった。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
