[
  {
    "uuid": "ade84304-1169-5fa8-bd53-f87083418cf4",
    "entry": "気を失う",
    "reading": {
      "primary": "きをうしなう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ウ行"
      ],
