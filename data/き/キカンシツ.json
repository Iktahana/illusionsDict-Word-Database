    },
    "definitions": [
      {
        "index": 1,
        "gloss": "boiler room",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古い映画のシーンでは、大勢の工夫が汽缶室で巨大なボイラーに石炭を投げ入れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うお、汽缶室の熱気は想像以上だな。立っているだけでサウナに入っているみたいだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "蒸気船の心臓部とも言える汽缶室では、高圧の蒸気が常にうなりを上げている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "汽缶室の計器が異常な数値を指し示したため、直ちに緊急停止のブザーが鳴り響いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "二人の農夫は次から次とせわしく落ちて来る芯を集めて、小屋のうしろの汽缶室に運びました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
