        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "庄屋のオトトも肝をつぶすに相違ない話なのである。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "花天狗流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が半分泣声になって叫ぶと、とたんに犬は肝をつぶすような吠え声をあげて、猛然と跳びかかってきた。",
              "citation": {
                "source": "こんにゃく売り",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきの肝臓病のこと、肝のあるおかげで肝をつぶすというようなこともあるけれど、こればかりはとれなくてね、盲腸のようには。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞｜種が砂丘の先、ポート・インディゴにあり、肝をつぶす恐怖と驚愕が出来していた。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "みょうちきりんなタコのばけものみたいな動物が、うじゃうじゃかたまっているその中から、いきなり英語でもって自分の名が呼ばれたものだから、きもをつぶすのもどうりであった。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "住んでいる人は、それほど感じないかもしれないが、ふと通りすぎる私などには、きもをつぶすような、寂莫たる土地である。",
              "citation": {
                "source": "馬鈴薯の花",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの先生、今ごろどこをうろつきまわっていることか、あす、この事件が新聞にでるのを見て、やっこさん、さだめしきもをつぶすことであろう。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
