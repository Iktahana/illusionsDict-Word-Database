        "examples": {
          "standard": [
            {
              "text": "彼女はアジアや欧州の拠点を転々としながら、国際弁護士としての着実なキャリアを積んできた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今は給料が安くても、現場で泥臭くキャリアを積むことが、10年後の自分にとって大きな財産になるはずだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "若いうちに様々な部署を経験し、ゼネラリストとしての視点を養いながらキャリアを積んでいく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "短期間で転職を繰り返すよりも、一つのプロジェクトを完遂させることで、より深いキャリアを積むことができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "放送作家で進むのか、会社の設立に向けてもう少しまっとうなキャリアを積むのか――。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
