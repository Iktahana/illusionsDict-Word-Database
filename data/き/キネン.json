  {
    "uuid": "d1c1e559-6065-578c-b16f-4f70401db502",
    "entry": "記念",
    "reading": {
      "primary": "きねん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "commemoration",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "創立100周年を記念して、会社で盛大な式典が開催された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい門出を記念し、家族写真を撮ることに決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の長年の功績を記念して、公園に銅像が建てられるそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プロジェクトの成功を記念して、チーム全員で豪華な食事に行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "海軍記念日は、ことしも、また、そろそろやってまいります。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八十八夜を記念しようという、なんの意味もない決心を笑いながら固めて、二人、浅草へ呑みに出かけることになったのであるが、その夜、私はいっそく飛びに馬場へ離れがたない親狎の念を抱くにいたった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校では、毎年創立記念日に学童の作品展覧会が催される。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルマンの教室を出て右を見ると河向いにウィルヘルム一世記念碑のうしろの胸壁の裏側が見える。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがもうみんなとうの昔に故人になったしまって、それらの記念すべき諸｜国手の面影も今ではもう朧気な追憶の霧の中に消えかかっている。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度二十五周年記念号を出すので何か書くようとの懇篤な御すすめがありましたので何かと考えてみましたが右様の次第でありますからほとんど何も申上げる材料はないのでありますが、せっかくの御すすめでありますから、ただほんの少しばかり思い付いたことを申上げたいと思います。",
              "citation": {
                "source": "書簡（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つの子規自筆の記念品は、子規の家から中村｜不折の家に行く道筋を自分に教えるために描いてくれた地図である。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂子屋太宰治　書房を展開せられて、もう五周年記念日を迎へられる由、おめでたう存じます。",
              "citation": {
                "source": "砂子屋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹木の幹に「登山記念、何月何日、何某」とナイフで彫つてある文字を見かけることさへあるが、私には笑へない。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "原品の肖像画は、「紀行文豪」たる、あるいはたりし記念として、家蔵としている。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから第五、第六の「あたかも」が、未だ続いて挙げられるが、もうその点は打ち切って、私たち同行四人が、シャスタ山に登ったのは、大正八年（一九一九年）九月十一日のことで、未だこの山の草分けを記念するための、シッソンの名が残っていた時分であった。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "災害記念碑を立てて永久的警告を残してはどうかという説もあるであろう。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある地方では明治二十九年の災害記念碑を建てたが、それが今では二つに折れて倒れたままになってころがっており、碑文などは全く読めないそうである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある地方では同様な碑を、山腹道路の傍で通行人の最もよく眼につく処に建てておいたが、その後新道が別に出来たために記念碑のある旧道は淋れてしまっているそうである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この謎のような言葉の解釈を彼自身の口から聞く事の出来る日が来れば、それは物理学の歴史でおそらく最も記念すべき日の一つになるかもしれない。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "レーリーの立派な仕事の楽屋にはこの忠実な田舎漢のかくれていた事を記念したい。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八九九年このインスティテューションの創立百年記念式にはトーマス・ヤングの業績について講演した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時の記念としてレーリー賞の資金が集められた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後ウェストミンスター・アベーに記念の標石を納めようという提議が大学総長や王立協会会長などの間に持出され、その資金が募集された。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "レーリーの私淑したと思わるるトーマス・ヤングの記念標と丁度対称的に向き合っている。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生が洋行の際に持って行って帰った記念品で、上面にケー・ナツメと書いてあるのを、新調のズックのカヴァーで包み隠したいかものであった。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この以上三期の中、我々にとつて最も記念の深いのは第二期である。",
              "citation": {
                "source": "蒲原有明氏の近況を聞いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しそれらの詩篇も過去の道程の記念として貴重なものであるので特に採篇したのである。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば私の詩集『月に吠える』――それは感情詩社の記念事業である――は、正に今日の詩壇を予感した最初の黎明であつたにちがひない。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はこの誌上出版記念の會へ顏出しするために是非一と通りは讀んでしまひ度かつたのだが、文章のさういふところがかたまつて出て來るとついほかのことを考へてしまつて大層進みが惡かつた。",
              "citation": {
                "source": "「親近」と「拒絶」",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々が平穏に、健全で、猶久しく彼のために記念祭を行ふやうに、神は我々に恩恵を垂れ給へ。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜日になりまして、お寺の鐘が響きますと、昔の記念のような心持が致します。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "その意味で、狹い路次の奧にあつた、木造の、あのささやかな洋館は日本麻雀道のためには記念保存物たる價値を持つてゐるかも知れない。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "左の岡の中腹に妙な記念碑のようなものがいくつも立っているのが、どういう意味だか分らない。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "総持寺の厖大な建築や記念碑を見廻した時に私を襲った感じが、どういうものかこのケンプェルの挿絵の感じと非常によく似ていた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
