    "definitions": [
      {
        "index": 1,
        "gloss": "prayer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は旅の安全を祈念して、出発前に地元の神社にお参りした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "被災地の一日も早い復興を、心から祈念いたしますと彼はスピーチした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "皆の健康と幸せを祈念し、今年も家族で初詣に出かけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "試験の合格を祈念して、合格祈願のお守りを買った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "卑屈の克服からでは無しに、卑屈の素直な肯定の中から、前例の無い見事な花の咲くことを、私は祈念しています。",
              "citation": {
                "source": "自信の無さ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "卑屈の克服からでは無しに、卑屈の素直な肯定の中から、前例の無い見事な花の咲くことを、私は祈念してゐます。",
              "citation": {
                "source": "自信の無さ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "千代ちやんひどく不快でもなつたのかい福や薬を飲まして呉れないか何うした大変顔色がわろくなつて来たおばさん鳥渡と良之助が声に驚かされて次の間に祈念をこらせし母も水初穂取りに流し元へ立ちしお福も狼狽敷枕元にあつまればお千代閉ぢたる目を開らき。",
              "citation": {
                "source": "闇桜",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "総ての事が里子には怪しき謎で、彼はたゞ惑いに惑うばかり、遂には母と同じく怨霊を信ずるようになり、今も横浜の宅で母と共に不動明王に祈念を凝して居るのです。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "里子は怨霊の本体を知らず、たゞ母も僕も此怨霊に苦しめられて居るものと信じ、祈念の誠を以て母と所天を救うとして居るのです。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十　赤城様――得三様　普門品、大悲の誓願を祈念して、下枝は気息｜奄々と、無何有の里に入りつつも、刀尋段々壊と唱うる時、得三は白刃を取直し、電光｜胸前に閃き来りぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、あらためて祈念した。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と祈念なし、机を取って、押戴いて、屹と見て、其方へ、と座を立とうとする。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかが女、と多少は軽蔑を以て接して来た、あの女房が、こんなにも恐ろしい、無茶なくらいの燃える祈念で生きていたとは、思いも及ばぬ事でした。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女というものは、こんなにも、せっぱつまった祈念を以て生きているものなのか。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の胸底の画像と違うのも仕方の無いことで、私のは謂わばまあ、田舎の耄碌医者が昔の恩師と旧友を慕う気持だけで書くのだから、社会的政治的の意図よりは、あの人たちの面影をただていねいに書きとめて置こうという祈念のほうが強いのは致し方の無い事だろう。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くて婦人が無体にも予が寝し衾をかゝげつゝ、衝と身を入るゝに絶叫して、護謨球の如く飛上り、室の外に転出でて畢生の力を籠め、艶魔を封ずるかの如く、襖を圧へて立ちけるまでは、自分なせし業とは思はず、祈念を凝せる神仏がしかなさしめしを信ずるなり。",
              "citation": {
                "source": "妖怪年代記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者の愛情と祈念が、やはり読者を救っています。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は――――「……小説が上手に書けますように……」　どうも可訝しい、絵が上手になりますように、踊が、浄瑠璃が、裁縫が、だとよく解えるけれども、小説は、他に何とか祈念のしようがありそうに思われる。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、一雪のお京さんは確に前条のごとくに祈念したのである。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "神々しき朝日に向つて祈念を凝したこともあつたのです。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に立つ栗の木の幸福な愛、さうしてその祈念、野生の儘の浄化。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集のはじめに",
                "note": "青空文庫"
              }
            },
            {
              "text": "某は当時｜退隠相願い、隈本を引払い、当地へ罷越候えども、六丸殿の御事心に懸かり、せめては御｜元服遊ばされ候まで、よそながら御安泰を祈念致したく、不識不知あまたの幾月を相過し候。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ともかくも……峠を抜けられましたのは、貴下が御祈念の功徳かも知れません――確に功徳です。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎朝神棚に向つて祈念することは實に十年一日の如しであつた。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、盗んだ金銀を元のところへ戻しに参ろうと存じまして、暫く祈念いたして居りますと、不思議にその面が取れました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "夜叉神堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "神秘崇厳なる「仮面劇」の発生は、恐怖から「喜劇」へと憧れる原始民族の祈念に因するものと私は一冊の六つかし気な本で読んだ。",
              "citation": {
                "source": "疑惑の城",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は夙に起信して、この尊をば一身｜一家の守護神と敬ひ奉り、事と有れば祈念を凝して偏に頼み聞ゆるにぞありける。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "新続金色夜叉第一章　生れてより神仏を頼み候事とては一度も無御座候へども、此度ばかりはつくづく一心に祈念致し、吾命を縮め候代に、必ず此文は御目に触れ候やうにと、それをば力に病中ながら筆取りまゐらせ候。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "して見ると、この靴工が毎朝隣人や貧者のために真心籠めた祈念の効は、尊者が多大の財産を慈善事業に撒き散らしたのと対等で、一生女に寄り付かず素食して穴居苦行しただけ尊者の損分じゃてや。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時また、甲子に当りて例のごとく燈掲げて一心に祈念するに、何処ともなく大きな白鼠｜忽然と出でて供物を食う。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そのたびごとに、不退転の勇を翻し、諸人救済の大業をなすべき機縁のいたらんことを祈念した。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "福岡の城下から中津の城下に移った彼は、二月に入った一日、宇佐八幡宮に賽して、本懐の一日も早く達せられんことを祈念した。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "人形遣ひをちょんだらあと言ひ、其子孫を嫌つてゐるが、此に似て一種の特殊部落の如きねんぶつちゃあと言ふのが、首里の石嶺に居る。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ヘルキュレス』を円戯場の砂に埋めて、忌々しいマルセーユ人に鼻をあかしてやらなければ、コルシカ人は大きな顔をしてプロヴァンスの街道を道中できねんでごぜえます。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "乱視の奈翁　――アルル牛角力の巻――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
