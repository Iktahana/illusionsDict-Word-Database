        "examples": {
          "standard": [
            {
              "text": "彼はかなりの器量好みで、いつも魅力的なパートナーと付き合っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「私、結構器量好みなんだよね」と彼女は笑って言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その監督は器量好みが激しく、キャスティングにも影響していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女の器量好みは有名で、パーティーでも注目の的だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "器量好みをする年でもない」といった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう云ってもお宅さんの手で一往お調べになるに越したことはないけれども、結婚がおくれた原因は全く器量好みのためで外に理由はないと云うのが、矢張ほんとうらしく思える。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんは隣り町の米問屋から器量好みで貰われてきているのであるが、旦那の機嫌をそこねないための心労で、今はすっかり老けた感じになっている。",
              "citation": {
                "source": "南方郵信",
                "author": "中村地平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
