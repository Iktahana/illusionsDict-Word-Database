    "definitions": [
      {
        "index": 1,
        "gloss": "pretty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "実に神経を使はなくては、何時も綺麗でキチンとしてゐるとはいくまい婦人の和服といふものは、段々改良されてはゆくのであらうか、なぞとそのうち僕は考へ始めたものである。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本飲み終つた頃、また後から一人来た、今度は先のよりは少し綺麗、デツプリ太つて自信がおありだ。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで綺麗な着物と帯とを買えば、きっと佐野次郎のことを忘れる。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何せ相手のお嬢さんは、ひどく若くて綺麗だそうだから、実は心配していたのだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は皆、その中では真剣になつて人生と取組み合ひ全力を出しきつて文学と四つ角力をとつてるのに、詩や俳句を作る時は、乙に気取つた他所行きの風流気を出し、小手先の遊び芸として、綺麗事に戯むれてゐるといふ感じがする。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "その石段の両側には、土産物の寄木細工を売る店や、かういふ町に適当な小綺麗の小間物屋や、舶来煙草を飾つた店や、中庭に廻廊のある二層三層の温泉旅館が、軒と軒とを重ね合せて、ごてごてと不規則に並んで居る。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり彼等は、綺麗な小娘や善い音楽を背景にして、都会生活の気分や閑散を楽しんでるのだ。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず第一に表紙の図案が綺麗で目新しく、俳味があってしかも古臭くないものであった。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父上はこれに一々｜水引をかけ綺麗にはしを揃えて、さて一々青い紙と白い紙とをしいた三宝へのせる。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "綺麗に禿げ上がった広い額が眼について離れなかった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに関する自分の記憶は実に綺麗に拭われたように消えてしまっている。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「綺麗な鳥よ、綺麗ジャノー。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの頃自分は愛読していた書物などの影響から、人間は別になんにもしなくても、平和に綺麗に一生を過せばそれでよいと云ったような考えが漠然と出来ていたので、病気で試験を休もうが、落第しようが、そんな事は一向心配しなかった。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の造作も無く綺麗に瘤をむしり取つた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やあ、けふはまた一段とお綺麗。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れたばかりの赤ん坊の足の裏と同じやうにやはらかくて綺麗なのに違ひない、と思へば、これといふ目立つた粉飾一つも施してゐない乙姫のからだが、いよいよ眞の氣品を有してゐるものの如く、奧ゆかしく思はれて來た。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、なに、」と浦島は狼狽して、「この花は、この紫の花は綺麗だね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」浦島は、いかにもやるせないやうな溜息をついて、「私にこんな綺麗な貝をくれたが、これはまさか、食べるものぢやないだらうな。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またたく間にこんな綺麗な舟一艘つくり上げてしまふのだからねえ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お爺さんが、ふつと眼の覺めたところは、竹の柱の小綺麗な座敷である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてまた、お鈴さんに連れられて、もとの小綺麗な茶の間にかへると、そこには、大小さまざまの葛籠が並べられてある。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供は床の中で目を覚まして、その鏡台のある隣りの部屋で、お母さんが頭の生地を綺麗にするために使ふ布が、小さな金盥の中の熱いお湯に漬けられては絞られる時の、お湯の滴の音を聞いてゐます。",
              "citation": {
                "source": "家族",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし考えてみると、例えば子供の時分に同じお伽噺を何遍でも聞かされたおかげで年取って後までも覚えておられるが、桃太郎でも猿蟹合戦でも、たった一度聞いて面白いと思ったきりだったらおそらくとうの昔に綺麗に忘れてしまったに相違ない。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此れ位の細工で防がれる程度の崩れ方もあるであらうが、此の十倍百倍の大工事でも綺麗に押し流すやうな崩壞が明日にも起らないといふ保證は易者にも學者にも誰にも出來ない。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎も角も自分の子供の時にはみんな貴重な舶來物であつた品物が、ちやんと此處等のこんな見窄らしい工場で出來て綺麗なラベルなどを貼られて市場に出てくるのであらう。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "登りつめると綺麗な芝を植ゑた斜面から玉川沿の平野一面を見晴す事が出來た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで吾々も昆虫と同様明日の事など心配せずに、その日その日を享楽して行って、一朝天災に襲われれば綺麗にあきらめる。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "颱風もなければ烈震もない西欧の文明を継承することによって、同時に颱風も地震も消失するかのような錯覚に捕われたのではないかと思われるくらいに綺麗に颱風と地震に対する「相地術」を忘れてしまったのである。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、時々の余震はあっても、その余は平日と何も変ったことがないような気がして、ついさきに東京中が火になるだろうと考えたことなどは綺麗に忘れていたのであった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生犀星氏がいつか或る随筆で書いてゐたが、仕事の終つた後で、きれいに机を片づけ、硯に墨をすりながら静かに句想を練る気持は、何とも言へない楽しみだと。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
