[
  {
    "uuid": "66ec375f-05be-5bcd-a80b-b1e3e9a6e010",
    "entry": "切っての",
    "reading": {
      "primary": "きっての",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
