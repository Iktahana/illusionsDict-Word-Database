    "definitions": [
      {
        "index": 1,
        "gloss": "deferential",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は社長に対して、常に鞠躬如とした態度を崩さない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は初対面の人に対しても、鞠躬如として丁寧に接する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その武士は主君の前では鞠躬如として控えめに振る舞った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "若い従業員は、重役の話を鞠躬如として聞いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "俺も相当｜鞠躬如たらざるを得なかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそも初枝女史は、実に筆者の実姉にあたり、かつまた、筆者のフランス語の教師なのでありますから、筆者は、つねにその御識見にそむかざるよう、鞠躬如として、もっぱらお追従に之努めなければなりませぬ。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁はさらに鞠躬如として甲にお掛けなさいと言う。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私を案内して呉れる役所の人がヘルメットをかぶつて道を行くと、島民共は鞠躬如として道を讓り、恭しく頭を下げる。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私を案内してくれる役所の人がヘルメットをかぶって道を行くと、島民どもは鞠躬如として道を譲り、恭しく頭を下げる。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「満船の時はどうも仕方がありません」と、ボースンは鞠躬如として答えた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "的替えい」　英膳、鞠躬如としてつけ替えたのは一寸角の金的です。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "鞠躬如として勤勉に立働く魚芳は、もしかすると、そこの家の養子にされるのではあるまいか、と私の妻は臆測もした。",
              "citation": {
                "source": "翳",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも、原始人の恭敬篤実なこころにかえり、天を懼れ頭を垂れ、鞠躬如、かたつむりのごとく遅々として地を往くほうが、すくなくともこのさい「穏当」ではなかろうか。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、この他ならぬ鷲が一歩その部屋を出て、自分の上役の部屋へ近づくと、たちまち鷓鴣のようになってしまい、書類を小脇にかかえたまま、鞠躬如として伺候するのだ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうするとどうだらう、あたりがしいんとしづまつて、どいつもこいつも鞠躬如として鳴りをひそめてしまつたぢやないか。",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は席に就いて、一通りの挨拶を済ましたのだが、さて、その紳士、四角い卓子の角のところににじり寄ったきりで、幾ら招じても座布団を敷こうとせず、洋服の膝もくずさず、茶にも煙草にも手を出さず、謂わば鞠躬如として眼を伏せている。",
              "citation": {
                "source": "失策記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなったらもうおしまいで、こちらは不愉快に黙りこむの一手だし、先方は更に鞠躬如と、雨だの風だの電車だのバスだの――そして漸く、色紙短冊の御揮毫をときた。",
              "citation": {
                "source": "失策記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっちゃんは勇敢に注射するが、ただそれだけで、他事はもう鞠躬如として太宰に仕えている。",
              "citation": {
                "source": "太宰治との一日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "直接の目標とされた会津さえも鞠躬如として降伏を願っていたではないか。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、鞠躬如たる誠意の姿が吾人の眼を奪うのみである。",
              "citation": {
                "source": "現代能書批評",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い詩界をわざとらしく窮屈に縄張りをして、極めて自尊的に、極めてことさらに、極めてせせこましく、必要もないのに鞠躬如として、あぶくを飲んで結構がるものはいわゆる茶人である。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "館丁は命をうけて鞠躬如として出て行く。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗て有楽座の廊下で先生を追ひ廻し、鞠躬如として先生の前に雑誌を捧げたあの晩のことが、再び新たに思ひ出された。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋に入ってからはさすがに覆面だけは引き下げたが、その代り今度は大きな安楽椅子に沈み込み、鞠躬如と差し出す献立表も電報もみな肩越しに受取ったのである。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "矩広に一礼すると、白髪の老体を鞠躬如として躙り寄った蠣崎某は、恭やしく懐中から取り出した白紙を口にくわえると、いかほどかの大事を成し遂げたる様、決然と眉を挙げ、一粒の青玉を※のうちに投じたのである。",
              "citation": {
                "source": "津軽の虫の巣",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はどのボートがない方がいいかを洞察し得るものは、私をその上に泛べている広い、たっぷりして活々した愛情なのであるから、その意味でも私は何だか鞠躬如とした気持になる。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "鞠躬如として答えます「ハイハイ、油気が入ればようございましょう、油は貴重品ですから」と。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　中老人の羽織袴のお取持、これは多分、先方からこの客を迎えのための案内役と覚しいのが、鞠躬如として、まかり出てくると、新元服が物々しく、「せっかく、お招きにあずかったは嬉しいが、前に、このような山があっては、進もうにも進まれませぬ」と言いました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "高慢な妹カーチャを真から崇め、鞠躬如として小間使いのように仕えてたんだ……。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "御高説を拝聴に参ったものです」　明智が鞠躬如として云った。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隈首相を相手どって談じこんだ慷堂は、今こうして俺みたいな青二才を気楽に招じ入れて、気楽に話しこんでいるけれど、なるほど北槻中尉が鞠躬如としているのも無理はない慷堂だと思ったのだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人の鞠躬如とした姿が私の記憶にも残っている。",
              "citation": {
                "source": "桜林",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく、読者には已に顔なじみの写真師が鞠躬如として大銀行家の応接間に現われた。",
              "citation": {
                "source": "恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
