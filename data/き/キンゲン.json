    "definitions": [
      {
        "index": 1,
        "gloss": "Yours Sincerely ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
