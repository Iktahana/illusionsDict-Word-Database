        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それが五年も休止状態にあったのであるから、そろそろまた一つぐらいはかなりなのが台湾じゅうのどこかに襲って来てもたいした不思議はないのであって、そのくらいの予言ならば何も学者を待たずともできたわけである。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "休止状態にあったみじめな生活が、海の上に浮んで来る。",
              "citation": {
                "source": "田舎がえり",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "表面に、溌剌と見えるからといって、青春者が、やはり世の中へたつのは、多少とも死もの狂いであるのと同様、先覚者も決して休止状態でいるのではない。",
              "citation": {
                "source": "遠藤（岩野）清子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬季中休止状態にある庭園も、公園も、夏にはまた緑色となって、再び花が開く。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなり私はいつの間にか又、放心的な休止状態に陷つてゐた。",
              "citation": {
                "source": "受驗生の手記",
                "author": "久米正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこの場合、こうした休止状態は、ただ中止に過ぎぬのである。",
              "citation": {
                "source": "パノラマ島綺譚",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
