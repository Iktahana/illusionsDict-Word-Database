    "definitions": [
      {
        "index": 1,
        "gloss": "to disappear (gradually)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "青い煙、白い煙、目の先に透明に光って、渦を巻いて消えゆく。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と石井翁は消えゆく煙の末に浮かび出た洋服姿の年若い紳士を見て思った。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕凪の海面をわたりてこの声の脈ゆるやかに波紋を描きつつ消えゆくとぞみえし。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔母のいいけるは昨夜夜ふけて二郎一束の手紙に油を注ぎ火を放ちて庭に投げいだしけるに、火は雨中に燃えていよいよ赤く、しばしは庭のすみずみを照らししばらくして次第に消えゆくをかれは静かにながめてありしが火消えて後もややしばらくは真闇なる庭の面をながめいたりとぞ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年はしばし四辺を見渡して停止みつおりおり野路を過る人影いつしか霧深き林の奥に消えゆくなどみつめたる、もしなみなみの人ならば鬱陶しとのみ思わんも、かれは然らず、かれが今の心のさまとこの朝の景色とは似通う節あり、霧立ち迷うておぼろにかすむ森のさまは哀れに物悲し、これ恋なり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲終れば、音を売るものの常として必ず笑み、必ず謙遜の言葉の二三を吐くなるに反して、彼は黙然として控え、今しもわが吹き終った音の虚空に消えゆく、消えゆきし、そのあとを逐うかと思わるるばかりであった。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなたにひびく笛のね、……青き頬ほのに消えゆく。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "寄せ返し、遠く消えゆく塩※暗き音を聴け。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "足音す、生血の滴りしとしととまへを人かげ、おちうどか、ほたや、六部か、背に高き龕をになひ、青き火の消えゆくごとく呻きつつ闇にまぎれぬ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "――黄髪の伴天連信徒蹌踉と闇穴道を磔負ひ駆られゆくごと生ぬるき悔の唸順々に、流るる血しほ黒煙り動揺しつつ、印度、はた、南蛮、羅馬、目的はあれ、ただ生涯の船がかり、いづれは黄泉へ消えゆくや、――嗚呼午後七時――鬱憂の心の海に。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十四年一月　　蕨春と夏とのさかひめに生絹めかしてふる雨はそれは「四月」のしのびあし、過ぎて消えゆく日のうれひ。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "空と海との燻し銀、けふの曇りにふる雨はそれは涙のしのびあし、青い台場の草の芽に沁みて「四月」も消えゆくや、帆かけた船も、白鷺もましてさみしやふる雨に。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "春と夏とのさかひめに生絹めかしてふる雨はそれは「四月」のしのびあし、過ぎて消えゆく日のうれひ。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "足音す、生血のにじみしとしとと、まへを人かげおちうどか、はたや乞食か、背に重き佩嚢になひ、青き火の消えゆくごとく呻きつつ闇にまぎれぬ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンパニーレの広辻はひっそりとして人影もなく、昔の大公の宮殿の燈火は一つ一つ速やかに消えゆくところであった。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚にも夫に先だたれるものとばかり思つてゐた私が、二年とたゝぬ間に思ひもしなかつたこんな病氣に罹つて、今はその命も消えゆく燈火のしづかなゆらぎをしてゐるとは、今更に寂しい微笑がこの色褪せた唇にのぼります。",
              "citation": {
                "source": "響",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "消えゆく処女美　彼女たち職業婦人はこうした昔の職業婦人の流れを汲んで、更にそれ以上に文化的な、蠱惑的な風俗を作るべく工夫を凝らしている。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "12微かに消えゆくゆめあり、酒のにほひか、わが日か、倉の二階にのぼりて暮春をひとりかなしむ。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "22倉の隅にさす日は微かに光り消えゆく、古りにし酒の香にすら、人にはそれと知られず。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "余も我子を亡くした時に深き悲哀の念に堪えなかった、特にこの悲が年と共に消えゆくかと思えば、いかにもあさましく、せめて後の思出にもと、死にし子の面影を書き残した、しかして直にこれを東圃君に送って一言を求めた。",
              "citation": {
                "source": "我が子の死",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は刈手たちの仲間いりをして大好物の水団を賞味するのも忘れて、じつとひとつ処に立ちつくしたまま、空の彼方に消えゆく鴎を見おくつたり、野良につらなる、刈り取られた麦の堆積を数へたりしてゐるのであつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "幻なりき幻なりき、事映の消えゆくにこそ、御賜のふゆの、かつがつに目耀ひ初むれ。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言つてゐたが、暫くすると、「さうだ、『泡と消えゆく』でよかつたんだ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小さきものは、水平線まで続く潮路の上を流離ながら、弛みなく変化して、今を生きようとかつ燃えかつ消えゆくのである。",
              "citation": {
                "source": "夜光虫",
                "author": "NOCTILUCAE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にして現象である以上の意味をもつことができないならば永劫の時の流の一つの點に浮び出る泡沫にも比すべき私の生において如何に多くのものがそのうちに宿されようとも、いづれは須臾にして消えゆく私の運命ではないか。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "永久と消えゆく水の白波を一つのことと思はるべしや　過去とか未来とかいふものは思想上には考へられるが実在はしない、実在するのは現在だけである。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもじと同じ、ただの女にすぎませぬのじゃ」　と紅琴は、伸び上がり伸び上がり、次第に点と消えゆく、島影に名残りを惜しんでいたが、その時、島の頂きに当たって、音のない爆音を聞いた心持ちがした。",
              "citation": {
                "source": "紅毛傾城",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にして現象である以上の意味をもつことができないならば永劫の時の流の一つの点に浮び出る泡沫にも比すべき私の生において如何に多くのものがそのうちに宿されようとも、いずれは須臾にして消えゆく私の運命ではないか。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほほゑみ、光、まぼろし、『時』のたはふれ、束のまなりき、これさへ、やがては眞闇おくつき、――白衣きえゆく。",
              "citation": {
                "source": "春鳥集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
