    "definitions": [
      {
        "index": 1,
        "gloss": "name of a piece of music",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
