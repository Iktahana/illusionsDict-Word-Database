    "definitions": [
      {
        "index": 1,
        "gloss": "former lord",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "旧主人の角川家の前も通った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "……旧主人の後室様がお跣足でございますから、石松も素跣足。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "既にしてわたくしはこの家の旧主人小倉が後に名を是阿弥と云ったことを知った。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊においねは旧主人をかさにきて、とかくに亭主を尻に敷く形があるので、権七はいよいよ気がさして来た。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、かの鶏がなぜ旧主人のお六に襲いかかったのか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、安蔵の死ぬ五、六日前に買った鶏がどうして旧主人のかたきを討とうとしたのか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理屋といっても、家には老母と小女がいるきりなので、お杉はどんなふうに頼み込んだか知らないが、その家を逢い曳きの場所に借りて、ときどきに旧主人に逢っている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鷹のゆくえ",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸へ出て来て旧主人の和泉屋に奉公することになった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく昔の家来すじの者が旧主人のかくれ家をさがし当てて、奇特にもその世話をしているのであろう。",
              "citation": {
                "source": "平造とお鶴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその後、深川の旧主人の店に再びその姿をみせなかった。",
              "citation": {
                "source": "平造とお鶴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖縄に於ては古来主権者の更迭が頻繁であったために、生存せんがためには一日も早く旧主人の恩を忘れて新主人の徳を頌するのが気がきいているという事になったのである。",
              "citation": {
                "source": "沖縄人の最大欠点",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "光隆寺は福田の屋敷の菩提寺ですから、命日というわけじゃあねえが、曽根も勤めの暇をみて、旧主人の墓参りに行ったのです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "吉良の脇指",
                "note": "青空文庫"
              }
            },
            {
              "text": "曽根も腹立ちまぎれに斬ってしまおうかと思ったのですが、自分も今は主人持ちですから、旧主人のかたきを討つというのは少し面倒です。",
              "citation": {
                "source": "半七捕物帳",
                "author": "吉良の脇指",
                "note": "青空文庫"
              }
            },
            {
              "text": "加藤家には、旧主人に愛された老婆が一人雇われて居りましたが、信之は、何かにつけて、うるさく思い、養父母の死後、間もなく暇を出して、若い女中とかえました。",
              "citation": {
                "source": "暴風雨の夜",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、手拭いを見せると、たしかに自分のものだが、いつ落としたか知らないと申しましたので、巡査が事情を告げると、彼は凶行の行われた日の夕方、千葉の旧主人の病気を見舞いに行ったが、案外重かったので家人に留められるままに滞在した旨を語りました。",
              "citation": {
                "source": "白痴の知恵",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その休茶屋には、以前お三輪のところに七年も奉公したことのあるお力が内儀さんとしていて、漸くのことでそこまで辿り着いた旧主人を迎えてくれた。",
              "citation": {
                "source": "食堂",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうお力は旧主人を迎え顔に、誰よりも先にそこへ飛んで出て来た。",
              "citation": {
                "source": "食堂",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "りよは火事が始まるとすぐ、旧主人の細川家の邸をさして駆けて行ったが、もう豊島町は火になっていた。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "初め小さい桜の木の苗を吉野山から齎し帰つて、これを江戸の邸宅の園内に植ゑたのは、斎藤氏の家の旧主人である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "云旧主人得寸株於芳野而所栽。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　わたくしは苗木を吉野より齎し帰つた風流の旧主人の其氏をだに伝へず、又已に長じた木を蘭軒に贈つた「清淡且仁慈」なる斎藤氏の其名字を留めざるを憾む。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月十五日に、旧主人宗対馬守の重役から、御用有之、明十六日朝四時出頭するやうにと云つて来た。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち私の旧主人が建ててゐる菁々塾の創立記念会があつた。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "純一は旧主人の高縄の邸へ名刺だけは出して置いたが、余り同県人の交際を求めようとはしないでいるので、最初断ろうとした。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "平民と同格なるはすなわち下落ならんといえども、旧主人なる華族と同席して平伏せざるは昇進なり。",
              "citation": {
                "source": "旧藩情",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は前年なにゆえに廃藩の事を賛成して旧主人の落路を傍観したるや。",
              "citation": {
                "source": "徳育如何",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかのみならずその旧主人とともに社会に立ち、あるいはその上に位して世の尊敬を受くるも、恬としてはばかる色なきはなにゆえなるや。",
              "citation": {
                "source": "徳育如何",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　白が甲州に養われて丁度一年目の夏、旧主人夫妻は赤沢君を訪ねた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
