[
  {
    "uuid": "7e238213-b5cf-583b-9ccb-9be0fe91bbc9",
    "entry": "器量",
    "reading": {
      "primary": "きりょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
