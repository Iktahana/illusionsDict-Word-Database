[
  {
    "uuid": "eef7422e-9a9a-5d71-a10d-053254c7a19d",
    "entry": "綺麗さっぱり",
    "reading": {
      "primary": "きれいさっぱり",
      "alternatives": [
        "キレイさっぱり"
      ],
      "is_heteronym": false
    },
    "grammar": {
