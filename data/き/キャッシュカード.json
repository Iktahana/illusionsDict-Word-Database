        "examples": {
          "standard": [
            {
              "text": "急な出費でお金が足りなくなり、キャッシュカードでATMから引き出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "海外旅行中、キャッシュカードを紛失してしまい、慌ててカード会社に連絡した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最近はスマートフォン決済が多いから、キャッシュカードを持ち歩くことが減ったな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "銀行口座を開設する際、キャッシュカードの発行も同時に申し込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このお店ではキャッシュカードでの支払いはできないと言われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "朝から何も食べていないことを思い出し、キャッシュカードを自動販売機のカードリーダに入れると、一番ボリュームのありそうなハンバーガーのボタンを押す。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャッシュカードとハンバーガーを受け取ると、あなたは黄色い包装紙を無造作にはぎ取って大きく一口食らいつく。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
