        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "立ち合いから一気に攻め込み、見事な極め出しで白星を挙げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "土俵際で粘ったが、最後は相手の強烈な極め出しに屈した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの技は極め出しだったのか、それとも寄り切りだったのか、微妙な判定だったね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は極め出しを得意としているから、警戒が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "半之丞はこの金を握るが早いか、腕時計を買ったり、背広を拵えたり、「青ペン」のお松と「お」の字町へ行ったり、たちまち豪奢を極め出しました。",
              "citation": {
                "source": "温泉だより",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く、西洋においても、十五世紀以来、多少の変化はあったとしても大局から見て絵画は立派な老舗の下敷となって退屈を極め出したのである。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "食べるのが　ちょっと　早いのよ　――　まあ　一口も　大きめだし。",
              "citation": {
                "source": "パイとやきがたのはなし",
                "author": "THE TALE OF THE PIE AND THE PATTY-PAN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
