[
  {
    "uuid": "473bb440-1c62-5579-8f08-288a0284c0c6",
    "entry": "教養のない",
    "reading": {
      "primary": "きょうようのない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
