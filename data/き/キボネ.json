    "definitions": [
      {
        "index": 1,
        "gloss": "worry",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この厄介な問題は、関係者全員にかなりの気骨を強いるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "度重なる計画変更の連絡に、担当者は深い気骨を感じていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は他人の気骨を顧みず、自分の都合ばかり主張する傾向がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あのプロジェクトの失敗は、私にとって大きな気骨として心に残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "すゞは、ほかの第三者に対するように、こだわらない、馴れ／＼しい態度で、中津に向おうとすると、気骨が折れた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "出がけのときは、やれやれ、また重苦しく気骨の折れることと、うんざり致します。",
              "citation": {
                "source": "愛",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて芸術家気質というものでしょうが、米斎君もたしかにそういう気骨を持っていました。",
              "citation": {
                "source": "久保田米斎君の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、里のほうにしても、また私たちにしても、どうもこの疎開という事は、双方で痩せるくらいに気骨の折れるものだという事に帰着するようである。",
              "citation": {
                "source": "薄明",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは病気骨の髄を犯しても不倒である必要があります。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "出がけのときは、やれ／＼、また重苦しく気骨の折れることと、うんざり致します。",
              "citation": {
                "source": "愛",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "気骨稜々たる慷慨家の公良孺。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後世のいわゆる「万鍾我において何をか加えん」の気骨も、炯々たるその眼光も、痩浪人の徒らなる誇負から離れて、既に堂々たる一家の風格を備えて来た。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしくは居るとしても、天下を憂い、国を想う志士の気骨が筑前人には欠けていたのかというと、ナカナカそうでない。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤田東潮は、会沢の学者肌に対して、寧ろ、悲憤慷慨する稜々たる気骨の政治家肌の男であつた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹一は紀代子と喋るだけでも相当気骨の折れる仕事だったから、手紙など書いてみようとすら思わなかった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "趙家の人となった愛卿は、身のとりまわしから言葉の端に至るまで、注意に注意を払い、気骨の折れる豪家の家事を遺憾なしに切りもりしたので、趙は可愛がったうえに非常に重んじて、その一言半句も聞き流しにはしなかった。",
              "citation": {
                "source": "愛卿伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度目の入院を終えたばかりの一九九一（平成三）年の夏、『パソコン創世記』を読んだと言う、気骨という言葉の似合うヴェテランの編集者が手紙をくれました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚した当時、博士は笑談に、お前は硝子出だから、扱ふに気骨が折れると云つた事があるさうだ。",
              "citation": {
                "source": "魔睡",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくとも英雄の気象があり、豪傑の気骨がある者は、「大丈夫｜命を造るべし、命を言うべからず」と豪語して、自分で大斧を揮い、巨鑿を使って、我が運命を刻み出して当然なのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく書かせて元の所へ置かせられた（改定史籍集覧本『丹州三家物語』七三頁）、三国｜鼎争の最中や戦国わずかに一統された際の人間は、百姓までも荒々しいと同時に気骨あり、こんな落書をしたので、それを直様自ら返辞した大守もえらい。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに此方がやれないんだから、謳はせるのに気骨がをれて。",
              "citation": {
                "source": "草いきれ",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "苟くも気骨のある丈夫の風上に置くもんぢやないぞ。",
              "citation": {
                "source": "貧書生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "又武士道徳の名残で気骨のある男子は婦人に親まんのを主義とする。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "揃いも揃って気骨稜々たる不遇の高材逸足の集合であって、大隈侯等の維新の当時の築地の梁山泊知らず、吏臭紛々たる明治の官界史にあっては恐らく当時の官報局ぐらい自由の空気の横流していたはけだし類を絶しているだろう。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればこそ、勿論長門守は、江戸大公儀の慈悲あるその処断を感泣しないまでも内心喜んで御受けしただろうと思われたのに、変り者と言えば変り者、慷慨家と言えば一種気骨に富んだ慷慨家です。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、これが奇態なもので、大名たちのうちにも気骨のある者が交じっているのか、応じて叫ぶ声がきこえました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼は何の未練気もなく斯んなことを喋舌つて、「それにしても君は俺達も、左う思つてゐるんだが、珍らしく淡白な男で、却つて、何をして貰ふにも一番気骨が折れるなんて彼女は面倒がつてゐたよ。",
              "citation": {
                "source": "女優",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は然うして置いて、何ぞ他に気骨の折れぬ力相応の事をして県庁の方は辞職する。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "商売屋じゃ、なかなか気骨が折れるだろうね。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃れ株の買占めで失敗ってから、家のばたばたになった本家の後始末に気骨を折っている父親が、このごろは皆なの思うほど気楽でもないことは、こっちへも解って来た。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "お島は気骨の折れる子持の客の帰ったあとで、気憊れのした体を帳場格子にもたれて、ぼんやりしていた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
