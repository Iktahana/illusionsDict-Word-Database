[
  {
    "uuid": "0eda7ada-9a28-5a09-842c-868106e3c10f",
    "entry": "聞きなす",
    "reading": {
      "primary": "ききなす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
