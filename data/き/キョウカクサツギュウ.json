        "examples": {
          "standard": [
            {
              "text": "無理な指示で部下を追い詰めるのは、まさに矯角殺牛ではないか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、素人をプロの複雑な仕事に無理やり関わらせようとして、矯角殺牛のような結果を招いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "本質を見失い、些細な点に固執して全体を台無しにするのは、矯角殺牛の愚行だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「そんなやり方では、かえって事態を悪化させるだけだよ。矯角殺牛になってしまう。」と友人は忠告してくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
