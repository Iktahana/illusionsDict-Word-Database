[
  {
    "uuid": "d6285947-c17a-5d62-833f-c93f7348dc1c",
    "entry": "金鉄",
    "reading": {
      "primary": "きんてつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
