[
  {
    "uuid": "2e56697b-4442-559a-9e28-5cf53e64ecd2",
    "entry": "切り落とし",
    "reading": {
      "primary": "きりおとし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
