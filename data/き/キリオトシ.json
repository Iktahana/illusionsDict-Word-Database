    },
    "definitions": [
      {
        "index": 1,
        "gloss": "leftover pieces (when slicing meat, fish, cake, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ある日思い切って左の頬をうんと切り落としてから後はこの不思議な幽霊に脅かされる事は二度となくなった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、一つのリンゴをとろうとしたからって、指を一本切り落として、それがあたりまえだといっているのは、あまりにざんこくであるとも考えられました。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "王は曾婆加里の目顔がそのさかずきで隠れるといっしょに、かねてむしろの下にかくしておおきになった剣を抜き放して、あッというまに曾婆加里の首を切り落としておしまいになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その竹藪ががさりと云うかと思うと、何者か突然あらわれて小僧の持っている提灯をばっさりと切り落とした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやなら、てめえのキタネエ指を、いま切り落としてやる！",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなり弟に乗しかかつて、傍にあつた鋏を取ると、その小さな、また可燐な、恰度朝顔の蕾のやうに尖つた、ヒクヒク動いてゐるそのおちんこをいきなり、チヨンと切り落として了つた。",
              "citation": {
                "source": "神童の死",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "思い切って、あたしの手首を切り落として下さい。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫くして件の青侍に導かれ、緩端に平伏したる齋藤茂頼、齡七十に近けれども、猶ほ矍鑠として健やかなる老武者、右の鬢先より頬を掠めたる向疵に、栗毛の琵琶股叩いて物語りし昔の武功忍ばれ、籠手摺に肉落ちて節のみ高き太腕は、そも幾その人の首を切り落としけん。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の内の拵えは今と大差なく、やはり切り落としの土間になっていて、そこに八間がついていました。",
              "citation": {
                "source": "蕎麦の味と食い方問題",
                "author": "村井政善",
                "note": "青空文庫"
              }
            },
            {
              "text": "りょうしはびっくりして、思わず犬をつき放して、振り上げていた刀で、犬の首を切り落としてしまいました。",
              "citation": {
                "source": "忠義な犬",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻環は、木綿針を長さ八分ほどに切り落とし、真んなかを麻糸で括った撞木式。",
              "citation": {
                "source": "想い出",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "四、五寸のものを丸ごと照り焼きにして、皿に盛る際、頭と尾を切り落とし、棒状形にして膳にのぼす。",
              "citation": {
                "source": "一癖あるどじょう",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし八沢の長坂の路傍にあたるところで口論の末から土佐の家中の一人を殺害し、その仲裁にはいった一人の親指を切り落とし、この街道で刃傷の手本を示したのも小池伊勢の家中であった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの練馬あたりの大根を見た目には、これでも大根かと思われるほど、ずっと形もちいさく、色もそれほど白くなく、葉を切り落とした根元のところはかぶのような赤みがかった色のものです。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まず提灯を切り落としました」「それは私にもうなずかれる。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三つの先」のその一つ、「我より敵へ懸かるの手」だ、正面の山窩の右の腕を、肩の附け根から切り落とした。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一｜方は山で、切り落としたようになって、一｜方は深い深い崖であります。",
              "citation": {
                "source": "初夏の空で笑う女",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえのお父さんの足には木が生えて、いくら切り落としてもまた生えてくるが、これを治せるのがおまえです。",
              "citation": {
                "source": "木のウィリアム",
                "author": "WILLIAM OF THE TREE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやく頭を切り落とした。",
              "citation": {
                "source": "ニール・オキャリー",
                "author": "NEIL O’CARREE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは二本のシロマツの丸太をえぐったものを継ぎ合わせたもので両端は四角く切り落としてあった。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペテロは剣を抜いて、大祭司の僕の右の耳を切り落としたが、イエスは「之にてゆるせ」と言って、その傷をいやした。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「十二弟子の一人なるユダ」とくり返して記したところに、この裏切者に対する記者の憤激がうかがわれる）　その時、かたわらに立つ者の一人が――これはペテロです（ヨハネ一八の一〇）――いきなり剣を抜いて、大祭司の僕を撃って耳を切り落とした。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　王女さまは、コロロッチョの首を切り落としに看守たちが牢屋へ向かうと聞くと、急いで王さまのところへ行き、足元にひれ伏して言いました。",
              "citation": {
                "source": "コロロッチョ",
                "author": "GRILLINO",
                "note": "青空文庫"
              }
            },
            {
              "text": "死骸を吊った綱を船に縛り付け、橋桁を伝わって欄干まで登って、そこで念入りに縛り付けて、綱の端を切り落としたのち、死骸の首へ巻き付けた。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "欄干の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "辛抱強い若い雌牛の膝を切り落としているのです――子どもを産んだことのないこれらの雌牛の目はヘーラーの目のようでした。",
              "citation": {
                "source": "夕映えのむこうの国",
                "author": "時代を超えた童話",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙太　（これも手ラッパで）あのなあ、えらく、お日でりだで、川の方の三角田にや明日あたり上から少し水ば切り落としとかねえじゃと言っているのよ、段六公。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、イリューシャをなぐる代わりに、今すぐお眼の前で、そこにあるナイフでもって、十分あなたの気の済みますように、わたくしの指を四本、ずばりと切り落としてはいかがでございましょうね。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなことになれば真っ先に私の右腕を切り落としてやる。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "残念だ、あのとき海に引きずり込まれて溺れたほうが良かった」　ガイ牧師が厳粛に、「トリガーセン、私は式を妨害するためなら自分の右手を切り落としかねません。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのナイフこそは、ハルクが自ら右脚をきりおとしたナイフだった。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
