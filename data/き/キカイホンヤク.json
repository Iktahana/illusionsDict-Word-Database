        "examples": {
          "standard": [
            {
              "text": "この論文は、機械翻訳ではまだニュアンスが伝わりにくい部分がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "多言語対応のウェブサイトでは、機械翻訳の精度がサービスの質を左右する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最近の機械翻訳は飛躍的に進化しており、日常会話ならほぼ問題なく使える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "白状すると、最初のメモには、機械翻訳との結びつきは入っていませんでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーソナルコンピューターでも機械翻訳が広く使われるようになった最近になって、「ああ、こことも結び付く」と気づきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
