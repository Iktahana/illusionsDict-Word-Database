    "definitions": [
      {
        "index": 1,
        "gloss": "cutting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　さう云つて父は立ち上り、近くの若葉をつけた灌木から、素直にますぐに伸びた一枝を切り取り、丹念に其皮を剥がし、先端を尖らしてくれた。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、切り取り面に水平に下から六七間の高さに、十番線（太い針金）を張り、それに五六間の長さで移動できるように、同じく針金を下げた。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その切り取り面に、六七本の穴が仕上がり、一々押えをして、点火して、ベルを振りながら、見るのは面白い。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして、トロの線路の敷けるだけの幅で、緑屋の上の切り取りを上流へ突っ込んで行った。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その切り取りとこの切り取りとの間に、小さな沢があった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、その切り取りの岩石に、断層というか、何というか、理があったのである。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ二ヶ月かそこら前にも、中位の柳行李位な石が、その切り取りから落ちて、そんなはずがあろう道理がないのに、急傾斜面を転がって、敷居位ならまだしも鴨居から壁、敷居を打ち折って、そこへ居据った、という出来事があったばかりだった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑屋の上の切り取りは、今ではもう四五十尺も、山の臓腑が白く高く聳えていた。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その切り取りの断崖の上に、畳二畳敷位の玉石が、載っかっていた。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしても、その切り取りは、も少し深く山の内部へ向って、切り込まねばならなかった、とすれば、どちらにしても、その玉石めいたものは、「目の上の瘤」であった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑屋の上の切り取りの方から、「命がけ」みたいな大きな声が聞えた。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大山が丁場にその姿を現わすと、緑屋の上の切り取りの辺が、何だか水の底ででもあるように、ひっそりと沈み込んで、静かであった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、小林はその切り取りの真下から離れて、下流寄りの埋立ての方へ立っていた。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　と思うと、そこ――椿の木が茂って、墓が少し立ち並んだ辺――へ、生えたように立ち尽して、切り取りの山に見入った。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもをかしな話でしてな、堰堤の方で働いてゐる時に、上の方の切り取りから、小さな石ころが一つ落つこつて来ましてね、わしの背中に当つたんでがすよ。",
              "citation": {
                "source": "万福追想",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪人諸方を廻り人を殺して、耳鼻唇髪を切り取り、蟒蛇に捧げて自家に招きおらしむ。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさしく、この野郎は、きのうきょうの騒動につけ込んだただの切り取り強盗ですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手人のあがり方がちっと手間がとれているんで、そこにつけ込み同じ手口のように見せかけて、てめえらの荒仕事もその罪跡を塗りつけようとたくらんでからの切り取り強盗にちげえねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく、切り取り強盗のこやつと一味のやつらもそれ相当手ごわい連中ばかりでしょうから、そこのところを抜かりなくじょうずにひと知恵絞ってね、ひと網にお捕りのときもずんと腹をすえておかかりなせえましよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆とる右腕を切ってやったら絵はかけぬはずじゃ、絵がかけなくば名声がすたるはずじゃ、名声がすたらばわたくしの恋もさめるはずじゃ、とこのようにあさはかなことを申されまして、おむごたらしいことに根もとからぷっつりとお切り取りなさいましたのでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、肥つたグリゴーリイ・グリゴーリエ※ッチは、木箱の中で丸焼の鶏をナイフで切り取りながら、語をついだ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎が十分麻酔した時機を見はからって、メスと鋏とを以て、胸壁の心臓部を出来るだけ広く切り取り、然る後心臓嚢を切り開くと、そこに、盛んに活動しつゝある心臓があらわれる。",
              "citation": {
                "source": "恋愛曲線",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の親切５・10（夕）　むかし津山藩主の何とかいつた奥方は、余程｜悋気深い性だつたと見えて、殿の愛妾を縊め殺した上、太腿の肉を切り取り、それを羹にして何喰はぬ顔で殿が晩酌の膳に上しておいた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初は家兎の心臓を切り取り、その代りに喞筒を置きかえようとしましたが、それは出血がはげしくて、到底目的を達することは出来ませんから、後には、家兎の心臓はその儘にして置いて、喞筒に比較的長い管をつけ、それをそれぞれ適当な大血管へ結びつけることに致しました。",
              "citation": {
                "source": "人工心臓",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊池寛は「ひかげの花」について、荷風も下手になったといい、「この頃はエロでなくても、傾向がわるいという理由ですぐ切り取りを命ずる警保局が、なぜあんな世道人心を害」する作品を切りとらせないかといった。",
              "citation": {
                "source": "一九三四年度におけるブルジョア文学の動向",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂写生の歌であるが、作者はこの歌に於て、尋常でない副景を描いて目に見えるやうに自然を切り取り、その上で之を秋の夕暮といふ枠の中へ収めて一個の芸術に仕上げてゐる。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで其現そうとする画面へ、其自然のどれだけを都合よく切り取り、どんな具合に配置すれば形もよく、見て頗る愉快であろうかを考えなくてはならない。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってここに心の動きの制限された処の、ただ形と光線と色彩との何の奇もなき風景の切り取り画と人物のスケッチ類の多くが、再び揃えの衣裳によってこの世に並び出したものである。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然を前にする処の印象派風の描法は、ありのままの自然の一部を切り取り、画面に構図を作り、見たままの色彩をそのままに現して行く。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには、やっぱり勤めている女性とすれば、自分の職場で今年はどうしたい、働く女性としてどう向上してゆくか、という問題もはっきりとりあげられると思います。",
              "citation": {
                "source": "悔なき青春を",
                "author": "――現場録音 No. 4 No. 5 をよんで――",
                "note": "青空文庫"
              }
            }
          ]
        }
