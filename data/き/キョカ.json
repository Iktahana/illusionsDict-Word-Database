[
  {
    "uuid": "8272591e-eefe-599e-a4ac-2b5c5b2bb50f",
    "entry": "許可",
    "reading": {
      "primary": "きょか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
