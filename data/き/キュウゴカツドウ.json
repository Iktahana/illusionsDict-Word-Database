        "examples": {
          "standard": [
            {
              "text": "災害発生後、自衛隊が直ちに被災地での救護活動を開始した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "国際的なNPO団体が、紛争地域の住民に対する救護活動を展開している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「私たちにできることは何だろう？」救護活動のボランティアに参加することを決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ボランティアたちは、熱心に救護活動に取り組み、多くの人々を助けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それは今度の天災で個人個人の間にも、あるいは一般に民衆的にも、また大阪神戸をはじめ全国の諸都市諸地方の団体的な救護活動にも、人を涙させるような同情の行為として一時に現われた現象だったと思う。",
              "citation": {
                "source": "地異印象記",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
