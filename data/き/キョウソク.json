[
  {
    "uuid": "daccbc5f-23ae-524c-9e48-5cb8b149657a",
    "entry": "教則",
    "reading": {
      "primary": "きょうそく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rules of teaching",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もっともだれに教わるのでもなく全くの独習で、ただ教則本のようなものを相手にして、ともかくも音を出すまねをしていたに過ぎなかった。",
              "citation": {
                "source": "二十四年前",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケーベルさんに笑われた九円のヴァイオリンは、とうの昔にこわれてしまったが、このごろ思い出してまた昔の教則本をさらっている。",
              "citation": {
                "source": "二十四年前",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それが、信号法教則書と題する教科書であることを、二人の気づかぬ間に私は知りました。",
              "citation": {
                "source": "満里子のこと",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、口惜しさのあまり座敷に転がつて、教則本を頼りに水泳の練習をしたり、庭先きの小さな池にタラヒを浮べて憧れを満足させた。",
              "citation": {
                "source": "秋晴れの日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちにはベビイ・オルガン一台あるきりで其で教則本をあげた。",
              "citation": {
                "source": "親子一体の教育法",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり、ベビイ・オルガンで教則本の三分の一ほどやったのであった。",
              "citation": {
                "source": "きのうときょう",
                "author": "――音楽が家庭にもたらすもの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "教則を作ることと罰則を作ることとである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "教則は案を具して文部省に呈し、その認可を受けなくてはならない。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "教則の案は直ちに作って呈し、罰則は不文律となして、生徒に自力の徳教を誨えた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "教則は文部省が輒く認可せぬので、往復数十回を累ね、とうとう保の在職中には制定せられずにしまった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューター関係の書籍を発行するダイマックス社という出版社を起こした彼は、ベーシックの教則本を作り、マシンに関する本を刊行するという条件でＤＥＣからＰＤＰ―８と端末を借り入れた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その学校の教則の如き、我が輩の見るところにおいて大なる異論あるなし。",
              "citation": {
                "source": "学問の独立",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお、その教則の事については他日陳述するところのものあるべし。",
              "citation": {
                "source": "物理学の要用",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この教場の中にありて区々の学校を見れば、如何なる学制あるも、如何なる教則あるも、その教育は、ただわずかに人心の一部分を左右するに足るべしとのことは、必ずしも知識をまちて然る後に知るべき事柄に非ざるなり。",
              "citation": {
                "source": "徳育如何",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸足の上に、夏冬ともセルの服一枚で過し、板の上に眠るばかりか、絶対菜食で、昔は一年のうち八ヶ月は断食すると云う、驚くべき苦行が教則だったとか云う話だがねえ。",
              "citation": {
                "source": "聖アレキセイ寺院の惨劇",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よって本月初旬より、内外の社員教員相ともに談じたることもあれば、自今都合次第にしたがい、教場また教則に少しく趣を変ずることもあるべし。",
              "citation": {
                "source": "慶応義塾学生諸氏に告ぐ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学の教則に、さまざま高上なる課目をのせ、技芸も頂上に達して、画学、音楽、唱歌、体操等を教授せんとする者あるが如し。",
              "citation": {
                "source": "小学教育の事",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯學校の教則のみならず、或は一部の著書を以て天下の人心を左右すること甚だ易し。",
              "citation": {
                "source": "帝室論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "予てのハイカラ病はいよいよ発作して従来の学規も教則もまた教官連をも凡てを廃止した。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めて母上と行ったとき、あの部屋、教則本、ヴェートウヴェンのソナタ。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "教師の心｜得べきことは何よりもまず世界の知識を児童に与えることで、啓蒙ということに重きを置き、その教則まで従来の寺小屋にはないものであった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる三条の教則なるものを定めて国民教導の規準を示したのも教部省である。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて一心に属し、去来、変化、無窮、無尽なり」と）大和三教論曰、夫古聖人之教則君子死後昇天作神、故祭有降神、乃至小人則死後帰地作鬼、時或為変。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子に教則本を教えた婦人ピアニストはウィーンで自殺した。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのベビー・オルガンで伸子は教則本を習いはじめた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピアノのおいてある、そこで伸子が教則本をひきはじめた洋間に、手軽なベッドをおいて、川辺みさ子は、伸子がその部屋に入って行ったときは、うしろのカーテンをひいて、ほの暗くしたなかに横たわっていた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめベビーオルガンで教則本やっていてあとでピアノを買って貰った。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃は子供でも大人の教則本、それから練習用の『チェルニー』という本をつかいました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "魂の底からして信仰してる人たち、神を守るために一生をささげてる人たち、そういう人々はすべて――もし彼らが大胆にカトリックの教則から離れローマの権力から脱した暁には――自称カトリックの卑しい多衆からは、ただに冷淡であるばかりでなくまた敵意ある者と見なされる。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩の方は手紙の型式になったスキーの教則だというが、大したこともなく、それより木版画の方を御紹介したいが、文章ではちょっと手に負えぬ。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
