    "definitions": [
      {
        "index": 1,
        "gloss": "aristocrat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "つまり、こんなのが、眞の貴人の接待法なのかも知れない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、それほど極端の悲觀論を稱へずとも、或ひは、貴人といふものは、しばしば、むごい嘲弄を平氣でするものであるから、乙姫もまつたく無邪氣の惡戲のつもりで、こんなひとのわるい冗談をやらかしたのか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "王侯貴人の像をイジくるよりか、それはわが党の『加と男』のために、じゃアない、ためにじゃアない、「加と男」をだ、……をだをだ、……。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "死火山の列雪青く、　　よき貴人の死蝋とも、　　星の蜘蛛来て網はけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔から物語の本にもある、屋の棟へ白羽の征矢が立つか、さもなければ狩倉の時｜貴人のお目に留って御殿に召出されるのは、あんなのじゃと噂が高かった。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "伐墓という語は支那には古い言葉で、昔から無法者が貴人などの墓を掘った。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "また其が貴人の屍體であツたとしても、賤婦野人の屍體であツたとしても、彼は其處に黒犬と斑犬との差別を付けようとしなかツた。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、こんなのが、真の貴人の接待法なのかも知れない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、それほど極端の悲観論を称へずとも、或いは、貴人といふものは、しばしば、むごい嘲弄を平気でするものであるから、乙姫もまつたく無邪気の悪戯のつもりで、こんなひとのわるい冗談をやらかしたのか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは甚だ不思議なことで、貞盛が呂公や許子の術を得て居たか何様かは知らないが、人相見でも無くて思ひ切つたことを貴人の前で言つたものである。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを突然に、郎等だにあらば打殺してましものをと言ふのは、余りに従兄弟同士として貴人の前に口外するには太甚しいことである。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時からとも無く、自然の成りゆきで駅の長は女となり、其長の下には美女が其家の娘分のようになっていて、泊る貴人等の世話をやくような習慣になったものである。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の不面目はもとより、貴人のご不興も恐多いことでは無いか。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "伐墓といふ語は支那には古い言葉で、昔から無法者が貴人などの墓を掘つた。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "天平勝寶の昔に貴人より庶民に至るまで、形にせられたる人心の象徴たる大佛に禮拜したと同じ意味である。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔から物語の本にもある、屋の棟へ白羽の征矢が立つか、然もなければ狩倉の時貴人のお目に留まつて御殿に召出されるのは、那麼のぢやと噂が高かつた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜花は果を結ばざるが故に、単に慰藉の用に供すべきのみなるかと問ふに、貴人の園庭に於て必らず無くてならぬものとなり居るところよりすれば、幾分かは実用の性質をも備へてあるなり。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "お作と女は貴人の宿をした覚えがないから、まごまごして返事もできなかった。",
              "citation": {
                "source": "妖怪記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "王侯貴人が往々文芸の士を羅致して、声威を張り儀容を飾る具となすように、藤次郎は俳諧師、狂歌師、狂言作者、書家、彫工、画工と交って、その多数を待つことほとんど幇間と択ぶことが無かった。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてイイダ姫の舞ふさまいかにと、芝居にて贔屓の俳優みるここちしてうち護りたるに、胸にさうびの自然花を梢のままに着けたるほかに、飾といふべきもの一つもあらぬ水色ぎぬの裳裾、狭き間をくぐりながち撓まぬ輪を画きて、金剛石の露｜飜るるあだし貴人の服のおもげなるを欺きぬ。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてイイダ姫の舞うさまいかにと、芝居にて贔屓の俳優みるここちしてうち護りたるに、胸にそうびの自然花を梢のままに着けたるほかに、飾りというべきもの一つもあらぬ水色ぎぬの裳裾、せまき間をくぐりながらたわまぬ輪を画きて、金剛石の露こぼるるあだし貴人の服のおもげなるをあざむきぬ。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここはどこだね」「霊虚殿でございます」「大王はどこにいらるる」「今、元珠閣で、太陽道士と火経を講じておりますから、すぐお出ましになります」　紫の袍を著た貴人が侍臣に取り巻かれて宮門の方から出てきた。",
              "citation": {
                "source": "柳毅伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫衣の貴人は静かに入ってきた。",
              "citation": {
                "source": "柳毅伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫の袍を来て青玉を持ったいかつい顔の貴人が、いつの間にか洞庭君の傍へ来て立った。",
              "citation": {
                "source": "柳毅伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "梁は楚の襄王のような貴人であろうとおもったが、それにしては従者がひどくすくなかった。",
              "citation": {
                "source": "西湖主",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "君も一人の貴人を殺し、しかしてその妻を自殺させて、もうそれで万事休矣というものさ。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは先年西海の果に崩御あらせられた貴人の御霊であったが、それを拝すると共に眼前が暗んで馬から落ちたのだと云う噂であった。",
              "citation": {
                "source": "頼朝の最後",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "車中よりは、人々齡四十の上を一つ二つ踰えたる貴人の驚怖のあまりに氣を喪はんとしたるを助け出だしき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の噂を聞くに、この貴人はボルゲエゼの族にて、アルバノとフラスカアチとの間に、大なる別墅を搆へ、そこの苑にはめづらしき草花を植ゑて樂とせりとなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "此貴人の使なりとて、「リフレア」着たる僕盾銀（スクヂイ）二十枚入りたる嚢を我に貽りぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
