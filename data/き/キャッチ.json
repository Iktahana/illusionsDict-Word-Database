        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "子供のキャッチボールのそれ球をわんわんのように這って椽の下にさがしに行ったりどろだらけな靴下をつくろってやることもあります。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は局員たちを相手にキャッチボールをはじめました。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらの気持ちを、そのまま正確にキャッチ、やや口ひきしめて首肯き、おぼつかなき風の手つきで、かぞえた。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これはアメリカ製でホックスキャッチャーと云います。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、よくみんなはキャッチボールをするから。",
              "citation": {
                "source": "久助君の話",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうにも狙ひがつけにくく、私は、ふたりの姿をレンズから追放して、ただ富士山だけを、レンズ一ぱいにキャッチして、富士山、さやうなら、お世話になりました。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "金文字のはいった扉を押すと、十球の全波受信機がキャッチしたサンフランシスコの放送音楽が、弦楽器の見事なアンサンブルを繊細な一本の曲線に流して、京吉の足は途端に、リズミカルに動き出した。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "章三は絶えず偶然を感じ、それをキャッチして来たのである。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムシトリナデシコ、英名キャッチ・フライ（蝿取）、その茎に粘液を出し蝿がとまると脱さぬ。",
              "citation": {
                "source": "きのふけふの草花",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯をみがいていると、こんどは予定どおり、デイヴ・クラーク・ファイヴの〈キャッチ・アス・イフ・ユー・キャン〉になったので、ようやく気分が落ちついた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホームランをキャッチしてしまった外野手が、高だかとグラヴをさしあげる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこからは、事務所の前で、ワイシャツの社員がキャッチボールをやっているのが見えた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐそばで、ホテルのコックがスポンジボールでキャッチボールをしている音が単調に聞こえる。",
              "citation": {
                "source": "謎の女",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "只今天文部は、電子望遠鏡の中に彼の姿をキャッチしたのだった。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんしろ今頃学校にいれば午餐をすまして、運動場でキャッチボールでもしている時間でした。",
              "citation": {
                "source": "誰が・何時・何処で・何をした",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその第一歩としては、何よりも画面の速度を正確にキャッチすることにつとめてもらいたい。",
              "citation": {
                "source": "映画と音楽",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば戦車だの飛行機だのと云つても、漢字を当てはめて見なければ意味が通ぜず、英語を嫌つて野球用語のピッチャーを投手、キャッチャーを捕手などと云つて見たところで、やはり漢字を当てはめてみなければ意味は通じないのである。",
              "citation": {
                "source": "閑人詩話",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうかなりな年配なひとだが、道で子供たちがキャッチボールかなんぞしていると、自分も青年のようにその中へ這入っていって子供たちに人気を呼んでいた。",
              "citation": {
                "source": "落合町山川記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　日曜日のひる近くで、近所の中学生が杉垣の外でキャッチボールをしている音がきこえる。",
              "citation": {
                "source": "杉垣",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの肥料をつかってこないよう出来たと見せようちゅうところの」　苅ったところで達治とキャッチボール○多賀さんの山　が右手　寺の山　左手　むこうはＡの家。",
              "citation": {
                "source": "Sketches for details Shima",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでもまた葉櫻の下で、數名の生徒たちがキャッチ・ボオルをしてゐた。",
              "citation": {
                "source": "葉櫻日記",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちも、此處で、よく授業を怠けては、こんな風にキャッチ・ボオルなどをしてゐたことを思ひ出した。",
              "citation": {
                "source": "葉櫻日記",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この森というのは、ずいぶん古くから手塚の薬局にいるが、代診として患者を往診した事はきわめてまれである、千三はいつも森が白い薬局服を着て往来でキャッチボールをやってるのを見ているのではなはだおぼつかなく思った。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああここがおれの生まれたところなんだ、おれが生まれたときに手塚の親父がぺこぺこ頭をさげて見舞いにきたんだ、それがいまそいつに占領されてあべこべにおれの方が頭をさげて薬をもらいにきてる」　ある日かれはこんなことを考えながら門をはいろうとするとそこで代診森君が手塚とキャッチボールをしていた。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "安場は日曜ごとに浦和へきた、そうして千三にキャッチボールを教えたりした、元来｜黙々塾に通学するものはすべて貧乏人の子で、でっち、小僧、工場通いの息子、中には大工や左官の内弟子もあった。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが安場がきてからキャッチボールがはやりだした、安場は東京の友達からりっぱなミットをもらってきてくれた、チビ公は光一のところへグローブの古いやつをもらいにいった。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "選手は入場するやいなやすぐキャッチボールを始めた、それがすむと、一同さっと散ってめいめいのシートシートに走った。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "（まだ誰一人なじみのない彼は、毎朝校舎の横手の青々した芝生に坐ってみたり、高等学部の前の記念樹の間をぶらついて、運動場でキャッチボールをしている人達を見やって親愛と征服の想いに瞳を輝かせたりして響きの懐かしい鐘の音を待った。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそも「土地利用」としましては、その根本的問題といたしましては、毎日その土地へ太陽から送られる熱や光を初め、その他いろいろのエネルギーをできる限り完全にキャッチするということであろうと考えているのでございます。",
              "citation": {
                "source": "自力更生より自然力更生へ",
                "author": "三澤勝衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが公園の中はひっそりかんとしていて、野球やキャッチボールをしている者はない。",
              "citation": {
                "source": "烏啼天駆シリーズ・４　暗号の役割",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
