        "examples": {
          "standard": [
            {
              "text": "「チェロの滑らかな共鳴胴が、深みのある音色を響かせる。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この古楽器の共鳴胴には、繊細な彫刻が施されている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「アコースティックギターの共鳴胴が、弦の振動を空気中に放出し、音量を増大させる。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「三味線の共鳴胴は、その独特の乾いた音色に不可欠だ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "バラライカ　露西亜の農民間に愛用される楽器の一種で、共鳴胴の表面が三角形をなす、マンドリンに類似した三絃琴。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            }
          ]
