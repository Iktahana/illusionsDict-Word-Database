    "definitions": [
      {
        "index": 1,
        "gloss": "pigeon pea (Cajanus cajan)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今日のランチは、野菜たっぷりの木豆カレーにしよう！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あの国の家庭料理では、木豆を使ったスープがよく飲まれているらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "プランターでも木豆は育てられるのかな？ちょっと挑戦してみようかな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "カキツバタを加木豆波太、加岐都波太、加吉都幡多、華己紫抜他、もしくは加岐都波奈と書くのは単にその和名を漢字で書いたもので、すなわちいわゆる万葉仮名である。",
              "citation": {
                "source": "カキツバタ一家言",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "カキツバタを加木豆波太、加岐豆波太、加岐都波太、加吉都幡多、華己紫抜他、もしくは加岐都波奈と書くのは単にその和名を漢字で書いたもので、すなわちいわゆる万葉仮名である。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「豆やふきまめー」も振鈴の音ばかりになった。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
