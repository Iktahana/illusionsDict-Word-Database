    "definitions": [
      {
        "index": 1,
        "gloss": "before I knew it",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そういうあたりまえのことにひょいと気がつくと何とも知れない涙が眼の奥から浸潤み出るのだ。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がつくとその路を自分は今夜三回も通っていた。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだ女は好い面の皮で、さぞ怨んでいるだろうよ」「二人が心中だという確かな証拠があるんでしょうか」「女の書置が見付かったから間違いもあるめえ」　云いかけてふと気がつくと、お登久の涼しい眼には涙がいっぱいに溜っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、源作は、小川に気がつくと答えた。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いったい俺は今夜あの男をどうするつもりだったんだろう」　生島は崖路の闇のなかに不知不識自分の眼の待っていたものがその青年の姿であったことに気がつくと、ふと醒めた自分に立ち返った。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がつくと綿で包んだような音がかすかにしている。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がつくと、白い猫が一匹、よその家の軒下をわたって行った。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がつくと男滝の方はどうどうと地響打たせて。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめては狩衣か、相成るべくは、緋縅の鎧……と気がつくと、暑中伺ひに到来の染浴衣に、羽織も着ず、貝の口も横つちよに駕籠すれして、もの欲しさうに白足袋を穿いた奴が、道中つかひ古しの蟹目のゆるんだ扇子では峠下の木戸へ踞んで、秋田口の観光客を――入らはい、と口上を言ひさうで、照覧あれは事をかしい。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がつくと、曲は終っている。",
              "citation": {
                "source": "秋の歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度気がつくともう目の前の絵は消えてそこにはさまざまな悲劇の場面が現われた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のいるのに気がつくとお互いに顔を見合わせたきりで、別に驚いたふうも困った様子もなくどこかへ行ってしまった。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはその人をやりすごして、すこしの間どうしようかと思っていたが、妹や弟のいどころが知れなくなってしまっては大変だと気がつくと、家に帰るのはやめて、大急ぎでその男のあとを追いかけた。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時始めてそれに気がつくと、人見は話の糸目を探りあてたように思って、落着きを見せて畳の上の金を蟇口にしまいこみながら、「こりゃいよいよ冬が来るんだよ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに気がつくと清逸はきゅうに咳を喉許に感じて、思わず鼻先で手をふりながら座を立ち上った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく何事も知らずにいた純次は気がつくといきなりがばと暗闇の中に跳び起きたらしかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに気がつくと、きゅうにすがすがしく力を感じた、落着いてふたたび書物に向うことができた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人のかたわ者はかたわがなおりかけたと気がつくと、ぺたんと地びたに尻もちをついてしまいました。",
              "citation": {
                "source": "かたわ者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばね仕掛けであるはずの戸が自然にしまらないのを不思議に思ってふと気がつくと、彼女が静かにハンドルを握りながら、ほほえんで立っていた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ夫人と、夫人の記した聖者伝に就き、こんなことを考えているうち、ふと気がつくと、富士と人間との間のその魅惑は、今度は私に取り憑いている。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、気がつくと、私は首尾よくその人の中に飛び込めて、川に融け合ったようです。",
              "citation": {
                "source": "愛",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "可訝いな、屋根裏が見えるくらいじゃ、天井の板がどこか外れた筈だが、とふと気がつくと、桟が弛んでさえおりますまい。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何もかも無我夢中だったが、はっと気がつくと、「こいつッ！",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして気がつくと、女の眼はなおもじっと動かなかった。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　気がつくと、前歯が一枚抜けているせいか、早口になると彼の言葉はひどく湿り気を帯びた。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "すごすご帰りの電車に乗って、ふと気がつくと、財布がない。",
              "citation": {
                "source": "経験派",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "近眼の紀代子は豹一らしい姿に気がつくと、それを確めようと眉のつけ根を引き寄せ、眼を細めていた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年はそれに気がつくとびっくりして歌を止めてたずねた。",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それから何分間経ったか……何時間過ぎたかわからなかったが、昂作が気がつくと間もなく、二、三人の男の会話がハッキリと耳に入って来た。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その草川巡査の取調べが全然予想と違った順序で、極めて、注意深く事件の核心に突込んで来るらしい事に気がつくと、もう恐ろしくて恐ろしくてたまらなくなって、飯を喰ってみてもナカナカ気持が落つかなかった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
