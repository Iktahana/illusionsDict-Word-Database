[
  {
    "uuid": "4ecda236-7570-5be8-b41c-207fc157d815",
    "entry": "挟撃",
    "reading": {
      "primary": "きょうげき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
