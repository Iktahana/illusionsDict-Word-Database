        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "利いた風な了簡で覗きに来る連中には百年経ったってわかりっこない。",
              "citation": {
                "source": "道成寺不見記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "と刎ねられて、利いた風な、と口惜がった。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "色の白い、目鼻立の好い男は、とかく軽薄らしく、利いた風で、懐かしくない。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "遣つて見ろ、そんな場合には自今毎でも蒲田が現れて取挫いで遣るから」「間も男なら犬の糞ぢや仇は取らない」「利いた風なことを言ふな」風「これさ、もう好加減にしないかい。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうすると、了局に那奴は何と言ふかと思ふと、幾許七顛八倒しても金で縛つて置いた体だなんぞ、と利いた風な事を言ふんぢやありませんか。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "チヨツ利いた風な事を言つてるよ。",
              "citation": {
                "source": "絶望",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿律義なものに厭味も利いた風もありようはない。",
              "citation": {
                "source": "子規の画",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しつこい真似すると承知しねえぞ」「利いた風なセリフ吐かすないッ。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸の名残りだの、めずらし屋だのと、利いた風な看板をあげておいて、あのざまはなんじゃ！",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "珠数屋はそれを見ると、急に利いた風な事が言つてみたくなつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お為めのいい」石鹸は眇のやうな眼附で、利いた風な事を喋舌る大学生の顔を見てゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿律氣なものに厭味も利いた風もあり樣はない。",
              "citation": {
                "source": "子規の畫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "利いた風な口を利くねえ！",
              "citation": {
                "source": "放浪の宿",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「利いた風なことをぬかすな」と、義雄は、眞面目になつて、自分の威嚴を持つて主張する主義にわけも分らず口を入れる女を叱りつけた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔｜Vis-a`-vis〕 の先生は、同じ痩せても、目のぎょろっとした、色の浅黒い、気の利いた風の男で、名を犬塚という。",
              "citation": {
                "source": "食堂",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "八、半可な通人ぶりや利いた風の贅沢をせざる事。",
              "citation": {
                "source": "彼の長所十八",
                "author": "――南部修太郎氏の印象――",
                "note": "青空文庫"
              }
            },
            {
              "text": "うぬが土百姓の分在で、利いた風な御託を並べやがる。",
              "citation": {
                "source": "鼠小僧次郎吉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「利いた風な事を云うな。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "利いた風なことを言うものではありません。",
              "citation": {
                "source": "継子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが黒い馬掛児に、心もち藍の調子が勝った、薄鼠の大掛児を着ている所は、さすがは当年の才人だけに、如何にも気が利いた風采である。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "下宿料の十円や十五円は懸物を一幅売りや、すぐ浮いてくるつて云つてたぜ」「利いた風な事をぬかす野郎だ。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "下宿料の十円や十五円は懸物を一｜幅売りゃ、すぐ浮いてくるって云ってたぜ」「利いた風な事をぬかす野郎だ。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ微妙な関係にあつて、三成にことさら反乱を起させてまとめて平げやうなどといふ利いた風な細工が自信満々でつちあげられるものではないので、家康には利いた風な見透しなどといふものはなかつた。",
              "citation": {
                "source": "家康",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きくくるくる頸に卷いた染色のハンカチーフは利いた風に結んで端を胸にたくしこんである。",
              "citation": {
                "source": "驛傳馬車",
                "author": "アーヴィング",
                "note": "青空文庫"
              }
            },
            {
              "text": "「気のきいたふうの夕刊売り、やめろ。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だめだよ、口端できいたふうな事を云ったって、からっきしだめじゃないか、しっかりおしよ」「へッ」　平吉はとぼけるように云って金網戸の錠を啓けた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気のきいたふうをした下仕えの女中を出して、立ちとまり霧の籬の過ぎうくば草の戸ざしに障りしもせじ　と言わせた。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙ってさっき聞いてりゃ、ぐにゃぐにゃの贅六なんかときいたふうなせりふぬかしゃがって、とれるものならみごととってみろッ」　いうやいなや、かたわらの中わきざしを引きよせて、ぎらり秋水にそりを打たしながら八つ化け仙次が立ち上がったものでしたから、それぞ右門の期したるところ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「…………」「そりゃね、あっしがきいたふうな漢語なんぞ使うのはがらにねえですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "捜してみたけりゃ、天井なりと、床の下なりと、もぐってみるがいいさ」「きいたふうなせりふをおっしゃいましたね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "やまがら美人影絵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
