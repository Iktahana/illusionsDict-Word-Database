          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夏の満員電車で、見知らぬ人の汗ばんだ腕が自分の肌にピタッと触れるのはすごく気持ち悪い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "背中に何かが這っているような感覚があるのに、鏡を見ても何もいなくて余計に気持ち悪い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "嘘を隠したまま過分な褒め言葉を受け取るのは、良心が咎めてなんとなく気持ち悪いものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
