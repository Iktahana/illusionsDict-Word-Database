    "definitions": [
      {
        "index": 1,
        "gloss": "Kyoto",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新緑の季節、古都の趣を残す京の都は、訪れる人々を魅了する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「やっぱり、京の都は何度来ても飽きないね。風情がある。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔の貴族たちは、華やかな京の都での生活に憧れていたのだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この画は、夕暮れ時の静かな京の都の情景を描いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "この美しい京の都にも、春にそむいた家なき十万人の戦災者引揚者が流れて来ていることを、忘れないで下さい。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "京の都には海があるもんかの。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――どれ、茶漬けの馳走にあずかりましょうかな」　宝蔵院漬けの茶漬けに味をしめた佐助は、その日の昼食を、奈良から一足飛びに飛んだ京の都、今出川畔、当時洛中に噂の高い、その名も富田無敵という男の道場で、したためた。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩飯は同じく四条、元室町出仕の吉岡憲法の道場、翌日の朝飯は百万遍、舎利無二斎の道場と洛中の道場を一つ余さず食べつくした挙句、やがて京の都を今日（京）を限りに大坂へ現われた時に既にアバタの茶漬け侍の威名は、その醜いアバタ面の噂と共に、大坂中に鳴り響いていた。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "前将軍の秀忠がおびただしい人数を連れて滞在しているところへ、新将軍の家光が更におびただしい同勢を具して乗り込んで来たのであるから、京の都は江戸の侍で埋められた。",
              "citation": {
                "source": "鳥辺山心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは、お江戸日本橋をふり出してから、京の都へ落ちつくまで、東海道の五十三｜次、どの宿でも、どこの宿場でも、ほんとうに失敗のし通しです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月の日の光は窓の外に満ちて、家々の屋根と緑葉とに映り輝いて、この東京の都を壮んに燃えるように見せた。",
              "citation": {
                "source": "並木",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "醍醐帝の延喜年間、西暦十世紀頃、京の都大路を、此那実際家、ゆとりのない心持の貴族が通って居たと思うと、或微笑を禁じ得ないではないか。",
              "citation": {
                "source": "余録（一九二四年より）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂上田村麻呂は今から千｜年余りも昔、桓武天皇が京都にはじめて御所をお造りになったころ、天子さまのお供をして奈良の都から京の都へ移って来たうちの一人でした。",
              "citation": {
                "source": "田村将軍",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なる程、備前岡山は中国での京の都。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "大東京の都市計画で、この方面一帯が何年か後には一大工業中心地になるという話がある。",
              "citation": {
                "source": "昔の火事",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この種のものを、東京の都市は、各処に数多く持っている。",
              "citation": {
                "source": "高千穂に思う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　ここで目を転じて、北京の都市を眺めてみよう。",
              "citation": {
                "source": "北京・青島・村落",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "根が分裂の激しい東京の都民性であり、殊に演劇の「近代古典」を顧る心を失うてゐた擾乱の時代に臨んでゐた歌舞妓芝居の俳優の死に、一都府挙げて愛別の表情を示さうなどゝは思ひもよらぬことだつたのかも知れぬ。",
              "citation": {
                "source": "市村羽左衛門論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、京の都からやって来て、そこに隠れ住んでいる、年とったえらい先生について、いろいろなことを学んでいました。",
              "citation": {
                "source": "長彦と丸彦",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "京の都の、名高い彫り物師にたのんで、観音様の像をほってもらいました。",
              "citation": {
                "source": "長彦と丸彦",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "京の都の大臣の所から盗んできた馬を、顔丸の丸彦にうばいとられてしまいましたし、その馬のことをよく知っている坂の上の朝臣が、堅田にやって来られるそうでした。",
              "citation": {
                "source": "長彦と丸彦",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の都心近くの掘割の水は、もっと汚く黒濁りがして、水草などはなかった。",
              "citation": {
                "source": "広場のベンチ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、音にきく北京の都を、その風物を、ゆつくりとはいかぬまでも、しみじみと訪れたい。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の都市計画と建築がさうなのである。",
              "citation": {
                "source": "其日、其日の気持",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年日本へ観光にきた仏蘭西の一画家が、東京の都会美には何処となく植民地の匂いがある。",
              "citation": {
                "source": "増上寺物語",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ふに灘は一等品を京大阪、東京の都会地へ出し、土地へは二等品で間に合すらしい。",
              "citation": {
                "source": "新潟の酒",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の都市は王政復古の後早くも六十年の星霜を閲しながら、猶防火衛生の如き必須の設備すら完成することが出来ずにいる。",
              "citation": {
                "source": "上野",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "コスモスの花が東京の都人に称美され初めたのはいつ頃よりの事か、わたくしはその年代を審にしない。",
              "citation": {
                "source": "葛飾土産",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の都人が食後に果物を食うことを覚え初めたのも、銀座の繁華と時を同じくしている。",
              "citation": {
                "source": "葛飾土産",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "この戦争に、シナで人命を失うもの百万人、シナの港々は言うに及ばず、南京の都まで英国に乗っ取られ、和睦を求めるためにシナより英国へ渡した償金は小判にして五百万枚にも及んだ。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "輝く初夏の空の下、際限なくつづく瓦屋根の間々に、あるいは銀杏、あるいは椎、樫、柳なぞ、いずれも新緑の色｜鮮なる梢に、日の光の麗しく照添うさまを見たならば、東京の都市は模倣の西洋｜造と電線と銅像とのためにいかほど醜くされても、まだまだ全く捨てたものでもない。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡船は東京の都市が漸次整理されて行くにつれて、即ち橋梁の便宜を得るに従ってやがては廃絶すべきものであろう。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            },
            {
              "text": "われらが住む東京の都市いかに醜く汚しというとも、ここに住みここに朝夕を送るかぎり、醜き中にも幾分の美を捜り汚き中にもまた何かの趣を見出し、以て気は心とやら、無理やりにも少しは居心地住心地のよいように自ら思いなす処がなければならぬ。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
