        "examples": {
          "standard": [
            {
              "text": "休会明けの議会は、早速新たな議題の審議に活発な議論を繰り広げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "学校の休会明け初日は、生徒たちの元気な声が校庭に響き渡った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長かった夏休みも終わり、休会明けの大学は活気を取り戻し、学生で賑わっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "休会明けの法廷で、被告人は冷静に証言を続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "同じく休会明けの二十四日には、田中正造ほか四十六名を提出者とし、六十二名を賛成者として「公益に有害の鉱業を停止せざる儀に付質問書」が衆議院に提出された。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
