  {
    "uuid": "cbdb4316-37eb-56fe-a5fe-f8451d525585",
    "entry": "強制力",
    "reading": {
      "primary": "きょうせいりょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
