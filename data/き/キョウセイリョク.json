        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女の放つ圧倒的なオーラには、周囲を黙らせてしまうほどの強制力があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「みんなが賛成している空気感そのものが、僕にとっては無言の強制力に感じられたんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "流行の波は、個人の好みを塗り替えてしまうほどの強い強制力を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "目標達成に向けたリーダーの情熱が、メンバー全員を動かす強制力となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
