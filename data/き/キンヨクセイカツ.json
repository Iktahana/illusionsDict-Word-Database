    "definitions": [
      {
        "index": 1,
        "gloss": "an ascetic existence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『明治三十五年、中學生の禁欲生活を目的とする琴聲會と言ふに入り、次第に深入りして、卒業の年迄、一人此氣分を守り遂げる。",
              "citation": {
                "source": "釋迢空",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "神としての資格を完全に得る為、物斎みを家に居てする間の禁欲生活を遂げさせる為、しるしを曲げて縛つて置きなどした信仰伝承があつたかと思ふ。",
              "citation": {
                "source": "古代民謡の研究",
                "author": "その外輪に沿うて",
                "note": "青空文庫"
              }
            },
            {
              "text": "万葉では、意義合理化せられてゐるが、女にあはぬ長い間の禁欲生活といふ義を含んでゐた証拠を一つあげる。",
              "citation": {
                "source": "古代民謡の研究",
                "author": "その外輪に沿うて",
                "note": "青空文庫"
              }
            },
            {
              "text": "ながめいみは、五月の雨期の忌みが、飛鳥・藤原朝の頃から、農村の重大事となつて来て、其長期の禁欲生活の印象が、此語及び、略形や、其成語などに、媾事遮断の苦痛や、焦慮・空虚感を表す様に導いたと見られる。",
              "citation": {
                "source": "古代民謡の研究",
                "author": "その外輪に沿うて",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、もっとも古くは、神の資格を得るための禁欲生活の間に、外からも侵されぬよう、自らも犯さぬために生命の元と考えた部分を結んでおいたのである。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "成年戒を今年授かろうとする者どもはもとより、受戒者もおなじく禁欲生活を長く経なければならぬ。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした持戒の間の禁欲生活の後、をとことなり、をとめとなる。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "祓へを行ふ地方で行れた、五月雨期の男女神人の禁欲生活が、雨障又は、霖忌であつた。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、御嶽精進も、物忌みの禁欲生活で、若い人々の山籠りをして神人の資格を得る、山人信仰の形式から出たものと見る方が正しいのである。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処で、ある期間の禁欲生活を経た若者たちは、その解放を意味する儀礼としての祭祀において、神群行の聖劇を行つた。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して何れが元か訣らぬが、仮に決着をつけて見れば、長雨の時期で禁欲生活をすることからながめが出で、此からめが出て、「ながめを経しめ……給ふ」になつたと言へるのであるが、我々は昔の言葉に対する用意や感覚に乏しいのであるから、簡単には決められないのである。",
              "citation": {
                "source": "熟語構成法から観察した語根論の断簡",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おみは大忌（人）で、主上が神となられ、同時に饗応役となられるのに対して、其為事を補佐する位置に立つ為に、禁欲生活をして、宮廷に籠つてゐる。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺院の人々は禁欲生活を過重し勝ちでとかく所謂煩悩に即した生活の中にも道徳律や悟脱の力のあることを忘れている様です。",
              "citation": {
                "source": "今後の寺院生活に対する私考",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "禁欲生活が道徳的に勝れている理由もなく、又特に早く悟れる理由もありません。",
              "citation": {
                "source": "今後の寺院生活に対する私考",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "禁欲生活の外分も保ちたいなんてのは、随分あさまし過ぎると思われます。",
              "citation": {
                "source": "今後の寺院生活に対する私考",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺院の人々は禁欲生活を過重し勝ちでとかく所謂煩悩に即した生活の中にも道徳律や悟脱の力のあることを忘れてゐる様です。",
              "citation": {
                "source": "今後の寺院生活に対する私考",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "禁欲生活が道徳的に勝れてゐる理由もなく、又特に早く悟れる理由もありません。",
              "citation": {
                "source": "今後の寺院生活に対する私考",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "禁欲生活の外分も保ちたいなんてのは、随分あさまし過ぎると思はれます。",
              "citation": {
                "source": "今後の寺院生活に対する私考",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "此物忌みの褌を締めて居る間は、極端なる禁欲生活をせねばならぬ。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が或期間、禁欲生活をすると、解放の時が来る。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまつゝみ常する君は、久方の　きのふの雨に　こりにけんかも（巻四）此歌は、いつも雨つゝみをしてゐるあなたは、昨日の雨で外出が出来ずに、懲りた事でせう、といふ意だとされて居るが、実は男、女の禁欲生活をして居る意味の罪である。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、精進とは、仏教の考へから、魚を食はぬ事を斥していふが、本来は、禁欲生活・物忌み生活を言うた語である。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かやうに、若者になる為には、石につめたり、山の中に塗りこめたりする事が行はれたので、普通、山ごもりは、単なる禁欲生活だと思はれて居るが、実は其間に、かうして、一度自然界のものゝ中に這入つて来なければならなかつた。",
              "citation": {
                "source": "霊魂の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、最古くは、神の資格を得る為の禁欲生活の間に、外からも侵されぬやう、自らも犯さぬ為に生命の元と考へた部分を結んで置いたのである。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "成年戒を今年授からうとする者共は固より、受戒者もおなじく禁欲生活を長く経なければならぬ。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからヴィール夫人はドクトル・ケンリックの「禁欲生活」の終わりに書いてある初期のキリスト信者の話をして、かれらの生活を学ぶことを勧めた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "ヴィール夫人の亡霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "この勢いのおもむくところは社寺領上地の命令となり、表面ばかりの禁欲生活から僧侶は解放され、比丘尼の蓄髪と縁付きと肉食と還俗もまた勝手たるべしということになった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは荒野に退いて禁欲生活を為し、一日に何度となくヨルダン川でみそぎをして、清浄心の境地に達しようとする人々であった。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "このエッセネ派というのはヨルダン川の東荒野地方に居住して粗衣粗食、独身の禁欲生活をなし、しばしば断食し、また一日に何度も川に飛び込んで禊をしました。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "その答として彼の頭に浮んだのは、仏僧の禁欲生活であった。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
