        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お盆には、仏壇の前に経机を置き、お経を唱える準備をします。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この立派な経机は、伝統工芸品として職人が丹精込めて作ったものです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "お寺の本堂には、読経のための簡素な経机がいくつも並べられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "自宅の仏間に、コンパクトな経机を設置して、毎朝お経をあげています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "枕上に経机を据え、線香を立てた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二時が過ぎたというので、経机に燈明を上げた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "袷を着ていた私は暑さに堪えずに単衣を着て経机に向っています。",
              "citation": {
                "source": "●「或る女」巻頭のホイットマンの詩",
                "author": "\"Not till the sun excludes you, do I exclude you;",
                "note": "青空文庫"
              }
            },
            {
              "text": "（蓮月、座敷に戻り皿を経机の上へ置き、紙を一枚女らしくかける。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（蓮月、経机の上の鉢から覆い紙を除け青年の膳へ持って行ってやる。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、宝物庫には番人がいて、経蔵には、年紀の少い出家が、火の気もなしに一人｜経机に対っていた。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白布を蔽うた台に、経机を据えて、その上に黒塗の御廚子があった。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中の棚に斜っかけに乗せてあった経机ではない小机の、脚を抉って満月を透したはいいが、雲のかかったように虫蝕のあとのある、塗ったか、古びか、真黒な、引出しのないのに目を着けると……「有った、有った。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣帯正しく端然として膝に手を支いて熟ともの思いに沈んだが、借ものの経机を傍に引着けてある上から、そのむかしなにがし殿の庭にあった梅の古木で刻んだという、渠が愛玩の香合を取って、一捻して、「こんなこッちゃあ可かん。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "八畳の座敷に経机を置いて、其処で水蔭は原稿を書いた。",
              "citation": {
                "source": "紅葉山人訪問記",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は丸窓の下の経机に凭つて終日坐禅を組んでゐるだけだつた。",
              "citation": {
                "source": "天狗洞食客記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "尼の遺産――といったところで、もちろん目ぼしいものは何にもなかったが、白木の経机と、三、四冊の経文と、三、四枚の着換えとが残っていたのを、みな慶善寺に納めることになった。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "南向きの六畳の部屋、経机を前にしとねにより、書見している一人の武士、ほかならぬ袴広太郎。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、経机が飛んできた。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「善周さんのお机はどれでございます」「これでございます」と、若僧は部屋の隅にある小さい経机を指さして教えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "筆屋の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "二「祝入営」の幟の中の私は、昼となく夜となく小さな古ぼけた経机の前で、鈍重な眼を据えてゐたが、言葉に変へるべく未だ脳裏の猛々しい情熱の渦巻きが余りに生々し過ぎるのを感じた。",
              "citation": {
                "source": "ダニューヴの花嫁",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "香炉、燈明皿、燭台、花瓶、木刻金色の蓮華をはじめ、須弥壇、経机、賽銭箱などの金具が、名の知れぬ昆虫のように輝いて、その数々の仏具の間に、何かしら恐ろしい怪物、たとえば巨大な蝙蝠が、べったり羽をひろげて隠れているかのように思われ、法信の股の筋肉は、ひとりでにふるえはじめた。",
              "citation": {
                "source": "死体蝋燭",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "紳士の姿はそこにも本堂にも見えませんでしたが、禿げちよろけの老人の外套は折り畳んだまま、お鏡餅の飾つてある小さな経机の上に載せてありました。",
              "citation": {
                "source": "中宮寺の春",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ささげ持った経机、さしかけられた天蓋傘、ゆらめく瓔珞、美しくお化粧した男の子は男の子故にさらに不思議な、美しさが出ていた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、可愛らしい仏像が数体と多数の精巧な仏器が置かれており、黒檀の経机、木魚（１）、二つの立派な鈴があった――つまり、お寺さんの仏具一式を小さくしたものがみんなここに揃っているというわけである。",
              "citation": {
                "source": "死生に関するいくつかの断想",
                "author": "BITS OF LIFE AND DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "内供は、こう云う時には、鏡を箱へしまいながら、今更のようにため息をついて、不承不承にまた元の経机へ、観音経をよみに帰るのである。",
              "citation": {
                "source": "鼻",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "家に帰つて仏檀の前の経机の上に骨箱を置いた時、愈※といふ気が起つた。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は態とそこの経机の前に坐つて本を開いた。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に、水の滴るような高島田に結うたオモヨさんの死骸が、丸裸体にして仰向けに寝かしてありまして、その前に、母屋の座敷に据えてありました古い経机が置いてあります。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに横たわっている尼僧の屍体も玉幡も経机も、すべて金泥の花弁に埋もれていて、散り敷いた数百の小片からは、紫磨七宝の光明が放たれているのだ。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つの礼盤の中央には、五鈷鈴や経文を載せた経机が据えられ、右の座の端には、古渡りらしい油時計が置かれてあった。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "護摩壇前の経机には、右端に般若心経が積み重なっていて、胎龍が唱えたらしい秘密三昧即仏念誦の写本が、中央に拡げられてある。",
              "citation": {
                "source": "後光殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、その一節と云うのは、経机の上で開かれていた『五障百六十心等三重赤色妄執火』と云う一句なので、その唱句が終った刹那に、突如胎龍の頭上に赤色妄執火が下ったのだ。",
              "citation": {
                "source": "後光殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "切り燈台の火は、花のような丁字をむすびながら、明く螺鈿の経机を照らしている。",
              "citation": {
                "source": "道祖問答",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は経机の向うに白の水干の袖を掻き合せて、仔細らしく坐っている。",
              "citation": {
                "source": "道祖問答",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
