        "examples": {
          "standard": [
            {
              "text": "キニク派の哲学者は、徳と幸福を同義と考え、自然に従う生活を説いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "社会の偽善を批判し続けたキニク派の態度は、多くの人々に衝撃を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼らの多くは、公衆の面前で食事をしたり寝たりするなど、常識外れの行動を取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ストア派がキニク派から受け継いだ要素は、彼らの禁欲主義的な側面にある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
