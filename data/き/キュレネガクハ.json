        "examples": {
          "standard": [
            {
              "text": "ギリシャ哲学史において、キュレネ学派は快楽主義の一派として知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "アリスティッポスが創始したとされるキュレネ学派の思想は、後のエピクロス派にも影響を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "キュレネ学派は、刹那的な肉体的快楽を追求することを提唱した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "（c）アリストンやピュロンやストア学者たちまでが人生の目的とした・あのように単純な・徳も、またキュレネ学派やアリスティッポス流の快楽も、まじりけなしでは我々の役に立たなかった。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "（c）それにキュレネ学派の人々の説くところによれば、「それ自体正しいものは一つもないので、習慣と法律とが正義を形成するのである」し、テオドロスのともがらのいうところでは、「賢者は盗みも涜神も、もしそれが自分のためになると知れば、どのような逸楽をもみな正しいものにしてしまう」のである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "キュレネ学派の哲学者たちはこう信じている。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
