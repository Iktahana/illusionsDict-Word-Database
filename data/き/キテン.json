[
  {
    "uuid": "cf124e88-ae4c-56e0-b3fc-e4065e9e1bc1",
    "entry": "基点",
    "reading": {
      "primary": "きてん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
