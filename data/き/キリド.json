    "definitions": [
      {
        "index": 1,
        "gloss": "low gate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "謎の矢場主英膳が、あの重籐の弓構えとって、突如矢場の切り戸わきに仁王立ちとなると、天にもひびけとばかり呼ばわりました。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから又、私はすこし大きくなりますと、身体の疵を人に見られるのが恥かしくてたまらないようになりましたので、ソッと奥様にお願いしまして、わざと夜中過ぎに、奥のお湯に入れていただいておったので御座いますが、或る冬の夜のこと、切り戸の外で、「見えようが……」「ウン。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その横の切り戸を開いて、又、横路地のような処をすこし行くと、長屋式の板壁の途中に小格子がたった一つあった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お増の宿は、その番地の差配をしている家の奥の方の離房で、黒板塀の切り戸を押すと、狭い庭からその縁側へ上るようになっている。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "お庄はその切り戸の節穴から、そっと裏を覗いてみると、離房の方の板戸は、ぴったり締っていて、中に人気もしなかった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝床を離れて手洗をすますと、お庄は急いで、お増の宿まで行って見たが、切り戸はまだ締っていた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "お庄は夜になると、よく一人で家を脱け出して、お増の部屋の切り戸の外に立ち尽していた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "白樺の粗末な板塀についた切り戸から入るようになっている。",
              "citation": {
                "source": "モスクワ日記から",
                "author": "――新しい社会の母――",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、次の朝、無銭飲食で二十日つけられている髪の毛ののびた雑役が、鉄扉の小さい切り戸から弁当を入れてくれながら、「犬養がやられた」と云って去った。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の覗いたのは、切り戸口といふやうな処だつたのだらう。",
              "citation": {
                "source": "戞々たり　車上の優人",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時正面の切り戸から悠然と立ち出でた小兵の人物、年格好は五十五、六、木綿の紋付に黄平の袴、左手に一刀を引っさげてスッスッと刻み足に進んで来る。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが何かの合図と見えて、そこの切り戸がスーと開いた。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んとも云われない芳香が、切り戸口から匂ってきた。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　女がコツコツと戸を叩くと、内側へスーと切り戸があいた。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ横手の露路へ出られる、切り戸口の傍らに立っている、満開の桜の下枝から、花が散っているばかりであった。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "切り戸が内側からあけられたのらしい。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、その切り戸から黒い物体が、無造作に塀の外へ転がし出されたが、またすぐに切り戸は閉ざされてしまった。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪異連続　塀の切り戸から転がし出された、若い男の死骸なるものを、山県紋也が小腰をかがめて、調べてみようとした時に、数人の足音が聞こえて来た。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一瞥しただけであったけれど、切り戸から地上へ転がし出された、若い男の死骸が異様なものであったことが、紋也の眼には焼きついていた。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "塀の切り戸から死骸の出るのを、待ち設けていて運んで行ったようだ。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「印籠をすった女煙術師、煙術師のはいり込んだりっぱな屋敷、その女煙術師の変った問答、幽鬼的の駕籠の行列、その駕籠の中の芳香を持った女、……そうして陰森としたこの小家、切り戸から出た若者の死骸、その死骸の異様な死相、死骸を運んで行った覆面の武士たち。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「豪奢をきわめた女乗り物、その中にいた芳香を持った女、乗り物を取り巻いていた男女の供人、そうして裏塀の切り戸口から、転がし出された若い男の死骸、その男の死骸を運んで行った、覆面をした数人の武士。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その家の黒塀の切り戸が開いて、そこから若い男の死骸が空地の草の上へ抛り出されて、すぐに切り戸が閉ざされたのである。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "代官松としては知らなかったのであるが、これで二人の男の死骸が、切り戸から空地へ出されたのであった。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても満知姫の犠牲になって、絶息するまでに衰弱をしたいろいろの人間をこの空家の、塀の切り戸から運び去った、武士たちはそもそも何者なのであろう。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まずよかった」と呟くと、切り戸口をトンと押した。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "切り戸口を出ると一丁の駕籠。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またひとしきりどかどかと続いて来るかと思うとまたぱったり途絶えるのである。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は畏って聞き果てると、膝に手をついたッきりどうしても顔を上げてそこな男女を見ることが出来ぬ、何か胸がキヤキヤして、はらはらと落涙した。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それきりどうしても再び出ようとは言わなかったのを、私が留学から帰った時に無理にすすめて出る事にはなったが、それでもやはり学校は欠席がちであった。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
