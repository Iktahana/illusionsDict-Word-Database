[
  {
    "uuid": "2d74e81c-851f-5f06-a411-befaa76cf52d",
    "entry": "気分",
    "reading": {
      "primary": "きぶん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
