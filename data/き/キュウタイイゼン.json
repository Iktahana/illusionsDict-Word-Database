[
  {
    "uuid": "deb71c4c-00b0-5fc5-a98b-1e924c379585",
    "entry": "旧態依然",
    "reading": {
      "primary": "きゅうたいいぜん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
