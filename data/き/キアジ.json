    "definitions": [
      {
        "index": 1,
        "gloss": "market sentiment (stock market)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
