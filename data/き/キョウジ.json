    "definitions": [
      {
        "index": 1,
        "gloss": "securing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いまからでかけてきょうじゅうに帰ってこられるかしらなどと考える。",
              "citation": {
                "source": "河口湖",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これはせっかくのご出陣ですが、じつはそのちょっと東京へいってくるつもりで……はなはだ残念だが……」「いやそりゃ残念ですな、日帰りですか」「今夜は帰れません」「それじゃきょうじゅうに東京へいけばえい。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年ぶりであいつらがまた江戸へ流れ込んだきのうきょうじゃねえかよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしても、きょうじゃあだめかね？",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きょうじゅうには、むりでございますよ」「あすになるか？",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "６から２までの数字があらわれたきりで、１という数字はまだなんだから、あいつは、それをどこかへ書くために、きょうじゅうに、きっと、しのびこんでくるよ。",
              "citation": {
                "source": "塔上の奇術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
