        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "金庫破りもやめて、堅気で生きろ。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで金庫破りなんて一度もやったことないってば。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケースを開けて、東部最高ともいわれる金庫破り道具一式をほれぼれと見つめた。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴァレンタイン九七六二番が釈放されてから一週間後のこと、見事な金庫破りがインディアナ州リッチモンドであった。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "事件の報告書を見比べてみると、その金庫破りの手口に、強い類似性が認められた。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベン・プライスがこの逃げ回る金庫破りの足跡を追っていると公表されると、盗難防止用金庫を持っている人々もほっとすることができた。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "十分後、ジミィは今までの金庫破りの自己記録を破る早さで、かんぬきを後ろに投げ捨て、扉を完全に開けていた。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏啼は金庫破りの三名人の豹太、沙朗、八万に命じて、この仕事に掛からせた。",
              "citation": {
                "source": "烏啼天駆シリーズ・４　暗号の役割",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の金庫破りの名人たちも、ばたばたばたと倒れてしまった。",
              "citation": {
                "source": "烏啼天駆シリーズ・４　暗号の役割",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いにして金庫破りにかけてはチーア卿は非凡なる技倆を持っている。",
              "citation": {
                "source": "共軛回転弾",
                "author": "――金博士シリーズ・11――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラザフォード（英人）は、快速アルファ粒子を彈丸として金庫破りを試みたが、輕い元素からは水素原子が出て來た驗しがある。",
              "citation": {
                "source": "物理學革新の一つの尖端",
                "author": "長岡半太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お上さんは笑い出して、同じく食卓についていた客人に向って、「何方もアムと言っている積りよ」鑵切難　金庫破り専門の泥棒が一仕事して帰って来た。",
              "citation": {
                "source": "英米笑話秀逸",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "金庫破りの名人が持っている様な万能鍵束、小型だけれど倍率の大きい虫眼鏡、黒い絹糸を縒り合せて作った一握り程の繩梯子、鋸のついた万能ナイフ、指紋検出の用具、手の平に入るライカ写真器、注射器、数個の薬品の小瓶｜等、等、等。",
              "citation": {
                "source": "妖虫",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
