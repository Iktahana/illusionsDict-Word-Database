          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "罪のない人々を盾にするなんて、奴のやり方は鬼畜の所業としか思えない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "戦場では人間が鬼畜に変わる瞬間があるという話を、かつて祖父から聞いたことがあって忘れられない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "恩師を裏切って私腹を肥やすような鬼畜な振る舞いは、どんな言い訳をしても許されない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "（青年の血相が変り鬼畜の形になって蓮月に飛びかかる。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）神職　鬼畜、人外、沙汰の限りの所業をいたす。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも先ず、その、世に浅ましい、鬼畜のありさまを見しょう。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）媛神　邪な神のすることを御覧――いま目のあたりに、悪魔、鬼畜と罵らるる、恋の怨の呪詛の届く験を見せよう。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく報告書で御覽の通り殺害の手口は鬼畜に類してゐます。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "外海小湖に泥土の鬼畜、怯弱の微輩。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方には穢土穢物を嫌ひたまはざる仏の慈悲に似たるものあり、他方には餓鬼畜生の慾情と戦へる霊妙なる人類としての純潔あり。",
              "citation": {
                "source": "処女の純潔を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "心は現世の鬼畜、悪魔、外道に弥増るやらむ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて其｜後、程もなく初花楼の初花太夫が稲佐の浜にて磔刑になるとの噂、高まりければ、流石の鬼畜の道に陥りたるわれも、余りの事に心動きつ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "住持はその額に鬼畜変体即成仏という七字を書き、首に血脈袋と珠数をかけて新らしい棺桶に入れさした。",
              "citation": {
                "source": "山姑の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なかなか、幽冥に通じて、餓鬼畜生まで耳を傾けて微妙の音楽を聞くという音調だ、妙なことがあるものでございますな、そして、やはりお心持は。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女のなかにもいかさまばくちの不了見者はたまにいるかもしれねえが、かわいい孫を三人もひねり殺すような鬼畜生は、そうたんとねえよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな鬼畜生は、それがあたりまえでござんす！",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "山野の荒涼とした風景よりも、垂直になった石壁の蕭条たる様の方が、人間に鬼畜の心を養うものだ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に、幾多の革命的闘士が日本警察・監獄・憲兵の鬼畜の如き暴力によって、虐殺され、不具にされた。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお蔭で全く僧侶達はマルクス主義の世界観としての科学的意味を知る代りに、「売国的邪宗門としてのマルキシズムの鬼畜的思想運動」を折伏しようと思うことも出来るし、又もう少し賢明な場合にはマルクス主義を華厳教や空観に帰着せしめたりすることも出来る。",
              "citation": {
                "source": "範疇の発生学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴木文史朗の「何千万を殺す」という「理想的なやりかた」論はこれら数十万人の人々の心に、鬼畜の言という感銘を与えた。",
              "citation": {
                "source": "鬼畜の言葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まるで餓鬼畜生だ。",
              "citation": {
                "source": "放浪の宿",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「悪人と云っても鬼畜ではない。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやいや人間であろうとも乃至は鬼畜であろうとも相手としては、同じ事じゃ！",
              "citation": {
                "source": "高島異誌",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一切の穢濁を断じて聖浄の楽土に住む得道出家の身にてありながら、徒にただ肉を追う餓鬼畜生の類なのだ。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きては地獄の転変に堕在し、叫喚鬼畜の相を現し、死しては悪果を子孫に伝へて業報永劫の苛責に狂はしむ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "村次郎と久米八は、明白に双生児であり、二人はそうとは知らず、直助とお袖が堕ち込んだ、鬼畜の道を辿りつつあるのだ。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ先生、やはりあの鬼畜は、わっしだったのですよ。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼畜、頑是ない五歳の子まで殺さんでもいいだろう。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれを遠島に処すなど、鬼畜の業ではないか」「あれとは、奥をか」「いいや、左太郎を――」「子供を――」　出雲守は、そう云ったまま、黙ってしまった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼畜の如き心をもっている）　そう久光を、非難する一方、深雪のことを考え、一家のこと、父のこと、母のこと――小太郎は、静かに、刀を差出して「同道致そう」　と、いった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "美女には、得てしてああいう惨忍な、鬼畜がおる。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いてしらん、ぎしぎし、たちあおい、かわほね、のいばら、つきみそう、てっせん、かなめ、せきちくなどが咲き、裏の畑の桐の花は高く薫った。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "人ごこちがなくなっていても、生きているとおりの顔いろをしていて、ほおは、せきちく色をしていましたし、くちびるは、さんごをならべたようでした。",
              "citation": {
                "source": "眠る森のお姫さま",
                "author": "ペロー　Perrault",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
