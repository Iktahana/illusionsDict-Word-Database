        "examples": {
          "standard": [
            {
              "text": "総理の定例会見は、記者クラブを通じて各社に通知される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は長年、首相官邸の記者クラブに所属しているベテラン記者だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "記者クラブの自主規制については、以前から様々な議論がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい情報公開制度の導入で、記者クラブの役割も変化しそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "新聞記者になれるのだと喜んでいたのに、自転車であちこちの記者クラブへ原稿を取りに走るだけの芸だった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も粗末な観念としての「戦争ジャーナリスト」の内、手近かにあるものは、陸海軍省記者クラブ式なジャーナリストである。",
              "citation": {
                "source": "戦争ジャーナリスト論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃の官庁の記者クラブの記者は大体に於て官庁自身の発表をば掲示を待つようにして待っていなくてはならぬのではないだろうか。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あははは、そんな妙な顔をするな」　そう言ったのは、海軍省の記者クラブで、懇意になった国民新聞のＦ君である。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒川記者も、警視庁の記者クラブにつめきって、たえず捜査本部に顔をだしていました。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮内庁では、門を入るといちめんまっ平らなコンクリート敷きになっていて、宮内庁記者クラブの建物の手前、警備の警官が詰めている建物まで、Ｓ字カーブを半分にしたようなラインが引いてある。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "国会記者クラブと会社の政治部デスクを、一日に何度も、往復しなければならない。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
