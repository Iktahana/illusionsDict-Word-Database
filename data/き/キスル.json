  {
    "uuid": "bbb054eb-5bd4-51de-aa21-62912ea1362d",
    "entry": "記する",
    "reading": {
      "primary": "きする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-特殊",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to write down",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旅先で感じた心の機微を、忘れないうちに手帳に記しておく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その古い石碑には、かつてこの地を治めた英雄の功績が記されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「氏名と住所をこちらの用紙に記して、受付に提出してください。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "大宮方面の案内者は、深沢弥作といって、親切な男であったことを附記する。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に言語などを機械的に暗記する事の下手な彼には当時の軍隊式な詰め込み教育は工合が悪かった。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "主に口授を筆記するのであったが、たまたま何かの教材の参考資料として、英国製で綺麗な彩色絵の上に仮漆を引いた掛図を持出し、その中のある図について説明をした。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（詳記するを許されませんがこの六ヶ月はコタエマシタ）　近く病院が移動するらしいですから、その時また、お便りします。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ不正を企るのならば、百三十六｜個の麻雀牌の背中の竹の木目を暗記するなどは、その努力感だけでも僕には寧ろ氣持がいい。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "事の顛末を記録するためには先ずわが家のラジオの歴史を略記する必要がある。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙台堀と油堀とを連ぬる小渠は一条のみならず、また木場附近の大和橋及び鶴歩橋の架れる一渠その他の小渠は、一これを記する能はざればなり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "荼枳尼天の形相、真言等をここに記するも益無きことであるし、かつまた自分が飯綱二十法を心得ているわけでもないから、飯綱修法に関することは書かぬが、やはり他の天部夜叉部等の修法の如くに、相伝を得て、次第により如法に修するものであろう。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしとにかくそういう種類の考えも、少なくも一つのヒントとしては役立つであろうと思うので、不謹慎のそしりを覚悟してついでに付記する次第である。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも一つのヒントにはなりうると思うからついでに付記する。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらもすべて大胆すぎた想像であるが一つの暗示として付記する。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが毎日同じ事を繰り返している間にあらゆる興味は蒸発してしまって、すっかり口上を暗記するころには、品物自身はもう頭の中から消えてなくなる。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "余輩は区々たる一二｜鼠輩を相手に論議する事を好まずと雖も、陋劣なる平凡主義者の実例として更に些か記する処なき能はず。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上が画工エリックの物語で、同雑誌記者の附記する所によれば、彼の画工の筆に成った恐しき婦人の絵姿は此のほど全く出来したが、何さま一種云われぬ物凄い恐しい顔である、婦人の如き、其の図を一目見るや忽ちに魘えて顫えて、其後一週間ほどは病床に倒れたという。",
              "citation": {
                "source": "画工と幽霊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで、いざこざの起らぬよう、それだけを附記する。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこにその美しい音樂があるか、我等は之れを分析的に明記することができない。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それら恥ずかしき身なりの植物たちが小声で囁き、私はそれを速記する。",
              "citation": {
                "source": "失敗園",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水品の美、真に赤松氏利根川図志の記するところの如し。",
              "citation": {
                "source": "水",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "定命録、続定命録、前定録、感定録等、小説｜野乗の記するところを見れば、吉凶禍福は、皆定数ありて飲啄笑哭も、悉く天意に因るかと疑わる。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕王の兵を起したる建文元年七月より、恵帝の国を遜りたる建文四年六月までは、烽烟剣光の史にして、今一々｜之を記するに懶し。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "女仙外史に、忠臣等名山幽谷に帝を索むるを記する、有るが如く無きが如く、実の如く虚の如く、縹渺有趣の文を為す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "永楽亭楡木川の崩を記する、鬼母の一剣を受くとなし、又｜野史を引いて、永楽帝｜楡木川に至る、野獣の突至するに遇い、之を搏す、攫されてたゞ半躯を剰すのみ、※して而して匠を殺す、其迹を泯滅する所以なりと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は蒲生方の記するところに拠って述べたので、伊達方には勿論毒を飼うたなどという記事の有ろうようは無い。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "して見れば将門始末の記するが如きことは先づ起りさうもない。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "（その時代の空気を示す為めに一寸追記する。",
              "citation": {
                "source": "パンの会の回想",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "左は言へど敢て在来の詩人を責むるにもあらず、又た自己の愛するところを言はんとにもあらず、唯だ我が秋に対する感の一として記するのみ。",
              "citation": {
                "source": "秋窓雑記",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "此二書に就き世評既に定まれるにも拘らず、余は聊余が読来り読去る間に念頭に浮びし感を記する事となしぬ。",
              "citation": {
                "source": "「伽羅枕」及び「新葉末集」",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "此墓の落葉むかしの小判哉　　永機　香以去後に凋落して行く遊仲間のさまを示さむがために、此に二三の人の歿年を列記する。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは魯文の記する所に従って、「絶筆、おのれにもあきての上か破芭蕉」の句を挙げて置いた。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "案外、長生きするのではないか。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to remember",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
