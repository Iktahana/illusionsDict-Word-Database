[
  {
    "uuid": "0d01b38c-f129-5573-b244-9b0e43cf076d",
    "entry": "共通感覚",
    "reading": {
      "primary": "きょうつうかんかく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
