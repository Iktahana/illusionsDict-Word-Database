    },
    "definitions": [
      {
        "index": 1,
        "gloss": "huge sum (esp. of money)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「満蒙の特殊利益は、日本が高価なる犠牲を払い、巨額の資金を投下して開拓したるものである。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本は過去十余年間、巨額の資本と高貴なる犠牲（日独戦争）を払いて、山東の資源を開発し、現に邦人の投資額約一億五千万円に達する。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此打合せが終ると、大佐の命令で、輕氣球は海岸の砂上に引出され、水素瓦斯は充分に滿たされ、數日分の食料と、飮料水と、藥品の買入れや、船舶の雇入れの爲めに費す可き、巨額の金銀貨の積込みも終ると、私と武村兵曹とは身輕に旅裝を整へて搖籃の中へと乘込んだ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより巨額の公債を有し、衣食に事欠かざれば、花車風流に日を送りて、何の不足もあらざる身なるに、月の如くその顔は一片の雲に蔽われて晴るることなし。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨額の負債の嵩みしためなり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "して見れば秀吉は宜いけれど、氏郷は巨額の年俸を与えられたとは云え極々短期の間に其年俸を受取れるか何様か分らぬ危険に遭遇すべき地に置かれたのだ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この賭博法は千フラン以上どれ程巨額な相手にでも親になり賭を引受ける。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蔭で思いがけない巨額の金が、二人の懐に転がり込んだので二人は少なからず面喰った。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その袋の中よりは、十万｜磅に近き価格のあるアメリカの鉄道の社債やその他巨額の、炭鉱あるいは諸会社の株券などが発見せられたり。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなく大胆な強盗が行われたことが判明、一〇万ポンド相当の価値がある米国鉄道社債を初め、炭坑や諸会社の巨額証券が鞄のなかから見つかった。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は毎年冬からまだ草木の萌え出さぬ春までの内に彼等にしては驚くべき巨額の四五十｜圓を贏ち得るのであつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "千、二千、三千、五千、乃至一万の巨額をも容易に支出する大資本主たるを以て、高利貸の大口を引受くる輩のここに便らんとせざるはあらず。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを三百六十五日の一年に合計すれば、金弐千壱百〇弐円四拾銭の巨額に上るにあらずや。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いのほか巨額の為替をちょいちょい送ってよこして、倉地氏に支払うべき金額の全体を知らせてくれたら、どう工面しても必ず送付するから、一日も早く倉地氏の保護から独立して世評の誤謬を実行的に訂正し、あわせて自分に対する葉子の真情を証明してほしいなどといってよこした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、三万を越している巨額の金が、現在の父に依って容易に、才覚さるべき筈もなかった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、父の手文庫の中に奇蹟のように見出された、三万円以上の、巨額な紙幣に対する、瑠璃子の心の新しい不安は、日の経つに連れても、容易には薄れて行かなかった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪冬の陣と共に豊家はあの通り悲しい没落を遂げて、世に大阪城の竹流し分銅と称されてやかましかった軍用金のうち、手づかずにまるまる徳川家の手中に帰したのは、実に六百万両という巨額でした。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "遂にこの訴訟は従男爵コンラド氏の敗訴となり、アリナの霊と、従男爵の血によりて生まれたる孩児の扶助料、及び、その実父に対する慰藉料として巨額の財産を分与して結着を見たりとなり。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "跡始末には巨額の費用を要する仕事であるから、去年の休戦以来、半年以上の時間をあだに過して、いたずらに雨や風や日光のもとにその惨状を晒しているのであろう。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "跡始末には巨額の費用を要する仕事であるから、去年の休戦以来半年以上の時間をあだに過して、いたずらに雨や風や日光の下にその惨状を晒しているのであろう。",
              "citation": {
                "source": "ランス紀行",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、適当な手段が見つかったとしても、巨額の対抗兵器と危険多き多数の兵員を要することだろう。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口のない部屋で、白昼のうちに巨額の金が盗まれたり、人が殺されたりしている」「その番人は、どんな風に殺されているんでしょ」「胸から腹へかけて、長く続いた細いメスの跡がある、それが変な風に灼けている。",
              "citation": {
                "source": "俘囚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、三万を越してゐる巨額の金が、現在の父に依つて容易に、才覚さるべき筈もなかつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、父の手文庫の中に奇蹟のやうに見出された、三万円以上の、巨額な紙幣に対する、瑠璃子の心の新しい不安は、日の経つに連れても、容易には薄れて行かなかつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "樽野は隅の方で稀に見るのであつたが、実父も舅も彼等と同じ位置、気位ひで同じやうに反り身になつて美妓に煽がれながら、口にする金額は悉く万円、千万円といふ巨額を棒片のやうに振り回しながら諸々の手配りに余念がなかつた。",
              "citation": {
                "source": "円卓子での話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨額の財産を相続したのを修学のための旅行に使用した。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日軍艦を購い大砲を購い巨額の金を外国に出すも畢竟日本国を固むるにほかならず、されば僅少の金額にて購い得べき外国の文学思想などは続々輸入して日本文学の城壁を固めたく存候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に私は家宅捜査をさせて頂いて、振動魔の貴方が、計算せられた紙ぎれや、また柿丘氏には不合格になったと思わせた生命保険に、貴方が莫大な保険金を契約して、柿丘氏を殺したあとで巨額の死亡支払金を詐取したその証拠書類やらを発見させて頂きたいんです。",
              "citation": {
                "source": "振動魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
