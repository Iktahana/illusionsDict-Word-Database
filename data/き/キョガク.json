[
  {
    "uuid": "aeb97abc-87a2-57b0-9e94-2c7142313655",
    "entry": "巨額",
    "reading": {
      "primary": "きょがく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
