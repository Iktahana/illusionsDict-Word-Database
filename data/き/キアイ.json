[
  {
    "uuid": "428ab8ad-26dc-573c-9afe-cc30302e73aa",
    "entry": "気合",
    "reading": {
      "primary": "きあい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(fighting) spirit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "時には僕が余り俄に改まったのを可笑しがって笑えば、民子も遂には袖で笑いを隠して逃げてしまうという風で、とにかく一重の垣が二人の間に結ばれた様な気合になった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の肥ったせいの高い兵士は、青竜刀を肩からはずして、空間に気合をかけて斬る練習のようなことをやっていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "正木の気合の談を考えて、それが如何なるものかを猜することが出来る。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "慢心や笑容を去つて、粛然たる気合になれば、悪いことは生ずべきで無い。",
              "citation": {
                "source": "震は亨る",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしているうちに潮のさして来るように次第に興が乗り、次第次第に気合いがかかって来るのが、見ていてもおもしろいものである。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにあの森の奥の方角で、何とも知れぬ気合いの声がタッタ一声「エイッ」と聞こえただけで、アトは又森閑としてしもうたけに、不思議な事と思うてソロソロ起上って、あの墓所まで来てみると、思いもかけぬ無残い姿の仏様じゃ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜間金太郎氏の演出なぞは素人眼にはスゴミが横溢しているようであるが、よく見ているとそのスゴ味は金春一流の意識的な気合い（アテ気と言っては過ぎる）から生まれたものであることが次第次第にわかって来る。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして耳のそばで呼吸の気合がする。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "復一はもう伏目勝になって、気合い負けを感じ、寂しく孤独の殻の中に引込まねばならなかった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから自分が五十九歳、妻が五十一歳の寛政四年にまづ妻の母親が死に、すぐ自分の養母が死にして、何だか気合ひ抜けしたやうな形になつた妻のお玉が、髪をおろして尼の態になり度いと申出たときに、早速それを許したのだつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　気合が更まると、畳もかっと広くなって、向合い、隣同士、ばらばらと開けて、間が隔るように思われるので、なおひしひしと額を寄せる。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "之は、書くぞ、書くぞという気合と気魄の小説である。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　京吉はパイをツモる時に、気合を掛けるようなことはめったにしなかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "自信がなければ、気合は掛けなかったのだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "追い込んで、抜く自信がある時だけ、ゴール直前で使う名騎手の鞭のような気合であった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、おかしげな気合を掛けたり、しまいには数珠を揉んで、「――南無妙法蓮華経！",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで思ふのに、文庫版『雲母集』の後記にも書いたごとく、二十年後の今日のより進んだ心境と手法とを以てして、たとひ巧慧に改め得たとしてもそれが果して真に当時の気合なり歌風なりを生かし得るであらうかである。",
              "citation": {
                "source": "文庫版『雀の卵』覚書",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「気合いひとつですからね。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その頃の囚人の気合は今と違うておったように思うなあ」　と嘗て奈良原翁は酒を飲み飲み筆者に述懐した。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "武道、その他の勝負等の場合には、相手の調子によって気合いが抜ける場合がないとも限らないが、能の仕舞の如きは、体力、芸力の気合いが寸分の隙間もなく続いて行かねばならぬ。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その気合いを抜いて上手に舞おうと心掛けるのは負けて逃げるのと同じこと。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "血気盛んな利彦氏が渾身の気合いをかけて前進し、非常な勢いで身をかわして踏み止まろうとするが、止まれない。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の気合いが途中で抜けちゃ詰まらん。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にそんな婦人の中でも、日本人の男性でも掌の痛さと、気合いの烈しさに辟易する大鼓を引き受けている人が居ると聞くに到っては、感心を通り越して瞠若の到りである。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならずその合唱隊や囃子方の揃った服装や、気合い揃った動きは、気分的に厳粛な背景を作って、演舞者の所作があらわす気分を、弥が上にも引っ立てて行く。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇者の鼻は鉄壁をも貫く気合を見せております。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供のやる気合ゲームで、相手がグウを出せと云ったら、それに誘われないように、チョキかパッを出さねばならない。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、別のジャンケン遊びを始めたが、これも美和子は、可愛いかけ声に拘らず、どこか気合がすぐれていて、相手の気を釣って、巧みに勝ってしまった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "気合をかけると己の脈がとまるよ、仰向いて胸を反らして力を入れると、肋骨がばらばらになるそうだ。",
              "citation": {
                "source": "仙術修業",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所への人づきあいもせずに、夜遅くまで書物をしていた蕪村。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
