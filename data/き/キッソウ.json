[
  {
    "uuid": "998ec424-fc76-5dcf-b910-60577a5a30fb",
    "entry": "吉相",
    "reading": {
      "primary": "きっそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
