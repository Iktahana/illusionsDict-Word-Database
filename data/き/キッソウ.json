    },
    "definitions": [
      {
        "index": 1,
        "gloss": "auspicious appearance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔から吉相の家は栄えると言われているので、引っ越しの際はよく調べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "風水に詳しい友人に言わせると、この家は吉相の玄関だから運気が上がるそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "代々受け継がれる家宝の壺は、その形から吉相とされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は面長で目鼻立ちがはっきりしており、人から吉相だと褒められることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "途中で自然からこの蓋が取れて手が切れるなんざ、おっと禁句、」とこの際、障子の内へ聞かせたさに、捨吉相方なしの台辞あり。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "古ギリシアやインドの創世紀は金の卵に始まり、世界は金の卵より動き始め、動くは善の原則たり、光明あり労働し利世する日は金の卵に生ず、故に一日の始めに卵を食うは吉相で、ラテン語の諺にアブ・オヴォ・アド・マルム（善より悪へ）というはもと卵より林檎への義だ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おけらの唄」の栄えるのは、福徳円満を祈る吉相である。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「吉相にござります。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "四真相応大吉相の図説に、寸分隙無く叶っている。",
              "citation": {
                "source": "天主閣の音",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……土金相兼という吉相だ。",
              "citation": {
                "source": "鵞湖仙人",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長生きをする吉相もあるが、恋愛をすれば必ず苦労する相をも併せ持っている。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その八　安吾愛妻物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "長生きの吉相があるとは有りがたいが、恋愛すれば必ず苦労する相も併せ持っているとは、いささか手きびしいな。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その八　安吾愛妻物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "屡々云ふが「真景累ヶ淵」の中のお久新吉相愛の二人が、始めてカップルで歩く夜の、いかにもウブそのものな新吉の会話の巧さは、かいなでの小説家では到底描けない。",
              "citation": {
                "source": "寄席風流",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "奎堂　さすがは太守のお腰の物、領民鼓腹、お家万代のはなはだ吉相、上々吉と観相つかまつりまする。",
              "citation": {
                "source": "稲生播磨守",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "左陸奥守――いたって吉相。",
              "citation": {
                "source": "稲生播磨守",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "奎堂　（虚ろな声で）これは吉相――。",
              "citation": {
                "source": "稲生播磨守",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "帯びる者の心で、凶相にも吉相にもなるのですっ。",
              "citation": {
                "source": "稲生播磨守",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "（追い縋って留める）郁之進　（争って）いえ、この多門三郎景光、はたして凶相か吉相か、久保奎堂の身体に問うてみるのですっ！",
              "citation": {
                "source": "稲生播磨守",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "その溝深きを吉相とす。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに参考のために、ある随筆に出でたる家相心得を示さば、「家相を正すというは、夏すずしく冬暖かに、奥より勝手向きの便利をよくし、盗賊、火災の防ぎ方を設け、低地の所は出水の手当ていたし、小破れを繕い、火の用心を大切にして住む家を、すなわち吉相の家とす」とあるは、おもしろき説明である。",
              "citation": {
                "source": "迷信解",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "その由来は、第一世ナポレオンが、この吉相をもって生まれてきたりしより起こった迷信であると伝えている。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "東洋は家相の吉凶をたずね、吉相を見てこれに住するけれども、家も国も、ともに貧弱なるはいかん」と詰問したれば、家相家が申すには、「わが国内にても、家相に頓着せざる人にてその家の栄ゆるところがある。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる家について取り調べてみるに、知らずして自然に家相の道理にかない、吉相を得ておる。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえに、西洋にても家相を知らずして、自然に吉相を得ておる家が多いに相違なかろう」との答えであった。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士に取っては、誉れの吉相」「何んと言われる、敵討たれ？",
              "citation": {
                "source": "大江戸黄金狂",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
