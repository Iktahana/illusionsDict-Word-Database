          "literary": [
            {
              "text": "そして二、三度高等学校の競争試験に応じて、かなり苦い経験を嘗めた。",
              "citation": {
                "source": "「古琉球」自序",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "五六年前、私が女学校に入ろうとする頃には、激しいと云っても、今ほど競争試験は激烈なものではなかったらしい。",
              "citation": {
                "source": "入学試験前後",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが内申制は競争試験よりも教師と両親と子供たちを腐敗させた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたリセ（官立高等中学）の競争試験で一等賞をおとりになったって。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな頭では競争試験のある小学校へ入れるかどうかと心配して、試験から帰つて来たのをつかまえて、「どうした。",
              "citation": {
                "source": "愉快な教室",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "競争試験が行われバリヴィは13人の候補者のうちの最高であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "教授の任命はフランスと同じように競争試験によって行われるべきであった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "競争試験となると刎頸の友も当てにならない。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "競争試験だから、他の不成績は自分の好成績と同じような願わしい効果を生じる。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
