    "definitions": [
      {
        "index": 1,
        "gloss": "kiss",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "多分僕の性格中にあるニヒリスチツクの傾向や、多分にアナアキスチツクの氣質やに、別の意味の關心を持つたのだらう。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は常識的な人物でありながら、どこにか驚くべく超常識的な、アナアキスチックの本能感をかくしてゐる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに自分が、アナアキスチックの自由に憧憬してゐるか。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本質的な氣質に於ては、むしろ遙かに私（筆者）以上のアナアキストであること。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その評論で、彼は私を代表的な詩人的アナアキストだと評してゐる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "弱者の糧太宰治-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）猛っている：入力者注　主に外字の説明や、傍点の位置の指定（例）「映画でも見ようか。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長三代太宰治-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）捧げ銃をして。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春昼太宰治-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）工合い-------------------------------------------------------　四月十一日。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私信太宰治-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）就いて、-------------------------------------------------------　叔母さん。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といふキスヰ声がした。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "転向したマルキストは、翻訳の不可能を知つたのである。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "燧の鉄と石の触れあう音、迸る火花、ホクチの燃えるかすかな囁き、附け木の燃えつくときの蒼白な焔の色と亜硫酸の臭気、こうした感覚のコムプレッキスには祖先幾百年の夢と詩が結び付いていたような気がする。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山羊の歌中原中也-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）吁！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸の如くに降りしきる雨の中にたたずんで、モミや落葉松の美しい木立に見とれる、この辺から、裾野式の高原を展開して、桔梗がさき、萩がさき、女郎花がひょろひょろと露けく、キスゲが洞燈のような、明かる味をさしている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "運動会の風景葉山嘉樹-------------------------------------------------------【テキスト中に現れる記号について】：入力者注　主に外字の説明や、傍点の位置の指定（例）増産競技であった。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "セメント樽の中の手紙葉山嘉樹-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）蔽われていた。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央アジア東トルキスタン辺の歌謡を見ると勿論色々な型式があるが、中には八、五、八、五の型式がある。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それぞれのエキスパートが品物の産地を云ひ當てるやうに、此の男には矢張り特別な眼識が具はつて居るかと思はれた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "震災日記より寺田寅彦-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）子供等と志村の家へ行った。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子どもらばかりボートの中へはなしてやってお母さんが狂気のやうにキスを送りお父さんがかなしいのをじっとこらえてまっすぐに立ってゐるなどとてももう腸もちぎれるやうでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷と後光宮澤賢治-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）苹果-------------------------------------------------------「ええ。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いき」の構造九鬼周造-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）畢竟｜：ルビの付いていない漢字とルビの付く漢字の境の記号（例）一見｜相容れない：入力者注。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いき」の構造九鬼周造-------------------------------------------------------【テキスト中に現れる記号について】：入力者注。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "また「方則」はつまりあらゆる言語を煎じ詰めたエキスであると云われる。",
              "citation": {
                "source": "言語と道具",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀬戸内海の潮と潮流寺田寅彦-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）沢山あります。",
              "citation": {
                "source": "瀬戸内海の潮と潮流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この会のエキスペジションで彼はインディアンの国土を見舞い、シカゴで始めて電車を見、またマイケルソンやローランドと親しく言葉を交わし、またエジソンの有名な昼寝を驚かした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "テンポにもエキスプレションにも少なくも理論的には相当な振幅はあった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またエッキス線で照らして皮膚や血液の病を癒す事も往々あるが、しかしこの線のために癌腫を生じた例があるから注意を要するとの事。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の新しい文壇は、小説に、戲曲に、評論に、明治以來すべて西洋のそれを模倣し、飜案輸入することに勉めたけれども、その中最も根本のものは詩であつて、これに西洋文藝のエキスされた一切の精神があるのだから、詩の飜案と輸入の完全にされない限りは、日本に眞の西洋思潮は移植されないわけである。",
              "citation": {
                "source": "詩に告別した室生犀星君へ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
