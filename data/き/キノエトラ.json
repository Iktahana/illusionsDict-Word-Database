        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "寛政六甲寅十二月日――（小作中一度載之。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六日、甲寅、晴、将軍家御出昨の如し、流鏑馬殊に之を結構せらる。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "安政元年甲寅、八歳。",
              "citation": {
                "source": "能久親王年譜",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "と記して傍に、寛政六年｜甲寅十二月　日とある石の記念碑である。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二には「至善院格誠日在、寛保二年｜壬戌七月二日」と一行に彫り、それと並べて「終事院菊晩日栄、嘉永七年｜甲寅三月十日」と彫ってある。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛政六年甲寅の中秋に、七絶三首があつて、引に「中秋与六如上人、蠣崎公子、伴蒿蹊、橘恵風、大原雲卿、同泛舟椋湖」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　以上記し畢つた後、寛政甲寅の遊には猶二人の同行者があつたことを知り得た。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此年乙未より安政紀元の甲寅に至る間は二十年である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "胎内の子は次年甲寅の初に生るべき棠軒の女長である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "外交はペリの米艦隊の去つた後、プウチヤチイヌの露艦隊が癸丑七月十八日を以て長崎に入り、次でペリの艦隊が此年甲寅正月十日を以て再び浦賀沖に来た。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此折衝の結果は日米間に締結せられた下田条約で、尋で日英、日露の条約も亦此甲寅の年に成つたのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "公私略に「甲寅正月廿四日朝卯中刻女子出産、名長」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此茶番が此年甲寅に催されたと云ふことは、天一坊書卸の年と云ふより推すことが出来る。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "抽斎の祖父｜本皓の実子で、甲寅には七十二歳になつてゐた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲寅には二十歳、当時｜良三と称してゐた談話者塩田氏より長ずること二歳であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二百八十四　わたくしは塩田氏の語る所の茶番の事を此年甲寅の下に繋けた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二百八十五　柏軒が此年甲寅に首唱して、矢島｜優善、塩田｜良三の二人が計画し、小野｜令図の家の祝のために催す茶番の事は、塩田氏の語る所が猶残つてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その二百八十六　塩田氏は此年甲寅に小野｜令図の家に催された茶番の事を語ること前記の如くであつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二百八十七　此年甲寅に森枳園が躋寿館の講師にせられた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "福山にある同名の藩学は江戸に遅るゝこと一年、甲寅の歳に落成した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "六年甲寅　平八郎二歳。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そは甲寅の年も早や秋立ち初めし八月末の日なりけり。",
              "citation": {
                "source": "矢はずぐさ",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四　目出度き甲寅の年は暮れて新しき年もいつか鶯の初音待つ頃とはなりけり。",
              "citation": {
                "source": "矢はずぐさ",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二十三　嘉永七年甲寅の歳枕山は三十七歳、毅堂は三十歳になった。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "松陰がその門人渋木重之助と共に下田の米艦に投乗せんとして捕えられたのはこの年甲寅の三月二十一日である。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕山はこの年甲寅の夏｜駿府に遊び秋に入って北総に赴いた。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "安政元年｜甲寅　　三月二十七日、下田において米艦に搭ぜんと欲して果さず。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してその兄に向って誓文を与えて曰く、今｜甲寅の歳より壬戌の歳まで天下国家の事をいわず、蘇秦、張儀の術をなさず、退いては蠧魚と為り、進んでは天下を跋渉し、形勢を熟覧し、以て他年報国の基を為さんのみ。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本｜嘉永七年｜甲寅三月十一日別啓本書内に開列懇請する所は、生らこれを思うこと累日、多方に策を求む。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉永七年｜甲寅九月十八日　彼らの江戸獄中にあるや、ただ法廷において相｜見ゆるを得るのみ。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
