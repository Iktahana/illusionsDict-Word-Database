        "examples": {
          "standard": [
            {
              "text": "祖父の手紙には、時々旧字体が使われていて、読むのに少し時間がかかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史的な文献を研究する際には、旧字体に対する深い知識が不可欠となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の名前の漢字は、戸籍上では画数の多い旧字体で登録されており、それが彼の個性となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "・旧かなづかいは現代かなづかいに、旧字体は新字体に改めた。",
              "citation": {
                "source": "時間",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、プログラムを専門とする結城浩は、「旧字体置換可能チェッカー『校閲君』」など工作員向けツールを用意し、加賀是空は、「１クリック Aozora」という作品ファイルのダウンロードを簡略化するソフトウェアを開発し、ともにネットで無料提供している。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
