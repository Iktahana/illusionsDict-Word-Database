    "definitions": [
      {
        "index": 1,
        "gloss": "industry",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "どんな勤倹な四民も年に一度のお花見には特定の「濫費デー」を設けた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら勤倹貯蓄の精神を励ましても、つい何か食べに出かけたくなったり芝居、活動を見に行きたくなるものです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠はついにその責任のために石を巻き、鉄を捩じ、屈すべからざる節を屈して、勤倹小心の婦人となりぬ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "同様にまた紀文大尽の成金は詩的であって、安田善兵衛の勤倹貯金はプロゼックだ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "田野を闢き、学校を興し、勤倹身を持し、敦厚人を待つ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "詰り遊歴者諸芸人を勤倹同盟の村で待遇するように待遇する。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "調和を失せる痛ましい日本が、一方に勤倹尚武を鼓吹しながら、同時また恁んな近代的情調を日比谷公園裏に蔵して居るといふ矛盾を笑はずには居られなかつた。",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人は評判の蓄財家で、勤倹の徳は、範を近代に垂るるといっても可いのですから。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "良心から切り離されて　台湾征伐、熊本籠城、日清日露の両戦役、又は北清事変、青島征伐等を見た明治人、勤倹尚武思想を幾分なりとも持っている明治人は、科学文明で煎じ詰められた深刻な享楽主義をとても理解し得ない。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等東京人の云う忠君愛国、勤倹尚武、仁義道徳は皆虚偽であった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それを思ふと、何事も二｜宮宗の勤倹一点張でやり通さうとする内相に、性慾は余り贅沢過ぎるやうだ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が赤貧洗ふが如き中より身を起して独力を以て住屋と画室とを建築し、それより後二年ならずして洋行を思ひ立ちしかも他人の力を借らざるに至ては君が勤倹の結果に驚かざるを得ず。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点から言っても、私の勤倹論は従来の勤倹論とその見地を異にしている。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来の勤倹論は自分が貧乏にならぬために勤倹しろと言うのであって、その動機は利己的であるが、私の勤倹論は他人の害になるからぜいたくをするなというのであって、その動機は利他的である。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが彼とても単に勤倹な主人であった時代もあるのだ！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それやこれやで、鳥取の池田家と、岡山の池田家と御転封に相成り、少将様こちらの御城に御移りから、家中に文武の道を励まされ、諸民に勤倹の法を説かせられて、第一に遊女屋は御禁制じゃ。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "水野｜越前の勤倹御趣意のときも、鼈甲の笄をさしていて、外出するときは白紙を巻いて平気で歩いたが、連合卯兵衛が代ってお咎めをうけたのだ。",
              "citation": {
                "source": "西川小りん",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴々たる人々の正夫人が芸妓上りであるという風潮に誘われて、家憲の正しいのを誇った家や、商人までが、一種の見得のようにして、それらの美女を根引し、なんの用意もなく家婦とし、子女の母として得々としたことが、市民の日常、家庭生活の善良勤倹な美風をどんなに後になって毒したかしれない。",
              "citation": {
                "source": "明治大正美女追憶",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち聯合軍側は各種の利害関係と、人種的、もしくは国家的反感のために、統一力の不足を明かに暴露致しておりました上に、勤倹質素の生活に堪え得ないため、刻々に物資の不足を来し、独逸軍の決死的奮戦に見る見る圧倒されまして、今三箇月もすれば決定的に、四分五裂の守勢敗北状態に陥るものと観測されておりました。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "父も、――如何に父は真事しやかに「勤倹尚武」を教えたであろう。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "――或精神的風景画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただに実際に心配なきのみならず、学校の官立なりしものを私立に変ずるときは、学校の当局者は必ず私有の心地して、百事自然に質素勤倹の風を生じ、旧慣に比して大いに費用を減ずべきはむろん、あるいはこれを減ぜざれば、旧時同様の資金をもってさらに新たに学事を起すに足るべし。",
              "citation": {
                "source": "学問の独立",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "大火後、遊廓は浅草｜田圃へ移され、新吉原となり、芝居だけ元の土地に残っていたが、ずっと下って天保十三年に、勤倹令を布いた幕府の老中、水野｜越前守が、中央に芝居小屋などのあるのはもってのほかのこと、御趣意に反くというわけで、浅草｜猿若町へ転地させられた。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "勤倹尚武「勤倹尚武」と言う成語位、無意味を極めているものはない。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し「勤倹尚武」と言うことも痴人の談でないとすれば、「勤倹｜遊蕩」と言うこともやはり通用すると言わなければならぬ。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠義はできんけんど、十年もたったら、マッちゃんじゃって、どない出世するかしれたもんじゃない」　なんの意味かよくわからぬまま、松江は釜の下をたきつづけた。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
