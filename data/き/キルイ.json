  {
    "uuid": "0a39a5b6-15ea-51bc-84ad-ba34e04d8809",
    "entry": "帰塁",
    "reading": {
      "primary": "きるい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
