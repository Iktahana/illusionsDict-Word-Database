[
  {
    "uuid": "7f74d65f-765f-57c6-9798-a1b569284c86",
    "entry": "着類",
    "reading": {
      "primary": "きるい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "clothing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "街路は冬のやうに白つちやけて、昔ながらの大道店が、ガマの油や、オツトセイや、古着類や、縞蛇や、得體のわからぬ壞れた金物類などを賣つてる。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、下着類を皆、脱いでここへ出して下さい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "代りの下着類はいつさいその押入の中にはひつてゐますから。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下着類も案外汚れたのを平気で着て、これはもともとの気性だったが、なにか坂田は安心し、且つにわかに松本に対する嫉妬も感じた。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "東の対へ夜着類を取りにやって寝た。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二条の院では夏の夜着類も作って須磨へ送ることにした。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "家財も着類もみな賣り盡して、殘つてゐるものは親子二人のからだばかりだ。",
              "citation": {
                "source": "俳諧師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつきも云ふ通り、あしかけ五年の浪々に、わづかばかりの貯へは勿論、家財も着類もみんな賣り盡して、導引揉療治にまで身を落したが、それでも世渡りは出來ないで、先月から三度の飯も滿足に食つたことがない。",
              "citation": {
                "source": "俳諧師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "安重根は聞いていないように、手早く卓上の行李をあけて、つぎつぎに古着類を取り出す。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――夕刻より着類三口持ちて本郷いせ屋にゆき、四円五十銭を得、紙類を少し仕入れ、他のものを二円ばかり仕入れたとある。",
              "citation": {
                "source": "樋口一葉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父母は屋敷内の畑を作り、小遣銭取りには少しばかりの蚕を飼って細々と暮しており、叔父はからだが弱い上に百姓が好きでないというので、主に呉服物や古着類の行商をして生計を立てていた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、膚着類は染物より白地を用ひ、絹ものより木綿を用ゆるを良しとす。",
              "citation": {
                "source": "養生の心得",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり森閑としてるからお留守なのかと思っちゃった」　片手で頭からベレーをぬぎながら、宏子はナフタリンのきつい匂いと古い下着類の散らかされている縁側よりのところへ坐った。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "向いあって売場のある下着類のところから、同じように水色メリンスの事務服をきた時江が、その様子を見てこっちへやって来た。",
              "citation": {
                "source": "道づれ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "月曜日に毛糸の足袋と下着類と戦争論その他を入れます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三四年（昭和九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何んだ、それおしもの着類か」　立ったなり眺めている。",
              "citation": {
                "source": "女心拾遺",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二番目の抽出からは二人の男の子の着類が出て来た。",
              "citation": {
                "source": "執達吏",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗濯代その他　国立劇場コメディイ・フランセエズでは、専属俳優の下着類は一切、劇場の方で洗濯してやることになつてゐる。",
              "citation": {
                "source": "ふらんす役者気質",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "○通り　モスク※のクズネツキー　きれいな肌色の女の下着類、レース、衣服、装身具、皮類の店ぎっしり並んで、間に本やは一軒、キモノ！",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ、私の送って上げた金は一体何に使ったの、……そりゃ、こんな着類をこしらえるにもいったろうが、私自身にも欲しい物や買いたいものが幾らもあるのを、そんな物より何より私には、ただただお前という者が欲しいために、出来ぬ中から私の力に能う限りのことをして来たのじゃないか。",
              "citation": {
                "source": "狂乱",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の為に金でも出す時は己が着類を質入れしたり売り払ったりしても出す女であった。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その汚れた下着類のにおいは私をむかつかせた。",
              "citation": {
                "source": "燃ゆる頬",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやら練習は終ったらしく、片手には着類をだき、片手にはカバンをぶらさげたところであった。",
              "citation": {
                "source": "牛",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずこに至って着類を身につけるツモリであるかと緒方はいぶかった。",
              "citation": {
                "source": "牛",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが牛は緒方の言葉をきき終ると、片手にかかえていた着類をポロポロととり落した。",
              "citation": {
                "source": "牛",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川時代もやや下った元禄十二年の阿波藩の取締令にも、　穢多ども着類其外諸品、百姓共へ申付候趣に准じ、尚以軽可仕。",
              "citation": {
                "source": "エタに対する圧迫の沿革",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "便所の紙も、缶の外側も、ついでだからいうが、タオルも下着類も、全部緑の勝ったカーキー色をしていて、こまかい所にまで注意が行き届いていることを思わせる。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（さう云つて起ち上り、その辺をうろうろ見まはしながら、押入の中から行李を引き出し、素早く二三枚の着類を丸め、行李をもとのところにしまひ、急いで部屋を出る）舞台しばらく空虚。",
              "citation": {
                "source": "傀儡の夢（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この学校と、それに関したこととの、こまかな思い出にふけることがおそらく、いま自分のどうやら経験できるいちばん多くの快楽を私に与えてくれるのだ。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ターマンは、方々にできるいろ／＼の品物を、売買しながら、南洋にちらばつてる小さな島、人間のすんでる島や誰もゐない島を、探検してまはつてる男です。",
              "citation": {
                "source": "シロ・クロ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
