[
  {
    "uuid": "35e8c927-8d94-5872-8614-0f568789c980",
    "entry": "基板",
    "reading": {
      "primary": "きばん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
