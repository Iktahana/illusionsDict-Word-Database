        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ホワイトソースがダマにならないよう、木べらを使って鍋の底を丁寧になぞる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あっ、熱いから気をつけて！」と、彼女は木べらを持ったままキッチンで叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "テフロン加工を傷めないためには、金属のヘラよりも木べらの方が断然おすすめだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "使い込まれた木べらは、角が丸くなって、すっかり彼女の手の形に馴染んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ジャムを煮詰める間、甘い香りに包まれながら木べらをゆっくりと回し続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "すみのほうには、火ばさみと、木べらがあり、紡車は、腰かけの上にあがっています。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "かまどは熱い、小麦粉も捏ねられている、パンは木べらにもう乗っている。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
