[
  {
    "uuid": "9073a56f-be08-5f2c-aeea-9e9392ed8587",
    "entry": "危篤",
    "reading": {
      "primary": "きとく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
