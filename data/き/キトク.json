      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "vested",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし特殊の題目について重なる学術国の重なる研究者の研究の結果を up to date に調べ上げて、その題目に対する既得知識の終点を究める事は可能である。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も科学者の中には往々そういう大事な根本義を忘れて、自分の既得の知識だけでは決して不可能を証明することの出来ない事柄を自分の浅はかな独断から否定してしまって、あとでとんだ恥をかくという例もあえて稀有ではない。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "既得の知識を繰り返して受け売りするだけでは不十分である。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで科学の既得の領土に隠居して、虎の子の勘定でもして楽しんでいるような人にはこの書はなんにもならない。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "既得の領土に安住を求むるか、センセーションを求めて奇を弄するかに迷わざるを得ないのである。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "口笛を吹くような礼儀知らずでさえなければ、二、三人でくわしておいたほうが、既得権の誇示になっただろうに。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "個人の既得権も利害関係も、センチメンタルな詠嘆も、すべてを無視して、彼のペンは気まぐれに地図の上を、走っていく。",
              "citation": {
                "source": "二人の盲人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "当局が捻出する文化のイデーは、どれとして民衆の既得の文化意識を満足させるものがない。",
              "citation": {
                "source": "一九三七年を送る日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど逍遙子を以て未得大理想とし、ハルトマンを以て既得大理想とせむはいかが。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ未だ沒却理想を信じて、この禿たる談理の筆を擲ち、逍遙子が驥尾に附いて、記實の事に從ふこと能はずといへども、逍遙子は既に沒却理想を立てたれば、これも既得大理想といふべきものにはあらざるか、ハルトマンが某無意識哲學を作るや辨證の一道を避けて、歸納演繹の論理を用ゐき。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまたその功名の価を損ずるところのものにして、要するに二氏の富貴こそその身の功名を空うするの媒介なれば、今なお晩からず、二氏共に断然世を遁れて維新以来の非を改め、以て既得の功名を全うせんことを祈るのみ。",
              "citation": {
                "source": "瘠我慢の説",
                "author": "瘠我慢の説",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しみ、怒り、歎く前に、果してここで悲歎していいのかと批判を働かしてみることは、然し已に一応の教養をもつた人間にとつては、甚だその既得の思想に瞞着され易いものであつて、ただこれだけの単純なことでも、相当の難事のやうであります。",
              "citation": {
                "source": "無題",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういふ調査は、軍部や外務省あたりでは既にちやんとできてゐると思ふが、われわれには、経済的な既得権、乃至は、不動産の類といふ風にしか理解できなかつた。",
              "citation": {
                "source": "私の従軍報告",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "從來、政權を握つたすべての階級は、全社會を自分らの收益條件に屈從させて、そして自分らの既得の地位を確保しようとした。",
              "citation": {
                "source": "共産黨宣言",
                "author": "カール・マルクス",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて肘掛にでもと尻をもつて行くと、さも既得権を侵害されたやうな眼つきで相手の背中をにらみつけるものがある。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん理知は一八世紀このかた自然科学の発達によって得たところのわれわれの既得権である。",
              "citation": {
                "source": "小知恵にとらわれた現代の法律学",
                "author": "末弘厳太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方はさして逆上せぬかわり、皇帝の死が直ちに安南における既得利権の損害を意味するので、もう愚痴たらたら、碌すっぽ顔も見ようともせず、ひたすら深き嘆きに沈むのであった。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしあるとすれば夫はマンネリズムということであって、夫は蓄積というよりも寧ろ既得のものの腐敗と消滅に他ならない。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "思想を促進する知識は既得の知識ばかりではなく知識を求める関心の正しさと広さを要求する。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから一つの新しい経験は、いつも既得の経験の整理された地盤の上でしか受け取られず、又云わばその再整理のためにしか受け取られない。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "既得の技術が原始状態にまで還元されたり、採用されなかったり、廃棄されたり、その発達を抑圧されたりしている。",
              "citation": {
                "source": "技術の哲学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "――宗教という観念にどんな既得表象をなげ入れるのも、どんな希望や期待を投入するのも、人々の自由である。",
              "citation": {
                "source": "認識論とは何か",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "高々既得の常識水準に足踏みする結果しか得られないわけで、学術上の論文としては何等科学的価値を持たないことになる。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナチ政権が如何に学芸の自由検討を許さないとしても、ドイツの学芸の既得技能が急に衰えたとは誰も考えないだろう。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "既得権を有っている当業者は組合大会を開いて之に反対したが、他の方面の文化統制に忙しい当局は、まだ美容院乃至床屋の文化的作業の検閲にまで必要を感じなかったので、床屋は自由にどこにでも開業出来るということになって了った。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、中西梧堂氏などの、鳥類科學によると、鶯のあの美しい音も、鶯自身の本能に云はせると、何も人間の俳味や耳を樂しませる爲に啼いてゐるのでなく、鶯は自らの生存のため、既得生活權の主張を叫んでゐるのだといふことである。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来欧米列国が支那朝鮮、即ち絶東に於て得たところの権利、既得の権利は国家として個人として得たるすべての権利は、日本に於て何処までもこれを尊重せねばならぬ。",
              "citation": {
                "source": "東亜の平和を論ず",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、無鑑査撤廃に自分達が反対するのは、それが既得権を侵害されるという意味ではない。",
              "citation": {
                "source": "芸術統制是非",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人の居住、商租権などの既得権すら有名無実に等しい。",
              "citation": {
                "source": "私が張作霖を殺した",
                "author": "河本大作",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は何かの方法によって彼らを新しく教育しなおすことはできるにしても、元も子もなくす覚悟でもなければ、彼らをその既得の習癖からひっぺがすことはまずできまい。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
