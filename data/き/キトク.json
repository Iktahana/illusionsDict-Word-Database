      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "critical condition",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――いつたい何処までゆきなさる、――いえ、兄の嫁の危篤を知らせに、此の下の村まで一寸。",
              "citation": {
                "source": "（七銭でバットを買つて）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "危篤な病人の枕もとへはおおぜいの見舞い人が詰めかける。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（文中、筆者は詩人が既に危篤の状態にありながら、醫者の死ではなしに、彼自身の死を死ぬことを欲して、遂に一切の注射を拒絶したといふ插話を引いて、大いに驚歎してゐる。",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "話の様子で察してみると、誰かこの老婆の身近い人が、川崎辺の病院にでもはいっていて、それが危篤にでも迫っているらしい。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の危篤に駈けつけるときには、こんな思いであろうか。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方なしに牛太郎と一緒におやぢのとこさ行つたらお袋が危篤で俺らこと捜しぬいてるところだつた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」伯母の病気が危篤だと云ふ代筆の手紙を手にして彼はかう呟いた。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "處で――父の……危篤……生涯一大事の電報で、其の年一月、節いまだ大寒に、故郷へ駈戻つた折は、汽車で夜をあかして、敦賀から、俥だつたが、武生までで日が暮れた。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに就て厳重に詮議するより他はないが、何分にも生命危篤という重体であるから、手の着様が無い。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほとんど危篤の状態らしい。",
              "citation": {
                "source": "故郷",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月のはじめに御発熱があり、六日の夜から重態にならせられ、十日にはほとんど御危篤と拝せられましたが、その頃が峠で、それからは謂ばば薄紙をはがすやうにだんだんと御悩も軽くなつてまゐりました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月のはじめに御発熱があり、六日の夜から重態にならせられ、十日にはほとんど御｜危篤と拝せられましたが、その頃が峠で、それからは謂わば薄紙をはがすようにだんだんと御悩も軽くなってまいりました。",
              "citation": {
                "source": "鉄面皮",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからこういう秘密な事を打明けられるまで、懇意になって、唯今の処じゃ、是非貴女のお耳へ入れなくってはなりませんほど、老人｜危篤なのでございます。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "我は不義者の児なりと知り、父はしかも危篤の病者。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴下の奥さんが御危篤のように存じられます。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "實はなくなりました父が、其の危篤の時、東京から歸りますのに、（タダイマココマデキマシタ）と此の町から發信した……偶とそれを口實に――時間は遲くはありませんが、目口もあかない、此の吹雪に、何と言つて外へ出ようと、放火か強盜、人殺に疑はれはしまいかと危むまでに、さんざん思ひ惑つたあとです。",
              "citation": {
                "source": "雪靈續記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん親しくなり、そのうちに父上の危篤の知らせがあって、彼はその故郷からの電報を手に持って私の部屋へはいるなり、わあんと、叱られた子供のような甘えた泣き声を挙げた。",
              "citation": {
                "source": "リイズ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は良人の容体の危篤に陥りしより、ほとんど一月ばかりの間帯を解きて寝しことあらず、分けてこのごろに到りては、一七日いまだかつて瞼を合さず、渠は茶を断ちて神に祈れり。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はなくなりました父が、その危篤の時、東京から帰りますのに、（タダイマココマデキマシタ）とこの町から発信した……偶とそれを口実に――時間は遅くはありませんが、目口もあかない、この吹雪に、何と言って外へ出ようと、放火か強盗、人殺に疑われはしまいかと危むまでに、さんざん思い惑ったあとです。",
              "citation": {
                "source": "雪霊続記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "身内の者が危篤だという電報が来ても、仕事が終らぬうちは、腰を上げようとしない。",
              "citation": {
                "source": "鬼",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしが出る時なア、もう危篤じゃった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それといっしょにご病勢もどっとご危篤になってきました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "危篤だと聞いて、早速駆けつける旨、電話室から病室へ言いに戻ると、柳吉は「水くれ」を叫んでいた。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "危篤の知らせで駈けつけたのは修一ひとり、無論本妻の計らひであつた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里での三年間が終わりに近付いた或る日、彼は突然、彰子が危篤だという日本からの電報を受け取った。",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は倫敦にいる自分の妻が危篤のために、上京するべく今は一瞬間も失ってはならないというのだ。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ヒルトン・キュービット夫人は深い傷を負って、今危篤だ。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」緊迫感のあるその鋭い声が、私の心に「危篤」の二文字を思い起こさせる。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分でもわかると思うが、君は演技なんてからきしで、うっかりこの秘密を教えると、スミスにも僕自身が危篤だと思わせることも無理になる。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやら我々が出発してほんの数分後に到着したさる英国婦人が、肺の病で危篤らしい。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
