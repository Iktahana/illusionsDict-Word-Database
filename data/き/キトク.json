  {
    "uuid": "391904ad-ecb4-544d-ae14-5340e7891aa7",
    "entry": "既得",
    "reading": {
      "primary": "きとく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
