        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "子供のキャッチボールのそれ球をわんわんのように這って椽の下にさがしに行ったりどろだらけな靴下をつくろってやることもあります。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は局員たちを相手にキャッチボールをはじめました。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、よくみんなはキャッチボールをするから。",
              "citation": {
                "source": "久助君の話",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこからは、事務所の前で、ワイシャツの社員がキャッチボールをやっているのが見えた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐそばで、ホテルのコックがスポンジボールでキャッチボールをしている音が単調に聞こえる。",
              "citation": {
                "source": "謎の女",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんしろ今頃学校にいれば午餐をすまして、運動場でキャッチボールでもしている時間でした。",
              "citation": {
                "source": "誰が・何時・何処で・何をした",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうかなりな年配なひとだが、道で子供たちがキャッチボールかなんぞしていると、自分も青年のようにその中へ這入っていって子供たちに人気を呼んでいた。",
              "citation": {
                "source": "落合町山川記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　日曜日のひる近くで、近所の中学生が杉垣の外でキャッチボールをしている音がきこえる。",
              "citation": {
                "source": "杉垣",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの肥料をつかってこないよう出来たと見せようちゅうところの」　苅ったところで達治とキャッチボール○多賀さんの山　が右手　寺の山　左手　むこうはＡの家。",
              "citation": {
                "source": "Sketches for details Shima",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この森というのは、ずいぶん古くから手塚の薬局にいるが、代診として患者を往診した事はきわめてまれである、千三はいつも森が白い薬局服を着て往来でキャッチボールをやってるのを見ているのではなはだおぼつかなく思った。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああここがおれの生まれたところなんだ、おれが生まれたときに手塚の親父がぺこぺこ頭をさげて見舞いにきたんだ、それがいまそいつに占領されてあべこべにおれの方が頭をさげて薬をもらいにきてる」　ある日かれはこんなことを考えながら門をはいろうとするとそこで代診森君が手塚とキャッチボールをしていた。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "安場は日曜ごとに浦和へきた、そうして千三にキャッチボールを教えたりした、元来｜黙々塾に通学するものはすべて貧乏人の子で、でっち、小僧、工場通いの息子、中には大工や左官の内弟子もあった。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが安場がきてからキャッチボールがはやりだした、安場は東京の友達からりっぱなミットをもらってきてくれた、チビ公は光一のところへグローブの古いやつをもらいにいった。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "選手は入場するやいなやすぐキャッチボールを始めた、それがすむと、一同さっと散ってめいめいのシートシートに走った。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "（まだ誰一人なじみのない彼は、毎朝校舎の横手の青々した芝生に坐ってみたり、高等学部の前の記念樹の間をぶらついて、運動場でキャッチボールをしている人達を見やって親愛と征服の想いに瞳を輝かせたりして響きの懐かしい鐘の音を待った。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが公園の中はひっそりかんとしていて、野球やキャッチボールをしている者はない。",
              "citation": {
                "source": "烏啼天駆シリーズ・４　暗号の役割",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "神経衰弱といふものは単に精神的に消耗するばかりでなく、肉体的にも稀代の衰弱を見せるもので、田園へ散歩に行き三四尺の流れが飛び越せず水中に落ち、子供とキャッチボールしたら、十米ぐらゐの距離をボールがとゞかぬ。",
              "citation": {
                "source": "二十一",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "木田の名刺をたよりに△△商会を訪ねてみると、そこのマーケットはとつくに火事に焼き払はれて、今はキレイな原つぱになり、人々がキャッチボールをやつてゐる。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の家は入口からズッと奥まで土間が通っていて、旧家になると、この土間でキャッチボールができるぐらい広々としている。",
              "citation": {
                "source": "露の答",
                "author": "ぬばたまのなにかと人の問ひしとき露とこたへて消なましものを",
                "note": "青空文庫"
              }
            },
            {
              "text": "神経衰弱というものは単に精神的に消耗するばかりでなく、肉体的にも稀代の衰弱を見せるもので、田園へ散歩に行き三四尺の流れが飛び越せず水中に落ち、子供とキャッチボールしたら、十米ぐらいの距離をボールがとどかぬ。",
              "citation": {
                "source": "二十一",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝ころんでタバコをくわえながら空を眺めたり、仔犬と遊んだり、キャッチボールをすることもできやしない。",
              "citation": {
                "source": "風流",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "校庭へ出てキャッチボールをするのだということがわかった。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのため適度の運動が必要で、終戦後キャッチボールをやった。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが私の年齢ではキャッチボールは無理だ。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十畳敷というバカ広い部屋で、キャッチボールができるほどだ。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャッチボール　私は昨年末からプロについてゴルフの稽古をはじめたおかげで、私が昔やったスポーツにいろいろフォームの狂いがあったことをさとった。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、一般に普及しているのはキャッチボールというべきだ。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいがいの男の子がよろこんでぶつけッこするだろう」　キャッチボールを独立した競技化して的をねらったら、結構たのしめるスポーツになりゃしないかと思う。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がキャッチボールをしていると、野球はカラダに毒ですよ、投網は健康ですぜ、と言う。",
              "citation": {
                "source": "釣り師の心境",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
