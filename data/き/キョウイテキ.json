[
  {
    "uuid": "020bf467-c084-5686-abe1-81b103e0c29b",
    "entry": "驚異的",
    "reading": {
      "primary": "きょういてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
