        "examples": {
          "standard": [
            {
              "text": "予期せぬトラブルで部品が供給不足となり、製品の製造に遅れが生じている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今年の夏は猛暑のため、電力の供給不足が深刻化する恐れがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新鮮な野菜の供給不足により、スーパーでは価格が高騰している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "専門技術者の供給不足は、IT業界全体の大きな課題となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "より温いより人口稠密な国、特に大都会と工業の多い国においては、食物の供給不足が長く続けば、ほとんど間違なく、暴威を振う大きな疫病の形でか、またはこれより激しくないが、しかし慢性的な疾病の形で、流行病をもたらさずにはおかない。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミルクと粉乳は高価で供給不足なので、代用品の開発が進められた（88）。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが現実はまだ供給不足だ。",
              "citation": {
                "source": "四日白魔",
                "author": "THE FOUR WHITE DAYS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
