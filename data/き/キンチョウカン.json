[
  {
    "uuid": "8fdaa022-4e94-56a2-bb05-57db87d35e13",
    "entry": "緊張感",
    "reading": {
      "primary": "きんちょうかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
