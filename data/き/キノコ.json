          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「わあ、見て！木の根元に丸い茸がたくさん生えてるよ」と子供が指を差してはしゃいでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "バターでじっくり炒めた茸の香りがキッチンに広がり、一気に食欲をそそられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "乾燥させた茸から取った濃厚な出汁を隠し味に使うと、スープの深みがぐっと増すんだよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "秋の味覚を楽しむなら、やっぱり網焼きにした香りの強い茸にスダチを絞って食べるのが一番だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "何という題であったか忘れたが、自分が九歳の頃東海道を人力車で西下したときに、自分の乗っていた車の車夫が檜笠を冠っていて、その影が地上に印しながら走って行くのを椎茸のようだと感じたと見えてその車夫を椎茸と命名したという話を書いた。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子規がその後時々自分に「あの椎茸のようなのはもっとないかね」と云ったことを思い出す。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はこの車夫に椎茸と云う名をつけた。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "街道に沿うた松並木の影の中をこの椎茸がニョキ／＼と飛んで行くのがドンナに可笑しかったろう。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝はこの椎茸が恐ろしく長くて、露にしめった道傍の草の上を大蛇のようにうねって行く。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお面白いのは日が高くなるにつれて椎茸が次第に縮んで、おしまいにはもう椎茸とも何とも分らぬものになって石ころ道の上を飛び飛び転がって行く。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体が西を向いて行くのであるから、椎茸は車の右脇へ頭を出したり左へ出したり。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな坊チャマを膝へ乗せた父上も大概な事ではなかったらしいが、椎茸もトンダ目に会ったものだ。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この椎茸少々｜宜しからぬ事があって途中から免職になったのはよかったが、その後任の爺さんがドーモ椎茸でなかったので坊チャン一通りの不平でない。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山に這入ると松茸の香がしめつた山氣に混つて鼻に泌みる。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "濕つた羊齒をかき分けると可愛らしい松茸が雀の子のやうにうづくまつてゐた。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども虫がしんしん鳴き時々鳥が百｜疋も一かたまりになってざあと通るばかり、一向人も来ないようでしたからだんだん私たちは恐くなくなってはんのきの下の萱をがさがさわけて初茸をさがしはじめました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の家には、蕨や、いたどりや、秋には松茸が、いくらでも土の下から頭をもちあげて来る広い、樹の茂った山があった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋になると、トシエの家には、山の松茸の生える場所へ持って行って鈴をつけた縄張りをした。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人に松茸を取らさないようにした。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、番人が現場へやって来る頃には、僕等はちゃんと、五六本の松茸を手籠にむしり取って、小笹が生いしげった、暗い繁みや、太い黒松のかげに、息をひそめてかくれていた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　番人は、トシエの親爺に日給十八銭で、松茸の時期だけ傭われていた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、Ｓ町の近くに田を持っていたあの松茸番の卯太郎は、一方の分を製薬会社の敷地に売って五千円あまりの金を握った。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "楢や櫟を切り仆して椎茸のぼた木を作る。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山葵や椎茸にはどんな水や空気や光線が必要か彼らよりよく知っているものはないのだ。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雁もどきッて、ほら、種々なものが入った油揚があらあ、銀杏だの、椎茸だの、あれだ、あの中へ、え、肴を入れて交ぜッこにするてえことあ不可ねえのかなあ。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――昼と晩の順は忘れたが、鱒と葱の玉子綴、鳥のスチウ、鱒のすりみと椎茸と茗荷の椀。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、いつかどこかでごちそうになったときに出された吸い物の椎茸をかみ切った拍子にその前歯の一本が椎茸の茎の抵抗に負けてまん中からぽっきり折れてしまった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん近くへ行って見ると居なくなった子供らは四人共、その火に向いて焼いた栗や初茸などをたべていました。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番初めに、初茸が立ち上って挨拶をしました。",
              "citation": {
                "source": "きのこ会議",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が書いて新聞に出しますから」　皆がパチパチと手をたたくと、お次に椎茸が立ち上りました。",
              "citation": {
                "source": "きのこ会議",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が日清戦争に予備役で召集されて名古屋にいたのを、冬の休みに尋ねて行ってしばらく同じ宿屋に泊っていたときのことである。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気で休学して郷里で遊んでいたときのことであるが、病気も大体快くなってそろそろ退屈しはじめ、医者も適度の運動を許してくれるようになった頃のことであった。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、夏目先生が英国へ留学を命ぜられたために熊本を引上げて上京し、奥さんのおさとの中根氏の寓居にひと先ず落着かれたときのことであるらしい。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつきのことばと言へ、今の笑ひ声と言ひ明らかに自分を侮辱してると彼は一途に思ひつめた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
