        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "アロマオイルは揮発性が高いので、使用後はしっかりと蓋を閉める必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ガソリンは非常に揮発性が高く、引火しやすい性質を持つため、取り扱いには注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この有機溶剤は揮発性が低く、作業中も匂いが気になりにくいのが特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "揮発性の物質を扱う際は、必ず換気の良い場所で行ってください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "すべての色彩と形が水中へ入れば一律に化生せしめられるように人間のモラルもここでは揮発性と操持性とを失った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "葱を刻んだのを、薬味箱に誇大に盛ったのを可笑しさを堪えた顔の小女が学生たちの席へ運ぶと、学生たちは娘への影響があった証拠を、この揮発性の野菜の堆さに見て、勝利を感ずる歓呼を挙げる。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青葉の揮発性の匂いがした。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどき店の奥のスタンドで、玻璃盞にソーダのフラッシュする音が、室内の春の静物図に揮発性を与えている。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女が、ほのかに匂っているオレンジに塗られたブランデーの揮発性に、けへんけへん噎せながら、デザートのスザンヌを小さいフォークで喰べていると、むす子がのそっと立ち上って握手をして迎える気配がした。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "木々の若芽の叢が、垂れた房々を擡げてほのかに揮発性の匂いを発散する。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "粘って青臭い護謨の匂いが、何か揮発性の花の匂いに混って来る。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "野には青麦が一面によろ／＼と揮発性の焔を立てゝゐた。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがいま眼の前の父の言葉といい、態度といい、全く思いがけないもので何だかわたくしの身体に融け入って来る和やかなものがありながら、それはもう父の茹り枯しの滓で、揮発性も爆薬性もない摘みほぐした綿のようになった父の性格の繊維だけを感ずるのでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして「詩人」とか「天才」とか、其頃の青年をわけも無く酔はしめた揮発性の言葉が、何時の間にか私を酔はしめなくなつた。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして「詩人」とか「天才」とか、そのころの青年をわけもなく酔わしめた揮発性の言葉が、いつの間にか私を酔わしめなくなった。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁の前面に肉片を置いたときにでも、その場所の気流の模様によっては肉から発散する揮発性のガスは壁の根もとの鳥の頭部にはほとんど全く達しないかもしれない。",
              "citation": {
                "source": "とんびと油揚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また換言すれば、精神に安定性を与えるものがこれ形式で、形式を揮発性にしたものがこれ精神である。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "燃焼している間に、太陽の組成分中で最も揮発性のもの、また最も精微なものが失われる。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "カントは、燃え切った太陽が『渾沌と混淆する』ことによって、すなわち、太陽から放出された最も揮発性な最も微細な物質が、往昔の渾沌の死骸と思われる黄道光物質中に突入することによって『更新』するという考えを述べているのである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "「放浪記」にあった自然発生の一種の揮発性の匂いは世路の向上の間にぬけた。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても嗅覚を刺激する液体で、燐と何かの揮発性のエーテルとが含まれているように、私には思われた。",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その罎には無色の揮発性の物を貯わえてあって、それはなんだかわからない。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "貸家",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、すべての揮発性の精油は一般性質としてアルコールに溶け、沸騰水の温度で揮発する性質を持っているので、それらは互いにいろいろと混じり、安価なもので高価であるような誤魔化しをして、この前に述べたようなどのような試験によっても悪用を発見される可能性が無い。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワインの種類によって特別な風味と香りがあるのは、たぶん量があまりにも少ないので分離することができない揮発性の油によるのであろう。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにが死因だったのかわからないが、地下鉄の中でそういう事態が起ったことはたしかなのだから、ともかく夫人の所持品を法医研究所へ送って試験をしてもらうと、香水の瓶の中に揮発性のシアン化物が入っていることが発見された。",
              "citation": {
                "source": "悪の花束",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの言葉の揮発性の真実は、残滓のような陳述の不備を絶えず曝露すべきである。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀灰色の塗料から、きつい揮発性の匂いが立った。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち可燃性のもの（硫黄）、揮発性のもの（水銀）、燃えないで灰になるもの（塩）、であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮膚は肺と同じようにある程度は呼吸し揮発性物質は皮膚を通して身体から出る、とガレノスはみなしていた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして翌日午前には検事と警察部長の臨検があり、一方名古屋憲兵隊からは外事班員、鑑識班員等の臨検があり、曲者の死因は揮発性有機毒の皮下注射によるものと判定せられた。",
              "citation": {
                "source": "偉大なる夢",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
