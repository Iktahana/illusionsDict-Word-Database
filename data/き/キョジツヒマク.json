    "definitions": [
      {
        "index": 1,
        "gloss": "the difference between truth and fiction in art being very subtle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
