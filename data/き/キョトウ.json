    "definitions": [
      {
        "index": 1,
        "gloss": "big-time robber",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ために字を熊坂とて、俗に長範の産地と称える、巨盗の出処は面白い。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "明和二年刑せられた巨盗真刀徳次郎はこの夜孕まれた由。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉、杜に語りて、この人は江湖の巨盗だ、すべて人家に至って様子を窺い置き、夜に至って猴を入れて窃ます、而して彼は外にあって応援す。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "講談本や探偵小説にある巨盗怪賊の忍術は、こんな事を云ったものかと思われると吹き立てる不良さえある。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「緑林黒白」こそは、日本、支那、朝鮮に輩出した巨盗大賊の伝記であって、行文の妙、考証の厳、新説百出、規模雄大、奇々怪々たる珍書であったが、惜しい事には維新の際、殆ど失われたということである。",
              "citation": {
                "source": "赤格子九郎右衛門",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小石川切っての大地主で、巨万の富を積んでいる成瀬屋は、蝙蝠冠兵衛に狙われると知って、屋敷の内外に鳴子を張り渡した上、幾つも幾つも罠を仕掛けて、苦もなく忍び込んだ巨盗冠兵衛を生捕りにし、番頭で用心棒を兼ねた伝六という男が、さんざん冠兵衛をなぶりものにした揚句、半死半生のまま役人に引渡したのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "槍の折れ",
                "note": "青空文庫"
              }
            },
            {
              "text": "生前の善根らしきもののお蔭で、助命の歎願などもありましたが、もとよりそんなものは取上げられるはずもなく、一代の巨盗もそれっきり江戸っ子の関心から拭い去られてしまったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "槍の折れ",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　平次の仕事は一とわたり家の内外を見ると、次には死んだ巨盗｜蝙蝠冠兵衛の脅迫状を見せて貰うことでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "槍の折れ",
                "note": "青空文庫"
              }
            },
            {
              "text": "確かにそこへ入れたはずの、巨盗の手紙三本は、煙のごとく消えてしまったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "槍の折れ",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　巨盗の幽霊の手紙は、明らかに紛失しましたが、さいわい総右衛門が文句を諳んじているのと、留吉が筆跡や紙をよく見ておいたので、大体のことは平次にも想像がつきます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "槍の折れ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここからは小石川牛込一帯の低地を眺めて、なかなかの景色ですが、そんなものはもとより眼にも入らず、巨盗蝙蝠冠兵衛の亡霊だけが、三人の胸の中に、次第に現実味を帯びて生長して行くのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "槍の折れ",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十八年前の巨盗は、口ほどにもなく、平次やガラッ八の敵ではなかったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "瓢箪供養",
                "note": "青空文庫"
              }
            },
            {
              "text": "「判官三郎という、巨盗を君は知って居るかな」「イヤ、一向……矢張り石川五右衛門といったような」「プッ」　とうとう皆な吹出してしまいました。",
              "citation": {
                "source": "判官三郎の正体",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「判官三郎というのは、近頃世の中を騒がして居る巨盗なんだが、この泥棒は不思議に婦人方に人気があるんだ。",
              "citation": {
                "source": "判官三郎の正体",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な巨盗ルパンが独り寂しく、かの暗い地下室の冷たい土の上に死に掛って横たわっていると思えば、一種悲愴な気持がわいてくるのであった。",
              "citation": {
                "source": "奇巌城",
                "author": "アルセーヌ・ルパン",
                "note": "青空文庫"
              }
            },
            {
              "text": "首領を救わんとする強盗団の計画はわずか二十四時間で見事に破られ、かの巨盗アルセーヌ・ルパンの逮捕は確実になった。",
              "citation": {
                "source": "奇巌城",
                "author": "アルセーヌ・ルパン",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　少年は今こそ巨盗のあらゆる憎むべき行に対して、痛烈に復讐の言葉を浴びせている。",
              "citation": {
                "source": "奇巌城",
                "author": "アルセーヌ・ルパン",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨盗を主人公にしよう」　と、思い立った。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よし、五十三次をあばれまわる巨盗だ」　私のハラは、きまった。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な緬甸の大涅槃像だとか、ニューヨーク湾の自由の女神像だとか、そういう巨像の空洞は、ルパンの様な世界的巨盗の倉庫として、何とふさわしくはないだろうか」「信じられん。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ことにこいつは日本左衛門と一緒に永年手をやかせていた抜け買いの巨盗、殺してしまっちゃ、何もなりゃあしません」「やっかいだな。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
