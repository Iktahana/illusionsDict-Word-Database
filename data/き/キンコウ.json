[
  {
    "uuid": "a389e2be-f16a-540a-a575-2db112adc7ce",
    "entry": "均衡",
    "reading": {
      "primary": "きんこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
