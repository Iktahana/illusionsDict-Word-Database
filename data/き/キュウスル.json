  {
    "uuid": "49b30d9d-72c8-56c4-896f-8c1b1fcff6cf",
    "entry": "給する",
    "reading": {
      "primary": "きゅうする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-特殊",
        "動詞-他動詞"
      ],
