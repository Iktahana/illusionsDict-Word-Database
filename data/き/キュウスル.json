[
  {
    "uuid": "bd718929-f76d-552e-8107-f4185d4c4721",
    "entry": "休する",
    "reading": {
      "primary": "きゅうする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-特殊",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to come to an end",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "公等碌々たる其の通りにして行けば、所謂雪は秦嶺に横たはり、雲は藍關を擁する時に至つて、一長歎して萬事休するのみなのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "運來つて起つて舞ひ、時至つて偃して休するのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の一生は旅なり、然れども「生」といふ駅は「死」といふ駅に隣せるものにして、この小時間の旅によりて万事休する事能はざるなり。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鉢の下に紙片があって「好く休する時を得て即ち好く休せよ、花を収め子を結んで錦州に在り」という詩句が書いてあった。",
              "citation": {
                "source": "緑衣人伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "でないと、閣下等の万事は休するのだ！",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨーロッパ大戦ののち書かれた多くの代表的文学作品は、塹壕から帰休する毎に深められて行く男のこの憎悪の感情と寂寞の感情にふれていないものはない。",
              "citation": {
                "source": "祭日ならざる日々",
                "author": "――日本女性の覚悟――",
                "note": "青空文庫"
              }
            },
            {
              "text": "我謹厳なる委員諸公は僕等の命休するも泰然たらむは疑ふべからず。",
              "citation": {
                "source": "文部省の仮名遣改定案について",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい平素は監守の任にある将卒の注意が緩んでいるとしても、もし一兵卒が櫃を怪しんだり、あるいは好奇心から偶然にもその蓋を開けて見るような事でもあるならば、折角の千辛万苦も、一朝水泡に帰して万事休するに至るは明瞭な事柄である。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "私等はこの日｜霊宝館を訪ねる予定であつたが、まだ雨が止まぬので此処に一休するつもりで来て、雨の霽れるのを待たずに此処を出たのである。",
              "citation": {
                "source": "仏法僧鳥",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私等はこの日霊宝館を訪ねる予定であったが、まだ雨が止まぬので此処に一休するつもりで来て、雨の霽れるのを待たずに此処を出たのである。",
              "citation": {
                "source": "仏法僧鳥",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小大の進退して休する則は進まず退かず。",
              "citation": {
                "source": "安藤昌益",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "がんりきの立場から言えば、取組ませては万事休するのですから、その敏捷な身体のこなしと、自由自在な一本の腕を以て、敵に組ませないうちに突き落してしまうに限るのであって、がんりきはよくその策戦に成功しました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが不足でないというならば万事休するまでではあるが、さに非ざる夢がありとすれば、実に気の毒千万な訳である。",
              "citation": {
                "source": "書道を誤らせる書道奨励会",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "空谷を過ぎて、山かせぎなどする人の休場である山の鼻で一休する。",
              "citation": {
                "source": "黒部川を遡る",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度この選択を誤まれば、万事は休するのである。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして外国貿易の喪失によって不要となった資本が遊休するものでないことは、疑いがない。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしさうだとすれば、海螢の發光物質の研究は萬事休する譯である。",
              "citation": {
                "source": "海螢の話",
                "author": "神田左京",
                "note": "青空文庫"
              }
            },
            {
              "text": "『この怪事件で、下手な真似をしたが最後、万事は休する』　ビクトワールが、ルパンの傍を通った時、『ジャンソン中学の裏手で逢おう』と彼は低い声で囁いた。",
              "citation": {
                "source": "水晶の栓",
                "author": "モウリス・ルブラン",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、見本の栓を奪う事によって、ドーブレクのために目的を感付かれては万事休するので、ジャックを使ってドーブレクの手元へ人知れず隠したのであった。",
              "citation": {
                "source": "水晶の栓",
                "author": "モウリス・ルブラン",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ひとりの兵士が、ただひとりでも、家を回ろうという考えを起こすか、あるいは側面から攻撃しようという考えを起こしたならば、万事休するのだった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間後、公表されたのは正午からロンドン駅の全線で列車が運休する。",
              "citation": {
                "source": "四日白魔",
                "author": "THE FOUR WHITE DAYS",
                "note": "青空文庫"
              }
            },
            {
              "text": "まえにものべたとおり、辻川博士が平素とちがって、ひじょうに快活だったし、それに話上手の潮見博士がいたし、辻川博士と二人きりのときには、いつも話のきっかけにきゅうする私も、つい釣り込まれて大いに喋った。",
              "citation": {
                "source": "蜘蛛",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年たちの問いにきゅうすると、苦しそうに休息をもとめるが、その目はたえず周囲を見まわしている。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "木綿が日本にふきゅうするまでは、麻布を着ぬ日本人は一人もなく、苧を績み布を織らぬ女も皆無にちかかった。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
