        "examples": {
          "standard": [
            {
              "text": "今回のピアノリサイタルは、若手とは思えない力強いタッチと繊細な表現力が同居した、非常に聞き応えのあるプログラムだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "専門的な学術シンポジウムだったが、各パネリストによる熱い議論は知的好奇心を刺激するもので、実に聞き応えがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「このオーディオシステムで聴くフルオーケストラの演奏は、音の厚みが全然違って、本当に聞き応えがありますね！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "また議論としてさほどききごたえのある発言もなかった。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
