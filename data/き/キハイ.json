[
  {
    "uuid": "4fdee6d9-58e6-58be-9b09-d5354a4c2c44",
    "entry": "棄背",
    "reading": {
      "primary": "きはい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "giving up and turning back",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "雪山での遭難の危険を感じ、頂上を目前にしながらも棄背する苦渋の決断を下した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "敵軍の圧倒的な戦力を前に、将軍はこれ以上の損害を避けるため即座に棄背を命じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "道が完全に崩落していることに気づき、我々は断腸の思いでその場から棄背した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "まひる利根川のほとりを歩めば、二人歩めばしばなくつぐみ、つぐみの鳴くに感じたるわが友のしんじつは尚深けれども、いまもわが身の身うちよりもえいづる、永日の嘆きはいやさらにときがたし、まことに故郷の春はさびしく、ここらへて山際の雪消ゆるを見ず。",
              "citation": {
                "source": "利根川の岸邊より",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんた、何でもあたしの方から仕向けなければ……狡いのか、意気地なしなのか、どっちなのよ」　小初の言葉のしんにはきりきり真面目さが透っていながら手つきはいくらかふざけたように、薫の背筋の溝に砂をさあっと入れる。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしはよくよく子供に運がない」　おまきはいつも愚痴をこぼしていたが、それでも末っ子の七之助だけは無事に家に残っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ大変と思ってタネリが急いで眼をはなしましたがもうそのときはいけませんでした。",
              "citation": {
                "source": "サガレンと八月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああはたして仁なりや、しかも一人の渠が残忍｜苛酷にして、恕すべき老車夫を懲罰し、憐むべき母と子を厳責したりし尽瘁を、讃歎するもの無きはいかん。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "入用なときはいつでも「預かり証」と引き換えに持って帰ることができるのである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は汽車旅行をするときはいつでも二十万分一と五万分一との沿線地図を用意して行く。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀れいずくの誰ぞや、指してゆくさきはいずくぞ、行衛定めぬ旅なるかも。",
              "citation": {
                "source": "たき火",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はい、もう泣きはいたしません。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼくは小さいときはいつでもいまごろ野原へ遊びに出た。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の間には海から陸へ移って行き夜には陸から海へ行ってたねえ、大抵朝は十時｜頃海から陸の方へかけぬけるようになっていたんだがそのときはいつでも、うまい工合に気象台を通るようになるんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜のおせきはいつもよりも綺麗に化粧しているのが、月のひかりの前にいっそう美しく見えた。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘の前にはガラス鉢が置いてあって、金魚が四ひきはいっていました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷車曳きはいつもの倍もある荷物を売って、お金を沢山に儲けました。",
              "citation": {
                "source": "二人の男と荷車曳き",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち復一の内部から融かすものがあって、おやと思ったときはいつか復一は自分から皮膚感覚の囲みを解いていて、真佐子の雰囲気の圏内へ漂い寄るのを楽しむようになっていた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそのときはいってやりなさい。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まきはいきり立つて「この子たち口減らずといつたら――」まきの憤慨してゐる様子が私にも想像されたが、すべてのものから孤独へはふり捨てられたこの老女は、やはり不人情の一言には可なり刺激を受けたらしい。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも迷惑をせば、いたせ、娘の親が人間同士の間でさえ、自分ばかりは、思い懸けない海の幸を、黄金の山ほど掴みましたに因って、他の人々の難渋ごときはいささか気にも留めませぬに、海のお世子であらせられます若様。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "美女　いいえ、歎きはいたしません。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんは、私と二人きりのときはいいけれど、お客が来たときには、へんに私から遠くなって、冷くよそよそしく、私はそんな時に、一ばんお父さんが懐かしく悲しくなる。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡弓弾きはいきなり胡弓を鳴らしながら賑やかに閾をまたいではいってゆかねばならないのだが、木之助は知らずに、「ごめんやす」と言ってはいっていった。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（謹んで承ります、一点といえども相背きはいたしますまい。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "妬きはいたさじ、何とも申さじ。",
              "citation": {
                "source": "彌次行",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "起きあがろうとする馬のもがきはいたましい。",
              "citation": {
                "source": "馬地獄",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧しきはいとなみぬ、空あふぎて。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "聲はあがる彌榮紀元二千六百年壽詞聲はあがる、彌榮、とどろきはいやあがる、彌榮とぞ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "聲はあがる、彌榮、とどろきはいやあがる、彌榮とぞ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここより望むべきザックセン平野のけしきはいかに美しくとも、茂れる林もあるべく、深き淵もあるべしとおもはるるこの少女が心には、いかでか若かむ。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここより望むべきザックセン平野のけしきはいかに美しくとも、茂れる林もあるべく、深き淵もあるべしとおもわるるこの少女が心には、いかでか若かむ。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
