[
  {
    "uuid": "6e5d094a-9164-5f8f-833c-ff362f7b01b0",
    "entry": "気はない",
    "reading": {
      "primary": "きはない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "形容詞"
      ],
      "ctype": null,
