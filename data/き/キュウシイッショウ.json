    "definitions": [
      {
        "index": 1,
        "gloss": "narrow escape from the jaw of death",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
