[
  {
    "uuid": "7c576753-1b10-5e5d-8781-066478455a3e",
    "entry": "教練",
    "reading": {
      "primary": "きょうれん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "drill",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新兵たちは毎日厳しい教練に励んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このドリルは、兵士の規律を養成するための教練だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "サッカーチームは、試合に備えて戦術教練を重ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もっと集中しろ！教練は甘くないぞ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "軍事教練の査閲のときに、校長先生に敬禮！",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと実験の教授というものは、軍隊の教練や昔の漢学者の経書の講義などのように高圧的にするべきものではなく、教員はただ生徒の主動的経験を適当に指導し、あるいは生徒と共同して新しい経験をするような心算ですべきものと思う。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "云わば実戦に堪える体力を養ってくれた教練のようなものであったのである。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は寝床に起きあがると中年女の壮烈な教練を始めた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホワイトマンによって教練された女達のなかにまじって、十九世紀の万国旗に包まれた太田ミサコが船出する。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "教練の度毎にヘマをやつて小隊長や分隊長に小言を云はれ續けだつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、彼はムキになればなるだけ教練や武術に失敗し、上官達に叱りつけられ、戰友達にはなぶり物にされるのだつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中隊教練が濟んで一先づ解散すると、分隊長の高岡軍曹は我々を銃器庫裏の櫻の樹蔭に連れて行つて、「休めつ‥‥」と、命令した。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎朝点呼から消燈時間まで、勤務や演習や教練で休むひまがない。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "留置場で五六日を過して、或る日の真昼、俺はその留置場の窓から脊のびして外を覗くと、中庭は小春の日ざしを一杯に受けて、窓ちかくの三本の梨の木はいずれもほつほつと花をひらき、そのしたで巡査が二三十人して教練をやらされていた。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、背後から突き刺す男のごたぶんにもれず、クラスで最も貧弱な肉体をして、顔も青ぶくれで、そうしてたしかに父兄のお古と思われる袖が聖徳太子の袖みたいに長すぎる上衣を着て、学課は少しも出来ず、教練や体操はいつも見学という白痴に似た生徒でした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝から、もういい加減に腐っていたら、午後になって僕が教練に出ようとして、ふと、ゲエトルを忘れて来たのに気附いて、あわてて隣りのクラスに行き、一時間だけ貸してくれるように、三人の学生にたのんだけれど、どの学生も、へんに、にやにや笑って、そうして返事さえしない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は教練を欠席して、そのまま家へ帰った。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "教練を済ませて、鉄砲の油と革の交った匂をかぎながら、銃器庫の方へ帰って行くとき、彼はいつも、その場所に、細い青い葱が植わっているのを見たようであった。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何年か前、夏の教練に疲れた三造は、よく其処の水を手ですくって飲んだものであった。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中隊若しくは大隊教練であつて、其嚮導を務める人は在郷軍人である。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスの馬は皆、馬教練所の卒業生ですって、｜進め、｜止れ、右、左、散歩………。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "演習というよりは教練だった。",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その教練の始まる前だった。",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに今日は最初の連合教練なのだった。",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなく教練が始まった。",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "教練の整列が崩れるのを待っていて、平三は清次郎を掴まえた。",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当夜は普段通り馬の教練と水飲みを終えて、九時には厩舎を閉めている。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "善く教練して絆がざるに去らず。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "インドの野猪は日本や欧州のと別種だが、やはり共同して勇戦すると見え、カウル英訳『仏本生譚』巻二と四に、大工が拾い育てた野猪の子が成長して野に還り、野猪どもに共同勇戦の強力なるを説いて教練し、猛虎を殺し、またその虎をして毎に野猪を取り来らしめて、分ち食うた仙人をも害した物語を出して居る。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "古スパルタ人は万事軍隊式で、豕までも教練厳しく行われその動作乱れず、鈴音に由って整然進退したとマハッフィの一著書で読んだが今その名を記憶せぬ。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本古来の武士道的教練も、中世フランス式教練も、古代スパルタも、論語孟子も、夫々独自であると同様に一味相通ずる「スタビリチイ」の精神に、新旧の差別なんてある筈はない。",
              "citation": {
                "source": "余の倅に就いて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "左うなると鼠軍の気勢は益々あがつて、昼間のうちから上甲板に勢ぞろひをして教練を試みたり、帆柱や帆綱に昇つて面白さうな運動を始めたりして、何も怖るゝものはないといふやうな始末となりました。",
              "citation": {
                "source": "船の中の鼠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに彼等の話題は教練のことに移って行った。",
              "citation": {
                "source": "翳",
                "author": "原民喜",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
