    "definitions": [
      {
        "index": 1,
        "gloss": "to be decided",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大正十四年八月頃、いよいよ詩を専心しようと大体決まる。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日ばかりして家が決まると旅館を出てその方へ越した。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は私と主人との結婚話が決まると、その日から灰吹掃除を書生に代ってやらせた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "明后日までにすっかり決まるのだ。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先発宿｜定めの佐十さんが南摩ホテルで拒絶され、釜屋で門前払いを食い、ようやくにして佐野屋という変梃な家の二階と決まる。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三人種田君の銀座の事務所に集まるとすぐ相談は決まるのであつた。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "座敷へ案内されて、まず自分の居どころが決まると、携帯の荷物をかたづけて、型のごとくに入浴する。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜといえば、前川は、小さい椅子にかけて、葉巻をくゆらせながら、開店景気とはいえ、この二日間の売上げの好かったことを話し、でもこれが当分続くとしても、やがて常連だけになり、そこで初めて店の収入が決まるというような、その場合の新子の気持とは、およそそぐわない話をし始めたからである。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鉄砲が鳴ったって熊とは決まるめえ」「熊でも出たんじゃないと、だれもこの夜中に鉄砲など撃つ者はあんめえが……」　彼らは暗がりの中に動きながら、周囲を見回した。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり崑崙山脈までの距離の遠し近しによって、出発の早し遅しが決まるのだそうですが、その行列というのが又スバラシイ観物だそうです。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに因っておまえの罪の重い軽いも決まるのだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雷獣と蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、山がユラユラッとして、地が呻いて、辷り出してしまうと、すっかり腹が決まるもんだね』『山は来るんだ。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「里分かぬかげを見れども行く月のいるさの山を誰かたづぬる　こんなふうに私が始終あなたについて歩いたらお困りになるでしょう、あなたはね」「しかし、恋の成功はよい随身をつれて行くか行かないかで決まることもあるでしょう。",
              "citation": {
                "source": "源氏物語",
                "author": "末摘花",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の官吏の昇任の決まる日であったから、大臣も参内したので、子息たちもそれぞれの希望があってこのごろは大臣のそばを離れまいとしているのであるから皆続いてそのあとから出て行った。",
              "citation": {
                "source": "源氏物語",
                "author": "葵",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の意志で決まることである、謝絶すればしいてとはお言いにならないはずである、自分がしっかりとしていればよいのであると、こんな気も明石はしたが、約束を変更することなどは軽率に思われることであると反省した。",
              "citation": {
                "source": "源氏物語",
                "author": "薄雲",
                "note": "青空文庫"
              }
            },
            {
              "text": "○中村暉氏――彫刻『少年道化』の良心的態度は支持されていゝものがある、作者の感情の美しさが無条件的に作品に現れてゐる、芸術家といふものは結局は精神上の叡智に依つて勝負けが決まるものであるから、中村氏のやうな聡明な行き届いた神経の下につくられた作品は最後的な勝に帰するだらう。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "島田良助氏――『夏蔭』度胸のある作家だ、度胸で負けるか、度胸で勝つかは芸術家の運命の決まるところだらう。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして古人の作は参考品としたら、さらに興味が深いであろうという議が起りまして、それが決まると、早速｜築地本願寺で開会することになった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "竜池会の起ったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしの慈悲が肝に銘じたならば、逃ぐるようなこともあるまいによって、流罪のおさばきが決まるまでこのまま当屋敷に起きふしをさし許すから、その間にじゅうぶん島へ渡るしたくなど整えておくがよいぞ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなりの順序が決まると、第一に忙しいのは、むろんのことに沿道沿道の警固に当たる面々ですが、それにつづいて多忙をきわめるのは、吉祥寺裏のお鷹べやで、お鷹のご用を承っている鷹匠たちです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギターでバンドのいい悪いが決まるんなら、じゃあ、ビートルズはなんだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "最終的な期は、卒業年度によって決まる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによって、判決が決まるわけである。",
              "citation": {
                "source": "母たち",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう風に話が決まると、二人とも何んだか急にぎこちなくなり、話が途切れてしまった。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "入ると決まるとさすがに可哀相だった。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一寸言葉を切って、「この一気が、一気になるか二気になるかで、勝ち負けが決まるんじゃないかな……？",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴女から見れば、十五六歳も年上の保昌殿ではあつたでせうけれど、貴女の御身の決まることは貴女に連なる他の方の心を安く守つて上げる事、到底この世に追つて得られぬ戀の理想であるならば、保昌殿程の威勢ある人の正妻として、其の位置が決まることの方がどの樣によい事であつたか、私はそれを思うたのですよ。",
              "citation": {
                "source": "誠心院の一夜",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたがた殿上の形勢は相手方の勝利にかたむいて、玉藻はいよいよ采女に召さるることに決まるらしいと、泰忠は残念そうに話した。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてサムボリスムなる名称のきまるまで、その一派は「デカダン派」を以て自称してゐることを思い合せて貰はう。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがそこは芝居であるからこのミルクホールの店先を肝心の夕刊嬢が丁度そのときまるで打合せておいたように通りかかる。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
