[
  {
    "uuid": "6576c47a-21b7-5342-9f64-e3786b647570",
    "entry": "季節風",
    "reading": {
      "primary": "きせつふう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
