    },
    "definitions": [
      {
        "index": 1,
        "gloss": "seasonal winds",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "シベリアから吹き下ろす冷たい季節風が、日本海側の山沿いに記録的な大雪をもたらしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ひえ〜、この強い季節風に逆らって自転車を漕ぐのは、トレーニングだと思わないとやってられないよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "湿った南東の季節風が吹き始めると、いよいよこの島にも蒸し暑い夏がやってくる合図だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そしてそれに紅白、あるいは紺と白と継ぎ分けた紙の尾を幾条もつけて、西北の季節風に飛揚させる。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つの因子というのは、季節季節でその地方一帯を支配している地方的季節風と名づくべきもので、これは一日中恒同なものと考える。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高知は毎時観測の材料がなくて調べなかったが、広島や大阪では、前記の地方的季節風が比較的弱くて、その代りに海陸風がかなり著しく発達している、そうして夕方から夜へかけては前者が後者と相殺する、そのために夕凪がかなりはっきり現れる、そうして海陸の位置分布の関係でこの凪の時間が異常に引延ばされるらしい。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して東京の夏には地方的季節風が相当強い南東風として発達しているためにそれが海陸風と合成され、もしこれがなければべた凪になるはずの夕方の時刻に涼しい南東がかった風を吹かせるらしい。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その同じ季節風が朝方には陸風と打消し合って朝凪を現出することになるのである。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "低気圧が近づいて来るとその影響で正常な季節風が狂って来る。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし低気圧がもう一層近くなってそれが季節風を消却してなおおつりの出る場合には、夕風は夕風でもいつもとは反対の夕風が吹くのである。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "南洋では年じゅう夏の島がある、インドなどの季節風交代による雨期乾期のごときものも温帯における春夏秋冬の循環とはかなりかけ離れたむしろ「規則正しい長期の天気変化」とでも名づけたいものである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って夕なぎが完全に行なわれるためには、低気圧による風や、また季節風のごときが邪魔をしない事が必要条件である。",
              "citation": {
                "source": "海陸風と夕なぎ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏期｜瀬戸内海地方で特に夕なぎが著しいのはどういうわけかと思って調べてみると、瀬戸内海では、元来どこでもいったいに強くない夏の季節風が、地勢の影響のために特に弱められている。",
              "citation": {
                "source": "海陸風と夕なぎ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月ごろの東京の風の一日じゅうの変化を調べてみると、やはり海陸風に相当する規則正しい風の周期的変化があるが、ただ東京では日々変化の位相が著しくくずれているのと、夏期の南東の季節風がかなりよく発達しているために、夕なぎに相当する時刻にはこの季節風のほうが著しく現われて来るのである。",
              "citation": {
                "source": "海陸風と夕なぎ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに日本の沿岸ではいかなる季節でも、風の日々変化するのを分析すると、海陸風に相当する風の弛張がかなり著しく認められるが、実際にいわゆる海陸風として現われるのは、季節風の弱い時季か、あるいは特別な気圧配置のために季節風が阻止された場合である。",
              "citation": {
                "source": "海陸風と夕なぎ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがもういっそう大仕掛けになって、たとえばアジア大陸と太平洋との間に起こるとそれがいわゆる季節風で、われわれが冬期に受ける北西の風と、夏期の南がかった風になるのです。",
              "citation": {
                "source": "茶わんの湯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ゆえにこのような区域に、特に降水が多いかという理由について、筒井氏の説を引用すると、冬季日本海沿岸に多量の降雨をもたらす北の季節風が、若狭近江の間の比較的低い山を越えて、そして広い琵琶湖上から伊勢湾のほうへ抜けようとする途中で雪を降らせるというのであるらしい。",
              "citation": {
                "source": "伊吹山の句について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "實際、季節風（Monsoon）といふものゝない西洋には、「春風」もなければ「秋風」もない。",
              "citation": {
                "source": "天文と俳句",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋も稍更けて北西の季節風が次第に卓越して來ると本州中部は常に高氣壓に蔽はれて空氣は次第に乾燥して來る。",
              "citation": {
                "source": "天文と俳句",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の色も空の模様も、もうすっかり様子が変わり、西北の季節風が氷のような冷たさを含んで船橋のあたりから吹き下ろしてくるのだった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「つまり、仰言る意味の風は、季節風でしょうね。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "季節風の影響のない五、六月中に、探検を完了するというのが既定の計画だとしたら風の影響などは何もないじゃないですか。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ、驚異の征服をなし遂げた、引き上げ時にですね、季節風の猛雨くらいあるほうが、劇的でいいですよ。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、季節風以外にも、風の問題はあるよ」　と、きっぱり言われてもパミールの辺りで、風の問題といえば季節風以外にはない。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに反して、季節風の猛雨が始まったら登行をするという、この折竹の説は暴論といおうか、まことに、常識外れの馬鹿馬鹿しいものだった。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "季節風前によくあるクッキリと晴れた日で、氷河の空洞のほんのりとした水色や森のように林立する氷の塔のくぼみが……美麗な緑色を灯したところは灯籠のように美しい。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "（十一月二十日）新嘉坡　快い北東の季節風に吹かれ、御納戸色の絹を展べた様な静平な海面を過ぎながら、十一月二十五日の朝蘭領のアノムバ島を左舷に見た。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、「湖水や海の水が、冬になって表面から冷えて行くときにはどんな流れが起るか」という問題にも関聯し、また飛行家にとって重大な問題である突風の解釈にも導かれ、更に進んでは海陸風や山谷風、また大東亜の空を吹く季節風にまでも、拡張されて行くのである。",
              "citation": {
                "source": "「茶碗の湯」のことなど",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし日本海から吹きつけて來る冬の季節風をまともに受ける難所である。",
              "citation": {
                "source": "冬ごもり",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
