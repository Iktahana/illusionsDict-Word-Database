    "definitions": [
      {
        "index": 1,
        "gloss": "boundlessness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "桑折、苅田、岩沼、丸森などの処々、斯様いう目を見たのであるから、蒲生家の士の正望の書いたものに「憎しということ限り無し」と政宗領の町人百姓の事を罵っているのも道理である。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが愛欲わが愛欲は限り無し、今日のためより明日のため、香油をぞ塗る、更に塗る。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "名をすら知らぬ草ながら、葉の形見れば限り無し、さかづきの形、とんぼ形、のこぎりの形、楯の形、ペン尖の形、針の形。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また葉の色も限り無し、青梅の色、鶸茶色、緑青の色、空の色、それに裏葉の海の色。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "我等の愛は限り無し、自然、道徳、学の愛、家庭、交友、国の愛、国の内外の人の愛。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉体的とも精神的とも分野をつき止めにくいあこがれが、低気圧の渦のように、自分の喉頭のうしろの辺に鬱して来て、しっきりなしに自分に渇きを覚えさせた。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷たいものがしきりなしに顔に当る。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜花が、しっきりなしにそれらの上へ散りかかります。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも我々自身の運命が我々の裡でひつきりなしにより明らかであると同時により目には見えないものとなつてゆくやうに。",
              "citation": {
                "source": "ドゥイノ悲歌",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな乘合がしつきりなしに鳴つてゐる。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、月｜給の上る見込みもなかつたし、ボオナスも減るばかりの上に、質屋や近しい友｜達からの融通もさうさうきりなしとは行かなかつた。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遍路が、細い山路を引っきりなしに鉦をならして通る。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄管から漏れる圧搾空気だけがシューと引っきりなしに鳴っていた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度だつて惡寒から熱、惡寒から熱といふしつきりなしのすきをねらつて――しかし今はもう惡寒はやみましたから御安心下さいまし――すきをねらつてといふよりもすきを掠奪して、よく手紙を書きます。",
              "citation": {
                "source": "水野仙子氏の作品について",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にもならないで、ばたりと力なく墓石から下りて、腕を拱き、差俯向いて、ぢつとして立つて居ると、しつきりなしに蚊が集る。",
              "citation": {
                "source": "星あかり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の空や通りはまるつきり白だか水色だか変にばさ／＼した雪の粉でいつぱい、風はひつきりなしに電線や枯れたポプラを鳴らし、鴉なども半分凍つたやうになつてふら／＼と空を流されて行きました。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "杯盤の間に於ても暗闘と暗闘とがひつきりなしにつづく。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペンネン技師からはひっきりなしに、向こうの仕事の進み具合も知らせてよこし、ガスの圧力や山の形の変わりようも尋ねて来ました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寢られないほど、ひつきりなしに、けたゝましく鳴立てたのである。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山口の農具展覧会行だらう、自転車と自動車とがひつきりなしにやつてくる。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の二三日｜絲のやうな小雨がひツきりなしに降續いて、濕氣は骨の髓までも浸潤したかと思はれるばかりだ、柱も疊も惡く濕氣て、觸るとべと／＼する。",
              "citation": {
                "source": "青い顏",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の二三日絲のやうな小雨がひツきりなしに降續いて、濕氣は骨の髓までも浸潤したかと思はれるばかりだ、柱も疊も惡く濕氣て、觸るとべと／＼する。",
              "citation": {
                "source": "青い顏",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "魔法使いは、ひっきりなしに、なべの中に新しいものを入れました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ひっきりなしにうなずきました。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、そのあいだも、ひっきりなしに、鉄砲のたまが、アシの中へとんできて、ザワザワと音をたてました。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "アヒルの子は、水の面がすっかりこおってしまわないように、ひっきりなしに、泳ぎまわっていなければなりませんでした。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、おばあさんがお話をすると、ひっきりなしに、「だって、だって」と言っては、口をはさみました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "前のほうを見ると、人のかげが、ひっきりなしに、ふわふわと通りすぎていきます。",
              "citation": {
                "source": "お墓の中の坊や",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "いなずまは、ひっきりなしにピカピカ光り、かみなりは一晩じゅう、ゴロゴロ鳴りつづけました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして無茶先生と一所に大急ぎでそちらへ近づきましたが、やがてとある崖の上へ出ますと、向うは一面の田圃で、すぐ眼の下には川が青々と流れて、その流れに沿うた道ばたの一軒の家から、最前の鉄槌の音が引っきりなしにきこえて来ます。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
