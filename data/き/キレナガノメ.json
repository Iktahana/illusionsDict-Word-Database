          "literary": [
            {
              "text": "どこからそうした媚びを得て来たものか知れなかったが、彼の切れ長の目は絵巻の小姓のそれのような冴えを持っていた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたとももう逢われなくなるのねえ」　お高祖頭巾のなかの切れ長の目が、いつしかシットリ潤んでいた。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「立派だこと」　お八重は切れ長の目を潤ませていた。",
              "citation": {
                "source": "圓太郎馬車",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の前に坐っている娘が、切れ長の目の可愛らしい少女であり、それがいまはやさしい穏やかな瞳でじっと私をみつめているのに、私は長いこと気がつくこともなかった。",
              "citation": {
                "source": "軍国歌謡集",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "音さしたらいかん」　マスノがうすいくちびるをそらして、少しつった切れ長の目にものをいわせると、竹一や正までが声もからだもひそめてしまった。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
