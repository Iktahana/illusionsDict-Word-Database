    "definitions": [
      {
        "index": 1,
        "gloss": "golden wedding (anniversary)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
