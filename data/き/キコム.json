[
  {
    "uuid": "53e76bbb-a673-53ee-b5df-2bb3e60b4682",
    "entry": "着込む",
    "reading": {
      "primary": "きこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
