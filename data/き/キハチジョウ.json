[
  {
    "uuid": "59281c5f-b5d3-57d4-89ec-7de74547f083",
    "entry": "黄八丈",
    "reading": {
      "primary": "きはちじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "yellow silk cloth with a dark striped or checkered pattern (from Hachijo island)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女が成人式で着ていたのは、珍しい黄八丈の振袖で、会場でもひときわ目を引いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "八丈島を訪れた際、伝統工芸である黄八丈の機織り体験に参加したんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "アンティークショップで、粋な黄八丈の帯を見つけて、衝動買いしてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "黄八丈、蚊がすり、藍みじん、麻の葉、鳴海しぼり。",
              "citation": {
                "source": "古典竜頭蛇尾",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩幅の広いのが、薄汚れた黄八丈の書生羽織を、ぞろりと着たのは、この長屋の主人で。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と黄八丈が骨牌を捲ると、黒縮緬の坊さんが、紅い裏を翻然と翻して、「餓鬼め。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　娘客の白い指の、指環を捜すように目で追って、「中坂下からいらっしゃいます、紫｜鹿子のふっさりした、結綿のお娘ご、召した黄八丈なぞ、それがようお似合いなさいます。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽織は黄八丈である。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄八丈のどてらの上に白縮緬の兵児帯、鳥打帽に白襟巻、それに赤皮の編上靴といふ全く独創的な出で立ちで本町の人通りを歩いて居ることもあつた。",
              "citation": {
                "source": "蓑田先生",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "掻巻はいつも神月と添寝した五所車を染めた長襦袢を裁ったのに、紅絹の裏を附けて、藤色｜縮緬の裾廻、綿も新しいのをふッかりと入れて、天鵝絨の襟を掛けて、黄八丈の蒲団を二枚。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄八丈の着物をきて藤色の頭巾をかぶって……」　白子屋のお熊が引廻しの馬の上に黄八丈のあわれな姿をさらしてこのかた、若い娘の黄八丈は一時まったくすたれたが、このごろは又だんだんはやり出して、出世前のむすめも芝居で見るお駒を真似るのがちらほらと眼について来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "襟付の黄八丈に緋鹿子の帯をしめた可愛らしい下町の娘すがたを、半七は頭のなかに描き出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ、ほんの僅かの間で、おかみさんが奥の八畳の居間に坐っていると、襖が細目に明いたらしいので、何ごころなく振り向くと、かの黄八丈の綿入れに藤色の頭巾をかぶった娘の姿がちらりと見えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "お菊はやはり黄八丈を着て、藤色の頭巾をかぶっていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七は上がり框から少し伸びあがって窺うと、四畳半の壁には黄八丈の女物が掛かっているらしかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "四畳半の襖の間からよく視ると、壁にかかっている女の着物は確かに黄八丈で、袖のあたりがまだ湿れているらしいのは、おそらく血の痕を洗って此処にほしてあるものと想像された。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの黄八丈は小柳のかい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの黄八丈は菊村の娘のだろうな。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘を潮来へやるときに、売物には花とかいうんで、着ていた黄八丈を引っぱがして、小柳のよそ行きと着換えさせてやったもんですから、娘の着物はそっくりこっちに残っている」「むむ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "その黄八丈の着物と藤色の頭巾で、小柳が娘に化けて菊村へ忍び込んだな。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを首尾よく仕負うせれば、お前もお暇になる代りに、十両のお金と別にお嬢さんの黄八丈のお小袖を下さる。",
              "citation": {
                "source": "黄八丈の小袖",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、お久は黄八丈という詞に少し力を入れて低声で云い聞かせた。",
              "citation": {
                "source": "黄八丈の小袖",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お熊の黄八丈の小袖が群集の中でも眼についた。",
              "citation": {
                "source": "黄八丈の小袖",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お久はそれを能く記憶していて、今度の褒美に黄八丈の小袖を懸けたのであった。",
              "citation": {
                "source": "黄八丈の小袖",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "十両の金よりも、黄八丈がお菊の魂を唆かした。",
              "citation": {
                "source": "黄八丈の小袖",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時に彼女は黄八丈の小袖も欲かった。",
              "citation": {
                "source": "黄八丈の小袖",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分を睨んでいる若旦那の怖い顔や、泣いて自分に頼むような若いお内儀さんの痛々しい顔や、むずかしそうな在所の両親の顔や、十両の小判や、黄八丈の小袖や、それが走馬燈のように彼女の頭の中をくるくると廻った。",
              "citation": {
                "source": "黄八丈の小袖",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "牢にいる間に、お熊は窃とお菊に約束して、もしお前が命を助かったらば、妾の形見として黄八丈の小袖を遣ろうと云った。",
              "citation": {
                "source": "黄八丈の小袖",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前がお仕置に出る時には、あの黄八丈を召して下さい。",
              "citation": {
                "source": "黄八丈の小袖",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お熊が引廻しの裸馬に乗せられた時には、自分の家から差入れて貰った白無垢の上に黄八丈の小袖をかさねて、頸には水晶の珠数をかけていた。",
              "citation": {
                "source": "黄八丈の小袖",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから江戸中の人の眼に晒されようとするお熊が黄八丈の姿を、お菊は牢格子の間から夢のように見送った。",
              "citation": {
                "source": "黄八丈の小袖",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
