        "examples": {
          "standard": [
            {
              "text": "臓器移植の成功は、拒絶反応をいかに抑えるかにかかっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の体は移植された心臓に対し、激しい拒絶反応を示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "医療チームは、患者の拒絶反応の兆候を注意深く監視していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "拒絶反応を抑えるための薬は、副作用も考慮して処方される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "新聞学科の僕に言わせれば、トランジスタだとかＩＣなんて単語は、聞いただけで拒絶反応を起こしかねないよ」「大したことないさ」「そうかなあ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
