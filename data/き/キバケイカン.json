          "standard": [
            {
              "text": "イギリスのパレードでは、凛とした表情の騎馬警官たちが馬のリズムに合わせて通りを行進していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「馬の上からだと視点が高いから、群衆の様子がよく見えるんだよ」と現役の騎馬警官が教えてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "公園の広場で見かけた騎馬警官に、観光客が笑顔で写真を撮らせてほしいと頼んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "胸甲をつけた騎馬警官が監獄の門の両側に分れ、キチンと馬首をそろえている間からランドリュが出てきて、襟のないシャツとズボンだけの姿で、素足で舗石を踏みながらギロチンのほうへ歩いて行った。",
              "citation": {
                "source": "青髯二百八十三人の妻",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
