    "definitions": [
      {
        "index": 1,
        "gloss": "hole cut in a wall, panelling, etc. to let light in",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――母親は、風呂敷のように皺ッぽい、たるんだ乳房を赤子の口にふくませながら、小さい切り窓から雨の外を、うつろに見ていた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月に、東京からそちらへゆく前、面会所の切り窓から「まあ半年か、長くて十ヵ月の疎開だね」と云って笑った重吉。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "切り窓の障子が明るんでいて、隅のほうにくろが一人、掛け蒲団を頭までかぶって寝ており、まん中の広いところでは、十幾人かの子供たちが、もちゃくちゃにした夜具の上で暴れていた。",
              "citation": {
                "source": "ちいさこべ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長押には槍、床には紫の杜若、白衣観世音の軸へ、切り窓から朝か夕かわからぬが、とにかくこの世の光が射していた。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い所に、角な切り窓が一つあるほか、明りの入る坪縁もなく通い廊もなかった。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、帝の方はどうお凌ぎかとみれば、そこのお囲いには、板壁の高い所に、小さい角な切り窓がただ一つあった。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんの顔だけを出せるぐらいな切り窓が一つ開いているだけだった。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
