          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大航海時代、多くの探検家が喜望峰を越えることに挑んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "喜望峰はアフリカ大陸の最南西端に位置し、美しい景観で知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "過去には、喜望峰沖の荒波で多くの船が遭難したという歴史がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "観光客は喜望峰からの壮大な海の眺めに感動していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "アンドリウ・スミス男喜望峰で見たは、一士官しばしばある狗頭猴を悩ます、ある日曜日その士盛装して来るを見、土穴に水を注ぎ泥となし、俄に投げ掛けてその服を汚し傍人を大笑せしめ、爾後その士を見るごとに大得色を現じた由。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "シップは喜望峰狗頭猴、下より来る敵を石などを集め抛下して防ぐといい、ダムピエート・ウェーファーは猴が石で牡蠣を叩き開くを記す。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "この花の原産地は阿弗利加の喜望峰だといふ事だが、あれなぞも何処かの男が禅坊主にでも食べさす積りで持つて来たものかも知れない。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠く喜望峰を経由して、印度洋から東洋の港々を帰って行く長い航海の旅を択ぼうか。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "倫敦を出発してから喜望峰に達するまで、彼は全く陸上の消息の絶え果てた十八日の長い間を海上にのみ送って来た。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「百点、Ａ１」としてパスしたが、Ｂ・Ａ・Ｌの意向では、この船は喜望峰廻り濠洲行きの、主として移民船に設計した関係上、内務省移民局の検査も受けなければならない。",
              "citation": {
                "source": "沈黙の水平線",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二年前、喜望峰の波止場で、朝霧の立ち込めた穏やかな海上を大きな水禽が群れをなして水とすれすれに翔んでいた光景を思い出す。",
              "citation": {
                "source": "暴風雨に終わった一日",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって喜望峰のテーブル山の景色と、現世にいない両親や伯母やイサベルのことを、さっきと同じく何物にも乱されずにぼんやりと思いつづけていた。",
              "citation": {
                "source": "暴風雨に終わった一日",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカの發見、喜望峰の廻航は、この新興のブルジョアのために新しい地盤をつくり出した。",
              "citation": {
                "source": "共産黨宣言",
                "author": "カール・マルクス",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペリイの取った航路は合衆国の東海岸からマデイラ、喜望峰を迂回して、モオリシアス、セイロン、シンガポオルを経、それからシナの海を進んで来たものと言われるが、遠くアナポリスから極東への船旅に上る前に、彼にはすでに長いしたくがあったという。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "このペリイが前発の二｜艘の石炭船を喜望峰とモオリシアスとに送らせるほどの用意をしたあとで、四隻の軍艦を率いて遠航の途に上ったのだ。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ使節一行は、日本退帆後、七月十一日琉球那覇着、同十九日に那覇出帆、アメリカ東印度艦隊根據地の上海から香港を經て、カープホーレルと譯されたケープトーンつまり喜望峰を※つて本國に歸つた。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「喜望峰を廻って行くとその位だそうです。",
              "citation": {
                "source": "丸の内",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "千四百九十七年、葡萄牙の船将ワスコ・デ・ガマが喜望峰を廻りて印度に進みしより、葡萄牙は東洋貿易の魁となり、麻剌加を略し、支那南岸に立脚の地を求めんとし、遂に天文十年（千五百四十一年）七月風波は葡萄牙船を漂わして、豊後神宮浦に着せしめたり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルジェリアから始めて、コンゴを通り、南端の喜望峰まで、主なところは全部廻ったそうである。",
              "citation": {
                "source": "桃林堂の砂糖づけ",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前に、『イグアノドンの唄』という大人のための童話を書いたことがあるが、その中の主人公の一人、すなわち南アフリカ喜望峰の一角に突如として出現した一億年前の化石魚シーラカンスなども、もちろんその一つである。",
              "citation": {
                "source": "異魚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高慢ですぐ激昂し、怒ったときはぞっとするような悪相になる」　一八一八年の春、植民大臣バザースト卿の甥が、喜望峰の帰りにセント・ヘレナへ寄った。",
              "citation": {
                "source": "フランス伯Ｎ・Ｂ",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いたるところ掲示板だらけで、ナポレオンの逃亡を援助したるものは死刑、とか、現金にならざればいかなる物品も売るべからず、とか、書信の仲介、または授受したるものはアフリカ喜望峰植民地へ追放に処す、そういった布告がベタベタと貼ってあります。",
              "citation": {
                "source": "フランス伯Ｎ・Ｂ",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "サヴァリー将軍とグウルゴオ将軍夫妻は、総督に至当の敬意を表さなかったという理由で英国へ送られ、ド・ラッス・カーズ伯はスコットという従僕にロンドンの銀行宛の手紙を託したというだけで逮捕され、父子もろとも喜望峰へ追いやられてしまった。",
              "citation": {
                "source": "フランス伯Ｎ・Ｂ",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "前任のオミラーが、ナポレオンに新聞を届けたというので喜望峰監獄へ送られたという話。",
              "citation": {
                "source": "フランス伯Ｎ・Ｂ",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "英領南アフリカ喜望峰の近くに、東倫敦という小さい漁港がある。",
              "citation": {
                "source": "イグアノドンの唄",
                "author": "――大人のための童話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを地質年代の錯誤と早まってはいけないので、同じ時代の空棘魚が、喜望峰州の住民と、先年ちゃんと対面をしているのである。",
              "citation": {
                "source": "イグアノドンの唄",
                "author": "――大人のための童話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "跋渉濠陽山又河、秋風今日向南阿、不知喜望峰何在、船破雲烟暗処過。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜望峰がどこにあるかはわからぬが、船は雲かすむほの暗さを破るようにして行くのである。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "）二七、喜望峰行　十三日、快晴（満月）。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "欲入南阿訪旧蹤、狂風捲海怒濤衝、檣頭認得青如髪、山是当年喜望峰。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆柱の上に青みが髪のごとく見え、その山こそがむかしの喜望峰である。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "）波あらき大海原の沖越えて、喜び望む峰に来にけり大海のながめにあきて見る山は、昔も今も喜望峰なり　また、喜望峰懐古の一首を得たり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "一帆船が七十年前にすすんだ路は、生も死も風にまかせて喜望峰に入ったのである。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
