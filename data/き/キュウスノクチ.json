        "examples": {
          "standard": [
            {
              "text": "急須の口を洗うときに欠かないように注意してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "急須の口の繊細なデザインが、滑らかな注ぎを可能にしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この急須の口からはお茶が完璧に注げるわ」と彼女は満足そうに言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼はアンティーク急須の職人技、特にそのエレガントな急須の口を称賛した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「気をつけて、少しずつ啜るんだ」と登は注意を与えた、「急須の口からじかのほうがいい、用心しないと喉にしみるよ」　おふみは顔をするどく歪めたが、噎せはしなかった。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "鶯ばか",
                "note": "青空文庫"
              }
            }
          ]
        }
