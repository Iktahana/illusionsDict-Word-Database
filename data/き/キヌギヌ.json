  {
    "uuid": "377d3117-2cbc-5183-8853-0b8d67c2711a",
    "entry": "衣々",
    "reading": {
      "primary": "きぬぎぬ",
      "alternatives": [
        "こうちょう",
        "ごちょう"
      ],
