[
  {
    "uuid": "190d663d-7af5-5a5e-ad5a-db7f40304dd3",
    "entry": "旧例",
    "reading": {
      "primary": "きゅうれい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
