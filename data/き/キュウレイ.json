        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "空中に噴出された熔岩が、急冷されて金滓になり、それが円錐状に堆積したものである。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "噴火丘をつくっている金滓は、空中高く噴きあげられた熔岩が、急冷されて落ちてきたもので、内部はがさがさになっている。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
