    },
    "definitions": [
      {
        "index": 1,
        "gloss": "old custom",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ここに修業の道士は、毎年九月三日の夜をもって、一人は登仙することを得るという旧例があった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "白猿伝・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "曙覧が新言語を用い新趣味を詠じ毫も古格旧例に拘泥せざりしは、なかなかに『万葉』の精神を得たるものにして、『古今集』以下の自ら画して小区域に局促たりしと同日に語るべきにあらず。",
              "citation": {
                "source": "曙覧の歌",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながらこは私に定むべき事にもあらねば無論旧例に依るを可とすべきか。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、供御調度のことについて旧例を改革しようとはしなかったのである。",
              "citation": {
                "source": "にらみ鯛",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし旧例ばかりを楯にとって、何ごとにも禁裡を冷たく見てきた徳川幕府の首脳部は、『俄に、御料を増すことは罷りならぬ』　こうこたえて、所司代の申出を斥けてしまったのである。",
              "citation": {
                "source": "にらみ鯛",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "和学講談所（主として有職故実を調査する所）の塙次郎という学者はひそかに安藤対馬の命を奉じて北条氏廃帝の旧例を調査しているが、幕府方には尊王攘夷説の根源を断つために京都の主上を幽し奉ろうとする大きな野心がある。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、徳川治世のはじめになって、この谷では幕府直轄の代官を新しい主人公に迎えて見ると、それが山村氏の祖先であったが、諸事石川備前守の旧例によることには変わりはなかった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "この貢納の旧例こそは、何よりも雄弁に木曾谷山地の歴史を語り、一般人民が伐木と開墾とに制限のなかったことを証拠立てるものであった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、養子取組之義は百姓に同断、（中略）一、穢多牢舎中病気療法之義旧例無之旨、町御奉行より申来候へども、牢中は同様の義に候へば、牢医に申付様被仰付候事。",
              "citation": {
                "source": "エタに対する圧迫の沿革",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "『山城名勝志』引「季瓊日録」（寛正五年）によれば、六月十四日の祇園の祭礼に、北畠から跳戈を出し、歌舞して御所へ参るのが旧例だとあって、此の徒が遊芸に由って御霊会の神事に仕えていたことがわかる。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「上申の内書のと、些末な当務に精根を費やされること、ご濶達なお上のご気性では、さぞ煩わしく思召めされるだろうと」「大きに、な……内書の扱いひとつにも、旧例故格といううるさいものがあって、もってのほかに心労する……このせつ、おれは瘠せたそうな。",
              "citation": {
                "source": "無惨やな",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし彼が趙姓であったなら、現在よく用いらるる郡望の旧例に拠り、郡名百家姓に書いてある注解通りにすればいい。",
              "citation": {
                "source": "阿Ｑ正伝",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧例に拠れば「夫人」と呼んでいいのだけれど、彼は古臭いのが嫌いで、「おい」という一語を発明した。",
              "citation": {
                "source": "端午節",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧例に依れば近年は節期や大晦日の一日前にはいつも彼は夜中の十二時頃、ようやく家に到著して歩きながら懐中を探り大声出して「おい、取って来たよ」　と、ごちゃ交ぜにした中国交通銀行の紙幣を彼女に渡し、顔の上にはいささか得意の色があった。",
              "citation": {
                "source": "端午節",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧例故実は、しばらくの間、旧人のあなた方の中でお守りあればよい」　執事は、彼の権まくに驚いて、義昭へ取り次いだ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "何につけても、故典、格式、旧例をたてにとって、ひと理論、ひねくらなければ得心しない公卿たちも、この四姓打破論には、何の異議をいう余地もなかった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都には古くから亥の子の日に餅を搗いて、農村から持って来る旧例のみはあって、その他の行事は何もないけれども、まだ名前だけはほぼ記憶せられているが、それから東では十月亥の日などは普通の日に過ぎない。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭の物忌は今日は一般に省略に傾き、有れども無きに近い宮社が多い中に、なお稀々にはその旧例を厳守して、是をもって名を伝えているものが幾つかある。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日は一力旧例の“大石さん祭り”でお蕎麦の接待があるよしだったが行かれなかった。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
