    "definitions": [
      {
        "index": 1,
        "gloss": "on the point of vanishing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
