        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "錦衣還郷が人情ならば、襤褸をさげて故園の山河をさまようのもまた人情である。",
              "citation": {
                "source": "故郷〔扉の言葉〕",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にとって、せめて錦衣のつもりなのであった。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧臣｜猶錦衣にして、旧帝｜既に布衲なり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "越王勾踐破呉歸　　　　越王勾践　呉を破りて帰る義士還家盡錦衣　　　　義士家に還りて尽く錦衣なり。",
              "citation": {
                "source": "閑人詩話",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "「義士家に還りて尽く錦衣なり、」私はこんな文章を好まない。",
              "citation": {
                "source": "閑人詩話",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "「錦衣なり」「春殿に満つ」と現在に読むのもいけない。",
              "citation": {
                "source": "閑人詩話",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "越王勾践、呉を破りて帰るや、義士家に還りて尽く錦衣、宮女花の如く春殿に満ちしかど、只今惟だ鷓鴣の飛ぶ有り。",
              "citation": {
                "source": "閑人詩話",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "真に是れ無縫天上の錦衣。",
              "citation": {
                "source": "「鏡花全集」目録開口",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてはや、楽府の仙楽と満庭の万歳のうちに式を終って、今しも袞龍錦衣のお人影が、侍座の玉簪や、侍従の花冠と共に珠の椅子をお立ちあらんと見えたときであった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "華やかな錦衣をまとい、花帽をいただいた四、五百人の軍隊が、まずうやうやしく轅門に彼を出迎え、さて営中に入ると、同じように綺羅な粧いをした大将が、周瑜の座を中心に、星の如く居流れている。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「第二とうしょう、きんいろメタル。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「くるみはみどりのきんいろ、な、　風にふかれて　　すいすいすい、　くるみはみどりの天狗のおうぎ、　風にふかれて　　ばらんばらんばらん、　くるみはみどりのきんいろ、な、　風にふかれて　　さんさんさん。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「第二とうしやう、きんいろメタル。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「くるみはみどりのきんいろ、な、　風にふかれて　　すいすいすい、　くるみはみどりの天狗のあふぎ、　風にふかれて　　ばらんばらんばらん、　くるみはみどりのきんいろ、な、　風にふかれて　　さんさんさん。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "氣　稟鴉は木に眠り豆は莢の中秋の日の眞實丘の畑きんいろ。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "氣稟鴉は木に眠り豆は莢の中秋の日の眞實丘の畑きんいろ。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "註　六行目、び、は「美」　　八行目、あい、は「愛」気稟鴉は木に眠り豆は莢の中秋の日の真実丘の畑きんいろ。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは燈心で地虫をつり、地蜂の穴を埋めてきんきんいふ声に耳をすまし、蝉のぬけがらをさがし、毛虫をつつついてあるく。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（いしかわ　きんいち、毎日社友・評論家、三三・三）",
              "citation": {
                "source": "飢えは最善のソースか",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは仕切りの簾の向うに派手な模様がチラチラして、ハンカチで汗をおさえながらすわってはるらしい姿見ると、もうまた胸がどきんどきんいうて来ましたが、光子さんの方でも簾越しにこっち見てなさって、這入って行くのん待ち構えたように、「今日は」いうてニコニコ笑いなさるのんです。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかたやむねに、ぴかぴかひかるきんいろのかざりがついています。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
