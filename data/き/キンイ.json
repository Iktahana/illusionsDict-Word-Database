[
  {
    "uuid": "56220b17-7000-5500-8904-0fbf2cb6029e",
    "entry": "近医",
    "reading": {
      "primary": "きんい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "local doctor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "最近医学の進歩につれて、この性欲なるものは、人体内の諸所より血液中へ分泌される内分泌物、すなわちホルモンの司る作用であって、そのホルモンが血液に混じて体内をめぐり、一方性欲を惹起させ、他方また精神、肉体を強靱ならしめていることが実証されて来ました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋で吾父は蘭医方に転じ、わたくしは輓近医学を修めたのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "天民ノ父｜諱ハ光近医ヲ業トシ宗春ト称ス。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「第二とうしょう、きんいろメタル。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「くるみはみどりのきんいろ、な、　風にふかれて　　すいすいすい、　くるみはみどりの天狗のおうぎ、　風にふかれて　　ばらんばらんばらん、　くるみはみどりのきんいろ、な、　風にふかれて　　さんさんさん。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「第二とうしやう、きんいろメタル。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「くるみはみどりのきんいろ、な、　風にふかれて　　すいすいすい、　くるみはみどりの天狗のあふぎ、　風にふかれて　　ばらんばらんばらん、　くるみはみどりのきんいろ、な、　風にふかれて　　さんさんさん。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "氣　稟鴉は木に眠り豆は莢の中秋の日の眞實丘の畑きんいろ。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "氣稟鴉は木に眠り豆は莢の中秋の日の眞實丘の畑きんいろ。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "註　六行目、び、は「美」　　八行目、あい、は「愛」気稟鴉は木に眠り豆は莢の中秋の日の真実丘の畑きんいろ。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは燈心で地虫をつり、地蜂の穴を埋めてきんきんいふ声に耳をすまし、蝉のぬけがらをさがし、毛虫をつつついてあるく。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（いしかわ　きんいち、毎日社友・評論家、三三・三）",
              "citation": {
                "source": "飢えは最善のソースか",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは仕切りの簾の向うに派手な模様がチラチラして、ハンカチで汗をおさえながらすわってはるらしい姿見ると、もうまた胸がどきんどきんいうて来ましたが、光子さんの方でも簾越しにこっち見てなさって、這入って行くのん待ち構えたように、「今日は」いうてニコニコ笑いなさるのんです。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかたやむねに、ぴかぴかひかるきんいろのかざりがついています。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
