        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "きゅうに遠くの方で急雨のような音がした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂蓮の急雨｜定頼卿の宇治の網代木これ見様体の歌なり。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜の風雨は高原らしい風雨であつた、雷鳴急雨、それは私の荒みつゝある身心を鞭つた。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜の中に急雨がやつて來た。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々急雨が山頂に降りそゝぎて來たなと思つてゐると、天一面を覆つて、眞黒く群れて縱横に飛び交はしてゐる山燕の幾千幾百を見掛けるのであつたが。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひげ武者のアイノに道を聽いて後、義雄がこの紅葉した濶葉樹密接林の間を驅ける時、目をつぶると、その葉毎／＼に當る風の音が急雨のやつて來るかと驚かれた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂蓮の急雨、定頼卿の宇治の網代木、これ見る様体の歌也。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月二十五日（水曜）急雨　池田さん来。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何を怒るや怒り猪の――俄に激する数千｜騎」突如として山｜崩れ落つ鵯越の逆落し、四絃を奔る撥音急雨の如く、呀と思う間もなく身は悲壮渦中に捲きこまれた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "検め見れば、鈎※、沈、綸など、紊れに紊れ、処々に泥土さへ着きて、前回の出遊に、雪交りの急雨に降ひ、手の指｜亀みて自由利かず、其のまゝ引きくるめ、這々の体にて戻りし時の、敗亡の跡歴然たり。",
              "citation": {
                "source": "元日の釣",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "マンションクラブの一夜は、お隣から急雨のごとく響ききたる変電所の騒音に明けて、八時半の急行列車に乗る。",
              "citation": {
                "source": "アーニイ・パイルの前に立ちて",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九日、夜来急雨あり。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後四時ころより天候にわかに変じ、烈風急雨、天地ために暗し。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "大絃は※々として、急雨のように響かせるところは響かせます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに彼だと思いながら、伊兵衛はいつかその音調に強く惹きつけられている自分を感じた……大絃はそうそうとして急雨のごとく小絃は切々として私語のごとし、という白氏の詩片がふと頭にうかんだ。",
              "citation": {
                "source": "夜明けの辻",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大絃は※々として急雨のように、小絃は切々として私語のごとしという形容のままだった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "急雨のような人の跫音、つづいて怒号。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ山上から急雨のような夜襲だった。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼はその後、終南山にひそんでいたが、天子ここを通ると知って、にわかに手勢一千を率し、急雨の山を降るが如く、野を捲いて、これへ馳けて来たものだった。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「呉兵だ」「伏兵だぞ」　すでに矢風は急雨のごとく身辺をかすめていた。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
