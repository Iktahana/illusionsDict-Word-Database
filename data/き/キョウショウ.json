[
  {
    "uuid": "dce98827-9e20-58d5-a784-511c6ed0ce63",
    "entry": "協商",
    "reading": {
      "primary": "きょうしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
