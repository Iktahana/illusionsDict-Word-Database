        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "台風で倒れそうな木を、早急に切り倒す必要があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "開発のために、森の木々を大量に切り倒した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「邪魔な低木は、このチェーンソーで一気に切り倒してしまおう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "いつたい「櫻の園」には第一｜幕の汽車の音、第二｜幕のギタアの音色、第四｜幕の終りの櫻の木を切り倒す斧の響きなどと、塲面々々の感じと相俟つて音響の効果が實に巧に用ゐられてゐるが、私の狹い知識の範圍では、戯曲に球突の球の響きなどを用ゐたのはひとりチエエホフあるのみのやうである。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ付け込んで値切り倒すほどの悪い料簡もないのと、いくらか気の毒だと思う心もあるのとで、父はそれを三｜歩に買おうと言いますと、相手は大層よろこんで、いや三歩には及ばない、二歩で結構だというのを、父は無理にすすめて三歩に買うことにしました。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "播磨は一刀にその肩先より切り倒す。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大切なお品を半金に値切り倒すといっては、先様の思召しがどうあろうも知れない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "化け銀杏",
                "note": "青空文庫"
              }
            },
            {
              "text": "来年はきつとなりますから、切り倒すことだけはお免し下さい。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェホフの桜の園で、桜の木の切り倒される悲しさは日本で同一の木を切り倒す悲しさとは、その質が根本から違っている。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の苦力が組になつて、伐倒や玉切りをして、一日やつと立木四本位を切り倒す位だつたかなと、森林官としてチャンボウへ出張してゐた頃を富岡は思ひ出してゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯れた大木などあの大鉞で、切り倒すのでございます」「ここがどこだか知っているか？",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術家の足元へ付け込んで、むやみに価切り倒すなんて失敬な奴へは売らないが好いというのが僕の意見なんだ。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その友達がまた品物の如何にかかわらずむやみに価切り倒す癖を有っているので、彼はただ歩くために少なからぬ時間を費やさされた。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪府下よりの報知に、「大木に鎌を打ち立て、『汝、余の瘧を落とさば鎌を去るべし、治せざれば切り倒すべし』と命令すれば治す」という。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "レオンチュウスはアレースに似たる勇將、槍飛ばしアンチマコスの生める息ヒッポマコスを射て斃し、更に鞘より鋭利なる劔を燦と拔き放ち、　190群がる敵を通り越し、＊アンチパテ，スにまつさきに、近づき寄りて討とめてどうと地上に切り倒す。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "續きて＊メノーン、イアメノス、オレステースを順々にレオンチュウスは勇を皷し大地の上に切り倒す。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "不死身を逮捕し彼の銀行を奪うこと、それは悪を根元から切り倒すことになるんです。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　この命令が、洞窟のそとに伝えられ、警官隊のなかの十人あまりが、木をきりたおすために、森のほうへかけだしていきました。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
