    "definitions": [
      {
        "index": 1,
        "gloss": "the past",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "風に吹かれつ、わが来し方に茫然としぬ、……涙しぬ。",
              "citation": {
                "source": "夏と私",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "来し方往く末、おもひ忘れて夢路をたどるやうなりしが、何物ぞ、俄にその空虚なる胸にひゞきたると覚しく、女子はあたりを見廻して高く笑ひぬ。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は来し方の一年間を思いかえした。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "心着けば旧来し方にはあらじと思う坂道の異なる方にわれはいつかおりかけいたり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "路は、あわれ、鬼の脱いだその沓を跨がねばならぬほど狭いので、心から、一方は海の方へ、一方は橿原の山里へ、一方は来し方の巌殿になる、久能谷のこの出口は、あたかも、ものの撞木の形。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから直にお葉の行方を追う意であろう、彼は旧来し方へ直驀地に駈けて行った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "心着けば旧来し方にはあらじと思ふ坂道の異なる方にわれはいつかおりかけゐたり。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝはや藪の中央ならむと旧来し方を振返れば、真昼は藪に寸断されて点々星に髣髴たり。",
              "citation": {
                "source": "妖怪年代記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その橋の上に乗りたるよう、上流の流れ疾く白銀の光を浴び、蜿りに蒼みを帯びて、両側より枝｜蔽える木の葉の中より走り出でて、颯と橋杭を潜り抜け、来し方の市のあたり、ごうごうと夜深き瀬の音ぞ聞えたる。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "儺はれし我の来し方ここにして早や遥かなり帰り今在りこれの子ら歎知らざり我が言ふをただおもしろと笑ひ爆ぜたる我が声にひびき応ふる子らありて顔ことごとく笑ひくづれつ沿道沖端に近づくに、城内、矢留両小学校の生徒、既に旧藩侯邸の前に整列して我が一行を迎ふるあり。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっとりと来し方をすべて忘れしごとし。",
              "citation": {
                "source": "悲しき玩具",
                "author": "―一握の砂以後―",
                "note": "青空文庫"
              }
            },
            {
              "text": "飴色の半月低く崖下に懸れるを見れば、来し方、行末の事なぞ坐ろに思ひ出でられつ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "良ありて渠の身を起し、旧来し方に皈るを見るに、その来りし時に似もやらで、太く足許の※きたりき。",
              "citation": {
                "source": "黒壁",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "というわけで、ソニーがしょっぱなで大ずっこけをかました電気炊飯器の来し方を探っていくと、電灯会社が電球の省エネ化という危機をきっかけに家電の開拓に取り組み、電力会社へと変貌をとげていくダイナミックな産業構造の変化と結びついたおかまの真実が見えてくる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "齢人生の六分に達し、今にして過ぎ来し方を顧みれば、行いし事として罪悪ならぬはなく、謀慮りし事として誤謬ならぬはなきぞかし。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾が過ぎ来し方は蹉跌の上の蹉跌なりき。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "七年の来し方を、一夜に語り一夜に聴かんと※れるなるべし。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨勢は少女が墜つる時、僅に裳を握みしが、少女が蘆間隠れの杙に強く胸を打たれて、沈まむとするを、やうやうに引揚げ、汀の二人が争ふを跡に見て、もと来し方へ漕ぎ返しつ。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "都鳥に似たる「ごめ」という水禽のみ、黒み行く浪の上に暮れ残りて白く見ゆるに、都鳥も忍ばしく、父母すみたもう方、ふりすてて来し方もさすがに思わざるにはあらず。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "船人もたれを恋ふるや大島のうら悲しくも声の聞こゆる来し方も行方も知らぬ沖に出でてあはれ何処に君を恋ふらん　海の景色を見てはこんな歌も作っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして静かに身の来し方を返り見た。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "民衆の文学という声が、文学の世界の現実として民衆の日常生活、心理、歴史への関り方を再現してゆくべきであるという自然な解釈からは脱れて、主として知識人の知性、批判力への否定のてだてとして出発して来たことは、あれほど到るところに谺していたヒューマニズムの響きの来し方として、愕きに似た感想を喚び起される。",
              "citation": {
                "source": "昭和の十四年間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜があけて、船室から甲板に出てみると来し方の海水は青々としているけれども、行く手の海は赤い色をしている。",
              "citation": {
                "source": "余齢初旅",
                "author": "――中支遊記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "六条院は紫の女王と来し方のこと、未来のことをしみじみと話しておいでになった。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人自身も寂しい来し方を思い出し、あのはなやかな人たちの世界の一隅を占めることは不可能な影の淡い身の上であることがいよいよ心細く思われて、やはり自分は宇治へ隠退してしまうのが無難であろうと考えられるのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "宿り木",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしの心はまた先生の眼を藉りて、いまは繍糸も落ちて黄褐変した台ぎれのみえているところや、下絵の墨絵の線がまざまざとみえているあたりの断裂を前にして、過ぎ来し方を偲び今さらのように飛鳥芸術の豪華をながめる。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ひ出に非ずあらゆる来し方の中より心痛まぬを採る　故人と共に過した四十年の人生は短いものでもなく随分忍苦に満ちた一生ではあつたが、生甲斐のあるやうに思つた年月も少くはない。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "行く方の空が遠くなって、来し方の空が近くなるだろう。",
              "citation": {
                "source": "旅人の言",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "祈りのうちに過ぎ来し方がそのままはっきり見えて来るのだ。",
              "citation": {
                "source": "旅人の言",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩角に懈怠よろぼひ、きり石に足弱悩み、歩む毎、きしかたの血潮流れて、木枯の颯々たりや、高樫に。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
