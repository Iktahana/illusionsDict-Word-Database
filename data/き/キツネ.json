    "definitions": [
      {
        "index": 1,
        "gloss": "fox (esp. the red fox, Vulpes vulpes)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "深夜、車のライトに照らされた狐が、道を横切っていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "雪の上には、狐の足跡がくっきりと残っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、森で狐に出会ったことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "これをもひとめ見た印象で言わせてもらえば、シューベルトに化け損ねた狐である。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場の蒼黒い顔には弱い西日がぽっと明るくさしていて、夕靄がもやもや烟ってふたりのからだのまわりを包み、なんだかおかしな、狐狸のにおいのする風景であった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の遠い先祖は、冬の来る前に穴を掘り、熊や狐やの獣と共に、小さくかじかまつて生きたへて居た。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ヘー有難うこれから当世白狐伝を御覧に入れる所なり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉間には狐疑の深い皺がきざみ込まれ、小さい灰色の眼には淺間しい殺意が燃え、眞蒼な頬は威嚇の怒りに震へて、黒ずんだ薄い唇は嫌惡と侮蔑にひきつつたやうにゆがんでゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日兎は森に這入つて行つた、牝狐を訪ねる算段で。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が森の径を巡つてゐる時、牝狐は家で囲炉裡にあたつてゐた。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "仔狐達は窓の近くで遊んでゐた。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "牡兎が森の方からやつてくるのを見付けると牝狐は、急いで子供達に云つた、「何時もの彼が来たらば、私は家にゐないとお云ひ。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "牝狐は一伍一什を聞いてゐた。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると仔狐達は――いいえ、ゐません！",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その時牝狐は顔を出した、「今日は、親愛な方！",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "牝狐は今にも彼を捕へさうだつたのだが、白樺の間に挟まつてしまつて、進むことも退くことも叶はなくなつた。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから……牝狐を慰めてやつた。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に牝狐の方では胸が清々してきて、もう一度牡兎を探す気になつてゐた。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」牝狐は赤面して、大急ぎで巣の方へ走つた。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」なんて狡い牝狐だらう！",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年九月六日『東京朝日新聞』）狐と鱗片　四足獣で鱗のあるものは珍しい。",
              "citation": {
                "source": "「万年筆」欄より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も鼠の尻尾も一種の鱗片で蔽われているし、その他身体の一部に多少の鱗片あるものはあるが、狐の先祖が鱗片を着けていたという説は新しい。",
              "citation": {
                "source": "「万年筆」欄より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い狐の毛皮を詳しく調べてみると、その毛の生え方が一種特別で数本ずつ束になって一定の間隙を置いて生じている。",
              "citation": {
                "source": "「万年筆」欄より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大概の野狐禅では傍へ寄り付けません。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓向うの壁がかぶりつきたいほどうまそうな狐色に見えた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "向ふ岸も、青じろくぽうっと光ってけむり、時々、やっぱりすすきが風にひるがへるらしく、さっとその銀いろがけむって、息でもかけたやうに見え、また、たくさんのりんだうの花が、草をかくれたり出たりするのは、やさしい狐火のやうに思はれました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京市何区何町の真中に尾花が戦ぎ百舌が鳴き、狐や狸が散歩する事になったのは愉快である。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分みんな狐につままれたような顔をしていたことと想像される。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幻滅を感じて狐につままれた顔をして引返してくる場合もあるであろう。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局は、やればやり得る学位を、無用な狐疑や第二義的な些末な考査からやり惜しみをするということが、こういう不祥事やあらゆる依怙沙汰の原因になるのである。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子は狐鼠狐鼠と僕の所へ這入ってきて、小声で、私は内に居るのが一番面白いわと云ってニッコリ笑う。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "近畿地方等で「狐があたんする」と言いますが、この「あたんする」は復讐するということであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "温室の中からガタガタと下駄の音を立てて、田舎のばあさんたちが四五人、きつねにつままれたような顔をして出て来る。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
