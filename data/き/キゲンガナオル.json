    "definitions": [
      {
        "index": 1,
        "gloss": "to get over a bad mood",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大好きなケーキをあげたら、彼女の機嫌が直った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "怒っていた父も、孫の顔を見たらすぐに機嫌が直るだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あれ？さっきまで怒ってたのに、もう機嫌が直ったの？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の機嫌が直るまで、しばらくそっとしておいた方がいい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一旦は腹立ちまぎれに何と言おうとも時が過ぎれば機嫌が直るに相違ない。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "機嫌が直ると、上から見下したような調子でくり返した。",
              "citation": {
                "source": "幻の彼方",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのままあやまつて寝さへすれば、翌朝は機嫌が直るといふものじや。",
              "citation": {
                "source": "心の鬼",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分で世間を狭めるんですから、損な性分です」「しかしその中に機嫌が直るでしょう」「君からも然るべく執り成して置いて下さい。",
              "citation": {
                "source": "変人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝ一年誠意を示せば、御機嫌が直る。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれの機嫌が直るように、賢く努めているものと見える。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
