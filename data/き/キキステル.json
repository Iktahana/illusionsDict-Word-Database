        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あんな根も葉もない噂なんて、聞き捨てておけばいいんだよ」と彼女は笑い飛ばした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は部下からの切実な訴えを、いつも鼻で笑って聞き捨てている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "隣の席から嫌味な声が聞こえてきたが、波風を立てたくなかったので聞き捨てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "酔っ払いのたわ言だと思って聞き捨てていたが、後になってその内容が的中した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それを聞いた事がなくば私の話は分りませんが、若しも聞いた事が有るなら必ずお分りになりますよ」益々奇妙な事を云うが、併し秀子の密旨などを持ち出す所を見れば聞き捨てる訳にも行かぬ。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、房代夫人の話は、面白く出来てる半面、ただ面白いと聞き捨てるわけにゆかないものを含んでいた。",
              "citation": {
                "source": "無法者",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度のことは決して浮っ調子な、大勢の人々のひまつぶしな冗談として、ききすてることの出来ないことだろうと思います。",
              "citation": {
                "source": "行く可き処に行き着いたのです",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
