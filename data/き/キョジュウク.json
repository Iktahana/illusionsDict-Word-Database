    "definitions": [
      {
        "index": 1,
        "gloss": "residential area",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "昔バビロンと呼ばれた都の跡で、クリスチャンの居住区域である。",
              "citation": {
                "source": "処女の木とアブ・サルガ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一の回転扉の次に、またトンネルがあり、その先に、また第二の回転扉があるという風に、少なくとも第五の回転扉を経なければ、月人の居住区へは達しないのだ。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、その居住区に永い間暮していたんだ」「おお、モウリ博士」「月人は空気をあまりに大切にするあまり、月世界の表面へ出ることも、たいへんいやがる。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてやっとじぶんたちの居住区までたどりついた降下路を街へでてみると、どうしたわけであろうか、人ッ子ひとり見えない。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とつぜんあのとおり、大震動と共に、あのような金属棒がわれらの居住区を突きさしたのだ」　オンドリは叩きつけるような口調でいった。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "かりに君たちの居住区が、こんな風に荒されたと考えてみたまえ。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてヤマ族の海底都市と連絡をつけて、ここに海底連合大居住区を建設するんだ。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬ですら自分の居住区域には決して便をしないものだ。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "将校団のほうはこんなことで瞞着されるはずはなく、かえって企図の裏を察し、未然に再度の暴発を抑圧することにきめ、ひそかに申合せて唐突に兵隊たちの居住区へ斬りこんだ。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋は全部で十二室あって、二階があたしたちの住居になり、地下室は衛兵の居住区になっていました。",
              "citation": {
                "source": "淪落の皇女の覚書",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "将校団のほうは企図の裏を察し、再度の暴発を未然に制圧するため申合せて、唐突に兵隊の居住区に斬りこんだ。",
              "citation": {
                "source": "海難記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは丘がスタンパーズ・ヒルの低い隆起に落ちるところで、ゲットーと黒人居住区が、独立戦争以前のボストン駅馬車出発所の周辺に集まっている。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つはプラハ最古の居住区で一夜にして一軒の家が完全に崩壊し、ヨセフ・ナデーと呼ばれる誰も思い出せない昔から一人で住んできた邪悪な老人が失踪したという事件であった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔵書の多くを送るよう実家に手紙を出すと、ブレイクは著述と画業のため居住区に似合いの古い家具を買い入れた――一人で暮らし、簡単な家事は自分でするようにした。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "わずかな地元の知り合いが彼に教えてくれたのだが、遠くの坂になっている所は大きなイタリア系住民の居住区で、しかし家の大部分はヤンキーやアイルランド人時代の遺物だという。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "洞窟の通路は兵の居住区をもかねているのだが、そこでは分配された物資を衣嚢につめたり出したり、なるたけ余計もってゆこうというので、キャンバスをもってきて新しく衣嚢をつくってる奴もいるしさ。",
              "citation": {
                "source": "赤い駱駝",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりはきちんと片附いていて、他の居住区のように雑然としたところは全然なかった。",
              "citation": {
                "source": "赤い駱駝",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "――――――――　十一月四日――フランス人居住区で「死」にまつわる珍妙な講演を聞いたが、会場があまりに暑く体調があまりに悪かったので居眠りしてしまった。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処はずっと雨で、二三日前は、居住区の方の壕の入口が壊れたという。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "通信科の兵が来て、それと一緒に居住区に歩き出した。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "通信科の居住区は、丘の頂上近くにある。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭い道に降り、そして居住区についた。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "送信所に到る通路が、いわば居住区の形で、寝台や卓子が並んでいた。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "医務室でその兵と別れ、居住区に戻り夕食を私は食べていた。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「皆来ていたのですが――」「来ていて、どうしたんだ」「居住区から呼びに来たのです。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにいる二人の兵隊も、同僚が居住区で何をされているか、よく知っている。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よし、居住区に行ってみる」　誰にともなく私は呟き、立ち上った。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は立ち止り、一寸何か言いたそうにしたが、何も言わず、私に背を向け、大股に居住区に入って行った。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "うしろに何か重い物を引き摺ったような歩き方で、居住区の中に消えて行った彼のうしろ姿が、奇妙に私の眼に沁みついて離れなかった。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗号室や居住区での雑談で、米軍が何処に上陸するかということが、時々話題にのぼった。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
