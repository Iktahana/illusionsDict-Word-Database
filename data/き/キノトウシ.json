        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "叔父は乙丑の生まれで、まさに働き者の牛のような人だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この厄介な問題が解決したのは、乙丑の年のことだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "乙丑の年に結婚した夫婦は、堅実で長続きすると言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その寺院の改築は、乙丑の年に着工された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "私の生まれた年は乙丑で、干支占いをすると頑固な一面があると出る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "甲子を一とし乙丑を二とすれば甲戌は十一であり丙子は十三になる、少しめんどうなだけに、それだけの長所はあるのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿六日、乙丑、晴、京都の使者参ず、去る十三日、禅定三品政子従二位に叙せしめ給ふと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶応元年乙丑、十九歳。",
              "citation": {
                "source": "能久親王年譜",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その二十八　文化二年には蘭軒の集に「乙丑元日」の七律がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「文化乙丑小春廿四日、据毛本鈔矣、斯日巳刻児生、其外祖父飯田翁（自註、名信方、字休庵）与名曰常三郎、恬。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "按ずるに蘭軒の女は文化乙丑に長女｜天津が夭し、壬申に二女智貌童女が夭し、文政癸未に四女順が夭し、今又五女万知が夭した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化乙丑に生れて、二十五歳になつてゐた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "次年元治紀元甲子四月五日に異母兄徴が歿し、尋で慶応紀元乙丑八月に母も亦歿した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らば文化十三年生で乙丑には五十歳になつてゐた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し恒庵若くは恒介が即恒三ならば、恒三は文化七年生で、乙丑には五十六歳になつてゐた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "二年乙丑　平八郎十三歳。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "又此頃乙丑丸の用達を薩より申付候内ニて、浪士等長崎ニ出てハ、此小曽根をかくれ家と致し居候ものも在之、既私らもひそみ居候事ニ候間、悪心無之事ハ是レヲ以御察可被遣候。",
              "citation": {
                "source": "手紙",
                "author": "慶応二年八月十三日　森玄道、伊藤助太夫あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "とあるから、この文は天啓五年（西暦一六二五）乙丑の歳の陰暦四月十六日（陽暦の五月二十一日）に書かれたこと疑を容れぬ（10）。",
              "citation": {
                "source": "大秦景教流行中國碑に就いて",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "とあるが、高宗本紀を驗すると、大食の使者は永徽二年の八月乙丑に朝貢して居るから、正しくは囘暦三十一年に當つて三十四年でない。",
              "citation": {
                "source": "創建清眞寺碑",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "（同巻ヲ倒ニシテ巻首ヨリノ中程ニ突然ト左ノ数行アリ）廿三日　将軍坂ニ下ル○廿三日ハ乙丑ノ九月ナリ校正者識廿四日夜　大坂ニ下ル。",
              "citation": {
                "source": "坂本龍馬手帳摘要",
                "author": "坂本龍馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十四年｜乙丑ノ歳晩予｜偶『有隣舎ト其学徒』ト題シタル新刊ノ書ヲソノ著者ヨリ恵贈セラレタリ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙集は嘉永より慶応に至る間の詩文を編集したもの、また丙集は慶応元年乙丑より明治十年丁丑まで十二年間の詩文を編成したものである。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三十四　慶応元年｜乙丑の春より夏にかけて枕山はしばしば芝口一丁目｜脇坂中務大輔安宅の邸に招かれて奉和の詩を賦している。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "『毅堂丙集』巻の四に曰く、「乙丑十一月余聘ニ応ジテ尾張ニ帰ル。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "その明かに甲斐国とあるものは、「持統天皇紀」に二年五月戊午ノ朔乙丑、百済ノ敬須徳那利ヲ以テ甲斐ノ国ニ移ス。",
              "citation": {
                "source": "マル及ムレについて",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙丑八月十四日、女、と書きつけたまだ真新しい木標。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "金鳳釵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この通り、乙丑八月の十四日としてあります。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "金鳳釵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはさうと、ぼくは恐らく岸田の日本画を一番沢山に見るだらうと思ふけれども、最近に見たのは、気まゝに切つた形の、紙本の、九画連作のもので、乙丑九月三日仲秋明月の夜於天下茶屋瓢々亭劉生酔筆と題する「ばけものづくし」であつた。",
              "citation": {
                "source": "岸田劉生の日本画",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがぼくの最々近に見た岸田の日本画であるが、これが短命だつた岸田にとつては早くも晩年に属する作品の一つで、乙丑九月とあるから大正十四年に当り、岸田は三十五歳、京都に偶居した頃の逸作である。",
              "citation": {
                "source": "岸田劉生の日本画",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、私の運勢をみていただけましょうか」「まず、お生れ年と、月日を」「本年三十二歳、甲子ノ年、乙丑ノ月、丙寅ノ日、丁卯ノ時刻に生れました。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
