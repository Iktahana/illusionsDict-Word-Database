        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "奇なる哉、字の色分明にして紫なり。",
              "citation": {
                "source": "花間文字",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ようよう、」とまた後の方で、雀海中に入った時のごとき、奇なる音声を発する者あり。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "素百餘を陳ね、瑪瑙の酒盞、水晶の鉢、瑠璃の椀、琥珀の皿、いづれも工の奇なる中國未だ嘗てこれあらず、皆西域より齎す處。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇なる哉、更に一時間いくらと言ふ……三保の天女の羽衣ならねど、身にお寶のかゝる其の姉さんが、世話になつた禮かた／″＼、親類へ用たしもしたいから、お差支へなくば御一所に、――お差支へ？",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その行ないすでに奇にして、その心また奇なりといえども、いまだこの言の奇なるには如かず、と馭者は思えり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "嗚呼、何ぞ其の奇なるや。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "嗚呼、運命｜遭逢、又何ぞ奇なるや。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅篋の度牒、袈裟、剃刀、噫又何ぞ奇なるや。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "道士の霊夢、御溝の片舟、噫又何ぞ奇なるや。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度は諸子が父上母上の頃には天竺と呼びたる最早くより開け進みし国にて、今日よりして評するも世界の文明の母ともいふべきところなれば、従つて趣味ある古話にも富みたり、御望みならむには随分諸子のために珍奇なる話を取り出して一年や二年の間はこの紙上に掲げん。",
              "citation": {
                "source": "印度の古話",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　途端に奇なる声あり。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "目見青きドミニカびとは陀羅尼誦し夢にも語る、禁制の宗門神を、あるはまた、血に染む聖磔、芥子粒を林檎のごとく見すといふ欺罔の器、波羅葦僧の空をも覗く伸び縮む奇なる眼鏡を。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇なるかな一は侠勇を尊び、一は艶美を尚びて、各自特異の旗幟を樹てたるや。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が生路はおおむね平滑なりしに、轗軻数奇なるはわが身の上なりければなり。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、「この奇なる結合（自己主張の思想とデターミニスチックの思想の）名が自然主義である」と。",
              "citation": {
                "source": "時代閉塞の現状",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "連峯蜒々として走るの間、山の尤も近くして又尤も奇なるもの岩船あり。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳴呼、昨日經る所幾十里、今日過くる所幾乎、村山水の奇態、高きもの、長きもの、遠きもの、近きもの、低きもの、河の緩なるもの、急なるもの、廣きもの、狹きもの、深きもの、淺きもの或は奇なるもの、或は平かなもの之を數ふれば幾十百、其間天下の勝たるをや。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「芥子粒を林檎のごとく見すという欺罔の器」と「波羅葦僧の空をも覗く、伸び縮む奇なる眼鏡」とを持った奇怪な妖術師である。",
              "citation": {
                "source": "鏡花氏の文章",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこれまで何遍も、船長の人物を説明すべき鍵を握ったと思ったが、いつも彼はさらに新奇なる性格をあらわして私の結論をくつがえし、わたしを失望させるだけであった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから以後僕が如何なる所業をして居たかは好奇なる我画家よ、どうか僕を許して呉れ。",
              "citation": {
                "source": "殺人行者",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "足本國の外を踐まざる我徒に至りては、只だその瑰偉珍奇なるがために魂を褫はれぬれば、今｜復たその髣髴をだに語ることを得ざるならん。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "あえてこれ天下に憚る処なしといえども、しかれども、数の奇なるもの、顧れば無慙な境遇。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と年紀だけに諭すがごとく、自らは悟りすましたようにいったのであるが、何のおかみさん、日傘が深張になったのは、あえて勝山の流転のごとき、数の奇なるものではない。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これしきの虫と、苛つて、恰も転つて来て、下まぶちの、まつげを侵さうとするのを、現にも睨めつける気で、屹と瞳を据ゑると、いかに、普通｜見馴れた者とは大いに異り、一ツは鉄よりも固さうな、而して先の尖つた奇なる烏帽子を頭に頂き、一ツは灰色の大紋ついた素袍を着て、いづれも虫の顔でない。",
              "citation": {
                "source": "蠅を憎む記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が生路は概ね平滑なりしに、轗軻數奇なるは我身の上なりければなり。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしてこれを取り来りてノルウェー産の樅のあいだに植えましたときに、奇なるかな、両種の樅は相いならんで生長し、年を経るも枯れなかったのであります。",
              "citation": {
                "source": "デンマルク国の話",
                "author": "信仰と樹木とをもって国を救いし話",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に道教で、五嶽眞影などといふ字の如く畫の如き奇なるものを有難がるのも、遠い古からの遺習に出たことで、後に此等の山其の祭るべき神、乃至祖宗を祭ることは、人の當然に爲すべきこととされた。",
              "citation": {
                "source": "道教に就いて",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "貫一はかの夢の奇なりしより、更に更に奇なるこの塩原の実覚をば疑ひ懼れつつ立尽せり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあれ日は過ぎ月は逝き、なれ等血もなく涙なく、よくぞ鬩めげる数千年、さても殺生はての死の、よくぞ好きなる、おゝ永遠の闘争よ、おゝ恩怨の同胞よ！",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さても殺生はての死の、よくぞ好きなる。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
