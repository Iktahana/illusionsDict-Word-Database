[
  {
    "uuid": "4c68a6e9-e41f-5266-b6c3-c0c9f1e0a671",
    "entry": "局地",
    "reading": {
      "primary": "きょくち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
