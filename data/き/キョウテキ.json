  {
    "uuid": "dfdd4131-d192-5ef9-b15f-22e6ac933944",
    "entry": "狂的",
    "reading": {
      "primary": "きょうてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "insane",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "及びその色情狂的情調。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ものにも捉はれない野蛮人めいた狂暴無智の感情の大浪と、そのうねりくねる所の狂的なリズム。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜の広東事変はこうした事実に対する同志の熱狂的｜昂奮によってなされたことであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は心持ち昂奮して床を靴尖で叩きながら立上ると、リー・シー・ツワンは遥かビクトリア・ビークの絶景の化粧された文明の礎を一瞥して、　――上海に於ける陳独秀のコムミュン騒動、また広東事変の失敗によって俺には熱狂的同志に対して俺自身に課せられた革命的任務の自覚が眼覚めたのだ。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜の広東事変はこうした事実に対する同志の熱狂的昂奮によってなされたことであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　以て如何に熱狂的だったかが知れるだろう。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼には男爵中の最も貧しき財産ながらも、なおかつ財はこれあり、狂的男爵の露命をつなぐ上において、なんのコマルところはないのであるが、彼は何事もしていない。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "尻尾を焼かれた馬が芝生のある傾斜面を、ほえるように嘶き、倒れている人間のあいだを縫って狂的に馳せまわった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは又熱狂的に拍手しました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚かには違い無いが、けれども、此の熱狂的に一直線の希求には、何か笑えないものが在る。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂子はバルザツクの「知られざる傑作」の主人公である画家が、絵画の絶対の完成を求めてその画布を人間の眼には何物とも判じ得られぬ狂的な形象に塗殺し尽して仕舞つた記述を読んで、悲涙を流した。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「狂的なひらめき。",
              "citation": {
                "source": "碧眼托鉢",
                "author": "――馬をさへ眺むる雪の朝かな――",
                "note": "青空文庫"
              }
            },
            {
              "text": "）ちかごろ、「狂的なひらめき。",
              "citation": {
                "source": "碧眼托鉢",
                "author": "――馬をさへ眺むる雪の朝かな――",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっきり言えることがらを、どんなにはっきり言っても、言いすぎることはないのであるから、べつに「狂的なひらめき。",
              "citation": {
                "source": "碧眼托鉢",
                "author": "――馬をさへ眺むる雪の朝かな――",
                "note": "青空文庫"
              }
            },
            {
              "text": "謂わば、ろれつが廻らない程に熱狂的である。",
              "citation": {
                "source": "パウロの混乱",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴は熱狂的に高慢であつた。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴は熱狂的に高慢であった。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに主人が私に絵をかく事をすすめて、私は主人を信じていますので、（いまでも私は主人を愛しております）中泉さんのアトリエに通う事になりましたが、たちまち皆さんの熱狂的な賞讃の的になり、はじめは私もただ当惑いたしましたが、主人まで真顔になって、お前は天才かも知れぬなどと申します。",
              "citation": {
                "source": "水仙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓさんのお家へ行つて、その津軽人の本性を暴露した熱狂的な接待振りには、同じ津軽人の私でさへ少しめんくらつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "療治の法を求めるのに、やや狂的になった。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅行から帰って、少しずつ仕事をすすめているうちに、私はあなたに対して二十年間持ちつづけて来た熱狂的な不快な程のあこがれが綺麗さっぱりと洗われてしまっているのに気が附きました。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたが贋乞食であることくらい、あなたがこゝへ来て十日も経たないうちに彼は嗅ぎ出しましたさ」　学者乞食の花田は廃朽の自然物から何か価値を取出すことに魅惑を持ち、偏執狂的にその在所を究めずには措かない。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩原君は之を指して色情狂的情調、或は凶暴的無智と云ふ。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集のはじめに",
                "note": "青空文庫"
              }
            },
            {
              "text": "この狂的接吻には、一同少からず辟易。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その曲の最もありふれた形式の一つを挙ぐれば、先ず日常生活に原因する悲劇的場面から初まって、その悲劇の主人公が次第に狂的、超人的な心理状態に入る。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際そんな単純な考えが熱狂的な少数の人の口から群集の間に燎原の火のようにひろがって、「芝」を根もとまで焼き払おうとした例が西洋の歴史などにないでもなかった。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "詳しく申し上げると長くなりますが……」　＝暗転＝　笠松博士には、前々から、観念構成｜虧欠症性の微弱徴候と、誇大妄想狂的精神欠陥とがあった。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もかもを、滅茶苦茶に打毀して了い度いような、狂的な焦燥が、嵐のように全神経を吹捲くるのであった。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            }
          ]
        }
