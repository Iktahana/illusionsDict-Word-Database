    "definitions": [
      {
        "index": 1,
        "gloss": "Kyushu region (sometimes incl. the Nansei Islands)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あの精到を極めた写実的な「土」でさえ、四国地方に育った者や、九州地方に育った者が、自分の眼で見、肉体で感じた農村と、「土」の農村とを思いくらべて異っていることに気づく。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "断念のために、折から夫理学士は、公用で九州地方へ旅行中。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際私の生家は此六騎街中の一二の家柄であるばかりでなく、酒造家としても最も石数高く魚類の問屋としては九州地方の老舗として夙に知られてゐたのである。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "太鼓に堪能で喜多流の大家であったというような話を筆者が幼少の時代に祖父から聞き伝えているところから考えると、喜多流なる流派の存在は現在伝うるところよりもズット古く戦国時代から既に存在していて、九州地方にも流行していた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "山本毎氏のは咽喉を開放した、九州地方一流の発音のハッキリし過ぎた、間拍子のキチンとしたもので、いつも地頭を承っていた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａはその頃、小樽タイムスを罷めて、九州地方をウロ付いているという噂でしたからね。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "九州地方の豪族は、古くから漢土と交通してゐた様子であるから、漢字も知つてゐたかも知れない。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇は、八年の長きにわたり、九州地方全部を巡られ、熊襲を平げ、民を撫順し給うた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年四月末、二ヶ月もかゝつた中國九州地方の長旅行から歸つて來て見ると、四圍の事情は私の留守の間に急變してゐて、どうでも差迫つた時間内にその家をあけ渡さねばならなくなつてゐた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "木槿の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その真似をして真昼間の平和な町をあるく九州地方の婦人の姿が、如何に不気味に阿呆らしいかは皆さん御承知のところであろう。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "九州地方の看護婦会の会長さんはよく云う。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年の夏から秋へかけての東京の子女の不良ぶりが、吾が九州地方の少年少女に如何に影響しているかがわかるのは今からでなければならぬ。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "上流家庭に不良が出るわけ　東京の社交婦人の忙しさは、とても九州地方の都会のそれと比べものにならぬ。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校や家庭の眼を忍んで、若い同志享楽したりすると、九州地方では直ぐに「不良」呼ばわりをされる。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "實際私の生家は此六騎街中の一二の家柄であるばかりでなく、酒造家としても最も石數高く、魚類の問屋としては九州地方の老舖として夙に知られてゐたのである。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は大阪俳優を率いて九州地方を巡業した経験もある男で、どういう機会にどういう契約を結んだのか知らないが、明治十八年の四月、大阪俳優の一座をひき連れて上京し、本郷の春木座に根城をかまえて、五月から開場した。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し果して邪馬臺を九州地方に擬定せんには、此の四の官名をいかに解すべきか。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｎ氏は、その翌朝京都を発つて九州地方まで旅をしなければならなかつた。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、『漢書』や「魏志」に九州地方に当時たくさんの女王がいたと書いてあるのは、たぶん支那の航海者がこの勇壮活溌にして政治上に勢力のあったのろくもいのごとき者がたくさん活動しているのを目撃して早合点をしたのではなかろうかと思います。",
              "citation": {
                "source": "ユタの歴史的研究",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたこなたと九州地方を流浪したことである。",
              "citation": {
                "source": "草木塔",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に九州地方は、鉄道を敷設するのは早かったし、農業改良技術を取り入れたり、またいくつかの産業では科学技術を採用もしている。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "北九州地方の炭坑労働者の生活などはこの頃以前にましてひどい有様になって来ている。",
              "citation": {
                "source": "ドン・バス炭坑区の「労働宮」",
                "author": "――ソヴェト同盟の労働者はどんな文化設備をもっているか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "□滞在中九州地方に近い処の方は何卒おあそびにお出下さいまし、なるべくこんな機会にお目に懸れる方には懸つておきたいと思ひます。",
              "citation": {
                "source": "編輯だより（一九一五年九月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "九州地方はよく茶をのむ、のみすぎる方だらう、隣家のものがちよつと来てもすぐ茶をくむぐらゐ、本県人、概して中国人はあまり茶をのまない、普通ならば、茶でも出さなければならない場合でも、ださないですましてゐる。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "九州地方｜大樟尤多しといへども此ごときは未見。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは君の郷里の九州地方とは違うんだよ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "島の中央には、九州地方第一の高山、宮の浦岳、一九三五｜米が聳える。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――僕はそれから、奥の方にある狭い室で、木製のバンコ（九州地方の方言。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に金が思う通りに溜まって一生安楽に暮されるという一種の邪宗門で、切支丹が日本に這入って来るのと同じ頃に伝わって来て、九州地方の山窩とか、××とか、いうものの中に行われておったという話じゃ」「ヘエッ。",
              "citation": {
                "source": "骸骨の黒穂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
