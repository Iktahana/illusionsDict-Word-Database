        "examples": {
          "standard": [
            {
              "text": "「来月のＱＴに向けて、仕事終わりにカフェで模擬問題を繰り返し解いているところさ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "試作品が厳しい環境下で仕様を満たすか確認するＱＴをパスし、ようやく量産が決まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "エンジニアとしての技術力を客観的に証明するため、より難易度の高いＱＴに挑戦する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
