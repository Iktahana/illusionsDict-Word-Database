[
  {
    "uuid": "3d2b8c40-73de-55bb-8b41-639bd6ff9387",
    "entry": "狂熱",
    "reading": {
      "primary": "きょうねつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
