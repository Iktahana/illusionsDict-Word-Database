      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "extreme passion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「やったー！優勝だ！」歓声があがるスタジアム、選手たちの顔には狂熱の表情が浮かんでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は研究に狂熱を燃やし、数日間寝る間も惜しんで実験を続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あのロックバンドのライブは、観客の狂熱が凄まじかったよ！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の頃、あのゲームに夢中になって、親に叱られるほど狂熱していたな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "彼の生活は、今や空虚な狂熱や、耽美的な情緒に惑溺する時代を通り越した。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして激昂する心を抑えてピアノの前に坐り所定曲目モザルトの一曲を弾いているうちにいつか頭が変になって来て、急に嵐のような幻想曲を弾き出す、その狂熱的な弾奏者の顔のクローズアップに重映されて祖国の同志達の血潮に彩られた戦場の光景が夢幻のごとくスクリーンの面を往来する。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "単にその技巧の上から見ても津田君の例えばある樹幹の描き方や水流の写法にはどことなくゴーホを想起させるような狂熱的な点がある。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "靜かな落付いた觀照や、心の澄み切つた靜寂の境地ではなく、常に動亂し、興奮し、狂熱し、苦惱し、絶叫するところの文學である。",
              "citation": {
                "source": "詩に告別した室生犀星君へ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二「今日本にあらゆる種類の全く無用な団体を作ろうとする熱、一種の狂熱がある……文学芸術の研究は決してかかる協会に伴なうものではない。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "又例の計画の狂熱がさめるかもしれない。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "又例の計畫の狂熱がさめるかもしれない。",
              "citation": {
                "source": "計畫",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "情熱というより狂熱ですね」　そう言っているうちに、信吉の頭に、喋っている考え――というより言葉から、ふと思いがけぬ考えが発展して流れて来た。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏蘭西革命当時の狂児でなくとも、あのマルセーユの歌を聴いて狂熱し、街路に突進しないものがどこにあろうか。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの單純な狂熱家が少年の頭には何となく喜劇的に見えたのは主として其爲であつた。",
              "citation": {
                "source": "いろ／＼の言葉と人",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して愚かな狂熱の坩壺の中に一切の智慧も理性も哀楽も焼け爛らして了つたのです。",
              "citation": {
                "source": "わが敬愛する人々に",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その淫蕩無比の臭気、その狂熱、その豊満、将に此の樹木の放つ動物的精液の激臭は下ゆく人をして殆ど昏倒せしめずんばやまなかつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集のはじめに",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、周囲の平凡な真ん中で、戦争当時の狂熱に接する様な気がした。",
              "citation": {
                "source": "戦話",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯父は、いってみれば、昔風の漢学者気質と、狂熱的な国士気質との混淆した精神――東洋からも次第にその影を消して行こうとするこういう型の、彼の知る限りではその最も純粋な最後の人たちの一人なのであった。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　いいかけて寂しく笑った、要するに記者の凡ての言は、お夏に対する狂熱の勃発したものであったのである。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔と首の表現の誇張感はモヂリアニ一流の人物の手を交叉させることに依つて、完全に画面を調和させてゐる『シュミーズの女』の表情の淫蕩性、『若き娘』の疲れたる愛慾の闘士といつた表情、この絵の胸のあたりのタッチの狂熱性は極度にモヂリアニの熱情を知ることができる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま、このタッチの狂熱性が沈潜して内部的な情熱となつて『裸婦』に現れるとき、豊淳な性や、重厚な性に悩む女を描く。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れどもこれ等の信仰は、盲目なる狂熱の独断にあらず、皆冷静の理路を辿り、若しくは、精練、微を穿てる懐疑の坩堝を経たるものにして「監督ブルウグラムの護法論」「フェリシュタアの念想」等これを証す。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども是等の信仰は、盲目なる狂熱の獨斷にあらず、皆冷靜の理路を辿り、若しくは、精練、微を穿てる懷疑の坩堝を經たるものにして「監督ブルウグラムの護法論」「フェリシュタアの念想」等之を證す。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは葉子という一人の存在を亡くするというのと同じことであり、従って現在の狂熱的恋愛の発生もないはずであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛国の狂熱が全国に漲った。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユリエは幽靈の樣な精神病者で、『色も香もない單調な生活に倦み果て』たあげくが、孟夏の狂熱に唆かされて、その身を『破廉耻至極な僕』のジヤンに任せた。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　夜、私は、古着の競売場、茶館、最も雑踏の街衢、または居酒屋にあつて、未知の鼻音の狂熱的な蒐集者であつた。",
              "citation": {
                "source": "断片",
                "author": "富永太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして、散文的に解る問題なもんか」と一旦は狂熱的な口調だったのが、しだいに落着いてきて、「ところで、最初易介が、すでにこの世の人でないとしてだ――勿論何秒か後には、その厳然たる事実が判るだろうと思うが、さてそうなると、家族全部の数に一つの負数が剰ってしまうのだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの七色――それはボードレールによれば、熱帯的な狂熱的な美しさとなり、またチャイルドが詠うと、それから、旧教主義の荘重な魂の熱望が生れてくるのだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と狂熱的な口調でやり返して、最後に、演奏台の端をガンと叩いた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、云うまでもなく、それは一つの臆測であろうけれども、風間の神秘的な狂熱的な性格を知り、彼の悲運に同情を惜しまない人達にとると、何んとなくそれが、欝然とした兆のように考えられて来る。",
              "citation": {
                "source": "オフェリヤ殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
