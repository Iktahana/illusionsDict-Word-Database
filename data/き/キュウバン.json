[
  {
    "uuid": "561dea66-b263-59ce-b063-100839c925b2",
    "entry": "吸盤",
    "reading": {
      "primary": "きゅうばん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
