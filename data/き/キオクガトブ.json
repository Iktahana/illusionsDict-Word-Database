          "standard": [
            {
              "text": "「え、昨日そんなこと言った？全く記憶が飛んでるわ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プレゼンの途中で緊張のあまり、一瞬、頭の中が真っ白になって記憶が飛んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "徹夜で仕事をしていて、いつの間にかウトウトして、その間の記憶が飛んでしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼、お酒を飲むといつも記憶が飛ぶから、あんまり飲ませない方がいいよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
