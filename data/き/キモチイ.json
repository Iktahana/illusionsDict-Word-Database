        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "仇討ちは気持ちいいものだとわかっていたつもりでしたが、これほど魂に安らぎが充ち満ちるとは今まで思ってもみなかったのです。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "素直にぶらさがるのがへちまの本性で見るのも気持ちいいが、ごろりと横になったまま図太くなるのも面白い。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ガマの穂はとっても気持ちいいのよ」　ぼくははっとなった。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでつぎの問題は、何といっても道江の君に対して抱いている気持ちいかんだが、これについては、今言ったようなきわめて薄弱な判断の材料があるだけで、ぼくには決定的なことは何も言えない。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "20日　夜　社交・娯楽といった目に見える快楽は気持ちいいものであるが、移り変わり消えるものだ。",
              "citation": {
                "source": "朝に想い、夜に省みる",
                "author": "MORNING AND EVENING THOUGHTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「気持ちいいわ」　正面から吹いて来る風に向けて、彼女は微笑した。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ているときれいで、気持ちいい」「どんな子だっけ」「陽に焼けた、ひきしまった子。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この水は、気持ちいい」「地下水だよ」「なんですって？",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「風が気持ちいい」「吹いてるね」「時間のせいでしょう。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「気持ちいいわ」「最高よ」「夜は寒いかと思ったけれど、なんともなかった」「私も」「顔を洗ってくる」　裕一は、砂丘のスロープを降りていった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども　きもちいいので、　まったく　てまどることなく、　たまごが　うめまして。",
              "citation": {
                "source": "みずかきジェマイマのはなし",
                "author": "THE TALE OF JEMIMA PUDDLE-DUCK",
                "note": "青空文庫"
              }
            },
            {
              "text": "文章はがっちりしていてきもちいいけれど、やさしいどころか」　それは伸子にも推察された。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
