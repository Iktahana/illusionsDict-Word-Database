[
  {
    "uuid": "c2cfec0d-febd-545e-a968-e0e4f0be5550",
    "entry": "貴公子",
    "reading": {
      "primary": "きこうし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
