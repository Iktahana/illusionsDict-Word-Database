[
  {
    "uuid": "71bf7787-427e-5cdb-8fc5-cb7b8d5b8641",
    "entry": "機械論",
    "reading": {
      "primary": "きかいろん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
