        "examples": {
          "standard": [
            {
              "text": "気温や湿度、降水量などの気候要素を分析して、この土地がブドウ栽培に適しているかを判断する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「風は重要な気候要素の一つだけど、地形によってその影響は大きく変わるんだよ」と先生が説明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地域ごとの気候要素の偏りが、植生の違いとして顕著に現れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ちょっとした山つづきの裏表では日照雨量従ってあらゆる気候要素にかなり著しい相違のあるということはだれも知るとおりである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
