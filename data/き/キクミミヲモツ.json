        "examples": {
          "standard": [
            {
              "text": "リーダーには、反対意見に対しても謙虚に聞く耳を持つ度量が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「よかった、やっと私の話に聞く耳を持ってくれたんだね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "市長は住民たちの不安を解消するため、対話の場で真摯に聞く耳を持つ姿勢を示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "現場の不満を汲み取るためには、管理職がもっと聞く耳を持つべきだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ウォード氏は、しかしながら、権力と仕事に生きる実際的な男で――ポートゥックスト谷のリヴァーポイントに広大な工場をもつ木綿製造業者だった――女のためらいなど聞く耳を持つような人物ではなかった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
