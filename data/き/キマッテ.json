        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は朝起きると決まってコーヒーを淹れるのが日課だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "週末は決まって家族で近くの公園へ散歩に出かける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女が話すと、決まって周りが笑顔になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この店では、ランチタイムには決まって長蛇の列ができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私はたいてい当選者は決まっているだろうと僻み根性を出して、傍観していたら、どうしたことか、私が最高点に当選していた。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺たちと話ししてりゃ片っ端から跟けられるに決まってらあね」「だから、お前は一体何だ、と聞いてるんだよ」「俺かい？",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "価値のあるものなら通過し、ないものは通過しないと決まっているのなら、私利私情などというものの入り込む余地はないではないかということになる。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうあんまりうま過ぎるのはたいていうそに決まっていると言って皆で笑った。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが契沖阿闍梨は古典を調べ、古い時代の仮名の用法を調べまして、古い時代には語によっていずれの仮名を用いるかということがちゃんと決まっていて混乱しない。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう訳であらゆる場合にすっかり決まっているとは言いにくいようでありますけれども、大体において清濁を区別して書いたということは言えるのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "研究題目は上長官の命令で決まっており、その上に始めから日限つきでその日までにはどうでも目鼻をつけなければならないこともある。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の通る道筋は、いつも同じように決まっていた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺の伜が大きくなれァ森の石松の二代目を継ぐに決まってらァ」　と言ったものの石松、ふと故郷の親父の事を思い出して居ます――　「そうだ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌女寿の家へは幽霊が出るということに決まってしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなに強いポチが殺される気づかいはめったにないし、ぬすもうとする人が来たらかみつくに決まっている。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "死にさえすれば、ことに若死にさえすればたいていの奴は天才になるに決まっているんだ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、本当でないに決まっている。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨のふる晩に、長い振袖を着た女の子が戸を叩きに来て、若い男と女とを誘い出して行った――寄れば障ればその噂で、なんの祟りか知りませんけれども、浅井さんもとうとう祟られたということに決まってしまいました。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "化け物の来るのは丑満と決まっていらあ」「まったく秋の夜は長げえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、何時でもそれに決まっている正午の汽車に、晃一の姿は見えなかった。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにいれば大抵の患者は健康になるに決まっているよ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "お八ツ時分になると、甘党の松島は卓上電話で紅谷から生菓子を取り寄せ、玉露を煎れて呑んでいたが、晩餐には姐さんのためにてんやものの料理が決まって二三品食卓に並び、楽しい食事が始まるのだったが、彼自身は口がきわめて質素で、ひじきや煮豆で済ますのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年旅館は決まっていて、六月の半ば過ぎになると、早くも幾梱かの荷物が出入りの若衆の手で荷造りされ、漬物桶を担ぎ出さないばかりの用意周到さで同勢上野へ繰り出すのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自分の取るべき方嚮について、親たちに相談しようというはっきりした考えもなかったし、話してみてもお前の好いようにと言うに決まっているのだったが、何となし家を見たいような気がして、一と思いに乗ってしまった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "私をそうやっておいて、どこかのお嬢さんと結婚するに決まっているわ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の経験から申しても、貴女の不幸になればとて、決して幸福になる気遣いはありません、若い同志で好き合ったから、家へ入れよう入りましょうと、気軽に約束しても、結果は必ずまずいに決まっておりますから、家へ入ることだけは思い止まっていただきましょう。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房で亭主に浮気をされることを考えてごらん、株屋のように体が閑で金にもそう困らない割に絶えず頭脳をつかっているものは、どうせ遊ぶに決まっているよ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　銀子は思うのであったが、時に一緒に歩いている時、コンパクトとか下駄とか、珍しく見立てて買ってくれるかと思うと、決まってそれとほぼ同値の、またはそれより少し優しの類似の品を一緒に買うのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、大隅君には友人も少いし、いまはもう私が引受けなければ、せっかくの縁談もふいになってしまうにきまっているし、とにかく私は北京の大隅君に手紙を出した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の小説が何かに出ると、方々の雑誌屋の店先で小説月評といったような欄をあさって見るが、いつでも失望するにきまっていた。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはどちらがいいか、議論をするとわからなくなるにきまっている。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに対しては出来るだけの応急救済法を講じなければならないことは勿論であるが、同時にまた将来いつかは必ず何度となく再起するにきまっているこの凶変に備えるような根本的研究とそれに対する施設を、この機会に着手することが更に一層必要であろうと思われる。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが猫の毛皮は大抵の物と摩擦すれば陽性になるにきまっている。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い雪、赤い雪、緑の雪　雪と云えば白い物と相場がきまっている。",
              "citation": {
                "source": "雪の話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
