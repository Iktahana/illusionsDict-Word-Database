[
  {
    "uuid": "07f2156e-64c1-5ffe-a67f-7e8b09808fe5",
    "entry": "休職",
    "reading": {
      "primary": "きゅうしょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "temporary retirement",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――病院の下の木造家屋の中から、休職大佐の娘の腕をとって、五体の大きいメリケン兵が、扉を押しのけて歩きだした。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の医師に診てもらうために出て来て私のうちで数日滞在してから、任地近くの海岸へしばらく療養に行っていたが、どうもはかばかしくないので、学校を休職して郷里の浜べに二年余り暮らした。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人苦沙弥先生も今頃は休職か、免職になったかも知れぬ。",
              "citation": {
                "source": "『吾輩は猫である』下篇自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジュリアは二年前のクリスマスにそこへ参りまして、休職中の海軍少佐の方と出会い、婚約の運びとなったのでございます。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅を終えた後、休職扱いにしてもらっていた事務所には戻りませんでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "体操の教師は二人ゐたがＴさんといふ錐のやうな眼の休職曹長が非常に私を憎んだ。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "體操の教師は二人ゐたがＴさんといふ錐のやうな眼の休職曹長が非常に私を憎んだ。",
              "citation": {
                "source": "文學的自叙傳",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ工場に通う老いた職工が火傷のために休職し、喰うにも困っているのを聞くと、私は深甚な同情のようなものに刺戟され、そして、露店を出してセルロイドの櫛やシャボン入れや、その他の小さい道具を小売りし、儲けた利益丈をその老人と家族へ恵んでやろうと云う企画で私を喜ばした。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　トムソンの父が休職の海軍大佐で、後に英介の志望を達せしめた人であつた。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "休職――こうして唯一の生活法であったかれの職業はかれから永久に奪われて行った。",
              "citation": {
                "source": "トコヨゴヨミ",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌日、突然休職の辞令が田中局長の頭に降りかかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "時の宰相ビスマルクに睨まれて、だしぬけに休職といふ辞令を請取つたので、強ひて平気な顔をして宰相に挨拶に往つたものだ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "宰相は肥つた体躯を椅子にもたせて、何か善くない事を考へてゐたらしかつたが、この休職外交官を見ると、急に拵へたやうな愛想ぶりを言つた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "休職の海軍軍人で小金の有る内福な事を繰返し繰返し云ってから、「一刻も早くはあ孫の顔が見たいばっかりで、」と涙をこぼして居た。",
              "citation": {
                "source": "蛋白石",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉子さんは休職軍人の娘だった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "比志島は以前にも借金のために休職になったのだが、日清戦争で復活して、また以前のように盛んに借金していた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅団長はまた幾度も休職になりかかった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてついに比志島は休職となって、そのあとへ師団長のそばにいた何とかいう参謀長がやって来た。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」休職中尉の体操兼舎監の先生が行き成り私を列の前に引き摺り出した。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "発売禁止後に起つた事件と云へば、ただそれ位のもので、私は別に免官にもならず、休職にもならず、戒告一つ受けるでもなしに終つた。",
              "citation": {
                "source": "随筆「断片」",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九四二（昭和十七）年九月、太平洋戦争のさ中に東京帝国大学工学部電気工学科を卒業した大内は、九月三十日に住友通信工業、現在の日本電気に入社、即日休職。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が吾輩を信じてくれる事はトコトンまで疑わんが、しかしそれでも吾輩の休職の裏面に潜む事件の真相なるものが、到底、常識では信ぜられんくらい悽愴、惨憺、醜怪、非道を極めたものがあるから、特に念を押す訳だよ。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……右は前記轟技師の不注意より起りしものなりしと同時に、当局の威信に関する事故なりしを以て、秘密裡に善後の処置を為し、轟技師の休職を以て万事の落着を見たり。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば妻子家族の病気とか、あるいは恋愛関係、それから起こる喧嘩口論や悲劇やうるさい雑用が引きつづきどしどし起ころうものなら絵描きは休職だ。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳が、「きのうだか、一ヵ月は休職のまんまにしとくって話だったじゃないの？",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、あの運転手は免許証を取り上げられるか、休職を命ぜられるか、そのどつちかだ。",
              "citation": {
                "source": "道化芝居",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその間に、休職を願った。",
              "citation": {
                "source": "傷痕の背景",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内の一人は、永らく休職していた筈の尾形警部であったのです。",
              "citation": {
                "source": "赤耀館事件の真相",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾形さんも、そうは思っていられるものの、証拠が見付からないのでとうとう休職まですることになったのです。",
              "citation": {
                "source": "赤耀館事件の真相",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
