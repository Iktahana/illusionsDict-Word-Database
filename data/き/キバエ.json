[
  {
    "uuid": "383294ff-cd94-5033-88b3-4a0fb1886fef",
    "entry": "着映え",
    "reading": {
      "primary": "きばえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(clothes which) look good on a person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "店で見ると派手すぎる気がしたけど、実際に着てみると顔色が明るくなって意外と着映えする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「そのワンピース、すごく着映えするね！どこで買ったの？」と友人に褒められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "シンプルなシャツでも、アクセサリー一つでぐっと着映えが増して見えるから不思議だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "写真映りも大事だけど、パーティーでは動いた時の着映えを一番に考えたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私はいまでもそう信じているのであるが、あのようなロマンスは、おそらくは私が名前を借りたその新進作家ですら書けないほどの立派なできばえだったのである。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも対象はいくら古くても、目と腕とが新しければ、いくらでも新しい「発見」はできるはずだろうが、私の見たできばえでは、そうでもなさそうであった。",
              "citation": {
                "source": "池",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "換言すれば映画芸術の要素としての律動的要素の優秀なるできばえである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかのニュートン祭にやはりこの「エルケーニヒ」か何か歌われたことがあると思うが、そういうときでも先生は、「要するに、やるという事がハウプトザッヘだから……」と言って、決して巧拙のできばえなどは問題にされなかった。",
              "citation": {
                "source": "田丸先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "田畑のできばえのことから近隣村内のできごとや、親類のいざこざまで、おもしろかったこと、つまらなかったこと、いまいましくて残念であったことなどのいっさいを予に話して聞かせる。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こちらでお作りになったのがよい色じゃなかったというあてつけの意味があるのではないでしょうか」　と一人の女房が言うように、だれも常識で考えてそうとれるのであるが、「でもあれだって赤くて、重々しいできばえでしたよ。",
              "citation": {
                "source": "源氏物語",
                "author": "末摘花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことにここでのできばえを皆晴れがましく思っているのである。",
              "citation": {
                "source": "源氏物語",
                "author": "初音",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああしじゅうせっついていちゃ、せっつきばえがしないからだめですよ」と美禰子が評した。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗七焼きの粋というしろものを、しみじみ拝見するかね」　いいつつ、あちらこちらとたなからたなへ見ながめていたその目に、はしなくも映ったのは、ひときわできばえのすぐれた三体の人形です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、よくよく見比べると、三体の焼きぐあい、色付けの仕上がり、細工のできばえに、あきらかな優劣が見えるのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと拝見するかな」　仕事に精進していないといったはずの弥七郎の作が、師泥斎をもしのぐできばえに不審をうって、いぶかりながら手にとりあげて台じりを返して見ると、なるほど彫りがある。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ離れて行くなら、つまらないものの掌に落ちるよりも、行きばえのする相手に落ち着いた方がいいという考え方もないわけではなかった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説としてのできばえからいえば、この作品は作者自身にとっても自信ある作とはいえないであろう。",
              "citation": {
                "source": "作品のテーマと人生のテーマ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、稲のできばえによって、年貢の上り高がちがう地主が、自己の利害の打算から、その季節と雨とが作物に及ぼす関係を敏感に計算する、その感情の生々しさも理解し得ないであろう。",
              "citation": {
                "source": "自然描写における社会性について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏は予想に越えたおできばえに驚いた。",
              "citation": {
                "source": "源氏物語",
                "author": "梅が枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの今日のできばえはたいしたものだった」　と衛門督へお言いになると、微笑を見せて「他の点では父祖を恥ずかしめるような私でございますが、遺伝の蹴鞠の芸だけで後世へ名を残すことになりましたらそれで無事かもしれません」　と言った。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "明石夫人以外は皆院の御弟子なのであるから、院も大将が聞いて難のないようにとできばえを祈っておいでになった。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（下）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「キットに付属しているカタログ・マニュアル類のうち、『μＣＯＭ―八〇トレーニング・キットＴＫ―八〇ユーザーズ・マニュアル』（マニュアル番号ＩＥＭ―五六〇）の内容は、抜群のできばえである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもただ念力だけでは作物のできばえを左右する訳にはどうしたって行きっこない、いくら佳いものをと思っても、思うようになるかならないか自分にさえ予言のできかねるのが述作の常であるから、今度こそは長い間休んだ埋合せをするつもりであると公言する勇気が出ない。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「痛くございません、あの人にたたかれるよりは、決して痛くございません」　いい気になって、いくつでもたたかせているから、お絹も張合い抜けがして、こんな安っぽい頭を、いくつたたいてもたたきばえがしないと見切り、手荒く突き放してしまったものですから、ハズミを食って、三尺ばかりケシ飛んでしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは今の団欒の中に、金椎とお松だけが加わっていないらしいから、駒井はここへ来て、扉をコツコツと叩いたが、叩いても叩きばえのする金椎でないことに気がつくと、そのまま扉をあけ放しました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、ハーガーは、じぶんのしたことを告げますが、その歌は、一ばんすばらしいできばえでした。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣り合いのとれない構図、大胆な配色、不細工な鉄枠の使い様、まことに素人臭いできばえである。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "しめしめ　――　これで　きまり　――　はたして　ねらった　いじょうの　できばえです。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "このできばえには実際驚異を覚えずにはいられない。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこの等伯の松林図は、構図といひ、用筆といひ、墨色といひ大和絵の浜松図などの形式をぜんぜん無視した斬新なできばえで、その新鮮さは桃山時代に生まれていまなほつづいてゐる。",
              "citation": {
                "source": "長谷川等伯の「松林図屏風」",
                "author": "吉野秀雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあて　ぞろぞろ　ねっこのこ　ぬったものを　われさきに　つちつちママに　もってって　できばえを　みてもらうのです。",
              "citation": {
                "source": "ねっこうまれのこびとたち",
                "author": "ETWAS VON DEN WURZELKINDERN",
                "note": "青空文庫"
              }
            },
            {
              "text": "おできばえがよければよいだけお礼の高もふえるのですから。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あツ、危ないよ、師匠」「何を言つてやがんだ、女の子に抱き附いて役得の氣で居やがる」「女の子も四十幾つとなれば、抱附きばえもしないよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "血塗られた祝言",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう身の上話は然し陳腐で、ありふれていて、ききばえのある話などは、先ず、ないものだ。",
              "citation": {
                "source": "大阪の反逆",
                "author": "――織田作之助の死――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
