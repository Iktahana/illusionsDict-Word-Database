    "definitions": [
      {
        "index": 1,
        "gloss": "unpleasant",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "非常に気持ちが悪い。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――嫌やよ、気持ちが悪い。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母などは病人の頭髪のようで気持ちが悪いと言ったりした。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "七日ばかりは気持ちが悪い。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルブランのものは面白いけれども、犯罪の方が主で、探偵の方が失敗するのだから、気持ちが悪いように思われる。",
              "citation": {
                "source": "科学的研究と探偵小説",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしたのかと思って、気持ちが悪いから、雪を払おうとすると、夢が覚めた。",
              "citation": {
                "source": "夢占",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "千枝子はケーブルが動き出すと、気持ちが悪いと云って顔を少しも上げなかった。",
              "citation": {
                "source": "比叡",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "気持ちが悪いよ」とまたすすめた。",
              "citation": {
                "source": "比叡",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ気持ちが悪い、どっか、せいせいするところがないかね。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳がかゆくて気持ちが悪い。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "足袋がまっくろで気持ちが悪い。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗びっしょりで、何とも気持ちが悪い。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コオルドクリームはお気持ちが悪いと云ってお使いにならない方がございますが、これはお寝みになります時、こうして万遍なく顔へ塗ってガーゼでお拭き取りになれば、まことにさっぱりするものでございます。",
              "citation": {
                "source": "帯広まで",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "気持ちが悪いンですの？",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うん一人占めと云われちゃ俺も何んだか気持ちが悪い。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気持ちが悪いったらない。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか気持ちが悪い。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロープとリュックサックは、ティンダル博士がワイスホルンの登山に使ったと云う、頑固な奴だの、救命用具では、丁寧に、かつぐばかりにズックの担荷に包んだ、等身大の人形まで並べてある、繃帯の間から蒼ざめた顔を半分だして、御前も気をつけなよって云ってるようなのが気持ちが悪い。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の行衛を見送ったが、さすがに気持ちが悪いらしい。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、前から来ていて買物を済まして、その時出て行こうとしていたお妾ふうの粋な女が、供の下女と一しょに引っ返して来て、こういう事件ができた以上、このまま帰るのは気持ちが悪いから、気のすむように身柄を審べて貰いたいとかなり皮肉に申し出た。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "うし紅珊瑚",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の知人に日本剃刀は音がしないが、西洋剃刀はケンケン鳴るので気持ちが悪いと云つた人があるが、ペンと毛筆の比較に於いても同じことが云へる。",
              "citation": {
                "source": "文房具漫談",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも自分の死ぬのが分ると気持ちが悪いからと言って、女の人などが病気になってもよう来ないのがあったそうです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗の出るまでやらないと僕は気持ちが悪いんだから。",
              "citation": {
                "source": "金色の死",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と考えますと、もうからだじゅうが、じっとりとつめたく汗ばんできて、こわくてしかたがないのですが、でも、あらためて見なければ、なお気持ちが悪いものですから、思いきって毛布の中から手をのばして、その紙を取ってまくらもとの卓上電灯の光にかざしてみました。",
              "citation": {
                "source": "大金塊",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "電気が周りに流れており、気持ちが悪いので、引き返して列車に戻った。",
              "citation": {
                "source": "見えざる力",
                "author": "THE INVISIBLE FORCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、くせになっているものですから、散歩をしないと、なんとなく気持ちが悪いので、信太郎氏は、その暗い森の中を、ブラブラと歩きまわっているのでした。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
