    },
    "definitions": [
      {
        "index": 1,
        "gloss": "far left (in politics)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "呉の時に太極眞人が會稽の上虞山に於て太極左宮仙翁葛玄に度人經を授け、靈書中篇を増した。",
              "citation": {
                "source": "道教に就いて",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "――俺、それは極左的でないと思うんだが、どうだろう？",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　須山は、誰かゞそれを「極左的だ」と云ったかのように、それに力をこめて云った。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私は、それを極左的だというのは、卑怯な右翼｜日和見主義者が自分の実践上での敗北主義をゴマ化すために、相手に投げつける言葉でしかないと、須山に云った。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月廿七日　まだ明瞭ではないが極右と極左が競り合っているとの事だ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞も極左翼と極右翼の二つだけが、ようやく発行をつづけている。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その数間後から、極左がそれをもみ消すように叫んで来る、すると、今度は極右、極左、と売子同志の声の争いが連続して来る。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は我国の三・一五、四・一六の後に起った、解党派、新労農党結成、或は一揆主義的極左主義的偏向を想起することが出来る。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "右翼的日和見主義を撃破し、トロツキーの極左的敗北主義に対して、建設の全事実が一国社会主義の可能を証明した。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは文学におけるレーニン的段階の確立のための推進、文学における党派性などについての理解が、彼女には「極左的」な響と感じられているのであろうか。",
              "citation": {
                "source": "前進のために",
                "author": "――決議によせて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、誰にでもわかる通り、これは誤った極左機械主義だ。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベズィメンスキーの極左機械主義にまけずプロレタリア・リアリズムの本質をゆがめている。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシア・プロレタリア作家連盟（ラップ）が右翼「同伴者」の反革命的要素と飽くまで闘争しながらも、自己の陣営内で、極左的傾向を注意ぶかく批判したわけがここにあるのである。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにも拘らずベスパーロフの理論の中には、多分な機械主義があり、詩人ベズィメンスキーの極左主義と結びついた。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大衆は、集団農場化の実践において、仕事が困難であるため特別に多かった極左的な誤謬を、党が、どんなに厳密に批判したかを、よく知っている。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "農業の社会主義化に関するブハーリンの右翼的誤謬といっしょに、極左的誤謬も、スターリンのステートメントによって屡々指摘批判された。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "党とそれを支持する労働者農民が、五ヵ年計画第一年から農村集団農場化の実践によって経験した国内の反動・右翼日和見との闘争、極左主義、前衛主義の克服等は、光彩ある歴史の中でも、画期的な価うちをもつものであると思う。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Hegel 派の極左党で、無政府主義を跡継ぎに持っている Max Stirner の鋭利な論法に、ハルトマンは傾倒して、結論こそ違うが、無意識哲学の迷いの三期を書いた。",
              "citation": {
                "source": "沈黙の塔",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二話　極左の蠅　その頃、不思議な病気が流行った。",
              "citation": {
                "source": "蠅",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "極左の一人として残る医学士の彼が、蠅に黴菌を背負わして、この恐ろしい犯行を続けていたことが明かになった。",
              "citation": {
                "source": "蠅",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治に於ては、私は、極右も、極左も、とらない。",
              "citation": {
                "source": "戦争論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし右の毒茸族のうちでも、今宵の犯罪者は、極左に属したものでないことだけは、不幸中の幸でありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒茸党の極左に属するものには、人間が手を触れただけで、その触れた部分を腐らせてしまうものがある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "看板を書き替えた手前、一刻も早く民主的実践を示さんとして極左的の勢力に取り縋ったのが間違いだったのである。",
              "citation": {
                "source": "日本出版協会論",
                "author": "嶋中雄作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで肥後に会同した清河その他に、薩藩左派の抬頭を報じてやがて薩藩極左派と連絡できる素因をつくったのは長州竹崎の商人｜白石廉作である。",
              "citation": {
                "source": "新撰組",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "薩藩は文久元年十月来公武合体派たる誠忠組の天下となって、応じて極左尊攘派も進出して、その領袖は藩校の国学教師｜有馬新七、無数の糸で町人身分と連がる外城郷士達が組織されていた。",
              "citation": {
                "source": "新撰組",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そう言えば此処の工場主なんかも言ってたよ、いっそ極左の奴等の方が仕末がいい位だってんだ、そいつ等だと、私等が何も構わなくても、警察の方が来てすぐ引っこ抜いて行って下さるし、後腹がちっとも痛めないし、――ってんだ、ハッハッハ。",
              "citation": {
                "source": "鋳物工場",
                "author": "戸田豊子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「見ろ、極左の蠢動する処、弾圧の如何に加重するかを！",
              "citation": {
                "source": "鋳物工場",
                "author": "戸田豊子",
                "note": "青空文庫"
              }
            },
            {
              "text": "外部的な・一般的な・公式上の合致は往々吾々を欺く、夫は丁度、排斥されるべき極左的偏向が無意識的に、往々は実に意識的に、反動を代表するのと同じである。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
