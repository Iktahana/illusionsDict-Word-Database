        "examples": {
          "standard": [
            {
              "text": "大衆の意見に流されず、自らの信念を貫くキュニコス派の姿勢は、時に周囲の反感を買いました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ディオゲネスに代表されるキュニコス派の哲学者たちは、質素な生活を送り、社会の慣習に疑問を投げかけました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "現代においても、世俗的な価値観を拒否する人々を指して、比喩的に「キュニコス派」と表現することがあります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "（ギリシア哲学の）「キュニコス派」は哲学者に属する極端な実例である。",
              "citation": {
                "source": "人間本性論（人性論）",
                "author": "A Treatise of Human Nature",
                "note": "青空文庫"
              }
            },
            {
              "text": "キュニコス派は、純粋に哲学的な推論に基づいて、世界でこれまでに存在した「キリスト教の修道士」や「イスラム教の苦行者」よりも、さらに突飛な行為に及んだのであった。",
              "citation": {
                "source": "人間本性論（人性論）",
                "author": "A Treatise of Human Nature",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
