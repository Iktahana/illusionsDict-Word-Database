          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "隣の部屋に住む気のいいおじいさんは、いつも採れたての家庭菜園の野菜を分けてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あいつは本当に気のいい奴だから、無理な頼み事でも断りきれないんだよな。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "旅先で道に迷った際、気のいい店主が仕事の手を止めて目的地まで案内してくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "日曜に天気のいいという確率、家族の甲乙丙の銘々が暇だという三つの確率、この四つがそれぞれ二分の一ずつだとしても、十六分の一しか都合のいい日の確率はない訳であるから、統計的に云えば思い立ってから平均十六週すなわち約四ヶ月待たなければならなかったとしても大して不思議はない勘定である。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京では、夏の暑い盛りに天気のいい日だと夕方涼しい南がかった風が吹くので、瀬戸内海地方のような夕なぎの苦しみを免れている。",
              "citation": {
                "source": "海陸風と夕なぎ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の入口の外の廊下には色々の人声がしていた、長岡先生のいつものような元気のいい改まった言葉も聞えた、真鍋さんが何か云うと佐野さんの愉快そうに笑う声も聞えた。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ出かける時になって始めて中村先生の声がすぐ側に聞えた、松本君の元気のいい声も聞えた。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山椒の皮を春の午の日の暗夜に剥いて土用を二回かけて乾かしうすでよくつく、その目方一｜貫匁を天気のいい日にもみじの木を焼いてこしらえた木灰七百匁とまぜる、それを袋に入れて水の中へ手でもみ出すことです。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山椒の皮を春の午の日の暗夜に剥いて土用を二回かけて乾かしうすでよくつく、その目方一貫匁を天気のいい日にもみじの木を焼いてこしらえた木灰七百匁とまぜる、それを袋に入れて水の中へ手でもみ出すことです。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人も生れ落ちるとこの山で育ったので、何にも存じません代り、気のいい人でちっともお心置はないのでござんす。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどあの根気のいいドイツ人に、日本語のうまい、そして文字までも書く事のできる人の多いわけだと思った。",
              "citation": {
                "source": "数学と語学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにまた天気のいい気分のいいおりに小さな鏡を机の前に立てて見たら、その時は鏡の中の顔が晴れ晴れとしていて目もどことなく活気を帯びて、前とは別人のような感じがした。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "測候所で案内してくれた助手のＢ君は剽軽で元気のいい男であった。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんの気なしにもらって飲んだお茶の水は天気のいい時は峰の茶屋からここまでかつぎ上げなければならぬ貴重なものである。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "飼い主でさえ、噛みつかれぬとは保証できがたい猛獣を、（飼い主だから、絶対に喰いつかれぬということは愚かな気のいい迷信にすぎない。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとすぐうしろから来た元気のいいはしらがどなりました。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天気のいい日に、嘉十も出かけて行きました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お天気のいい時教室さはいってるづど先生にうんとしからえるぞ。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "気のいい火山弾宮沢賢治-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）座っていました。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして気のいい火山弾は、だまってわらって居りました。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいしいヤシの実だの、パイナプルだの、バナナだの、赤と紫の大きな花だの、香気のいい草だの、又は、大きい、小さい鳥の卵だのが、一年中、どこかにありました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "相変わらず元気のいいのが今井の叔父さんで、『君の鉄砲なら一つで外れたらすぐ後の一つで打つことができるが僕のはそう行かないから困る、なアに、中るやつなら一発で中るからなア』と言って『あははははは』と笑った。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "見たところ元気のいい子で、顔も背中も渋紙のような色をして、そして当時｜流行っていた卑猥な流行唄を歌いながら丸裸の跣足で浜を走り廻っていた。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "元気のいい人たちの中には少数の沈んだ顔もあった。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ二人の似ているのは人まねでないということと、根気のいいという点だけである。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思うとまた天気のいい金曜が続きだすとそれが幾週となく継続することもあるように思われた。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがやっと天気のいい金曜の回りがやって来て、それから数週間はずっとつづいた。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "船の出るとき同行の芳賀さんと藤代さんは帽子を振って見送りの人々に景気のいい挨拶を送っているのに、先生だけは一人少しはなれた舷側にもたれて身動きもしないでじっと波止場を見おろしていた。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あしたはきっと何とかなるよ」　それから世間で聞いて来た面白い話や、とても景気のいい私たちの未来の空想話をして、床に入ると思うと、いい気持ちそうに直ぐに鼾をかきました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "品川に気のいいお茶屋があると云つては、いろいろの友達にも紹介した。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも僕の景気のいい時ならいいんだが、もう為方がないときばつかり騒ぐから、逃げて行く女に手当もやれずさ。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "天気のいい日には鳶が輪をかく。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼女は響きのいい、すき通るような声を出した。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
