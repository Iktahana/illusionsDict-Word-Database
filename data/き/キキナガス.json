[
  {
    "uuid": "7af47644-49c3-5e7a-aa8a-7db781ae6dc0",
    "entry": "聞き流す",
    "reading": {
      "primary": "ききながす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
