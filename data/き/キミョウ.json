[
  {
    "uuid": "1513fdef-94ab-5075-9a49-ff0ebb5c7721",
    "entry": "奇妙",
    "reading": {
      "primary": "きみょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
