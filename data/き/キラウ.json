[
  {
    "uuid": "bae7506d-0e9d-56f8-8953-8136955cd07e",
    "entry": "嫌う",
    "reading": {
      "primary": "きらう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to hate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「嫌う」ともちがうし、「こわがる」ともちがう。",
              "citation": {
                "source": "ピタゴラスと豆",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "書かせ給ふは何ならん、何事かの御打合せを御朋友の許へか、さらずば御母上に御機嫌うかゞひの御状か、さらずば御胸にうかぶ妄想のすて所、詩か歌か。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が人を揶揄することを好んで人から揶揄されることを嫌うのは都会的｜諷刺家の性分で、父親はそれが娘だとぐっと癪に触った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前はむさんこに肥を振りかけるせに、あれは嫌うとるようじゃないかいの。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、彼等は、その毛虫の嫌う、社会主義によらなければ、永久の貧乏から免れないのだ。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも最初のうちはあやまって堪忍されたのであるが、あまりにそれが度重なるので、ほかの芸人がすべて彼女と一座するのを嫌うようになった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、内地の船頭が土左衛門を舟に積むのを忌み嫌うように。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間が蛇を嫌うのは、大昔に、まだ人間とならない時代の祖先が、爬虫に、ひどくいじめられた潜在意識によるんだ、と云う者がある。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「庄屋の旦那が、貧乏人が子供を市の学校へやるんをどえらい嫌うとるんじゃせにやっても内所にしとかにゃならんぜ。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人夫妻の方ではその翌日の仕事が駄目になりまして、その不満がお客に向うと、「あのお客達は長尻で困る」などと愚痴をこぼし、終いには訪問されるのを嫌うようになります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　わたしは今日始めて、平生わたしの呪術を嫌う娘から、本当の声で母と呼ばれた。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上また母親はあらかじめ一封の書を認めておいて、不断滝太郎から聞き取って、その自分の信用を失うてまで、人の忌嫌う我児を愛育した先生に滝太郎の手から託さするように遺言して、（私が亡くなった後で、もしも富山からだといって人が尋ねて来たら、この手紙を渡して下さい。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も老人病弱者にても若し肉食を嫌うものがあればこれに適するような消化のいい食品をつくる事に就ては私共只今充分努力を致して居るのであります。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すいても嫌うても、気立の優しいお妓だから、内証で逢いに行っただろさ。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いや、家内安全の祈祷は身勝手、御不沙汰の御機嫌うかがいにおまいりしながら、愚痴を云ってちゃ境内で相済まない。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居や講談にはややもすると拷問の場が出るが、諸大名の領地は知らず、江戸の奉行所では前にいったような事情で甚だしく拷問を嫌うことになっている。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "御馳走になったからお世辞をいうのじゃあねえが、あなたのような人を嫌う者はありますまい。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫌うなら嫌うが可い、妾ア必然祟って与るから……。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫌えば嫌うほど執念深く祟って与るのが当然だアね。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は決してお前を嫌う訳じゃアない。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "決してお前さんを嫌うんじゃないよ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お杉の霊魂は此窟を去るのを嫌うのであろう。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　敵は最も火を嫌うのである。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが嵩じて、あくる年の三月頃になると、かれは燈火をも嫌うようになった。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "月といわず、日といわず、燈火といわず、すべて自分の影をうつすものを嫌うのである。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし源吉の先例があるので、諸人はその復讐を恐れて、直接に彼に対してどういう制裁を加えることも出来なかったが、自然の結果として彼を忌み嫌うようになった。",
              "citation": {
                "source": "深川の老漁夫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所の人達もおせんの素姓をよく知っている上に、片輪の少女に対する一種の同情もまじって、その父を嫌うようにその娘を嫌いはしなかった。",
              "citation": {
                "source": "深川の老漁夫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、詳述をはゞかるが、世人の忌み嫌うある種族の一人であったのだ。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが併し、それでは例えばバアイック公爵を初めとしてその他の多くの名流の紳士達が君と同席することを嫌うばかりでなく交わり迄を断とうとするのはどうしたことであろう？",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから蜘蛛や蟹をきらう人も知人のうちにある。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
