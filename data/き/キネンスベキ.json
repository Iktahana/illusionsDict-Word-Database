    "definitions": [
      {
        "index": 1,
        "gloss": "commemorable",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "本日はわが社にとって、創業百周年という記念すべき日を迎えました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「よし、ここが僕たちが初めて出会った記念すべき場所だね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "記念すべき第十回の大会では、過去の優勝者が全員招待されるという豪華な企画が用意されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それがもうみんなとうの昔に故人になったしまって、それらの記念すべき諸｜国手の面影も今ではもう朧気な追憶の霧の中に消えかかっている。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この謎のような言葉の解釈を彼自身の口から聞く事の出来る日が来れば、それは物理学の歴史でおそらく最も記念すべき日の一つになるかもしれない。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もない中空で、一片の雲のように易々と、停っていられると云う道理は、人生の曙に於いて、はじめて私が直面した記念すべき謎であった。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "池田屋斬込み　新撰組結成の翌年、元治元年六月五日は、彼等にとつて、最も記念すべき日であつた。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "記念すべき一回目の配本に間に合わなくなるのは残念でしたが、その時にはもう、浮かんできた構図を確かめながら書いて行くことが、心のあらかたを占めていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは僕にとつても芥川にとつても記念すべき旅行だつた。",
              "citation": {
                "source": "世に出る前後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌集は私のものゝ中でも最も記念すべきものである樣に思はるゝ。",
              "citation": {
                "source": "樹木とその葉",
                "author": "野蒜の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの記念すべき最後の夜、あの人は妾が何もかも思い切って逃げたと思ったのです。",
              "citation": {
                "source": "華やかな罪過",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "山内義雄氏はフランス文学のうつし手として、これまでも多くの意義ある業績を示しておられるが、この「チボー家の人々」は訳者の努力をも記念すべき位置におく種類の作品であると思う。",
              "citation": {
                "source": "次が待たれるおくりもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日は人類の永遠に記念すべきとうとい日です。",
              "citation": {
                "source": "ジェンナー伝",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "記念すべき細君の床揚の祝いにつけても、どうかして主人は捨吉を喜ばそうとしているように見えた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「党生活者」は、真にボルシェヴィクらしい前衛作家によって前衛の生活がこまかく書かれた初めての作品として記念すべきばかりでない。",
              "citation": {
                "source": "小説の読みどころ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年はひろい規模で様々の祝典が催されたり、日本の歴史の上での記念すべき年として予定されているわけですが、日常生活が市民一般にあらわしている相貌に於ても、現実的にごく画期的なものをもっているのは興味ふかいところであると思います。",
              "citation": {
                "source": "歳々是好年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争が不条理に拡げられ、欺瞞がひどくなるにつれて、日本じゅうの理性を沈黙させ、それをないものにしていた治安維持法が撤廃された記念すべき日も、近くふたたびめぐり来ようとしている。",
              "citation": {
                "source": "現代の主題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この記念すべき機会に、どうか一言、同志リャザーノフに挨拶を願いたい。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "記念すべき一九一七年以来、毎年、国家計画部と最高経済会議とが中心になり、ソヴェト同盟内の各企業の生産力、労働力、消費、などを調査し、その年の生産予定をきめた。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはソヴェトのプロレタリア文学運動にとって記念すべき大会の一つだった。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、きっと一九〇五年の、記念すべき時代を自身工場の中にいて、経験したのだろう。",
              "citation": {
                "source": "ロシアの過去を物語る革命博物館を観る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "記念すべき一九一七年からソヴェト同盟は年々当面の生産計画とともに常に先へ先へ五ヵ年位ずつ一まとめにした生産拡大計画をもって進んで来た。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「憑きもの」は網野菊という一人の婦人作家にとって、記念すべき作品であるばかりでなく、日本の大多数の婦人が、封建性を否定する情勢の動きによって、自分たちの運命に重く憑いていたものが何であるかを知りはじめた、その真面目で、率直な記念とも云える作品であると思う。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おさえ切れぬ嬉しさにそゝられて、日毎見馴れている玻璃窓外の躑躅でさえ、此の記念すべき日の喜びを句に纒めよと暗示するかのように見える。",
              "citation": {
                "source": "小さな旅",
                "author": "富田木歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "抽斎が迷庵門人となってから八年目、文化十四年に記念すべき事があった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰るに先つて諸家に招かれた中に古賀精里の新に賜つた屋敷へ、富士を見に往つたなどが、最も記念すべき佳会であつただらう。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その百十　此年文政三年冬の半に、蘭軒の姉｜幾勢が記念すべき事に遭遇した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その百六十九　此年文政八年の秋には、蘭軒の家に猶一｜事の記念すべきものがあつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢代はもうこの記念すべき房へは二度と来ることはあるまいと思い、よく桟敷を眺めそれから外へ出た。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな記念すべき正月はない。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪最初の記念すべき洋館であり、ある西洋人の設計になったものだと聞くが詳細の事を知らない。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞ此の月の事を只に私の日記に――生涯の記録に意味のあると云うばかりでなく、世界の文学史上に記念すべき月とさせたいものである。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
