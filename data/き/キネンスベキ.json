[
  {
    "uuid": "0172799e-1b6a-5c30-bf6a-2af49ea95736",
    "entry": "記念すべき",
    "reading": {
      "primary": "きねんすべき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
