    "definitions": [
      {
        "index": 1,
        "gloss": "bridge tower",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "擦過した氷山は、船橋塔より遙かに高かったと言われている。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "海を圧する歓呼と万歳声裡に船橋塔の彼方、檣に高く英国旗を靡かせたイキトス号はいよいよ巨体を揺すぶって埠頭を離れ始めたが、太子はただ彫像のごとくにこちらを瞶めて立っていられるのみであった。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
