[
  {
    "uuid": "0ce7bde1-0675-5242-b60a-dbe21789607c",
    "entry": "共闘",
    "reading": {
      "primary": "きょうとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
