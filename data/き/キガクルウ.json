        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "明日の運命の墓誌銘をつくるために妾は女だてらに気が狂うほど急がしいのです。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の運命の墓誌銘をつくるためには妾は女だてらに気が狂うほど急がしいのです。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、いまに気が狂うのかも知れません。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『そうよ懐が寒くなると血がみんな頭へ上って、それで気が狂うんだろうよ』と言ったのは長屋の者らしい。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、それだけなら、ただ気が狂うだけね。",
              "citation": {
                "source": "かけっこ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "気が狂うかも知れぬ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一の所化　所化長順が気が狂うてござる。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気が狂うても見せられようか。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく気が狂うか全くの虚脱状態になってしまうだろう。",
              "citation": {
                "source": "中毒",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "気が狂うまで自分を愛してくれるなんて、世界じゅうにあの人ほど自分を愛してくれた人はいないのだ！",
              "citation": {
                "source": "街頭の偽映鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "百日のあいだは我が姿を人にみせるなというお告げにそむいて、みだりに奥をうかがう時は、仏罰によって眼が潰れるか、気が狂うか、どんなわざわいを蒙らないとも限らない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蝶合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さりとて菊めも気が狂うたとも思われぬ。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ鈍痛とのみ思っていた痛みは、どっちに臥返ってみても我慢のできないほどな激痛になっていて、気が狂うように頭は重くうずいた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は気が狂うのではないかと思って、その時はっとしたのをおぼえている。",
              "citation": {
                "source": "オパール色の手紙",
                "author": "――ある女の日記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "）さりとて気が狂うたとも思はれぬ。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「法性寺の阿闍梨も気が狂うたそうな」　阿闍梨もという言葉に深い意味が含まれているらしく聞こえたので、千枝太郎は又ぞっとして師匠の顔をみあげると、泰親はさらに説明した。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二「阿闍梨も気が狂うたそうな」　丁度それと同じ頃に、おなじ詞が関白の屋形にある玉藻の口からも洩れた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼長め、いよいよ気が狂うたと見ゆる。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「彼の時代には己も若かったし、力も有たしナア、　今のみじめな様子は、マア報いかな、　馬鹿にして居る」　こんなことを云って、うすばかな、しまりのわるい五十姿の女房に別れて着物のほころびまで自分でなおしながら暮して居るこの頃の孤独の生活が気が狂うほどいやで有った。",
              "citation": {
                "source": "ピッチの様に",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここかかしこか、とやかくというている間にその漁夫が気が狂うてしまった。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "気が狂うと人は唖になるものなのか。",
              "citation": {
                "source": "或る作家の厄日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊女一　気が狂うのではないかと思うと、一方ではまたしっかりしたところがあるしね。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の肉体は、この急速度に対抗できても、心理的に疲れて、気が狂うか、もしくば心臓が破裂するだろう。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
