    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to cut up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私には、もう、あなたの本心といふものが、こんど、はつきりわかつたわ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしも今それがはつきりわかつたわい。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分達は間違つてゐた、人はかういふ風にして、いたはり合はねばならないのだ、と心の奥ではつきりわかつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて、その出来る、醸される形がはつきりわかつてゐないと共に、そのあとに残される、朽ちずに残されるものが本当にきまつてゐない。",
              "citation": {
                "source": "黒猫",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "これによつて見るも、船醉は精神の持ちやうによつて起つたり起らなかつたりするものだといふことがはつきりわかつたと思ふ。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "假りに肺病だといふことが本人にはつきりわかつてゐたとしたら、では醫者にかかつたでせうか？",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今此処に生憎その雑誌がないので具体的な例を挙げて云ふことは一寸出来ないが黒岩氏はまだ頑として男尊女卑の信条にかぢりついてゐられるのがはつきりわかつてゐる。",
              "citation": {
                "source": "最近の感想",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "その姿が僕には、だんだんはつきりわかつてくる。",
              "citation": {
                "source": "魔のひととき",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "良平はその電燈の光に頭から汗の湯気の立つのが、彼自身にもはつきりわかつた。",
              "citation": {
                "source": "トロツコ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず文芸上の作品に必しも誰も動かされないのは彼にははつきりわかつてゐた。",
              "citation": {
                "source": "或阿呆の一生",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間何時死ぬかつう事も、親の生れた時と子の生れた時さへはつきりわかつてせえゐりやあ、すつかり知れるものでごわすからなあ。",
              "citation": {
                "source": "山を想ふ",
                "author": "水上瀧太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　三田は三番の部屋のなかの光景がはつきりわかつた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがはつきりわかつてゐると、どうにも僕の氣持をきめることが出來るんだけれど、幾ら問詰めて行つても更にはつきりした手應へがないんでね。",
              "citation": {
                "source": "蠢く者",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、今日、おれには、はつきりわかつた。",
              "citation": {
                "source": "歳月",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手に十分心の通じない焦躁、常に相手の顔が見えぬ物足りなさ、相手の気持がわかつたやうでまだはつきりわかつたと云ひきれぬ不安、競争者の現れる危惧など。",
              "citation": {
                "source": "青年の夢と憂欝",
                "author": "――力としての文化　第五話",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがはつきりわかつてゝも？",
              "citation": {
                "source": "誰でもない……自分でもない",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "――事務所の受附ではつきりわかつてゐるのは作曲家の巨摩六郎だけで、あとの男二人についてはどうもあいまいなことしか覚えてゐず、いろいろな印象を綜合すると、どうも、その一人は以前の伴奏者金谷秀太らしく、もう一人は、一度数週間前に訪ねて来たことのある例の軽井沢の青年に違ひないといふ断定が下されました。",
              "citation": {
                "source": "誰でもない……自分でもない",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういふ点からいつても彼を非難すべきいはれはないといふことが、彼女にもはつきりわかつてゐる。",
              "citation": {
                "source": "ある夫婦の歴史",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏は昔からの貧乏だが、世の中へ出ると、自分のゐるところがはつきりわかつて来るね。",
              "citation": {
                "source": "屋上庭園",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その砂浜の上を手をつないで、輪になつた一群の女が、髪をふり乱し、からだを前後に大きくゆすぶり、低い合唱につれてゆるゆると廻る有様が、はつきりわかつた。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "お世辞でないことは、その声のうるんだ調子ではつきりわかつた。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間一人が満足に育たないとなると、日本といふ国は、これや考へもんですぞ」　誰も、その言葉の意味がはつきりわかつたものはなかつた。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女には伯爵の「苦しみ」といふのがはつきりわかつたとはむろん云へなかつた。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "北原先生のおところがはつきりわかつたら教えてちようだい」　市ノ瀬牧人を帰してしまつて、康子は、ことによると、もつと話して行きたかつたのではなかろうかと思つた。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「曲者は、外から入つたのではないと、はつきりわかつたよ」「すると」「あれだけ嚴重な、締りの家だから、外から押入つたとすれば、何處かに變なところがあるわけだ」「？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鬼女",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでことがはつきりわかつた。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人の部屋の中のいくつもの画や像を見ただけで、現在残つている積極的な信仰は実際上老人きりのもので、身内の連中は、どういうわけか、異教徒になつていることがはつきりわかつた。",
              "citation": {
                "source": "とけない問題",
                "author": "THE INSOLUBLE PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年が実はみじめな気持でいることがふいにブラウン神父にはつきりわかつたのは、その微笑であつた。",
              "citation": {
                "source": "村の吸血鬼",
                "author": "THE VAMPIRE OF THE VILLAGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして資本家連中がみんな、ブラウンは過激主義者だということがはつきりわかつたと、こぞつて報告し、過激主義者連中が、彼はブルジョア・イデオロギーに頑固に執着している反動だと、こぞつて断言したところから推測すると、ブラウンは或る程度分別くさい話ばかりしてだれにも感心してもらえなかつたのであろう。",
              "citation": {
                "source": "ピンの先き",
                "author": "THE POINT OF A PIN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
