[
  {
    "uuid": "c87e5ded-3184-5eff-b000-46c946c1e325",
    "entry": "切り分かつ",
    "reading": {
      "primary": "きりわかつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
