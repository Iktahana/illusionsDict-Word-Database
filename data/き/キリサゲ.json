    "definitions": [
      {
        "index": 1,
        "gloss": "devaluation (e.g. of currency)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
