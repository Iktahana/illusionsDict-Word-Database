[
  {
    "uuid": "04879f06-7856-5ec0-961e-67ddd1c98b4b",
    "entry": "勤苦",
    "reading": {
      "primary": "きんく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
