[
  {
    "uuid": "a0d94d23-5495-5d5f-af2f-a0e942259fa1",
    "entry": "金科玉条",
    "reading": {
      "primary": "きんかぎょくじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
