  {
    "uuid": "8546bee1-09c0-5a3c-8e36-cb35bb2a12a7",
    "entry": "機外",
    "reading": {
      "primary": "きがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "outside a plane",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "はげしい横転の始まった瞬間には、僕の身体は、機外においてけぼりにされたように感じた。",
              "citation": {
                "source": "三重宙返りの記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "機外の助手に手を上げて――白い歯、太い首、われらの英雄よ！",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "独り独仙君に至っては機外の機を弄し過ぎて、少々疲労したと見えて、碁盤の上へのしかかって、いつの間にやら、ぐうぐう寝ている。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボートの艫に小型のモーターをつけた旧式な機外船が、けたたましいエンジンの音をひびかせながらロッジのほうへ走ってくる。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ……」　石倉が林の中の道に姿を消すと、間もなく機外船のモーターがかかり、エンジンの音が岸から遠退いて湖心のほうへ進んで行った。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察から伝達があったのだとみえて、夕方、キャンプ村の管理をしている石倉が機外船で迎いにきた。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ご苦労さま」　久美子が乗りこむと、機外船はガソリンの臭気とエンジンの音をまきちらしながら、対岸の船着場のほうへ走りだした。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
