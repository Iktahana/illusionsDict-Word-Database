        "examples": {
          "standard": [
            {
              "text": "国際空港の喧騒から離れた一角に、多宗教に対応した静寂な祈祷室が用意されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は毎日決まった時間になると、職場のビルの地下にある小さな祈祷室へと向かうのが日課だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "病院の待合室の隣には、家族が心の安寧を保ちながら静かに祈れるよう祈祷室が設置されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「これは祈祷室です。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は祈祷室に於ける第一の感じを裏切られたのである。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はかうした話に聞き入りながら、ふとあの祈祷室の窓際に坐ってゐた異國の修道士の姿を想ひ出した。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
