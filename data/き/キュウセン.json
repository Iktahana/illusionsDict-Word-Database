[
  {
    "uuid": "47e7af5a-b4f4-519d-bc7b-82211eab8bbc",
    "entry": "休戦",
    "reading": {
      "primary": "きゅうせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cease-fire",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして此人々の膝の上にあつたセルヰエツトは、それ／″＼の手に掴まれて、軍使の掲げる旗のやうに、休戦と平和とを表して閃いた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「休戦を申込む方法はないか。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが長追は無用と云うので立花の先鋒小野和泉馬を横えて日本軍を制し、隆景亦休戦を命令した。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "独り悦ばぬのは赤松政則であって、それは休戦になればその拡張した領土を山名氏に還さねばならないからである。",
              "citation": {
                "source": "応仁の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "▼文化的なものの内部に於て抵抗、排除、抗争、建設などの今こそ行はれる実践期ではないか、今に始まらぬが文化的な面に於ては停戦や休戦と呼ばれることなどはもともとなかつたのだ。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はかくばかり迫り合った空気をなごやかにするためにも、しばらくの休戦は都合のいいことだと思ったので、「もうだいぶ晩くなりましたから夕食にしたらどうでしょう」　と言ってみた。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやく「休戦ラッパ」が鳴った。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "跡始末には巨額の費用を要する仕事であるから、去年の休戦以来、半年以上の時間をあだに過して、いたずらに雨や風や日光のもとにその惨状を晒しているのであろう。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "跡始末には巨額の費用を要する仕事であるから、去年の休戦以来半年以上の時間をあだに過して、いたずらに雨や風や日光の下にその惨状を晒しているのであろう。",
              "citation": {
                "source": "ランス紀行",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の休戦当時にも斯うした例があるので、交通機関の乗合自動車は宵から賢くも運転を止めてしまったらしく、そこらに一台もその姿を見せなかった。",
              "citation": {
                "source": "倫敦の一夜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を……」影の大統領「休戦の提議だ。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "五ヶ年間の休戦協定を申入れろ。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚、宇宙戦争の勃発により、第三次世界戦争は休戦となり、急転直下して世界同盟成る。",
              "citation": {
                "source": "予報省告示",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "開戦と同時に、戦争当時国は手の裡にある新兵器をチラリと見せ合っただけで、瞬時に勝負の帰趨が明かとなり即時休戦状態となるのかもしれない。",
              "citation": {
                "source": "『地球盗難』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇　今度の休戦が昨年の十一月十一日の十一時に成立つたといふので、ある御幣担ぎは、この十一といふ数を何か特別のもののやうに縁起を担ぎ出した。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとその日は、独逸から休戦の申出があつたといふので、街は祭のやうに騒々しかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "サルジニアは震駭して屈伏し二十八日午前二時休戦条約が成立した。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "墺国の国力は消耗し、ナポレオンは一七九七年三月前進を起し、四月十八日レオベンの休戦条約が成立した。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月五日には独軍は早くもソンムの強行渡河に成功、仏国の抵抗意志は急速に低下して到るところ敗退、六月十四日独軍パリに入城、六月二十五日休戦成立した。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一八年十一月の休戦の合図をマリアは研究所にいて聞いた。",
              "citation": {
                "source": "キュリー夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし人間に無条件に通じ合う愛というものがあり得るなら、こうやって初冬の晴れた大空を劈いて休戦を告げる数百千の汽笛が鳴り渡るとき、どうして人々は敗けて、而も愛するものを喪った人々の思いを察しようとしないのだろう。",
              "citation": {
                "source": "時代と人々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶然のことから父につれられてアメリカへ行き、丁度欧州大戦休戦の前後、紐育にいた。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "放送の声は明確にはききとれなかったが、休戦という言葉はもう疑えなかった。",
              "citation": {
                "source": "廃墟から",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "放送の声は明確にはききとれなかつたが、休戦といふ言葉はもう疑へなかつた。",
              "citation": {
                "source": "廃墟から",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも上海に百哩半径の円を描いて休戦するか。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、柿の木の下へ顕れた義弟が真っ赤な顔で、「休戦休戦。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月十一日、ニューヨークの小さなホテルの露台に立ってヨーロッパ大戦休戦当日の光景を見下ろした。",
              "citation": {
                "source": "年譜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "満井駅では北二哩の山上に、日露両軍休戦条約地の記念碑のあるのが望まれた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅玉島の無線電信局が、東京に向って、『休戦』を乞うて来た。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
