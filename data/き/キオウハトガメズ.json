        "examples": {
          "standard": [
            {
              "text": "「今回の失敗はもういい、既往は咎めず、次から頑張ろう。」と上司が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女が過去にした過ちについては、既往は咎めず、これからの行動を見てあげてほしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「まあ、既往は咎めずって言うし、過去のことは水に流そうか。」と彼は笑って言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "成事は説かず、遂事は諫めず、既往は咎めずという教もあるから、わしはいずれにしても異存はないと申上げて置いた。",
              "citation": {
                "source": "つゆのあとさき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
