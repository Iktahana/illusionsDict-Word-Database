        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は長年の夢だった、母校の教壇に立つことができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「さあ、今日は君が教壇に立つ番だよ！」先生が笑顔で言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "教育者としての彼の姿勢は、常に教壇に立つことへの責任感から生まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
