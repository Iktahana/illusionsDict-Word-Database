        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "肺病院の如な東京物理学校の淡い青灰色の壁にいつしかあるかなきかの月光がしたるる。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ううむ、帯は京物だな」まじまじ見守ったものである。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "安永から天明の頃、江戸の俳諧師二鐘亭半山なるものの書いた「見た京物語」には、「島原はまはり土塀にて甚だ淋し、中の町と覚しき所、一膳飯の看板あり」とあって、それよりやや降り、「島原の廓、今は衰へて、曲輪の土塀など傾き倒れ、揚屋町の外は、家も巷も甚だ汚なし。",
              "citation": {
                "source": "大菩薩峠",
                "author": "壬生と島原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "『君の名は』や『東京物語』の年だ。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "小津の『東京物語』で、尾道から出て来た老夫婦が、東京から尾道へ帰っていきますよね。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "このカラスたちは、ざんこくで、ひきょうもので、よくばりで、しかも、だいたんふてきな顔つきをしています。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとボクサーのおとうさんをもつ井上一郎君と、すこしおくびょうだけれども、あいきょうものの野呂一平君です。",
              "citation": {
                "source": "魔法博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノロちゃんは団員のうちでいちばん、おくびょうものですが、ちゃめで、あいきょうもので、みんなにすかれています。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいきょうものですから、みんなにもすかれていました。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、ノロちゃんだって、あいきょうものだし……。",
              "citation": {
                "source": "魔法人形",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいきょうもののノロちゃんにちがいありません。",
              "citation": {
                "source": "探偵少年",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "八人の少年のうちには、坂口君はもちろん、力のつよい井上君や、あいきょうもののノロちゃんも、はいっていました。",
              "citation": {
                "source": "探偵少年",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "小林君も、ノロちゃんがすきですし、おくびょうだけれどもすばしっこいのと、だれにもすかれる、あいきょうものなので、団員に入れることにしたのです。",
              "citation": {
                "source": "天空の魔人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
