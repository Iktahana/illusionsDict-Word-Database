        "examples": {
          "standard": [
            {
              "text": "教皇庁は、バチカンの行政機関として、全世界のカトリック教会を統括している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "教皇庁は、最近の教皇の声明について、公式な見解を発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は教皇庁で長年勤務し、教会法に精通している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "＊　輔仁大学はローマ教皇庁に属する大学であるが、ここの女学生は幸福そうである。",
              "citation": {
                "source": "北支点描",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "使者は病気であとに留まったが、ポーロ兄弟は帰国後教皇庁にその旨を伝え、第二回旅行には教皇の書翰の他に二人のドミニコ会士を伴っている。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
