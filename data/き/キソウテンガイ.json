[
  {
    "uuid": "b887246f-292c-54ed-8b4a-16e40fdbc7fa",
    "entry": "奇想天外",
    "reading": {
      "primary": "きそうてんがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
