        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "奇想天外は、ナミビアの砂漠で過酷な環境に適応して生きる珍しい植物だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "植物図鑑で奇想天外のユニークな姿を見て、いつか実物を見たいと思った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの奇妙な葉を持つ奇想天外が、数千年も生きるなんて信じられない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
