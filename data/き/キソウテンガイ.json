    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fantastic",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の描くSF小説のプロットは、いつも奇想天外で読者を飽きさせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「え、それが成功したの？」彼のビジネス戦略は奇想天外すぎて、最初は誰も信じなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "パーティーでの彼女の服装は、奇想天外で皆の注目を集めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この映画のラストシーンは、本当に奇想天外な展開で度肝を抜かれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それを受けて「雲に鳥」は、前のフレーズと聯絡がなく、唐突にして奇想天外の着想であるが、そのため気分が一転して、詩情が実感的｜陰鬱でなく、よく詩美の幽玄なハーモニイを構成している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇想天外じゃないか。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が、やがてパパになるというのも奇想天外、いや、それよりも何よりも、今夜の此の朗読劇こそ圧巻だ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさに奇想天外、暗闇から牛である。",
              "citation": {
                "source": "天狗",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて大崎八段と対局した時、いきなり角頭の歩を突くといふ奇想天外の手を指したことがある。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、ひとつにはそれは、木村・花田を選手とする近代将棋に対して、坂田がいかに奇想天外の将棋を見せるか、見とくなはれといふ意味も含んでゐた。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この坂田がどんな奇手を指すか見てをれ、あつといふやうな奇想天外の手を指してやるんだと、まるで通り魔に憑かれて、坂田はふと眼を窓外にそらした。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "前人未踏の、奇想天外の手であつた。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「マイクロプロセッサーを使って、コンピューターのおもちゃのようなものを作ってみよう」さらに一歩進んで「こいつで高級言語を走らせ、誰でも手のだせる個人用のコンピューターを作ろう」などという奇想天外なアイデアは、少なくともＩＢＭやＤＥＣからは、何年たってもでてこなかっただろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして中村正常が、ずつと前発表した最初の戯曲に就いて、その構想の奇想天外の妙に拍手を覚えた、その他二人のことに就いては種々と好意を持つた話を聞いた。",
              "citation": {
                "source": "新興芸術派に就いての雑談",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルフレッド大王とは奇想天外だ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙然たることその金看板のごとく、行動の疾風迅雷的にして、その出所進退の奇想天外たることまたいつものとおりで、面に自信の色を現わしながら颯爽として足を向けたところは、伝六のいったつじ君の徘徊している柳原の土手ではなくて、つい宵の口に通ったばかりのあの紀国坂だったのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には好んで奇想天外の手段を執る者も殖えて来たらしいが、大方矢張り探偵小説や活動写真の影響であろう。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、これは全く奇想天外の名案だと思うが、この一切の装置を、お葬式に使う花筒のなかに仕掛けるのだ。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだ、わかるかな」　轟博士は、奇想天外なことをいう。",
              "citation": {
                "source": "地球を狙う者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも想像してなるべく奇想天外な場所を選んで書きいれるのです。",
              "citation": {
                "source": "誰が・何時・何処で・何をした",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二人の犯人」「通夜の人々」これらの作を読んでみても、先ず感じられる欠点は、先を急いで余悠がなく、描写から来る詩味に乏しく、謎を解く鍵には間違いはなくとも、その解き方に奇想天外がなく、矢張り学者の余技たることをともすれば思わせることである。",
              "citation": {
                "source": "日本探偵小説界寸評",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "變るにしても奇想天外な變りやうであつてはならないんだ。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる奇想天外からきたものほど、素朴なわれわれの祖先が印象をふかくし、かつ正直に請け入れ、むしろ喜び迎えたかに思われますのがふしぎはないことと思われます。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて口論の場面が来、最後には奇想天外的に一匹の猿が登場する。",
              "citation": {
                "source": "高台寺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこにもない様に顔の小さい、足の長い美人たちが、それが商売である図案家によって、奇想天外に考え出されたモードのおしゃれをして、たったり坐ったり寝そべったりしています。",
              "citation": {
                "source": "若人の要求",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "といへる、奇想天外なり。",
              "citation": {
                "source": "萬葉集卷十六",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "でこんでこんに塗りたくって、美しい絵を入れて、もう一つおまけに、詩集用のオルゴオルもつけてね、まず、きれいな音の中から、詩が飛び出して来るやつ……奇想天外詩集と云うものを出したい。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大脳、小脳、延髄、松果腺なんどと、無量無辺に重なり合っている、奇妙キテレツな恰好をした細胞が、やはり、奇想天外式に変形した神経細胞の突起によって、全身三十兆の細胞の隅から隅までつながり合っている。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……私と瓜二つの青年がいて、二人共奇想天外式の精神病に罹っている。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏人は、奇想天外な金儲の話には、理屈を超越するものだ。",
              "citation": {
                "source": "愉快な話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
