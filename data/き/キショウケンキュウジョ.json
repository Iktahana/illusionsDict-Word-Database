        "examples": {
          "standard": [
            {
              "text": "気象研究所の研究員が、スーパーコンピュータを使った気候変動予測について発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は将来、気象研究所で最先端の天気予報技術を研究したいと夢見ている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "気象研究所のサイトで、過去の台風のデータが公開されているのを見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "申し遅れましたが、私が高層気象研究所の北鳴です。",
              "citation": {
                "source": "雷",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソ連については、イリーンの通俗科学書による知識しか得られないのであるが、それによると、レニングラードの実験気象研究所では、人工降雨の科学的研究が、組織的に進められているらしい。",
              "citation": {
                "source": "雨を降らす話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "パサデナのアメリカ気象研究所を訪ねた時、所長クリック博士は、肯定的な実験結果を知らせてくれた。",
              "citation": {
                "source": "雨を降らす話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
