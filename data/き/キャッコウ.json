[
  {
    "uuid": "61528c6d-9d8d-58d3-902c-51667ccbc74f",
    "entry": "脚光",
    "reading": {
      "primary": "きゃっこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
