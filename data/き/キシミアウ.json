        "examples": {
          "standard": [
            {
              "text": "市場のシェアを奪い合って、大手二社が激しく軋み合っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「お互いに譲らないわね」「まあ、プライドの高い職人同士が軋み合うのはいつものことさ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "プレート同士が軋み合う境界線付近では、巨大なエネルギーが蓄積され続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "限られた予算の奪い合いで、学内の各研究室が醜く軋み合う様子を見て失望した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "身体と身体とが、打ち合う音、筋肉と筋肉とが、軋み合う音、それは風雨の争いにも、負けないほどに恐ろしかった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階の博刃は今し高潮に達したとみえ、ふみきる跫音、鉄とあらがねの相撃ちきしみあうひびき、人の心胆を寒からしめる殺気、刀気……ののしるこえ、物を投げる音！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
