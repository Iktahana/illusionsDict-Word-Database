        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祖母が作った菊芋のきんぴらは、素朴だけど忘れられない味だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "道の駅で新鮮な菊芋を見つけたので、早速購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "菊芋は、独特のシャキシャキとした食感が魅力だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そこには菊芋の丈け高い麻のような茎も見えていた。",
              "citation": {
                "source": "草藪の中",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは村でほとんど知っている者のない『きくいも』というものであった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの『きくいも』をだれが食べるだろう。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "きくいもが金の花びらを開いていた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いつかおまえがまた帰って来るだろうと思ったからねえ」「ぼくのきくいもを食べましたか」「ああ、おまえはわたしに不意討ちを食わせるつもりで、あれを植えたんだね。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でもきくいもよりかずっといいでしょう」　かの女はぽかんとした顔をして、わたしをながめた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
