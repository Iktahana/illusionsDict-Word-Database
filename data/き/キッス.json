        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "カチカチ山　カチカチ山の物語に於ける兎は少女、さうしてあの慘めな敗北を喫する狸は、その兎の少女を戀してゐる醜男。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "理窟は別として、人間の生活慾は、牛肉を快喫する動物性はあツても、人間の感情は、ただ一片の同胞の筋肉を見ても悚然とする。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "カチカチ山　カチカチ山の物語に於ける兎は少女、さうしてあの惨めな敗北を喫する狸は、その兎の少女を恋してゐる醜男。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬまで僕一人で満喫する積りだ」　夕陽が隣の瓦屋根の角と後塀の上を掠つて庭に落ちる。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "久助君はその爽快味を満喫するため、大きく口をあけて、ハアーッハアーッと呼吸しながら、家まできてしまったのである。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "葷を喫すれば惡魔其の脣を舐むるとまで説いてゐる。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊池寛は、午前三時でも、四時でも、やはり、はね起き、而して必ず早すぎる朝食を喫するという。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不自由なる牢獄にて大患に罹りし事とて、一時全快はなしたるものから、衰弱の度甚だしく、病気よりは疲労にて斃るることもやと心配せしに、これすら漸く回復して、遂には病前よりも一層の肥満を来し、その当時の写真を見ては、一驚を喫するほどなり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五分刈頭のわたしは、夜になると、街の被服商で購つて来た海兵用の白の作業服を着て、一服喫すといふ場合には、徐ろに胸のポケツトから、先頃「しぐれ」進水式の折に拝領した銀製のシガレツト・ケースを取り出し、高射砲型のライターからパチンと火をつけた。",
              "citation": {
                "source": "緑の軍港",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この道は東京からの、日帰り乃至は一泊の旅には最も平易であり新緑と海の香りを満喫するに充分であらう。",
              "citation": {
                "source": "或るハイカーの記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「生臭を喫すれば悪魔その脣を舐める」とまで説いている。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "後日斎を解くに至り、粥を与えて始めて喫す。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、恋愛の代りに、義務や服従を喫するのに、飽き果ててしまっていた。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日もむろん前日にまさる炎暑でしたが、勤番は半日交替で午前中にひけるはずでしたから、伝六の怪しげなる腕まえによって調理された朝食を喫すると、あまりぞっとしない顔つきで、むっつりとしながら出仕いたしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "眞晝がた人人、一戰友を葬り、歩哨は時の食を喫す。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "新婚旅行も唐崎さん――ではない新妻みどりの稼ぎ貯めた財布のお陰で南伊豆まで遠出をし、温泉気分と夫婦生活とを満喫することができた。",
              "citation": {
                "source": "幸運の黒子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "五分刈頭のわたしは、夜になると、街の被服商で購つて來た海兵用の白の作業服を着て、一服喫すといふ場合には、徐ろに胸のポケツトから、先頃「しぐれ」進水式の折に拜領した銀製のシガレツト・ケースを取り出し、高射砲型のライターからパチンと火をつけた。",
              "citation": {
                "source": "緑の軍港",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、単に煙草を喫すばかりの人形になつてゐた。",
              "citation": {
                "source": "鱗雲",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "莟の多くは刻々にそのふくらみをゆるませ、窄んだ唇を半ば綻ばせて、春を満喫すべく、われがちに花弁を開かうとしてゐる。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、そんな他愛もない文句を、とりとめもなく思ひ浮べたが、それはたゞ徒らに喫す煙草のやうに何の心に懸はりなく、心は白く漠然と明るく澄んでゐるばかりだつた。",
              "citation": {
                "source": "父の百ヶ日前後",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏藪の筍がによき／＼のぞきはじめた、当分、筍のうまさを満喫することだらう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "澄太居のよさを満喫する、澄太君には大人の風格がある、私は友人として澄太君をめぐまれてゐることを感謝する、考へて見ると、私のやうなぐうたらに澄太君のやうな人物が配せられたといふ事実はまことに意義深遠なものがあると思ふ。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてフカフカと莨を喫す。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "真実に惘れたもんだね」「どうしてまたそう作太郎を嫌ったものだろうねえ」おとらは前屈みになって、華車な銀煙管に煙草をつめながら一服｜喫すと、「だからね、それはそれとして、左に右私と一緒に一度還っておくれ。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "真実に惘れたもんだね」「どうしてまたそう作太郎を嫌ったものだろうねえ」おとらは前屈みになって、華車な銀煙管に煙草をつめながら一服喫すと、「だからね、それはそれとして、左に右私と一緒に一度還っておくれ。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "平原のハイキングならまだしもだが、少くとも山岳の多い日本でのハイキングに或る程度山へ入らなければ意味を成さないのに、今年のやうにかうじめ／＼した秋霖が打続いたのでは、よほど運が好くなければハイキングの快味を満喫するといふ訳には行かない。",
              "citation": {
                "source": "霧ヶ峰から鷲ヶ峰へ",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、明け方の五時から正午まで――十二時になるとお婆さんが二階の戸を叩打して男を追い出す――こうして、この空博奕に勝ったやつが、白熊テレサと彼女の over voluptuousness を専有し満喫するのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の女性が、結婚の科学をも十分わきまえて、ますます強く美しい肉体の歓びをも満喫する生活を持ってゆくとすれば、それは本当にうれしいと思う。",
              "citation": {
                "source": "結婚論の性格",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手数をかけりゃ、啖呵にもきっすいの江戸油をかけなきゃならねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "外遊時代に書いた「支那街の記」「西遊日誌抄」などをみると、荷風はしきりにボードレェルなどをひいて自傷の状をかなでているのであるが、荷風の本質は決して徹底したデカダンでないし、きっすいの意味でのロマンティストでもないことが感じられる。",
              "citation": {
                "source": "歴史の落穂",
                "author": "――鴎外・漱石・荷風の婦人観にふれて――",
                "note": "青空文庫"
              }
            }
          ]
        }
