    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the way (to somewhere)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼女のこの頃の来方は気紛れでなく、一日か二日置き位な定期的なものになった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年九月二十六日『東京朝日新聞』）　　　　　　　　　六　　　　　　霧　霧の出来方には色々ある。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドクトル、ベエアマンはここで花崗岩の破れ目の出来方について講釈をして聞かせた。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　来方は我にもあり、ただ御身は髪黒く、顔白きに、我は頭蒼く、面の黄なるのみ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしんば、自首を計算に入れていたとしても、その来方があまりに早すぎる。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "老父のそこまでの話の持って来方には、衰えてはいるようでも、下町の旧舗の商人の駆け引きに慣れた婉曲な粘りと、相手の気の弱い部分につけ込む機敏さがしたたかに感じられた。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、まさかおれと別れて五年目の今日、お前が二円の無心にやって来ようとは、――むろん、予想していた、見抜いていた――しかし、その来方が余り早すぎた。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九〇〇年版、スキートの『巫来方術篇』一五七および一五九頁。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ、マキノ君か――どうも連中の来方が遅くつて心外だぞ。",
              "citation": {
                "source": "馬上の春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "裁判好きの輩判官に賄賂を重ねて両造ともにからけつとなるを「猴に裁判を乞うた」というのだそうな（スキート著『巫来方術篇』一八七頁）。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それや百合さんかローラが、いざ無頼漢に奪はれるとなれば、大活劇になつて――俺の誉れをお前に見物させてやることも出来たんだが、救助隊の来方が早過ぎたわけさ。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで大辻はその由を帆村に伝えたが、まあこんな風な電話のかかって来方は事件依頼主が身柄を秘したいときによくやる手で、それほど大したことではなかった。",
              "citation": {
                "source": "暗号数字",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "就中破天荒な変化と云ふべきは、電燈会社の建つた事、女学生の靴を穿く様になつた事、中津川に臨んで洋食店の出来た事、荒れ果てた不来方城が、幾百年来の蔦衣を脱ぎ捨てて、岩手公園とハイカラ化した事である。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "禿頭に産毛が生えた様な此旧城の変方などは、自分がモ少し文学的な男であると、『噫、汝｜不来方の城よ※　汝は今これ、漸くに覚醒し来れる盛岡三万の市民を下瞰しつつ、……文明の儀表なり。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処の村校の尋常科を最優等で卒業した十歳の春、感心にも唯一人｜笈をこの不来方城下に負ひ来つて、爾後八星霜といふもの、夏休暇毎の帰省を除いては、全く此土地で育つた。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは不来方城｜畔の鐘楼から、幾百年来同じ鯨音を陸奥の天に響かせて居る巨鐘の声である。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり僕らの来方が間に合つてよかつたのです。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "元々地勢上そういう運命にあり、矢来方面早稲田方面から神楽坂へ出る幹線道路として年々繁華を増しつつあったわけであるが、震災以後｜殊に目立ってよくなった。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして夜も昼も、坂下からずっとこの寺町の通り全体に大道露店が一ぱいになったものだったが、それから以後次第にそれなりに、私のいわゆる神楽坂プロパーと等しなみの殷賑を見るに至り、なお次第に矢来方面に向って急激な発展をなしつつある有様である。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "タイピストを辞めさせてまで世話する筋合いがドコに在るか存じませんが……ホホ……それで、わたくしは決心を致しまして、あの宿の主人と相談を致しまして、ヨリ子を今朝から当宅へ引取って、わたくしの側で召使う事に致しましたが、あまり来方が遅う御座いましたので、当宅の自用車を迎えに出したので御座います。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "家来方は云う迄もねえ、可愛いお神さんもお坊ちゃんも、無惨や無惨や白骨だ！",
              "citation": {
                "source": "天主閣の音",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「余り出来方が早いので御驚ろきなさりやしなくつて」「えゝ」と云つたが、実は始めて気が付いた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一夜酒の出来方を、「ほ」と見て人の健康を祝福したのである。",
              "citation": {
                "source": "「ほ」・「うら」から「ほがひ」へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は流行を呪ふ立場にあるけれども、言語の流行は、我々が長くかゝつてやる仕事を、短い間にやつてのけて生活に取込むといふのだから、普通の文化生活とは這入つて来方が違ふ。",
              "citation": {
                "source": "古代中世言語論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "警部はその第一着として、笹木光吉の残して行ってくれた弾丸の飛来方向の計算にとりかかった。",
              "citation": {
                "source": "省線電車の射撃手",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、弾丸の飛来方向がちゃんと出て来たので現場を中心として、鉛筆でその方向に長々と直線をひっぱった。",
              "citation": {
                "source": "省線電車の射撃手",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……ふうむ、これは疑問線の力が弱いのか、それとも疑問線の到来方向が変ったかナ。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれを地面、家屋敷ぐるみ、そっくり居抜きでお引取りになって、御家来方と一緒にお住いでございます、と明瞭に答えてくれる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たち、さびしく無力なのだから、他になんにもできないのだから、せめて言葉だけでも、誠実こめてお贈りするのが、まことの、謙譲の美しい生きかたである、と僕はいまでは信じています。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "疑って失敗する事ほど醜い生きかたは、ありません。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
