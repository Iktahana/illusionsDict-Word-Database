[
  {
    "uuid": "4bbdbb0c-fcf0-5c82-a8bd-62d6d43fb5c1",
    "entry": "来方",
    "reading": {
      "primary": "きかた",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
