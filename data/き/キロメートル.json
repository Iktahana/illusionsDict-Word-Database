        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "自宅から駅まで、だいたい2キロメートルくらいかな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "フルマラソンは、42.195キロメートルもあるんだって！走れる気がしないよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この国道は、直線距離で100キロメートル以上続いているらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "目的地までの距離が、あと3キロメートル！もう少し頑張ろう！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それから二時間たって、現場から四十八｜粁距ったここで守備隊の出発防備隊の召集ときているんだ。",
              "citation": {
                "source": "防備隊",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "深谷というのは僕たちの村から、三｜粁ほど南の山の中にある小さな谷で、僕たちは秋きのこをとりに行って、のどがかわくと、水を貰いに立ち寄るから、よく知っているが、家が四｜軒あるきりだ。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "大沼というまわり四｜粁ほどの湖水がこの氷の下に隠れているのだそうです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやらこの重味には星に準ずる運行も見出せぬではないか、この身が十五億粁の彼方にあいつを追ひかけて煙りとならぬ限りは――。",
              "citation": {
                "source": "凩日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一｜粁も車が走ったかとおもうころ、車のうえがさわがしくなりました。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日私たちの住む地球の上は毎秒三〇万粁の速度で、昼夜を分たず世界各国語による交通が電波によって飛び交っているのであるが、最も興味あるべきこの世界ニュースの聴取が日本では極めて狭い範囲に止められているのはどういう理由からであろう。",
              "citation": {
                "source": "「ラジオ黄金時代」の底潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "幟町も中心地から二粁以内にあり危険区域ですから安心はできません。",
              "citation": {
                "source": "書簡",
                "author": "家族・親族宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "屈斜路湖は周圍四十七粁で、まるで海のやうにも見える。",
              "citation": {
                "source": "摩周湖紀行",
                "author": "――北海道の旅より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "フウトウは、河内の西北にあたり、河内から離れる事一三〇｜粁の地で、こゝは世界にほこる漆樹園といつてもいゝところである。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "種子島の西南三二｜海里、面積は五○○平方｜粁、島形は、円く殆ど出入なき水平的肢節。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊や鹿が棲むという、幽邃な金門公園を抜けて、乗っていたロオルスロオイスが、時速九十｜粁で一時間とばしても変化のないような、青草と、羊群のつづく、幾つもの大牧場を通って――途中でだいぶ自動車を停めた露骨なランデェブウにもお目にかかりました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう、二｜粁もあるゴルフ場まで、ついて来て、朝露に濡れた芝生の上を、口笛吹き吹き、探してくれました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊や鹿が棲むという、幽邃な金門公園を抜けて、乗っていたロオルスロオイスが、時速九十粁で一時間とばしても変化のないような、青草と、羊群のつづく、幾つもの大牧場を通って――途中でだいぶ自動車を停めた露骨なランデェブウにもお目にかかりました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう、二粁もあるゴルフ場まで、ついて来て、朝露に濡れた芝生の上を、口笛吹き吹き、探してくれました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "今更かえっている暇はない」「一千粁――？",
              "citation": {
                "source": "地図にない島",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体月までの平均距離は三十八万｜粁ばかりある。",
              "citation": {
                "source": "地図にない島",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最大速力一時間四百五十｜粁で、一万八千粁も飛ぶことが出来るのだ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒々と湾をかこんで、数十｜粁の円陣をつくる大絶壁！",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "本館というのは二十五｜粁ばかり西北方へ行った地点にあり、コロラド大峡谷を目の前に眺める眺望絶佳な丘陵の上にあった。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は可なり交通の頻繁な渡舟場でしたが、一粁あまりの川下に、電車が通じ橋が掛ってから、すっかり寂びれてしまいました。",
              "citation": {
                "source": "渡舟場",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "河向う三粁ほどのところに小さな町がありまして、そこへ地元の物資をひそかに売り出すことを、中村の息子の佳吉は仕事としていました。",
              "citation": {
                "source": "渡舟場",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二日の夜明けには、火先は一粁ほどのところへまで寄せてきました。",
              "citation": {
                "source": "古木",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのどよめきが、次第に盛り上ってきて、火災は一粁ほど先まで迫り、昼間のように明るくなりました。",
              "citation": {
                "source": "古木",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十年も前へ物を移すということは、二十｜粁後へ物をはこぶこととは違って、甚だ困難なことだ。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "地球から四千六百八十｜粁距ったところに、地球と月との重心があるが、この重心を稍通りすぎるに足るくらいのエネルギーを人工竜巻に与えることにより、あとは自然にアルプス崩れの岩石が月世界に到達する。",
              "citation": {
                "source": "地軸作戦",
                "author": "――金博士シリーズ・９――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは約十｜粁ばかり東へいった、山麓附近を目がけて下りてくるようだ。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あと一粁ばかりのところで、車はとめられた。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで約一キロメートル前方の山腹で一斉射撃の煙が見えたら、それから一秒余おくれて弾が来て、それからまた二秒近くおくれて、はじめて音が聞こえるわけである。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この競走に加わった気球は三十四あったが、最長の距離に達して月桂冠を得たのはドイツの気球で丁度千キロメートルを航した。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし実際は二億二千八百万キロメートルの距離にある直径百四十万キロメートルの火の玉である。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
