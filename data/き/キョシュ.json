  {
    "uuid": "95c6f67c-ce87-57ff-bbf6-79047ca16e60",
    "entry": "拠守",
    "reading": {
      "primary": "きょしゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "defense",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "若し夫れ尚依然として自ら韜晦し漫に無責任の呼号を事とするの陋に出でんか、足下平生の主張は矯飾自ら衒ふものにして従来記する所は悉く確信拠守する所なき妄誣に過ぎざるを表白するものなるべし。",
              "citation": {
                "source": "自由の使徒・島田三郎",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "後三年の役に清原武衡、家衡らがこの柵に籠城して、頑強にそれを拠守したのには、さすがの八幡太郎も閉口して手のつけようがなかったのであった。",
              "citation": {
                "source": "春雪の出羽路の三日",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはこの城が後に再び他の豪族の拠守するところとなっていたためかも知れぬ。",
              "citation": {
                "source": "春雪の出羽路の三日",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "金沢氏拠守のことはその伝えがあるが、その他にもなかったとは保し難い。",
              "citation": {
                "source": "春雪の出羽路の三日",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
