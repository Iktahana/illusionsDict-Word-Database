[
  {
    "uuid": "b7094f71-afd4-571f-8bc2-4262f7f1807b",
    "entry": "清い",
    "reading": {
      "primary": "きよい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
