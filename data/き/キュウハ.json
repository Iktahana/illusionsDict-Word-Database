[
  {
    "uuid": "5bd18881-e299-5f6d-9abf-a61f83bce1a6",
    "entry": "急派",
    "reading": {
      "primary": "きゅうは",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
