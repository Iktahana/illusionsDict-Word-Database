    "definitions": [
      {
        "index": 1,
        "gloss": "localized (pain, rainfall, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
