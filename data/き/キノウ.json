      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "function",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「この新型オーブン、スマホと連携して予熱を完了させる機能まで付いてるの？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長引く風邪の影響で、胃腸の機能が著しく低下し、食欲がまったく湧かない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大規模なシステム障害が発生し、銀行のオンライン窓口が本来の機能を失っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それにしても私は今自分の身体に起りつつある些細な変態の兆候を見て、内部の生理的機能についてもある著しい変化を聯想しないではいられない。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして自分の内部の機能にどのような変化が起るかを試験してみようと思っている。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この薬剤を飲ませまた皮下に注射すると肝臓の機能を害して中毒の症状を起すが、その蒸気を呼吸させると体内の蛋白質の分解を促し却って肝臓の機能を興奮させる。",
              "citation": {
                "source": "「万年筆」欄より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ消化され吸収されるものばかりでなく、折々は不消化物も与えないと胃の機能が衰えるようなもので、実験中に起るべき種々の困難に出来るだけ遭遇させ、漸次これを除いて最後の結果に到着すると同時に、目的以外の現象にも注意してそれを等閑に附せないような習慣をつけたいものである。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来私は、磁石の方角を直覚する感官機能に、何かの著るしい欠陥をもった人間である。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら学者の説によれば、方角を知覚する特殊の機能は、耳の中にある三半規管の作用だと言うことだから。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとマダム・レムブルグは素早く太い胴体を飜えして、この近代の機能の発明家は青い化粧的で、牛の舌みたいな腕で扉を閉めると、再び細目に開けて、　――それどころですか。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　夜の女の衣裳の背後が社交的に展いて、生姜色の皮膚の断面に機能の失せた女の蠱惑が感じられた。",
              "citation": {
                "source": "戦争のファンタジイ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "音律といふ事は、文章の一機能である。",
              "citation": {
                "source": "文章の音律",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはたしかにひなと親鳥とではその生理的機能にそれだけの差があることを意味するのではないかと思われる。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "花の植物生理的機能を学んで後に始めて充分に咲く花の喜びと散る花の哀れを感ずることもできるであろう。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし中毒であれば、飲まない時の精神機能が著しく減退して、飲んだ時だけようやく正常に復するのであろうが、現在の場合はそれほどのことでないらしい。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけのきわめて卑近な簡単な一例から考えても、人間の脳の機能に関係する原子分子の一つ一つの役目が、それほど閑散な、あってもなくても済むようなものではないであろうということが想像される。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、自分の場合にはそれらの詩がみんな自分の肉体の生理的機能となんらかの密接な関係をもっていたような気がする。",
              "citation": {
                "source": "詩と官能",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　どうも自分の詩の世界は自分のからだの生理的機能と密接にからみ合っていて直接な感官の刺激によってのみ活動しているのではないかという気がするのである。",
              "citation": {
                "source": "詩と官能",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことを長年考えていたのであるが、近ごろ大阪医科大学病理学教室の淡河博士が「黒焼き」の効能に関する本格的な研究に着手し、ある黒焼きを家兎に与えると血液の塩基度が増し諸機能が活発になるが、西洋流のいわゆる薬用炭にはそうした効果がないという結果を得たということが新聞で報ぜられた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば安政元年の大震のような大規模のものが襲来すれば、東京から福岡に至るまでのあらゆる大小都市の重要な文化設備が一時に脅かされ、西半日本の神経系統と循環系統に相当ひどい故障が起こって有機体としての一国の生活機能に著しい麻痺症状を惹起する恐れがある。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらはむしろ狂に近い例かもしれないがしかしともかくもこんないろいろの事実を総合して考えると、一般に「笑い」という現象の機能や本質について何かしらあるヒントを得るように思う。",
              "citation": {
                "source": "笑い",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者は与えられた一つのものに内在する有機的構造を分析展開して見せるに対して、後者は与えられた離れ離れの材料からそれによって合成されうべき可能の圏内に独創機能を働かせて建築を構成し綾錦を織り成すものだとも言われないことはないのである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "短歌でもそうであるが、俳句においてこの利器はいっそうその巧妙な機能を発揮する。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう意味で終わりの五字と最初の五または五七とを対立させる機能をもっており、従って「や」と同等である。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄であれ誰であれ、男から来る力を嗅ぎわける機能の段々と熟して来るのをお末はどうする事も出来なかつた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちの唯一の財産、最初にして最後の財産＝身体には、これだけの機能が備わっています。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ世の中に、これだけの機能の備わっている道具は、又とあるでしょうか。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけの機能を使って出来ないことがあるでしょうか。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうやって患者の身体に助太刀しているうち患者の身体自身に備わっている体温調節の機能が盛り返して来て、病気を弾ね除けてしまいます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのため私たちの筋肉はだんだん元来の機能を失って行きつつあると言われました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、人間は昔の完全な身体の機能を取り戻すために、時々獣類のように動くことを稽古しなさい。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たびよりかへれる巡禮のうた萩原朔太郎いすらへるよりかへり　われはゆきのうへにたちぬ",
              "citation": {
                "source": "たびよりかへれる巡禮のうた",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのう読んだ辰野氏のセナンクウルの紹介文の中に、次のようなセナンクウルの言葉が録されてあった。",
              "citation": {
                "source": "織田君の死",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
