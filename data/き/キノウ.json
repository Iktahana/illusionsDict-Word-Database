[
  {
    "uuid": "fbd27421-f720-56fc-abfb-64df8cccd279",
    "entry": "機能",
    "reading": {
      "primary": "きのう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
