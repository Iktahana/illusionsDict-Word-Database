        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "うどんやへはいり、狐うどんとあんかけうどんをとった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一人立ちしていても貧乏だし、お夏さんは親のすねかじりで勿論お小遺いもそんなにないので、二人は財布を見せあいながら、狐うどんを食べた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一人立ちしていても貧乏、お夏さんは親のすねかじりで勿論お小遣もそんなにないので、二人は財布を見せあいながら、狐うどんを食べた。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「「当り矢」さん、狐うどん、二杯、下さいな」　うどん屋も、顔見知りだった。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本をさらわれてしもうたけ、こっちも、泥棒でもしようごとある」　二杯の狐うどんを、マンと、もう一人の男にわたして、夜泣きうどん屋は、しきりに、愚痴をこぼした。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、同じやるなら、今まで東京になかった目新しい商売をやって儲けようと、きつねうどん専門のうどん屋を始めることになった。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の町をうろうろ歩きまわり、戎橋の梅ヶ枝できつねうどんをたべ、バットを買うと、一銭余った。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の町をうろ／＼歩きまわり、戎橋の梅ヶ枝できつねうどんをたべ、バットを買うと、一銭余った。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日いつぺん、きつねうどんを食べたがね。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかめ、卵とじ、鴨南蛮、鍋焼――と、昔風なのからカレーうどん、きつねうどん（油揚げの入った奴。",
              "citation": {
                "source": "うどんのお化け",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "きつねうどん一つ食ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "煉炭の七厘をかこんで、きつねうどんを三杯註文する。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
