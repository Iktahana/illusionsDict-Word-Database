        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "故に支那訳経の飛狸、著翅狸はコルゴの英名フライイング・キャット、飛猫に合う。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "バーババーバというスキャットが、慶一を馬鹿にしてるかのように襲いかかった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "君チャンハ急ニ、キャットサケンデ、ハネオキルト、ソトヘトビ出シタ。",
              "citation": {
                "source": "テガミ",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたらば、一日おいて全逓のワイルド・キャットが始った。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アップルを退社した後、キヤノンに協力してラスキンが開発したキャットというマシンは、オリジナルのマッキントッシュのプランに沿ったものである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "トムキャット社は互換ＢＩＯＳの開発を進め、一時さまざまな角度から販売の可能性を探ろうと試みたが、日本電気の強い反発が予想されたために、商品化には弾みがつかなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生はキャット（ねこ）をカットと発音する、カツレツをカトレットと発音する。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダアク・キャットのピッチャーの二股長半ねーエ。",
              "citation": {
                "source": "お魚女史",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてもそれは「キャット撫で声」と言わねば人を驚かさない。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポール・キャット　先日、航空に関する或る集まりで、日本の航空輸送の将来についての話が出たことがある。",
              "citation": {
                "source": "エスキモーの国から",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貨物はやはり橇列車で輸送しているが、人間の方は、ポール・キャットと呼ばれる新しい雪上車で運ぶことになっていた。",
              "citation": {
                "source": "エスキモーの国から",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポール・キャットは、カタピラ式の軽トラクターが、やはりカタピラ式の客車を一輛ひっぱって走る型のもので、雪のよいところは時速十二マイル、平均して十マイルの時速で走るようになっている。",
              "citation": {
                "source": "エスキモーの国から",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに　――　わ・た・し、　キャット・ベルという　おかの　うらに　ドアを　みたこと　あるんですよ　――　しかも　わ・た・し、　チギウィンクルおばさんとは　だいの　なかよしなんですよ！",
              "citation": {
                "source": "チギウィンクルおばさんのはなし",
                "author": "THE TALE OF MRS. TIGGY-WINKLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝生の上へ広く四隅に人を配置して、一人が球を投げると、それを一人が棒で受け飛ばしたり、手で受けとめたりして、その度毎に一種異様な声を張り上げて、「フラフラホウ、フラアラアキャット」というようなことを叫ぶ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "球を受け留めると、「フラフラフラホウ、フラアラアラキャット」なんぞと口走る。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人が「ベビさん」「キャットさん」といっているのを聞くこともある。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "青空文庫版を作成するにあたり無い知恵を絞った結果、この「四風」の読み方について「よもかぜ」というのを思いつきました（「スーフー」だと別世界に……）　シモーヌ・シモンの「キャット・ピープル」シリーズといい岸久美子さんが魅力的な「怪奇十三夜」といい、怪談話には猫が合います。",
              "citation": {
                "source": "四風の街",
                "author": "The Street of Four Winds",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャット・フードの袋にはさまれて、米とスライスしたアーモンドとをいっしょに詰めあわせたものの箱が、上下さかさまとなっていた。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈ザ・ヒルビリー・キャット〉と愛称をつけられたエルヴィス・プレスリーは、ボブ・ニールのマネジメントのもとに、カントリー・アンド・ウエスタンのショウに加わり、巡業公演に出た。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ザ・コーズというこの五人がつくった『シュ・ブーン』は、アトランティックのレイベルからは発売されず、キャットのレイベルで出された。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
