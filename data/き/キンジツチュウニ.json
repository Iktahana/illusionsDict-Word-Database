        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それで、近日中にお目にかかりたいのですが、ご都合おしらせ下さいませ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "近日中にエンヂンを取り付けて競技会へ出場させて見ようと考へてゐる。",
              "citation": {
                "source": "緑の軍港",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "近日中にエンヂンを取り付けて競技會へ出場させて見ようと考へてゐる。",
              "citation": {
                "source": "緑の軍港",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "歸路には、馬町の先生を訪ねて、近日中に厨川柵へ一緒に行つて貰ふ約束をした。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰路には、馬町の先生を訪ねて、近日中に厨川柵へ一緒に行つて貰ふ約束をした。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "白木屋の玄関に立っている案内がきをよむと、展覧会の会場はいくつもあり、近日中にえらい陸軍の軍人が来て景物に講演をやったり、軍用犬の実演をやって見せたりする日どりまで知らしてある。",
              "citation": {
                "source": "「モダン猿蟹合戦」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い本を宅下げするようにして置くから、近日中にとりに来てくれ。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨があがれば、近日中に、町から一、二里ばかり隔った、牧場に行く気でいます。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "『よろしい、では近日中に改めて出頭なさい』という答えです。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "――既に病気が本復した以上、修理は近日中に病緩の御礼として、登城しなければならない筈である。",
              "citation": {
                "source": "忠義",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀は意味ありげに云った、「拙者は近日中にカラフトに赴任しにゃなりません」「しかし、もう、船がありますまい」「出せば、あります」　阿賀妻は顔をあげた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて旧臘中一寸申上候東京表へ転住の義、其後色々の事情にて捗どりかね候所、此程に至り諸事好都合に埓あき、いよいよ近日中に断行の運びに至り候はずにつき左様御承知｜被下度候。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "近日中に茂樹に逢えるように取計ってやろうと約束した。",
              "citation": {
                "source": "椎の木",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "近日中に逢わしてやろう。",
              "citation": {
                "source": "椎の木",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し書き疲れましたし、それに、近日中にお目にかかってお話しすることばかりですもの。",
              "citation": {
                "source": "女心の強ければ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「近日中にお伺いしましょう。",
              "citation": {
                "source": "旅だち",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしますと、仲人のかたは、それはよいことで賛成だと申されて、近日中に、章吾さんの健康診断書と、千重子さんの健康診断書とを、交換することにしたいと、そう言い出されました。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなかいやな思い也、近日中につれてゆくことにする。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩魚の腹を割いて、胃袋から小石が出たならば、近日中に台風がくるものと考えてよいと、まことしやかな顔をするのである。",
              "citation": {
                "source": "石を食う",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は明暗荘へ戻って正宗の出るのを待っとれ、近日中に出るように、はからってやる」「アレッ。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事件の担当になったカニンガム警視は近日中に何らかの有力な手がかりを得たいとしている。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂人として監禁されたくはないので、近日中に公開する予定のこれらの写真がなかったら自分が発見し推論したものを語ろうとは思わなかっただろう。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なるたけもって行くまいよ、ね、きりがありゃしないもの」　つや子の学校も夏休みになり、近日中に、東北の田舎の家へ出かける、その仕度であった。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「近日中に母はまた前沢へ参る予定」――。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポツダム宣言によって、日本の治安維持法は近日中に撤廃され、治安維持法によって処罰されていた思想犯人はすべて釈放される、という報道なのであった。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "近日中に又面会に参ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょう小泉信三の正統派三人の研究を先に入れ、近日中に『リカアド』が見つかるでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "近日中に行ってもう一度しらべます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私に下すった宿題は、力こぶを入れた答えをさし上げますよ、近日中に。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お正月並に外出用の冬着を一組近日中にお送りいたします。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
