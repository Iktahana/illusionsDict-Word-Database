        "examples": {
          "standard": [
            {
              "text": "「初めて来たレストランなのに、メニューの配置から店員の動きまで、妙な既視感がある。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「『あれ、この光景、夢で見た気がする……』と、彼は強烈な既視感に襲われて立ち止まった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「最近のヒット曲はどれも似たようなコード進行で、どうにも既視感が拭えない。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「うん、既視感の海を泳いでいるみたいだ」「まったくだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう錯覚を心理学では既視感と呼んでいるらしい。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "またしてもテンプルは妙な感覚になり、既視感を覚えた。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
