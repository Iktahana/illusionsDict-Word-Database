[
  {
    "uuid": "08e80578-59f0-5d5f-ab93-f3dd57362446",
    "entry": "気まずい",
    "reading": {
      "primary": "きまずい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
