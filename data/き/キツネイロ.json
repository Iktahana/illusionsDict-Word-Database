        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "フライパンでパン粉を炒め、きれいなきつね色になったらグラタンのトッピングにする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ホットケーキの両面を、ムラなく美味しそうなきつね色に焼き上げるのは意外と難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "揚げたてのコロッケは、サクサクとした衣がきつね色に輝いていて食欲をそそる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "きつね色の毛をした、耳のぴんとつったった、あばらの間のやせくぼんだ、ぶきみな、よろよろ犬です。",
              "citation": {
                "source": "のら犬",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根の上には、灰色、きつね色、だいだい色、さまざまの雲が、かさなりあっていた。",
              "citation": {
                "source": "おかまの唄",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あの、大きいきつね色のどらねこは、君んちのかい。",
              "citation": {
                "source": "僕たちは愛するけれど",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央アルプスの主稜に新雪の閃耀が反映するころになれば、乗越の熊笹の斜面はきつね色にこげるだろう。",
              "citation": {
                "source": "二つの松川",
                "author": "細井吉造",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう１ど　下のオーヴンを　のぞくと、　パイは　すてきな　きつね色で、　ほかほか　ゆげが　出ていました。",
              "citation": {
                "source": "パイとやきがたのはなし",
                "author": "THE TALE OF THE PIE AND THE PATTY-PAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "上のオーヴンの　とびらを　あけると、　もくもくと　出てきたのは　こうばしい　子牛と　ブタももの　かおり、　みごと　きつね色の　パイが　のっかっていて　――　パイきじの　てっぺんに　あいた　あなから　ちいさな　かなものの　やきがたが　ちらり！",
              "citation": {
                "source": "パイとやきがたのはなし",
                "author": "THE TALE OF THE PIE AND THE PATTY-PAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "きらきら　きれいな　きつねいろで　あかの　すじが　さしていて。",
              "citation": {
                "source": "わるねずふたりぐみのはなし",
                "author": "THE TALE OF TWO BAD MICE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
