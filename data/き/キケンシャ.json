        "examples": {
          "standard": [
            {
              "text": "今回の選挙は、棄権者が過去最高を記録した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "棄権者を減らすための啓発活動が活発に行われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "マラソン大会では、序盤で多くの棄権者が出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "有権者の半数近くが棄権者となり、選挙結果に影響を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そしてこの選挙にもう一つの面白い現象は、棄権者が全有権者の半分以上もあったことだ。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
