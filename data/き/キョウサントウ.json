        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "選挙を前に、共産党の候補者が駅前で熱心に格差是正を訴えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おい、共産党のポスターが剥がされてるぞ」と近所の人が指差した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はかつて共産党員だったが、党の方針に疑問を感じて離脱した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「共産党の組織力は侮れない」とライバル政党の幹部が苦々しく漏らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いまの日本の共産党は、どうでしょうか。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと云って彼は有りふれの社会主義者でもなければ共産党でもない。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガロンはロシア人共産党員とともに上海に入ると、直に大馬路の一隅で露支共産会合が開かれ、赤衛軍の決死隊が組織され、党員徽章が配付されると労農領事館には青天白日旗とソビエット・ロシアの聯邦旗が交錯して掲げられた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事件は洪秀全の太平天国以来組織的に築かれた支那共産党の一つの滅亡であった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「北伐軍にゃ、まだ／＼政治部を出た共産党が、だいぶまじっとるんだよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こいつだけは、いくら共産党狩りをやったって、どこまでもだにのように喰いついとるという話だな。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「共産党は空気ですよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一方の窓の上の壁には、人民から強奪、強姦して国を売る張作霖の漫画と、共産党とソヴェートロシアを、「共産賊党」「赤色帝国主義」と称しているポスターが、電燈の陰影の背後に、ボンヤリと並んでいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "便衣隊と前後して、共産党員が市内にもぐりこんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）貴様、共産党の手さきであろうが！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "特曹は、支那の共産党員と、何か共謀して事をたくらんでいると、重大視していた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「共産党宣言」は暗黙の中にこの気持ちを十分に表現しているように見える。",
              "citation": {
                "source": "想片",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿帳には下手糞な字で共産党員と書き、昨日出獄したばかりだからとわざと服装の言訳して、ベラベラとマルキシズムを喋ったが、十年入獄の苦労話の方はなお実感が籠り、父親は十年に感激して泣いて文子の婿にした。",
              "citation": {
                "source": "実感",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はわざわざ上京して共産党の本部を訪問した。",
              "citation": {
                "source": "民主主義",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はバッタシーの前共産党代議士で組織者として有名だ。",
              "citation": {
                "source": "英国メーデーの記",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は社会党の右派でも左派でもなければ、共産党員でもない。",
              "citation": {
                "source": "家庭の幸福",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "座談会の出席者は、討論の相手とマイクとどちらの方へ話しかけていいのかうろうろ迷っているし、共産党員は威勢ばかりで懐疑のない声だ。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄洋社と愛国社に向って現今の共産党以上の苛烈な圧迫を加えたものであったが、これに対して愛国社が言論に、玄洋社が腕力に堂々と相並んで如何に眼醒しい反抗を試みたかは天下周知の事実だからここには喋々しない事にする。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃賊軍として死刑に処せられた者は、今日の共産党被告以上に見られてゐたのであるから、出版物にこれだけ書くだけでも容易でない。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの布団でふいに男が顔をあげて、きつと少年をにらみつけて『誰だつ―貴様は―』　と低い声でいつた、失敗つたと思つたが、少年は『誰でもない―静かにしろ、おれは共産党だ』その男はくるりと布団をかぶつて、底の方へゴソゴソと芋虫のやうにもぐつてしまつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『共産党だ―』と出鱈目を言つてやつたら、ゴソゴソと布団の中に恐縮して頭をひつこめた男のことを思ひ出したのである。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "共産党宣言が最もすぐれた芸術品であるとは言へないからである。",
              "citation": {
                "source": "政治的価値と芸術的価値",
                "author": "マルクス主義文学理論の再吟味",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシア共産党の一指導者が、彼の国のプロレタリア文学について論じたときに、プロレタリアは既にすぐれた作家と作品とをもつやうになつたが、まだ欠けてゐるのは、トルストイとドストエフスキーとをもつに至らないといふ点である、といふやうな意味のことを言つた。",
              "citation": {
                "source": "諸家の芸術価値理論の批判",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これは或いは滅多に云えない事だが、僕等はある方法によって、そこは世界一を誇る警察網の力だが、すでに河田たちが共産党に加入しているということの確証を握ったのだ。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして　――共産党ではないさ。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だが、この新聞の持つ究極の意味は、それによってプロレタリアの党（共産党）の影響を深く工場の労働者大衆の中に浸透させ、やがては党を工場の基礎の上に建設する目的をもっていた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――で、労働者の党と云えば、それは「共産党」しかないわけだろう。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
