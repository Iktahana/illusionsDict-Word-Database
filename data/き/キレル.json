    "definitions": [
      {
        "index": 1,
        "gloss": "to break",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "左手の籔が切れる所に来ると、右手の方に養漁場がみえ、その他は一面の田で遠く神田上水源の方の森並に縁取られてゐる。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "常に彼の作品は、二二が四で割り切れる所の、あまりに常識的な理智的合理物でありながら、しかも言語の或るかくれたる影に於て、ふしぎに神祕的な「鬼」を感じさせる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、世捨人だつて、お金が少しでもあるから、世を捨てられるので、一文無しのその日暮しだつたら、世を捨てようと思つたつて、世の中のはうから追ひかけて來て、とても捨て切れるものでない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」牡兎は跳んで逃げた、泥をはねかしながら息の切れる程走つて去つた。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "本街道から製材所の横を切れると、もう既に裾野であるが、富士のそれとは違って、乾き切った砂漠で、セージと通称する白ッ茶けた草や、マンザニタと呼ばれるところの、灌木などが茂って、馬蹄の砂が濛々と舞いあがるのには、馬上｜面を伏せて、眼をねぶるばかりであった。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、子供たちは、その小さな心臓がハチ切れるように、喘いでいるのにその屍体を起すことにかかっていた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "参拝者の来るのが始めのうちは引切りなしに続いてくるが三十分もたつと一時まばらになりやがてちょっと途切れる。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは「ツイ」切れるか。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学における fellowship は未婚者のみに許されるという規則であったので、結婚と同時に大学との縁は切れることになった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（移動）　又見た眼、男行く、又切れる　女、次の銃眼へ。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "厭世家と云ふものは一種のイゴイストですから……」　聲が途切れると、またしんとなる。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜がふけるに従って、頭の上では、星が切れるように冴えかえった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、そこに、新しい手の切れるような札束があった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなに引っぱったら緒が切れるがな。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "星が切れるように冴えかえっていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "内地でもいつかはこの種の建築物の保存期限が切れるであろうが、そうした時の始末が取り越し苦労の種にはなりうるであろう。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "正宗を砥ぎにやったのをなまくらにして返して、これでも切れると云って平気でいるのは、少しおかしいと云わなければならない。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "星野温泉行のバスが、千ヶ滝道から右に切れると、どこともなくぷんと強い松の匂いがする。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "体内から薬の気が切れると、疼くような唸きにのた打った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）剣は、切れるように、刃がついとんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体の重心さえ失わなかったら滑り切れるだろうと思った。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだい、おまえは思い切れるかい、うむ、お香、今じゃもうあの男を忘れたか」　女はややしばらく黙したるが、「い……い……え」ときれぎれに答えたり。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この数は二、三、四、五、六のどれでも割り切れるから、一年おきの行事でも、三年に一度の万国会議でも、四年に一度のオリンピアードでも、五年六年に一度の祭礼でも六十年たてばみんな最初の歩調をとり返すのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手の切れるほどあたらしい紙幣であれば、私の心はいつそう跳つた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手の切れるほどあたらしい紙幣であれば、私の心はいっそう跳った。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "肺の大さははじめもあとも同じですから、丁度同じころに息が切れるのです。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」一郎は息も切れるように叫びながら丸太棒をもとのようにしました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……リンリン、リンリンリンリンリンリンリン……　眉香子はその音の切れるのを待ちかねて受話機を取り上げた。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし捨て切れるものじゃない。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬も嬉しくて尾を千切れる程振りました。",
              "citation": {
                "source": "どろぼう猫",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
