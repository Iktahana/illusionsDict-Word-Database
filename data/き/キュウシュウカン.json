        "examples": {
          "standard": [
            {
              "text": "災害時用に、高性能な吸収缶を備えた防毒マスクを準備した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この吸収缶は、特定の化学物質を除去するのに特化している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「え、この吸収缶、もう交換時期なの？」と、作業員はマニュアルを確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "工場の作業員は、有害ガスから身を守るために吸収缶を定期的に交換している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "煙がその吸収缶に吸われて、とたんに息がらくになった。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
