        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "父は乙未の年生まれで、温厚な性格だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "乙未の年に創業したこの店は、今年で70周年を迎える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域の人口調査は、毎回乙未の年に実施されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人は乙未生まれで、いつも周りの人を癒やす存在だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "先月の地震は、乙未の年の天災を思い起こさせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "二十八年（乙未）　一八九五○一月、新富座の中幕「鎌倉三代記」にて、菊五郎の三浦之助、好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日、乙未、相模国大庭御厨の内に、大日堂有り、本尊殊に霊仏なり、故将軍の御帰依等閑ならず、而るに近年破壊の由聞食し及ばるるに就いて、雑色を召し、修造を加ふ可きの旨、今日相州に仰せらると云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿六日、乙未、天霽、相州、武州、大官令等参会し、御所新造の事群議に及ぶ、是去る五月合戦の時、焼失するに依りてなり。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちで大和の地震はかなり大きかったと見えて、「書紀」にも「七年夏四月乙未朔、辛酉、地動き、舎屋悉く破る、即ち四方に令し、地震の神を祭らしむ」と言ってある。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十八年乙未、四十九歳。",
              "citation": {
                "source": "能久親王年譜",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "建久四｜癸丑年に十九なら安元元｜乙未年すなわち未歳生まれで寅歳でない、『東鑑』は偽りなしだから『異本曾我物語』は啌で寅歳生まれで虎と名づけたでなく寅時にでも生まれたのだろ。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "この雑誌には、山川菊栄、神近市子、板垣直子のような評論家からフランス文学の翻訳の仕事をした大久保（八木）さわ子、そのほか下位文子、正宗乙未、松本恵子等の翻訳家、平林たい子、中本たか子、戸田豊子、大田洋子、円地文子、大谷藤子、真杉静枝、大石千代子、林芙美子、詩人として永瀬清子等の作品ものせられた。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇平、文吉が姫路の稲田屋で九郎右衛門と再会したのは、天保六年｜乙未の歳正月二十日であった。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "天保六年乙未閏七月十七日歿。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此年乙未の秋には、其※斎が歿したのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此年乙未より安政紀元の甲寅に至る間は二十年である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二百十五　わたくしは此年天保乙未に狩谷斎の詳伝の有無を知らない。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二百十六　此年乙未には蘭軒門人森枳園の家に冢子約之が生れた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は「天保六乙未六月廿二日卒、（中略）仏諡知幼」と云ひ、此は「天保乙未七月朔生、二日卒、仏諡泡影」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "六年乙未　平八郎四十三歳。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙未初秋土子笑面識　　　　　　　　一　これは享和二年に十歳で指物師清兵衛の弟子となって、文政の初め廿八歳の頃より名人の名を得ました、長二郎と申す指物師の伝記でございます。",
              "citation": {
                "source": "名人長二",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八歳の秋、天保六年乙未の年には捨吉は尾張国丹羽郡丹羽村なる叔父鷲津松隠の家にあった。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "天保六年乙未の歳も早く秋となった時、大沼捨吉は再び江戸に還ろうとしていたのである。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙未だというから天保六年の生れだろうと思う。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "霙橋辻斬夜話",
                "note": "青空文庫"
              }
            },
            {
              "text": "京山男少年乙未秋　　　京水百鶴　　北越雪譜初編　巻之上越後塩沢　　鈴木牧之　　編撰江戸　　　　京山人百樹　刪定○　地気雪と成る弁　凡天より形を為して下す物○雨○雪○霰○霙○雹なり。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "京山男少年乙未秋　　　京水百鶴",
              "citation": {
                "source": "北越雪譜",
                "author": "北越雪譜叙",
                "note": "青空文庫"
              }
            },
            {
              "text": "次ぎに推古天皇の七｜年乙未四｜月廿七｜日に大地震があつた。",
              "citation": {
                "source": "日本建築の發達と地震",
                "author": "伊東忠太",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本書紀に七年夏四月乙未朔辛酉、地動、舍屋悉破、則令四方俾祭地震神とあるが、地震神といふ特殊の神は知られてゐない。",
              "citation": {
                "source": "日本建築の發達と地震",
                "author": "伊東忠太",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
