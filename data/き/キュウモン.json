[
  {
    "uuid": "d101f021-0522-5c0f-8d79-2a9fc85ba507",
    "entry": "糾問",
    "reading": {
      "primary": "きゅうもん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
