[
  {
    "uuid": "2a3565b7-cfa6-57db-b41a-d722f4e27cd4",
    "entry": "切り開く",
    "reading": {
      "primary": "きりひらく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
