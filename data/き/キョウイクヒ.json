[
  {
    "uuid": "a4342278-a02a-50b2-aa64-35ac1928883a",
    "entry": "教育費",
    "reading": {
      "primary": "きょういくひ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
