    },
    "definitions": [
      {
        "index": 1,
        "gloss": "education or school expenses",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "子供たちの教育費だけがいくらか不足だった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しばかりある株券と地所とは愛子と貞世との教育費にあてる名儀で某々が保管する事になった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから子供の教育費だ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしら程度の地主の借金の大半はこの教育費だが、さて卒業してどうなる？",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活費の点でもソヴェトでは例えば家賃、教育費、ある場合食費、電話料、電燈料、水道料等も各個人の収入との比例によって定まる。",
              "citation": {
                "source": "露西亜の実生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人がその仕事に熟達し、女としての経験もゆたかになり、成人しかかる子供たちの教育費に多くの費用がいる時期、妻・主婦・母として一番経済的負担の重い四十歳を越すと、停年である。",
              "citation": {
                "source": "離婚について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の子供たちの教育費は一さい僕らが負担してもいい――。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊豆地方の大震災　惨たる各地の被害　震源地は丹那盆地　死者二百三十二名　伊豆震災救済策　震災地方の納税減免　国庫負担法で業務教育費交付　両腕の動かしかたに共通の一種独特の職業的癖をもっている日本の列車ボーイが沈着な声で誰かに云ってる。",
              "citation": {
                "source": "ニッポン三週間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化建設のために大きい予算をもって、例えば日本の教育費削減とは反対に、ソヴェトでは国庫負担の学校、托児所、教員がうんとこの二三年の間に増やされる。",
              "citation": {
                "source": "ひとごとではない",
                "author": "――ソヴェト勤労婦人の現状――",
                "note": "青空文庫"
              }
            },
            {
              "text": "収入の七〇％以上は非配給物資の購入費にあてられて育児教育費は労働者三・九％、職員三・九％である。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅か七〇円二銭の教育費で中等学校の月謝七〇――二五〇円さえ普通の手段で支払えないことは明瞭である。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其外教育費を出しながら子供を小學校に遣ることが出來ないと云ふ事情――學校どころでは無い、兄弟父子離散、實に如何なる言葉で申したならば此の慘憺の有樣を訴へることが出來ませうか。",
              "citation": {
                "source": "公益に有害の鑛業を停止せざる儀に付質問書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "……學校ちうやつが金喰ひでな、村税の半ぼんは教育費やがな。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が昨年の九州旅行で聞いた事ですが、布哇や北米やその他へ出稼ぎしている彼地方の男女は、毎年尠からぬ額の金を郷里へ送って父母の慰安とし、弟妹の教育費に当てる者が多く、中には家倉を新築させ、田畑を買わしめる者さえあるといいます。",
              "citation": {
                "source": "激動の中を行く",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "平一郎が成長するにつれ生活費もかさまり、また彼の前途に控えている「教育費」の心配も予めして置かねばならなかった。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに私が県地にいて小学教育を督励していた経験では、是非とも強迫就学となし、その教育費も他の租税の如く、賦課するのでなければ結局の目的は達せられないという事を知っていたから、最前地方官会議の随行中文部省に出頭した時もこの意見を述べるし、また九鬼文部大輔にも面会してこの事を話して置いた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分の最も働き盛りの殆んど全ての歳月と精力とをその子供等の教育費や、それから娘たちの嫁入りの仕度の為めに費さなければならなかつた。",
              "citation": {
                "source": "夢",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうことが彼の後援者たる田舎ものの財布に負担をかけるとなると、彼らはとかく教育費はたいへんな出費だと考えたり、先生は単なる穀つぶしだと思ったりしがちだから、そうならないように、彼はいろいろと用事をしたり、また好かれるようにしたりした。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時分はとても給料が少なく生活費、沢山の子供（十三人出来）の教育費などで借金が出来、時々執達吏に見舞われましたが、私は一向に気にせず押えるだけは自由に押えて行けとその傍の机上で植物の記事などを書いていました。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第二部　混混録",
                "note": "青空文庫"
              }
            },
            {
              "text": "表向は長男で、実は光子の連子になる為年が丁年になった時、多年秘密の父から光子の手許に送られていた教育費が途絶えた。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君は子供の教育費だけは親類へ泣きついて、どうにかするから、生活費――家賃と食料とはあなたがお稼ぎなさいと言ふ。",
              "citation": {
                "source": "来訪者",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "大伯母からは克子の教育費が送られ、克子は女子大学へ進んだ。",
              "citation": {
                "source": "水鳥亭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "克子の教育費は、亮作を含めた生計費に用いることを禁ぜられ、信子もその禁令を堅く守っていたが、戦争がはげしくなり克子への食糧が大伯母から届けられるようになると、そのもの自体の恩恵に浴することは稀れであっても、配給の食糧をかなり豊富にとることができて、亮作も間接の恩恵に浴することができた。",
              "citation": {
                "source": "水鳥亭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私どもは子供が生れた時から、将来教育費に当てるつもりで少しずつ積んで行き、こればかりは自分の所有にないものとして考えていたのであるが、見ると三百円になっている。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそれは単に名目上の制度からそうだという迄であり、それが実質的にもそうだというなら、夫は子弟の教育費資本を所有するごく一部分の社会層だけを見て之を社会の全般と考える極めて偏頗な同類感に立っている結果にすぎぬ。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお孃さんが、先生の家や學校に關した下※りの用事を、教へる方が忙しく暇がないだらうから手傳ひをさせるといふ條件で、養育院から一人孤兒を連れて來て、その教育費と被服費を拂つて下さるのです。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度フミちゃんの教育費に十分なわけです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アントアネットが外国での就職を甘受したのも、半ばは弟の教育費を補助するためであった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その教育費のほとんど全部を仕送っていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから彼らが帰国した後も、生活費だけは幾年も送金してくれているとか、生れた子供には成人までの教育費が保証されているとか云う例は、珍しくも何ともなかった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
