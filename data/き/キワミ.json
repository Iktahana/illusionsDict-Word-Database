        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "カント・アーベントには相当に意味があるが、映画アーベントに至っては笑止の極みである。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車で田舎へ遊山に出かけるというようなことは非常な金持のすることで吾々風情の夢にも考えてはならない奢りの極みであるような気が何となしにしていた。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二剣はきらめき弾はとび　　かばねは山なし血は流る戦のちまたのいさほしを　　我身にあつめし其時かオー　否　否　否　　楽しき極みはなほあらん。",
              "citation": {
                "source": "遠友夜学校校歌",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三黄金をちりばめ玉をしく　　高どのうてなはまばゆきにのぼりて貴き位やま　　世にうらやまれん其時かオー　否　否　否　　楽しき極みはなほあらん。",
              "citation": {
                "source": "遠友夜学校校歌",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四楽しき極みはくれはどり　　あやめもたへなる衣手かやしほ味よきうま酒か　　柱ふとしき家くらかオー　否　否　否　　楽しき極みはなほあらん。",
              "citation": {
                "source": "遠友夜学校校歌",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五正義と善とに身をさゝげ　　欲をば捨てて一すぢに行くべき路を勇ましく　　真心のまゝに進みなばアー　是れ　是れ　是れ　　是れこそ楽しき極みなれ。",
              "citation": {
                "source": "遠友夜学校校歌",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "六日毎の業にいそしみて　　心にさそふる雲もなく昔の聖　今の大人　　友とぞなしていそしまばアー　是れ　是れ　是れ　　是れこそ楽しき極みなれ。",
              "citation": {
                "source": "遠友夜学校校歌",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "七楽しからずや天の原　　そら照る星のさやけさに月の光の貴さに　　心をさらすその時のアー　是れ　是れ　是れ　　是れこそ楽しき極みなれ。",
              "citation": {
                "source": "遠友夜学校校歌",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "八そしらばそしれつゞれせし　　衣をきるともゆがみせし家にすむとも心根の　　天にも地にも恥ぢざればアー　是れ　是れ　是れ　　是れこそ楽しき極みなれ。",
              "citation": {
                "source": "遠友夜学校校歌",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "九衣もやがて破るべし　　ゑひぬる程もつかの間よ朽ちせでやまじ家倉も　　唯我心かはらめやアー　是れ　是れ　是れ　　是れこそ楽しき極みなれ。",
              "citation": {
                "source": "遠友夜学校校歌",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつとも知らず相手を判らず茫漠のうちに喰い尽されて失くなることは想像するだに不安の極みだ。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつし身のつひに果てなん極みまで　　添ひゆくいのち正眼には見よ第三五課　家庭　私は紅山茶花を見るといつも思うのです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "誠に畏き極みである。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことの瞳でものを見る人は、人の王のさかえの極みをも、野の百合の一つにくらべようとはしませんでした。",
              "citation": {
                "source": "めくらぶどうと虹",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当時、直ちに梁に撃たれ、直ちに火に焚かれたものは、勿論悲惨の極みである。",
              "citation": {
                "source": "九月四日",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで機因は、宇宙の因果律が構成するところの、複雜微妙極みなきプロバビリチイの數學から割り出される。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがもつと本質的な原因は、それが広茫極みなき天の穹窿で、無限の遠方にあるといふことである。",
              "citation": {
                "source": "月の詩情",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、その「さよな」といふ所から、揃つた聲の調子が急に下つて行くのを聞くのは、眞に悲哀の極みである。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でわたしがこの世に愛情の極みのおまえを、如何なる理由にしろ壊してよいものか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽欲の極みか、甘き寂寞の大光明、に喘ぐ時。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くて、わが運正しき紅玉の妙音楽は極みある命数の大歓楽に鳴りひびく。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "嗚呼今か畏怖の極み、轡虫は調子はづれに噪めきつつ、はたと息絶え、落ちかかる黄金の弦心臓の喘さながらまた黒き柩にしづむ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "不安いま、黒き旗して死の海を船ゆく恐怖、深沈の極み真黒に点鍾の悲音たまたま、天候の険悪いよよ、闇憺とわが夜はくだつ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤァハレ青雲やそのそぎ立、その極み、こをば。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤァハレ国の壁そのそぎ立、その極み、こをば。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤァハレ國の壁そのそぎ立、その極み、こをば。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び動くということなき永久の静かさは、実に冷酷のきわみである。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲まさにたけなわになりて、この楽器のうちにひそみしさまざまの絃の鬼、ひとりびとりにきわみなき怨みを訴えおわりて、いまや諸声たてて泣きとよむようなるとき、いぶかしや、城外に笛の音起りて、たどたどしゅうも姫が「ピヤノ」にあわせんとす。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が聞いたらばかばかしいきわみな話だろうが、現にある事実なのだ。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿馬鹿しいきわみだ。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
