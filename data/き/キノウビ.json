        "examples": {
          "standard": [
            {
              "text": "彼のデザインするツールは、無駄がなく、まさに機能美を追求している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い道具には、装飾がなくても使い込まれたことによる機能美がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "航空機の翼は、空気抵抗を極限まで減らした機能美の結晶だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ミニマリズムを追求した建築物は、その機能美が際立っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "飛行機の美しさ、すべての機械の美しさ、機能美の近代建築もまたそうである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            }
          ]
        }
