        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "待ち合わせは駅前のレトロな喫茶にした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この喫茶のモーニングセットは、トーストとコーヒーが付いていてお得だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人と休日の午後を、お気に入りの喫茶で過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの喫茶のチーズケーキ、本当に美味しいからおすすめだよ！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
