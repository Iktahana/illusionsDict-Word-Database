[
  {
    "uuid": "e441be67-ac14-50f7-a3ea-6817f9665d90",
    "entry": "喫茶",
    "reading": {
      "primary": "きっさ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
