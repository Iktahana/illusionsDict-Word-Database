    "definitions": [
      {
        "index": 1,
        "gloss": "tea drinking",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は休日の午後を、静かに読書をしながら喫茶に費やすのが好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "日本の伝統文化には、茶道に代表される喫茶の作法がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "健康のために、毎日緑茶を喫茶する習慣をつけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "学生のすくない大阪には、本格的の喫茶店がなく、珍らしい土産話と思つたからである。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一分間の閑も惜しく、タイムイズマネーで忙がしく市中を馳け廻つてる大阪人が、かうした東京の喫茶店風景を見て、いかにも閑人の寄り集りのやうに思ひ、むしろ不可思議に思ふのは当然である。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もさう言はれて、初めて喫茶店の客が「何を考へて居るのだらう」と考へて見た。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "武林無想庵氏の話によると、この余裕性をもたない都市は、世界で紐育と東京だけださうだが、それでもまだ喫茶店があるだけ、東京の方が大阪よりましかも知れない。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里の喫茶店で、街路にマロニエの葉の散るのを眺めながら、一杯の葡萄酒で半日も暮してゐるなんてことは、話に聞くだけでも贅沢至極のことである。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ君と喫茶店で紅茶を呑みながら同君の出品画「Ｉ崎の女」に対するそのモデルの良人からの撤回要求問題の話を聞いているうちに急激な地震を感じた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "震動が衰えてから外の様子を見に出ようと思ったが喫茶店のボーイも一人残らず出てしまって誰も居ないので勘定をすることが出来ない。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「喫茶店」が「サロン・ド・テー」になりかけているけはいもみえる。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年の歳末にその天野君と落合太郎君と私とで寒い晩に四条通の喫茶店へ茶を飲みに行ったことがある。",
              "citation": {
                "source": "偶然の産んだ駄洒落",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "売店で煙草を買っていると、隣の喫茶室で電話をかけている女の声が聞こえる。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野広小路の喫茶店へはいった。",
              "citation": {
                "source": "千人針",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの日は津田君の「出雲崎の女」が問題になっていて、喫茶室で同君からそのゆきさつの物語を聞いているうちに震り出したのであった。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は花田君子柳の下に棄てて、カバレット銀座、未来の情婦、万国の血をみて狂うメイ・フレデリック、私を見るや彼女の情熱死物狂い（その頃喫茶店インタナショナルの芸術家は珈琲とフランス菓子に驚歎して昆虫類が今後人間に代ってエゴイズムと排他主義、実行する。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "関東地震の起った瞬間に私は上野の二科会展覧会場の喫茶店で某画伯と話をしていた。",
              "citation": {
                "source": "家庭の人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　杏仁水　ある夏の夜、神田の喫茶店へはいって一杯のアイスクリームを食った。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍋町の風月の二階に、すでにそのころから喫茶室があって、片すみには古色｜蒼然たるボコボコのピアノが一台すえてあった。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ミルクのはいったおまんじゅう」をごちそうすると言ったＳ君が自分を連れて行ったのがこの喫茶室であった。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｆ屋｜喫茶店にいた文学青年給仕のＭ君はよく、銀座なんか歩く人の気が知れないと言っていたが、考えてみれば誠にもっとも至極なことである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうときに、清らかに明るい喫茶店にはいって、暖かいストーブのそばのマーブルのテーブルを前に腰かけてすする熱いコーヒーは、そういう夢幻的の空想を発酵させるに適したものである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころの給仕人は和服に角帯姿であったが、震災後向かい側に引っ越してからそれがタキシードか何かに変わると同時にどういうものか自分にはここの敷居が高くなってしまった、一方ではまたＳとかＦとかＫとかいうわれわれ向きの喫茶店ができたので自然にそっちへ足が向いた。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　熱帯魚（その三）　喫茶店の二階で友人と二人で話していた。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろよく喫茶店などの卓上を飾るあの闊葉のゴムの木とは別物である。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと前のことであるが、ある夏の日｜銀座の某喫茶店に行っていたら、隣席に貧しげな西洋人の老翁がいて、アイスクリームを食っていた。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、名刺を、友人や先輩、または馴染の喫茶店に差し上げてしまっていたのです。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この愚僧は、たいへんおしゃれで、喫茶店へ行く途中、ふっと、指輪をはめて出るのを忘れて来たことに気がつき、躊躇なくくるりと廻れ右して家へ引きかえし、そうしてきちんと指輪をはめて、出直し、やあ、お待ちどおさま、と澄ましていました。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は大学へはいってからは、戸塚の、兄の家のすぐ近くの下宿屋に住み、それでも、お互い勉強の邪魔をせぬよう、三日にいちどか、一週間にいちど顔を合せて、そのときには必ず一緒にまちへ出て、落語を聞いたり、喫茶店をまわって歩いたりして、そのうちに兄は、ささやかな恋をしました。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ高田の馬場の喫茶店に、兄が内心好いている女の子がありましたが、あまり旗色がよくないようで、兄は困って居りました。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十銭のコーヒーを飲みつつ、喫茶店の少女をちらちら盗み見するのにさえ、私は決死の努力を払った。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、「いでゆ」という喫茶店にはいった。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから三年経って、私は東京の大学へはいり、喫茶店や、バアの女とも識る機会を持ったが、やはり浪を忘れ得なかった。",
              "citation": {
                "source": "デカダン抗議",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
