        "examples": {
          "standard": [
            {
              "text": "「まさかそんな解決策を思いつくとはね。まさに奇想天外より落つ、といったところだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "締め切りが迫る中、彼は奇想天外より落つアイデアで危機を乗り越えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その発言を聞いたとき、彼の思考は完全に奇想天外より落ちていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "其の言行や奇拔にして當時の人にしては奇想天外より落つるといふ樣なことばかりされた人である。",
              "citation": {
                "source": "貝殼追放",
                "author": "愚者の鼻息",
                "note": "青空文庫"
              }
            },
            {
              "text": "「當時の人にしては奇想天外より落つるといふ樣なことばかりされた人である」とさもほこりかに詰問者は書立ててゐるが、「先生」の偉らかつたのは、最も吾々の生活を時勢の進歩に伴はせつつ合理的に導いた事にあるのであつて、滿洲浪人や衆議院々外團のやうな奇行を賣物にする徒輩と同列に見られては堪らない。",
              "citation": {
                "source": "貝殼追放",
                "author": "愚者の鼻息",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
