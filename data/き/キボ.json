[
  {
    "uuid": "711b9355-e9e6-5f33-8804-52ad4151c9d7",
    "entry": "規模",
    "reading": {
      "primary": "きぼ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
