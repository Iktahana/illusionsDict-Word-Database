[
  {
    "uuid": "3cc7c4f3-f366-54b2-8aa5-353c895b274c",
    "entry": "勤番",
    "reading": {
      "primary": "きんばん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
