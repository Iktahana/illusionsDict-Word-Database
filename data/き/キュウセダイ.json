        "examples": {
          "standard": [
            {
              "text": "「今の若い子はねえ…」と、旧世代の社員が嘆くのをよく耳にする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい技術が次々と登場し、旧世代の家電製品はあっという間に時代遅れになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は旧世代の考え方にとらわれず、常に新しい視点を取り入れようとしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は旧世代のアーティストの作品から多くのインスピレーションを得ている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "百万ページを収録するという『銀河ヒッチハイカーズ・ガイド』さえ、これで一気に旧世代の遺物になってしまうでしょう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが現実に用意されていたＯＳの選択肢は、もっともパーソナルコンピューターらしいグラフィックスや音の機能を欠いた、旧世代文化のコピー版だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
