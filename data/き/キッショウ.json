    },
    "definitions": [
      {
        "index": 1,
        "gloss": "lucky omen",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "庭に現れた白い蝶は、何か吉祥の知らせのように感じられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しいプロジェクトの開始にあたり、皆で吉祥を願って乾杯した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "早朝に見た虹は、今日一日が良い日になるという吉祥の兆しだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古来より、富士山と鷹と茄子は初夢で見ると吉祥とされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私は吉祥寺ではないかとも云ってみた。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしもその日の夕刊に、吉祥寺か染井の墓地である犯罪の行われた記事が出たとしたら、探偵でない自分は、少なくも一つの月並みな探偵小説を心に描いて、これに「玉虫」と題したかもしれない。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此處寛政三年波あれの時、家流れ人死するもの少からず、此の後高波の變はかり難く、溺死の難なしといふべからず、これによりて西入船町を限り、東吉祥寺前に至るまで、凡そ長さ二百八十間餘の處、家居取沸ひ、空地となし置くものなり。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みどり児を、片袖で胸に抱いて、御顔を少し仰向けに、吉祥果の枝を肩に振掛け、裳をひらりと、片足を軽く挙げて、――いいぐさは拙いが、舞などしたまう状に、たとえば踊りながらでんでん太鼓で、児をおあやしのような、鬼子母神の像があった。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、西の方遥に、山城国、浄瑠璃寺、吉祥天のお写真に似させ給う。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "君と逢ったらすぐに、ものも言わずに、その吉祥寺のスタンドに引っぱって行くつもりでいたのだが、しかし、君の汽車は、ずいぶん遅れた。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、君を吉祥寺のスタンドバアに引っぱって行く事を、断念しなければいけなかった。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野から吉祥寺まで、省線で一時間かかる。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜は、三鷹、吉祥寺のおでんや、すし屋、カフェなど、あちこちうろついて頼んでみても、どこにも酒が一滴も無かった。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は丸山君を吉祥寺駅まで送って行って、帰途、公園の森の中に迷い込み、杉の大木に鼻を、イヤというほど強く衝突させてしまった。",
              "citation": {
                "source": "酒の追憶",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、スルメを二枚お土産にもらって、吉祥寺駅に着いた時には、もう暗くなっていて、雪は一尺以上も積り、なおその上やまずひそひそと降っていました。",
              "citation": {
                "source": "雪の夜の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い雪道に白い新聞包を見つける事はひどくむずかしい上に、雪がやまず降り積り、吉祥寺の駅ちかくまで引返して行ったのですが、石ころ一つ見あたりませんでした。",
              "citation": {
                "source": "雪の夜の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこへ行こうというあてもなく、駅のほうに歩いて行って、駅の前の露店で飴を買い、坊やにしゃぶらせて、それから、ふと思いついて吉祥寺までの切符を買って電車に乗り、吊皮にぶらさがって何気なく電車の天井にぶらさがっているポスターを見ますと、夫の名が出ていました。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉祥寺で降りて、本当にもう何年振りかで井の頭公園に歩いて行って見ました。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉祥寺の駅の前でわかれたが、わかれる時に僕は苦笑しながら尋ねた。",
              "citation": {
                "source": "水仙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰途、吉祥寺駅から、どしゃ降りの中を人力車に乗って帰った。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにまた、Ｎ君はべつな本をひらいて私に見せたが、それには、「翌天保四年に到りては、立春吉祥の其日より東風頻に吹荒み、三月上巳の節句に到れども積雪消えず農家にて雪舟用ゐたり。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京｜天王寺にて菊の花片手に墓参りせし艶女、一週間思い詰しが是も其指つきを吉祥菓持せ玉う鬼子母神に写してはと工夫せしなり。",
              "citation": {
                "source": "風流仏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱の盤　吉祥天女、御功徳でござる。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番上りのものには、瑪瑙の莢に、紅宝玉の実を装った、あの造りものの吉祥果を遣る。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴はその日、森ちゃんを吉祥寺駅まで送って、森ちゃんには高円寺行きの切符を、自分は三鷹行きの切符を買い、プラットフオムの混雑にまぎれて、そっと森ちゃんの手を握ってから、別れた。",
              "citation": {
                "source": "犯人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉祥寺、西｜荻窪、……おそい、実にのろい。",
              "citation": {
                "source": "犯人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは、マサ子のよ」　と七歳の長女は得意顔で、「お母さんと一緒に吉祥寺へ行って、買って来たのよ」「それは、よかったねえ」　と父は子供には、あいそを言い、それから母に向って小声で、「高かったろう。",
              "citation": {
                "source": "家庭の幸福",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから十日ほど経って、きのうの朝、私は吉祥寺の郵便局へ用事があって出かけて、その帰りみち、また杉野君の家へ立ち寄った。",
              "citation": {
                "source": "リイズ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「吉祥院前の接骨医へ早く……」「お怪我は？",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その眉の上なる、朱の両方の円柱に、……妙吉祥…………如蓮華……　一｜聯の文字が、雪の降りつもる中に、瑠璃と、真珠を刻んで、清らかに輝いた。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の寺院は一名｜吉祥草院。",
              "citation": {
                "source": "法華僧の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議な夢を見たものだと思っていると、その夢が三晩もつづいたので、足軽も捨てては置かれないような心持になって、駒込の吉祥寺へたずねて行くと、それは伝説のあやまりで、お七の墓は小石川の円乗寺にあると教えられて、更に円乗寺をたずねると、果してそこにお七の墓を見いだした。",
              "citation": {
                "source": "夢のお七",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "『古事記』に大国主その兄弟に苦しめられた兎を救い吉報を得る事あり、これらは兎を吉祥とした例だが兎を悪兆とする例も多い。",
              "citation": {
                "source": "十二支考",
                "author": "兎に関する民俗と伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
