[
  {
    "uuid": "47b937a3-07de-5574-8360-d09d0979e9ff",
    "entry": "吉祥",
    "reading": {
      "primary": "きっしょう",
      "alternatives": [
        "きちじょう"
      ],
      "is_heteronym": false
    },
    "grammar": {
