      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "tree climbing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「おーい、ここまでおいで！」と、あの子は得意げに木登りをして枝から手を振った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔は放課後になると、近所の神社にある大きなイチョウの木でよく木登りをしたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ズボンの膝に穴が開いているのを見て、母親は息子がまた木登りをしたのだとすぐに悟った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "木登りに失敗して服を泥だらけにしながら、彼はケラケラと笑っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いつものように、彼は木登りをしようとする。",
              "citation": {
                "source": "愛撫",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼児の危い木登りには、まだ柿の実を取って食おうという慾がありましたが、このいのちがけのマラソンには、それさえありません。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは何だ、と学校でも先生様が叱らしゃりますそうなが、それで留めますほどならばの、学校へ行く生徒に、蜻蛉釣るものも居りませねば、木登りをする小僧もない筈――一向に留みませぬよ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "恭一君は木登りが上手でよくその木にのぼつてゐて、うかうかと知らずに下を通つたりすると、椿の実を頭の上に落してよこしておどろかすことがありました。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "恭一君は木登りがじょうずでよくその木にのぼっていて、うかうかと知らずに下を通ったりすると、椿の実を頭の上に落としてよこして、おどろかすことがありました。",
              "citation": {
                "source": "小さい太郎の悲しみ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "京子は子供が木登りする時のような手つきで、延び上って加奈子の耳へ片手で垣を作り、あたりを憚ってハンケチをねだった。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "地上から約六、七十フィートばかり登ったのではあるけれど、木登りの危険は事実もう去ったのだ。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ついぞ愚痴などを言った事のない祖母だけれど、このごろの余りの事に、自分さえなかったら、木登りをしても学問の思いは届こうと、それを繰返していたのであるから。",
              "citation": {
                "source": "瓜の涙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "膝を極めて、――起身の娘に肩を貸す、この意気、紺絣も緋縅で、神のごとき名将には、勿体ないようですが、北の方を引抱えた勢は可かった、が、いかに思っても、十七の娘を負って木登りをした経験は、誰方もおありになりますまい。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以来迷信的に木登りを怖れる質が生じてゐた。",
              "citation": {
                "source": "寄生木と縄梯子",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうだ俺は、それ以来一度も木登りといふことを試みたことは無かつたのぢやないかしら――不図私は、そんなことを思ひ廻らせてゐる矢先に、ずつと先の方に踏み入つてゐたフロラが、「ハロー、ハロー！",
              "citation": {
                "source": "寄生木と縄梯子",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は少年の頃、果物をとる目的で高い枝を伝ふてゐた時、突然枝が折れて地上に転落し左腕を折つた経験を持つて以来、木登りと聞くと迷信的な怖れを抱いて、忽ち脚がすくんでしまふのです。",
              "citation": {
                "source": "祝福された星の歌",
                "author": "An episode from the forest",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐が木登りするということはきいたことがないけになあ。",
              "citation": {
                "source": "屋上の狂人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでなけりゃ、あなに木登りのおたっしゃなわけはないからな。",
              "citation": {
                "source": "屋上の狂人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい時から高い所へ上りたがって、四つ五つの頃には床の間へ上る、御仏壇へ上る、棚の上に上る、七つ八つになると木登りを覚える、十五、六になると山のてっぺんへ上って一日降りて来ませんのや。",
              "citation": {
                "source": "屋上の狂人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "木登り方は先生の猿よりも上手になった。",
              "citation": {
                "source": "猿小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして猿共と一所に木登りをするけれども、木から木へ飛び移ったり綱渡りをするのが恐ろしくて恐ろしくて、どうしても猿共に敵わないんです。",
              "citation": {
                "source": "猿小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "木登りをして梨を揺り落す。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "眞紅な奴が枝も裂けさうになつてるのへ、眞先に僕が木登りして、漸々手が林檎に屆く所まで登つた時「誰だ」つてノソ／＼出て來たのは、そら、あの畑番の六助爺だよ。",
              "citation": {
                "source": "漂泊",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "真紅な奴が枝も裂けさうになツてるのへ、真先に僕が木登りして、漸々手が林檎に届く所まで登ツた時、「誰だ」ツてノソノソ出て来たのは、そら、あの畑番の六助｜爺だよ。",
              "citation": {
                "source": "漂泊",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀さんは國に居る頃から私と違ひまして、木登りの惡戲から脚に大きな刺などが差さつても親達に見つかる迄はそれを隱して居るといふ方でしたが、私は他の身體の疼痛を想像するにも堪へませんでした。",
              "citation": {
                "source": "幼き日",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は國に居てよく木登りをしたやうに、その土藏造の部屋の入口へ兩脚を突張りまして、それを左右の手で支へて、次第に高く登つて行くことを企てました。",
              "citation": {
                "source": "幼き日",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度小父さんの家がまだ京橋の方にあった時分｜田舎から出て来たばかりの彼は木登りが恋しくて人の見ない土蔵の階梯を逆さに登って行くことを発明したが、そんな風にある虚偽を発明した。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "所で、大阪を見たり、論じたりする場合、必ず、その好敵手である東京と比較して、女が、食物がというが、凡そこれ位、常套手段は無い――と思うが、何うも、これは、アメリカ人が、木登り耐久までもして、世界一という比較を誇ろうとする如く、文化の進歩上いい現象なのかもしれない。",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "団七の医者久庵、思つた割にをかしくなけれど、木登りをして熊だ鴉だとからかはれ、とど木から落ちて「両人待つた」と云ふ。",
              "citation": {
                "source": "両座の「山門」評",
                "author": "三木竹二",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る日、縁側から、母がそういう私らしくない乱暴な木登りを見ていた。",
              "citation": {
                "source": "幼年時代",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、水泳より山にいって、栗を取る方が面白くなり、木登りは上手になりました。",
              "citation": {
                "source": "鳶と柿と鶏",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「木登りも、その、野心の一つかい。",
              "citation": {
                "source": "鳶と柿と鶏",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛丸は、木登りが得意中の得意だった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、お母さんはまぶしさうに見あげるばかりですし、中学校の英語の先生であるお父さんは、昔から木登りなんか少しも出来ないので、みんな見あげてはさわぐだけです。",
              "citation": {
                "source": "かぶと虫",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
