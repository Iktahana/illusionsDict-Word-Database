[
  {
    "uuid": "3fd44303-e541-55dc-a447-78ff637cb636",
    "entry": "木登り",
    "reading": {
      "primary": "きのぼり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
