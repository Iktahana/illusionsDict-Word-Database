[
  {
    "uuid": "6e47524a-1f13-547d-b924-179caf2d0e30",
    "entry": "気候風土",
    "reading": {
      "primary": "きこうふうど",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
