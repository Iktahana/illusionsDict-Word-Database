    "definitions": [
      {
        "index": 1,
        "gloss": "today and tomorrow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
