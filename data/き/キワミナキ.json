        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "青年は窮みなき空高くながめ、胸さくるばかりの悲哀をおさえて、ひそめし声に力を入れ、『必ず手紙を送りたまえ、今こそわが望みは君が心なれ。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "）天壤と窮みなき、天津日嗣、ここに　（讚へまつれ、いざや。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "無限者と合一し一切の存在をわが懷に抱いた我は全身をもつて窮みなき歡喜と幸福とに浸るであらう。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "神は窮みなき惠みによつてこの唯一の途を徹底的に進むのである。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧者の一燈・やもめのレプタ（一錢）もここでは窮みなき尊さに輝く。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲まさにたけなわになりて、この楽器のうちにひそみしさまざまの絃の鬼、ひとりびとりにきわみなき怨みを訴えおわりて、いまや諸声たてて泣きとよむようなるとき、いぶかしや、城外に笛の音起りて、たどたどしゅうも姫が「ピヤノ」にあわせんとす。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダンテもこの愚劣きわみなき人生と、愚劣きわみなき自分に驚いて、こんな場面を着想したのではあるまいか。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　きわみなき苦悶　われわれが既にその多くの局面をながめてきた古い恐るべき争闘が、再び始まった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
