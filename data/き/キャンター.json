        "examples": {
          "standard": [
            {
              "text": "馬が軽やかなキャンターで馬場を駆け抜ける様子は、見ていて本当に美しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "乗馬クラブのレッスンで、ようやく駈歩（キャンター）の合図を馬に伝えられるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "障害物を飛び越える直前、馬はリズムを整えるためにキャンターの歩幅を調節した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「よし、いいぞ！そのリズムでキャンターを維持して」と指導員の大きな声が響いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "このマーク・キャンター、富士通との提携を発表するに当たっては右手を握ってラッパを作り「トラタタッタタ〜」と壇上でイントロを入れて稀代のパフォーマーぶりを発揮。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
