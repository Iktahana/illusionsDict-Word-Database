        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は物腰が柔らかく、どこか雅やかで、典型的な京男といった印象だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "京都出身の友人は、やはり洗練された京男の雰囲気を纏っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの店の店主は生粋の京男で、所作がとても美しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "凄艶な面に冷たい笑いを浮べながら、道行く人を物色していましたが、丁度通りかかったのは、夕遊びでもうひと堪能して来たらしい京男でした。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊びの場処も、亦伝統で都合よく出来ているというが、そのように都合よく遊べる場処にする丈、遊び熱が、京男に強いと云えよう。",
              "citation": {
                "source": "京都人の生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「京男と異って東男には、よいところがあるかもしれないからねえ、お前達二人も連れて行って、東男を見せてあげよう」「まあ、お姫様イヤでございますよ」　と、まんざら厭でもなさそうな様子で、幽霊女がしなをつくって云って、鶏娘の方をチラリと見た。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は庄太郎とて三十五六の男盛り、色こそは京男にありがちの蒼白過ぎたる方にあれ、眼鼻立ちも尋常に、都合能く配置されたれば、顔にもどこといふ難はなく、風体も町人としては上品に、天晴れ大家の旦那様やと、多くの男女に敬まはるる容子なり。",
              "citation": {
                "source": "心の鬼",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
