        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「きゃっ」と子犬が甘えるような声を出し、しっぽを振った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "鳥が木陰で「きゃっ、きゃっ」と楽しげにさえずっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ネズミが壁の隙間から「きゃっ」と鳴いて走り去った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「きゃっ」と可愛らしい声が聞こえ、振り返ると子猫がいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
