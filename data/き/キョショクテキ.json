        "examples": {
          "standard": [
            {
              "text": "あの politician は、虚飾的な言葉で有権者の心を掴もうとする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女の服装はいつも派手で、虚飾的な印象を与える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "豪華すぎる装飾は、かえって虚飾的に見えがちだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "SNS でのキラキラした投稿は、時に虚飾的に映ることもある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それにしても、僕はまだ、君が、星田代二の素性をどうして看破したか、そのいきさつを聞いていないんだけれど、よろしかったらどうか――」　内心の侮辱を忍びつつ、これも、所謂『教養階級』の虚飾的な外交辞令であった。",
              "citation": {
                "source": "殺人迷路",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この頃、私は、その内容に何か理由あり気なものを蔵してゞもゐるといふ風に考へるのは、自分に対する一種の虚飾的方便に過ぎなかつたらしい。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに田舎の紳士どもはその勲章めいた徽章がほしいわけであるか、あるいは県官らの勧めに余儀なくせられたるわけであるか、今日のところではとにかく非常に盛大なものとなつて、あるいは実用的よりもかへつて虚飾的に流れはせぬかと思ふほどである。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治の人には明治の思想あればそれを歌に詠むはいふ迄もなき事ながら虚飾的の忠君愛國などは之を詠んで何の妙もなかるべし。",
              "citation": {
                "source": "萬葉集を讀む",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪のＫは全く虚飾的結婚して、えらいさわぎしたのですから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんそれは、彼の性格のうちにある軽蔑的なものと相応じてはいたが、しかしなおいっそう、彼のうちの自動的な虚飾的なものから来るのであった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
