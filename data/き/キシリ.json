  {
    "uuid": "3e442ef9-de29-5251-83be-272e4c0540db",
    "entry": "きしり",
    "reading": {
      "primary": "きしり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞-と",
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "creak",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "隣の部屋からキンキン早すぎる回転の安蓄音器が、きしりわめく。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もやい綱が船の寝息のようにきしり、それを眠りつかせるように、静かな波のぽちゃぽちゃと舷側を叩く音が、暗い水面にきこえていた。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸外では寒いからっ風が勢いこんで吹きすさんでいるらしく、建てつけの悪るい障子が磨りへらされた溝ときしり合って、けたたましい音を立てていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か音がしていますわ」「どんな音」「そら、夢の水車のきしりのような音」「ああそうだ。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青ぞらはふるい　ひかりはくだけ　風のきしり　陽は織れど　かなし」　野ばらの木が赤い実から水晶の雫をポトポトこぼしながらしずかに歌いました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "退屈まぎれに見ておりました旅行案内を、もとへ突込んで、革鞄の口をかしりと啣えさせました時、フト柔かな、滑かな、ふっくりと美しいものを、きしりと縊って、引緊めたと思う手応がありました。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "船は、うめくような音をたてて、ミシミシときしりはじめました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "車は、秋の陽のなかを、ぎいぎいときしりながら、のろのろ進んでいつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の部屋からキンキン早すぎる廻転の安蓄音器が、きしりわめく。",
              "citation": {
                "source": "音について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（この日、退院の約束、断腸のことどもあり、自動車の音、三十も、四十も、はては、飛行機の爆音、牛車、自転車のきしりにさえ胸やぶれる思い。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十一年十月　　赤き花の魔睡日は真昼、ものあたたかに光素の波動は甘く、また、緩るく、戸に照りかへす、その濁る硝子のなかに音もなく、言……遠くきく、電車のきしり……………棄てられし水薬のゆめ……やはらかき猫の柔毛と、蹠のふくらのしろみ悩ましく過ぎゆく時よ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづこにか薄日さし、きしりこきり斑鳩なげく寂寥や、空の色なほ紅ににほひのこれど、静かなる、はた孤独、山間の霧にうもれて悔と夜のなげかひを懇に通夜し見まもる。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮れかぬる電車のきしり……凋れたる調和にぞ修道女の一人消えさり、裁判はてし控訴院に留守居らの点す燈は疲れたる硝子より弊私的里の瞳を放つ。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆綱の影、潮じみた欄干の明り、甲板の板の目、鐶のきしり、白い飛沫、浅葱いろの潮※。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中を踏み散らして広い運動場を一回りするうちに、赤い日影が時計台を染めて賄所の井戸が威勢よくきしり始めるのであった。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ゴメズが咆え立てるのを止めた時には、すでに列車は激しいきしり音を立てながらカーヴを曲っていた。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々が寝入って後、草も木も寝入って後、ひとり目ざめてしんとした夜の寂寞の中に、万年筆のペン先が紙にきしり込む音だけを聞きながら、私は神がかりのように夢中になって筆を運ばしている事もあった。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しろがねの樞はきしり、諸とびらつと離るるや、階を繪師はあがりぬ。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "滑車はきしり、綱は彼の手のひらをすり切るほどだつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "車道には電車がきしり、自動車が辷つて流れてゐる。",
              "citation": {
                "source": "癩者",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "つらきあらしを譬ふれば陰府なる門のきしりかも脆き、弱きをにへとしていけるをきほふ世々の聲うちに恨の叫ありうちに憂の涙あり。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸壘あまねく經※りて輪車靜かにきしり行く、星斗は開く天の陣山河はつらぬ地の營所、つるぎは光り影冴て結ぶに似たり夜半の霜。",
              "citation": {
                "source": "天地有情",
