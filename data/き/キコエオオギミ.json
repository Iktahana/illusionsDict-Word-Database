[
  {
    "uuid": "3b25036f-a9fa-5a28-8ae1-47133d9786d4",
    "entry": "聞得大君",
    "reading": {
      "primary": "きこえおおぎみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
