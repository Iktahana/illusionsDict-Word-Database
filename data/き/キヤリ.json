    "definitions": [
      {
        "index": 1,
        "gloss": "workmen's chant while pulling a heavy load",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大坂やわれ幼なうて伯母上が、肩にすがりし木遣り街かな。",
              "citation": {
                "source": "短歌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔時は大の男幾人、木遣りで揚げたというほどの大凧も飛んだと聞くが、子供には手頃でいつの時にも行わるるのは二枚半の絵凧である。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは五年目々々々に行はれる村の行事で、伊賀から伊勢へ、さう遠くもないところを、ぐるツと※り道して往復七日がかりで、木遣り音頭を謠ひながら、白裝束に脚絆、甲掛け、菅笠に金剛杖といふ山登りの姿をして、ゆる／＼と出かけるのである。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "木遣り音頭の聲賑かに、殆んど村中の人殘らずに送られつゝ、先づ隣り村の平井明神に參詣して、だん／＼伊勢路へ向ふのであるが、其の時から文吾の小ひさい身體は笑はれ通しであつた。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "木遣りなんか唄ったこたあねえんですからね。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間、ながく低く吼えるような木遣り歌であった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにもかくにも彼の家では、やがて木遣りの唄もいさましく送られて来るであろうこの男を待っていたであろう。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな中にも筏唄など言ふものは、労働の性質、又職業の接続からでありませうが、木遣りの姿を見せてゐたのは愉快でした。",
              "citation": {
                "source": "東北民謡の旅から",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "唄の方は、男性風な処は、却て鄙びて聞えましたが、念仏調子の外に、船唄から、木遣りの類の労働唄の心持ちが出て居ました上に、西洋の声楽もとり入れてある様に聞えましたのは、ひが耳でせうか。",
              "citation": {
                "source": "芝居に出た名残星月夜",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外、木遣り・伊勢音頭の類を見ても、念仏の影響してゐる事は容易に考へられる。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "元、祇園林を曳くに伴うた音楽・風流なる故の名でしたのが、夏祭りの曳き山・地車の、謂はゞ木遣り囃しと感ぜられる様になつたのでした。",
              "citation": {
                "source": "翁の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭が上にあがって音頭を取った、そして大勢の衆の木遣りの唄につれて棟木がゆるゆると上に引き上げられた。",
              "citation": {
                "source": "少年の死",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大通りに、木遣りの声が流れて来た。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "振舞い酒に好い気持になった連中が、向うから来る廻礼の女なんかをひやかしながら、木遣りの声を張り揚げて流してゆく。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　木遣りでも出そうな騒ぎ。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "日枝神社の山王祭と共に、御用祭又は天下祭と言われ、隔年に行われたこの威儀は、氏子中の町々を興奮の坩堝にし、名物の十一本の山車が、人波を掻きわけて、警固の金棒の音、木遣りの声、金屏風の反映する中をねり歩いたのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "夕立の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "日枝神社の山王祭と共に、御用祭又は天下祭と言はれ、隔年に行はれたこの威儀は、氏子中の町々を興奮の坩堝にし、名物の十一本の山車が、人波を掻きわけて、警固の金棒の音、木遣りの聲、金屏風の反映する中をねり歩いたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "夕立の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四の六　万吉はいい声だったが、明らかに木遣りの声であったし、節まわしも木遣りそのままであった。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを兵曹長が横からもう一突きやりました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きやりと閃く青白い恐怖が彼の頭の中にあらゆるものを一｜嘗めに浚って行ったあとは、超自然のような勢力が天地を縦横無尽に駆け廻る、その勢力に同化してしまって洋々蕩々たる気持になってしまうのだ。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "番兵たちや、あらゆる町の人たちが、まるでどきどきやりながら、矢を射る孔からのぞいて見た。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "張扇のようなもので台を叩き、拍子の間を取る音を混ぜて消防のきやりを稽古しているしもたやがあります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "古ギリシアの人が獅のために刺を抜きやり、のち罪獲て有司その人を獅に啖わすとちょうど以前刺を抜いてやった獅であって一向啖おうとせず、依って罪を赦された話は誰も知るところだ。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁夫二　（俊寛を突きやり）失せろ、流人め。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して彼等警官は些の事情もあらざるに、或は被害民を罵詈し、或は之を突きやり、甚しきは帯剣もて之を乱打せりと。",
              "citation": {
                "source": "鉱毒飛沫",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "生憎右手の工場で電気のエンジンを廻し出し、そのブーブーという音頭に響きやり切れず。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へえ、そんな人騒がせなこともときどきやりますが、あれあどうも少し狂言らしいんで……」「そうなのかい？",
              "citation": {
                "source": "美しい村",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（あの時お妻が、留女を、突きやり、俺の手を強く引っ張って、急いで歩いて来なかったら、あの女を仔細に見ることが出来、あの女が澄江かそうでないか、ハッキリ知ることが出来たものを）　それを妨げられて出来なかったことが、主水には残念でならなかった。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "叙事詩の中で、炉ばたに坐っている人に何か心の屈託があって、それを言い出そうとしてはちゅうちょしているさまを形容するのに、いつも出てくる文句は「岸なる灰を沖へかきやり、沖なる灰を岸へかきよせ、そのあいまあいまを突きながらかきまぜながら」というのであります。",
              "citation": {
                "source": "言語と文化史",
                "author": "――アイヌ文化の探究にあたりて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体組織と機能とが何か驚くべきやり方で変容し、斜めに投影されている――そのくせ通常の体の比率と性質との間に醜悪な関係をとどめているのだと。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
