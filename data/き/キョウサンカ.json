        "examples": {
          "standard": [
            {
              "text": "戦後の混乱期、東欧諸国が次々と共産化していく様子を当時の政治家は危惧していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「隣国が共産化したら、うちの商売も立ち行かなくなるかもしれないな」と祖父が漏らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "革命勢力の台頭により、その島国はわずか数年で急速に共産化した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歴史の授業で、冷戦下におけるアジア諸国の共産化について議論した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "軍人に出会って、世界の帝国主義が事実上に高潮しつつある事を厳然として指摘するかと思えば、社会主義者の顔を見ては、人類社会に於ける形而上と形而下のすべてが宗教、政治、芸術、経済の各方面に亘って民衆化し共産化しつつある事を決然として断言します。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし、それにしたって、印度からこちらの海岸線が、そう無暗に共産化してどうなるんだ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
