    "definitions": [
      {
        "index": 1,
        "gloss": "neighbourhood",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "近隣親族の徒が、この美しい寝顔の前で埋葬を議することを、痛く不快に感じた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "俄の騒ぎですから、近隣の人達が、どうしましたと云って尋ねにきた位でありました。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」風呂入りに集った近隣の老人達はおりくの家のことを悪く云いあった。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして引き出しを手伝ってくれた近隣の者と、義兄や甥に酒を振る舞った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その巨石を取巻く大小の墓の前には、それぞれに紅と白の桃の花が美しく挿し並べて在ったが、その墓の間々へ物見高い近隣の町の者や、通りかかりの肥汲みの百姓や柴売り、又は近道伝の太宰府参りらしい町人なんどが真黒く、犇々と押しかけて、中央の白い花崗岩の石甃の上を、折重なるように凝視している。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語がまだ初歩なのに仏語をちゃんぽんに教わっては不利益だという理由であったが、実際はその教師となるべき青年が近隣で不良の二字をかぶらせた青年であるがためだということが後にわかって来た。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々ものを言いかくれど、答は無くて、ただにこにこと笑うを見て、始め泰助は近隣の狂女ならんと見て取りつ、問えばさるものは無しという。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この血の跡を慕い行かばその行先を突留め得べきが、単身にては気味悪しと、一まず家に立帰りて、近隣の壮佼の究竟なるを四人ばかり語らいぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "交番も程遠く近隣に人無ければ、誰ありて介抱するもの無く、一杯の水を恵むもあらず、屑屋は人心地も無く呻きおりぬ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "孩児の頃より既に音律を好み、三歳、痘を病んで全く失明するに及び、いよいよ琴に対する盲執を深め、九歳に至りて隣村の瞽女お菊にねだって正式の琴三味線の修練を開始し、十一歳、早くも近隣に師と為すべき者無きに至った。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "読んで見ると、自分の放埒時代にしじゆう留守をさせられた彼女の、若き妻としての外出中の夫に対する心遣ひを、こまごまと打開けたものや、子の無い自分が長柄川閑居時代に、ふと愛した近隣のこどもに死なれ愁歎の世にも憐れなありさまを述べたものなどであつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と近隣に響きわたるほどの高声でわめけば、店の表に待っている借金取りは、はてな？",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "松川｜彼処に住ひてより、別に変りしこともなく、二月余も落着けるは、いと珍しきことなりと、近隣の人は噂せり。",
              "citation": {
                "source": "妖怪年代記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の慾張りなばあさんが近隣の二三の人から團子の模樣のついた素燒の菓子皿を貰ひ集めた。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日になって平太郎は新八郎を送って往って、一日其処で遊んで夕方になって帰ってみると、近隣の壮佼が五六人来ていて、「今晩は、お伽をいたそうと思って来ておる」と云った。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「頼もう、頼もう」　それは詞の使い方からして、近隣の人の声ではなかった。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近隣の人は皆年久しく住みたれど、そこのみはしばしば家主かわりぬ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕力もあり、年紀も長けたり、門閥も貴ければ、近隣の少年等みな国麿に従いぬ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらぬも近隣の少年は、わが袖長き衣を着て、好き帯したるを疎じて、宵々には組を造りて町中を横行しつつ、我が門に集いては、軒に懸けたる提灯に礫を投じて口々に罵りぬ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "近隣の人達は誰れも不愉快そうな顔をして居ます。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "近隣の家々は、よどんだ空気の中に靄に包まれてぼやけて居た。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "気も絶え入んほどに愕き惑ひしが、走り還りて泣き叫びつゝ、近隣の人を呼ければ、漸く其筋の人も来りて死躰の始末は終りしが、殺せし人の継しき中にもあらぬ母の身にてありながら、鬼にもあらぬ鬼心をそしらぬものもなかりけり。",
              "citation": {
                "source": "鬼心非鬼心",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、彼の漁師の家では、酒を買い、肴をこしらえて、近隣の者に御馳走することにして、獲った鮭の中から旨そうな奴を選んで、それを料理した。",
              "citation": {
                "source": "鮭の祟",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の仁蔵には直と云う近隣で評番の美しい女房があった。",
              "citation": {
                "source": "狸と同棲する人妻",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日わたくしは第一高等学校の北裏を歩いて、ふと樒屋の店の鎖されているのに気が付いたので、近隣の古本屋をおとずれて、翁媼の消息を聞いた。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "香以のその他の友に関して、近隣の梅本高節さんは語った。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "某致仕候てより以来、当国｜船岡山の西麓に形ばかりなる草庵を営み罷在候えども、先主人｜松向寺殿御｜逝去遊ばされて後、肥後国八代の城下を引払いたる興津の一家は、同国｜隈本の城下に在住候えば、この遺書御目に触れ候わば、はなはだ慮外の至に候えども、幸便を以て同家へ御送届｜下されたく、近隣の方々へ頼入り候。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "朔造氏は幕に這入ると、装束のまま楽屋の畳の上に平伏して息も絶え絶えに噎せ入ったが、その背後から翁が、「ええい……このヒョロヒョロ弁慶……ヒョロヒョロ弁慶……」　と罵倒する大声が、舞台、見所は勿論、近隣までも響き渡ったので、観衆は皆眼を丸くして顔を見合わせていた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小樽タイムスの記者某と、近隣の医師の介抱によりまして、ヤット仮死状態から蘇生しました私は、どうした原因かわかりませんが、自分自身の過去に関する記憶を、完全に喪失しておりましたのです。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎の合戦の時、近隣の連中が陣見舞に酒肴をもたせて光秀の陣に来た。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
