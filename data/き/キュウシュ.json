[
  {
    "uuid": "09d55df9-98a9-5fe2-b217-ee6565d5ed9b",
    "entry": "旧主",
    "reading": {
      "primary": "きゅうしゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "former lord",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "旧主人の角川家の前も通った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はアルサス、ローレンの歴史を研究した末、此二州は元々独乙のものであつたのだから、戦勝後は当然旧主の手に帰るべきものだといふ説を発表した。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "将門傾国の謀を萌すと雖、何ぞ旧主を忘れんや。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "……旧主人の後室様がお跣足でございますから、石松も素跣足。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "既にしてわたくしはこの家の旧主人小倉が後に名を是阿弥と云ったことを知った。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉沢の家は旧幕府の旗本で、維新の際にその祖父という人が旧主君の供をして、静岡へ無禄移住をした。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊においねは旧主人をかさにきて、とかくに亭主を尻に敷く形があるので、権七はいよいよ気がさして来た。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕府が瓦解の後、久住は無禄移住を願い出て、旧主君にしたがって駿府（静岡）へ行ったので、陪臣の箕部もまたその主君にしたがって駿府へ移ったが、もとより無禄というのであるから、どの人もなにかの職業を求めなければならない。",
              "citation": {
                "source": "有喜世新聞の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧主に叛いた左馬助としてみれば因果応報であるが、信長も相当に反間を用いている。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "石田三成が約束したように、信州に旧主武田の故地なる甲州を添え、それに沼田のある上州を加えて、三ヶ国位は貰えたであろう。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の夏この家からは数町を距てたある停留所で電車を待っていた時に、向かい側の寄席のある路次から、ひょっくり出て来た恐ろしくふとった女があると思って見ると、それが紛れもないジョンの旧主婦であった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで興哥は事情を話して、二人で厄介になることになったが、金栄は旧主に仕えるようにして二人の面倒を見た。",
              "citation": {
                "source": "金鳳釵記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、かの鶏がなぜ旧主人のお六に襲いかかったのか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、安蔵の死ぬ五、六日前に買った鶏がどうして旧主人のかたきを討とうとしたのか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理屋といっても、家には老母と小女がいるきりなので、お杉はどんなふうに頼み込んだか知らないが、その家を逢い曳きの場所に借りて、ときどきに旧主人に逢っている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鷹のゆくえ",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸へ出て来て旧主人の和泉屋に奉公することになった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく昔の家来すじの者が旧主人のかくれ家をさがし当てて、奇特にもその世話をしているのであろう。",
              "citation": {
                "source": "平造とお鶴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその後、深川の旧主人の店に再びその姿をみせなかった。",
              "citation": {
                "source": "平造とお鶴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやお父上を打って立ち退いた者、この了海に相違ござりませぬ」と、彼は自分を敵と狙う者に会ったというよりも、旧主の遺児に会った親しさをもって答えたが、実之助は、市九郎の声音に欺かれてはならぬと思った。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "老いたるかれらはみずから艫擢を把らなかったが、旧主君の前にあると同一の態度を以って謹んで歌った。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕府が瓦解の後、久住は無禄移住をねがい出て、旧主君にしたがって駿府（静岡）へ行ったので、陪臣の箕部もまたその主君にしたがって駿府へ移ったが、もとより無禄というのであるから、どの人もなにかの職業を求めなければならない。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖縄に於ては古来主権者の更迭が頻繁であったために、生存せんがためには一日も早く旧主人の恩を忘れて新主人の徳を頌するのが気がきいているという事になったのである。",
              "citation": {
                "source": "沖縄人の最大欠点",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "光隆寺は福田の屋敷の菩提寺ですから、命日というわけじゃあねえが、曽根も勤めの暇をみて、旧主人の墓参りに行ったのです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "吉良の脇指",
                "note": "青空文庫"
              }
            },
            {
              "text": "曽根も腹立ちまぎれに斬ってしまおうかと思ったのですが、自分も今は主人持ちですから、旧主人のかたきを討つというのは少し面倒です。",
              "citation": {
                "source": "半七捕物帳",
                "author": "吉良の脇指",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当に、讃州丸亀の京極の藩中でお膳番を勤めたのは、彼の旧主の鈴木源太夫である。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お膳番なんて、武士のはしくれでさ、知行といって、僅か二十石五人扶持、足の裏にくっついてしまいそうな糊米ほどしかありませんや」　彼は、いかにもそれを軽蔑したような口調で、二十石五人扶持といったが、彼の旧主の鈴木源太夫の知行でさえ、本当は十石三人扶持しか取っていなかった。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際お膳番を勤めていたのは、旧主の鈴木源太夫ではなくして、自分であったような気持にさえなっていた。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」彼は、ちょっといいよどんだが、すぐ旧主の源太夫が、どうして十石の武士を棒に振ったかということを思い出した。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は旧主の鈴木源太夫が朋輩の幸田｜某を打ち果した前後の様子を、古い二十年近い昔の記憶から探り出していた。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
