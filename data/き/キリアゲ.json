[
  {
    "uuid": "92792c38-59cc-506f-b1cc-26a87cb44855",
    "entry": "切り上げ",
    "reading": {
      "primary": "きりあげ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
