    "definitions": [
      {
        "index": 1,
        "gloss": "Kiso valley section of the Nakasendo",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
