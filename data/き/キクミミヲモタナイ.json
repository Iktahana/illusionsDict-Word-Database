          "literary": [
            {
              "text": "だが基本的には他人の提案に聞く耳を持たないジョブズは、以降も何度かこのプロジェクトは不要であると主張した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがＲＵＲの株主連中は、当然のように聞く耳を持たないでしょう。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがトリガーセンは聞く耳を持たないだろう。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェシはロシア人のバカげた言い分など聞く耳を持たない。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョージ卿は貧乏だが、そんな話は聞く耳を持たないだろう」「違うぜ。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
