        "examples": {
          "standard": [
            {
              "text": "今年の秋は、近所の公園で旧車会のパレードが開催されると聞いて、今から楽しみだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "旧車会の仲間たちと、週末はいつもお気に入りの山道をツーリングしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は若い頃から旧車会に所属し、地域のイベントにも積極的に参加している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
