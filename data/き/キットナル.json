        "examples": {
          "standard": [
            {
              "text": "平和な日常の話をしていたが、政治の話題になると彼の表情は屹度なった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "嘘がバレた瞬間、相手の目が屹度なり、重苦しい沈黙が流れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「やり直しだ」と低い声で告げた上司の顔は、かつてないほど屹度なっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ぼくは言わないの、ジョージ、ワシントンも言わなかったから」「そうそうその方がいいんですよ、曲馬師と大統領とはまるで較べものになりません」「ぼくは母様、ぼくきっと大統領になりますよ」「まあいいこと、屹度なるんですよ」　母様は離れで縫物を始めなさる。",
              "citation": {
                "source": "少年・春",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の為めにだって屹度なる。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのときは会社だなんて、あんまりみんなでやったから損になったんだけれども、おれたちだけでやるんなら、手間にはきっとなるからな。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに早くっても今夜おそくか、明朝にきっとなるだらうと産婆が云ったために、彼は幾分か安心したのであったけれども、自分の留守にこのあまりに不思議な怖ろしい奇蹟が彼女に行はれたといふことが彼には、どうしたことだといふやうに、只驚かされてしまったのだった。",
              "citation": {
                "source": "かなしみの日より",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいには、　「今になる、蛇になる、　　きっとなる、笛が鳴る、」と唄いながら、とうとう河の岸へ出た。",
              "citation": {
                "source": "夢十夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日はあいにくいないけれども、そのボーイが、きっとなると、安南入を指差して、これは東洋人だが、われわれの同胞だ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は和歌子さんとめおとになっても恥かしくないようにきっとなるからね――」「ほんとう？",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "このかたの話をとっくりお聞きになったら、きっとなるほどとお思いになりましてよ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "万年の後には死と云えば自殺よりほかに存在しないもののように考えられるようになる」「大変な事になりますね」「なるよきっとなる。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっとなるに違いない！",
              "citation": {
                "source": "日は輝けり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見返されて、お民はいよいよきっとなる。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿波守もきっとなる。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
