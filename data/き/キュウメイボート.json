        "examples": {
          "standard": [
            {
              "text": "フェリーに乗船してすぐに、甲板に吊るされた救命ボートの番号と設置場所を確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "救命ボートのハッチを閉めると、外の荒波の音は遠ざかり、重苦しい静寂が包み込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「助かった……のか？」救命ボートに引き上げられた瞬間、全身の力が抜けて床に倒れ込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "船員は、声をからして、しきりに、救命ボートへ、船客をのせているが、これは老人や女子供が先であった。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ、船がいきなり左へかたむいてしまったので、右舷の救命ボートは、下へおろせなくなった。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "救命ボートが四隻、しずかにうかんでいる。",
              "citation": {
                "source": "幽霊船の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "つりあげた救命ボートの下をくぐって、ひょいと、むこうを見ると、船首のとっぱなに、黒いものが、うずくまっていました。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
