    },
    "definitions": [
      {
        "index": 1,
        "gloss": "golden and shiny",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
