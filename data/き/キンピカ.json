[
  {
    "uuid": "ae7645f8-127b-5df8-ad03-0ac53cb897a6",
    "entry": "金ピカ",
    "reading": {
      "primary": "きんピカ",
      "alternatives": [
        "きんぴか"
      ],
      "is_heteronym": true
    },
    "grammar": {
