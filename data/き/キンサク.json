      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "recent work",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こんど河出書房から、近作だけを集めた「女の決闘」という創作集が出版せられた。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その文中で花袋の近作、紀行文集『草枕』の中の事実に合っていない個所を注意した。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この心理を巧みに映畫で描いたものが、チャップリンの近作「街の灯」であつた。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "△歌の数は最近作十首内外ということにしたい。",
              "citation": {
                "source": "鎖ペンを握って",
                "author": "――三月十九日夜――　　山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして十首内外ならば、ほぼ、或る纏った気分を現わすことも出来ようし、また最近作として置けば季を限る必要はない。",
              "citation": {
                "source": "鎖ペンを握って",
                "author": "――三月十九日夜――　　山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――田螺公）五首ずつ集　　　　　　　　　最近作二月末日〆切　五首　　　　　　　　　（題□□□）佐波郡三田尻駅前浴永不泣子宛（椋鳥会『初凪』　大正二年一月）",
              "citation": {
                "source": "雑信（二）",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は四、五はい水を飲んで、さらにもう一冊の創作集を取り上げ、「走れメロス」という近作を大声で読んでみました。",
              "citation": {
                "source": "みみずく通信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは友人の近作について饒舌をふるつた。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて助教授宮坂は日本人的のぎこちない真面目な顔付きでガルスワーシーを覗き込むようにしながら氏の近作「銀の匙」と「白鳥の歌」に就いて発言しようと口を切った時、玄関へ一団の訪問客の押しかけて来たけはいを感じて言葉を切った。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、太宰治氏に教えられたことだが、志賀直哉氏の兎を書いた近作には「お父様は兎をお殺しなされないでしょう」というような会話があるそうである。",
              "citation": {
                "source": "大阪の可能性",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "之等の内、第六を先にした理由は、最近作が多く、整理に就き易かつたからである。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "之等の詩は邪宗門の最近作と同傾向のものであつて、却てその第一章『魔睡』中に入る可きものである。",
              "citation": {
                "source": "雪と花火余言",
                "author": "東京景物詩改題に就て",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、先週勤め先の学校で国漢の老教師が近作だという七言絶句を職員室の誰彼に朗読して聞かせていた時、父祖伝来の儒家に育った自分が冗談半分その韻をふんで咄嗟に酬いて見せた。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句が好きなんだそうで、夜、寝る前に松右衛門殿にさまざまの近作を披露して、その感想を求めたけれども、越後は、うんともすんとも答えぬので、清七殿ひどくしょげかえって、さっさと寝てしまったが、あの時は可哀想だった。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "流布される人気は何時の場合も、好感的なもので、作為のない彼の人柄がさうした好ましさを生むのであらう、この作家の初期の画面は神経をゆきわたらした、ねつとりとした粘液質のものだが、最近作では次第にそれが様式化され図式化されてきてゐて、淡白なものになつてゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ベンスン殺人事件』『カナリア殺人事件』『グリーン殺人事件』『僧正殺人事件』その他に近作一つと都合五つの長編小説を著わし、他に若干の短編小説がある。",
              "citation": {
                "source": "ヴアン・ダインの作風",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とそっちを向くと、　「君の近作を読みましたよ」と言って、笑っている。",
              "citation": {
                "source": "少女病",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とそっちを向くと、「君の近作を読みましたよ」と言って、笑っている。",
              "citation": {
                "source": "少女病",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけても最近作「鏡地獄」は、江戸川氏でなければ書けないもので、怪奇の美という此四文字が、ピッタリ宛て嵌まるように思われました。",
              "citation": {
                "source": "探偵文壇鳥瞰",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こなひだも俺の近作を見せたら、ひどく感心しをつたやうぢやて。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それぢや、談しますが、あの男はついこなひだ先生の御近作を拝見したといつて――あれには弱つたよ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "南禺が昔馴染の口から、嘉則がその日自分の見せた近作を散々にこきおろしてゐるといふ噂を耳にしたのは。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「先生、何でもよろしおますよつて、御近作を一つ……」といつて、大阪人に附物の茶かすやうな笑ひ方をした。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大仏次郎氏の近作「雪崩」などを見ても、読者が大仏氏に牽かれるのは、この作者のこの作者らしい人生観照の或る気分、現代のインテリゲンツィアの一部の人々がよかれあしかれ実際にもっており、或は扮装としてポーズしている知的情感的な或る気分の、文学的表現の味に魅力を感じているのであろうと思われる。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、先生は近作の漢詩を取出して高瀬に見せた。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "中棚鉱泉の附近は例の別荘へ通う隠れた小径から対岸の村落まで先生の近作に入っていた。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は空腹も忘れて、近作の推敲に一心だつた。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏の近作『三四郎』はこの筆法で往くつもりだとか聞いている。",
              "citation": {
                "source": "田山花袋君に答う",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシアの艦隊が、その実質にはツァーの政府の腐敗を反映して、どんなものであったかということは、ソヴェトの海洋文学の作者ノヴィコフ・プリボーイの近作「ツシマ」が、私達に雄弁な描写を与えている。",
              "citation": {
                "source": "花のたより",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
