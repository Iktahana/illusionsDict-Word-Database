[
  {
    "uuid": "5ce9dade-1ef2-5167-8103-fbf1237057c3",
    "entry": "近作",
    "reading": {
      "primary": "きんさく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
