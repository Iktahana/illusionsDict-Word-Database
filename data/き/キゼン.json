[
  {
    "uuid": "657093d4-03fa-5065-b4ad-c4d8dd298352",
    "entry": "毅然",
    "reading": {
      "primary": "きぜん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-たる",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "resolute",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "取引先からの無理な値下げ要求に対しても、彼女は毅然とした態度で「できかねます」と答えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "どんなに周囲から反対されても、彼は自分の信念を毅然と貫き、一歩も引かなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "目の前の不正を見逃すことができず、彼は毅然とした口調で上司に抗議した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "」（文字少し大きく）　宮本武蔵、両刀を抜いて毅然と立つ。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "公卿にも一人くらいはこういう毅然たる人があって宜かったのである。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "更にその中で、毅然として勝敗の外に立ちつつ、全局を支配して行く名将の心境（というものがあるとすれば）、それこそ正に舞曲を以て天命の所作と心得ている能楽師（そんな人がいるとすれば）の心境と一致するものではあるまいか。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くには湯の湖、戦場ヶ原を隔てて男体山が毅然として雲表に聳え立っている。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにモオパスサンの毅然たる男性が在る。",
              "citation": {
                "source": "女人創造",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日一派の有力なる詩論は、毅然として「自由詩は詩に非ず」と主張してゐる。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人が今日の社会に望むものは、民衆と同じ側に立って演説する人――彼等はあまりに多すぎる――でなくして、むしろ彼等に対抗し、反対の側に立っていながら、しかも根柢の足場に於て、民衆と同じ詩的精神の線上に立っているところの、一の毅然たる風貌を有する人物である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毅然たるところが一つも無かった。",
              "citation": {
                "source": "親友交歓",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其姉は即ち燕王の妃にして、其弟｜増寿は京師に在りて常に燕の為に国情を輸せるも、輝祖独り毅然として正しきに拠る。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで無くては四方八方難儀の多い上に、横ッ腹に伊達政宗という「くせ者」が凄い眼をギロツカせて刀の柄に手を掛けて居る恐ろしい境界に、毅然たる立派な態度を何様して保ち得られたろう！",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "臙脂屋は聞けども聞かざるが如く、此勢に木沢は少しにじり退りつつ、益々｜毅然として愈々苦りきり、「丹下氏、おしずかに物を仰せられい。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、何一つ毅然たる言葉が無いのだ。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸一先生の柔和にして毅然たる人物は、これ等の教訓を兒童の心に吹き込むに適して居たのです。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、ダンサーをして新円を稼いで行くことを、陽子の自尊心が許したのは、ホールの環境に汚れずに、溺れるくらいダンスが好きでありながら、毅然として純潔を守って行く茉莉の自信の強さに刺戟されたからであった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその題を見ただけで、反動的ファッショ政治の嵐の中に毅然として立っている小説家の覚悟を書こうとしている評論だなと思った。",
              "citation": {
                "source": "四月馬鹿",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の一隅には、誰も附添っていない一人の負傷者が、打捨てられ、毅然たる様子で横たわっていた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "維新後、西洋崇拝の弊風が天下を吹きめぐって我国固有の美風良俗が地を払って行く中に毅然として能楽の師家たる職分を守り、生涯を貫いて倦まず。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は九州に帰って後、そうした惨澹たる世相の中に毅然として能楽の研鑽と子弟の薫育を廃しなかった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "かようにして毅然たる翁の精進によってこの九州の一角福岡地方だけは昔に変らぬ厳正な能楽神祭が継続された。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の辺鄙福岡地方の能楽を率いて洋風滔々の激流に対抗し、毅然としてこの国粋芸術を恪守し、敬神｜敦厚の美風を支持したのは翁一人の功績であった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「前川夫人に泣かされないから、あの人に毅然として対抗しているから。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その毅然として、なにかかたく信ずるところあるがごとき花前は、その技においてもじつに神に達している。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは毅然たる態度でそのなすべきことをなしつつある。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "確信も意識もないにしても、かれの実行動は緊張した精神をもって毅然直行している。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "花前が例の毅然たる態度で技師先生のまえにでた。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思って見ると、花前の毅然とした顔つきが、このごろは、いくらかやわらいできたようにも見える。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "毅然として友に降らざりしヨブも、今は神御自身の直示に接して、この謙遜の心態に入るに至ったのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　父は激せず熱せず、毅然とした立派な調子で云い放った。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、今まで毅然として立っていた、直也の男性的な顔が、妙にひきつッたかと思うと、彼の赭い頬を、涙が、滂沱として流れ落ちた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、我々は、日本政府に不忠実なるものとして、折角平和のうちに得た通商の許可も取り消されないとも限らない」「いや、貴下は疑い過ぎる」副艦長のゲビスは、毅然として屈しなかった。",
              "citation": {
                "source": "船医の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
