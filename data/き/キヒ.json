    },
    "definitions": [
      {
        "index": 1,
        "gloss": "evasion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は、本能的に白樺の下へ行くのを忌避していた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場の空気は、幹太郎を忌避し、敬遠した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方科学者のほうではまた、その研究の結果によって得られた科学的の知識からなんらかの人間的な声を聞くことを故意に忌避することがあたかも科学者の純潔と尊厳を維持するゆえんであると考えるような理由のない慣習が行なわれて来た。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当座、いろ／＼と臆測されたが、就中政江の義弟たちは、政江がもと助産婦をしていたことが忌避されたのだと取沙汰した。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀子は、親爺が栗栖を忌避して、別の医者にかかっていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの頃物を書くのに、平俗は忌避せぬが、卑俚には甘んぜない。",
              "citation": {
                "source": "訳本ファウストについて",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "形式主義への・この本能的｜忌避と闘ってこの男に礼楽を教えるのは、孔子にとってもなかなかの難事であった。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "喘息と胃弱と蓄膿とに絶えず苦しまされている彼の身体が、自らの生命の短いであろうことを知って、第一の生き方の苦しさを忌避したのであろう。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学が其の効用を発揮するとすれば、それは、斯ういう時世に兎もすれば見のがされ勝ちな我々の精神の外剛内柔性――或いは、気負い立った外面の下に隠された思考忌避性といったようなものへの、一種の防腐剤としてであろうかと思われるが、之もまだハッキリ言い切る勇気はない。",
              "citation": {
                "source": "章魚木の下で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前から忌避し軽蔑されていた肉慾描写や、不倫の世相が、自然主義の輸入以来逆照され初めた。",
              "citation": {
                "source": "探偵小説の真使命",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前から（徳川時代から）忌避され軽蔑されていた肉慾描写や不倫の世相が、自然主義の輸入以来、臆面もなく逆照され初めて、往昔、最低級の芸術として扱われていた作品が、堂々として一般民衆の趣味傾向の王座を占むる事となった。",
              "citation": {
                "source": "甲賀三郎氏に答う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありとあらゆる男性は、皆申し合せたようにこのお許しの哀願を忌避します。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "忌避するためにジタバタ致します。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの方面ではむしろ反対に一生懸命「世界一」になることを忌避しているのではないかと思われるふしがある。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あの落穴――その恐怖こそ私のような大胆不敵な国教忌避者のために用意してあったのだ。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "利き過ぎた薬　当局の「作家忌避」　▼屋外労働者の生活問題に触れてゐる俗謡『土方殺すにや刃物は要らぬ、雨の三日も降ればいゝ――』を文筆労働者である作家に、あてはめてみると、或る作家の書いたものに、一度二度の発禁があれば、その作家を土方の雨同様、生活を乾上らすには充分だらう。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼ノ兵役忌避ヲ本旨トスル「クエーカー」宗ノ如キハ、小乘教ノ基督ニ於テスラ天國ノ戰ヲ指シ、地上ニ於テ尚我レ刄ヲ出サンガ爲ニ來レリト宜シテ終ニ羅馬ヲ天火ニ亡シタル一面ヲ有スルニ係ラズ、只其ノ殺ス勿レノ一項ヲ盾トシテ盲守スルニ過ギザル者。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "將來「クエーカー」宗ノ如キ又淺薄ナル非戰主義ノ如キヲ輸入シテ徴兵忌避ヲ企ツル者アラバ、刑罰ハ斷々トシテ其ノ最モ重キ者ヲ課シテ可ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "特ニ彼等ノ殆ド凡テハ今ノ大學教育ナル高等職業紹介所ニ入ルコトヲ以テ一種ノ特權階級ノ如ク考ヘ、心裏實ニ徴兵忌避ノ私ヲ包藏シテ其ノ猶豫ヲ求ムル者ナラザルハナシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時紅葉は私を忌避してイツ尋ねても居留守を遣い、途中で会っても碌すっぽ口を利かないという場合であったから、事情を話して私の仲介ではとても駄目だと断わった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちこの事件は、前述の如き心理状態に在りて、結婚を忌避しつつありしアリナ嬢を、従男爵が追求して謝絶の辞に窮せしめ、強いて同棲を承諾せしめしより起りしものにして、この婦人のこの画像に対する精神的の貞操を破らしめし罪は寧ろ従男爵側に在りと云うべし。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は人間を忌避し恐怖する。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうです、爾来ですよ、私は一切好意ある見方を、忌避することにいたしました。",
              "citation": {
                "source": "奥さんの家出",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……初めてギリシア人と接触して以来、数世紀の後までも、国民性の相違から来る忌避の感情が持続していた。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち癩のあらわれとしての最もシリアスで、同時に最も本質的な面は当然これを忌避しなければならぬことになる。",
              "citation": {
                "source": "映画と癩の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それをなすためには複雑な内容を忌避しなければならず、したがつて我々は意識的に一応退化しなければならない。",
              "citation": {
                "source": "映画と民族性",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうした会合に適した家もあるにはあつたが、青年はまだそれほどそんな世間に触れてもゐなかつたし、たえ子にも余りぱつとしたところや、人に顔を見られるやうな家は忌避されねばならなかつた。",
              "citation": {
                "source": "復讐",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロレタリア文学の伝承を忌避したがる一部の人々があるが今日力をつくして拒否すべきものは、文学運動までをああいう目にあわせた兇暴な治安維持法の変形した再登場である。",
              "citation": {
                "source": "プロレタリア文学の存在",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は反感的に放送を聴くことを忌避していました。",
              "citation": {
                "source": "壊れたバリコン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜汽車の仄暗き車燈の影に母なき子供等は眠り泣きひそかに皆わが憂愁を探れるなり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
