  {
    "uuid": "cba6a7fe-13fe-528f-a5c1-6f202791ea73",
    "entry": "譏誹",
    "reading": {
      "primary": "きひ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "abuse",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "スウィフトの『ガリバー巡島記』にヒントを得たやうな『ニェルス・クリームの地下旅行』Niels Klims Underjodiska Reis といふ物語の如きは、餘りにも眞に迫つて、偶然事實と符合したので、これは自分のことを惡口したものだと、譏誹の訴へを起したものすらありました。",
              "citation": {
                "source": "スカンヂナヴィア文學概觀",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜汽車の仄暗き車燈の影に母なき子供等は眠り泣きひそかに皆わが憂愁を探れるなり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さは云へまことやまつつじ、　　日影くもりて丘ぬるみ、　　ねむたきひるはかくてやすけき。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔塀のかなたに嘉莵治かも〕塀のかなたに嘉莵治かも、　　　　　ピアノぽろろと弾きたれば、一、あかきひのきのさなかより、　　春のはむしらをどりいづ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時しも赭きひのきより、　　農学生ら奔せいでて、雪の紳士のはなづらに、　　雪のつぶてをなげにけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだひとつ消えよかしと両手を肩に縋りながら顔もてその胸を押しわけたれば、襟をば掻きひらきたまいつつ、乳の下にわがつむり押入れて、両袖を打かさねて深くわが背を蔽いたまえり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日暮々々に水そゝげば此草とりつく便あるに任せて蔓をのばし、はや六月の初め、ひと花咲きそめて白きひを洗ひ捨てゝ四方山を見るに、さりとは口惜しや一銭つかはで是ほど面白く風情ありしことを知らず、もたれたる遊びに金銭を費して無益の年月を送りけるよと、今ぞ心のほこりを掃ひける。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "老夫婦にからだをまかせて、ときどきひとりで薄く笑っている。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきひとのうたったのまねしたんだぞ。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、さっきひとの云ったことを、うまく使ひやがったなとは思ひましたが、元来それは梟をよろこばせようと思って云ったことですから、私もだまってうなづきました。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば道成寺縁起という一つのテーマがあり、それの内容となるべきひとくさりのグロテスクでエロチックでまた宗教的なストーリーがある。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほしなし、すけ、てんもく、たけしま、きひめ、という珍らしい名なるがあり。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつきひとのうたつたのまねしたんだぞ。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもう追いつけなくなったときひばりはあのみじかい別れの歌を贈ったのだろうと思います。",
              "citation": {
                "source": "おきなぐさ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まひるの草木と石土を　照らさんことを怠りし　赤きひかりは集い来てなすすべしらに漂えよ。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒白鱗の帷子、同じ鱗形の裁着、鰭のごときひらひら足袋。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一際烈しきひかりものの中に、一たび、小屋の屋根に立顕れ、たちまち真暗に消ゆ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の角で、町の角で――　跛ひきひき追えど及ばぬ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は生れつきひ弱かったので、その後も幾度となく病気をした。",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどきひとり部屋の中で、変装してみたりなどしている。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しののめきたるまへ私の心は墓場のかげをさまよひあるくああ　なにものか私をよぶ苦しきひとつの焦燥このうすい紅いろの空氣にはたへられない戀びとよ母上よ早くきてともしびの光を消してよ私はきく　遠い地角のはてを吹く大風のひびきをとをてくう、とをるもう、とをるもう。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よきひとの側へにありてなにをかたらむすずろにもわれは思ふゑねちやのかあにばるをかくもやさしき君がひとみに海こえて燕雀のかげもうつらでやは。",
              "citation": {
                "source": "純情小曲集",
