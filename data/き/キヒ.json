[
  {
    "uuid": "5787bb9b-cb2a-5499-8933-995cdaf34eb2",
    "entry": "忌避",
    "reading": {
      "primary": "きひ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
