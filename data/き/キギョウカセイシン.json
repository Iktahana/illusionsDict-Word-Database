        "examples": {
          "standard": [
            {
              "text": "新しい市場を開拓するには、旺盛な起業家精神が欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女のプロジェクトは、まさに起業家精神の賜物と言えるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大学では、学生の起業家精神を育むための講座が開設された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は失敗を恐れず、常に新しい挑戦を続ける起業家精神の持ち主だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
