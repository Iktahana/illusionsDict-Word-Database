    "definitions": [
      {
        "index": 1,
        "gloss": "(just) out of curiosity",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
