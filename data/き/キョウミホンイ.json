[
  {
    "uuid": "0e086bc0-5345-56a3-9958-5094ff721910",
    "entry": "興味本位",
    "reading": {
      "primary": "きょうみほんい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
