        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "誰もが等しく学べるよう、教育の機会均等を目指す政策が発表された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会社は社員の昇進において、性別や年齢に関わらず機会均等であることを掲げている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "機会均等の原則に基づき、全ての応募者に公平な選考が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スポーツの世界では、努力した者が報われる機会均等が重要だと彼は語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "貴女は、皆に機会均等だと云いながら、青木君兄弟にばかり、いやに好意を持ち過ぎますね。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴女は、皆に機会均等だと云ひながら、青木君兄弟にばかり、いやに好意を持ち過ぎますね。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、女性の政治的権利の要求、社会生活の上の機会均等などの要求も、一人の人の発育の過程によって、其態度が違って来る。",
              "citation": {
                "source": "今日の女流作家と時代との交渉を論ず",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一、教育の機会均等、二、教師の社会的重要性、三、教育行政における地方分権の実施要請等を骨子としている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ、こういうのがロシア語では機会均等と云うのでしょうか？",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由競争、機会均等の美名が、最も権勢に憧れるものを権力ある地位につかせ、職責と称する役得の味を彼等に占めさせたのである。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにおいてか機会均等が叫ばれ、差別撤廃が唱えられるのは当然です。",
              "citation": {
                "source": "融和促進",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし機会均等といい、差別撤廃ということは、もと別々のものの間に起ることであって、引き続きその両者の対立が予想されているかの嫌いがあります。",
              "citation": {
                "source": "融和促進",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "差別撤廃といい、機会均等というのは、融和に達するの道筋であり、過渡時代の一時の現象でありまして、結局は両者が全然融解和合して、そこに区別すべき何物もないようにならねばなりません。",
              "citation": {
                "source": "融和促進",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども侯は日本人をして韓国の利益を壟断せしむる如き何等の偏頗なる政略を行使せず総ての外国人に対して機会均等主義を適用せり。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁論大会のようなものをちょっと覗いてみると、髪をぼうぼうにした学生が、紋附の羽織などを着て、官学閥の打破とか、機会均等とかいうことを、大声疾呼して大いに熱弁をふるっていた。",
              "citation": {
                "source": "私の履歴書",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無産者大衆が教育の機会均等を実質的に享受しているなどということは、全くの譫言にすぎまい。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが他方文学的自由主義者は、経済上の自由主義や政治的自由主義とはあまり関係がないので、従って、彼等の「公平」は機会均等や「人間平等」の興味とは別であらざるを得ない。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、文部大臣の権威　国際競争に限らず、勝負は機会均等でなければならぬ。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝ったものが勝ったもの、という神経の太いより合い世帯の社会で、個人というものの価値の目やすが、現代に近づくにつれて低下して来て、世に勝つための機会均等が、アナーキスティックだから、ギャングまで発育よくなって来てしまうのですね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕も略※その方針だが、斯ういう大問題は将棋の手見たいに先の先まで考えて置く必要があるからね」「いや、平社員は兎に角、水平線から上は機会均等で唯寿命の問題だよ」「寿命の問題とは？",
              "citation": {
                "source": "小問題大問題",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "便宜上の話だよ」「僕は敵の便宜を計りたくないんだ」「しかし吉川君、敵の便宜は同時に自分の便宜だぜ、機会均等だからね」　と安達君が道理を説いた。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
