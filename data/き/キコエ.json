[
  {
    "uuid": "ce1a9a69-88fe-57a5-afbb-5952e0988e8c",
    "entry": "聞こえ",
    "reading": {
      "primary": "きこえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
