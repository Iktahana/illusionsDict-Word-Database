      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to keep (e.g. the lead)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "破れかぶれのライターに発表会を葬式にされてしまったワークスは、売り上げランキングの上位をキープする大ベスト・セラーとなった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ママズ＆パパズの〈マンデイ・マンデイ〉と、スペンサー・デイヴィス・グループの〈キープ・オン・ラニング〉だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これ、おまえのぶん」　といって、高志は〈キープ・オン・ラニング〉を慶一にわたした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま、四階は〈アイ・フィール・ファイン〉、慶一と柾生は〈キープ・オン・ラニング〉、二階は〈スループ・ジョン・Ｂ〉をやっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "なしくずしに、〈キープ・オン・ラニング〉が終わる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは、むずかしいよ」　柾生が、さっきの〈キープ・オン・ラニング〉のことを、いま終わったように話しはじめた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの番組だって、ヒット中の曲はなんどもかけるだろ」「〈キープ・オン・ラニング〉にしたら？",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ディス・プログラム・イズ・コンパイルド・バイ・ケイ・アンド・ユアーズ・トゥルーリー、キープ・ユア・ヘッド・アップ、ティル・ネクスト・サンデイ、バイバイ」　ワラのあいさつが終わると、〈バルボア・ブルー〉が大きくなり、二〇秒ほどでフェイドアウトした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでは音程もはずれるし、リズムもキープできないだろう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分から他人の垣を越えようとせず、ある垣を此方からもキープアウトして居る。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "バンキープールの奇遇　私はブダガヤに参詣するばかりが目的ではなかった。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜汽車に乗り翌日昼過ぎにバンキープールという停車場に着きました。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "浩がボトルキープしておいたウイスキーはすぐなくなり新しく注文しなくてはならなかった。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "キープラ　Jan Kiepura　映画の方では非常に有名な歌手だが、私などはあまり興味を持てない。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "テナーのキープラ、ソプラノのムーアと同じように私は考えている。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いい女といい庭をキープ・アップするのには金がかかるのだ。",
              "citation": {
                "source": "二つの繪",
                "author": "芥川龍之介の囘想",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャンキープラといふ本格歌手を生かした、音楽映画だが、何うも買へない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
