[
  {
    "uuid": "c7677915-4c5f-5bed-be27-5d40a0c5e5b0",
    "entry": "興味津々",
    "reading": {
      "primary": "きょうみしんしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
