        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼女は共同井戸から水を汲んでいた。",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには共同井戸になっていて隣のお媽さん達が二三人来て、それが水を汲まないで頭を集めて話していた。",
              "citation": {
                "source": "雀が森の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして車が、鶴屋という町のかどの宿屋を曲がって、いつでも人馬の群がるあの共同井戸のあたりを駆けぬける時、停車場の入り口の大戸をしめようとする駅夫と争いながら、八｜分がたしまりかかった戸の所に突っ立ってこっちを見まもっている青年の姿を見た。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ下の路傍にある鮮人の共同井戸の側へ行って、わけもなく中を覗いて見たりなんかした。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛤井戸といつて、水が蛤の水の様に紫がかつた色をして居り、量も多く質もよく、その辺の家々の共同井戸になつて居た。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神さんの弟は一日うどんの玉を島中へ自転車で卸しに出掛けますし、老人達は、うどんを延したり、町の共同井戸から水を汲みこんだりして、まつたく、此家族の一日は時計よりも狂つた事がありません。",
              "citation": {
                "source": "小さい花",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃色の布をかぶった大柄なアグーシャが村の共同井戸のところで後家のマルーシャにいった。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸といえば、町内には共同井戸が一つあるだけじゃないか。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "神伝魚心流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸へとびこんで、ミソ漬けのムスビ五ツまきあげてやれ」　共同井戸だから、宵のうちは井戸端がにぎわっている。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "神伝魚心流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "共同井戸のポンプが鳴った、パチパチ焚火のはねる音がした。",
              "citation": {
                "source": "鋳物工場",
                "author": "戸田豊子",
                "note": "青空文庫"
              }
            },
            {
              "text": "共同井戸の側には、次第に人が集つた。",
              "citation": {
                "source": "玉の輿",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "移つて來た最初の夏、久しく雨が止絶えてタンクが涸れて、汚れ物が大分溜つたので、妻は近所の共同井戸へ行つて、二三枚の浴衣を洗濯した。",
              "citation": {
                "source": "水不足",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京府下南葛飾郡葛西村字大島の共同井戸より、フトこのごろの五月雨続く夜ごとのさびしさにつれて、青白き一団の陰火立ちのぼり、四、五尺の高さにてパッとかき消さるるを見たり。",
              "citation": {
                "source": "おばけの正体",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒板塀と共同井戸と、格子戸と野良犬と、型の如き道具立ての中を、マラソンの選手のように、飛び込んで来た六人。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分、此處ですよ」　路地の奧と入口に共同井戸はあるのですが、血の流れて居るのは、その井戸端ではなくて、伊三松の家のお勝手からチヨロチヨロと落ちる水が、下水に溜つてそれは魚屋が鮪をおろした時ほどの色になつて居るのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "處女神聖",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは二つのしもた屋が背中合せになつて居り、取つ付きのお勝手口には、達者さうな内儀が、此邊には數の少い共同井戸の、井戸端で洗濯をして居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "持參千兩",
                "note": "青空文庫"
              }
            },
            {
              "text": "平次の家の近く、通りから少し入つた一間の路地、一方は板塀で、一方は表を閉した貸家、その先が生垣で、共同井戸で、袋路地になつて居りますから。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "平次女難",
                "note": "青空文庫"
              }
            },
            {
              "text": "平次の家の近く、通りから少し入った一間の路地、一方は板塀で、一方は表を閉した貸家、その先が生垣で、共同井戸で、袋路地になっておりますから、日が暮れると滅多に人の通らないところです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "平次女難",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな人か知らないが此方へ通すが宜い」「へエ――」　ガラツ八が心得て路地へ首を出すと、共同井戸のところに待機してゐる、手頃の年増を一人呼んで來ました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "遺書の罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "顏を洗ふことにして、裏の共同井戸に飛出すと、そのまゝ水下駄を突つかけて逃げ出しましたよ」「女護ヶ島から逃出して來たのか、冥加な野郎だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美少年國",
                "note": "青空文庫"
              }
            },
            {
              "text": "駄菓子屋の裏手、共同井戸の側まで誘ひ出して、あまり人の目に立たないやうに埒をあけようと思ひましたが、秋の陽は意地惡く照しつけて、あんまり樂なお白洲ではありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "金藏の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな人か知らないがこっちへ通すがいい」「ヘエ――」　ガラッ八が心得て路地へ首を出すと、共同井戸のところに待機している、手頃の年増を一人呼んで来ました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "遺書の罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "駄菓子屋の裏手、共同井戸の側まで誘い出して、あまり人目に立たないように埒をあけようと思いましたが、秋の陽は意地悪く照しつけて、あんまり楽なお白洲ではありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金蔵の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は不思議に早く帰った路地の入口、共同井戸の前に、白い顔が自分を見詰めて居たのです。",
              "citation": {
                "source": "芳年写生帖",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "部落の共同井戸端から、洗濯中の女たちがその姿を眺めて、「ほんとに団長そっくりね」「まったくね。",
              "citation": {
                "source": "Ｓの背中",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "とも角も、眞珠太夫の人氣は、江戸中の評判で、湯屋でも床屋でも、共同井戸でも、男も女もその噂で夢中でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "眞珠太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "突き当りに共同井戸があって、ドブ板はすこし腐って路地には白犬がねそべっている。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その背中へクニ子は、「来年はな小母さん、種子あげまっせ」　そして、裏の共同井戸の物音を聞きつけると、今度はそっちの方へ走ってゆき、「下の小母さん、朝顔の花見に来てつかあされ。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠居所の井戸の釣瓶縄が切れて使えない間、二人して近くの共同井戸へ水を汲みに行ったこともあった。",
              "citation": {
                "source": "栞",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はいつもそこの廃れた共同井戸の縁にうずくまっていたが、ジャン・ヴァルジャンはよく彼に施しをしてやった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
