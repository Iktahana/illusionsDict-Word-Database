[
  {
    "uuid": "fa7a8890-a17c-53e7-8f6b-4913f09448a7",
    "entry": "享年",
    "reading": {
      "primary": "きょうねん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-接頭辞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "age at death",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "先日亡くなられた恩師は、享年92歳。温かい指導をありがとうございました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古文書には、その王の在位期間と享年が記されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "有名な彫刻家、田中一郎氏が享年78歳で永眠された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の墓碑銘には、戒名と共に、享年が刻まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "が、その時の大火傷、享年六十有七歳にして、生まれもつかぬ不具もの――渾名を、てんぼう蟹の宰八と云う、秋谷在の名物｜親仁。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年の七月、享年七十七歳であった。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "享年七十……幾歳であったか、実は筆者も詳しく知らない。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉の享年はまだ三〇でしたのに、その髪は白髪がちらほらと、ただいまのわたくしと同じように。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "享年八十一歳である。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "賣家も唐樣で書く三代目の徳川の天下、幸に家光の豪邁なるを以て、啻に父祖の業を墜さざりしのみならず、その業を整頓し、幕府の基礎を牢くし、三百の諸侯を掌上に弄して、將軍の威光は、旭日冲天の勢も啻ならざりしが、享年長からず、幼孤を殘して、滿月の影を西山に收めしかば、幕府の勢は、忽ち一頓せし也。",
              "citation": {
                "source": "宗吾靈堂",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "享年五十六歳であった。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、明治十二年九月二十三日の午後十時、師匠は、享年五十四でありました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "東雲師逝去のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "『天涯孤独信士』　裏には、「俗名船井三郎、享年三十六歳云々」としてあった。",
              "citation": {
                "source": "私はかうして死んだ！",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "団十郎は天保九年の生まれで、享年六十六歳であると聞いた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、永享年間（西暦一四二九―一四四一）の乱に武功をあらわして、ほまれを授かった事たびたびであった。",
              "citation": {
                "source": "ろくろ首",
                "author": "ROKURO-KUBI",
                "note": "青空文庫"
              }
            },
            {
              "text": "「性蓮院妙相日縁信女、父本皓、母渋江氏、安永六年｜丁酉五月三日｜死、享年十九、俗名千代、作臨終歌曰」云々としてあるのは、登勢の生んだ本皓の女である。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "文政十二年三月十七日に歿して、享年五十三であったというから、抽斎の生れた時二十九歳で、本郷真砂町に住んでいた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に「文化丙子九月六日病卒、享年八十有三」としてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓表に「居丸山邸舎三年、罹疾不起、実文政癸未八月十七日、享年四十四、葬巣鴨真性寺」と書してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "享年三十九歳である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らば享年四十六であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "享年四十八歳、大正九年五月九日病死す。",
              "citation": {
                "source": "遠藤（岩野）清子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "年四十二歳を享年四十二歳と解釋し得るかが一の疑問であるが、假りにこの解釋を可能としても、張守節が太初元年の條下に、明かに時年四十二歳の意味で加へた註を、勝手に享年四十二歳の意味に解釋し、剩へ之を勝手に後元元年の條に移すなどは、牽強附會の尤も甚しきものとして斷然排斥せなければならぬ。",
              "citation": {
                "source": "司馬遷の生年に關する一新説",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "茲に於てか懺悔洗礼を要す」　享年七十又三。",
              "citation": {
                "source": "臨終の田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "享年七十七であった。",
              "citation": {
                "source": "赤格子九郎右衛門",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪折れの音凄じや大桜　享年四十六歳。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蛭川真弓　享年四十八歳」　位牌ではないか。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "石川啄木と同じく名は一、享年二十七才、肺疾で短命を約束されてゐた彼は、俳壇の啄木といはれて惜しまれた。",
              "citation": {
                "source": "九月朔日",
                "author": "心猿",
                "note": "青空文庫"
              }
            },
            {
              "text": "維新の後私塾を開いて生徒を教授し、後に東京学士会院会員に推挙せられ、ついで東京教育博物館長また東京図書館長に任ぜられ、明治十九年十二月三日享年六十三で歿した。",
              "citation": {
                "source": "上野",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "あだかも、享年わずかに二十一歳の若さで薨去せられたという将軍を街道から遠く見送るかのように。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "天和・貞享年間の「雍州府志」には、京都｜天部部落の状態を記して、その家富める者多しと書いてあるが、これはひとり天部のみの事ではなかった。",
              "citation": {
                "source": "特殊部落と細民部落・密集部落",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "鷲津幽林は寛政十年十月十七日享年七十三で没した。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "側面に刻した墓誌に「先生姓藤原、名典、字伯経、一名守諸、号竹渓、称次右衛門、尾張人、給仕幕府、中興大沼氏、晩｜致仕、以文政十年｜丁亥十二月二十四日没、享年六十六。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
