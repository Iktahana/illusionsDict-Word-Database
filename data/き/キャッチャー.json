        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「これはアメリカ製でホックスキャッチャーと云います。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば戦車だの飛行機だのと云つても、漢字を当てはめて見なければ意味が通ぜず、英語を嫌つて野球用語のピッチャーを投手、キャッチャーを捕手などと云つて見たところで、やはり漢字を当てはめてみなければ意味は通じないのである。",
              "citation": {
                "source": "閑人詩話",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二京丸は三百四十｜噸、昨年の十月から今年の四月まで捕鯨母船極洋丸と共に南極の洋へ遠征し、キャッチャーボートとして百七十頭の巨鯨をとった手柄の船だ。",
              "citation": {
                "source": "鯨を釣る",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかくとして、僕の会社のキャッチャーボートが四、五艘、いま牡鹿半島の鮎川港を根拠地としていて、毎日金華山沖で盛んに捕鯨をやっている。",
              "citation": {
                "source": "海豚と河豚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜半十二時、私らは第二京丸というキャッチャーボートに乗って鮎川港から金華山沖へ出た。",
              "citation": {
                "source": "海豚と河豚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで走ったから、全速力十三哩のキャッチャーボートでは追いつかれない。",
              "citation": {
                "source": "海豚と河豚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャッチャーボートは、この月末に南極の海へ母船と共に、巨鯨を狙って出発するという。",
              "citation": {
                "source": "海豚と河豚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通のキャッチャーボートは三百六十トンから四百トン、十四｜哩から十六哩の速力がでるそうだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「上着を着ていたら、キャッチャー（排障器）にからまれて駄目だったろう。",
              "citation": {
                "source": "母子像",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "六メートルも飛んでいた私が、一尺五寸ぐらいのドブをとびそこなって墜落したり、キャッチャーがうけとれなかったぐらいスピードのあった私が、スポンジボールを十｜米も投げることができなくなった。",
              "citation": {
                "source": "世に出るまで",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この前はキャッチャーでしたけど。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きみはリトル・リーグでキャッチャーをやってたんだよ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "前部にはカウ・キャッチャーが装備してあり、煙突の前、ボイラーの突端には、ランタンのようなヘッドランプが乗っていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "カウ・キャッチャーの中央にある重い連結器を、ラリー・デイヴィスは両手で押してみた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はキャッチャーだった」　洋介の返答に、恵理子はうれしそうに微笑を深めた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、外見が人にあたえる印象とは大きくちがって、彼は頼りになる優秀なキャッチャーだった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供用のキャッチャーズ・ミットが、かちかちになって現れた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "野球用品の売り場で、キャッチャーズ・ミットの本格的なものをひとつ、彼は選んだ。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりのキャッチ・ボールは、ピッチャーとキャッチャーとに、最初から役目が決まっていた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はキャッチャーのつもりで川原へ来た洋介は、恵理子をピッチャーズ・プレートへいかせ、自分はホーム・ベースのうしろの捕手の定位置に立ったから、自動的にそうなった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャッチ・ボールの後半、彼はキャッチャーとしてきちんとしゃがんで、恵理子の球を受けた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちの高校の野球チームで投げたら、打てない奴はいっぱいいると思う」「ピッチャーは面白いわね」「キャッチャーもいいよ。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "強い陽ざしが連続する夏の日々のなかで、恵理子がピッチャーとして投げる球を洋介はキャッチャーとして受けるというキャッチ・ボールを、ふたりは続けた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕はリトル・リーグでキャッチャーをやってました」　と洋介は彼に言ってみた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっすぐに速く投げるのね」「いつもは僕がキャッチャーになって、受けている」「そうですか」　というような話を、四人はおたがいの間でまわしていった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとしきり続けてから、「僕がキャッチャーをやります」　と、洋介は恵理子の父親を示していった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャッチャーの指示として、父親はそれを受けとめた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋介が示すピッチャーズ・マウンドへ恵理子の父親は歩き、洋介はキャッチャーの位置に立った。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
