[
  {
    "uuid": "25729494-9673-50e3-9ac2-634b74e3e575",
    "entry": "機嫌のいい",
    "reading": {
      "primary": "きげんのいい",
      "alternatives": [
        "きげんのよい"
      ],
      "is_heteronym": true
    },
    "grammar": {
