      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "in a good mood",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　さう答へて玄関にあがると、機嫌のいい時にするいつもの癖で、青木さんは小｜柄な奧さんの體を軽く引き寄せながら、そのくちびるに短い接ぷんを與へた。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがどうも、どの木も画かきには機嫌のいい顔をしますが、清作にはいやな顔を見せるのでした。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中から「いるよ」と機嫌のいい声がして「早くおはいりよ」と皆三のいうのが聞える。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると目がぐるぐるっとして、ご機嫌のいいおキレさままでがまるで黒い土の球のように見えそれからシュウとはしごのてっぺんから下へ落ちました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、非常に機嫌のいい声でこう云うのであった。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "目のくりくりした丸顔で、玉も撞くし映画も見るが、浪曲は何よりも好きで、機嫌のいい時は楽燕張りの節廻しで、独りで南部坂を唸ったりしていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の古谷君は、機嫌のいい時は馬鹿にいいが、悪い時はまたひどかった。",
              "citation": {
                "source": "酒の追憶",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中から「ゐるよ」と機嫌のいい声がして「早くおはいりよ」と皆三のいふのが聞える。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　などと機嫌のいい時には、手さぐりで下の男の子と遊んでいる様を見て、もし、こんな状態のままで来襲があったら、と思うと、また慄然とした。",
              "citation": {
                "source": "薄明",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日顔を見せませんから案じられます、逢いとうはございます、辛抱がし切れませんでちょっと沢井様のお勝手へ伺いますと、何｜貴方、お米は無事で、奥様も珍しいほど御機嫌のいい処、竹屋の婆さんが来たが、米や、こちらへお通し、とおっしゃると、あの娘もいそいそ、連れられて上りました。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁が物見窓から舞台を覗いている時は、機嫌のいい時である事がその顔色で推量されたが、それでも何となく舞台が引緊まって来た。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と私は事更に機嫌のいい声を張り上げて、ある特別の親しみを見せるやうな調子で言ひました。",
              "citation": {
                "source": "愚かな朝の話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が子供の頃、母はもつとも機嫌のいい時に限つてこのうたをうたつた。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "機嫌のいい時には、これまで口にしたこともなかった、猥らな端唄の文句などを低声で謡って、一人で燥いでいた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "私だって商売は嫌いじゃないんですし」　叔母が叔父の機嫌のいい時を見てこう言うと、叔父はたちまち機嫌を損じて、「資本が無いから手は拡げられないよ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間ばかりすると、いしの機嫌のいい大声が聞えた。",
              "citation": {
                "source": "小村淡彩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "機嫌のいい時面と向って「縫子さん、またヒステリー起しちゃいけませんよ」などと出入りの細君が云っても、彼女はちっとも怒らなかった。",
              "citation": {
                "source": "縫子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前などの女房にならんでも、東京にはえい奧さんにしてやると云うて呉れる人がある」と、かの女は機嫌のいい時にはこちらをじらしてゐた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "課長の奴め、定めしおれがペコペコお辭儀をして詑びごとを言ふものと思つてゐたらうが、おれは平氣の平左で、別に怒つてもゐなければ、さうかといつてあまり機嫌のいい顏もしないで、奴を尻眼にかけたまま、まるで誰にも氣がつかないやうな素振りで自分の席にどつかり腰をおろした。",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまは早や、故き人の、潔癖とかんしやくの話をよくきいたが、それは、前に引いた、八歳の童兒の憤慨を知れば當然のことと思へるし、それが貴かつたのだが、わたくしはまた、小時間づつしかお目にかからなかつたせゐか、何時も、ものやさしい機嫌のいい、話好きの一面にしか觸れてゐない。",
              "citation": {
                "source": "八歳の時の憤激",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さア、伸公、ずいずいずっころばしを唄って帰ろうや」　啓吉達が勇んで路地の中へ帰って行くと、寛子は開けっぱなしの玄関に立っていて、気味の悪い程な機嫌のいい顔でニコニコ笑ってつっ立っていた。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茂登は機嫌のいい或る日冗談めかしてこんなことを云って笑った。",
              "citation": {
                "source": "その年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り、今夜一晩は、語り明して――月丸の、機嫌のいい顔を見て、父に詫び、母に詫びて、死のう――）　と、思った時「小太郎は、わしのことを知るまい。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の平一郎に対する理解は機嫌のいい時は「面白い」という程度の好感に止まっていても、何か平一郎に悪意をもつ場合には全然善良なる中学生としての彼の価値を否定する性質のものであった。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯父の張鎰が機嫌のいい顔をして立っていた。",
              "citation": {
                "source": "倩娘",
                "author": "陳玄祐",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も毎朝ラジオ体操がやれるようなほがらかな気分になれれば、そうしたら、きっといつもきげんのいい顔をお目にかけることができるかもしれない。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんから自分の一人むすこの悪友でもあるかのごとく思いなして、君が行くとかつてきげんのいい顔を見せた事のないその父らしい声だった。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きげんのいいときゃ、やけに朗らかにしゃべるくせに、むっつりしだしたとなると、べっぴんがしなだれかかっても、からきし感じねえんだからな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、取り替えようにもあいにくと妻はないし、伝六はあいかわらずうるさいし、したがってむっつり名人のきげんのいいはずはない。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌日、教授はきげんのいい顔で二少年のところへやってきて地球へいくことにきめたといった。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
