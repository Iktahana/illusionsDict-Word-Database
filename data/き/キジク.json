[
  {
    "uuid": "375857f1-dc70-546d-a125-c93c0ffad32a",
    "entry": "機軸",
    "reading": {
      "primary": "きじく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "axis",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "加之｜色なら圖柄なら、ただ暖く見せる側の繪といふことが解るだけで、何處に新機軸を出したといふ點が無い。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし放送員の新機軸は認めることにした。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "新機軸を出そうとした放送員は、芸もなく昔の野球放送の型を踏襲していたに過ぎなかったのだ。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "新機軸というものはむつかしい。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の後｜天保になって菊五郎は、堺町の中村座の夏演戯で亦『四谷怪談』をやる事になり、新機軸を出すつもりで、幽霊の衣裳に就いて考案したが、良い考えが浮ばなかった。",
              "citation": {
                "source": "幽霊の衣裳",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢詩和歌の擬古の裡に新機軸を出したものは姑く言わぬ。",
              "citation": {
                "source": "鴎外漁史とは誰ぞ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "古来邦画家は先人の画風を追従するにとどまって新機軸を出す人は誠に寥々たる晨星のごときものがあった。",
              "citation": {
                "source": "知と疑い",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってこれが勉強法と言っても、別になんの新機軸もなく、そうたいして骨折って勉強したこともない。",
              "citation": {
                "source": "わが中学時代の勉強法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅れてきた帝国主義国家、ドイツ、イタリア、日本は、ファシズムを国家の機軸に据えて、先を行く帝国主義諸国の覇権を脅かしながら勢力の拡大を試みた。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の社会は農業を機軸とした経済から工業、そして今では情報を中心とした経済体制へと移行している。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "調書や証言の類を排列していって、それによって次々に事件を解決してゆく手法にも、新機軸がうかがわれる。",
              "citation": {
                "source": "当選作所感",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればこの人は芸文に劃然たる一新機軸を出しし者にして同代の何人よりも、その詩、哲理に富み、譬喩の趣を加ふ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば此人は藝文に劃然たる一新機軸を出しゝ者にして同代の何人よりも、其詩、哲理に富み、譬喩の趣を加ふ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それも並々ならぬ新機軸を持った砕氷船なんだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのダーウィンの進化論と、あのフロイドの精神分析学と、あの日蓮の折伏主義とを、混和させたような同氏の思想が、探偵小説に盛られたなら、新機軸を出すに相違無い。",
              "citation": {
                "source": "探偵小説を作って貰い度い人々",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故今後の探偵小説家はどうしても筋の運び方、材料の取り方に新機軸を出すより外はないであろう。",
              "citation": {
                "source": "「二銭銅貨」を読む",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し、この男を、暗室内の犬に近づけて、犬が唾液の点滴を多くしたならば、誰が何と言おうとも、この男が犯人にちがいなく、これによって世界の探偵学に一新機軸を開き得るかと思うと、心臓が肋骨の外へ踊り出すような感じを起しました。",
              "citation": {
                "source": "新案探偵法",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "新機軸への開拓に深く印象づけられて、幸いにも今日あるに到ったことは勿論、日本画の骨子に松年先生の賜物もあるが、栖鳳先生の偉大なる御指導の程にも敬慕と感謝の念は忘れることは出来得ない。",
              "citation": {
                "source": "随想",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "初め狩野派の加藤文麗を師とし、後｜北山寒巌に従学して別に機軸を出した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつ当時の一政変は政論をしてますます改革的方針に向かわしめたるものあり、十一年の中ごろ、時の政府に強大の権力を占め内閣の機軸たるところの一政事家は賊の兇手に罹りて生命を殞したり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば欧洲の白色人種が喫煙に新機軸を出したるは、僅に一事軽便なるシガレツトの案出ありしのみ。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "その点では James Joyce が新機軸を出したと云ふべし。",
              "citation": {
                "source": "雑筆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰か年少の天才の中に、上記の新機軸を出すものはゐないか？",
              "citation": {
                "source": "澄江堂雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "英のシエクスピールやミルトンや仏のパスカルやコルネイユや皆別に機軸を出さざる莫し。",
              "citation": {
                "source": "文士としての兆民先生",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰でも前人以外に新機軸を出さねばならぬと誨えられた。",
              "citation": {
                "source": "文士としての兆民先生",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "橘の実を「ときじくの香の木の実」と言うた。",
              "citation": {
                "source": "花の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此人々の、祖先の中の一人であつた彼が、垂仁天皇の仰せにより、常世へ行つて、ときじくのかぐの木の実を将来した。",
              "citation": {
                "source": "花の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときじくは、常にある意で、かぐはよい香のある意である。",
              "citation": {
                "source": "花の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "田道間守がときじくの―かぐのこのみを採りに行つたと伝へのある南方支那と思はれる地方は、かくの如き木の実の実る富みの国であつたのだ。",
              "citation": {
                "source": "「とこよ」と「まれびと」と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
