      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "possession by a fox spirit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔の村では、奇妙な言動をする人が現れると、狐憑きではないかと噂されたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女の普段とはかけ離れた行動を見て、人々は思わず狐憑きではないかと囁き合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖母は狐憑きの迷信について、ただの昔話ではないと真剣な顔で語ってくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "天狗や狐憑き、河童など　天狗に攫われるということも、随分沢山あったそうです。",
              "citation": {
                "source": "江戸の化物",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "巫女　（上手に出られたのでやや狼狽しながら、義助の方を見て）これは狐憑きもひどい狐憑きじゃ。",
              "citation": {
                "source": "屋上の狂人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると狸腹の紳士や、狐憑きのやうな千三ツ屋が、声を合せてドツと笑つた。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　連中の青息は穴のあいた風琴のやうに手応えもなくなり、狸腹や狐憑きの姿も消え失せて、阿父は道具立てばかりが依然として艶々しい独り舞台で腕組をしてゐるのが目立つた。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは狐憑きを呼んで来て、神下しをかけて、一々名前を訊き出すといふ事だ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大助は狐憑きの言ふが儘に、ちやんと十九人の名前を書きとめたものだ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……『狐憑き、落つればもとの無筆なり』……という川柳を知っているかね君は……」　私は面喰った。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……狐憑き……落つれば……落つれば……もとの無筆……もとの無筆……　と心の中で繰り返したが、わからないものはいくら考えても解らなかった。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一字も知らなかった奴が狐憑きになるとスラスラと読んだり書いたり、祖先のいろんな才能や知識を発揮したりして人を驚かす例がイクラでもあるから、こんな川柳にまで読まれているんだ」「ヘエ――。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それにしても、その狐憑きの男のことを書いたと云ふドストエフスキイの小説はどうも一度讀んで見たい氣がする。",
              "citation": {
                "source": "本のこと",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "書き損ひの原稿と、あの髮を蓬々さした、狐憑きのやうな眼付きして、厭な姙婦氣取りのおせいとが待つてゐると云ふ譯かな。",
              "citation": {
                "source": "湖畔手記",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日子の初舞台は『キティ颱風』で、あのときは、はら／＼するばかりであつたが、その後、アトリエ公演の『狐憑き』に出て、こんどが三度目であるが、しかし、まだ、それこそ役者というようなものではない。",
              "citation": {
                "source": "女優の親",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "地にぬかずく、というようなことが、つまりは、戦争の性格で、人間が右手をあげたり、国民儀礼みたいな狐憑きをやりだしたら、ナチスでも日本でも、もう戦争は近づいたと思えば間違いない。",
              "citation": {
                "source": "天皇陛下にさゝぐる言葉",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇が現在の如き在り方で旅行されるということは、つまり、又、戦争へ近づきつゝあるということ、日本がバカになりつゝあるということ、狐憑きの気違いになりつゝあるということで、かくては、日本は救われぬ。",
              "citation": {
                "source": "天皇陛下にさゝぐる言葉",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "否、今まで狐憑きだった日本に、始めて、人間が生れ、人間の礼節や、人間の人情や、人間の学問が行われるようになった証拠なのである。",
              "citation": {
                "source": "天皇陛下にさゝぐる言葉",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ今の旅行のようでは、狐憑きの信仰がふえる一方に、帽子を握って手をふる背広服の人形がメーデーに現れたり、「アヽ、ソウ」などというような流行語が溢れて、不敬罪が流行ハンランするに至るであろう。",
              "citation": {
                "source": "天皇陛下にさゝぐる言葉",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝには身寄りのない貧窮家族、病人を抱へたのや、子だくさんの寡婦、頭のネヂのゆるんだのや、狂信狐憑きのやうなのや、十一家族もゴチャゴチャと虱と共に雑居して朝晩タイコを叩いて踊つてゐる。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "お衣ちやんはこれから神前に御報告してオユルシをいたゞかなくちやこゝを出られないのですから」「ぢや、オユルシがでたときのことにしませう」　ケチな性根をだしたばかりに神前へ坐らされ狐憑きの踊りを見せられ、あげくに五千円はやつぱりまきあげられる。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "常夜は、此を助ける為に、狐憑きの身ぶりで、指もさゝば怨み葛の葉、今にしのだに怨みの言葉。",
              "citation": {
                "source": "愛護若",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "龍教といっても、殆ど知る人もない怪しげなもので、裏長屋の片隅の狐憑きのような婆さんが、気違いじみた僅かな信徒を相手に言いたてた咒術のようなものだ。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "謎の微笑の陰影のために、口元が何となく狐憑きみたいになっていた。",
              "citation": {
                "source": "未来の天才",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダ・ヴィンチは恐らく狐憑きの女の顔を知らなかったのだろう。",
              "citation": {
                "source": "未来の天才",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "美作の護法実が水を飲んで正気に戻るのとよく似た行法で、狐憑きや犬神憑きの患者や、稲荷下げなどの挙動と甚だよく似ているのである。",
              "citation": {
                "source": "憑き物系統に関する民族的研究",
                "author": "その一例として飛騨の牛蒡種",
                "note": "青空文庫"
              }
            },
            {
              "text": "快く引きうけて下さいましたので、マサカと思っていましたが、狐憑きの血筋は争われないものですね」　新十郎は笑って、「お嬢さまはお考えちがいをなすッていらッしゃいます。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その三　魔教の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "初代三好の卑しくも美しき高座、万橘の、あの狐憑きの気ちがい花のように狂喜｜哄笑するところ。",
              "citation": {
                "source": "随筆　寄席風俗",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "金とともに出て行ったきり帰らないおさよを、毎日カンカンになって怒っていた源十郎のことだからフラリと、狐憑きのようにはいってきたおさよ婆さんを見ると、源十郎、われにもなくカッとなって、いいわけのことばも聞かばこそ、おのれッ！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　長屋の連中が蜻蛉の辰の軒下に立って呼吸を凝らしていると、なかでは長いこと話が続いたのち、やがて、三次ひとり狐憑きのような顔をしてぼんやり出て来た。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "霙橋辻斬夜話",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間のように落ちへ行って狐憑きの婆あが飛んで出るんじゃあ、こちとら引っ込みがつかねえからなあ、はっはっは。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怪談抜地獄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかのみならず、その地方において方術もしくは祈祷を専務とせる者さえ、またこれを狐憑き、狸憑き、もしくは蛇憑きの類ならんといえりとぞ。",
              "citation": {
                "source": "甲州郡内妖怪事件取り調べ報告",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ごらんのとおり、てまえども両人はご奉行神尾殿からお話しこうむって、きつねつきのお腰元をお静めに参った御嶽行者でござる。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
