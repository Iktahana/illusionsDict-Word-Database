[
  {
    "uuid": "91b48c9b-b0b1-5ee1-a5d4-8a66cd5034db",
    "entry": "狐憑き",
    "reading": {
      "primary": "きつねつき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
