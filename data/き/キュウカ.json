  {
    "uuid": "2f358a64-23e6-5adc-b56c-60c1bdfe4a4a",
    "entry": "九夏",
    "reading": {
      "primary": "きゅうか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "summer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "九夏三伏の暑熱にも怯げず土佐炭｜紅は魚屋の御用聞きなどを呼入れて、世話女房の酌で一杯やるといつた無事な日常、世人も羨む位であつた。",
              "citation": {
                "source": "名工出世譚",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙洞忠勤のおんむかし、九夏三伏のあつさにも、あせをのごひて終日庭中にかしこまり。",
              "citation": {
                "source": "山家ものがたり",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらきのふまでの街頭歌曲の寵児たちは九夏三伏の酷熱裡を或は南方の野に転戦したり、或はまた埒もなき軍用工場で一職工として酷使されてはしまつてゐたことだらう。",
              "citation": {
                "source": "旧東京と蝙蝠",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
