[
  {
    "uuid": "75c99270-2144-525d-b0cf-db3ad0cd5afd",
    "entry": "気風",
    "reading": {
      "primary": "きふう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
