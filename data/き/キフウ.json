    },
    "definitions": [
      {
        "index": 1,
        "gloss": "character",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "目立たない洋髪に結び、市楽の着物を堅気風につけ、小女一人連れて、憂鬱な顔をして店内を歩き廻る。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体こういう気風である。",
              "citation": {
                "source": "時代色",
                "author": "――歪んだポーズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日大学の専門の学生でさえ講義ばかり当てにして自分から進んで研究しようという気風が乏しく知識が皮相的に流れやすいのは、小学校以来の理科教授がただ与えられた知識を覚えればよいというように教えこまれている結果であろう。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思うと樋口も木村もどこか似ている性質があるようにも思われますが、それは性質が似ているのか、同じ似たそのころの青年の気風に染んでいたのか、しかと私には判断がつきませんけれども、この二人はとにかくある類似した色を持っていることは確かです。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "大工は名を藤吉と申しましたが、やはり江戸の職人という気風がどこまでもついて廻わり、様子がいなせで弁舌が爽やかで至極面白い男でございました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に、北海道あたりでは、未だ植民地的な気風が残つてゐるのでせうから質が悪いかも知れません。",
              "citation": {
                "source": "私有農場から共産農団へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、その大乗教義が、どのように日本民族の発展に役立って来たかと申しますと、まず第一に国民生活上、和恭勤勉の気風を涵養したことであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち電気風呂に入ったとき、中に居るときは何ともありませんが、出しな入りしなにはぴりぴり感じます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あしたこそ金を持って……を迎いに行ってやるんだ」「おやどこかへ行っているの」「スイスのホテルで着物を売っては男と食い継いでいるんだ」「ちっと怒っておやんなさいな」　この店の前持主のマダム・ルコントは面白い気風の女だった。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩は敢て重い荷物を担がせられたから憤慨するのではないが、一国の生命は地方人士の朴直勤勉なる精神にありとさえいわれているのに、その地方人士の一部がかくも懦弱にして狡猾なる気風に向いつつあるのは、実に痛嘆すべき次第である。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して心ある国民の頭脳には、勇健なる思想と尚武の気風とは次第／＼に侵み渡りつゝある也。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に英邁勇敢なるルーズヴエルト氏が大統領に就任せし時以来、一部国民の精神は著しく其感化を受けしものゝ如く、表面に黄金を崇拝する事に変りはなけれど、其精神に於ては英雄崇拝を以て本義と為し或者は尚武練胆の気風を皷吹し、或者は米国魂に加ふるに日本魂の精萃をすら吸収し伝播せんと企てつゝあるが如し。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽薄なるハイカラの模倣、柔弱なる気風の彌蔓、如何にして生活すべきやの嘆声、小成功熱の流行、議員高官の収賄、詐偽会社の出没。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地の人の気風は銀子にもよく判らなかったが、表面の愛らしい言葉つきの感じなどと違って、性質は鈍重であり、しんねりした押しの強さが、東京育ちの銀子にずうずうしくさえ思えるのだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここへ来て、もう四年にもなるので、家族のロマンチックの気風にすっかり同化している。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に日本人は、宗教的な気風や哲学的の瞑想を全く持たない。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "舶来の自然主義は、その新鮮なるバタの臭いがぬけると同時に、たちまち日本人伝統の気風に融化し、全く主観的精神のない、純粋なる客観的観照主義の文学になってしまった。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に詩人と小説家との別れるところは、この点の高貴性に関係なく、単なる気風や趣味の上での、人物的な相違にあるのだ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち小説家は、概して趣味が世俗的で、気風が世間的にできている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども一国の学者を挙げて悉く博士たらんがために学問をするというような気風を養成したり、またはそう思われるほどにも極端な傾向を帯びて、学者が行動するのは、国家から見ても弊害の多いのは知れている。",
              "citation": {
                "source": "博士問題の成行",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから読む方の力は今の人達より進んで居た様に思われるが、然し生徒の気風に至っては実に乱暴なもので、それから見ると今の生徒は非常に温順しい。",
              "citation": {
                "source": "落第",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か操持をもつという気風を自らたのしむ性分もあった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｙの権高な気風と、徹底した利己主義に、雪子はやゝ超人的な崇高な感じは受けたが、下町娘の持つ仁侠的な志気はＹにひどい反抗と憎みを持つた。",
              "citation": {
                "source": "過去世",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは伊達政宗という大名の開いたまちだそうであるが、日本で、der Stutzer の気取屋のことを「伊達者」といっているのは、案外、仙台のこんな気風をからかったことから始ったのではないかしらと思われるほど、意味も無く都会風に気取っているまちであった。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから自分は一生涯の、おそらくは最も重大な時期を、仙台のまちに委ねてしまうのだから、つい念入りにこのまちの性格に就いて考え、あれこれと不満を並べてみたくなっただけの事で、こんな気風のまちは、学問するにはかえって好適の土地なのかも知れない。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、その名城の傍の温泉も、永遠に淳朴の気風を失ふ事は無いであらうと、ちかごろの言葉で言へば「希望的観測」を試みて、私はこの愛する弘前城と訣別する事にしよう。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "分家の黒石藩が南にあるが、この辺にはまた黒石藩としての独自の伝統もあり、津軽藩とちがつた所謂文化的な気風も育成せられてゐるやうだから、これは除いて、さうして、北端は竜飛である。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "多少は主人の気風に同化されているらしく見えた。",
              "citation": {
                "source": "太郎坊",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてかへって蜘蛛からあざけられて、熱病を起して、毎日毎日、ようし、おれも大きくなるくらゐ大きくなったらこんどはきっと虫けら院の名誉議員になってくもが何か云ったときふうと息だけついて返事してやらうと云ってゐた。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり僕も気の毒になったから屋根の上からじっとボールの往来をにらめてすきを見て置いてねえ、丁度博士がサーヴをつかったときふうっと飛び出して行って球を横の方へ外らしてしまったんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
