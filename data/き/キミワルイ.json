    "definitions": [
      {
        "index": 1,
        "gloss": "unpleasant",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蛙や蝸牛などのグロテスクなものを薄気味悪い思いをしてまで食べなくとも、巴里には甘い料理がいくらもある。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "盛りあがった気味悪い肉が内部から覗いていた。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで泣いて居たらしく眼をはらして、充血した白眼が気味悪い程光つて居た。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてだらしなくくづした膝から肩へかけて、人工的に作上げた曲線の気味悪い美くしさだけが目についた。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと薄気味悪いね」　と、鶴雄が言うと弓子は、「なアに平気よ」　と、澄ましていた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "横紙破りの、ちょっと他人には真似ることの出来ないいたずらだったから、やってみると、快感はあったが、しかし、そのいたずらが結局殺人行為となってみると、いかな豹吉でも、さすがに薄気味悪い後味は心の底に残っていた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ署の玄関の石段を、固い姿勢で豹吉は登って行った――と、作者は書いたが、たしかに警察署の玄関へはいって行くことは、署員か御用商人か、新聞記者か、それとも警察の関係者以外にとっては、何か薄気味悪いものである。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは桷のあいだと開いている天井窓から、そのうす気味悪い小屋の中をのぞいてみました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐ろしいのか気味悪いのか、それとも腹立たしいのかわからぬまま、妻木君の黒い眼鏡を見つめて戦いていたが、やがてその笑いが静まって来ると私の心持ちもそれにつれて不思議に落ち付いて来た。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく、その子供の笑顔は、よく見れば見るほど、何とも知れず、イヤな薄気味悪いものが感ぜられて来る。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、よく見ていると、やはりこの美貌の学生にも、どこか怪談じみた気味悪いものが感ぜられて来るのである。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか、薄気味悪いことになりました。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵に対してこの無数の毒蛇は、素早く一様に鎌首をもたげ、しゆつしゆつと気味悪い音を立てて手向ふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でなければ何とも知れない底気味悪い遠方のものが云っているのだ。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは何とも説明し難いものではあるが彼をして現代の青年の仲間入りしようとする勇気を無雑作に取拉ぐ薄気味悪い力を持っていた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、創作の机から上げた氏の顔が平生の美貌と違った長いよれよれの顔で、気味悪いグロテスクな表情を呈して居た。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "利左は薄気味悪い微笑を頬に浮べて、「見たら、あいそが尽きるぜ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれの生涯の不幸が、相かわらず鉄のようにぶあいそに膠着している状態を目撃して、あたしは、いつも、こうなんだ、と自分ながら気味悪いほどに落ちついた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれの生涯の不幸が、相かはらず鉄のやうにぶあいそに膠着してゐる状態を目撃して、あたしは、いつも、かうなんだ、と自分ながら気味悪いほどに落ちついた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "振り返って砲兵工廠の方を見ると、一段と色の濃い火の中に青や赤の色の気味悪い火を交えて見えた。",
              "citation": {
                "source": "変災序記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "世俗の怖れる二百｜十日の前一日、二三日来の驟雨模様の空がその朝になって、南風気の険悪な空に変り、烈風強雨こもごも至ってひとしきり荒れ狂うていたが、今思うとそれが何かの前兆でもあるかのように急にぱったり歇んで、気味悪いほどに澄んだ紺碧の空が見え、蒔きずての庭の朝顔の花に眼の痛むような陽の光が燃えた。",
              "citation": {
                "source": "死体の匂い",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一緒に生活しているものが、そんな嫌なことをするのは、あたしがするのも同然、気味悪いわ。",
              "citation": {
                "source": "唇草",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その気味悪い笑いのうしろで立てたしゃくりのような笑い声が、加奈子を怯えさせたのであった。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まいどおおけに」「どうぞごひいきに」　夫婦がかりで、薄気味悪いくらいサーヴィスを良くしたが、人気が悪いのか新店のためか、その日は十五人客が来ただけで、それも殆んど替刃ばかり、売上げは〆めて二円にも足らなかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが男親であるか女親であるかを問いただそうかと思ったが、なんだか薄気味悪いのでやめた。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は臆病者でないと信じていながら、一時はなんとなく薄気味悪いようにも感じさせられたのは、われながら余りにも愚かであったと、又次郎は声をあげて笑いたくなった。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞いている中に、いつもこの人間に対して感じる馬鹿馬鹿しさは消えてしまい、一種薄気味悪い恐ろしさと、へんな腹立たしさ（直接Ｍ氏に対する怒りではない。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "島の丘の背が、赤褐色に染って、うすきみわるい光をおびはじめた。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "うすきみわるい大きなまるい頭が、まるでゴム風船をよせあつめたように見え、そしてかれらは、まるで風が障子の破れ目にあたるときに発するような奇異な声をあげて、しきりになにごとかささやきあった。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "横になればなったままで、のろのろと這い出し兼ねないぬらぬらと細く、きみわるい蒼白さに澄んでいたからである。",
              "citation": {
                "source": "香爐を盗む",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
