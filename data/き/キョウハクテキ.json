[
  {
    "uuid": "f95f3524-7d97-51eb-a325-734ae071d042",
    "entry": "脅迫的",
    "reading": {
      "primary": "きょうはくてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
      ],
