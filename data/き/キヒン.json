[
  {
    "uuid": "fd382bd6-9d7d-5e60-916c-4317d1235f3d",
    "entry": "気品",
    "reading": {
      "primary": "きひん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
