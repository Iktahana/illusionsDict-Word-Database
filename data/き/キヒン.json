      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "elegance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "芸術家の気品を感ぜずに、人間の胃腑を感ずる」「わかっています。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌る日、眼光鋭く、気品の高い老紳士が私の陋屋を訪れた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその意図は、支那の風物をイメージさせるためではなくして、或る気品の高い純粋詩感を、意識的に力強く出すためである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸附近の林の中へ這入つても、雨のやうな緑と、気品の高い青空の影とを感ずる。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく腕は立派でも、衣食に追われて画くようでは、よい絵は出来ず、第一絵に気品がなくなる。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣食足った人の道楽に画いたものは下手でも自然の気品があって尊いものだ。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかといって職業上の名の小そのとだけでは、だんだん素人の素朴な気持ちに還ろうとしている今日の彼女の気品にそぐわない。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いなせ」「いさみ」「伝法」などに共通な犯すべからざる気品・気格がなければならない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすが好男子の田島も、それこそすごいほどのキヌ子の気品に押されて、ゴミっぽく、貧弱に見える。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "りんとして、この世のものとも思えぬ気品がある。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "能の気品はそうした立脚点から生まれて来るのである。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この蛙の絵なども気品の高さ、京やそこらの商売画描きなどは足元にも及ぶものではない。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる伝法肌で気品のある役には不適当であるといわれたが、それでもあらゆる役々を引受けて、団菊左と同じ舞台に立っていた。",
              "citation": {
                "source": "源之助の一生",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪俳優嵐璃鶴の後身にて、出獄の後、団十郎の門に入りて追々に昇進し、気品ある役々を得意としたるより殿様役者として知らる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような文学こそ、新しい近代小説への道に努力せんとしている僕らのジェネレーションを刺戟するもので、よしんば僕らがもっている日本的な文学教養は志賀さんや秋声の文学の方をサルトルよりも気品高しとするにせよ、僕はやはりサルトルをみなさんにすすめたい。",
              "citation": {
                "source": "猫と杓子について",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "派手な愛嬌はなく、どこか仮面のような冷かさがあったがしかしそれがかえって凛とした気品になっていた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "上流に育ったらしい気品のある顔立ちだが、どこか濃艶な色っぽさがあり、十代に輝いたであろうこの女の新鮮な美しさが、今三十代になって再び成熟し切った美しさにしたたっているかのようであった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "花のすがたは求むところなき気品をたたえている。",
              "citation": {
                "source": "草木塔",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "シルクハットのもつ贅沢な気品を、自分の頭の上に載せて見たくてたまらなかった。",
              "citation": {
                "source": "シルクハット",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ま……どうぞ……」と澄み通った気品のある声で会釈しながら、未亡人は私の真向いに来てほの紅い両手の指を揃えた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもその長い眉と黒く澄んだ眼の気品に打たれて又伏し眼になった。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親は白い頭髪を短く角刈にして、気品があった。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れたばかりの赤ん坊の足の裏と同じやうにやはらかくて綺麗なのに違ひない、と思へば、これといふ目立つた粉飾一つも施してゐない乙姫のからだが、いよいよ真の気品を有してゐるものの如く、奥ゆかしく思はれて来た。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「筆蹟にも気品があります。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま見ると、背もすらりとして気品もあるし、まるで違う人のようであった。",
              "citation": {
                "source": "故郷",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "淀野隆三の文章は、たしかに綺麗で、おっとりした気品さえ出ている。",
              "citation": {
                "source": "碧眼托鉢",
                "author": "――馬をさへ眺むる雪の朝かな――",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨はあがったが気温が高く、障子をあけ放した縁側のほうから、ときどきひんやりした微風が吹きこんで来た。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜は気温が高く、梅雨どきらしく蒸していたが、ときどきひんやりした微風が吹いて来た。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
