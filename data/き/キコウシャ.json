    "definitions": [
      {
        "index": 1,
        "gloss": "contributor (of articles)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
