        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「これ、小学校の修学旅行の記念写真だ。みんな幼くて、誰が誰だか一瞬分からなかったよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "お気に入りの記念写真をフォトフレームに入れ、リビングの一番目立つ場所に飾ることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あ！記念写真のとき、僕だけ目をつぶっちゃってる。もう一回撮り直してほしかったなあ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "結婚披露宴の最後に撮った親族との記念写真は、幸せそうな新郎新婦の笑顔が印象的だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これはね、私が大学へはいったとしの秋に、或るひとに連れられて松竹の蒲田撮影所へ遊びに行って、その時の記念写真なのです。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "記念写真帖について、大山君、瀧口君の友情こまやかなるにうたれた、私はその友情に値しない友人だ、省みて恥づかしかつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、いま、私の手許に全家族の記念写真でもあったなら、私はこの部屋の床の間に、その写真を飾って置きたいくらいである。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、二、三の悪いことをしたから、この記念写真にはいる資格がないのだ。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年後には、私も、きっと、その記念写真の一隅に立たせてもらえる。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときには、私の家の人たちは、その記念写真の右上に白い花環で囲んだ私の笑顔を写し込む。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "見てみイ、お前のお父つぁんとお母んの写真が出てるぜ」　新太郎が町内のマラソン競争で優勝した時の十八年前の記念写真が、変装写真や俳優の写真にまじって、三枚四十銭の見本の札をつけて、陳列してあったのだ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとあった変装写真や歌舞伎役者の写真がすっかり姿を消して、出征の記念写真が目立って多くなっているなかに、どうした奇蹟であろうか、二十年前のマラソン競争の記念写真が、色あせたまま、三枚一円八十銭の見本だと、値だけ高くなって陳列されているのを見ると、気が遠くなるほどなつかしかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕元の壁の額に入れられたマラソン競争の記念写真の中から、半分顔を出して、初枝がそれを覗いていた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等学校にいた頃、脚本朗読会をやってわざわざ友田恭助を東京から呼び、佐伯は女役になってしきりにへんな声を出し、友田は特徴のある鼻声をだし、終って一緒に記念写真を写したこともある。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "君枝の父親が町内のマラソン競争に優勝した時の記念写真が、三枚五十銭の見本の札をつけて、陳列してあったのだ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎は写真に凝っていて、今夜じゅうにあのマラソン競争の記念写真を引伸して持って来てやると約束したと、いそいそと下駄をはいているところへ、お渡御が済んだらしく、他吉がとぼとぼ帰ってきた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁の額に入れられたマラソン競争の記念写真の中から、半分顔を出して、初枝がそれを覗いていた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和七年三月、渋柿）曙町より（八）　二女の女学校卒業記念写真帳と、三女のそれとを較べて見ていると、甲の女学校の生徒の顔には、おのずから共通なあるものがあり、乙の女学校には、また乙の女学校特有のあるものがあるような気がして来る。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二人でモダン写真館へ行って記念写真を撮りますと、あそこの写真館のサロンで二人で抱き合って長い長い接吻を致しましたが、二人とも涙に濡れて、お互いの顔が見えないようになってしまいました。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡子君自慢の腕をふるつて記念写真撮影。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の写真師の撮影所で、記念写真を撮られたことも何か気持にしっくり来なかった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "この家は、外部の力で、持てなくなって、友達たちがよりあって、私のいなくなった家を片づけてくれ、私の姿をスケッチした額の下でその家解散の記念写真をとっておいてくれた。",
              "citation": {
                "source": "田端の汽車そのほか",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴーリキイの原稿、それから一九〇五年にゴーリキイが宣伝文をかいたというために検挙されたペテロパヴロフスクの要塞監獄の監房の写真、さらにトルストイやチェホフなどとあつまっている記念写真、レーニンと西洋将棋をさしている写真など興味ふかいものが並べられた。",
              "citation": {
                "source": "私の会ったゴーリキイ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隈公園といふのがあつた、そこは侯の生誕地だつた、気持のよい石碑が建てられてあつた、小松の植込もよかつた、どこからともなく花のかをり――丁字花らしいにほひがたゞようてゐた、三十年前早稲田在学中、侯の庭園で、侯等といつしよに記念写真をとつたことなども想ひ出されてしようぜんとした。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫は五十二歳、女は二十七歳で結婚」と標柱して、左角の上には、伊藤｜子さんの結婚記念写真が出ていた。",
              "citation": {
                "source": "柳原※子（白蓮）",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「桜」の結成の記念写真が時事に大きく掲載された。",
              "citation": {
                "source": "二十七歳",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞社は、どこからか、その記念写真をさがし出して来て、千二の顔だけを大きく伸ばして、写真版につくりあげたのである。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳田、戸田君等一同来、低温室と天覧室とで記念写真をとる。",
              "citation": {
                "source": "雪今昔物語",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学時代の海浜生活の旧い記念写真を眺めながら、色々の思ひ出に耽つて見たが、魚刺を持つて魚を追ひ廻すやうなことはもう二度とは出来さうもない。",
              "citation": {
                "source": "真夏の日本海",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "記念写真をとった時に、湯川さんは「日本へ帰ったら、これはラビ教授の家だとことわっておいて下さい。",
              "citation": {
                "source": "湯川秀樹さんのこと",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国だったら、例えばＣ・Ｔ・Ｒ・ウィルソン先生のように、貰ったノーベル賞金で、剣橋の郊外、美しい緑の土地に、自分の趣味に合った家を作り、応接間兼書斎に、受賞式の記念写真と賞状とを飾って、客毎に写真の説明をしながら、にこにこしていればよいのである。",
              "citation": {
                "source": "湯川秀樹さんのこと",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それどころか現にこの記念写真を見て、当日は公務多端のため退庁がおくれ、帰宅して着がへるひまもなく役所から直ぐ会場へかけつけたと時間ぎりぎりに参会して軍服のままであつたとばかり、その申わけまではつきり記憶してゐる鴎外先生がこの写真では白い袴を召した和服で、中央に足を組んでうつつてゐるのに驚いた。",
              "citation": {
                "source": "新詩社と石川啄木",
                "author": "――一つのおぼえ書き――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
