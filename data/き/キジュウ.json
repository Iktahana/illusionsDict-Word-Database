    "definitions": [
      {
        "index": 1,
        "gloss": "machine gun",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "文化的な仕事しかしていない東宝という映画製作所の闘争で、数千の武装警官と機銃をのせた甲虫が登場した光景は、フィルムにもおさめられた。",
              "citation": {
                "source": "新しい潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "機銃を構えて猫背の肥満漢が茶色の大きな眼鏡をかけて、人をばかにしたような顔で、にこついていた。",
              "citation": {
                "source": "烏啼天駆シリーズ・４　暗号の役割",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうした……」　言葉半ばに、探偵の瞼は重くなり、抱えていた機銃をごとんと足許へ取落とした。",
              "citation": {
                "source": "烏啼天駆シリーズ・４　暗号の役割",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "が続いてその機銃の上へ、彼の身体が転がった。",
              "citation": {
                "source": "烏啼天駆シリーズ・４　暗号の役割",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その博士は腕に機銃に似たような物をかかえていた。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "服はきれいではないが、小わきにりっぱな機銃みたいなものを抱えている。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、わしは今、抵抗するつもりはない」　頭に繃帯を巻いた方が、こんどは機銃みたいなものを抱えた方にたいし、金属Ｑよばわりをするのだった。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにか用ですか」「そのニセモノのそばへ寄って、頭に巻いている繃帯をぜんぶほどいてくれたまえ」　と、機銃みたいなものを抱えている博士がいった。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "がもうひとりの博士が、機銃みたいなものを、いっそうそばへ近づけたので、顔色をさっと青くすると、おとなしくなった。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これでいいですか、針目博士」　すると機銃みたいなものを、なおもしっかり抱えている針目博士が、「それでよろしい。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "金属Ｑという奴は――」　と、博士が蜂矢探偵の質問に答えはじめたとき、機銃のような形をした人工細胞破壊銃をかまえた博士に、ちょっと隙ができた。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あっ、撃った」「えっ」「人造人間の腕に仕掛けてある機銃が、一せいにこっちに向いて、撃ちだしたぞ」　だだだン、だだだン、だだだン。",
              "citation": {
                "source": "人造人間の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてステッキを叩いていうには、「これが買って来た軽機銃だよ。",
              "citation": {
                "source": "暗号音盤事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "白木は窓のところに立ち、カーテンの蔭から、例のステッキに似せた軽機銃の銃口を窓外にさし向けたまま、石のように硬くなっていた。",
              "citation": {
                "source": "暗号音盤事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、こんどは白木がひらりと身を翻して床の上に腹匐いになると、例の機銃を肩にあてて遂に銃声はげしく撃ちだした。",
              "citation": {
                "source": "暗号音盤事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "機銃と毒｜瓦斯弾をもった監察隊員が、テレビジョンの送像器の前を、うろうろしています。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵機は、爆弾の外に、機銃をよくつかひますから。",
              "citation": {
                "source": "鵠が音",
                "author": "島の消息",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからは、機銃を実直ぐに据ゑたまゝ、後ろ十米ぐらゐの距離を保つて追つかけたんです。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実はツマで、文章のみの感が多く、ダヽヽヽといふ機銃の音などの描写のみに入念で、事実を伝へるに先立つて先づ感傷を押売りにする。",
              "citation": {
                "source": "文章のカラダマ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がつくと、私が無意識に掴まつてゐたのは、物々しい機銃の脚であつた。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が如何やうに胸のうちに敵を愛してゐたところで、向ふのトーチカの先様に通じる由はないのだから、どつちの方角から迫撃砲だの機銃だの重砲だの乃至は飛行機の爆弾だの、何が来て、いつ成仏するか分らない。",
              "citation": {
                "source": "わが戦争に対処せる工夫の数々",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯今日は裏の防空壕の上に、庭の敷石（実は小石をセメントで固めたもの）をずらりと敷き、敵機の機銃弾に対し、いささか強き壁とした。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばたばたと、ヘリコプターをかこんだ五六名の腕ぷしの強そうな男たちは、ピストルや軽機銃をかまえてヘリコプターの搭乗者へ警戒の目を光らせる。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "機銃弾は発見されたが、血だまりは雨に洗われたためか、はっきりしなかった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘリコプターから機銃掃射が始まったので、すぐ柿の木へかけあがったわけである。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さいわい、三人とも怪我がなかったからよかったようなものの、もうしばらく、機銃掃射をつづけられたら、どんなことになっていたのかわからないのだ。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大団円　やがて、機銃のうなりがピッタリやむと、ヘリコプターはヘクザ館の上空に停止したらしく、ブーンブーンといううなり声が、同じ方向から落ちてくる。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
