  {
    "uuid": "c3ec89aa-259c-533d-ba81-af682fc67bb8",
    "entry": "巨口",
    "reading": {
      "primary": "きょこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
