      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "returning to Brazil",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "日本での三年に及ぶ農業研修を終え、彼は来週ようやくサンパウロへ帰伯する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祖母の代にブラジルへ渡った親戚が、二十年ぶりの里帰りを済ませて帰伯の途についた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ブラジルの眩しい太陽が恋しいよ」と笑いながら、彼は手際よく帰伯の準備を進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "帰伯する友人を見送るため、空港には日系人コミュニティの仲間たちが大勢集まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "頭はどうにか逆まにして染めるのでしたが、顔を染めるときはくちばしを水の中に入れるのでしたから、どの鳥もよっぽど苦しいやうでした。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と人力ひきはくびをかしげました。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と人力ひきはくびを起して反対側へかしげました。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときはくちょうたちは、まっしぐらに、まるで、さかさになって落ちくだるいきおいでおりて行きました。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時｜姉婿花忠茂が密に遣つた手紙に、「御やしき中忍びにて御ありきはくるしからぬ儀と存じ候」と云つて、丁寧に謹慎を勧めてゐる。",
              "citation": {
                "source": "椙原品",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "みどりもふかきはくようの……ほととぎすの歌だ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕上げた上でないと分らないが、清盛の無形のきはくが、僧兵たちの武力を、圧倒するように、演出したつもりである。",
              "citation": {
                "source": "映画『新・平家物語』",
                "author": "溝口健二",
                "note": "青空文庫"
              }
            },
            {
              "text": "さけび声を立てて、わたしたちを興奮させてはならないと言つけられたので、かれらはだまっていたが、この顔つきはくちびるの代わりにものを言っていた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人の驚きはくどくどしく説くの要はあるまい。",
              "citation": {
                "source": "探偵小説アルセーヌ・ルパン",
                "author": "EDITH AU COU DE CYGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
