        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "汝、その、胸を開けて、出来立ての乳首を見せろ、という難題だって、往生しねえじゃならねえわ。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち少し気がおかしくなり、彼女がこの家へ来立てに飼いつけて二三年で姿を見失った赤砂糖色の小猫のことを頻りに言い出しました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "搗てて加えて渠らは貴族という条、マダ出来立ての成上りであった。",
              "citation": {
                "source": "四十年前",
                "author": "――新文学の曙光――",
                "note": "青空文庫"
              }
            },
            {
              "text": "………連載一回分（二千字前後）欠………堕落し立てのホヤホヤ記者の友人甲「女なら今の東京だね」記者の友人乙「どうして」甲「どうしてだって、東京の職業婦人はまだ出来立てのホヤホヤだろう。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「亭主、麦熬しでもできるかい」「はい、出来立ての熬しがございます。",
              "citation": {
                "source": "小壺狩",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜平は子供の頃から出来立ての熬しのにほひを嗅ぐのが何よりも好きでした。",
              "citation": {
                "source": "小壺狩",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大浦の天主堂を見た眼では、明るく出来立てで大きく、どこかに東本願寺というような感がしなくもない。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来立ての信号ですから使い古されていないで愉快です。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "へへん、出来立ては、喧嘩のあとで環が鳴りって、とかく、痴話喧嘩と申すものは、仲がよいと、始まりやす。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「門」をカナドと訓んだのは、「金門にし人の来立てば」（巻九・一七三九）等の例に拠ったので、「金門」で単に「門」という意味に使っている。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "俄か紳士風の出来立ての町の方が私にはよつぽど似合ふわ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そっと取り出して顕微鏡で覗いて見ると、この出来立ての雪は天然の雪よりも一層の見事さである。",
              "citation": {
                "source": "雪を作る話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに精選した原料を用いてあっても、蒸し返しや造り直しでは味が死んでしまっていて、出来立ての品とは較べものにならぬ。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして一方は世界史的に承認された宗教であるに反して、他方はまだ出来立ての成り上り宗教に過ぎないから、というだけでもない。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来立てのほやほやだ」　彼は顔色を変えて鉄のように青くなり目を※って言った。",
              "citation": {
                "source": "狂人日記",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは産褥の枕辺に坐って、出来立ての人間の子をしげしげ覗いた。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、セリフの出来立てのを、而も二枚三枚と長いのを、それ覚えろと、すぐやられるのは困る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "と書きたてるほど大げさなことでもないのに、それをそれほど有名にしたのは、まつたく、その男の――つまり、その歴史の時間での先生である溝口文学士の性格によるのでした。",
              "citation": {
                "source": "ある男の死",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、早くしろ、早く」　と急きたてる。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右から憲兵が腕をとって引きたてゝていた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右の腕は、憲兵によって引きたてられてさきに行っている。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の野路をガタ馬車が走る、野は菜の花が咲き亂れて居る、フワリ／＼と生温い風が吹ゐて花の香が狹い窓から人の面を掠める、此時御者が陽氣な調子で喇叭を吹きたてる。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "十　隨分長く待たされたと思つたが實際は十｜分ぐらゐで熱海からの人車が威勢能く喇叭を吹きたてゝ下つて來たので直ぐ入れちがつて我々は出立した。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「源ちゃんにあげて下さいな、今夜焼きたてが食べさせたいことねエ、そら熱いですよ。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」頸が落ちると群集はわめきたてた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "列すぎてまた風ふきてぬかり水、　　白き西日にさゞめきたてり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいにはそれを鎮める姉の声が高くなって来て、勝子もあたりかまわず泣きたてた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤え赤え煙こあ、もくらもくらと蛇体みたいに天さのぼっての、ふくれた、ゆららと流れた、のっそらと大浪うった、ぐるっぐるっと渦まえた、間もなくし、火の手あ、ののののと荒けなくなり、地ひびきたてたて山ばのぼり始めたずおん。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と声を出して叫んで、あわてて外套の襟を掻きたてるかも知れない。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まわりの山で、せみは鳴きたてています。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
