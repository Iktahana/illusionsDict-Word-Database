        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ええっ！明日から一週間の海外出張？ 急に言われてもパスポートの期限が切れてるよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ねえ、今日の夜、ご飯行かない？」「そんな、急に言われても今日は先約があるから無理だよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今すぐこの中から一番を決めてくださいと言われても、どれも良くて急には選べません」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「はあ？ 来月結婚してくれって……。いくらなんでも急に言われても心の準備ができてないわ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "……そうは思っても、急に言われても、私には、どうにも出来ない――誠　だから、あんたの手でそれをしろと言ってるんじゃない。",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
