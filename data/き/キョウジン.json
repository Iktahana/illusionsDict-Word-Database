[
  {
    "uuid": "7bbe1c4c-c7d8-539e-b597-a782777a86fd",
    "entry": "強靭",
    "reading": {
      "primary": "きょうじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
