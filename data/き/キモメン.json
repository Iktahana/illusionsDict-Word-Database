    "definitions": [
      {
        "index": 1,
        "gloss": "repulsive man",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あいつ、性格は良いんだけど、自称キモメンとか言って卑屈なのが損してるよね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ネット掲示板で『キモメンが勇気を出して婚活パーティーに行った結果』というスレを見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「俺みたいなキモメンに優しくしてくれるなんて、彼女はきっと天使に違いない！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「キモメンだからモテないって決めつける前に、少しは身だしなみに気を使えばいいのに。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
