          "standard": [
            {
              "text": "警察は、凶悪犯人の逮捕に全力を尽くした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その凶悪犯人は、なぜこのような行為に及んだのだろうか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "凶悪犯人の供述により、事件の全貌が明らかになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「ああその……つまり山ノ井なる地球人は、貴重なる多数の生命をうばった、にくむべき凶悪犯人である。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "空バケツを抛り出すやいなや、ぼくは階段を逃げ降り、凶悪犯人のように、下駄を突ッかけて、戸外へ飛び出してしまったのである。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            }
          ]
        }
