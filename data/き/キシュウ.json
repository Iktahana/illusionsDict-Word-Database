    "entry": "季秋",
    "reading": {
      "primary": "きしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "end of autumn",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "進潮、退潮、潮よく動いて海長へに清く、春季秋季、よく移つて年永く豐ならんである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十一年寅季秋の奉獻に係るのである。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "進潮退潮、潮よく動いて海｜長しえに清く、春季秋季、季よく移って年永く豊である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "また月令季秋雀大水に入って蛤となり孟冬雉大水に入って蜃となる、この蜃は蛤の大きなものだ、欧州中古｜石に化すと言うごとく蛤類の肉が鳥形にやや似居るから生じた迷説だが、邦俗専ら蜃をこの第二義に解し蛤が夢を見るような画を蜃気楼すなわち竜宮と見るが普通だ。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "表紙には生田氏中興池田氏過去帖慶応紀元季秋の十七字が四行に書してある。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "元禄八年歳次乙亥季秋吉旦。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天保十五甲辰季秋十四日、与諸子同遊中川七首」の詩が詩存中にある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治三年庚午季秋東京築地中通り　牛馬會社",
              "citation": {
                "source": "肉食之説",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもしも意地悪きしゅうとのごとく冷い眼を持ちつづけることさえできるならば、演出者は安心して俳優に惚れこむべきである。",
              "citation": {
                "source": "演技指導論草案",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            }
          ]
        }
