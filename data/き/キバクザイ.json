          "literary": [
            {
              "text": "ダイナブックが起爆剤となって、各社はいっせいに小型マシンの開発に血道を上げた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "散らかり放題散らかった部屋で西がいじくり回していたのは、地殻変動の起爆剤だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "普及の起爆剤となった新しい表示形式では、自分のページからリンクと呼ばれる連携の絆を、他人のページに張れる。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
