[
  {
    "uuid": "e4d7d720-82b8-55b9-a1c0-f5325cf00aa4",
    "entry": "機械化",
    "reading": {
      "primary": "きかいか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
