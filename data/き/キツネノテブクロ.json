        "examples": {
          "standard": [
            {
              "text": "薬草園の奥で、紫色の美しいベル形の花を咲かせた狐の手袋を見つけたが、毒性があると聞いて触らなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "狐の手袋から抽出される成分は、古くから心臓病の薬の重要な原料としても利用されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この山間部では、初夏になると野生の狐の手袋が群生している場所があり、鮮やかな彩りを見せる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "』『それぢや、此の辺できつねのてぶくろと云ふのでせう。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "『花が手袋の指に似てゐるから、きつねのてぶくろと云ふのです。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
