          "literary": [
            {
              "text": "四　ある日、ブロンクス区探偵局の主任プライスがヘララ事件に就て、部下の探偵たちと、鳩首協議していると、捜査に出ていた一人の部下が、あわただしく駈け込んで来た。",
              "citation": {
                "source": "恐ろしき贈物",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダムダム珍は、例の巣窟に党員中の智恵者を集めて、鳩首協議を重ねていた。",
              "citation": {
                "source": "獏鸚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、誰が号令したのだろう」　係官は鳩首協議した。",
              "citation": {
                "source": "人造人間事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
