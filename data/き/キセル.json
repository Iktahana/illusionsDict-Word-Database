[
  {
    "uuid": "e3f1f1f8-349a-5372-b41e-845bf7b42be1",
    "entry": "煙管",
    "reading": {
      "primary": "キセル",
      "alternatives": [
        "きせる"
      ],
      "is_heteronym": false
    },
    "grammar": {
