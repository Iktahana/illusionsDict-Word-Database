    "definitions": [
      {
        "index": 1,
        "gloss": "to be unable to accomplish something because one has chosen the wrong method",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
