    "definitions": [
      {
        "index": 1,
        "gloss": "impregnable castle (walls)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
