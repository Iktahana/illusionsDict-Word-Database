[
  {
    "uuid": "3e8d0f8c-31fb-5f61-af16-21e8b11584fb",
    "entry": "金貨",
    "reading": {
      "primary": "きんか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
