    "definitions": [
      {
        "index": 1,
        "gloss": "raspberry (any plant of genus Rubus, esp. Rubus palmatus var. coptophyllus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "馬肉、羊肉、木苺、菱の実｜等を喰い、馬乳や馬乳酒を嗜む。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬肉、羊肉、木苺、菱の實等を喰ひ、馬乳や馬乳酒を嗜む。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "椿のほかにいまこの森で目につく花は木苺である。",
              "citation": {
                "source": "庭さきの森の春",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その深い木立の下草に諸所｜木苺の實がまつ黄に熟れてゐた。",
              "citation": {
                "source": "梅雨紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "芒や木苺が掩ひかぶさつた間に僅に身を窄めて登るだけの隙間がある。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "段々行くと木苺の刺が引つ掛る。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "木苺を採つて食つた。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "木苺といつても六尺もあるのだから手を延して折り曲げねばならぬ。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "松原で咲く花のうち、最も早く咲いた木苺の花は既に散つて、こまかな毛を帶びたその青い實が見えて來た。",
              "citation": {
                "source": "家のめぐり",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲れると彼は腰を降して、軽くゆるがせながら腕を伸して桑の実をつまんだり木苺を拾つたりした。",
              "citation": {
                "source": "籔のほとり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "風は木々の葉なみをそよがせ、時おり木苺の長い枝を、ジナイーダの頭上で揺すっていた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お家の外を歩き廻つても、石垣のところには黄色い木苺の實が生つて居るし、竹籔のかげの高い榎木の下には、香ばしい小さな實が落ちて居ました。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人うち連れて近郊散策、新緑がうつくしい、水音がうれしい、木苺がうまかつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、祖母さんのアクリーナが娘のワルワーラと庭へ出て木苺をあつめていると、やすやすと隣から塀をのり越えてたくましい立派なマクシムが、髪を皮紐でしばった仕事姿のまま庭へはいって来た。",
              "citation": {
                "source": "マクシム・ゴーリキイの人及び芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんもりと繁った樹の間には、虎杖や木苺や山独活が今をさかりと生い立っていた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして路の傍きを見ると路に沿って山吹や木苺が叢生していた。",
              "citation": {
                "source": "遠野へ",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の祖父は一面は酒客でデカダン気味のところのあつた人だが、孫の私なども可愛がつてくれた、木苺の熟す時分になると、七歳ぐらゐになる私を連れて、山の谿流に沿うて上下し、木苺を籠に丹念に採つて、それを私にも食べさせてくれたのをおぼえて居る。",
              "citation": {
                "source": "孫",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼顔、木苺、百合、蘭、……駒鳥が葉蔭へ巣をかけている。",
              "citation": {
                "source": "畳まれた町",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の雑木山へは、近所の子供といつしよにつれだつて、木苺つみや、栗拾に、よくあそびに行きましたが、八の字山は、高い山なので、まだ登つたことがありませんでした。",
              "citation": {
                "source": "八の字山",
                "author": "土田耕平",
                "note": "青空文庫"
              }
            },
            {
              "text": "さま／″＼なる果実こと／″＼く熟し木苺の実｜摘尽されて花園今はあれにけり。",
              "citation": {
                "source": "珊瑚集",
                "author": "仏蘭西近代抒情詩選",
                "note": "青空文庫"
              }
            },
            {
              "text": "この下りではボウダラの棘やイバラや木苺の刺で大に苦しめられた。",
              "citation": {
                "source": "初旅の大菩薩連嶺",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の野に木苺をもとめ、秋の山に木通や葡萄の蔓をたずねて、淡い淡い甘味に満足しているのである。",
              "citation": {
                "source": "白峰の麓",
                "author": "大下藤次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は夜中になるときまって咳が出たので、彼女は彼に木苺の汁や菩提樹の花の絞り汁を飲ませたり、オーデコロンをすり込んでやったり、自分のふかふかしたショールでくるんでやったりした。",
              "citation": {
                "source": "可愛い女",
                "author": "DUSHECHKA",
                "note": "青空文庫"
              }
            },
            {
              "text": "之が石塔尾根に登って行く路であって、登り囗は夫とも分らないように倒木が横たわったり、木苺が茂ったりしているが、少し上ると闊葉樹の大森林の中に判然と路の形がつけられている。",
              "citation": {
                "source": "笛吹川の上流（東沢と西沢）",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此辺までは大木が茂って下草は余り生えていなかったが、此処から頭の上が透いて薊や木苺が所嫌わず生えているので、手足がチクチク刺される。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう二十八町下れば麓へ出られるのだ、急げ急げと独言して、薊、車前草、木苺などの繁った道を、沢について右に左に五、六回水を渉りながら、飛ぶように駆け下りた。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "刺の生えた木苺が邪魔で仕方がない、地面も凹凸があって歩き悪い、水の流れた跡は幾筋もあるがどれも新らしいものではなかった。",
              "citation": {
                "source": "釜沢行",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の方が楽で、松本君と私とは、雑木に交って木苺、バラ、棒ダラなど、刺のある灌木の叢生している中を、苦しみながら押し分け登って、漸く大きな露岩の上に出ると、田部君は既に腰を下して私等の来るのを待っていた。",
              "citation": {
                "source": "春の大方山",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるもあるも四、五間の間は透間もなきいちごの茂りで、しかも猿が馬場で見たような瘠いちごではなかった。",
              "citation": {
                "source": "くだもの",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、ソーンフィールドから一｜哩の、夏は野薔薇に、秋は胡桃やきいちごに名高い、そして今も猶野薔薇と山櫨は少しばかりの珊瑚色の實の殘つてゐる小徑にゐた。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
