        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "喉の痛みと咳がひどいので受診したところ、急性気管支炎との診断を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あーあ、気管支炎のせいで楽しみにしていた今夜のカラオケは欠席だよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "埃っぽい物置を掃除していたら、持病の気管支炎が悪化して熱が出てきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "抗生物質を服用し始めてから、気管支炎による激しい咳もようやく落ち着いてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "都をば泥海となしわが子等に気管支炎を送る秋雨　今日の東京も滅茶滅茶にこはれてしまつたが、明治末年の雨の日の東京の道路と来たらお話にもなにもあつたものではなかつた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬はインフルエンザとなり、喘息となり、気管支炎となり、肺炎となりて、親と子と八人を責め苛む。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしは日本の気候が合わなくて、よく気管支炎をやりましたが、今でもそんなことがございますのでしょうか？",
              "citation": {
                "source": "葡萄蔓の束",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に、真面目な調子で――気管支炎なの、病気は……。",
              "citation": {
                "source": "モノロオグ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると気管支炎とある。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "気管支炎と云えば肺病の下地である。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "感冒をこじらせ、気管支炎喘息をおこしかけているくらいのところで、手早く処置すれば四、五日で快癒する程度のものであった。",
              "citation": {
                "source": "新西遊記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中で悪い気管支炎にかかったのである。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "喘息やカタルや気管支炎がついてまわった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが自分の気管支炎にさわるかどうかも考えなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その報知によれば、シュルツは気管支炎が再発して、それが肺炎に変化したのであった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとした風邪も気管支炎に変ずる恐れがあった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "流行感冒、気管支炎、肺炎などが彼に襲いかかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は毎冬たいてい同じ時期にそれにかかって、古い気管支炎を再発するのだった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月、痼疾の気管支炎のため慶応病院へＩ・Ｐ・Ｐ・Ｂの治療に日々通う。",
              "citation": {
                "source": "年譜",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "慢性気管支炎にはブタの肺が注目される。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどい気管支炎の患者では息が気管支を入ったり出たりするときに起きる口笛のような音を遠くからでも聴くことができる。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
