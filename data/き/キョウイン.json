[
  {
    "uuid": "ca533a24-944c-5f5c-906d-86624335bff1",
    "entry": "凶音",
    "reading": {
      "primary": "きょういん",
      "alternatives": [
        "きょうおん"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bad news (esp. of a death)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "深夜に鳴り響いたあの電話のベルが、一族にとっての凶音となってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "恩師の訃報という凶音に接し、彼はしばらくの間、言葉を失って立ち尽くした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「戦地からの凶音を恐れ、当時の村人たちは郵便配達員の姿を見るたびに身を硬くしたそうです。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "穏やかな午後の静寂を破るように届いたその凶音は、一家の運命を根底から変えてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "我は冥々の裡に、一の凶音の來り迫るを覺えながら、強ひて口を開きて、ペリコの政客たる生活の其詩に及ぼしゝ影響を説き出しつ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝忍藻がいなくなッた心配の矢先へこの凶音が伝わッたのにはさすが心を乱されてしまッた。",
              "citation": {
                "source": "武蔵野",
                "author": "山田美妙",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
