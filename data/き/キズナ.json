[
  {
    "uuid": "7703a6bf-6a82-54dc-bc32-3e9e22bf4289",
    "entry": "絆",
    "reading": {
      "primary": "きずな",
      "alternatives": [
        "きづな"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bond (between people)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "家族との絆は何よりも大切で、どんな困難も乗り越える力になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長年の友情で培われた二人の間には、強い絆が存在する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "災害時、地域の人々の間に助け合いの絆が生まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「仲間との絆を信じて、最後まで諦めずに戦おう！」とキャプテンは叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その一つに繻絆一枚で腰掛けて老人の読んでゐた新聞に、三十何年とか撒水車を挽いてゐるといふ男の笑つて汗を拭いてゐる写真が通りがかりに見えた。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "中の字を星形にした徽章のついた制帽を冠って、紺のめくらじまの袴をはき脚絆に草鞋がけ、それに久留米絣の綿入羽織という出で立ちであったと思う。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "剣道場の入口から、時々水を飲みに、剣道用の繻絆姿で現れるのは生徒だが、それは選手だから暑中休暇も帰省しないで道場にゐるといふわけである。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "繻絆の前をハダけて、靴をツツかけて水を飲みにゆく。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速、焚火にかかって、徒渉に濡れた脚絆を乾すやら、大鍋を吊して湯を沸かしたりする。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい時から苦学をしてやっと電気学校を卒業はしたが、目的のある柚木は、体を縛られる勤人になるのは避けて、ほとんど日傭取り同様の臨時雇いになり、市中の電気器具店廻りをしていたが、ふと蒔田が同郷の中学の先輩で、その上世話好きの男なのに絆され、しばらくその店務を手伝うことになって住み込んだ。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "関のさびれた町に入って主人は作楽井が昨年話して呉れた古老を尋ね、話を聞きながらそこに持ち合っている伊勢詣りの浅黄の脚絆や道中差しなど私に写生させた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まん中の大きな釜からは湯気が盛んにたち、農夫たちはもう食事もすんで、脚絆を巻いたり藁沓をはいたり、はたらきに出る支度をしていました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」農夫長は隣りで脚絆を巻いている顔のまっ赤な農夫を指しました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその人は、すぐに河をわたるでもなく、いかにもわらじや脚絆の汚なくなったのを、そのまま洗うというふうに、もう何べんも行ったり来たりするもんだから、ぼくらはいよいよ、気持ちが悪くなってきた。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから硬い板を入れた袴をはき、脚絆や草鞋をきりっとむすんで、種山剣舞連と大きく書いた沢山の提灯に囲まれて、みんなと町へ踊りに行ったのだ。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "津田君といえども伝習の羈絆を脱却するのは困難である。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのため平常克服してゐたところの性慾が、意志の覊絆を離れて奔放に暴れ※る。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）「おい親友、鉄カブトかぶれよ、危ねえぞ」「何言ってやんでえ　可笑しくッて鉄カブトが冠れますかッてンだ」「鉄砲の弾丸は頭ばかり当たるッて訳のもんでもあるめえ、手に当る事もありゃ足にも当らア鉄のテッ甲脚絆でもはめてきアがれ」○帽子の中へ写真を入れて置く兵隊。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆や鉛筆でもつて抱擁し、愛撫し、手ばなさぬやうにする、さういふ愛の絆によつてのみ、それ等のデッサンや繪は價値があるやうに思へる、とあなたは仰言られて居ましたけれど。",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が一緒に日本へ行きたいと訴えるのだが、船人のたくましい腕の絆も別離が切って落す。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　厚化粧した彼女の覊絆の下で男が云った。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻脚絆を巻くのがおそく、整列におくれて、たび／＼一緒に聯隊本部一週の早駈けをやらされたものだ。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長火鉢に寄っかかッて胸算用に余念もなかった主人が驚いてこちらを向く暇もなく、広い土間を三歩ばかりに大股に歩いて、主人の鼻先に突ったッた男は年ごろ三十にはまだ二ツ三ツ足らざるべく、洋服、脚絆、草鞋の旅装で鳥打ち帽をかぶり、右の手に蝙蝠傘を携え、左に小さな革包を持ってそれをわきに抱いていた。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　と答えて客はそこに腰を掛け脚絆の緒を解きにかかった。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『僕は朝早く弟と共に草鞋脚絆で元気よく熊本を出発った。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡り鳥のように四国の脊梁山脈を越えて南海の町々村々をおとずれて来る一隊の青年行商人は、みんな白がすりの着物の尻を端折った脚絆草鞋ばきのかいがいしい姿をしていた。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反してもっとまじめで真剣なだけにいちばん罪の深い人間的な宣伝の場合と思われるのは、避くべからざる覊絆によって結ばれた集団の内部で、暗黙のうちに行なわれる、朋党の争いである。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで本所へ渡る船を待っていると、一と足おくれてこの渡へ来たのは菅笠をかぶった四十恰好の色の黒い男で、手甲脚絆の草鞋がけ、頸に小さい箱をかけていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを聽いてからお道には暗い陰が絆はつて離れなかつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "支配人の内川、職長の小山、大津、守田、会計の岩井、みな、コセ／＼した内地に愛想をつかして、覊絆のない奔放な土地にあこがれ、朝鮮、満洲へ足を踏み出した者ばかりだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　兵士達は、靴もぬがず、軍服もぬがず巻脚絆も解かず、たゞ、背嚢の枕に頭を落すと、そのまゝ深淵に引きずりこまれるように、執拗な睡眠の誘惑に打ちまかされてしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻脚絆を解いて、自分の背嚢に近づいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "沃丁を塗ったあとが化膿して、巻脚絆にしめられる袴下は、傷とすれた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つとめて八橋と遠ざかりたいと念じている矢先きへ、又こんな新しい関係を結び付けて、逃げることのできない因果のきずなに、いよいよ自分のからだを絞めつけられるのに堪えなかった。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "tether",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "船は岸壁にしっかりと絆で繋がれ、荒波にも耐えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子犬は細い絆で柱に繋がれていたが、すぐに外れてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼らは互いを太い絆で結びつけ、決して離れないと誓った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
    ],
