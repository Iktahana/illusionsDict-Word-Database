          "standard": [
            {
              "text": "UFO現象や超常現象などを扱う分野は、しばしば境界科学として分類される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "境界科学の研究者たちは、既存のパラダイムにとらわれない斬新な発想を重視する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "最近、境界科学の分野で、従来の説明では理解できない現象が次々と報告されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "主流科学からは異端視されがちだが、境界科学の視点から新たな発見があるかもしれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
