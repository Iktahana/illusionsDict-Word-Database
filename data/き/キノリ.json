[
  {
    "uuid": "c9ad1575-1bd3-58a5-a81a-4f96e31c5849",
    "entry": "気乗り",
    "reading": {
      "primary": "きのり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
