        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あの気の長い彼が珍しく声を荒らげるなんて、よっぽどのことがあったんだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "完成まで十年かかるプロジェクトなんて、私のような短気な人間には無理だ。気の長い人でないと務まらないよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「いつまででも待つよ」という彼の言葉に、彼女の気の長い性格がよく表れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「ええ華族様は気の長いもんだ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白雪　あんな気の長い事ばかり。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "利口なのや馬鹿なの、気の長いのや短いのなぞに依って種々雑多に千変万化しますが、いずれにしても鼻の表現に裏切られる事は免れ得ませぬ。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "果てもない広い森林と原野の間に自在に横行していたものが、ちょっとした身動きすら自由でない窮屈なこういう境遇に置かれて、そして、いくら気の長い、寿命の長い象にしても、十年以上もこうして縛られているのでは、そうそういい目つきばかりもしていられないではないかという気もした。",
              "citation": {
                "source": "解かれた象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の長いこと無類である。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "女を見飽きたり、知り飽きたりしたと臆面もなく言ふ男が多いのに私は驚いた、うつくしさの再吟味を理論でやつてから改めて女の美しさを発見しようとする気の長い男達が少くないのだ。",
              "citation": {
                "source": "小熊秀雄全集-10",
                "author": "詩集（９）流民詩集２",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな気の長い人が西洋にもあったものか、チャムバースの『ブック・オヴ・デイス』に珍譚あり。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに気の長い道中である。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さしあたりは駄菓子屋の近所に網を張って、平さんなる者の出入りを窺うのほかは無い、気の長い仕事のようであるが、まあ我慢して張り込んでくれと、半七は幸次郎に云い含めた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "菊人形の昔",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し一度も盛岡の土を踏んだことのない人で、此会話の深い／＼意味と、其誠に優美な調子とを聞き分くる事が出来るならば、恐らく其人は、大小説家若くは大探偵の資格ある人、然らずば軒の雨滴の極めて蕭やかな、懶気な、気の長い響きを百日も聞き慣れた人であらう。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "土人達の習慣によると、ヅリヤンを盗んだ者は重く罰せられるが熟れて自然に落ちたのを拾つた者は、飛んだ幸福者として羨まれるさうで、気の長い土人達は、ヅリヤンの鈴生に生つた木蔭で、朝つぱらから煙管を啣へて一日｜凝と待ち通しに待つてゐるさうだ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　笹村もお銀の気の長いのを、時とするとじれったく思うことがあったが、衰弱がどこまで嵩じて来るか、じっと見ていたいような気もした。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな気の長いことを言っていた日には、いつ立てるか解りやしないじゃないか」　お島はその晩も二階で小野田と言争った。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "……と気の長い話でありますが、こう考えるよりほかに道もありませんでした。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "門人を置いたことについて",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作は三年間も掛かったのでその気の長いことは無類で、一つの木に取りつくと、気の済むまでは何時までも取っ附いていじっているので、何処までも、突きつめて行く精力はえらいものでありました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "谷中時代の弟子のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "又私は随分気の長い方でない、何事もテキパキ早く遣ると云う風で、時としては人に笑われるような事も多い。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんの一足ちがいで、旦那様」「何処かに、爺――野良馬でも、工面つくまいか」「さあ――婆さん、松のところの馬は、走るかのう」　和田は（走らぬ馬があるか、気の長い）　と、じりじりしてきた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "小野さんは優しい、物に逆わぬ、気の長い男であった。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の長い話ですが、お弁当のサンドウイツチと編物の道具とを手提袋に入れ、畳椅子をぶら提げて、わざわざ出かけて行くお神さんなどがあります。",
              "citation": {
                "source": "ふらんすの芝居",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の長い人だから、時間が当てにならない。",
              "citation": {
                "source": "黒髪",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "悠暢な気の長い女であることはよく知っているので、そのつもりで辛抱して待っていたがしまいには辛抱しきれなくなって、いいようのない不安の思いに悩まされているうちに、高い塀に取り囲まれている静かな栽庭にそろそろ日が影って、植木の隅の方が薄暗くなり、暖かかった陽気が変ってうすら寒く肌に触るようになってきた。",
              "citation": {
                "source": "黒髪",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生はまた気の長いったらたまげる程です。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも先生も奥様も今まで同居した人で私ほど気の長い人はなかったと言っていらっしゃいます。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人の気の長いには実に閉口する」　おりから靴音の近づきて、たけ高き一少尉入り口に立ちたり。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、門の外には夜のやうに黒い馬が二匹、焦立たしげに土を蹴つて鼻孔から吐く煙のやうな水蒸気の長い流に、胸をかくしながら、立つてゐる。",
              "citation": {
                "source": "クラリモンド",
                "author": "LA MORTE AMOUREUSE",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸だ、不幸だと言いながら気の長いお倉の様子は、余計にお種をセカセカさせた。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞ、あの金がなくては、これからさきのながい旅ができない身の上、かわいそうだと思って、お返しなすってくださいまし」「この女めッ、だまっていりゃいい気になって、まるで人を盗っ人のようにいやあがる」「どういたしまして、けっしてそんな大それたことを申すのでは」「やかましいやいッ。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
