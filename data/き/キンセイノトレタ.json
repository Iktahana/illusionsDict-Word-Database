        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "道の土がかわいて処女の均整のとれた体重を程よくうけとめて呉れる。",
              "citation": {
                "source": "兄妹",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのお体がどんなに均整のとれた立派な恰好だか判りますわ。",
              "citation": {
                "source": "明暗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい迷惑じゃねえか」　高志のほうは、いつものように、完璧に均整のとれたノットだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "均整のとれた鋼鉄に似た枝枝の繁みが魁麗な花むらの重さを受けとめかねてゆったりと撓み、もう人人の称讃には飽き飽きしたという風情で、後継ぎのない悲しさもあきらめきった高雅な容姿だった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてどれも均整のとれた姿であった。",
              "citation": {
                "source": "ツンドラへの旅",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊り子巽妙子の、均整のとれた四肢と、なだらかな腰と、美しい乳房の膨みと、丸い頸の曲線と、小麦色の滑らかな肌とは、真に比ぶべきものも無い芸術品でした。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第二夜　匂う踊り子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ質素な二階半建て木造の町家で、地味な尖り屋根、大きな中央煙突、芸術的な彫刻を施した戸口と放射状の扇状窓、三角形の破風、均整のとれたドリア風片蓋柱をもつ、プロヴィデンスではよく見るコロニアル様式のものだった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに殆ど無限に広がる莫大な、規則的な、幾何学的に均整のとれた石材の迷宮を、またそれらが氷床の上に屹立させる崩れて穴だらけになった稜線を把握しながら。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "中肉でよく發達した、均整のとれたからだつき。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "全裸體の女が長椅子に横になつて、おかしな姿勢をしている寫眞で、一種の猥畫の類だが、女は一人だし、引きしまつた均整のとれた身體をしているために、それほど猥せつな感じはしない。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "擬似体験ゲームの世界の中ではどんな痴漢のまねごとをやらかしても許されますし、しかも現実の世界では考えられないような均整のとれた体の美人モデルがいっぱい出て来るでしょう。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミチは彼女の肉体が素晴らしく均整のとれた美しさと、類い稀れな色白であることを充分に承知して居るのだ。",
              "citation": {
                "source": "刺青",
                "author": "富田常雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その均整のとれた肉体の線は日本人には珍らしかったが、首筋から肩と胸へ流れる線と、伸びる両腕の躍動の間に、こっちを向いた女体に藤三は息が詰った。",
              "citation": {
                "source": "刺青",
                "author": "富田常雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の女に、こんな均整のとれたからだがあるのかと疑われるほどであった。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがスッキリと、均整のとれた肉体を丸はだかにされて、一匹の美しい野獣のように檻の中に入れられている。",
              "citation": {
                "source": "黒蜥蜴",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人は、均整のとれた体つきで、背も余り高くなく、年のころは三十がらみか。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
