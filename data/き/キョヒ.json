    "definitions": [
      {
        "index": 1,
        "gloss": "enormous expenditure",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
