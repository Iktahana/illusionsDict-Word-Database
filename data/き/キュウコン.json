[
  {
    "uuid": "bd2a3609-8082-5d22-b826-e16cb1fcd052",
    "entry": "求婚",
    "reading": {
      "primary": "きゅうこん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
