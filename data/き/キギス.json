        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（荷繩を投げよはや荷繩）雉子鳴くなりその雉子、　　人なき家の暁を、歩み漁りて叫ぶらし。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "萱の中からは何べんも雉子も飛んだ。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐙の雉子のもゝのまがりめ二ツ三ツに張砕けたり。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "○外濠は神田堀より入りて、右すれば神田橋一ツ橋｜雉子橋下を経て俎橋下に至り、いはゆる飯田川となりて堀留に窮まり、左すれば常磐橋その他の下に出づべし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへばよく雉子や山鳥などが、うしろから『四十雀さん、こんにちは。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「賢、」　と呼んだ、我ながら雉子のように聞えたので、呟して、もう一度、「賢君、」「は、」　と快活に返事する。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "総六親仁は、最初、この茄子の種を齎らして、背戸へこぼして行ったのは、烏に肖て翼違い、雉子のようでやや小さく、山鳥かと思うと嘴の白い、名を知らぬ、一羽の鳥であったという。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其うしろ姿は正しく猫、加之も表通りの焼芋商に飼つてある雉子猫だ。",
              "citation": {
                "source": "雨夜の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで狩猟などをも悦んでいたことであるから定基のところへ生き雉子を献じたものがあった。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "定基は、此の雉子生けながら作りて食わん、味やよき、心みん、と言い出した。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてむしらせると、雉子はばたばたとするのを、取って抑えてむしりにむしった。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "旨く味わうが為に雉子の一羽や二羽の生づくりが何であろう。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と前の床几に並べたのを、さらりと撒くと、颯と音して、揃いも揃って雉子鳩が、神代に島の湧いたように、むらむらと寄せて来るので、また一盆、もう一盆、夫人は立上って更に一盆。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一声高らかに雉子が啼くと、山は暗くなった。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雉子の雌鳥ほろりと落いて、打ちきせて、しめて、しょのしょのいとしよの、そぞろいとしゅうて、遣瀬なや。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜、菖蒲、山の雉子の花踊。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "加之、其※時は、何処から持つてくるものやら、鶏とか、雉子とか、鴨とか、珍らしい物を持つて来て、手づから料理して父と一緒に飲む。",
              "citation": {
                "source": "刑余の叔父",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "足音に驚いて、幾羽の雉子が時々藪蔭から飛び立つた。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその一方、未の刻に麹町から出た火があって、雉子橋、一つ橋、神田橋に及び、また北風になった風に煽られて、八重洲河岸、大名小路を嘗め、西丸下桜田に至って二つに別れ、一方は通町に出で、一方は愛宕下から芝浦まで往った。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "生娘の袖誰が曳いてか雉子の聲で、ケンもほろゝの無愛嬌者、其癖甘いから不思議だとさ。",
              "citation": {
                "source": "神樂坂七不思議",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち並ぶそれらの大樹の根本を塞ぐ灌木の茂みを、くぐりくぐってあちらこちらに栗鼠や白｜雉子が怪訝な顔を現わす。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲、狭霧、立ちはばかり、丹の雉子立ちはばかり、白き猪の横伏し喘ぎ、毛の荒物のことごとに道｜塞ぎ寝る水上は思ふべきかな。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "煤がふります、雉子馬に、睫毛擦る子がまろい眼に。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "開けよ、声を雉子、外の霞に。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "開けよ、聲を雉子、外の霞に。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "雀子はちゆちゆとさへづり、子を思ふ焼野の雉子けんけんと夜も高音うつ。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雉子の尾」の中のある数章「閻魔の咳」等。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼野のきぎす夜の鶴、子を思う親の情に変りはねえが、親を思う子の情は、親のねえ子ではじめてわかるものだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あああ、焼野の鶴に夜のきぎす――」　なんかと富五郎、何を思い出したのかそこらのお寺の説法にでも聞いたらしい文句を並べだしたりはいいが、どうもいうことがさかさまである。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
