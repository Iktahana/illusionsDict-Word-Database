    "definitions": [
      {
        "index": 1,
        "gloss": "with a momentary flash of light",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
