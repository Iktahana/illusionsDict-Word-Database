        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "父は甲午の生まれで、今年還暦を迎える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人は甲午の年に結婚式を挙げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "甲午の年は、新しいプロジェクトを始めるのに良い時期だと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖母が生まれたのは甲午の年だったらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "二十七年（甲午）　一八九四○二月、新富座にて「忠臣蔵」を上演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "四日、甲午、小御所東面の小庭に於て、和田新左衛門尉常盛以下の壮士等切的を射る、是弓馬の事は、思食し棄てらる可からざるの由、相州諫め申すに依りて、興行せらるる所なり、故に勝負有る可しと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五日、甲午、晴、鶴岳宮放生会、将軍家聊か御不例に依りて御出無し。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿二日、甲午、奉行人等を、関東御分の国々に下し遣はし、其国に於て、民庶の愁訴を成敗す可きの由、其沙汰有り、参訴の煩を止められんが為なり。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四日、甲午、晴、亥剋、由比浜辺焼亡す、南風烈しきの間、若宮大路数町に及ぶ、其中間の人家皆以て災す。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十七年甲午、四十八歳。",
              "citation": {
                "source": "能久親王年譜",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲午使人曰本国旧俗詳見袋中書百年以来民風大変神怪之事今則絶矣云々。",
              "citation": {
                "source": "ユタの歴史的研究",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで親族打ち寄って、度々評議を凝らした末、翌天保五年｜甲午の歳の正月中旬に、表向敵討の願をした。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は「天保五甲午六月十三暁子誕生」と云ひ、此は「天保五甲午六月十五日卒、葬于本所法恩寺内善行寺、法名夏山院日周信士、年二十三」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "五年甲午　平八郎四十二歳。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "上被には蓮華と佛像とを畫き、裏面中央に「倣尊澄法親王筆」、右邊に「保午浴佛日呈壽阿上人蓮座」と題し、背面に心經の全文を寫し、其右に「天保五年｜甲午二月廿五日佛弟子竹谷依田｜瑾薫沐書」と記してある。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "え、怖ろしいこってねえか、全く、それも甲午乱（日清戦役）のこったけにもう五十年も近うなるだ……」　不意に先達の婦がエイッチェと嚏をした。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "政和甲午（四年＝西暦一一一四）有告人殺其父。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "正暦甲午歳冬十二月……」と題して七言律一首が続けられてゐる。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "正暦甲午歳冬十二月……」と題して七言律一首が續けられてゐる。",
              "citation": {
                "source": "山越しの阿彌陀像の畫因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "正暦甲午歳冬十二月……」と題して七言律一首が続けられている。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "庚辰詔曰、現御神止大八島国所知天皇大命良麻止詔大命乎……（続紀、文武元年）（三）二月甲午朔戊申天皇幸宮東門使蘇我右大臣詔曰｜明神御宇日本倭根子天皇詔……（大化二年紀）詔曰、明神大八洲所知倭根子天皇大命良麻止宣大命乎……（宝字元年七月紀）（四）大日本根子彦国牽天皇、大日本根子彦太瓊天皇太子也。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　ものゝふの呪術夏四月甲午朔。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "正暦甲午歳冬十二月…」と題して七言律一首が續けられてゐる。",
              "citation": {
                "source": "山越しの彌陀",
                "author": "釈迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり、文政頃の酒価と酒の質について『異聞雑考』の記すところでは――味噌は甲午の夏五月より、金一両二十貫四百目になりぬ。",
              "citation": {
                "source": "酒渇記",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "前漢太初四年六月十一日癸丑　前秦太初四年六月十一日甲午南凉同　　　　　　　　庚寅　西秦同　　　　　　　　壬子　いずれも銘文の干支に合わぬ。",
              "citation": {
                "source": "石上神宮の神宝七枝刀",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "弘庵は初松平｜隠岐守の儒臣｜長野豊山について学び、後に古賀亭の『近世偉人伝』義集第三編には「天保甲午五年土浦侯聘為賓師委以学政。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」〔天保甲午五年土浦侯聘シテ賓師ト為シ委ヌルニ学政ヲ以テス〕としてある。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治二十七年甲午正月元旦に未亡人太田氏梅が没した。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "大沢さんかい、甲午堂かい？",
              "citation": {
                "source": "仁王門",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大沢も甲午堂も蒲原も、みんな私が子供の時分から知っている、村や近くの町の医者でした。",
              "citation": {
                "source": "仁王門",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「甲午堂は夜逃げをしたから、もう村にはおらん。",
              "citation": {
                "source": "仁王門",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかにね、あれは甲午（承応三年）の冬だったが、一と矢といっても腿の皮を貫いただけさ、いまはもう傷あとも残ってはいないよ。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲午の年九月九日に崩りたまひき。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
