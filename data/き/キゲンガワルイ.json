    "definitions": [
      {
        "index": 1,
        "gloss": "in a bad mood",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "昔自分に親しかったある老人は機嫌が悪いと何とも云えない変な咳払いをしては、煙管の雁首で灰吹をなぐり付けるので、灰吹の頂上がいつも不規則な日本アルプス形の凸凹を示していた。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんは、このごろ、とても機嫌が悪い。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言って、機嫌が悪い。",
              "citation": {
                "source": "一燈",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」杉野君は、機嫌が悪い。",
              "citation": {
                "source": "リイズ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お怒りなすって、まあ、飛んだ御機嫌が悪いのねえ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房は己の内にいる時の方が機嫌が悪い。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こっちの機嫌が悪いらしいので、老人は気の毒そうに黙ってしまった。",
              "citation": {
                "source": "雪女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三ちゃんが黙って遊びに行ってしまったって大変御機嫌が悪いから、早く行って大人しくあやまっていらっしゃいと言うのである。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でもお客が大変｜待あぐんで機嫌が悪い、急いで迎いに、というのです。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「始終このごろは機嫌が悪いではありませんか、無理でないかもしれない。",
              "citation": {
                "source": "源氏物語",
                "author": "朝顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御機嫌が悪いやうですね。",
              "citation": {
                "source": "歯痛",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえって美妙を尋ねる時は最中の一と折も持って行かないと御機嫌が悪いというような影口があった。",
              "citation": {
                "source": "美妙斎美妙",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "弥助は、九郎助が機嫌が悪いのを知ると、傍へ寄った。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "司法主任は、相変らず御機嫌が悪い。",
              "citation": {
                "source": "闖入者",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "家来も侍女共も主人の機嫌が悪いので、みなはらはらしていた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかでもない早引の忠三、ひどく機嫌が悪いとみえ、口小言をいいながら走り出した。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてスパイダーが渋々差出したマッチを受取ると、「今夜は莫迦に御機嫌が悪いじゃないか。",
              "citation": {
                "source": "赤い手",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが因で父っさんの機嫌が悪い。",
              "citation": {
                "source": "半七捕物帳",
                "author": "化け銀杏",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と稍御機嫌が悪い。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と少々機嫌が悪い。",
              "citation": {
                "source": "紅色ダイヤ",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "然う言っていないと、祖母の機嫌が悪い、面倒だ。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が泣く、祖母の機嫌が悪い。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は大変御機嫌が悪いんだってねえ、　どうしたの。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌を唱わなけりゃあ御機嫌が悪いんだと一人ぎめして居るんだものいやになっちゃう。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを食わないと婆さんすこぶる御機嫌が悪いのさ」「食えばどうかするのかい」「何でも厄病除のまじないだそうだ。",
              "citation": {
                "source": "琴のそら音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "六※かしい理窟抔を持ち出すと甚だ御機嫌が悪い。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆さんはまた私がそうしないと機嫌が悪いんですの。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗藤では勿論叔父の機嫌が悪い。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "またなんかごきげんがわるいですね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "けさはひどく、きげんがわるいらしい。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
