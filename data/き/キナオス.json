    "definitions": [
      {
        "index": 1,
        "gloss": "to change clothes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "体を拭き、衣服を着直すと、目もくれず、楠公碑の前へ行って並んで坐った。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "恥かしいのか、給仕人のことばもそら耳に、衣服や冠を着直すやいな、あわてて店のそとへ出て行った。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "虎の口をのがれたように、穆順は衣服を着直すとすぐ走りかけた。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　イントロダクションのところをもういちどききなおすと、ワラは、高志と慶一のほうにむきなおった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえ、歌ってみろ」　と慶一にいって、またはじめから弾きなおす。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、これを書きなおすと、『ヨコハマ、アラワシテウ、アヘンクツ』だ。",
              "citation": {
                "source": "深夜の電話",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はとても、もう英語の単語を二十、発音記号に書きなおすというような仕事を丹念にはつづけていられなくなった。",
              "citation": {
                "source": "部屋",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この偏向コイルは大変に高価であり、自作するとなると手巻きして調子を見ては、もう一度巻きなおす作業を繰り返さざるをえないという。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "――――――――――――と署長は又ちょっと口汚なく罵って、訊きなおす。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "原籍を鹿児島県、東桜島、古里、温泉場だなんて書くと、あんまり遠いので誰も信用をしてくれないのです、だから東京に原籍を書きなおすと、非常に肩が軽くて、説明もいらない。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "原籍を鹿児島県、東桜島、古里、温泉場だなんて書くと、あんまり遠いので誰も信用してくれないんです、だから東京に原籍を書きなおすと、非常に肩が軽るくて、説明も入らない。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "続きなおすのをすっかり仕てしまいたいと思ったが出来そうにもない。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貧しき人々の群」第二まで書きなおす。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一日　終りの方をかきなおすのが出来て箱根葦の湯紀伊国屋へ御送りする。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "単行本にするのをなおし「渋谷家」にかかる、とうてい真赤でしようがないので書きなおすことにした。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「渋谷家」を書きなおすかと思うと、うんざりだが、仕方がない。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一の後の方を書きなおす。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――と聞きなおすのだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　まだ聞き取れないので、聞きなおすと、きまりの悪るそうな顔をして口をつぐんでしまったが、しばらくすると、「盛岡の方です。",
              "citation": {
                "source": "北国の人",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかり書きなおす。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "厄介なことではあるが、とにかく大金庫が戻ってきたことは何よりありがたいというので、課員総出で力をあわせて、その大金庫をようやくまっすぐにおきなおすことができた。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "傷の縫い合わせをする、三角巾を巻きなおす、沃丁を塗る、水をのませる、布団や筵を見つけてきてかぶせる、副木を当てる。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、猟から帰って、彼は言う――「あれだけの道を、また歩きなおすのはいやだなあ」　脂ぶとりの女を見て、あの女は、うまく骨をかくしていると言う。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、この再版では当然この個所を書きなおすべきであるが、しかし『論語之研究』の序文で見ると、わたくしのはなはだ不備な紹介や議論が博士のこの公刊を促進することに幾分役立ったように思われ、その点において思いがけぬ効果を収めたことになる。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正六位は年二期を合わせて三十口、これら全部を賦役令の比例によって布にひきなおすと、布三十九端に当たる。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那文で書かれた日本の古典やいろいろの著作はそれを日本文に書きなおすことによって、いくらでも世間に弘めることができるのである。",
              "citation": {
                "source": "〔『支那思想と日本』初版〕まえがき",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして学問に関しなかばモーロクしかけた師よりもはるかに熱心な弟子にむかって質問の内容をききなおすのである。",
              "citation": {
                "source": "オフ・ア・ラ・コック・ファンタスティーク",
                "author": "――空想半熟卵――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、考えている風だったが、ほっそりした形のいい腕をテーブルの上にすこし深く置きなおすようにして、リン博士は伸子にきいた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "イラン語の詩の古臭い翻訳を書きなおすか、下書きを敷いて、墨汁の罐に筆を出し入れしつつ、更に一通の履歴書を書いているだろうことが分っていた。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、自分の矛盾に自分で憫笑しながらも、伸子は、そうやってやって行くうちには、佃とて木の根っこではない、いつかは少しずつ変るまいものでもないと、希望を抱きなおすのであった。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
