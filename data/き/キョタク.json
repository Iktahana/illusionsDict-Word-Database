[
  {
    "uuid": "08dbaa1b-498f-50d4-8cf5-d0f9aaedf822",
    "entry": "居宅",
    "reading": {
      "primary": "きょたく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "residence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この住所は、本人の確実な居宅であると確認された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "故郷に建てた居宅は、広々としていて、両親も喜んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "都市部では珍しい、緑に囲まれた静かな居宅が理想だね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "余の居宅の近所にも犬は大分居る、図書館員の様に騒ぐものも出て来るに相違ない。",
              "citation": {
                "source": "入社の辞",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一、居宅に望なし。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一、わが居宅は六畳、四畳半、三畳の三部屋なり。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "居宅に望なき人の心境とはおのずから万里の距離あり。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで志山林に在り、居宅を営まず、などと云われれば、大層好いようだが、実は為うこと無しの借家住いで、長い間の朝夕を上東門の人の家に暮していた。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論立派な邸宅というのでは無かったに疑い無いが、流石に自分が造り得たのだから、其居宅の記を作って居る、それが今存している池亭記である。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "邦原君は東京の山の手に住んでいて、大正十二年の震災に居宅と家財全部を焼かれたのであるが、家に伝わっていた古い兜が不思議に唯ひとつ助かった。",
              "citation": {
                "source": "兜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるときなど一発の銃弾がスタンガスンの居宅の窓に撃ち込まれ、本人から一フィートとないところの壁にめり込んだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと解放されたときには、ドレッバーの居宅ももぬけの殻、気づいたときには秘書ともども欧州へ出発していた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男が逮捕された部屋は、どうやらシャーロック・ホームズ氏なる人物の居宅で、氏も素人並みに捜査方面で才の片鱗を見せたらしく、ゆくゆくは両氏の指導の賜物として程々の技能は身につけられることを期待したい。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "この金額は金貨にて払ひ渡すことゝし、使を以て居宅に送り届けたりと云ふ。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "本人は前記の日正午頃四千フランの金貨を二袋に入れ、それを持ちて、レスパネエ夫人に随ひ、その居宅に往きたり。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　これに続いて、目白辺の屋敷猫を殺しむくいし事下谷辺にて浪人居宅｜化霊ありし事三州岡崎宿にて旅人｜狒々に逢う事奥州にて旅人山に入り琴の音を尋ねる事　題を見ただけでも、唐から渡りものの飜案で、安価な上方版のお伽稗子そのままなのが直ぐ知れる。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが現在の彼等の生活に、最もふさわしい居宅であった。",
              "citation": {
                "source": "都会地図の膨脹",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つの問題は通行人の膀胱の緊張を調節し緩和するためには、この都市にはあまり共同便所が少ない、この共同便所の少ないことは人間の居宅に近く放尿するといふ結果になるから至急政府に向つて共同便所増設の請願猛運動を起すことに決議された。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その居宅は田鶴見子爵の邸内に在りて、裏門より出入すべく、館の側面を負ひて、横長に三百坪ばかりを木槿垣に取廻して、昔形気の内に幽しげに造成したる二階建なり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾来富山は益す傾慕して措かず、家にツィシアンの模写と伝へて所蔵せる古画の鑒定を乞ふを名として、曩に芝西久保なる居宅に請じて疎ならず饗す事ありければ、その返とて今日は夫婦を招待せるなり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は思はず立ちどまり、もう一度、ウラスマルの居宅の方を顧みて詫び入りたい心持ちになつた。",
              "citation": {
                "source": "アリア人の孤独",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがつて我々の交際はいつも集会の席上にかぎられていて、さらに進んで互の居宅を訪問するとか、あるいは酒席をともにするとかいうところまではついに進展しないでしまつた。",
              "citation": {
                "source": "人間山中貞雄",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校に一洵老を訪ねたが会へない、居宅へまはつて奥さんから混合米一升だけ借りる。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "この家の裏に淡島寒月さんの居宅があって其の家裏を領している太い椎と松とに鶉が籠っている、そして昼頃から曇って来た静かな空気の中にゴロッチョゴロッチョと濁った声を伝えている。",
              "citation": {
                "source": "小さな旅",
                "author": "富田木歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに抽斎の居宅には多く客を延くべき広間がないので、新築しなくてはならなかった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "父蘭軒の時からの居宅で、頗る広大な構であった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年に五百の姉壻長尾宗右衛門が商業の革新を謀って、横山町の家を漆器店のみとし、別に本町二丁目に居宅を置くことにした。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "保は職を辞する前に、山田脩をして居宅を索めしめた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち今の居宅である。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その百十六　勝久が本所松井町福島某の地所に、今の居宅を構えた時に、師匠勝三郎は喜んで、歌を詠じて自ら書し、表装して貽った。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "入京以来第三の居宅である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「寛政九年善郷江戸に至るの故を以て、帯刀免許の命を蒙り、町年寄を兼ることを辞して後、東洞院の善郷が居宅に移り、同年八月二日死、宗仙寺に葬る、法名隣山粛徳信士。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "住所居宅の事一、人の棲は高かき乾燥たる地に家作し、精々清潔に棲ふを養生の大旨とす。",
              "citation": {
                "source": "養生の心得",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
