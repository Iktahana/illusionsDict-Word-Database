        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "身を悶え、肩を揉み揉みへとへとになったらしい。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆の出来た足を揉み揉み女運転手が帰って来るのを待った。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには腰の低い小間物屋のおかみさんも店の外まで出て、おげんの近づくのを待っていて、「御隠居さま、どうかまあ御機嫌よう」　と手を揉み揉み挨拶した。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸本は手を揉み揉み兄を見送ろうとして一緒に次の部屋まで出た。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めは矢代も足を揉み揉み歩いていたが、そのうちにもう一歩も歩くことが出来なくなった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「帆村さんはもう帰って来ないかも知れませんよ」　鴨田理学士が両手を揉み揉み云った。",
              "citation": {
                "source": "爬虫館事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ蹲って、手を伸ばし、水を含んだ軟かい泥を掬い上げては、幾たびか揉み揉みして、自分のような小さいものを両手で持っているばかりである。",
              "citation": {
                "source": "不周山",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥様がこうして御一人でいらっしゃるのが、私は心配で堪りません……御留守居は最早沢山で御座いますよ……」　この奉公人は、リョウマチ気のある手を揉み揉み言っていた。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだろうな、こういう具合にして見たら……」とサモイレンコは指を揉み揉み考えて、「いいかね、やっぱり金は貸してやることにする。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "気を揉み揉み、控え屋敷で待っていた右馬介は、やっと退がって来た高氏をそこに迎えたが、彼の冴えない顔を見て、はっと胸を暗くした。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍者たちはぜひなく囲いの次の部屋で、白い息を凍らせながら手を揉み揉みじッと寒烈に耐えている。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中の一人は、百姓らしい手をもみもみ吉左衛門にたずねた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その男は手をもみもみ言った。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と久兵衛は手をもみもみ言った。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼が伊之助にその話をして家に引き返して来て見ると、長いこと独身で働いていた下男の佐吉があかぎれだらけの大きな手をもみもみ彼の前へ来た。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "きつねめさんの　台所に　もどると、　めちゃくちゃななかを　ばにばにベンジャミンは　何とか　かきわけて　気を　もみもみ　ちりほこりに　まみれながらも　オーヴンに　たどりつきます。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とキングは手をもみもみ、「では今こそ裁判員よ……」「そこのだれかがこのポエムを読みとけたら、」とアリス（このほんの数分でたいへん大きくなっていたので、まったく物おじもせず口をはさんでね）、「銀貨１まいあげてもよくてよ。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、つづけて「優しくもみもみとある様に見ゆる姿、まことに有りがたく見ゆ。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
