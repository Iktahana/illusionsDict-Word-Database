    "definitions": [
      {
        "index": 1,
        "gloss": "monitor (device, software or person)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "昼なお暗い、アトリエといった趣の彼の仕事場に集まると、鮮やかなカラーのグラフィックスを組み込んだ、縦組み、アンチエイリアス表示の頁がモニターに浮かんでいました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "６８０３０搭載マシン購入のための貯金を崩し、Ｔ田はサードパーティのアクセラレーターと大型モニターを買った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "全部込みで三十九万八千円のモニター価格は、頑張ってくれたと思う。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソファに寝ころんだまま、ちょっとはなれたモニターに表示される電子本のページを、パソコン・ゲーム用のリモート・コントローラーでめくったりすることもできる。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋でモニターやれ」　という高志のことばに、ありがたくしたがったわけだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「モニターには出てるけど、いまからちょっとテープをまわすから、そのままでいて」　慶一は落ちつかない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ワラ、モニター見てるか」「うん」「撮れそうか」「もうちょっと。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "四人は、七インチのモニターを囲んで、塔の下に腰をおろし、しばらく黙って画面を見つめる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "モニターのなかの寮と周囲の山や丘が、徐々に輪郭を明瞭にととのえていく。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、モニターで見たより、かなり暗かった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まかしてよ」　高志が、うしろで黙ってモニターを見ている慶一をふりかえった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「知りませんよ」　一〇三のヴェランダにおいたモニターの垂直同期を調整しながら、そうこたえたワラは、怒っていないどころか、むしろ高志の遅刻を歓迎しているらしい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "モニターの画像に納得したワラが、山崎をわきに押しやり、ファインダーをのぞきこむ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "回路図を付けたうえで、ＲＯＭ★に記憶させておくモニターと呼ばれる基本ソフトのプログラムリストも公開するという方針には、品質管理の担当者から「公開した情報にもとづいてユーザーが何か手を加え、そこで問題が起きたらどう責任をとるのか」とクレームがついた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベーシックで使うことが常識となった初期のパーソナルコンピュータでは、モニターやベーシックの翻訳ソフトがＲＯＭに焼き込んだ形で搭載されるようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "試作機の電源を入れなおしたとき、ラジオに雑音が入るのに気付いた後藤氏は、モニタープログラムが起動されてＣＰＵが動くことで雑音が生じていることを直感した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしたマシンで、ベーシックの翻訳プログラムを自動的に立ち上げたり、どのキーが押されたかを判定して画面にその文字を表示するといった基本的な動作は、モニターと総称される小規模な基本ソフトがになっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七五年、キルドールはこのデジタルシステムズにＣＰ／Ｍをライセンスするとともに、インテリジェント端末に使おうと考えたオムロン・オブ・アメリカ社、ネットワーク用のモニタープログラムとして使おうとしたローレンスリバモア研究所と供給契約を結んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三に、専用のモニターだけでなく、家庭用テレビにも接続できるようにすること。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "資料を開いてＰＣ―９８０１の説明を始めると、しばらくはスペックに目を走らせていた渡部が、「動かしてみましょうか」と小澤をさえぎり、段ボールから取り出したマシンにモニターをつなぎはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "六Ｋバイトの整数ベーシック★は、二ＫバイトのモニターとともにＲＯＭ化されて回路に組み込まれており、電源を入れると同時に使いはじめることができた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つのキットとも、ＲＯＭに収めて供給されるモニターは、システムをテレタイプで使うことを前提として書かれていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしたメモリー内の領域の配置は、基本ソフトのモニターが受け持つが、この作りは各社でばらばらになっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて同じマイクロコンピューターを使っているのなら、同じ機械語のプログラムが異なったシステムでそのまま使えるようにモニターの作り方に留意するように求めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピットマンは機械語レベルでの互換性のために、モニターに注文をつけた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって、結果を説明するには各個体の消費をモニターする必要があった。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガレージ・セールや蚤の市をまわって古いＴＶを見つけ、少なくともヴィデオ・デッキのモニターとしては機能するまでに修理し、画面に昔の映画を再生し、その様子を写真に撮ればいい。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
