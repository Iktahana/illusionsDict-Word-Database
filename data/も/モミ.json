      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "unhulled rice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "背戸の田圃のぬかるみに映る星、籾磨歌が聞える。",
              "citation": {
                "source": "星",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところどころ籾殻を箕であおっている。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が十二月二十五日の午前に帰って見ると、庭一面に籾を干してあって、母は前の縁側に蒲団を敷いて日向ぼっこをしていた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "くる／＼廻る親玉号は穂をあてがえば、籾が面白いほどさきからとび落ちた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして籾は、発動機をかけた自動｜籾擂機に放りこまれて、殻が風に吹き飛ばされ、実は、受けられた桶の中へ、滝のように流れ落ちた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「武井から、今日の昼、籾擂代を取りに来たが、その銭はあるか知らん？",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「籾擂を機械に頼みゃ、唐臼をまわす世話はいらず、らくでええけんど、頼みゃ、頼んだだけ銭がかゝるんじゃ。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "退職技手こぞりてひとを貶しつゝ、　　　わかれうたげもすさまじき、おのれこよひは暴れんぞと、　　青き瓶袴も惜しげなく、籾緑金に生えそめし、　　　　　代にひたりて田螺ひろへり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "籾ができると父は細長くきれいに藁を通して編んだ俵につめて中へつめた。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、狸は自分の家で、例のとほりありがたいごきたうをしてゐますと、狼が籾を三升さげて来て、どうかお説教をねがひますと云ひました。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云ひながら狼の持って来た籾を三升風呂敷のまゝ呑みました。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの狼の下げて来た籾が芽を出してだんだん大きくなったのだ。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらは、籾や藁から発ったこまかな塵で、変にぼうっと黄いろになり、まるで沙漠のけむりのようだ。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが何せ、器械はひどく廻っていて、籾は夕立か霰のように、パチパチ象にあたるのだ。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　まったく籾は、パチパチパチパチ歯にあたり、またまっ白な頭や首にぶっつかる。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二度目の月と醤油との会合ははなはだ解決困難であるが、前の巻の初めに、史邦の「帷子」の発句と芭蕉の脇「籾一升を稲のこぎ賃」との次に岱水が付けた「蓼の穂に醤のかびをかき分けて」を付けているところを見ると、岱水の頭には何かしら醤油のようなものと帷子との中間にまたがる観念群があるのではないかと疑わせる。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "義理のやうに一寸募つた暑さも直ぐ涼しくなつて、是れでは北海道中｜種籾一粒取れまいと云ふのに、薄気味悪く米の値段が下つたりした。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく因果の道理の説明に、「稲」の話が持ち出されて来ますから、一応説明してみますと、まず稲には、因として籾がある。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち筆を執る職のものに、籾と土地と肥料とを与えられて、作って見ろと言われても、とても専門の農業家のように作れるものではありません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一反の稲を作るのさえ、その籾の選定からしていろいろの知識経験が必要であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その籾がどういう地質に合うか合わないか、嘗てそれを実際に試してみて、すなわち因果の理法を実行した結果の成績を記憶にとどめて置きます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その籾によっての収穫の利益予想も、みな因果の理に支配されます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その籾を苗に育てます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして八月のなかばになると、オリザの株はみんなそろって穂を出し、その穂の一枝ごとに小さな白い花が咲き、花はだんだん水いろの籾にかわって、風にゆらゆら波をたてるようになりました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このスヰツチをかうすると、」などと言ひながら、あちこちのスヰツチをひねつて、モーターをぴたりと止めて見せたり、また籾殻の吹雪を現出させて見せたり、出来上りの米を瀑布のやうにざつと落下させて見せたり自由自在にその巨大な機械をあやつつて見せるのである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今その典型的ともみえるのを紹介に及んでみる。",
              "citation": {
                "source": "非文学的文士",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後の五時から七時までのその夜学では、生徒は勤め人かそれとも他の学校に席を有してゐるものであり、如何にもみんな一寸顔を出してゐるといつた気持で来てをり、二年間一緒の教室にゐて、一度も話を交はさずに終る男もあるのである。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは恰かも青い色が青い色であり、赤い色が赤い色であるやうに、夢をみようともみまいともしないで私は夢みてゐるのである。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もみぢ萩原朔太郎霜つききたり木ぬれをそむるとおもひしものを庭にあづまやの遠見をそめうすべにさせる魚をそめわかるるきみのくちをそめ",
              "citation": {
                "source": "もみぢ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くあの「ポツダム宣言」の約束を全部果して、そうして小さくても美しい平和の独立国になるように、ああ、私は命でも何でもみんな捨てて祈っています。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
