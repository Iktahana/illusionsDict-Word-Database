[
  {
    "uuid": "e349366e-96f7-5b29-8706-e3238e44ac42",
    "entry": "籾",
    "reading": {
      "primary": "もみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
