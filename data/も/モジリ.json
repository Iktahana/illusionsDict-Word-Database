    "definitions": [
      {
        "index": 1,
        "gloss": "parody (of a famous work)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
