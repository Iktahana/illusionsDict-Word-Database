[
  {
    "uuid": "f985c5d4-e66b-5d71-96ba-be2b8b557812",
    "entry": "餅花",
    "reading": {
      "primary": "もちばな",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
