        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何だかいい儲け口があるから、北海道へ行くとか言ってたけれど、その旅費がほしかったのかも知れないわ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんです、何か旨い儲け口ですか」　謙作はそう云って魚軒を口にしながらその後で盃を持った。",
              "citation": {
                "source": "港の妖婦",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "商売のほかにいろいろの儲け口をあせるのだな」「世が悪くなりましたからね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "冬の金魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなすばらしい儲け口は又とないよ。",
              "citation": {
                "source": "透明猫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大分｜費い込みの出来た叔父は一層｜儲け口を見脱すまいとして燥っていた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "一緒に会社を退いた人たちも、その当座寄ると触ると儲け口を嗅ぎつけようとして、花を引いていても目の色が変っていたが、そんな人たちも長くこの家を賑わしてはいなかった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "好い儲け口があるからと言つて、飛びこんで来た知り合ひの大工は、外神田の電車通りに、羅紗や子供服や釦などの、幾つかの問屋にするのに適当な建築を請負つて、その材料を分の好い条件で、木山に請け負はせる話を持ちこんだのだつた。",
              "citation": {
                "source": "のらもの",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし結局は親店の仕事を手伝ひ旁々自分の儲け口を見つけるより外なかつた。",
              "citation": {
                "source": "のらもの",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、飴というものはなかなか儲かるものでげして、わずか五銭のもと手でその時三十銭から四十銭にはなりました」「そんなにいい儲け口を止めてしまったのには？",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さう出來ると、面白いが、ねえ」と、義雄は氷峰を見ると、氷峰はそれに答へないで、「そんなことよりも、巖本君」と、天聲に向ひ、「君の地位を利用して、何かうまい儲け口を早く見つけ給へ、いつまでもあんな新聞にかじり附いちやアをられんぞ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "まつたく本局勤めなんてどこが好いだらう――うまい儲け口なんか一つとしてありやしない。",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも儲け口たるや、本に書いてないところにしかありっこない。",
              "citation": {
                "source": "杉垣",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また杉次郎は情婦のお菊が、旅に出かけて行くというので、別れるのが厭だという心持から、一緒に行く気になったのであり、弁太は弁太で行を共にしたら、うまい儲け口があるかもしれない。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸方の会社や資本家にわたりをつけておいて、儲け口を売りこむといふ天性の自由業、まともなことは何一つできない。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、他愛のない噂話や雑談の中から自分の儲け口を見つけるのに妙を得てゐた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "３．そら儲け口だといふので勢込んで駈け出したフリツの野郎を全く君達に見せたかつたよ。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もせっかくの儲け口をサランパンにしちまって逃げましてね。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さっそくですがね兄さん、儲け口」　座るなり桃輔は言った。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "儲けようったって、今時そう儲け口が転がってるもんじゃない」と幾分か自分に対して恩に被せるように答えるのを、「そうさ」と幾分かさげすむように聞き流して、裏へ出て行った。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらかの金をもつててですよ、いろんなことに、手を出してみたが、どれもこれも思はしく行かんので、何か新手でぼろい儲け口はないかと、そればかり考へてるやうなのは？",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "儲け口があるのだがどうだね。",
              "citation": {
                "source": "沓掛時次郎　三幕十場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとっさんが儲け口があるといってたが聞いたかい。",
              "citation": {
                "source": "沓掛時次郎　三幕十場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルイザはわずかな金の儲け口も見逃さなかったので、婚礼の御馳走だの洗礼の御馳走だのという特別の場合には、やはりつづけて料理女として雇われていった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを知りつつ、洋学が出来ないばっかりで、宝の庫に入りながら、指を銜えて、みすみす儲け口を取逃がしてしまうのが残念でなりません」　　　　　　　　　七十三　お絹は今日は、これだけのことを話して帰りました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸おあいそもよし、相応に目先の利く所もあって、たまには儲け口もありましたが、いつも女にしてやられ、年中ぴい／＼して居ます。",
              "citation": {
                "source": "幇間",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「儲け口がそんなにあるのかい」と俺はロクに言ったのだが、百成が、「そりゃ、もう、いっぱい――濡れ手に粟でさあ」とあさましいことを言った。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人にしかできない、日本人にはもってこいの、ぼろい儲け口……」　そんなことを言う百成は、アビル時代の彼と思いくらべると、バケの皮がはがれたみたいにも見られる。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その儲け口というのは、――物資を上海に持ちこむには日本軍の許可がいる。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたぼろい儲け口が立派に成立している。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
