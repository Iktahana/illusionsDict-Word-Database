[
  {
    "uuid": "4931488e-cd79-5ac4-8ba3-af8171271f0f",
    "entry": "最も",
    "reading": {
      "primary": "もっとも",
      "alternatives": [
        "もとも"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "most",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だいたい芸術といふ、最も悲劇的な仕事は最も喜劇的に見られ易いならはしである。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、此処には、我が民謡の精神は実になみ／＼としてゐて、これは、詩書を手にする程の人には最も直ちに、感じられる底のものである。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことは、詩の道として、最も健全なことである。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルレーヌの有名な詩人論“〔Poe`tes Maudits.〕”の中に、※ルレーヌの認めて最も真物の詩人となした五人の詩人中に加へられてゐるのである。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し実験室で可なり熱中する人々から最も専念する人々を身近に眺める時に、多くの幸福論者は兎も角一応の反撥を感ずるのが事実である。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も不利な位置、――花道の上に当る一番の端ッこが五つ並んで空いてゐるだけであつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもさうした純潔の詩人の生涯こそ、かの音楽家のそれと等しく、人生の最も神聖なる住宅、即ち道徳及びその他の感情生活の世界を支配する最高至美の権威でなければならない。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "新婚まもなく若い稚気のぬけなかった夫人は、恐らく恐怖にふるえながらも、人生の最も楽しく忘れ得ない夢を経験したのだ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり一口にいえば、今の日本の若い娘たちが、最も退屈を感じて『詰まンないの』というような場所であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ家の中に住んでる家族の者にさえも、ほとんど全く解らない不思議な言葉で、何時間も倦きずに睦じく語り合ってた二人の男女こそ、この世における最も理想的に幸福な夫婦であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかんずくヘルンを最も悲しませたのは、盆踊等の農村行事や風俗やが、明治政府によって禁圧されたことから、自然に衰褪して来ることだった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたヘルンの小泉八雲が、常に最も好んだ散歩区域は、寺院の閑静な境内だった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その寺は庭が広く、背後に老杉の茂った林があったので、彼の瞑想的な散歩に最も好ましい所であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそうした八雲の悲しい心は、常に最も夫人の心を痛ましめた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその対話の中には、いつも人生の最も悲哀な言葉が含まれていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人にとってのヘルンは、最も信頼する良人であったと共に、一面ではまた『大きな駄々ッ子坊や』でもあった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし仕事をしている時のヘルンは、最も気むずかしやの八釜しい主人であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の詩の中では、郷土望景詩數篇が最も氣に入つたらしく、口を極めて賞讚してくれた。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分について言へば、自分は彼の多數の友人――實に彼は多數の友人と交つてゐた――の一人であり、しかも交情日尚淺く、相知ることの最もすくない仲であつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもただ、自分が彼について語り得る唯一の權利は、あらゆる他のだれよりも、すべての彼の友人中で、自分が最も新しい、最近の友であつたといふことである。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　室生犀星君は、最近における故人の最も親しい友であつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この公平な理解と見識では、詩壇の最も高い純粹鑑賞に劣らなかつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして芥川君の文學は、正にこの點で自分の敵――しかも最も強力な敵、それへの戰で最大の名譽を感ずるほど、それほど偉大で強力な敵。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし私が、私の言語における「詩」といふ定義を換へるならば、彼は疑ひもなく詩人――しかも最も若き時代の詩人――であつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の中の最も微妙な本能は、頑として彼の詩人でないことを、したがつて彼の作品の不滿であることを主張した。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは時に、最も氣の利いた詩的の表現、詩的の構想をもつてゐる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ちつまり言へば、彼は私の最も「親愛なる友」であつたのだ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自選詩集に採録されてる有明の詩は、彼の中での最も惡い作品であり、多くは修辭的の技巧に凝つて、リリツクの純眞性を喪失してゐるやうなものばかりである。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤村氏の自選詩集には、過去の作品での最も秀れたもの、最も純粹で美しいものばかりが選りぬいてある。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、いまのこの時代に、もっともっとたくさんあって当然のように私には感ぜられるのだが、しかし、案外、見当たらない。",
              "citation": {
                "source": "織田君の死",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
