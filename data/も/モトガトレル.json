        "examples": {
          "standard": [
            {
              "text": "食べ放題で元が取れるほど食べるのは、今の年齢ではもう無理だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「このサブスク、月に3本以上映画を見れば元が取れる計算だよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "高価な調理器具を買ったが、毎日使っているので十分元が取れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "コンピューターを図書館代わりに使えば、取れないはずの元が取れるのではないかと思いついたのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "四万だよ」「イヤだ」「四万あれば君は元が取れるじゃないか。",
              "citation": {
                "source": "ボロ家の春秋",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
