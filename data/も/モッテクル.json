        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "置所から色々の供物を入れた叺を持ってくる。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなってくると何をいうても、直ぐそこへ持ってくるので話がゆきつまってしまう。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　街に展いた窓の出張に置かれた洋紅色の花鉢を寝台の枕もとに持ってくると、夜の女は眸の快楽のために、「――その女房と云うのはどんな役目なの？",
              "citation": {
                "source": "戦争のファンタジイ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――仲買人、掛値を云うて持ってくる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "バスチアンとイドウとが氷塊を小汽艇へ積み込んでいるところへテレーズがコーヒーの茶わんを持ってくる。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）を一杯持ってくる。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "観測の器械は一ぺん調べてそのままにして、表は全部持ってくるのだ。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど、おとうさまは、聞いている人が、ふきだしてしまうような、おかしいお話がお好きですの」「ええ、それでは、結婚の贈り物には、お話だけを持ってくることにします」と、息子は言いました。",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、それを前掛けに入れて、持ってくるんだがね、その前に、一つ一つの星に、番号をつけておかなければならないのさ。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、あすの晩、わしのところへ来るときには、忘れずに、そいつの目玉を持ってくるんじゃよ。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "（女の子さがして持ってくる）三男　　それ合わせてごらんよ。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "判官が言いつけどおり帳簿を持ってくると、城隍神はそれを見てから朱筆を取り、何か紙片に文字を書いて世高にくれた。",
              "citation": {
                "source": "断橋奇聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃ、おれが行って持ってくるかな」　正勝は身動ぎながら言った。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "持ってくるかこねえか、ここにいて見てればいいや」「大したもんだなあ。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "論より証拠だ、とにかく、持ってくるか持ってこねえか、見ていれば分かるさ」「いったい、その手紙っての、どんな風に書くんだね？",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀久ちゃんが金を持ってくるかこねえか、酒でも飲みながら待ってみてくれよ」　正勝はそう言って、盃に酒を注いで回った。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『この手紙では何の意味もないが、もしこの手紙の差出人を特定する他の手段がないものとすれば、大きな意味を持ってくる。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "執事が済まなそうに言伝を持ってくるより先に、脇をすり抜け、部屋に滑り込んだ。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "日よけは下ろしておらず、これはその部屋を夜は滅多に使わないからなのだが、ところがバークリ夫人は自らランプを付け呼び鈴を鳴らし、住込女中のジェイン・ステュワートに紅茶を一杯持ってくるよう言いつけた。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と友人は小机を電灯の前へ持ってくる。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と向き直って言葉を継ぎ、自分の顔の前に明かりを持ってくる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつ呼鈴を鳴らしたまえ、女中が君の珈琲を持ってくるから。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "足を抱え込み、やせたひざを鷲鼻の近くに持ってくる。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は物をあまり近くへ持ってくるので視力を減じたのだ。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へいってちょっと持ってくるものがあるからって、あやつにそう言って来たまでです」「そうか、そんなら仔細はないじゃないか。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚を女に渡し、ビール二三本そえて持ってくる様に命じた。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "新蔵は家の小作人で、毎年冬になると年貢米を二十俵ずつ持ってくる。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祝儀の進物に持ってくるくれえなら、箱書きなんぞまえからちゃんと用意してくるのがあたりめえなんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すずりと半紙をちょっと拝借させてくれぬか」　のみならず、小僧が求めたその二品を持ってくると、いきなりさらさらと次のごとき文句を紙にしたためました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "村正騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "随分、身体が汚れてるべよ」　お湯を持ってくる途中、監督に会った。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
