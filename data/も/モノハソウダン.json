    "definitions": [
      {
        "index": 1,
        "gloss": "a wise man is he who listens to counsel",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
