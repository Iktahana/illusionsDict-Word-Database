    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to come back",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その戻ってくる場合も常とは違って、ある者は門前に倒れているのもある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜おそく戻ってくると、頭上でかさかさと挨拶するのは楢の葉である。",
              "citation": {
                "source": "草木塔",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく佇んで戻ってくると伊助は帳場の火鉢をせっせと磨いていた。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵闇の長い堤をぶらぶら戻ってくると、僕をじらすように大きい魚の跳ねあがる音が暗い水の上で幾たびかきこえた。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "せいぜいが地面から三、四尺ほどのところを高く低くゆらめいて、前に行くかと思うと又あとの方へ戻ってくる。",
              "citation": {
                "source": "異妖編",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが戻ってくるまでちゃんと看視していてね。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが今晩、君の指定した時刻までには必ず戻ってくる。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――僕は妻とお手伝いが例の脇道を急いで戻ってくるのに出会いましたが、立ち止まって話をするつもりもありません。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」グラント・マンロウ氏を戸のところまで見送り、戻ってくると我が友人はそのように言った。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから御者はまた窓から外へ出て、警官と医者の助けを呼んでから戻ってくる。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "当人の考えでは、講師は正面玄関から戻ってくるから、姿が見えるはずだった。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "拳銃を手に戻ってくると、卓上は片づけられ、ホームズは趣味のヴァイオリンを一心に掻き鳴らしていた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルーシィ、きっと君をもらいに戻ってくるよ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "二ヶ月したら、絶対に戻ってくる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしが見込んだとおりの男なら、たちまち戻ってくる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "声を止めて返事に聞き耳を立てるが、おのれの叫び声のほか返ってくるものはなく、ものわびしい静かな谷あいにこだまするだけ、数え切れない響きが自分の耳へと戻ってくるだけだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし人の叫び声のような滝の轟音ばかりが、私の耳に戻ってくる。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして苦痛もなく、動く力も、また厳密に言えば考える力もなく、ただ生きていることと、自分の病床を取りまいている人々のいることとをぼんやりと麻痺したように意識しながら、病気の危機がとつぜん過ぎ去って完全な感覚が戻ってくるまで、じっとそのままでいるのだった。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど長いわびしい冬の夜じゅう、街をさまよい歩いている友もなく家もない乞食に夜が明けるように――そんなにのろのろと――そんなに疲れはてて――そんなに嬉しく、霊魂の光が私にふたたび戻ってくるのであった。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "このイヴェントの精神を今後に活かそうという意気込みが語られますが、日常的な学校生活のリズムが戻ってくると、「あれはなんだったんだ」との悲鳴のような訴えかけが紙面を飾りました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "金公金公、金公どうしたっていうもんだから、金公もきまり悪く元の所へ戻ってくると、その始末で、いやはよっぽどの見もんであったとよ」「そりゃおかしかったなア」　皆一斉に笑う。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大杉と別れた後の堀保子は大杉は必ず再び自分の懐ろに戻ってくるものと固く確信して孤独の清い生涯を守っていたが、大杉が果敢なくなった後はその希望も絶えて、同棲時代からの宿痾が俄に重って、去年の春｜終に大杉の跡を追って易簀した。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "長兄の家へ戻ってくると、とよ子の病気が伝染性のものと知って、嫂の恐れ方は一通りでなかった。",
              "citation": {
                "source": "草藪",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに三月の花が咲いて、陽気もだん／＼にあたゝかくなり、世間の景気も春めいて来たので、主人の家族もみんなこゝを引払うことになって、久松もはじめて日本橋の店へ戻ってくると、土地が近いだけに憎い怨めしい医者坊主めのことが一層強く思い出されます。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、小梅にいるあいだも毎日忘れたことはなかったのですが、近間へ戻ってくると又一倍にその執念が強くなって来ました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも無事に、その紙鳶を受取って元の席に戻ってくると、なぜそんな詰まらないことを云うのだと、一緒に行っていた母や姉に叱られた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はやがて風呂からあがって、自分の座敷へ戻ってくると、女中のお文さんが夕飯の膳を運んで来た。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩、盆踊りに夜がふけて、踊り疲れた二人が村はずれの地蔵さまのそばまで戻ってくると、すすきのあいだに白い影がぼんやりと浮き出してみえた。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまに木村のおじさんが、顔色を変えて戻ってくるから待っていなさい」　しばらくすると木村さんは果たして、真っ青な顔をして出てきました。",
              "citation": {
                "source": "暗夜の格闘",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は生きていたら必ず戻ってくるはずでございます。",
              "citation": {
                "source": "墓地の殺人",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
