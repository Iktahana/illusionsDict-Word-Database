[
  {
    "uuid": "eab1ed0f-17a0-5ef8-84b7-6414b80c6425",
    "entry": "妄想",
    "reading": {
      "primary": "もうそう",
      "alternatives": [
        "ぼうそう"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
