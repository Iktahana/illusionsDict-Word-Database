[
  {
    "uuid": "b3b5d48d-4c87-5740-a3bc-38269affbdc3",
    "entry": "求むる",
    "reading": {
      "primary": "もとむる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
