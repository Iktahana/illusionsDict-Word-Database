    },
    "definitions": [
      {
        "index": 1,
        "gloss": "imitation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今日の日曜を此所に來りてわれら模擬飛行機の座席に乘れど側へに思惟するものは寂しきなり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るき四月の外光の中嬉嬉たる群集の中に混りてふたり模擬飛行機の座席に乘れど君の圓舞曲は遠くして側へに思惟するものは寂しきなり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "来年はどうかして合格しなければならぬと、試験度胸をこしらえるため、方々でやっている模擬試験（入学試験のまねごと）というのを度々受けたのでしたが、その翌年、本当の入学試験が来たとき、三つも中学校を受験してやはり駄目でした。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東練兵場へ出かけて模擬戦を観る、鉄条網、毒瓦斯、煙幕、タンク、機関銃、……労れて、少し憂欝になつて戻る。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの中世紀の魔教サバトの徒は、耶蘇とキリスト教とを冒涜する目的から、故意に模擬の十字架を立てて裸女を架け、或は幼児を架けて殺戮した。",
              "citation": {
                "source": "ニイチェに就いての雑感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けふは運動山で、南京攻略の模擬戦をするのださうだ。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくしてみんなは、じぶんたちが南京攻略の模擬戦を計画中であつたことを、やつとのことで思ひだした。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚ほ言を換へて曰へば、封建制度は独り武士にのみ其精華なるシバルリーを備へたるにあらず、平民も亦た之を模擬せり、然り、平民の内にもシバルリーは具はりたり、少なくとも侠勇の理想彼等の中に浸潤して、武士の間に降りし雨は平民までをも湿ほしたること、疑ふべからざるの事実とす。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "よいと思ったら何事にも機敏な秀吉のことだから、直ちに陣営の塀や櫓を白紙で張り立て、前面の杉林を切払って模擬城を築いた。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "各クラス毎で経営している模擬店がずらりと並んでいた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "模擬店をクラスが経営することに就ては学校当局は最初反対していた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫛は鼈甲模擬のゴムの櫛であつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは稻の花に模擬つたので、稻の花が一｜杯に開く樣との縁起であつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠國の山から切り出すのだといふ模擬の重い臺へゴム製の表を打つた下駄を突つ掛けて居るものもある。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞えて来る笛の音も、鼓の音も奏楽の響も、模擬店でビールの満を引いている人達の哄笑も、勝平の耳には、彼の金力に対する讃美の声のように聞えた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云ったまゝ空になった杯を、右の手で振り廻すようにしながら、ふら／＼丘の麓にある模擬店の方へ行ってしまった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの模擬店の雑沓は、何うです。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "余興も、模擬店も大成功よ。",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでは文句ばかりに悸されて厭々ながら立ちあがつたまゝの蒟蒻役者であつた模擬武士達は、黄金の光りに活気づいて猛烈な大合戦を演じた。",
              "citation": {
                "source": "天狗洞食客記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この十一世にもこれに類する何らかの期待が在るのだらうが、それは私の知る由もない彼の胸中の秘であつたが、いよ／＼許されてテルヨの薙刀と鉾を交へると決つた時の私は、昔日、黄金の音を聞いて馳せ参じた模擬武士と同様血相を変へた。",
              "citation": {
                "source": "天狗洞食客記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず想像と意志とを比較して見ると、想像の目的は自然の模擬であって、意志の目的は自身の運動である。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隱岐は、模擬革のボストンバツクをぶらさげて、彼女と肩を竝べた。",
              "citation": {
                "source": "痴日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "委員をきめて、模擬試験をやるんだ。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……―幕―……　　　第二景　夢の中の模擬試験音楽。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "模擬試験場と書いてある。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "模擬試験なら、受けると自信がつくから受けてもいいんだが、どこにあるんだろうね。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが模擬試験場なんですね。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "空中楼閣的模擬発明よりも奇なるホンモノの発明も亦、無からずして可ならん哉、乃ち、商工省特許局発行の広報より抜粋して次に数例を貴覧に供せんとす。",
              "citation": {
                "source": "発明小僧",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞えて来る笛の音も、鼓の音も奏楽の響も、模擬店でビールの満を引いてゐる人達の哄笑も、勝平の耳には、彼の金力に対する讃美の声のやうに聞えた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "九合半のしし岩は、両あごを突きだした形をしていたが、震災のため下あごがもぎ取られて、落ちてしまったという。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
