        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "宅へ帰って、一二時間黙坐して見たいなんて気が起ります。",
              "citation": {
                "source": "虚子君へ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "片側の古衣屋つづき、衣紋掛重き恐怖に肺やみの咳洩れて、饐えてゆく物のいきれに、陰湿のにほひつめたく照り白み、人は黙坐す。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナタナヱル無花果樹下に黙坐す、ナザレのイエス彼を見て、以て猶太人の中に尤も硬直にして欺騙なきものと思へり。",
              "citation": {
                "source": "各人心宮内の秘宮",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "一言も下さずに奥へ立った後を、夜半に及ぶまで宗矩は端然と黙坐したまま退かない。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも厭なりこれも厭なりで、二時間ばかりと云うものは黙坐して腕を拱んで、沈吟して嘆息して、千思万考、審念熟慮して屈托して見たが、詮ずる所は旧の木阿弥。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "……門外不出、黙坐読書。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "終日黙坐、麦ばかりの御飯を少々戴いて。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙坐沈思、門外不出、――おとなりから※子五六顆、かはり夕顔二三枝頂戴する。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪るかったと気がついたら黙坐して思い返すに限る。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙坐の人の呼吸は全く絶えて、波と共に魂は遠く、形骸を捨てゝ走つてしまつた。",
              "citation": {
                "source": "海潮の響",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "我等会員はホツプ夫人と共に円卓を繞りて黙坐したり。",
              "citation": {
                "source": "河童",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "我ら会員はホップ夫人とともに円卓をめぐりて黙坐したり。",
              "citation": {
                "source": "河童",
                "author": "どうか Kappa と発音してください。",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三人の親戚と一緒に、二階の書斎に黙坐して、骨壺の帰りを待つた。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
