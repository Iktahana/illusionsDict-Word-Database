        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の発言は真実であった。以て、会議は彼の提案通りに進んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "証拠は明白であった。以て、被告は有罪とされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "天候が悪化した。以て、イベントは中止せざるを得なかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
