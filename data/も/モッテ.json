        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の誠実さを以て、皆が彼を信頼している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その優れた技術を以て、多くの問題を解決した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "過去の失敗を以て、私たちは新たな教訓を得た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "on (a day, date)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
