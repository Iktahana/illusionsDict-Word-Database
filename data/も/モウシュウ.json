[
  {
    "uuid": "1b8099a6-657d-596f-bb44-ab7bae6b8d86",
    "entry": "妄執",
    "reading": {
      "primary": "もうしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
