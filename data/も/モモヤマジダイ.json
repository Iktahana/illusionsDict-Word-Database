  {
    "uuid": "2242cc15-c456-5dfd-81f4-b8e462ac0204",
    "entry": "桃山時代",
    "reading": {
      "primary": "ももやまじだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
