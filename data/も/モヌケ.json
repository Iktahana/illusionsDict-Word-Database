[
  {
    "uuid": "84ac78e2-15fc-5718-9eff-5caffb0d4a30",
    "entry": "蛻",
    "reading": {
      "primary": "もぬけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
