        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だが事実はそんなにアツサリ文字通りのことではない。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此處で「跳び込む」といふ語を使つたのは、眞にそれが文字通りであつたからだ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに一ヶ月余りといふものを寝て起きて食ふと言ふ全くその文字通りの日暮しのために、いつときも我慢し切れなくなつてゐた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "附録の「芭蕉私見」は、全く文字通りの一私見にすぎない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源は文字通りの悪戦苦闘を続けた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "附近一帯の水涸れで、工面のいい家は、どん／＼井戸を掘り下げたり、水道を引いたりして、文字通り「涼しい顔」をしてゐられるのであるが、この埃の溜つた井戸の使用者は借家人であり、その家主は、前代は財布の紐で首でも吊つたんではないか、と疑はざるを得ない吝ん坊なのである。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　この小説は、外の、捨て身な作品と共に、私たちの生活を、文字通りに食ひ込む雑誌の創刊号に発表される。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は文字通りに「味を覚える」。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "（四）「敬」「帝」「命」のようにエ段音の次にイ音が来たものは、文字通りケイテイメイと発音していたのであるが、江戸後半の京都方言では、エ段の母音ｅとｕとが合体してｅの長音〔e_〕となり、エ段長音が発生した。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから「日記」を「にき」と書いてあるのも、これはすこぶる疑問でありまして、文字通り「ニキ」であったか「ニッキ」であったか、「ニッキ」というような促音は、これを書きあらわす方法がなかったものでありますから「にき」と書いていたのか、これは大分疑問だと思います。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治以後になって文字通りに読むのだというので「ナメリ」「アメリ」とよむようになりましたが、昔は「ナンメリ」「アンメリ」といったろうと思います。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も私の住んでゐた附近は、文字通りにひどい所で二度と歸る氣はしないが。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾度か自殺を考へたほど、それほど思想上と生活上との、救ひがたい絶望的苦悶に陷入つて居たかを、君は少しも――眞に文字通りに少しも――知つてはくれないのだ。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この詩集世に出づるや、當時の◇文壇は文字通り驚嘆した。",
              "citation": {
                "source": "名詩集「思ひ出」の眞價",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "協会の諸兄によろしく（七月二十三日）（井上金太郎　宛）　腹くだりで入院なぞと真とに不甲斐ない話のようですが僕としては、身体の続く限りやるだけの事はやった後でブッ倒れたのですから（入院の時軍医さんの前で文字通りヘタヘタと倒れました）俯仰天地に恥じません。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "文字通りの意味でのシンパシーまたミットライドとはこんなのを言うのかもしれない。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "饅頭屋、土産物商、時計屋、骨董屋などの表看板は、文字通り表看板にすぎなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、柿本には、まだ、おばが、文字通りに着のみ着のまゝでＳ銀行に避難して、五ツの娘は、殺されていた、ことは分っていなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　落盤を気づかっていた爺さんが文字通りスルメのように頭蓋骨も、骨盤も、板になって引っぱり出された。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも恐怖とはいうものの、私はそれを文字通りに感じていたのではない。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文字通りの気持から言えば、身体に一種の抵抗を感じるのであった。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻が茶碗をぶつつけるあたりから、おゝこの音を聞け、の邊までは原作と文字通り同樣である。",
              "citation": {
                "source": "川端康成第四短篇集「心中」を主題とせるヴァリエイシヨン",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜘蛛の巣が二三度顔にまつわり付いたのには文字通り閉口した。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆者を除いた九名の選手と仮装マネージャーが、文字通りに長鯨の百川を吸うが如くである。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道の掘立小屋は、それこそ文字通りの掘立小屋で、柱を地面に突き差して、その上を茅屋根にして、床はといへば板を列べた上に筵を敷いただけ、それで家の中へ水が這入つて来ないやうに家の周囲に溝を作へるのです。",
              "citation": {
                "source": "私有農場から共産農団へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海老責は罪人を赤裸にして、先ず両手をうしろに縛りあげ、からだを前にかがめさせて、その両足を組みあわせて厳しく引っ縛り、更にその両足を頤にこすり付くまでに引きあげて、肩から背にかけて縛りつけるのであるから、彼は文字通りに海老のような形になって、押潰されたように平た張り伏しているのである。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく文字通りに荒凉たるありさまで、さながら武蔵野の縮図を見せられたようにも感じられた。",
              "citation": {
                "source": "九月四日",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると、温泉宿も普通の旅館と同様で、文字通りの温泉旅館であるから、それに対して昔の湯治場気分などを求めるのは、頭から間違っているかも知れない。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
