          "standard": [
            {
              "text": "あの夫婦の仲の良さは、まさに紅葉に鹿のような素晴らしい組み合わせだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "花札の絵柄にもある通り、紅葉に鹿は古くから調和の象徴とされてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新居に飾る絵画として、縁起の良い紅葉に鹿の図を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "すなわち梅に鶯、紅葉に鹿、菜の花に蝶の引続きである。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
