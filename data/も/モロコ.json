    "definitions": [
      {
        "index": 1,
        "gloss": "gudgeon (any fish of genus Gnathopogon or related genera)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――同胞諸子が堅忍なられんことを！",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かようにしていって、科学は絶対のものでない、なおいくらも研究の余地はある、諸子の研究を待っているという風にしたいと思うのである。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "季倫の父石苞、位已に司徒にして、其の死せんとする時、遺産を頒ちて諸子に與ふ。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし鼈四郎は夫人が通客であった場合を予想し、もしその眼で見られても恥しからぬよう、坂本の諸子川の諸子魚とか、鞍馬の山椒皮なども、逸早く取寄せて、食品中に備えた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "建文帝の国を遜らざるを得ざるに至れる最初の因は、太祖の諸子を封ずること過当にして、地を与うること広く、権を附すること多きに基づく。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "太祖の天下を定むるや、前代の宋元傾覆の所以を考えて、宗室の孤立は、無力不競の弊源たるを思い、諸子を衆く四方に封じて、兵馬の権を有せしめ、以て帝室に藩屏たらしめ、京師を拱衛せしめんと欲せり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "藩王以下は、永楽に及んで藩に就きたるなれば、姑らく措きて論ぜざるも、太祖の諸子を封じて王となせるも亦多しというべく、而して枝柯甚だ盛んにして本幹却って弱きの勢を致せるに近しというべし。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "太祖が諸子を封ずることの過ぎたるは、夙に之を論じて、然る可からずとなせる者あり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "孝孺の妻｜鄭氏と諸子とは、皆｜先ず経死す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "高煦生きながらに焦熱地獄に堕し、高煦の諸子皆死を賜う。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度は諸子が父上母上の頃には天竺と呼びたる最早くより開け進みし国にて、今日よりして評するも世界の文明の母ともいふべきところなれば、従つて趣味ある古話にも富みたり、御望みならむには随分諸子のために珍奇なる話を取り出して一年や二年の間はこの紙上に掲げん。",
              "citation": {
                "source": "印度の古話",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の教育者、特に小学教育者諸子よ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸子はこゝまで読み至つて何の感慨をか得たる。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸子既に人を教ふるの賢明あり、以てかの無学なる植木屋の老爺に比すべからず。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "剰さへ諸子の花苑には、宇宙の尤も霊妙なる産物たる清浄｜無垢の美花あり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども諸子よ、ひるがへつて乞ひ問はむ、諸子が其霊妙純聖の花を育てながら、よく彼の一老爺が草花より得たると同じ美しき心をば各々の胸に匂はせつゝありや。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸子は其多数が比々として表白しつゝある不浄と敗亡と乱倫とを如何せんとするや。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ我は多く云はじ、たゞ一言を記して、世の聖人たらざるべからずして、然も未だ成れるを聞かざる小学教育者諸子に呈す、諸子先づ三尺の地を割いて一茎の花を植ゑよ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「また受造者みづから敗壊の奴たることを脱れ神の諸子の栄なる自由に入んことを許れんとの望を有されたり」（羅馬書第八章二十一節）とあるは即ち是なり。",
              "citation": {
                "source": "主のつとめ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸子にもたまにはそういう経験が薬だろうと。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸子にもたまにはさういふ經驗が藥だらうと。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸子は暫く激つ心を抑へて待つ所あれと告げた。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私部が家の面目に掛けて諸子に滿足を與ふべければ、吾爲に須臾くかゝりあひなき吾領民との爭鬪を待たれよ、吾自ら茲に諸子を迎へたるは途上無益の爭鬪なからんと願ふに外ならぬ。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらば諸子は吾に從て吾家に來れ必ず諸子の望みを滿足させんことを誓ふとの意である。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "たうもろこしの葉が、風にさやさやと騷ぐのも、ながなか優雅なものである。",
              "citation": {
                "source": "金錢の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてちらっと大きなたうもろこしの木を見ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カムパネルラが「あれたうもろこしだねえ」とジョバンニに云ひましたけれどもジョバンニはどうしても気持がなほりませんでしたからたゞぶっきり棒に野原を見たまゝ「さうだらう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たうもろこしだって棒で二尺も孔をあけておいてそこへ播かないと生えないんです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然たうもろこしがなくなって巨きな黒い野原がいっぱいにひらけました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその鶴をもってこっちを見てゐる影ももうどんどん小さく遠くなり電しんばしらの碍子がきらっきらっと続いて二つばかり光ってまたたうもろこしの林になってしまひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
