  {
    "uuid": "bdc243ca-f2ea-52c4-b63a-10328c021aef",
    "entry": "もみ上げ",
    "reading": {
      "primary": "もみあげ",
      "alternatives": [
        "モミアゲ"
      ],
      "is_heteronym": false
    },
    "grammar": {
