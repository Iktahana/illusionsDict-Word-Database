    "definitions": [
      {
        "index": 1,
        "gloss": "tuft of hair under the temple",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いわゆるナッパ服を着て、頭を光らせ、もみ上げを剃り上げた、眼の鋭い若者が二人来て隣に腰かけた。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生毛が小さい小さい柔かく、もみ上げから衿元、頬にかけてうずまきに生えて居る。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "額ぎはからもみ上げへかけての具合、剃り毀つには堪へられない程の愛着が、師匠源内法師の胸にあつた。",
              "citation": {
                "source": "身毒丸",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分宇野のもみ上げ、永い顔と、あの獺のカラーとを知って居る。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "練吉の頬はきれいに剃刀があてられ、もみ上げから下の青味を帯びつるつるした皮膚にはこまかい汗がにじみ出てゐた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は背のひくいしなびた男で、黄色い顔をして、ちょっぴりしたもみ上げの毛をきれいになでつけて、幅のない中音で話をして、ものを言うとき口を曲げるのが癖だった。",
              "citation": {
                "source": "可愛い女",
                "author": "DUSHECHKA",
                "note": "青空文庫"
              }
            },
            {
              "text": "げほうから二軒おいて先きの、われわれ「カミドコ」といつた、理髪店｜勇床のおやぢは、芝居きちがひで、ぼくはこゝで初めてもみ上げを短かく剃られたチヤン苅りにされ、当分このアタマに拘泥したものだつた。",
              "citation": {
                "source": "両国界隈",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いつ来たの、僕ちっとも知らなかった」　保のまぶたはぽってりとしていて、もみ上げや鼻の下に初々しい和毛のかげがある。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もみ上げや鼻の下に和毛のかげをもった保のぽってりした少年ぽい顔である。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は四十歳がらみの男で、染めたもみ上げは彼が経てきた年月を感じさせた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "朽葉色の田螺頭巾をかぶり、それより色の黒い頬のコケに、長いもみ上げをばさらと散らし、虱もいそうな破れ袍をおかしげに着て、皮帯皮靴、大股ひらいて、拳を天に振っている。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうせ、下手人はもみあげの長いヴァレンチノだろう。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もみあげは長く伸びて黒かった。",
              "citation": {
                "source": "虹",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもみあげ長きフランシス・フォードという役者を覚えた。",
              "citation": {
                "source": "私の活動写真傍観史",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――絵の具だらけのずぼん・蒼白い額へ垂れさがる「憂鬱」な長髪・黒りぼんの大ネクタイと長いもみあげ・じっと卓上のアブサンを凝視している「深刻」な眼つき・新しい派の詩人とあたらしい派の画家と、新しい派の女と、軽噪と衒気と解放と。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分が持つて來た書物を座蒲團で卷いた枕の方へ無意味に兩眼を流れ出で、兩方のもみあげのあたりに傳ふ、生ぬるい涙じるを手の平で押しぬぐつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "スペイン人のようにもみあげの長いひと。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず、鼻下の細｜髭を剃り落しもみあげを長くして、これなら、三日｜軽口師の「鼻のカムポス」とは、誰がみようと分るまいというのである。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三日剃刀をあてないと見えて、もみあげから※へかけじじむさそうに、髭が薄黒く隈取ってはいたが、細くスーッと切れ上がった眼、高く長く通った鼻、薄くしっかりと結ばれた口、どうしてなかなかの美男であった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして僕の前に立っているのは、燕尾服を着た、頭のはげた、もみあげの長い、そして背の高いおじさんだった。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こわごわ手をあげてさはつてみれば、彼女のもみあげから頬にかけて、やはらかいうぶげがしつとり霧にぬれて光つてゐた。",
              "citation": {
                "source": "すらんらん集",
                "author": "仲村渠",
                "note": "青空文庫"
              }
            },
            {
              "text": "グラン・ブルレンチノ風の長いもみあげを見せびらかすように気取ってゆく。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇野浩二は私より二年くらい前に、大正年間の文壇という壇のうえにもみあげの長い顔をすえ、室生犀星の顔にはモンスターが棲んでいると何かに書き、私が文壇の壇の上に坐りこむと或る雑誌の人が原稿依頼に来て、原稿料は幾らくらい差し上げたらよいかと聞いたから、私は宇野浩二君に支払っている額を払ってくれと答えた。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻下にすばらしく長いひげをたくわえ、その尖端をカイゼル流にもみあげたのが、うしろからでもはっきり見えるくらいなので、ほかにもひげの多い先生が何人かいたにもかかわらず、少佐赴任以来「ひげ」といえばもう少佐にきまったようなものであった。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩まである濃い色の髪を頭の中央から分けて垂らし、口のまわりのひげや顎ひげ、そしてもみあげは、生えるままにまかせてある。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一六歳になると、エルヴィスは、サイドバーンズ（もみあげ）を長くのばしはじめた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは髪をリーゼントにしてもみあげを長くのばしているから、風圧で横に流された涙は、もみあげのなかに入りこんでいった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "三階の二つのアパルトマンの一つにはポワレという老人が住み、もう一つには四十歳がらみの年輩の男が住み、その男は黒いかつらをかぶり、もみあげを染めていた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳を聾せんばかりのどよめきが、土用波のように見物人をもみあげた。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛の硬いもみあげが旋風を描き、節級冠の燕尾がこの者の俊敏さをあだかも象徴しているようにみえる。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
