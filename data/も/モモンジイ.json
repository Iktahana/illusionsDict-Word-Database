        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「陰でももんじいを言うくらいなら、本人に直接言えばいいのに。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「彼のいないところで、みんなでももんじいを言うのはもうやめよう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あいつのももんじいばかり聞いていたら、こっちまで気分が悪くなってきた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
