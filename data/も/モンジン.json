        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　武蔵が、Ｔ「先生の門人として　道中御供　致し度う御座る」　ウンウンと団九郎。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（門人数名を供に連れている）　こらッと、その侍白倉源五左衛門、おしまの腕を掴む。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "後から、おしまに武蔵、更に門人一同。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "固唾を呑む門人とおしま。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、門人が五六名、武蔵に打って掛ってもよろしい。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "方孝孺の門人｜林嘉猷、計をもって燕王父子をして相疑わしめんとす。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "廖※廖銘は孝孺の遺骸を拾いて聚宝門外の山上に葬りしが、二人も亦収められて戮せられ、同じ門人｜林嘉猷は、かつて燕王父子の間に反間の計を為したるもの、此亦戮せられぬ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "廖氏氏」］二子及び門人｜王※等拾骸の功また空しからず、万暦に至って墓碑｜祠堂成り、祭田及び嘯風亭等備わり、松江に求忠書院成るに及べり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "止観は隋の天台智者大師の所説にして門人｜灌頂の記したものである。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "又其章の、門人が子思子に問われた言葉に、「昔は子の先君子出母を喪せる乎」とあるによれば、子思子の父の子伯魚も妻を去られたようである。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛衞は新入の門人に、先づ瞬きせざることを學べと命じた。",
              "citation": {
                "source": "名人傳",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛衛は新入の門人に、まず瞬きせざることを学べと命じた。",
              "citation": {
                "source": "名人伝",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "△新村忠雄　幸徳秋水の門人なり。",
              "citation": {
                "source": "日本無政府主義者陰謀事件經過及び附帶現象",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのためとしてわたしは彼の勧めにより、その時｜凋落の底にある江戸座の俳人の元老市塵庵四季雄の門人となったものだが、そして師匠がわたしの身の上に望んだ事は、自分同様一生の独身であった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私の門人のＳという男が、私の字を読み慣れている。",
              "citation": {
                "source": "茶屋知らず物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の大新聞二三種に黒枠二十行ばかりの大きな広告が出て門人高山文輔、親戚細川繁、友人野上子爵等の名がずらり並んだ。",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂歌は初代｜弥生庵雛麿の門人で雛亀と称し、晩年には桃の本鶴廬また源仙と云った。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "上木し得るまでに浄写した美麗な巻で、一勇斎国芳の門人国友の挿画数十枚が入っている。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時是真は息と多勢の門人とを連れて吉原に往き、俄を見せた。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "席上には酒肴を取り寄せ、門人等に馳走した。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに門人中坐容を崩すものがあったのを見て、大喝して叱した。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論能楽の事に関しては一流の定見を持っていて一切を断定的にドシドシ事を運んだが、しかし日常の事に関しては非常に気が弱くて、夫人は勿論、門人や女中にでも遣り込められると、「成る程のう。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊の噂が高まってくるとともにその門人となる者もできた。",
              "citation": {
                "source": "神仙河野久",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊は時どきその門人を伴れて熊山へ往った。",
              "citation": {
                "source": "神仙河野久",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "火のものを絶って尊に跟いて往った門人達は、熊山の山頂で神仙の奏する音楽を聞くことができた。",
              "citation": {
                "source": "神仙河野久",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊は門人達に、「熊山、吉野山、伯耆の大山などには仙境があって、吉野山の神仙と、熊山の神仙とは常に往来している」と話したこともあった。",
              "citation": {
                "source": "神仙河野久",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仰塵にはかの大匠の下畫によりて、門人等が爲上げたりといふ聖經の圖あり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の俳諧師、雪中庵の門人、四五輩。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり在来の辻斬りと同じように持ち槍の穂の冴えをためすのと、自分の腕の働きを試すのと、この二つであろうとは誰でも思い付くことであるので、江戸じゅうの槍術｜指南者やその門人たちが真っ先に眼をつけられたが、その方面では取り留めた手がかりもなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "槍突き",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七が出たあとでだんだんにその門人や知人などが寄って来たらしく、茶の間の六畳と女中部屋の三畳とに押し合って坐っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "冬の金魚",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
