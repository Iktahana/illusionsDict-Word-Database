[
  {
    "uuid": "f280b44b-e907-5c6b-b70c-a4832735c2b3",
    "entry": "門徒",
    "reading": {
      "primary": "もんと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "follower (of religion; esp. Jōdo Shinshū practitioners)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "加賀産れで丸々と克明な門徒のばアやがもご／＼云ひながら挨拶すると、井田も口の内で何か云ひながら、世話になると云ふ心を示した。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "名告るのも恥入りますが、この国は真宗門徒信仰の淵源地じゃ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした場所と、身の上では、夜中よりも人目に立たない、静な日南の隙を計って、岐路をあれからすぐ、桂谷へ行くと、浄行寺と云う門徒宗が男の寺。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "門徒宗でおあんなすったっけが、トばかりじゃ……」　と云い淀むと、堪りかねたか、蒲団の上へ、はっと突俯して泣くのであった。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、村の門徒男女大勢。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "御門徒衆、一統の男さえ立てばええわい』信徒二『そりゃまあそうや。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "御門徒衆一統の男さえ立てばええ。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こりゃ門徒一同のずんと男が立つわけじゃ』信徒四『お堂が斯う立派に出来てみると、早く中身の親鸞さまの御影像もお迎え申し、据わるところに据わって頂かんことにゃ、何となく落付きが悪い。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三井寺方の申条によれば、門徒宗の方に於て開山聖人さまの御影像を取戻し度くば、生首二つ持参いたせ。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お上人さま始め御門徒衆御一同、数ならぬ私どもまで他宗に対してどうして顔が立ちましょうか』蓮如『名誉、不名誉は言ってはいられぬ。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちの息子の源兵衛はな、門徒若衆達の寄合いの帰りに今宵は山科に来ている筈、戻りは遅うなろうも知れん。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも御門徒の一大事に就ての談合と、道々も口を酸くして聞かしてやったではないか』おくみ『それがほんとなら、大事ないけれど』源兵衛『言いがかりもいい加減にしやれ、さあ、もう夜明けも間近だ。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なあ父者、永く生きても五七十年、わし等のような素凡夫の首が、尊い御影像に換えられ、御門徒衆一統の難儀を救えるなら、願うても勤めたい親子がもうけ役。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その理由言うて聞かして親鸞影像を、なお暫らく三井寺方へ預り置かんとすれど、勢込んだる門徒衆の執心。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "心を安めよ仏子源右衛門』源右衛門（額ずきつつ）『老先短いこの年寄が、忰に代って生き永らえ、悲しいやら面目ないやら、心苦しゅうござりまするが、御門徒宗が他宗の智識に、これほどまでに褒められる手柄をしたと思えば、どうやら心が慰められます。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に四郎が不思議の神通力を現すと云う噂は、門徒の信心を強め、新たに宗門に投ずる者を次第に増さしめた。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "石山本願寺時代、信長の雄略を以てしても本願寺門徒を攻め倒すことが出来ず、十一箇年の星霜を費して、やっと媾和している。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "先祖代々からの堅い門徒で、往生の一義に於ては、若い時からしっかりとした安心を懐いて居た。",
              "citation": {
                "source": "極楽",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がその町に住まい始めた頃働いていた克明な門徒の婆さんが病室の世話をしていた。",
              "citation": {
                "source": "小さき者へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "信長が法華や門徒を虐殺しましたが、あの時代は坊さん連中が暴力を揮った最後ですから、大体、仏の予言が的中したわけであります。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "禪寺は綺麗だが、門徒寺は汚ないと昔しから言ふ通り、隆法の寺も眞宗だけに掃除が屆かないで、本堂の前だけは塵埃もないが、それは皆境内の隅々へ掃き寄せられて雜草の肥料になつてゐる。",
              "citation": {
                "source": "ごりがん",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "その教化の広大なることかくのごとしといえども、上人の死後、その門徒なる者、宗教の事につき、あえて他宗の人を殺したることなくまた殺されたることもなきは、もっぱら宗徳をもって人を化したるものと言うべし。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "本願寺さまは本願寺さまでなければならぬところを、大谷家になり、子爵と定まり、伯爵となったが、それだけでも門徒には大打撃だったのだ。",
              "citation": {
                "source": "九条武子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある年の秋の夕暮、われ独り南蛮寺の境内なる花木の茂みを歩みつつ、同じく切支丹宗門の門徒にして、さるやんごとなきあたりの夫人が、涙ながらの懺悔を思いめぐらし居たる事あり。",
              "citation": {
                "source": "るしへる",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "門徒寺と云つても檀家が一｜軒あるで無い、西本願寺派の別院並で、京都の岡崎にあるから普通には岡崎御坊で通つて居る。",
              "citation": {
                "source": "蓬生",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時｜在所の者が真言の道場であつた旧地へ肉食妻帯の門徒坊さんを入れるのは面白く無い、御寺の建つ事は結構だが何うか妻帯を為さらぬ清僧を住持にして戴きたいと掛合つた。",
              "citation": {
                "source": "蓬生",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "本堂の阿弥陀様｜計りでは此の不思議な怖ろしい宿業が除かれぬやうな気がするので、門徒宗でやかましい雑行雑修の禁制を破つて、暇があれば洛中洛外の神社仏寺へ三男を抱いて参詣した。",
              "citation": {
                "source": "蓬生",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、一家安穏のためにした信心が一向役にたたないと思ったせいか、法華気違いだった旦那が急に、門徒へ宗旨替をして、帝釈様のお掛地を川へ流すやら、七面様の御影を釜の下へ入れて焼くやら、大騒ぎをした事があるそうである。",
              "citation": {
                "source": "ひょっとこ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは今まで調べられた、どの切支丹門徒の申し条とも、全く変ったものであった。",
              "citation": {
                "source": "じゅりあの・吉助",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "村々の念仏宗旨の門徒たちが、之を発起して催したことに、後は次第になつて行つたやうだが、以前は多くは半ば職業に、半ば宗旨布教の為の念仏聖の団体が、盂蘭盆前後に頼まれてあるき、又頼まれることを予期して、檀那場になつてゐる村々を廻つたものである。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
