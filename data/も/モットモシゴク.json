    "definitions": [
      {
        "index": 1,
        "gloss": "perfectly reasonable",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
