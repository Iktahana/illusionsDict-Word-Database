        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そしてその靴底から傳はつてくるモノトナスな響が、みんなの聽覺を擽るやうに刺戟した。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月九日（水曜）　生活がモノトナスだと云うことがひどく苦しく、頭を疲らせ、仕事の量が少ない。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはモノトナスな、けれどもなつかしいリズムをもつた畳句のある童謡で、また謡の心持にしつくりと嵌つた遊戯であつた。",
              "citation": {
                "source": "田園の憂欝",
                "author": "或は病める薔薇",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとは、その点の価値が分らなかったから、彼の描く性格の単調なところ、殆どモノトナスなところ、がひどくいやでしたが。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
