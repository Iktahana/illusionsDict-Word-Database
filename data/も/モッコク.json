    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese ternstroemia (Ternstroemia gymnanthera)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三　庭木　新しい僕の家の庭には冬青、榧、木斛、かくれみの、臘梅、八つ手、五葉の松などが植わっていた。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓外の木斛の青葉が、日に照され光って、いやに中江の眼にしみた。",
              "citation": {
                "source": "立枯れ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "父はその庭石を据えなおし、椿の枝を鋏み、木斛の虫をとり、楓の枯葉をはらい、草花に肥料をやった。",
              "citation": {
                "source": "父の形見",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "重い曇り空から、細雨が粗らに落ちていて、木斛の葉も柳の葉も、夾竹桃の茂みも、しっとり濡れていたが、篠懸の葉下のベンチはまだ乾いていた。",
              "citation": {
                "source": "広場のベンチ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の木斛の葉に、雀の白い糞を見ました。",
              "citation": {
                "source": "白藤",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、庭の百日紅はまったく綺麗だ、上方が折れ朽ちてる桜の古木の横手、山茶花や木斛や木犀や檜葉などの茂みの中に、鮮紅色と白色との花が群がり咲いている。",
              "citation": {
                "source": "聖女人像",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "久保田さんは一歩半ばかりよろめいて、ひょいと向うを見ると、木斛の粗らな下枝の茂みの彼方に、高等学校の受験準備をしてる長男の洋太郎が、寝間着姿で縁側に立っていた。",
              "citation": {
                "source": "人の国",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "時節は十一月のはじめ、小春の日かげに八ツ手の花はきら／＼と輝き木斛の葉は光沢を増し楓は霜にそまり、散るべき木の葉はもう大抵ちつてしまつた後である。",
              "citation": {
                "source": "枯葉の記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬青樹、扇骨木、八ツ手、木斛なぞいう常磐木の葉が蝋細工のように輝く。",
              "citation": {
                "source": "写況雑記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "時節は十一月のはじめ、小春の日かげに八ツ手の花はきらきらと輝き木斛の葉は光沢を増し楓は霜にそまり、散るべき木の葉はもう大抵ちってしまった後である。",
              "citation": {
                "source": "枯葉の記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "松やもっこくやの庭木を愛するのがファシストならば、蔦や藤やまた朝貌、烏瓜のような蔓草を愛するのがリベラリストかもしれない。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
