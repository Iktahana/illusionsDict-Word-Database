    "definitions": [
      {
        "index": 1,
        "gloss": "to praise extravagantly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "縁起、マジナイの類は、今日少しく学問あり、知識あり、事理を解するものの、一笑に付し去りて顧みざるところなりといえども、現に御幣担ぎ連の持てはやす以上は、必ずしかるべき原因あることなるべし。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は僅に二三の京阪の新聞紙を読んで、国の中枢の崇重しもてはやす所の文章の何人の手に成るかを窺い知るに過ぎぬので、譬えば簾を隔てて美人を見るが如くである。",
              "citation": {
                "source": "鴎外漁史とは誰ぞ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "げに人傳に聞きつる如くおとなびて見え給へど、世の人の美しとてもてはやす類の姿貌にはあらざるべし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが宿は花もてはやす人もなし何にか春の訪ねきつらん　宮は涙ぐんでおしまいになって、香をとめて来つるかひなくおほかたの花の便りと言ひやなすべき　と返しを申された。",
              "citation": {
                "source": "源氏物語",
                "author": "まぼろし",
                "note": "青空文庫"
              }
            },
            {
              "text": "高潔な人間ともてはやすのも表面だけで、その実、高潔な人間を尊敬している訳ではない。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学者を国家の装飾のようにもてはやす西洋の事だから、ダヌンチオはその席に群がるすべての人から多大の尊敬と愛嬌をもって偉人のごとく取扱かわれた。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、世間がもてはやすのもあたりまえだと、自分の未熟を恥ずかしく思ったのでした。",
              "citation": {
                "source": "二人の軽業師",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともあのころは、こんな早死の才人のことを、もてはやす風潮も一方にはあった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "武隈の塙の松は有名なる奥州の歌名所で、古来人のもてはやす所である。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の前で天才が飢えて死んでも知らん顔をしているくせに、ズーッと後になるとヤイヤイもてはやす。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "という憎悪となり、やがて、満月の高慢が好かない、人が月見の何のともてはやすことが憎い――ということにまで進んで、そうして、その反動が新月を好きになることに加わって行くのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれは関東に於て、甲府百万石を賜わって国主になるなんぞと、もてはやすものもあるが、まんざらの誇張とも思われぬ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
