    "definitions": [
      {
        "index": 1,
        "gloss": "imitation (of someone, something)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
