    "definitions": [
      {
        "index": 1,
        "gloss": "(treasuring something by) never taking (it) off the premises",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "コオセットをはめてるところ………………靴下はもちろん黒檀色がいいよ、だが門外不出、自分で自分を監禁することはできないって？",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "・一人となれば風鈴の鳴る　白い花たゞ一りんの朝風のふく　とりとめもなく考へてゐる日照雨　　　改作一句・ちかく、あまりにちかくつく／＼ぼうし　八月十九日晴々として門外不出。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、蔵書家には門外不出を標榜している人が多く、自宅へ来て読むというならば読ませてやるが、貸出しはいっさい断わるというのである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、蔵書家には門外不出を標榜している人が多く、自宅へ来て読むというならば読ませて遣るが、貸出しは一切断るというのである。",
              "citation": {
                "source": "読書雑感",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○門外不出、いや不能出。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月十六日曇、晴れてお祭日和となつた、お宮の大鼓が鳴つてゐる、私は門外不出。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "文字通りに、三日間の門外不出だ、ちよつとポストまで出かけたいのだが、風がふくのでやめる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――三日間まつたく門外不出。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　十月廿二日晴、門外不出六日間、自分を見詰めつゞけてゐる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "門外不出、独臥読書。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も門外不出、終日読書。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "門外不出、終日読書。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "門外不出、終日無言。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "文字通り、門外不出だつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "門外不出、文字通りの無言行だつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "門外不出、黙然独坐の一日であつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "門外不出、自己に沈潜する。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "門外不出、漁眠洞さんからうれしいたよりがあつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も門外不出、しづかに読書をつゞける。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……門外不出、黙坐読書。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "門外不出、黙々として自己を省察した。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "門外不出、黙々黙照。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "門外不出、終日徹夜して専念に句稿を整理する、みづから選ぶ、――むつかしい／＼、つゝましくすなほに、しづかにおちついて仕事をする、善哉々々。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "門外不出、つゝましく読書、清閑を楽しんだ。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "門外不出、黙々として終日机辺を離れなかつた。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今日も門外不出、しんねりむつつりで暮らした。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "春光あまねし、自粛自戒、独を慎む、わざと澄君を訪ねないで、門外不出、清閑を楽しんだ。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "門外不出の心がまへで、独坐閑読。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "自戒自粛、昨日も今日も門外不出、ひたすら謹慎した。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙坐沈思、門外不出、――おとなりから※子五六顆、かはり夕顔二三枝頂戴する。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
