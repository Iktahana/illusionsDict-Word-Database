    "definitions": [
      {
        "index": 1,
        "gloss": "to turn a somersault",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一夜あけたら、もんどり打つて、おのれを異國人あつかひにしてしまつたこの十年來の友が憎かつた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早出の蚊を食おうとぬるい水にもんどり打つ池の真鯉――なやましく藹たけき六月の夕だ。",
              "citation": {
                "source": "汗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "里の言葉を知らぬ身も、戀には女賢うして、袖に袂に蔽ひしが、月日經つまゝ、鶴はさすがに年の功、己が頭の色や添ふ、女の乳の色づきけるに、總毛を振つて仰天し、遍く木の葉を掻搜して、男の裾を見出ししかば、ものをも言はず一嘴、引咬へて撥ね飛ばせば、美少年はもんどり打つて、天上に舞上り、雲雀の姿もなかりしとぞ。",
              "citation": {
                "source": "妙齡",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早出の蚊を食はうとぬるい水にもんどり打つ池の真鯉――なやましく※たけき六月の夕だ。",
              "citation": {
                "source": "汗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私達の腕先が襟首のあたりに懸つたかと思ふと、悲鳴を挙げて宙高くもんどり打つ赤鬼もあれば、断末魔の唸りを挙げて虚空をつかむ青鬼達が、「助けて呉れ／＼！",
              "citation": {
                "source": "武者窓日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと一処に一瞬の時も移さず宙を飛んで奴等はパツと飛び散つた、かと思ふと、てんでんに吾先きにと、或者は障子を突き抜き、或者は上りがまちからもんどり打つて転げ落ち、扉を蹴破り、一陣の突風を巻き起しながら風を喰つて一目散に逃走した。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "がつくりと片羽が折れたやうになつた大鶴は、そのままもんどり打つて投げつけられたやうに下に落ちて来たが、地べたからすれすれのところで巧に立ち直つたかと思ふと、急にまた元気よく傷つけられた片羽をばたばたさせながら、西南の方角をさして落ちのびて往つた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "と彼が叫ぶのと殆ど同時に、彼女は途中で足を滑らしながら、彼の足許へもんどり打つて落ちてきた。",
              "citation": {
                "source": "恢復期",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人、二人、三人、四人、ところが、それが、次ぎ次ぎに、もんどり打つてひつくり返る。",
              "citation": {
                "source": "かへらじと",
                "author": "日本移動演劇連盟のために",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京府下吉祥寺四八〇一千九百三十年四月槇本楠郎梟と燕と鷄ふくろは老いぼれいくぢなしお山にかくれて夜は鳴く『ぼろ着て奉公』おらイヤだつばめはハイカラ燕尾服『土喰て虫喰て口澁い』もんどり打つては空でなくにはとりや朝から聲高くまつ紅な鷄冠をふり立てて蹴爪とぎとぎ『米くれろう！",
              "citation": {
                "source": "赤い旗",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "和尚さま」　矢庭に彼はもんどり打つて、土の上にころがつてゐた。",
              "citation": {
                "source": "閑山",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、沼のふちの草原まで来ると、足がからまつて、もんどり打つてすつ転がる。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒューム管は、もんどり打つていくつかの桑の株にぶつかり、そのまゝ、闇の中へ消えた。",
              "citation": {
                "source": "山形屋の青春",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の體がもんどり打つて、原つぱから、田圃の中へ墜落する。",
              "citation": {
                "source": "麥藁帽子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "上に乘つて居た金之進が一とたまりもなく、もんどり打つて落ちるところを、喜助は下からひと思ひに突き上げたのだ」「――」「掛矢で叩き込んだやうに、刀が首筋を突拔けたのはその爲だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "御宰籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あツ」　縁側から足を踏み外して、もんどり打つて庭へ落ちるのを、浴びせて一と太刀。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "紅筆願文",
                "note": "青空文庫"
              }
            },
            {
              "text": "天魔太郎が空中にほうったモエギ色の下緒は、二ツ三ツもんどり打つとみるや、一転ごとに大きくなって、最後には三間（六メートル）あまり、青色の大蛇となり、覚心坊のやぐらにからみつき、鏡のごとき二つの目をみひらき、紅蓮のほのおをはいて、ユラユラとやぐらの頂上にはいあがるのです。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "脚から先に高くあがり、そのまま波の頂上へもんどり打つのではないかと、一瞬、錯覚が走る。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もんどり打つように西瓜と西瓜売りが前へ転んだ。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おのれッ――」と、ほとんど間髪も容れず、久助の襟がみは、その武士の迅速な手に引ッつかまれ、路傍の煮売屋の葭簀へむかって、もんどり打つばかり叩きつけられていた。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」柄がしらに小手を叩かれて、万吉はかれの足もとへもんどり打つ。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "鳴門の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "襖を取りのぞいて、お寺の本堂のやうに、だだつ広くなつたところで、もんどりうつて喜んだ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガランとした部屋の中に、たつた一人、真白な面を緊張めてくるくるともんどりうつ凄さ、可笑さ、又その心細さ、くるくると戯け廻つて居る内に生真面目な心が益落ちついて、凄まじい昼間の恐怖が腋の下から、咽喉から、臍から、素股から、足の爪先から、空一面に拡がり出す。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとどうしたことでせうか、小男は丁度電気にでもうたれたやうに、『あつ――』と小さな叫び声をあげて、もんどりうつてひつくり返りました、それからその場を転げまはつて苦しみはじめました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "靈は默つてその侮辱をうける他はなかつた…………と思ふと、久米の仙人は※を打たれた鳥のやうに、もんどりうつて小河の河つ縁に落ちて來た。",
              "citation": {
                "source": "久米の仙人",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして気の毒なほど、尖った葉っぱの上で、モジモジしたかと思うと、やがて思いきったように、一つ、クルリともんどりうつや否や、枝から枝へ、葉から葉へと、赤いまま、大きいままのお月様が、あろうことかコロコロコロコロまるで手毬のように転がり落ち出したではないか。",
              "citation": {
                "source": "三郎爺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
