        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "花道へ現れた紙屋治兵衛に「モダンボーイ」と呼びかける弥次馬の声などもただ笑って聞いてばかりもいられないような気がする。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "その點で言へば、君は僕より却つてずつとモダンボーイである。",
              "citation": {
                "source": "詩に告別した室生犀星君へ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "反對に僕の場合では、外部の趣味にハイカラやモダンが殆んどなく、生活の根柢してゐる精神にだけ、キリスト教的な西洋の蛇が食ひ込んでゐるのである。",
              "citation": {
                "source": "詩に告別した室生犀星君へ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、臥床のお蔭で文藝春秋、三田文學、中央公論、改造、話、オオル讀物、モダン日本などの十二月號、エラリイ・クイインの三作、それに土居市太郎八段から贈られた「將棋作戰學」までも讀み上げてしまつた。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "教養あり、識見ある、モダンとかゞ羨しい。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "売り手のよごれた苦いじいさんは、洋服姿のモダンボーイに変わっている。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭がわるくてブルジヨア臭いぺらぺらしたふつうのモダンボーイだと思つてゐるんだ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "相当の地位の官吏の娘と生れ、英語塾で教育を受けた彼の妻の梅子は、当時に於てはモダンにも超モダンの令嬢である筈だ。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第七一課　モダン極楽・モダン地獄　地獄、極楽とは一応、私たちの心の状態を指します。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、モダン極楽もないことはありません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モダンの淑女……きものは不斷着でも、足袋は黄色く汚れない、だぶ／＼しない皺の寄らないのにしてほしい。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時節がら、槍、白馬といへば、モダンとかいふ女でも金剛杖がひと通り。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にも、こども服のノーテイ少女、モダン仕立ノーテイ少年の、跋扈跳梁は夥多しい。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "モダンの富士｜詣でのような風をしていても、あんたがどんな人間か、眼力ひからす松王丸がちゃんと睨んでいるわ。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、京極でモダンな洋食店のメーゾン檜垣の主人もその一人であった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故、一般に東京のモダンより、上方のモダンの方が調子外れで薬が強いとされていた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お若くて、まるでモダン・ガールのようだのに大乗哲学者だなんて……」　かの女は、よく、こういう意味の言葉を他人から聞かされつけている。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは旧い貧民街を蚕食して、モダンな住宅が処々に建ちかかっているという土地柄だった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モンパルナスのキャフェ・ド・ラ・クーポールの天井や壁から折り返して来るモダンなシャンデリヤの白い光線は、仄かにもまた強烈だった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女はむす子に案内されて画商街へモダンの画を見に通った幾日かを思い起した。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "始め私は磨きの好い靴の先や洋装の裾のひらめきや、ずばずばしたもの云いに赫子を快活なフラッパーな文化的モダンガールだと思って好奇心を持った。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この近所では亀島河岸のモダン乙姫と申しております」　私の微笑は深まった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにはまたさういふモダンを取り入れて詩示することを意識した彼自らの慊厭の気持が、人を揶揄した筆つきや、どす黒い色調で観者に逆襲してゐた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "売店で、かず枝はモダン日本の探偵小説特輯号を買い、嘉七は、ウイスキイの小瓶を買った。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちかいうちには、モダン型の紙幣が出て、私たち旧式の紙幣は皆焼かれてしまうのだとかいう噂も聞きましたが、もうこんな、生きているのだか、死んでいるのだかわからないような気持でいるよりは、いっそさっぱり焼かれてしまって昇天しとうございます。",
              "citation": {
                "source": "貨幣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とみも、都会のモダンガールみたいに、へんな言葉づかいの手紙を書く、ということが、異様にもの珍らしく、なかなか笑いがとまらなかった。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
