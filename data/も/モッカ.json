[
  {
    "uuid": "a99042dd-7d0b-54fd-991e-d1e49c7b022c",
    "entry": "目下",
    "reading": {
      "primary": "もっか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
