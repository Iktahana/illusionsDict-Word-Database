        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "同じ団体にはいってヘッベルの劇場の楽屋見学をしたときは、奈落へ入り込んでモーターで廻わす廻り舞台を下から仰いだり、風の音を出す器械を操縦させてもらったりした。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場では、モーターや、ベルトや、コムベーヤーや、歯車や、旋盤や、等々が、近代的な合奏をしていた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "三台のポムプは、昼夜間断なくモーターを焼く程働き続けていた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "モーターの早い規律正しい廻転から起る音の中にはかなり純粋な楽音がいくつかある。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々実験の結果モーターの取付けに適当な弾条をつけただけで、この問題は容易に解決された。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのガソリンは、モーターに超高速度を与えて、自動車を走らせ、飛行機を飛ばせる。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "電流と磁気との基礎的な関係をゆっくり丁寧になるべく簡単な実験で十分徹底的に諒解させれば、ダイナモやモーターの色々な様式などは三文雑誌にでも譲って沢山であろう。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務長ガ無電ヲ神戸港ノ司令部ニ打ツ　兵来リテ汽車ニテ○○へ急グ　航行中ノ運送船ヨリ縄梯子ヲ降シ、モーターボートヨリ兵乗リウツル。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮肉なことには地図にないような道路は最近に出来た最も立派なモーターロードなのである。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄道省で出来た英文のモーターロードマップがあって、これは便利であるが、あまりに簡単でその道路と他の地物との関係が不明であり、また最近のところまでアップ・ツ・デートにはなっていないらしい。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし人間の寿命がモーターの回転数で計られるようになることが幸か不幸かはそれはまた別問題であろう。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "バスチアンがいきなり女を船に引きおろしておいてモーターをスタートする。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは映写機のモーターの唸音の中から格好な楽音だけをわれわれの耳に特有な抽出作用によって選び出し、そうして視覚から来る連想の誘引に応じてスクリーンの上に投射したものらしい。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸の岩の上には見事なモーターボートを納めた倉庫まで出来た。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい景色じゃないの……明日は早く起きてモーターボートで島めぐりをしてみない」「……ウウン……凪いでいたら行ってみよう」「……だけどコンナ村に住んでいる人間は可愛想なものね。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "村中を駈けずって仲間を呼び出してまわったが、その仲間の四五人が、冷酒の勢いに乗じて別荘に押しかけた時分には、若旦那夫婦と女中二人を乗せたモーターボートが、大凪の沖合はるかに、音も聞こえない処に辷っていたのであった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「東京を出てからもう二年目の秋だな」　復一は、鏡のように凪いだ夕暮前の湖面を見渡しながら、モーターボートの纜を解いた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うちの船が二三艘帰って来て、あなたが一人でもくもくへ月見にモーターで入らしってるというのよ。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は威勢よくその日傘を拡げると手を愛想に振りながら待たしてあつたモーター・ボートに乗つた。",
              "citation": {
                "source": "雪",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このスヰツチをかうすると、」などと言ひながら、あちこちのスヰツチをひねつて、モーターをぴたりと止めて見せたり、また籾殻の吹雪を現出させて見せたり、出来上りの米を瀑布のやうにざつと落下させて見せたり自由自在にその巨大な機械をあやつつて見せるのである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "モーターボートで湖を一周しようといふのである。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "右隣はモーターボートに学生風の男ばかり乗り、ビールを飲みながら近所の船の女を品藻してわい／＼騒いでいます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お秀の船宿は父親が生きている七八年前、素人の間に釣が流行り出した時分が全盛で、田舟十五六ぱいの外に荷足が三艘、それに中古のモーター船もその時代に買入れました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペンキの剥げたモーターボートなぞ誰も借りに来る客はありません。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでふだんガソリンの用意なぞはなくガソリンを自分で持って来た客だけにモーターボートを貸すことにしています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし久振りに貸手のあったモーターボートは今だに帰って来ません。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "河岸に繋いであるモーターボートを見ると、急に思い立ったものと見え、運転手に町のスタンドからガソリンを買わして来てまでして、ボートを借りて出船して行きました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お秀はさっきから二三度も土手を越し家と桟橋との間を往復して帰り舟を待ったのですが、とう／＼モーターボートの客は帰って来ません。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お秀はふと、ゆうべ到頭帰って来なかったモーターボートを思い出したらしく、ゆうべの乗船客の身元控帳を調べ始めます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやっと思って見ますと、昨日のモーターボートが帰って来ました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
