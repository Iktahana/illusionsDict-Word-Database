        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "土瓶むしの土瓶のつるを持ち上げると土瓶が横に傾いて汁がこぼれた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し分りやすく換算すれば、一秒ごとに三十五匁ないし七十匁くらいのものを一尺くらい持ち上げるのとほとんど同じくらいである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "銃は、真直に、形正しく、鼻のさきへ持ち上げることが出来なかった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一升瓶を持ち上げる）（奥田）（それを制して）いや、僕のはまだここに一ぱいあります。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲団を持ち上げるとき、よいしょ、と掛声して、はっと思った。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲団を持ち上げるとき、よいしょ、と言ったり、お掃除しながら、唐人お吉を唄うようでは、自分も、もう、だめかと思う。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その石を持ち上げると、下は深い深い穴になっていました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と若者はつば広のソンブレロを持ち上げると、ルーシィも小さな手を振った。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "その沈黙はしかし感傷的という程度であるにはあまりに長く続き過ぎたので、外界の刺激に応じて過敏なまでに満干のできる葉子の感情は今まで浸っていた痛烈な動乱から一皮一皮平調に還って、果てはその底に、こう嵩じてはいとわしいと自分ですらが思うような冷ややかな皮肉が、そろそろ頭を持ち上げるのを感じた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮田は彼女の頬を両手ではさみその美しい唇を、接吻にまで持ち上げるときのことを考えると、なやましいまでに、感情が昂奮した。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "大刀取りは左の手で右衛門の身を上へ持ち上げるようにして右足を剪いだ。",
              "citation": {
                "source": "三浦右衛門の最後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにも拘らず、彼の女の体は薄い白絹に包まれ、彼の女の手首には、恐らく象牙製と思われる腕輪が三つも重なっていて、それらは彼の女が耳なぞを掻くため、腕を持ち上げる度に、快い音響を発しつゝ、打ち合った。",
              "citation": {
                "source": "ラ氏の笛",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、飛びあがったスペイン猫、背を持ち上げると爪を磨き、威嚇するようにうなり出した。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし貴殿だけは張子房でござる」「薄ッきたない張子房で」「武田家における山本勘介」「跛者でなくてみつ口でござんす」「アッハハハ」「アッハハハ」「どっちにいたしても帷幕の謀将」正雪いよいよ持ち上げる。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、基康の持っていた清盛の教書は、成経と康頼とを天国へ持ち上げるとともに、俊寛を地獄の底へ押し落した。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "駒平が胸のところからわづか上の高さに、下から石を持ち上げるとき、彼が重さを託してゐる一枚の板は撓むかと思はれた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "セメントの俵を持ち上げることに汗を搾つてゐた駿介は、東から西へ、町へ向つて行く電車の響を聞いた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "慣れるまでは、この持ち上げる時に落葉は崩れ落ちて、何度もやり直しをしなければならぬ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "須磨子は雪国の信濃に生れただけあつて、降り積る雪を押し分けて香ぐはしい顔を持ち上げる高原の花のやうな落付と根強さとを持つてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "（１）ウントク、ウントコ、あるいはヨケナイという語が元来なんの意味か解せぬが、前語なら、ものを持ち上げるときその他の一つの掛け声である。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "地を割つて頭を持ち上げる貝割葉のころから一つとして同じものもないやうな朝顏の中には、最早三尺あまりも自然な蔓の姿を見せて、七月はじめの生氣を呼吸してゐるのもある。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "さも悪者らしく、巻煙草の横くわえで、のっそりのっそり両手をパンツの衣嚢に肩をそびやかして横行するところから、あの両肱をぐいと持ち上げる憎さげなシュラッギングまで。",
              "citation": {
                "source": "茶色っぽい町",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後で箸を持ち上げると、真赤な林檎が洋盃の底から現れたが、空中に出すと忽ち湿気を吸って、表面が真白な氷で蔽われた。",
              "citation": {
                "source": "人間灰",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、俺ら世界のプロレタリアート、ソヴェトの文化を、持ち上げるんだ。",
              "citation": {
                "source": "楽しいソヴェトの子供",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "コップを持ち上げる毎に、寛い紅い袖がずって深く白い腕が見えた。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すくつて杓子を持ち上げると、長く縷を引く。",
              "citation": {
                "source": "聖ニコラウスの夜",
                "author": "SANKT NIKOLAUS BEI DEN SCHIFFERN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私はその汚点を写真に撮って、種板を補力して焼付けてみると、果して手型に相異なく、しかも長い華奢な手で、あらゆる細部が、襞や線や指紋の一つも欠けないではっきりと現たではありませんか」「それは警官が屍体を持ち上げるときに、触ったのでしょう」と老紳士が反駁した。",
              "citation": {
                "source": "ペルゴレーズ街の殺人事件",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "起きて働くどころか足を持ち上げることさえ大儀だった……。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には私が全身の力を出してやつと持ち上げることの出来たやうな大きな重いものもあつた。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "性質が薄情残酷で、これから一寸頭を持ち上げることはあつても、また失敗して、そんなことを繰り返してる中にだんだん悪い方へ填つて行く』と言やはつたがな。",
              "citation": {
                "source": "鱧の皮",
                "author": "上司小剣",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
