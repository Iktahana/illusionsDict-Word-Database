        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "トリスタンの此の書は、彼の一生の物語である。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人はその時のことを追想して、草双紙で読んだ昔物語を、そっくり現実に経験した様だったと言ってる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし琴、生花、茶道によって教育され、和歌や昔物語によって、物のあわれの風雅を知ってた彼の妻は、良人と共に、その楽しみを別ち味わうことができた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての物語は、夫人自身の主観的の感情や解釈を通じて、実感的に話されねばならなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "病人は床に起きあがつて、殆んど例外なしに悲慘である所の、多くの天才の末路について物語つた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」けれども、私は、男女川の小説も、羽左衛門の物語も、一生涯、書く事は無いだろう。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――と、その老夫人は物語る。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に、君、――」「おい、おい」という嗄れた呼び声が馬場の物語の邪魔をした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳朶の下の方から首条にかけての皺が、慥かにもう四十代も中半を越えた私の父であることを物語つてゐた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵の詩人は、物語にゆくか感覚に堕する。",
              "citation": {
                "source": "河上に呈する詩論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとり日本の子供だけが、例外的に老成ぶつて、親父と同じやうな興味のもの――現實的で事實に即した物語や、合理性のある童話や――を悦ぶと考へられない。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば芭蕉の句で「物言へば脣寒し秋の風」蕪村の句で「負けまじき角力を寝物語かな」の類。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下樣の繩暖簾とはことかはりて、醉うても聞き苦しきいさかひはなけれど、苟めの物語も高聲になり、默してやみなんことも笑ひさざめき、座中自ら春を生ずる自らはよけれど、他人の閑を破るはにくし。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めの半分はオラーフ・トリーグヴェスソンというノルウェーの王様の一代記で、後半はやはり同じ国の王であったが、後にセント・オラーフと呼ばれた英雄の物語である。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがために物語はいっそう古雅な詩的な興趣を帯びている。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がこの物語を読んでいた時に、離れた座敷で長女がピアノの練習をやっているのが聞こえていた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピアノの音はこの物語の終わりまでつづいて行った。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "読み終わった本を枕もとへ置いて、蒲団をかぶって聞いていると、音楽の波に誘われて物語の幻は幾度となく繰り返し繰り返し現われた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地理学書でもまた物語でも読んで知っていたアトリオ・デル・カヴルロとかソマムとか、こういう名前も何となく嬉しく、また地質学者から教わる色々の岩石の名前も珍しかったと見えてよく覚えている。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯨取りもとうにもうノルウェー式か何かになってしまったはずだから、自分が父から聞いたような美しい勇ましい夢物語はやはり永久の夢物語になってしまったに相違ない。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すじ向いに座を構えたまうを帽の庇よりうかゞい奉れば、花の御かんばせすこし痩せたまいて時々小声に何をか物語りたまう双頬に薄紅さして面はゆげなり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖書や源氏物語には音はない。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚服記に就て太宰治　魚服記といふのは支那の古い書物にをさめられてゐる短かい物語の題ださうです。",
              "citation": {
                "source": "魚服記に就て",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを日本の上田秋成が飜譯して、題も夢應の鯉魚と改め、雨月物語卷の二に收録しました。",
              "citation": {
                "source": "魚服記に就て",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はせつない生活をしてゐた期間にこの雨月物語をよみました。",
              "citation": {
                "source": "魚服記に就て",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日、或る學生に次のやうなシルレルの物語詩を語つて聞かせたところ、意外なほどに、其の學生は喜んだ。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」母は、ことし六十五歳であるが、デユマや、コナン・ドイルの傳奇探偵物語の類を好むのである。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "物語を創作するといふまことに奇異なる術を體得してゐる男なのだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムカシ　ムカシノオ話ヨ　などと、間の拔けたやうな妙な聲で繪本を讀んでやりながらも、その胸中には、またおのづから別個の物語が※釀せられてゐるのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "からくみやこにたどりける、　　　芝雀は旅をものがたり、「その小屋掛けのうしろには、　　寒げなる山によきによきと、立ちし」とばかり口つぐみ、　　　とみにわらひにまぎらして、渋茶をしげにのみしてふ、　　　　そのことまことうべなれや。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
