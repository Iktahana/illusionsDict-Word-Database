        "examples": {
          "standard": [
            {
              "text": "試験開始の合図があるまで、問題用紙を裏返したまま待機するように指示された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "緊張のあまり手が震えて、問題用紙に名前を書き込むのにも苦労した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "試験終了後、問題用紙の持ち帰りが許可されたので、自宅で自己採点をすることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "あぶついて問題用紙に獅噛みついているクラスの者たちの顔を何と浅ましい顔だろうと思った途端、敵愾心がいきなり頭をもたげて、ぐっと胸を突き上げた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "泡喰って問題用紙にしがみついているクラスの者の顔を何とあさましいと見たとたん、いきなり敵愾心が頭をもたげて、ぐっと胸を突き上げた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "泡喰って問題用紙に獅噛みついているクラスの者の顔をなんと浅ましいと見た途端、いきなり敵愾心が頭をもたげて来て、ぐっと胸を突きあげた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いま給仕が問題用紙を配ります。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "問題用紙が配られた一、作文「新聞の使命に就て」二、左の語を解説せよ　Lumpen　室内楽　A la mode　Platon　そんな問題だった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "横文字を読むために問題用紙を横に動かす音が、サラサラと鳴った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
