        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "また庭に引出して水をやあびせられむかと、泣叫びてふりもぎるに、おさえたる手をゆるべず、「しっかりしろ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "また庭に引出して水をやあびせられむかと、泣叫びてふりもぎるに、おさへたる手をゆるべず、「しつかりしろ。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が口も利かないでフイと門を、人から振もぎる身躰のやうにづん／＼出掛けた。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「台湾坊主で、あの丸髷はかつらなんだ」　と言ふと、吃驚してネ、そのまゝ酔も何もさめ果てゝしまつて、「帰らう、帰らう」　と言つて、どんどん帰り仕度して、女のとめるのを振りもぎる様にして、逃げて来たことがあつたよ。",
              "citation": {
                "source": "本因坊と私",
                "author": "関根金次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、偶然のことで余に見つかると彼は、火のやうに赤くなつて、踊りの最中、相手を振りもぎるがいなや湯殿の中にかくれて、どうしても顔を現はさなかつたことがあつた。",
              "citation": {
                "source": "西瓜喰ふ人",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いてふりもぎる、拍子に体が宙がえりを打って図らず見えた腹に何か白いものがついて居る。",
              "citation": {
                "source": "樹蔭雑記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は酔っているんじゃねえぞ」　尚も管を巻くのを、洋服男は堪えかねて上衣を掴んだ手を振りもぎると、酔払いはよろ／＼とよろめいて危く転びかけたが、やっと踏み止まると、さあ承知しない。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその眼から、自分と自分を引きもぎるようにして、鈎の手の廊下で半ば離室になってる自分の室へ退いた。",
              "citation": {
                "source": "幻の彼方",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はふりもぎるように慶子の視線から顔を外らして、静に紫の壜を電気にかざして、中の溶液をも一度すかし見た。",
              "citation": {
                "source": "蘇生",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車の上から彼女が、堅く引緊めた頬に微笑を浮べて、伏目がちにこちらを透し見やった時、彼は振りもぎるような気持で、つと歩き出した。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「裏へ出るんだ」　勘兵衞は夢中になつて絡みつくお關を振りもぎる樣に焔の來る方とは反對の、北向きの腰高窓に飛び付き、障子を開けて雨戸の棧を上げましたが、どうしたことか、雨戸は糊付けになつたやうに敷居に固着して、押しても突いても、叩いてもビクともすることではありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "妾の貞操",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなら宜い』とナカ／＼現金な男さ」「塚本さん、イヨ／＼お伽噺ですよ」　と星野さんは万年筆を手にしたが、さりとて振りもぎる次第にも行かなかった。",
              "citation": {
                "source": "社長秘書",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これには何か間違ひがありませう、どうぞ――」　心配さうな顏を出す重三を振りもぎるやうに、「どうも仕方がありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "怪傳白い鼠",
                "note": "青空文庫"
              }
            },
            {
              "text": "これには何か間違いがありましょう、どうぞ――」　心配そうな顔を出す重三を振りもぎるように、「どうも仕方がありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪伝白い鼠",
                "note": "青空文庫"
              }
            },
            {
              "text": "圭子　（真青になって、ふりもぎる欣二の腕を又掴んでとめながら）あなた、欣二さん！",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや、撲ったな」　さあ米友が承知しない、両の腕に力を籠めてうんと振りもぎると、押さえていた二三人がよろよろとよろけて手を放す。",
              "citation": {
                "source": "大菩薩峠",
                "author": "東海道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お雪でなければ、まあ、くすぐったいと、はしゃいで振りもぎるところでしょう。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "信二は首すじをつかまれ、おさえつけられ、ふりもぎることができなかった。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "『よくも俺はああまで自分を卑しめることができたもんだ……大事なものから身を振りもぎることがな！",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "時としては鹿もその包まれた頭をふりもぎることがある、言いかえれば、一群の猟犬に追いつめられても逃げてしまうことがある。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
