    "definitions": [
      {
        "index": 1,
        "gloss": "monpe",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "古来からの茅葺、柾葺、杉皮葺は、とにかくとして、現在多くの民は、トタン葺の家に住み、ふろしきを被つて、もんぺいをはき、中流以下悉く粗食に甘んじてゐる、といふ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもは、もんぺを穿いて、木綿のちゃんちゃんこで居る嫁御が、その姿で、しかもそのありさまでございます。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二つ三つ田を越したところで、丁度同じ年位の娘が頬かぶりの上に笠をかぶり、「もんぺい」をはいて、膝ッ切り埋って働いているのが見えた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "訓練第四日、防空訓練もいよ／＼本格的、もんぺ部隊に感心する、青年監視人に感謝する。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして毎日、新聞で見る今日の銃後の女としての服装もエプロン姿から、たとえそれがもんぺいであろうと、作業服式のものであろうと、ひとしくりりしい裾さばきと、短くされたたもととをもって、より戦闘的な型へ進んで来ているのである。",
              "citation": {
                "source": "新しい婦人の職場と任務",
                "author": "――明日の婦人へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "高層建築が左右からそびえたって空も見えないレキシントン街を背景に、もんぺをぬいだ赤松常子参議員が、白足袋に草履の足もとも元気そうに、コート姿をはこんでいる。",
              "citation": {
                "source": "この三つのことば",
                "author": "――わたしたちは・平和を・欲している――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと政恒は薄茶がすきで、もんぺいの膝を折っては一日に何度か妻に薄茶をたてさせた。",
              "citation": {
                "source": "明治のランプ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、木綿の「裾細」（もんぺいのようで袴腰のついているもの）をはいて、膝位まである雪を踰え、友達の処へでもゆき、「此は好い本だしか。",
              "citation": {
                "source": "蠹魚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦和の方から、女子青年の娘さんたちが久留米絣の揃いの服装、もんぺに鉢巻姿で自転車にのって銀座どおりを行進して行ったのだそうだ。",
              "citation": {
                "source": "女の行進",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学報国会が大会を陸海軍軍人の演説によって開会し、出席する婦人作家はもんぺい姿を求められたというようなことは日本の文学史の惨憺たる一頁であった。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第五巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、足をばたばたさせるもんぺがある。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶色の服をきてゐたンで違ふんだが、三月の晩は、紫色の銘仙のもんぺを着てゐたンだから、違ふ事はたしかだが、時々、清子の奴、食べる事も出來ねえで、ダンスでもしてゐるんぢやアねえかと思つてね。",
              "citation": {
                "source": "なぐさめ",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷を積める車とどまり軽衿の子の歩み行く夕月夜かな　カルサンは即ち「もんぺ」で今では日本国中穿たざる女もないが、この間までは山国の女だけしかしなかつた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "その「もんぺ」を穿いた女が、着いたトラックから降りて自分だけの荷を担いで夕月の中を我が家へ帰つてゆく。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも八ヶ岳山麓の月のある夕の小景で、カルサンといふ洵に響きのよい舶来語を使つて昔のもんぺ姿を抒してゐるのが面白い。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "一緒に乗った男は、米沢人で、糸織のもんぺをはいて居た。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もんぺを着け、藁ぐつを履き、みだれる髪の毛を手拭いでうしろに縛りあげていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "やうやく像がわかるくらゐの明るさだつたが、現れる人像の一つ一つがきまつたやうに同じ服装の女ばかりで、丁度ちやんちやんこのやうな厚い感じの仕事着にもんぺをはき、手甲・脚絆をつけてゐるが、背には粗朶らしいものを負うて、鉈や鎌の類ひの物を手にさげてゐるやうであつた。",
              "citation": {
                "source": "逃げたい心",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいぶあわてたらしく、澄子さんもいいもんぺやシャツを着るのを忘れて、一等みすぼらしいもののまま焼け出されたとか。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯いかなる事ありとも、外出のときはやはりもんぺをはくべし、と命令し置く。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "行先は石の巻だ、草枝はもんぺをはいてわしといっしょに来てくれ。",
              "citation": {
                "source": "鞄らしくない鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もんぺはそこで借りりゃいいぞ」　目賀野はそういって命令を伝えると、彼自身は隣室へとびこんで、ばたりと扉を閉じた。",
              "citation": {
                "source": "鞄らしくない鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "通行人の身なりも、だいぶんかわって来て、もんぺすがたがすくなくなり、ゲートルはほとんど見えない。",
              "citation": {
                "source": "一坪館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云う声に驚いて見ると、甚五郎爺が大きな雪かきを肩にかついで、長靴を履いた上にわらぐつを履いて「もんぺ」をだぶだぶにつけて立って居る。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "スカートの代りにもんぺを用いれば靴下はいらない。",
              "citation": {
                "source": "中庸",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "防空頭巾やもんぺを作った。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もんぺをはいて防空鞄をさげ、防空頭巾やゲートルや三角巾や乾飯をその中へつめて毎日持ち歩いた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺色のもんぺの膝のところに四角い継ぎがしてあった。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のもんぺの膝のところにもつぎがあたっていた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶色のもんぺに紺色の布が黒い大きなずぶずぶした縫目であてがわれてあり、ところどころがういたりつれたりしていた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
