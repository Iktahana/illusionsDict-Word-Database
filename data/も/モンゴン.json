    "definitions": [
      {
        "index": 1,
        "gloss": "wording (esp. of written text)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
