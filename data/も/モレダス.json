          "standard": [
            {
              "text": "ガス管の小さな穴から、シューッとガスが漏れ出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "湯船からお湯がゆっくりと漏れ出して、床が濡れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "秘密の情報が、どこからか少しずつ外部に漏れ出しているらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "時折、彼、ポール・チョインスキ、及び大家のドンブロウスキは、若い紳士の部屋の上にある閉ざされたロフトから割れ目を通してそのような光が漏れ出すのを見たことがあると考えていたものの、それについては黙っていようということになっていたのだ。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "組織に漏れ出すのだろうか？",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして力なく机に両方の肱をついて、頬のやうにほのかに赤らみ、※のやうにふくらかにくびれた水蜜を手のひらにそうつとつつむやうに唇にあててその濃なはだをとほしてもれだす甘い匂をかぎながらまた新な涙を流した。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            }
          ]
