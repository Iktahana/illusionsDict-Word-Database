    "definitions": [
      {
        "index": 1,
        "gloss": "to flare up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "墓原の草の葉末を照らす燐火のように、深い噴火口の底にひらめく硫火の舌のように、ゆらゆらと燃え上がる。",
              "citation": {
                "source": "ある幻想曲の序",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山火事は谷から峰へと燃え上がるが、また上から下へも燃えて行く。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五　吼えろヴォルガ　「燃え上がるヴォルガ」（俗名、吼えろヴォルガ）を見た。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ立去りぎわに名残惜しくてや、両手もて輪をつくり、抱くように胸のあたりまで火の上にかざしつ、眼しばだたきてありしが、いざとばかり腰うちのばし、二足三足ゆかんとして立ちかえれり、燃えのこりたる木の端々を掻集めて火に加えつ、勢いよく燃え上がるを見て心地よげにうち笑みぬ。",
              "citation": {
                "source": "たき火",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな炎をあげて燃え上がるべき燃料は始めから内在しているのである。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも沸き上がり燃え上がる大地の精気が空へ空へと集注して天上ワルハラの殿堂に流れ込んでいるような感じを与える。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "走りながらもぼくは燃え上がる火から目をはなさなかった。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内に焚火は天幕の一隅に燃え付いて、天幕は鬼火のように燃え上がる。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドリアンは俄かに人生が彼に向って火の如く燃え上がるのを感じた。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くから眺めてゐると、自分の脱出して来た家に火事が起つて、見る見る燃え上がるのを、暗い山の上から瞰下すやうな心持があつた。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くから眺めていると、自分の脱けだしてきた家に火事が起って、みるみる燃え上がるのを、暗い山の上から瞰下すような心持があった。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて枯れ柴のパチパチと燃え上がる音がして来た。",
              "citation": {
                "source": "蜜柑",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この燃え上がる恋心は、突発的で移り気な少年の気まぐれではなく、強い意志と傲然とした気質を持つ、野性的でたくましい男の熱情だった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人に思う存分打ちのめされたら、自分の命は始めてほんとうに燃え上がるのだ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがこの最後によって一時なりとも美しく燃え上がるだろう。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平八郎は難波橋の南詰に床几を立てさせて、白井、橋本、其外｜若党中間を傍にをらせ、腰に附けて出た握飯を噛みながら、砲声の轟き渡り、火焔の燃え上がるのを見てゐた。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人の手をつっ突いたり、燃え上がる焔を煽いだりした。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "焔々と燃え上がる火柱が、一間の眼前にユラユラと、揺れながら立っているのであった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのしどけなさ、しどけなく乱れた裾、燃え上がる裾に、白雪と紛う腓。",
              "citation": {
                "source": "紅毛傾城",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの燃え上がるような歓喜は、艙蓋が開かれると同時に、跡方もなく砕け散ってしまいました。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よい夏だ、夏がわたしと一所に燃え上がる。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼はむく／＼と湧き立ち燃え上がる烈しい情熱に顫えずにいられなかった。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "沈着な根強い男の認識に根柢より燃え上がる女の生命が移った。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "焔は鼻の先から燃え上がる。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "白昼のように明るく燃え上がる光の中で、諏訪方にはなおも踏みとどまろうとする勇者もあり、ただ一人元の陣地に引き返して来て二発の大砲を放つものさえあった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく一同はあかあかと燃え上がる火をながめていたが、そのうちに焼餅もよい色に焦げて来る。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにはまた、あかあかと燃え上がる松薪の火を前にして、母屋を預かり顔に腕組みしている清助を見いだす。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかあかと燃え上がる炉の火が一同の顔に映るようなところで、東京の吉村さんたちのうわさがいろいろ出ましたっけ。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は、私の働きと力とをはじめて認めてくれたように、私の下で燃え上がる火のそばによってきます。",
              "citation": {
                "source": "煙突と柳",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ熱い日盛のことだから、土から熱気が火焔のやうにもえあがる。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
