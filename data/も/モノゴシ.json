    "definitions": [
      {
        "index": 1,
        "gloss": "manner",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大隅君は独り息子であるから、ずいぶん可愛がられて、十年ほど前にお母さんが死んで、それからは厳父は、何事も大隅君の気のままにさせていた様子で、謂わば、おっとりと育てられて来た人であって、大学時代にも、天鵞絨の襟の外套などを着て、その物腰も決して粗野ではなかったが、どうも、学生間の評判は悪かった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに一人物腰などからかなりの老人らしく思われるのがやって来て、私の右にしゃがんでしばらく黙って見ていたが、やがてこんな問答がはじまった。",
              "citation": {
                "source": "断片（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その物腰は武家の奉公でもしたものらしく、行儀よく疊に手をついてお辭儀してゐた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "物腰がやわらかで、無口で、そうして、ひどい泣き虫の女であった。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの娘は年齢から眼鼻立ち、背丈恰好、物腰、声音まで、死んだお熊さんに瓜二つ……と申す仔細は、ほかでも御座んせん。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "れふしたちは、平生浜べで呶鳴りあつてゐるときとは打つて変つて、馬鹿ていねいな物腰で、四角ばつて挨拶をした。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "心なしか、わたくしが、父の通夜明けの春の宵に不忍の蓮中庵ではじめて会った雛妓かの子とは、殆ど見違えるほど身体にしなやかな肉の力が盛り上り、年頃近い本然の艶めきが、坐っているだけの物腰にも紛飾を透けて浸潤んでいる。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "物腰が、鷹揚である。",
              "citation": {
                "source": "清貧譚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "てるは、その物腰の粗雑にして、言語もまた無礼きわまり、敬語の使用法など、めちゃめちゃのゆえを以て解雇されたのである。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お帳場にお待ち申しておりましたんですけれども、おかみさんが二階へ行っていいから、とそうおっしゃって下さいましたもんですから……」　と優容な物腰。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌日、まるで申し合わせたように、鈴鹿峠の麓の茶屋に柔かな物腰をおろした若い娘があった。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の長崎にて見し紅化粧したる天女たちとは事変り、その物腰のあどけなさ、顔容のうひ／＼しさ、青葉隠れの初花よりも珍らかなり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "使ひ狃れたる和尚の物腰、体の構へ、寸毫の逃るゝ隙も見えざりけり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "新子が、ハッと視線を上げると、思いがけなくも、路子の兄の準之助氏が、独り落ちつき払った愛想のいい物腰で、部屋の中へはいって来た。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校の教師か巡査かとでも云ふ物腰であつた。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の男の物腰はそれはどうしても刑事であった。",
              "citation": {
                "source": "藍瓶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどく物腰の鄭重な男に見送られて、廊下を歩きながら、豹一はあの長髪の男はたぶん昼食の時間の済むまでもう一時間待たされるだろうと思った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうもすみません、お邪魔をさせていただきます」　女はおちついた物腰であいさつをした。",
              "citation": {
                "source": "雷峯塔物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お父さん、私は不幸にして、お父さんとお母さんとに別れましたが、興哥さんとの縁が尽きないものですから、暫く夫婦になっておりました、これからは慶娘と興哥さんを夫婦にしてください、そうすれば、慶娘の病気もすぐ治ります」　こう言った慶娘の声も物腰も興娘そのままであった。",
              "citation": {
                "source": "金鳳釵記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔦代は狼狽の物腰を見せて、後ろを振り返り振り返り早足に急いだ。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴァイオレット・スミス嬢は、その夜おそく、ベーカー街にやって来たのであったが、この美しい背の高い、物腰の上品な、若い婦人に突然に来訪されて、その話を持ち出されて、懇ろに依頼されても、ホームズはその持前の柄にもなく、意外に不愛想であった。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして物腰はとても上品で、笑う時はとても気持のいい人でした。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　入ってきた男は体格のいい中背の人間で、年は三〇前後、髯はきれいに剃られているが顔色は悪く、物腰は穏やかでへりくだるようでいて、灰色の瞳は驚くほど鋭くとげとげしい。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがいつも服装と物腰に充ち満ちている、彼一流の自信と元気がない。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十三　その物腰と風采は、人形町の頃よりも、三ツ四ツ年紀もたけ、※たさも、なお増りながら、やや人に馴れ、世に馴れて、その芥溜といえりし間、浮世のなみに浮沈みの、さすらいの消息の、ほぼ伝えらるるものがあったのである。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」二十九「愛吉、愛吉、」　と二ツいって二ツ頷いた、丹平の打悄れた物腰｜挙動、いかにもいかにも約束事、と断念めたような様子であった。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の表情にも、ものごしにも、暗い、何か純粋でないものが自ら現れていた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎兵衛はそのなんだか訳のわからぬ重々しげなものごしによって多くの火消したちの信頼を得た。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "附き添う老婢のものごし、服装の工合。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大河をまへに、唇に啣えた帯留の金――手をうしろにまはして、暑さうなものごしの、なにかしら寂しさうに、きりきりと締め直す黒い繻子の一筋。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
