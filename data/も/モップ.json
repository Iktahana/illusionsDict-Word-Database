        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "不審な音に気づき、ひとりはモップ、ひとりは黒板用の大きな三角定規と、それぞれ得物らしきものをもって廊下へ出たところに、みごと錠をはずした高志が入ってきた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「モップと三角定規。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "革命的大衆団体は神奈川地方団協、全協地区委員会は湘南小地区のモップル、××組合、××××は協同して実況調査。",
              "citation": {
                "source": "大衆闘争についてのノート",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "優勢なモップが押し寄せたとなると、一溜りもなく潰れそうなのだ。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "モップル（１）に行ったら、土岐哀果の歌集「空を仰ぐ」と「現代支那語講座」が宅下げしてあるから頼むよ。",
              "citation": {
                "source": "新しき夫の愛",
                "author": "――　牢獄の夫より妻への愛の手紙　――",
                "note": "青空文庫"
              }
            },
            {
              "text": "モップルの人に、今後時々行って見てくれるように頼んで置いてくれないか。",
              "citation": {
                "source": "新しき夫の愛",
                "author": "――　牢獄の夫より妻への愛の手紙　――",
                "note": "青空文庫"
              }
            },
            {
              "text": "モップルから入れてくれたドイツ語の本は、書き入れがあるので不許可になった。",
              "citation": {
                "source": "新しき夫の愛",
                "author": "――　牢獄の夫より妻への愛の手紙　――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この衝突のときモップがついて焼打ちをやり、その罪をつまり共産党になすりつけるようなことになる。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "おねずみおばさんは　モップを　もって　あたりを　ぐるぐる。",
              "citation": {
                "source": "おねずみおばさんのはなし",
                "author": "THE TALE OF MRS. TITTLEMOUSE",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそうならば夫はモップにすぎぬ。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
