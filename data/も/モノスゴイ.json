[
  {
    "uuid": "81bb3daf-7278-5b93-b595-96df99fbd9bb",
    "entry": "物凄い",
    "reading": {
      "primary": "ものすごい",
      "alternatives": [
        "ものすっごい",
        "ものすんごい"
      ],
      "is_heteronym": false
    },
    "grammar": {
