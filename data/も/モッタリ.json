    "definitions": [
      {
        "index": 1,
        "gloss": "thickly (of whipped eggs, cream, etc.; such that it leaves a trail or forms soft peaks)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その大きさの消長するのは夏冬で雪が解けたり積もったりするためらしい。",
              "citation": {
                "source": "雪の話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔六、〕銀河ステーション　そしてジョバンニはすぐうしろの天気輪の柱がいつかぼんやりした三角標の形になって、しばらく蛍のやうに、ぺかぺか消えたりともったりしてゐるのを見ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思ったら、もう次から次から、たくさんのきいろな底をもったりんだうの花のコップが、湧くやうに、雨のやうに、眼の前を通り、三角標の列は、けむるやうに燃えるやうに、いよいよ光って立ったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、一人ずつ木からはね下りて、河原に泳ぎついて、魚を手拭につつんだり、手にもったりして、家に帰った。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年の八月にはスコットランドに旅してアルジル公の客となり、ヨットに乗って「長湖」に浮んだり、公爵の子供の時に見たという狐火（will-o'-the-wisp）の話に興味をもったりした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "六、銀河ステーション　そしてジョバンニはすぐうしろの天気輪の柱がいつかぼんやりした三角標の形になって、しばらく蛍のように、ぺかぺか消えたりともったりしているのを見ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思ったら、もう次から次から、たくさんのきいろな底をもったりんどうの花のコップが、湧くように、雨のように、眼の前を通り、三角標の列は、けむるように燃えるように、いよいよ光って立ったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "楢夫は消えたりともったりしきりにしてゐましたがだんだんそれが早くなりたうとうその変りもわからないやうになって一郎はしっかりと楢夫を抱いてゐました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　銀河ステーション　そしてジョバンニはすぐうしろの天気輪の柱がいつかぼんやりした三角標の形になって、しばらく蛍のように、ぺかぺか消えたりともったりしているのを見ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき向こうの河原のねむの木のところを大人が四人、肌ぬぎになったり、網をもったりしてこっちへ来るのでした。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなもなんだか、その男も三郎も気の毒なようなおかしながらんとした気持ちになりながら、一人ずつ木からはねおりて、河原に泳ぎついて、魚を手ぬぐいにつつんだり、手にもったりして家に帰りました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、一人づつ木からはね下りて、河原に泳ぎついて、魚を手拭につつんだり、手にもったりして、家に帰った。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うは何年か専門で勉強すればあとはゆっくりそれでくらして、酒を呑んだりうちをもったり、だんだん勉強しなくなる。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」署員たちが向ふ鉢巻をしたり棍棒をもったりしてかけ寄った。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈の工合で、白い珠の一つ一つが、それぞれ乳色に鈍く艶を消したり、うす蒼く微かな翳をもったりして、並んでいる。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「厭よ、厭よ、睡っては、こんな良い機会は、めったにないのに、睡ってばかりいちゃ厭よ」　月の面に雨雲がもったりとかかった。",
              "citation": {
                "source": "一握の髪の毛",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「執ろう、飲む者が執りましょう」　哲郎は起って女と並んだ時、爪立ちを止めた女の体がもったりと凭れて来た。",
              "citation": {
                "source": "青い紐",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏口から襷をかけて、太い腕をまくり出した女達がザルを抱えたり、葱をもったり忙がしく出入りした。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういうことを云っているかと聞いてみると、「金持が妾をおいたり、別荘をもったり贅沢三昧をしているのは、魂の安住と云うことを知らぬ哀れなことだ。",
              "citation": {
                "source": "反宗教運動とは？",
                "author": "――質問に答えて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分たちが嘗てはそのものであった学生、兄や弟や仲間たちが皆そうである学生、よろこんだり悲しんだり不幸をもったりして成長と挫折の可能の間に青春を経験しつつある外ならぬその学生としての感じが、親密に共感をもって伝えられて来ると思う。",
              "citation": {
                "source": "生態の流行",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニージュニの職人組合の長老をやり、染物工場をもったりしていた祖父は、自分の娘が一文なしの渡り者の指物師などと一緒になることを辛棒できなかったのである。",
              "citation": {
                "source": "マクシム・ゴーリキイの人及び芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "数年前に求められていたインテリ型というのはどういう実際の内容が意味されているのかはっきりしないけれども、だいたいは読書を愛したり、音楽や映画にも趣味をもったり、いろいろ人生ということについて良人とも語り合いたい心をもった若い女のことというほどのことであろう。",
              "citation": {
                "source": "若い世代の実際性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその反面、恋愛論などで婦人の精神と肉体とに非常に溌溂積極な表現を期待しているような評論家でも、そういう場面よりほかのところで女が活溌であることは何となく肯がいかねる感情をもったりして、自分の男としての情緒にそれをそのまま肯定しているのはどういうわけなのだろう。",
              "citation": {
                "source": "職業のふしぎ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小ざっぱりした平常着姿で本をもったりギターをもったりしている男女労働者に交って廊下へ出ると、つき当りは大舞台の入口だ。",
              "citation": {
                "source": "ドン・バス炭坑区の「労働宮」",
                "author": "――ソヴェト同盟の労働者はどんな文化設備をもっているか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧来の男の身勝手な生きかたと自然主義的現実曝露の気分との混淆で生きる主人公が、禅学趣味をもったり、外国小説をよんだり、自然発生の若い女らしいポーズを知的らしきもので粉飾する明子の珍しさに魅せられて、その交渉の面では受動におかれた姿が描かれている。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度往復した」「十四円じゃろ」「ああ」「――あしたは日てえ上田じゃ、電話よこしよった」「ふーん」　十九になったばかりの直二は、泥だらけのオバオールで、飯茶碗を片っ方にもったまま、箸をもっている手で汁碗を逆手にもったりして、余念なく食べている。",
              "citation": {
                "source": "猫車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
