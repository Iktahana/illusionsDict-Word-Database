[
  {
    "uuid": "ab3c8535-b18b-5ffd-bb33-65a1762d6800",
    "entry": "持ち続ける",
    "reading": {
      "primary": "もちつづける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
