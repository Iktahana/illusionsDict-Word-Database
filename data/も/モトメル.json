[
  {
    "uuid": "fcdb1756-e0c3-538b-86b2-cfbcc87f1258",
    "entry": "求める",
    "reading": {
      "primary": "もとめる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
