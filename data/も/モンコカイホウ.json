          "literary": [
            {
              "text": "家では、すっかり、門戸開放主義なの。",
              "citation": {
                "source": "操守",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "元來氏は豁達にして腹心を披くの門戸開放家にも非ず。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち夫の英獨協商の如きは亦清國の領土保全門戸開放を以て原則としたるものなりき。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来氏は豁達にして腹心を披くの門戸開放家にも非ず。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち夫の英独協商の如きは亦清国の領土保全門戸開放を以て原則としたるものなりき。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "我輩は門戸開放主義で誰とでも喜んで話をする。",
              "citation": {
                "source": "我輩は何故いつまでもすべてに於て衰えぬか",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "反対がどういう形式で現われたるかというと、即ち支那の保全、門戸開放。",
              "citation": {
                "source": "東亜の平和を論ず",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "この門戸開放という議論が何故に起るかというと、門戸を閉すものがなければこれを開放する必要が起ろう道理はない。",
              "citation": {
                "source": "東亜の平和を論ず",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            }
          ]
        }
