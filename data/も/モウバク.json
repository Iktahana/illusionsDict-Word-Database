    },
    "definitions": [
      {
        "index": 1,
        "gloss": "heavy bombing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　ちょうどそのとき、ラジオのニュースで、きょうも我が荒鷲が敵の○○飛行場を猛爆して多大の戦果を収めたことを報じた。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年九月以降のロンドン猛爆の結果より見て、今日の発達した空軍でもなお空軍による決戦戦争は不可能のようである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界中で、われわれほど毎日のように猛爆をうけている市民はいない。",
              "citation": {
                "source": "今昔ばなし抱合兵団",
                "author": "――金博士シリーズ・４――",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛爆、また猛爆、その惨状は聞くにたえないものがあった。",
              "citation": {
                "source": "今昔ばなし抱合兵団",
                "author": "――金博士シリーズ・４――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツ機必死の猛爆にも拘らず実に巧妙に、そして整然と、わがイギリス兵は本国へ帰還したと、写真入りで報道してあった。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "“首都｜重慶は、昨夜、また日本空軍のため、猛爆をうけた。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが真昼間Ｂ29一千機によるという横浜市の猛爆撃を目の前に見て以来、急に皆の気持が変ってしまった。",
              "citation": {
                "source": "小さい機縁",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
