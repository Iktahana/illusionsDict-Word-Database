    "definitions": [
      {
        "index": 1,
        "gloss": "inside the gates",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "右手に萩の園と掛札ある家を、これが百花園かと門内を覗くに、どうやら変なれば、客待ちの車夫に問うに、百花園はまだずっと先なり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを享樂しつゝ、しばらくつぶつてゐた眼を開くと、門内の前庭に焔を洗つたやうなカンナの花瓣が思ふさまその幅廣の舌を吐いてゐた。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "門の鉄扉の外側に子守が二、三人立って門内の露人の幼児と何か言葉のやりとりをしていると、玄関から逞しいロシア婦人が出て来て、逞しいむき出しの腕でその幼児を軽々と引っかかえて引込んで行った。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼頃近くになっても霜柱の消えないような玄関の前に立って呼鈴を鳴らしてもなかなかすぐには反応がなくて立往生をしていると、凜冽たる朔風は門内の凍てた鋪石の面を吹いて安物の外套を穿つのである。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）○＝（Ｆ・Ｉ）大きな門前　羽織袴の徳兵衛刀箱を持って門内へ入る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "後を追って来たふんぞり七兵衛が門内を窺う。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しも、その表に立ち止った一人の武者修業の侍（早水団九郎）　のこのこ門内へ入る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "団九郎、悠々として、門内に入る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "団九郎、例に依って、フンゾリ返って門内に入る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "本郷大学正門内の並み木の銀杏の黄葉し落葉するのにも著しい遅速がある。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の門内や玄関まで押しかけて来ない。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑くなったから門内の池の傍のベンチで休んだ。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋのをぢさんも或大名屋敷の門内に住んでゐたが、おそらく其の昔は家老とか用人とかいふ身分の人の住居であつたらう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡警は前以って、内川の云いつけでそんな奴は門内に這入らせた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "３４＝門前　坊主の案内で門内に入る善男善女達――３５＝裏口　小門から覆面の立派な侍や隠居風の町人が、続々と入って行く。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "34＝門前　坊主の案内で門内に入る善男善女達――35＝裏口　小門から覆面の立派な侍や隠居風の町人が、続々と入って行く。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかとの裏の三角形の鉄片がまず門内の敷石と摩擦してゴリゴリまたゲリゲリとすさまじい音を立てる。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方この地方には名物の夕凪の時刻に門内の広い空地の真中へ縁台のようなものを据えてそこで夕飯を食った。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の頼母しいのと、當人自慢の生白い處へ、先づ足駄をひつくりかへしたのは、門内、團右衞門とは隣合はせの當家の家老、山田宇兵衞召使ひの、葛西の飯炊。",
              "citation": {
                "source": "片しぐれ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の頼母しいのと當人自慢だけの生白い處へ、先づ足駄をひつくりかへしたのは、門内、團右衞門とは隣合はせの當家の家老、山田宇兵衞召仕への、居まはり葛西の飯炊。",
              "citation": {
                "source": "二た面",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處へ、門内の植込の木隱れに、小女がちよろ／＼と走つて出て、默つて目まぜをして、塀について此方へ、と云つた仕方で、前に立つから、ござんなれと肩を搖つて、足を上下に雀躍して導かれる、と小さき潛門の中へ引込んで、利口さうな目をぱつちりと、蒋生を熟と見て、「あの、後程、内證で御新姐さんが。",
              "citation": {
                "source": "麥搗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其口の寸法だけ真四角に門内の土が見えた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに分秒電火の働き、一散に下階へ駈下りて、先刻忍びし勝手口より、衝と門内に遁れ出づれば、米利堅産種の巨犬一頭、泰助の姿を見て、凄まじく吠え出せり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "御出入の商人、職人、盆栽のお見出しに預りたる植木屋までが、驚破鎌倉と馳参じ、玄関狭しと詰懸け詰懸け、夜一夜眠らで明くる頃、門内へ引込みたる母衣懸の人力車、彼はと見れば、こりゃどうじゃ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "麹町の華族、小浜正道氏の門内に、ひたと犬の鳴きたる夜あり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "照子は腰元を召して、「門内に変死があるというね。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――」　門内の群集を分けて車上の照子は、老婆の死骸に面を背けつ、それより深川家の式台まで矢を射るごとく乗附けて、かねて別懇のなかといい、殊に心の急きたれば、案内も謂わで夫人の居間。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜は中尊寺の門内にも咲いていた。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ござったかな、と思いながら、擽ったいような御門内の草を、密と蹈んで入りますと、春さきはさぞ綺麗でございましょう。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんか、食いもんないのか」　芝はここが気に入ったようすで、注文を出す。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
