[
  {
    "uuid": "7dd968b0-64e4-5007-8437-e27ba959506a",
    "entry": "目する",
    "reading": {
      "primary": "もくする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-特殊",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to regard (as)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "明らさまに言へば、『愛の詩集』の後半に現はれた彼の思潮とその傾向とは、私の立場からみて全く相反目する所の敵国である。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれは大正六年のことで、当時国語国文学の研究ということは非常に衰えておった時分でありまして、別に注目する人もなかったと思います。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "地殻的構造の複雑なことはまた地殻の包蔵する鉱産物の多様と豊富を意味するが、同時にまたある特殊な鉱産物に注目するときはその産出額の物足りなさを感じさせることにもなるのである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして車掌の方では鋏穴ばかりを注目するのだから止むを得ないというのである。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず試みに、子音にのみ注目するとする。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また同じレーノルズの砂の膨張性（Dilatancy）に関する研究は、その後あまり注目する人もなかったようである。",
              "citation": {
                "source": "物理学圏外の物理的現象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この問題より前にまず五官による認識の本質的特徴に注目する必要がある。",
              "citation": {
                "source": "感覚と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンナがそれに注目する。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどき味を試す為に瞑目する。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二人は胸に充実した感じを吹きさまそうとでもするように、深く息を吸い入れ暫らく沈思瞑目する。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、宗右衛門は窮屈に面をそむけるか、瞑目するかして必ずその前を通ることに極めた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜ西洋科学の中で、自分がこのように特に医学に注目するようになったか、その原因の一つは、自分の幼少のころの悲しい経験の中にもひそんでいる。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの人々を注目するのが、少年の今の最重要任務であるかの如く見えた。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人の自負は未だ舞台の広大なるに眩目する程に小心ならざる也。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "言ひ難きにあらず、発表し難きにあらず、唯だ夫れ日常思惟するところのもの極めて高潔なる事あり、極めて卑下なる事あり、自ら責め、自ら怒り、自ら笑ひ、自ら嘲り、静坐する時、瞑目する時、談笑する時、歩行する時、一々その時々の心の状あれば、その中に何事か自ら語るを快しとせざるものなき能はず。",
              "citation": {
                "source": "各人心宮内の秘宮",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "暁鴉に先ちて寝床を出で、池頭に立ちて蓮女第一回の新粧を拝せんとするの志あるもの、既に俗物を以て指目するに忍びず、然れども佳人何すれぞ無情なる、往々にして是等の風流客を追ひ回へすことあるは。",
              "citation": {
                "source": "心機妙変を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから自分は見向きもしない位であつたが自分の家では久しく「日本」をとつて居たので、この時分から少しづゝ注目するやうになる。",
              "citation": {
                "source": "竹の里人〔一〕",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "果してその言のごとくなったことを知った時、老聖人は佇立瞑目することしばし、やがて潸然として涙下った。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四、役人は、互に嫉視反目するな。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この善良な人間たちは暇に任せて象のその後の行動に注目する。",
              "citation": {
                "source": "解かれた象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからこの二人がどうして、ラルフ・スミスの親類に、熱心に注目するようになったか？",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "テキストを流し込めば、ほとんど一瞬に組版が終わる手軽さに注目するか、細かな問題点が数多く生じることを指摘するのか。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この制度調整が図られた時期にも、注目する必要がある。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "加之、この時に際し、外国の注目する所たるや、火を見るよりも明らけし。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして瞑目するまで、美しい目の視線は遠い、遠い所に注がれていて、あるいは自分の死を不幸だと感ずる余裕をも有せなかったのではあるまいか。",
              "citation": {
                "source": "安井夫人",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "晋の司馬休、敵に殺さるべきを一向気付かず、その馬食事をやめて鞍に注目するを見て乗り試むるとすなわち急に十里｜奔り、後を見れば収兵至った、かくて難を免れた酬いにその馬に揚武と加号した。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "中二は父と母とに抱かれながら瞑目する。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して世或は之を目して、之れ我等意中の事にして、未だ道破し得ざるものを、道破し得たりとて、之に雷同して、天下に外道的伝道を試みる者あり……政治上に危険なる運動は、当局者の細心に注目する所也。",
              "citation": {
                "source": "文壇一夕話",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝでは、私は専ら、文学の方法論的研究に注目することにしよう。",
              "citation": {
                "source": "エミイル・ゾラの文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに鴎外漁史に問はん、漁史は結果のみを写して原因を写さざる戯曲を称して猶ほ良好なるものと謂ふ乎、原因に注目する者を称して猶ほ偏聴の誚を免れざるものとなす乎。",
              "citation": {
                "source": "罪過論",
                "author": "石橋忍月",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
