        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だから特別の新らしい趣味で、赤城や軽井沢のやうな高原的風望を好いといふ人や、反対に少し古い趣味で塩原のやうなアカデミツクの景色――山あり、谷あり、滝あり、紅葉ありといつたやうな景色――を悦ぶやうな人や、その他特別の意味での情趣をたづねるやうな人には、伊香保はあまり好かれない温泉である。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子持山若かへる手の紅葉まで我はねもとおもふ汝は何ぞと思ふ　　　　　万葉集",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小枝の先に散り残った枯れ／＼の紅葉が目に見えぬ風にふるえ、時に蠅のような小さい虫が小春の日光を浴びて垣根の日陰を斜めに閃く。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手に手に紅葉の枝をさげた女学生の一群が目につく。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "孕の山には紅葉が見えて美しい。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝日を反映さする金茶色の唐松と、輝やく紅葉――そのくせ、もう枯れ枯れに萎び返って、葉の尖はインキを注したように、黒くなって、縮れている――で、夏ならば緑一色のちょんぼりした林が、今朝は二、三倍も広くなったような気がする。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "曙の色は林の中まで追いついて、木膠や蔦の紅葉の一枚一枚に透き徹る明る味を潮して、朝の空気は、醒めるように凛烈となった。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅葉の秋木も、一合五勺位から皆無になったが、虎杖は二つ塚側火山の側面まで生えている、それも乱れ髪のように、蓬々としている。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "木曾川は底まで澄みきつて、両岸の紅葉を映してゐる。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が此夏、鮎釣りに泳ぎ渡つた際、大きな蟻に臍を食ひつかれて愕いた、竜宮岩も紅葉の間に浮んで、静もりかへつてゐる。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "山頂近く、紺青と紫とに染められた岩の割目を綴る僅の紅葉はもう真紅に色づいてゐるが、少し下がつた水準では未だ漸く色づき初めた程であり、ずつと下の方は唯深浅さまざまの緑に染分けられ、ほんの処々に何かの黄葉を点綴してゐるだけである。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、紅葉の季節に見直すといゝかも知れない。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此邊迄來ると紅葉がもうところ斑に色付いて居る。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "細い溪流の橋の兩側と云つたやうな處のが特に紅葉が早いらしい。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの棚は普通のぶだうだが、もう一つのは山葡萄で紅葉してゐる。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂原つぱへ出ると、南を向いた丘の斜面の草原には秋草もあれば櫻の紅葉もあつたが、どうも丁度工合のいゝ處を此處だと思ひ切りにくいので、とう／＼其の原つぱを通り越して往還路へ下りてしまつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山頂近く、紺青と紫とに染められた岩の割目を綴るわずかの紅葉はもう真紅に色づいているが、少し下がった水準ではまだようやく色づき初めたほどであり、ずっと下の方はただ深浅さまざまの緑に染め分けられ、ほんのところどころに何かの黄葉を点綴しているだけである。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、紅葉の季節に見直すといいかもしれない。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は芝居で見る黙阿弥作の「蔦紅葉宇都谷峠」のあの文弥殺しの場面を憶い起して、婚約中の男女の初旅にしては主人はあまりに甘くない舞台を選んだものだと私は少し脅えながら主人のあとについて行った。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄櫨や山葡萄が紅葉しており、池には白い睡蓮が咲いている。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝展というものに対する私の心像を眺める時に先ず眼につくのはあの竹の台の桜の紅葉で、その次には会場の前に並んだ美々しい自動車の群である。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで筆を擱こうと思ってふと縁先の硝子障子から外を見ると、少しもう色付きかかった紅葉の枝に雀が一羽止ってしきりに羽根を繕っている。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅葉の葉にはスペクトラムのあらゆる光彩が躍っている。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この雀や紅葉の中へなら何時でも私の「私」を投げ込む事が出来る。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "磨かれた車窓に、西紅葉の横顔がスプリングのついた船舶に乗船する女のように輝いていた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく見ると簑は主に紅葉の葉の切れはしや葉柄を綴り集めたものらしかったが、その中に一本図抜けて長い小枝が交じっていて、その先の方は簑の尾の尖端から下へ一｜寸ほども突き出て不恰好に反りかえっていた。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今僕の眼の前の紅葉の枝に簑虫が一匹いる。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時大きなのがちょうど紅葉の葉を食っているところを見付けたが、頭をさしのべて高いところの葉を引き曲げ蚕が桑を食うと同じようにして片はしから貪り食うていた。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本、東北本線花巻駅乗換、花巻温泉紅葉館にて。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒霞渓の巌と紅葉については、土地の者の私たちよりもよその人たちの方がくわしいだろう。",
              "citation": {
                "source": "海賊と遍路",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
