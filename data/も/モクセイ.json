    "definitions": [
      {
        "index": 1,
        "gloss": "Jupiter (planet)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（大正十四年六月『木星』）",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西の方の獅子宮には白く大きな木星が屋根越しに氷のような光を投げていた。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大マルズック星（木星）が天界の牧羊者（オリオン）の境を犯せば神々の怒が降るのも、月輪の上部に蝕が現れればフモオル人が禍を蒙るのも、皆、古書に文字として誌されてあればこそじゃ。",
              "citation": {
                "source": "文字禍",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのゆふべ君のかげ消えしかなたに、さてしもや、みえそめぬ海のかなたにけふも見よ、木星の青ききらめき。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "南の空に高く、左から順にほゞ同じ位の間隔をおいて竝んでゐるのは、土星と木星と火星とであらう。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に木星の白い輝きの明るさは、燦々と、まことに四邊を拂ふばかりである。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに母の四緑木星も六白金星とは合はぬと判つた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは、地球、或はその他如何なる惑星――木星でも海王星でも――を規準としてゞも太陽系の運動を算定することはできる。",
              "citation": {
                "source": "文学の本質について（一）",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "時とすると晴れわたつた満月の夜などに水水しい木星の瞬きも光る。",
              "citation": {
                "source": "書斎と星",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "天文学者７・20（夕）　サー・ロバアート・ポールといへば愛蘭生れの名高い天文学者で、剣橋大学で天文学の講座を受持つてゐる先生だが、幾ら天文学者だからといつて、木星から高い生活費を受取る訳にも往かないので昼飯は精々手軽なところで済ませる事に決めてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "予言をしたり未来を左右したりするのに最も有効なものは、吾人が遊星と名づくる五つの星（水星、金星、火星、木星、土星）であると考えた。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀元前二〇〇〇年ころに至って、初めて、以前にあの木星の支配者であったところの、バビロンでは特別に大事な神様マルドゥクが、シンやシャマシュに取って代わり、自ら太陽神として何よりも崇ばれるようになったのである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "木星に関する同様の周期は八三太陽年である。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "真ん中が太陽、次が水星（Me）と金星（V）、それから地球（T）とその衛星（L）、その外側には火星（Ms）と二衛星、次には木星（J）とガリレオの発見した四衛星がある。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代になってから木星を巡る小衛星が更に三つ発見された。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "また火星と木星の軌道間にある多数の小遊星もやはり右旋である。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩みの遅い土星は一周に三〇年を要し、かの光り瞬く木星の軌道は一二年を要する。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "火星と金星が出会うと雨が降り、木星と水星とが出くわせば雷電風雨となる。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "一五四〇年には初めに牡羊座で日食が起り、次に天秤座で土星と火星の会合、次には獅子座で太陽と木星の会合があったが、この年の夏は珍しいほど暑気の劇烈な夏であった。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一五六三年に、土星と木星とが獅子座において、しかも蟹座のおぼろな諸星のすぐ近くで会合した、そのときにどんな影響があったかを忘れる人はあるまい。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『身体の各部分は一つ一つ特別な遊星に相応していて、たとえば温熱の源たる心臓は太陽に相応し、脳は太陰に、肝臓は木星に、腎臓は金星に、また黒い胆汁を蔵する脾臓は憂鬱の支配たる土星に、胆嚢は火星に、肺臓は水星に相応している。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "一六一〇年には木星を観測してこの遊星の衛星中の最大なもの四個を発見した。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてあたかも遊星が太陽を回ると同様な関係に、木星に近い衛星ほど回転速度が大きいことを見た。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同様にまた太陰は地球を、ガリレオの発見した木星の衛星は木星を、また太陽黒点は太陽を回っている。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『この精霊や天使等の間では、太陰やまた木星土星を巡る月、すなわち、衛星にも住民がいることは周知のことである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "木星の一日はわずかに一〇時間である。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上でまだ、当時知られていた限りのすべての衛星（土星に五個、木星に四個、それに地球の月と土星の輪がある）もまた黄道からわずかに外れた軌道を運行している。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は土星の比重が木星のよりも小さく、また木星のが地球のよりも小さいことを知っていたので、そこからして、遊星の比重はそれが太陽に近いほど一般に大きいと結論した。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "われはもくせい、ほのかなる花のさだめに、目見しらみ、うすらなやめばあまき香もつゆにしめりぬ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "もくせいもくせいがにほふよ。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
