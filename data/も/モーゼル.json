        "examples": {
          "standard": [
            {
              "text": "彼は古い軍用銃のコレクターで、特にドイツ製のモーゼルを大切にしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "冒険小説の主人公が、懐からモーゼルのピストルを取り出して敵に向けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "博物館のガラスケースの中に、歴史的な戦いで使用されたモーゼルが展示されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "尤も高等中学に居る時分に演習に往つてモーゼル銃の空撃ちをやつたことがあるが、そのほかには室内射的といふことさへ一度もやつたことがない、人が鉄砲を持つて居るのを見てさへ、何だか剣呑で不愉快な感じがする位であるから、楽しみに銃猟に出かけるなどといふことはいくらすすめられても思ひつかぬことであつた。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、プロシヤのモーゼル銃はスナイドル以上かも知れんぞ。",
              "citation": {
                "source": "風変りな決闘",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "食いものは随分まずい、酒も墺太利流に、水でも割らなければ飲めないような酸っぱい奴で、ラインやモーゼルよりも更にまずい。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "モーゼルの白｜葡萄酒をとくに好んでいた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "モーゼルはすでに一世紀余り以前に言っていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
