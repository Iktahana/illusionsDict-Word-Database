          "literary": [
            {
              "text": "「親分、申し訳ありません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとうに、申し訳ありません。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」船山「至極健康であります、その節は野戦病院で軍医殿にいろ／＼御厄介になり、申し訳ありません」庄平「健康で何よりだ、しかし、何といっても病後だからな、走ったり、無理な事をしてはいかん」船山「走らないと、軍医殿のバスを見失いそうでありましたから」一七　二条駅附近の通。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夜分遅くに申し訳ありません。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "サザランドさんが些細なことで煩わせまして申し訳ありません。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まことに申し訳ありません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "少年少女の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ、今日は、つぎつぎに急ぎの仕事が押しかけたもので、たいへん遅くなって申し訳ありません」　総監は、人ざわりのいい言葉で、老博士の機嫌をとった。",
              "citation": {
                "source": "第五氷河期",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "かような次第で、私が昨夜秋川家の塀をのり越えて人様の庭に忍び込んだのはたしかなことで申し訳ありませんけれども、やす子の死については全く存じませんです」　早川辰吉は、こう云つて不安気に一座を見渡した。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私こそ無理にお願いして申し訳ありません。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、こんなことを訊ねてお顔を紅くさせては申し訳ありませんが、これも訊問の順序として致し方ありません。",
              "citation": {
                "source": "愚人の毒",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に私は今……」「申し訳ありません。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ぶしつけなんですけど……」　ボロン氏も猫背夫人も、思い余ったというふうに、「申し訳ありませんが……ぶしつけですが……なにしろ娘が……いえ、なにその……」　と、ひたすら頼み入る、さすがのコン吉もここにおいて、憤然と蹶起し、「あの申し訳ありませんが、僕は支那人ではありません。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "謝肉祭の支那服　――地中海避寒地の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者には申し訳ありませんが、ここに一時中絶し、いずれそのうち機会を見て、中編後編を書きつづけましょう。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ浜路さんにお仙さん、ほんとに申し訳ありませんねえ」もう一度繰り返したものである。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隔壁の内側の詰物が、地下室と調理場の壁の上端まで、ずうっと焼け通っていますから」「すると、石田九万吉なる人物が、燃えぐさを持って、ヴェンチレーションの穴から、台所の天井裏へ這いこんだなどというのは、まるっきり、ないことだったんだね」「申し訳ありませんが、まァ、そういうこッてす。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐伯氏はギョッとしたように、急に顔をあげてキャラコさんのほうを眺めていたが、聴衆のほうへ向き直ると、とつぜん、「申し訳ありません。",
              "citation": {
                "source": "キャラコさん",
                "author": "蘆と木笛",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに申し訳ありません、お許し下さい』そして畳に頭をこすりつけて詫び入るのでした。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「申し訳ありません。",
              "citation": {
                "source": "処刑の話",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは我々とは違う立場に――こんな表現で申し訳ありませんが――つまり、無害な人間なのです。",
              "citation": {
                "source": "処刑の話",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの申し訳ありませんが――ドミン　はい？",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドミン　申し訳ありません、お嬢様。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘレナ　申し訳ありません、疑ったりなんかして。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドミン　申し訳ありません、この者たちは、わたしたちと同じ人間なのです。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファブリ　申し訳ありません。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ドミン　「申し訳ありませんでした、お嬢様。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この鳥には何らかの超越的なものが――つまりその――実際の所――全く存在せず――うまく表現できずに申し訳ありません――単なる地上の鳥であるということでしょうか？",
              "citation": {
                "source": "夕映えのむこうの国",
                "author": "時代を超えた童話",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムーアがいびきをひとかきして、立ちあがり、「大変申し訳ありません。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "申し訳ありませんが、あなた好みの例外は適用できません。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私が、まちがって、ちがった鉛筆を買ってきましたので、もうしわけありません。",
              "citation": {
                "source": "気にいらない鉛筆",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もうしわけありません」　おかみさんはぼうしだけ残して、オーバーなどをかかえこむと、にげるように客室をとびだして台所にもどった。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            }
          ]
        }
