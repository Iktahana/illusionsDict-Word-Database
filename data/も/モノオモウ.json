    "definitions": [
      {
        "index": 1,
        "gloss": "to worry",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうして単に雪後の春月に対して物思う姿の余情を味わえば足りるであろう。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "若干か、お銭にするだろう、と眼光｜炬のごとく、賭物の天丼を照らした意気の壮なるに似ず、いいかけて早や物思う。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなので、「人とは如何なるものであるか」との問いに対して、「人とは物思うものである」と答えるのも間違いではない。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五夜の月が、淋しく物思う地上の一人子を哀れむように照らしております。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "物思うかれの身に月日は早くたった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "物思う側の彼女をも、思われた唯一人の幸福者をも記そう。",
              "citation": {
                "source": "樋口一葉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "げに物思う折の現はまた一場の夢なりかし。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "物思う身に秋は早くも暮れて、櫟林に木枯しの寂しい冬は来た。",
              "citation": {
                "source": "駅夫日記",
                "author": "白柳秀湖",
                "note": "青空文庫"
              }
            },
            {
              "text": "前途に期待のある身に取っては物思う暇のないほど嬉しいことはない、一月も二月も夢のように過ぎて、南郊の春は早く梅も鶯もともに老いた。",
              "citation": {
                "source": "駅夫日記",
                "author": "白柳秀湖",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると私は生気なく、しみじみと物思う気持ちになる。",
              "citation": {
                "source": "悲しい誤解",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は物思う種すら与えないほど、涯しなく深く澄んでいた。",
              "citation": {
                "source": "恨なき殺人",
                "author": "宮嶋資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一首は、麗らかに照らしておる春の光の中に、雲雀が空高くのぼる、独居して、物思うとなく物思えば、悲しい心が湧くのを禁じ難い、というので、万葉集の大部分の歌が対詠歌、相待的な愬えの歌であるのに、この歌は、不思議にも独詠的な歌である。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "独物思うそゞろあるきの黄昏に、唯一つ黙って咲いて居る此花と、はからず眼を見合わす時、誰か心跳らずに居られようぞ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、このごろ再び、物思う身となりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "春雨の格子戸に渋蛇の目開きかける様子といい、長火鉢の向うに長煙管取り上げる手付きといい、物思う夕まぐれ襟に埋める頤といい、さては唯風に吹かれる鬢の毛の一筋、そら解けの帯の端にさえ、いうばかりなき風情が生ずる。",
              "citation": {
                "source": "妾宅",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅雨晴の静な午後と秋の末の薄く曇った夕方ほど物思うによい時はあるまい……。",
              "citation": {
                "source": "花火",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もせずにジリジリ衰弱するのを見てわきまえている腹立たしさにくらべれば、何かのために物思うヒマもなく疲れる方が、かえって安らかなのだ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　いつもはつぎの間に、侍女のひとり二人が寝泊りするのだけれど、ひとり夜更けに起きて物思うようになってからは、それも何かとうるさいので、このごろは遠ざけて、近くに呼びたてる人もない。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "香と花とを捧げ終って、駒井は何か物思うことあるが如く、やや離れて、天樹院の五輪塔を暫くながめておりましたが、「婆さん」　箒をつかっている婆さんを呼んで、「お前は、この天樹院様をどう思う」「天樹院様をでございますか？",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "物思うことの多い若き男女は、熊野の神前に祈って、そうしてこの車をクルクルと廻せば、待つ人の辻占になるという。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなに止めたのに――」　縁がわに坐りこむと、お通は、半日でもそうして居られた、さびしいその顔が、独りで物思うことを好むように。",
              "citation": {
                "source": "宮本武蔵",
                "author": "地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人中に座って物思うげに煙草を吸っていたのが、ブラチだった。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "物思う人「巫女が死んでいる！",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の心がこの躯を見棄てて後まで、夢に現れまたしばしばまぼろしに姿を示すのを、魂が異形に宿を移してなお存在するためと推測したのがもし自然であるならば、それを野の鳥の声｜殊に清く、人の休息しまたは静かに物思う刻限を測って、訪れ来る者に求めようとしたのも、怪しむ余地は殆とないのである。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野鳥雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときから弥生はものおもう日が多くなり。",
              "citation": {
                "source": "日本婦道記",
                "author": "風鈴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
