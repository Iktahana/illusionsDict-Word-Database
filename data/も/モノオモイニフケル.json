    "definitions": [
      {
        "index": 1,
        "gloss": "to be lost in deep thought",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
