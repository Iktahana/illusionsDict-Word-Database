[
  {
    "uuid": "b05f096e-8f2c-5a5a-95ed-d9b70b03a72f",
    "entry": "毛頭",
    "reading": {
      "primary": "もうとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(not) in the least",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いったい自分は法科などへはいってこんな俗吏になろうと云うような考えは毛頭なかった。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "御新造は驚きたるやうの惘れ顏して、夫れはまあ何の事やら、成ほどお前が伯父さんの病氣、つゞいて借金の話しも聞ましたが、今が今私しの宅から立換へようとは言はなかつた筈、それはお前が何ぞの聞違へ、私は毛頭も覺えの無き事と、これが此人の十八｜番とはてもさても情なし。",
              "citation": {
                "source": "大つごもり",
                "author": "一葉女史",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし千人針にはそんな害毒を流す恐れは毛頭なさそうである。",
              "citation": {
                "source": "千人針",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "在来のいわゆる穏健な異端でない画に対して吾人が不合理を感じないのは、そこに不合理がないという証拠では毛頭ない。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生をおもちゃにする気は毛頭ありません。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、家に火をつけて全る焼けにするとおどかされたって、議員などになる意志は毛頭なかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私はこのようなわずかの材料から語原説などを提出する意は毛頭ない。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十五万石の大目付、丸潰れと来たなあ」「それでももしや、お熊の縁談から起った意趣、遺恨じゃないかと思うて、襟半の方へ探りを入れてみると、花婿の半三郎も、今は隠居しとる父親の半左衛門夫婦も、神信心の律義者という評判に間違いないらしい」「それは毛頭間違いない。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの華族や富豪を訪問する時のような物々しい圧迫感を毛頭受けなかった処に感心して、何となくお茶の湯を習う必要を感じている処へ、頼うだお方が筆者を振り返って言った。",
              "citation": {
                "source": "お茶の湯満腹談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "家元としてコレ位出来ていればまず……なんて考え方は毛頭ない。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい意味での善良な国民、穏和な意味でのプロレタリアは、実際めいめいのまじめな仕事に真剣に従事している限り、拙速主義の疑わしい知識に飛びついて朝夕心を騒がせ気をいら立てる必要は毛頭ないのである。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこういう見方をする事がこの付け句の「鑑賞」の上に有利だというのでも毛頭ないのである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれは決して凡兆という人の特異の天分を無視してこの人をこれだけの点から非難する意では毛頭ないのである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし先生にその責任をもって行くわけでは毛頭ない。",
              "citation": {
                "source": "田丸先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからわたしは今はもう、お前達に感謝こそすれ、仇敵と思う心は毛頭もない筈ではないか。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「毛頭、お掛値はございやせん。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "及ばずながら私が光子様をお庇い申せば、夜叉、羅刹を駆集めて、あなた方と喧嘩をしてなりと毛頭御渡し申しませんが、事を好んでするではなし。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱顔、蓬なる赤毛頭、緋の衣したる山伏の扮装。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども何と仰せられましても、自分で射ち殺した覚えなぞは毛頭ございません。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それかといって今更のように叔父を憐れむ気には毛頭なれない私であった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもその面白味はあの初菊という女の胴や手が蛇のように三味線につれて、ひなひなするから面白かったんで、人情の発現として泣く了簡は毛頭なかったんです。",
              "citation": {
                "source": "虚子君へ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが彼の画風は、理窟っぽいぎすぎすしたところは毛頭ありません。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし碌でないことなど致しまする心は毛頭持ちませぬが、何とか人を困じきらせぬように、何とか御燐み下されまするのも、正しくて強い御方に、在って宜い御余裕かと存じまするが……」と、飽まで下からは出て居るが、底の心は測り難い、中々根強い言廻しに、却って激したか主人は、声の調子さえ高くなって、「何と。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "猟はこういう時だと、夜更けに、のそのそと起きて、鉄砲しらべをして、炉端で茶漬を掻っ食らって、手製の猿の皮の毛頭巾を被った。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間界の迷惑など、お心に掛けさせますには毛頭当りませぬ儀でございます。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "処へ宗八、丸官閣下お使者といたし、車を一散に乗着けまして、隣家の豆屋の女房立会い、戸を押開いて見ましたれば、いや、はや、何とも悪食がないたいた様子、お望みの猿は血を吐いて斃ち果てておりましたに毛頭相違ござりません。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、何もおれは今更お前の慈善行為にけちをつける気は、毛頭ない。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はジンメルの日記に「人は退屈か軽佻か二つのうちの一方に陥ることなくして、一方を避けることは出来ない」という言葉を見つけた時、これあるかなと快哉を叫んだくらいだから、軽佻を攻撃する気は毛頭持ち合わせていない。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に余が評論したるところの「人生」も亦た、人性とか、人情とか、生命とか云ふものには毛頭の関係も無かりしなり。",
              "citation": {
                "source": "人生の意義",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親の論法が優れていて此方が負ける、というのでは毛頭ない。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
