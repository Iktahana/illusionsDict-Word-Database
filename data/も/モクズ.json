    "definitions": [
      {
        "index": 1,
        "gloss": "scraps of seaweed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
