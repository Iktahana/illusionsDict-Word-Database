    "definitions": [
      {
        "index": 1,
        "gloss": "High Court (of Kamakura)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "左右に居流れたは検断所の司、評定衆、問注所の司、引付衆、越訴奉行、祗候人の人々で、同じくいずれも武装していた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "問注所の役人がいならぶ。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁円は、問注所から衛府を通って、御門の外へ出た。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つ二つの現われとして、公問所とか、問注所などという役所を設けた。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その願いはかえりみられず、嘆願書は問注所から突っ返され、かえって義経に対して、頼朝の不興と疑いは深まっているという噂さえ鎌倉から聞いたのである。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このうえは関東へ下って、問注所の人々をうごかすか、鎌倉殿へ直訴してもとまでの決心を仄めかした。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御城下の掟として、不審の者は、見当り次第、縛めて、問注所へ突き出す定めになっておる。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざわざ、問注所へ突き出すほどの者でもないし、斬り捨てるには愍れ過ぎる。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "何者」　と、これを問注所の白洲へ蹴落しても、当然であっていいのである。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "その高氏は、一昨年ついそこの、渡良瀬川の対岸まで帰り着いた日、執権の命をたずさえた一群の武者に待たれて、“――鎌倉問注所ノ査問ノ儀、仰セ受ケテ、申シ開キ相スム迄、国元ニ蟄居シ、慎ミ在ルベキコト”　という厳しい命を蒙ってしまったのだ。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、ふしぎなのは、この二年余、問注所から高氏への喚問すら一度も行われていないのだった。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯父上からいかなる御注意をば」「このたび、鎌倉へお入りあらば、従前とは事ちがい、ただちに問注所の控え屋敷に入って、一時、そこにて御起居あるものとか伺いまする」「む。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご幼少からお側に仕え、若殿のご気質はよく存じ上げておりますゆえ、上杉殿ほどには」「伯父上の老婆心はかたじけないが、問注所に坐った上は、出たとこ勝負と観念のほかあるまい。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "裁許橋　さきに鎌倉へついた新田義貞は、かたのごとく侍所ノ別当へ着到を告げ、同日問注所のある裁許橋の内へ入った。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "琵琶小路から西の山寄りに見えるそれも、鎌倉十橋の一つで、そこを渡った所が、すなわち問注所の一郭だった。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "問注所は、幕政下の“政所”“侍所”とならんでの鎌倉三大｜官衙の一庁である。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "御座所ちかくに、白洲をおくのはよろしくない」　要路の声から、問注所を柳営外へ移したのは、それからだといわれている。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶり海の香にひたって、まずは深々と眠るまでよ」　問注所の朝は、森閑として、小鳥のさえずりの中だった。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一だん高い正面に、問注所衆の座席やら書記机などが見える。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "――打ち見やれば、問注所執事以下の奉行人七、八名の姿が、しずしず来る。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "義貞は、反対側の杉戸から大床へはいって来て、問注所衆と“御簾ノ廂”の方へ、礼をしたのち、ぴたと座にかまえた。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "装束の両袖を大きく開いて、問注所衆の列座へ、まずうやうやしく一礼する。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "道誉もニガ笑いし、問注所衆の面々から“御簾ノ廂”の内の人まで、クツと笑いを怺えたようだった。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "高氏の言で、今、問注所のそうした空気も、ふと妙に、迷ぐらかされたのを見ると、主席の執事貞顕は、すぐその弛緩をひき緊めるべき職責に駆られていた。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "足利のせがれがよ、新田や道誉を前におき、問注所にて怯みもなく、身の科を申し開いた由は、昼、其許から聞いたが、どうも其許の話は、ただ型のごとき報告であったようだの」「はて、なにか遺漏があったとでも、仰せられますか」「そうとも。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、その沙汰は、とうに余の耳に入っていたが、高氏が問注所でなした答弁を、其許はなぜか、聞かせておらん」「は、は、は」と、守時は軽くうけて。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "先頃の問注所の対決では、“御簾ノ廂”にいて、蔭ながら高氏の挙止や態度を、つぶさに見聞きしていた守時である。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "――要するにそれもこれも、問注所裁きの結果にちがいなかった。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "高氏とは、問注所の対決以来、会っていない。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわれてみれば、往年の確執も、問注所の対決で、解決した形ではあったが、相互の胸のうちまで、きれいに、うち溶けていたわけではない。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
