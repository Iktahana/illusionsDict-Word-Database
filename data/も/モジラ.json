        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ベイコットの発見はヒトのアタマジラミがコロモジラミと雑婚して増殖力の強い子孫を得ることであった。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸の人間が衣類を着るようになって種々のアタマジラミからコロモジラミが生じた。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "原始人種にはふつうコロモジラミがいない。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "アタマジラミからコロモジラミへの発展の過程で多くの興味ある習慣の変化が生まれる。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "コロモジラミとアタマジラミは病気をヒトからヒトへ運ぶ。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらは同じ病気をヒトに起こしヒトのコロモジラミとアタマジラミによってヒトからヒトに伝播される。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分このことはエニド・ロバートソン博士が言うようにマレー半島でアタマジラミは居るがコロモジラミは居ないという事実によるのであろう。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑熱と激しい発汗はコロモジラミの増殖に不適当になるからである。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "これとは別に高温で水夫は衣服を脱ぐのでコロモジラミには不適当になったことはありそうなことである。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
