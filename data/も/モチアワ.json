    "definitions": [
      {
        "index": 1,
        "gloss": "glutinous millet (for making mochi and certain types of alcohol)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
