    "definitions": [
      {
        "index": 1,
        "gloss": "blind spot (on the retina)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "少くとも文学の中の哲学は、論理そのものの素質の中に包含せられている不用意と盲点とを油断なく点検することである。",
              "citation": {
                "source": "スフィンクス（覚書）",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "論理の中から盲点を発見する意識作業に従事することは文学者以外にないのではないかと思う。",
              "citation": {
                "source": "スフィンクス（覚書）",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろの文芸評論家に心理家の多くなって来たことも、論理のこの盲点の点検家を社会が必要として来た結果にちがいないと思うが、しかし、近年最も作家の成長力を迷わせたものも、同時に作家の内部にある自意識という武器であった。",
              "citation": {
                "source": "スフィンクス（覚書）",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら、科学性の客観的敗北は常にこの盲点を契機として行われ、しかもそれが敗北であることがどうしても自覚され得ないという危険をもっているからなのである。",
              "citation": {
                "source": "作家のみた科学者の文学的活動",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけれども、社会と文学との諸問題について、「同時代に対する少しぐらいの盲点をおかしても、むしろ現代の論理を把握する技術として、創造への道を提示する」（「批評の盲点」瀬沼茂樹）批評があってよいし、なくてはならないのは、事実ではないだろうか。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はここでいかなる天才犯人にも盲点ということのあるのに今更気がついたのだよ。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつ俺の音楽青年だつたことを知らないのだ」「やはりあれも盲点の一つかね」「うん、ともかく失敗だつたよ。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "調べはじめて間もなく、ネットスケープにはちょっとした盲点があると祝田さんは思うようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "現住所を起動機能付きで記録する「Save location といったメニューを用意しておかなかったのは、ネットスケープの盲点だな」と祝田さんは考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論それは、弛緩した心理状態にありがちな盲点現象です。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その危く見逃すところだった微細な点――云わば｜毛ほどのものとも云うものに、実を云うと、犯人の死命を制した一つの盲点があったのだよ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、それは一種脳髄上の盲点で、自分にはさほどの黄視症状も起っていないにかかわらず、当然黄視症が発していると信じてしまったのだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が、智凡尼は入るとすぐ、千手観音の画像が不気味な躍動をしているのを、発見したのだったけれども、これは屡出逢う事で、とうに脳裡の盲点になっていたのだから、当然気にしなかったと同時に、その時階下が、誰もいない空室だったと誤信してしまった。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって（八（はち）――九（く）――六（ろく）と）記憶をしいた一連のうちで、冒頭のはとくとろが、あるいは盲点を、鉄漿という観念の上に設けていたかもしれないのである。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひっそりしてはいるが、然し、それは盲点ではない。",
              "citation": {
                "source": "蛸の如きもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして例の事件は、盲点に巧みに隠蔽せられることとなった。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らが八百長だと思ったときは、案外八百長ではなく、八百長は観衆の盲点をついて巧妙に行われているようである。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "競輪の観衆は、目先の賭に盲いて、盲点が多いから、そこをついて、いくらでもダマせるのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、本当の八百長は、観衆の盲点をついて、巧妙に行われているものだ。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "大多数の人々はフォーカスで安い配当を貰って満足しており、巧妙に盲点をつかれていることに気付かないのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "包むには共同謀議が必要であって、すでに八百長を暗示している事実なのだが、包む、という策戦が、八百長としてでなく、競走の当然な策戦の一つとして観衆に認められているところにも、観衆のアマサがあり、盲点があるのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、観衆は、落車には同情的であり、落車にもいろいろの場合があることを度外視しているから、ここにも盲点がありうるのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "この犯人は極めて巧妙に刑事の盲点をついていた。",
              "citation": {
                "source": "安吾巷談",
                "author": "湯の町エレジー",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉旅館というものの宴会、酔っ払い、混雑という性格を見ぬき、万人の盲点をついて、悠々風の如くに去来していたにすぎない。",
              "citation": {
                "source": "安吾巷談",
                "author": "湯の町エレジー",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを特に指定して逐一きゝだした信玄が、然し、今日我々が歴史的に完了した姿に於て信長の評価をなしうるように、彼の人間像をつかみ得たか、然し、信玄には信長を正解し得ない盲点があった。",
              "citation": {
                "source": "織田信長",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "つらつら思うに、こういう手口こそは、むしろ専門家の盲点で、素人タンテイが一番気付きそうなことなのである。",
              "citation": {
                "source": "フシギな女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダムというものは垂直のカベで水を遮るものだと考えてハチマキに思い至らなかったところに素人の悲しい盲点があったんだね。",
              "citation": {
                "source": "フシギな女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ふたりは賓主普通の礼儀などはそっちのけで、もうてんから打ちとけて対座した。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれにはもうてんで氣が向かなくなつたんだ。",
              "citation": {
                "source": "手紙",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお、もうてんで隠そうともせず、両の目を開いている。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
