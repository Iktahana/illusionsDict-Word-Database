    "definitions": [
      {
        "index": 1,
        "gloss": "as if (something untrue were actually true)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あの、いちど落第したものですから」「はあ、芸術家ですな」にこりともせず、おちついて甘酒をひと口すすった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "文楽は学生時代にいちど見たきりで、ほとんど十年振りだったものですから、れいの栄三、文五郎たちが、その十年間に於いて、さらに驚嘆すべき程の円熟を芸の上に加えたであろうと大いに期待して出かけたわけですが、拝見するに少しも違っていない。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんの冐險が自慢になるものですか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると博士はジョバンニが挨拶に来たとでも思ったものですか　しばらくしげしげジョバンニを見てゐましたが「あなたはジョバンニさんでしたね。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にその泥岩｜層は、川の水の増すたんび、奇麗に洗われるものですから、何とも云えず青白くさっぱりしていました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし龍麿の『奥山路』については大体の性質が解ったものですから、言語学会とか、国学院大学の国語学会で紹介したこともありますが、『帝国文学』に始めて「国語仮名遣研究史上の一発見」という題で大正六年の十一月号に書いたのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、古くから日本に用いられている『韻鏡』という書物がありまして、これは古代の支那語の音を、日本の五十音図と同じ原理で、最初の子音の同じものは同じ行に、終の音の同じものは同じ段に並べて図にしたものですから、これによっても、古代支那語の音は或る程度まで知られるのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "忙しいため十分｜纏める暇もありませぬし、時間も足りなくて急いだものですから、不徹底な所があったろうと思います。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "店屋の人自身がこれはほんのその時きりのものですから永持ちはしませんよと云って断っていたそうである。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は驚いて「どうもとんだ粗相をしました」と云うと、主人は、「いや、どう致しまして、一体この置き所も悪いものですから」と云った。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "儀式には厭だから行かないが、午餐だけは断るわけにも行かないものですからね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな大勢の人の中で話をしたきりで、お互の生涯が済んだと見做されるものですか。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "別なんというものは、時間に属するものですから、あの島ではそんなものはなかったのでございます。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（勿論、あなたのところに宛てたものは一切勘定に入れませんでした、これは文字なぞではなく、ペンによる呼吸みたいなものですからね……）まあ、何といふ手紙でせう！",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁が極く明るい色に塗ってありますものですから、どんな時でも日が少しばかりは、その壁に残っていないという事はございませんの。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は一処にじっとしているとひどく不安に襲われるものですから、立上ると、まるで発作を起した女のように、部屋の中をぐるぐると廻りました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋愛過度、チタでレオ・トルストイに小説を書く方法を三万ルーブルも仕払って教ったのですが、いまの世の中で何んの役に立つものですか………。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何分相手が女だものですから、あさはかにも欲しい一念から堅い口をききましたのでしょう。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お調べはもうこんなものですか」と、庄太は酌をしながら小声で訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云ひながら、両手をあげたものですから、小さなみそさざいどもは、みんなまるでまん円になって、ぼろんと飛んでしまったのです。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがキッコは席も一番前のはじで胆取りにしてはあんまり小さく巡査にも弱かったものですからその中にはいりませんでした。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると博士はジョバンニが挨拶に来たとでも思ったものですか、しばらくしげしげジョバンニを見ていましたが「あなたはジョバンニさんでしたね。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったいそんなことがあるものですかね。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして人間の頭でそんなことがわかるものですか。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "価は惜まぬ、ね、価は惜まぬから手放さないか、と何度も言われますがね、売るものですか。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "預りものだ、手放して可いものですかい。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "謂って利益になることなら、何｜秘すものですか。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、器具も、薬品も不完全なので、満足に看護も出来ず、見殺にしたのが多いのですもの、敵情を探るなんて、なかなかどうしてそこどころまで、手が廻るものですか。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつかり夢でも視たやうで、――郡山までは一｜度行つた事があるものですから……」　園も窓を覗きながら、「しかし、何うも済みません、第一｜見た事もありませんのに、奥州二｜本松と云ふのは、昔話や何かで耳について居たものですから、夢現に最う其処を通つたやうに思つたんです。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
