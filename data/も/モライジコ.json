        "examples": {
          "standard": [
            {
              "text": "信号待ちをしていたら後ろから追突され、完全なもらい事故で車が大破した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「こっちは悪くないのに、もらい事故で保険料が上がるなんて納得いかないよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "煽り運転に巻き込まれてガードレールに激突したのは、悲惨なもらい事故だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "実際ダッシュウッド邸の女主人になれないし、メイフィールドがこれを知ったら、もらい事故だと言って、きみを捨てるよ。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
