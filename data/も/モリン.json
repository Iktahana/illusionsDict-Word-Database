[
  {
    "uuid": "e6803d56-d1c2-51bc-b3c7-48181328aa70",
    "entry": "茂林",
    "reading": {
      "primary": "もりん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
