    "definitions": [
      {
        "index": 1,
        "gloss": "freshly picked (tomato, apple, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
