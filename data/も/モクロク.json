        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "つい先日バラの苗やカンナの球根を注文するために目録を調べたときに所在をたしかめておいた某農園がここだと分かった。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その『弘仁式』は、嵯峨天皇の弘仁年間に出来たもので、今は亡びてしまいましたけれども、幸にその目録だけが遺っております。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "津田君は先達て催した作画展覧会の目録の序で自白しているように「技巧一点張主義を廃し新なる眼を開いて自然を見直し無技巧無細工の自然描写に還り」たいという考えをもっている人である。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸に岩がころがっている絵があると思って、目録を見たら「柿」としてあった。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "跡で著述目録を御覧に入れましょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "リルケの著作目録を上げますから。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏物語や枕草子などをひもといてみてもその中には「日本」のあらゆる相貌を指摘する際に参考すべき一種の目録書きが包蔵されている事を認めることができるであろう。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "短歌｜俳諧に現われる自然の風物とそれに付随する日本人の感覚との最も手近な目録索引としては俳諧歳時記がある。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "をぢさんも幾らかの目録を持つて一緒に行つた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "女はいろいろ心配をかけて気の毒であったと云って、奉書の紙につつんだ目録をくれた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐に化かされたのだろうとお亀は云ったが、ふところに入れて来た目録は木の葉ではなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふところにはやはり十両の目録包みを持っていて、すべてがこの間の話をくり返すに過ぎなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "信心者からの奉納物らしい目録包みの巻絹や巻紙や鳥や野菜や菓子折や紅白の餅なども其処らにうず高く積まれてあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤村庵というのがあって、そこには藤村氏の筆跡が壁に掛け並べてあったり、藤村文献目録なども備えてある。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめは、いくらか系統的な叙述の形式を取ろうと企てたが、それは第一困難であるのみならず、その結果はただの目録のようなものになってしまう恐れがあるので、むしろ自由に思いのままに筆を走らせることにした。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "集めた標本類は整理いたしましてから目録をつくって後ほど持って参ります。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このわなの絵は外国でも日本でも種苗目録のおしまいあたりにはきっとついていて、然も効力もあるというのにどう云うわけか一寸不思議にも思いました。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等｜夥間に結納と申すは、親々が縁を結び、媒妁人の手をもち、婚約の祝儀、目録を贈りますでござります。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "詳しい創作及び発表目録は、各年の白秋年纂『全貌』に採録してあるゆゑ、参照していただきたい。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、巻尾にこれまで発刊した私の詩集目録を添へて置いた。",
              "citation": {
                "source": "「白秋詩集」第二巻解題",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は好ましくなかったが、仕事のあいまに教えてやるのも面白いと思って、会話の目録を作らして、そのうちを少しずつと、二人がほかで習って来るナショナル読本の一と二とを読まして見ることにした。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "アダリーの身分の証明書と財産目録はやはり金井弁護士の処に在る』「そうして……そうして……」　私は真青にふるえながら古木学士の顔を見た。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "右つとめ終って後、御目録を頂戴し荒巻軍治氏（翁の令弟）に祝言を仰付られた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず平日の心得方よろしく暮し向万事質素で、門弟の引立方等が深切に行届いている段が藩公の御耳に達し、奇特に思召され、御目録の通り下し賜わり、弥々出精せよという有難きお言葉である」という御沙汰であった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この中に分類目録がありますね」　私は念のためにきいてみました。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして月曜日の十二時までに目録を私に下さいませんか。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、自分が金遣いの荒い道楽者連中のあいだでも群を抜いていたということと、あまたの新しい愚行を考え出して、ヨーロッパじゅうでもいちばん放縦な大学でその当時常に行われていた悪徳の長い目録に、かなりの増補を加えたということとを、言っておくだけにしよう。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がここに人類の災害の長い不気味な目録のなかから、これらの広大な一般的な災厄のどれよりも本質的な苦痛に満ちている、多くの個人的の実例を選びだしてもいいことは読者に告げるまでもないであろう。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　愛吉は堪えかね、堪えかねて、火の粉が入ったようにぐッとその目を圧え、「だって、だって何でさ、加茂川亘さんて――その、あの、根岸の歌の先生ね、青公家の宗匠ン許へ、お嬢さんの意趣返しに、私が暴れ込んだ時、絽の紋附と、目録の入費を現金で出しておくんなすったお嬢さんを大贔屓の――新聞社の旦那でさ。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
