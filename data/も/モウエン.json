        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "忽ち轟音とともに自動車が猛煙につつまれた。",
              "citation": {
                "source": "冬日記",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしがモトムを連れてどつかへ今すぐ移るつていうことは、あんまり角がたちますから……」　すこし言い過ぎかとは思つたけれども、彼女にしてみれば、事を早くきめてしまうのには、もうえん曲な言いまわしはしていられなかつた。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "四｜山六｜岳のお社廟を彼方に、泰山街道はもうえんえんと蟻のような参拝者の流れだった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
