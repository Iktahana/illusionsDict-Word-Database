    "definitions": [
      {
        "index": 1,
        "gloss": "to get entangled (with each other)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "葛と藤とは違った性質の蔓ではあるが、触れればもつれ合うのが元来どちらの蔓の性でもある。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の一念は、娘の一念にもつれ合う便りを与えた。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "声が形となり、形が声となり、それから一緒にもつれ合う姿を葉子は目で聞いたり耳で見たりしていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この同じ一点に向ってる丁度逆の二つの力がどのようにもつれ合うか？",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "国内国外もつれ合う潮の流れの複雑さと、主体的に日本のインテリゲンツィアをこめる全人民に民主的感覚が成熟していないことのために、難航である。",
              "citation": {
                "source": "誰のために",
                "author": "――インテリゲンツィアと民主主義の課題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "伏線に伏線が重なりもつれ合う、そして読者が五里霧中になる。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い蝶が二つもつれ合うてヒラ／＼と舞うて居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "洞ろな笑いと、訳の解らぬ絶叫と、滅茶滅茶にもつれ合う中を、六人の男女が狂態の限りを尽すのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "笑い茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "スピードメーターの針は確実に上がり、カーディガンともつれ合うやけに耳障りな風の音がスピードオーバーを告げるブザーをかき消してしまう。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると部屋の真中に、小犬の様にもつれ合う二つの肉団。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めは、その月の中の兎のように見えていた薄黒いものが、光の度を増すにつれて、もつれ合う無数の蛇に変って行った。",
              "citation": {
                "source": "悪魔の紋章",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼らは、後にその落下に斜めの・偶然の・運動を持たせなければならなくなり、さらに彼らのアトムに曲った鉤形の尾をもたせ、互いにもつれ合うことができるようにしなければならなかった。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は目の前の透明な湯の中に、浮き上った桃色の肌の上に、水晶体凝視の魔術の様に、まざまざと、もつれ合うおぞましの幻を描いていたが、その余りにも強烈な刺戟に、真蒼になって思わず飛び出す様に浴槽を出た。",
              "citation": {
                "source": "妖虫",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "褐色の昆布の大森林、嵐の森の梢がもつれ合う様に、彼等は海水の微動にそよいでいます。",
              "citation": {
                "source": "パノラマ島綺譚",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、そのドロドロの、黄に青に赤に、無数の蛇の舌ともつれ合う異形の叢をかき分けて、先にも云った幾十幾百の螢が飛びかい、電燈の光域に入るに従って、夫々の不可思議な姿を、幻燈の絵の様に現します。",
              "citation": {
                "source": "パノラマ島綺譚",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "人工｜花山の谷底、あたたかく匂やかな湯気の中で、奇怪なる花火の五色の虹を浴び、ざれ狂う二匹の獣の様に、二人の裸体がもつれ合う。",
              "citation": {
                "source": "パノラマ島綺譚",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、丁度その時、まるで申合せでもした様に、打上げられた花火の、巨大な金色の花瓣は、クッキリと黒｜天鵞絨の空を区切って、下界の花園や、泉や、そこにもつれ合う二つの肉塊を、ふりそそぐ金粉の中にとじこめて行くのでした。",
              "citation": {
                "source": "パノラマ島綺譚",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "大円球上に、死にもの狂いにもつれ合う、二つの肉塊。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その叫び声を空高く残して、もつれ合う二人は、丸屋根の上をゴロゴロと、初めはゆるやかに、徐々に加速度を増して、果ては弾丸の様な早さで、アッと思うまに、風を切って、屋根の外へと転落した。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つの真黒な怪球は、二条の赤い光を宙に交錯させつつ、もつれあうようにクルクルと廻りだした。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしと求婚者は前のように仲よくもつれあう。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "古いドームと尖塔の輪郭線が描く魅惑、もつれあう道と小路が渦巻く謎と突然の眺望、それらの醸す誘いと驚異。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六歳の伸子は、愛し、憎み、思考し、はげしくもつれあう人生を生のままに目で見、耳できき、ふれられる体の表現として、とらえられている小説にひかれた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「木内さんはさっき、女房持ちだって云ったようだな」と房二郎がきいた、「ああ、門前仲町の飲み屋でだ、ほんとかい」「それが問題さ」　寒い風が吹いていて、灯の見えない街を、二人はもつれあうように歩いていた。",
              "citation": {
                "source": "へちまの木",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜尾組と大村組との印半纏が入りみだれ、集団となった人間と声とが、インド丸の甲板上を、滑稽な交響楽になって、もつれあう。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "」うわずった少年のさけび声がして、おかあさまともつれあうようにしながら、座敷へとびこんできたのは、やっぱり信雄君でした。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどは海の底で、もつれあうタコ入道です。",
              "citation": {
                "source": "電人Ｍ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　人間と人間がもつれあうもの音、そして、「うーん……。",
              "citation": {
                "source": "おれは二十面相だ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともつれあう声の乱打ち。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
