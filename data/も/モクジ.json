[
  {
    "uuid": "2af80ae3-8d9c-5196-b45a-0a8813bf30f3",
    "entry": "目次",
    "reading": {
      "primary": "もくじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
