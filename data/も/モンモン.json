[
  {
    "uuid": "0af04c7f-c948-5e83-aeed-c03cd552c1d4",
    "entry": "悶々",
    "reading": {
      "primary": "もんもん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-たる",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "anguished",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "余は悶々として二時間を過した。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」又かと思ふと氣持が惡くなつて胸が悶々する。",
              "citation": {
                "source": "青い顏",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして眼に映る物の全てに意味があツて、疑が出て來て、氣が悶々してならぬ。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "氣が惓ンずる、悶々する、何を聞いても見ても味氣ない。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "始め何の爲に悶々するのか解らなかツたが、軈がて其の因がハツキリ頭に映ツて來る。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、何のことは無い、ガラス越に花を見るやうな心地で、毎日お房を眼前に据えて置きながら悶々してゐた。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで唯氣が悶々して、何等の踏切が付かぬ。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで是ればかりじやない、其處ら中に眼に見えぬ針があつて、始終俺をつついて、燥つかせたり、憤らせたり、悶々させたり、欝がせたりする。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の滿足に依ツて、燃えてゐた血は幾か鎭靜になツたが、氣は相變らず悶々する。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を悶々するのか自分にも能くは解らなかツたが、始終悶々する。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のものでも無い或る卑しい想念を、自分の生れつきの本性の如く誤って思い込み、悶々している気弱い人が、ずいぶん多い様子であります。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも苦しいことは、性慾ばかりが旺盛になって、明けても暮れても、セクスの観念以外に何物も考えられないほど、烈しい情火に反転｜悶々することだった。",
              "citation": {
                "source": "老年と人生",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年時代の僕は、それの焦熱地獄のベットの上で、終日反転悶々して苦しんだが、今ではもうそんな恐ろしい地獄もない。",
              "citation": {
                "source": "老年と人生",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の胸中の悶々推測る可きである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然もかれはこの物質上の貧困によつて却つて現世の念慾を絶つを得、瞑思一徹、心に無限の富を得るに至つて、彼や、人の悶々｜措く能はざる極貧の境涯に淡然として安住するを得るに至れり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらでだに悶々の情に堪えないで来たわたしのおまえに対する情熱は、ゆうべの夜中頃からいよ／＼張り膨らまり、もはや最後の手段を取らないでは居ても立ってもいられない気持になった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが自分を遂にそうと知って悶々の末、決断しておまえに恋を打ち明けたとき、おまえは呆れた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ここ肥前長崎港のただなかは長雨ぞらの幽闇に海づら鈍み、悶々と檣けぶるたたずまひ、鎖のむせび、帆のうなり、伝馬のさけび、あるはまた阿蘭船なる黒奴が気も狂ほしき諸ごゑに、硝子切る音、うち湿り――嗚呼午後七時――ひとしきり、落居ぬ騒擾。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀れなるかな、激烈なる生存競争に敗れて気息｜奄々たる、一頭の成牝若くは処女獣をさえ収め得ず、小なる小なるハーレム一つ創り得ずに止む永遠の孤独者、または昨の英雄、かつてのハーレム中の獰猛者、しかもまた老大奮わぬ今日の悶々者、かつはまた既に煩悩の兆して、未だ力弱き半成牡。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、李陵が悶々の余生を胡地に埋めようとようやく決心せざるを得なくなったころ、蘇武は、すでに久しく北海のほとりで独り羊を牧していたのである。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗人昭々トシテ我獨リ昏キガ如ク、俗人察々トシテ我獨リ悶々タリ。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この生活苦と、仁義、公儀の八釜しい憂世を三分五厘に洒落飛ばし、上は国政の不満から、下は閨中の悶々事に到るまで、他愛もなく笑い散らして死中に活あり、活中死あり、枯木に花を咲かせ、死馬に放屁せしむる底の活策略の縦横｜無礙なものがなくては、博多仁輪加の軽妙さが生きて来ないのである。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯その心の中だけで悶々と思い煩っているのであった。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからは朝になるまで、僕は悶々とのたうち回り、ああでもないこうでもない、どれも解答らしいものにはたどり着けません。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭はもんもんして手の中は熱い。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "影がさいた、もんもん。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その白犬がの、狂気になったかの、沖の方へ、世界の涯までと駈出すと思う時、水戸屋の乾の隅へ、屋根へ抜けて黄色な雲が立ちますとの、赤旗がめらめらと搦んで、真黒な煙がもんもんと天井まで上りました。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、もんもんと鳴きしづもる一万の蝉が、静かに、深く遠くシンシンとして、私の部屋に籠つてゐるのが分り初めるのであつた。",
              "citation": {
                "source": "蝉",
                "author": "――あるミザントロープの話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "不図した些細なハヅミに由つて、私の凭れる廻転椅子は、睡りのやうにユラユラと滑り出しさうになり、そして、白い空虚な部屋の中には、此処にも矢張りもんもんと滾る蝉の音が木魂してゐた。",
              "citation": {
                "source": "蝉",
                "author": "――あるミザントロープの話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だからよ、福代ちやんの旧友のあんたの歌でも聴いて、もんもんの情をお慰めなさいつてわけよ」「親切だね。",
              "citation": {
                "source": "誰でもない……自分でもない",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
