        "examples": {
          "standard": [
            {
              "text": "この皿には、新鮮な海の幸が美しく盛り合わせられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は色とりどりの野菜をサラダボウルに盛り合わせて、食卓を華やかにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "クリスマスのパーティーでは、さまざまなチーズが大きな木製のボードに盛り合わされていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "これをいかに十七字の容器に盛り合わせるかが次の問題である。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "盛物と云って、野菜や果物をもりあわせることは非常にたのしみなことであった。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
