        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "来年はどうかして合格しなければならぬと、試験度胸をこしらえるため、方々でやっている模擬試験（入学試験のまねごと）というのを度々受けたのでしたが、その翌年、本当の入学試験が来たとき、三つも中学校を受験してやはり駄目でした。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "委員をきめて、模擬試験をやるんだ。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……―幕―……　　　第二景　夢の中の模擬試験音楽。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "模擬試験場と書いてある。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "模擬試験なら、受けると自信がつくから受けてもいいんだが、どこにあるんだろうね。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが模擬試験場なんですね。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "高校三年生の二学期に行われた旺文社の模擬試験では全国で六位、東大合格率が七五パーセント以上と出た。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよロータリー式地下戦車の模擬試験だ！",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、照常様なんかはその家庭教師の模擬試験にカンニングをするんです」「ばかだなあ。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
