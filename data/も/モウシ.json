[
  {
    "uuid": "3d64d259-fb00-5d1d-b324-6678bb6c5945",
    "entry": "孟子",
    "reading": {
      "primary": "もうし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
