        "gloss": "to pile up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "日本で富士山よりも高い火山を、欠損空線を継ぎ合せ、盛り上げることによって、創造してゆく快味は、八ヶ岳高原にたたずんで、始めて得られるのである。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのにそうかと云って、洋画家で絵絹へ油絵具を塗る試みをあえてする人、日本画家でカンバスへ日本絵具を盛り上げる実験をする人がないのはむしろ不思議なくらいである。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもより深い煙を巻き上げ、医師の話すひとつひとつの奇妙な挿話を盛り上げる。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい日本画を主張する人は多い、そしてこれらの人々は洋画に刺激されて、どんどんと油絵のやうに絵の具を盛り上げるのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "画家たちは殆ど一人のこらず、紙や絹の上に実にきれいにしかも出来るだけ厚く絵の具を盛り上げることに腐心している。",
              "citation": {
                "source": "帝展を観ての感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三百文の切山椒は飯櫃の蓋に盛り上げる程あつたさうである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰れから先きに動いたともなく、二人は銀杏の傍を離れて、盛り上げるやうに白砂を敷いた道を神殿の方に歩いた。",
              "citation": {
                "source": "東光院",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "後ろに長く引くのは、板硝子のやうな航跡、その両側に船底から食み出した浪が糊を附けて硬ばつた藍色の布の襞と皺とを盛り上げる。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは、この映画のいわゆるクライマックスなので、リズムを強く高く盛り上げるのに苦労した。",
              "citation": {
                "source": "映画『新・平家物語』",
                "author": "溝口健二",
                "note": "青空文庫"
              }
            },
            {
              "text": "其間に闊葉樹が黄や紅の冴えた色を丸くこんもりと盛り上げる。",
              "citation": {
                "source": "秋の鬼怒沼",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また近く国会に提出される航空機生産法案、同保安法案などにも「できるだけその内容を盛り上げる」という話である。",
              "citation": {
                "source": "「もく星」号の謎",
                "author": "――白鳩号遭難事件を回顧して――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……青年、それに気が附き叩く手を休めて、百姓を見ている……間）百姓　……（叩き終り、散り拡がった麦を両手で掻き集め、ムシロの端を掴んで盛り上げる。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺のは又むやみと盛り上げるんだから十円や二十円では足りん。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその赤の間を、太々と豊かに白の漆喰を盛り上げるのです。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ主題を繰り返しながら、最後の一文目がけてじわじわとサスペンスを盛り上げる手法が最高です。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇野が書き出すとしたらどのあたりを突き破って出るのかと、ひまのある寝ざめの床でそれをおもうていたが、結局、今までの集大成を盛り上げるそれが一つのきっかけとなりはしないかと、会って話の工合がうまく運んだ時に進言するつもりで私はいた。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "粉飾と技巧の限りを尽して、外から美しさを盛り上げる方法だ。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の音は、マレシャルやカサドのように、決して一粒｜選りの珠玉的な甘美さを持ったものではないが、楽曲の精神を把握して、そのクライマックスに盛り上げる力にいたって、僅かにヴァイオリンのフーベルマンを以て比ぶべきだと思う。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "堆金といって模様を高く盛り上げるものや、沈金といって逆にそれを沈めたものや、また螺鈿といって貝を嵌め込んだものなどを作ります。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえ、彼は会話を盛り上げる役目を果たし、活気があるし、感性に富んでいるようにも見えた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "總じて東京の近郊は土壤が黒くて道がぬかるみで惡いが、春先き三月のはじめころになると、さすがに土の底からもりあげる春のけはひを靴の底に感じることが出來る、丘をくだる時、すこし滑りぎみな赤土の中に、吸ひこむやうな春の誘惑がある。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "（拍手）　さらにまた社会党は以上の基本方針にもとづきまして日中国交回復、正常化のために国民運動を展開し、もりあげることにいたしました。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "築城の縄取り盗み一　ここに六万五千人の人間が、地上に一｜個の建築をもりあげるため、蟻のごとく土木に蝟集している。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
