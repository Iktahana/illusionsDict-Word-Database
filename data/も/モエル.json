    "definitions": [
      {
        "index": 1,
        "gloss": "to burn",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "赤い火の燃える炉辺。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔦かずらの這う古く懐かしい家の中で、薪の燃えるストーヴの火を囲みながら、老幼男女の一家族が、祖先の画像を映す洋燈の下で、むつまじく語り合うことを言うのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした彼の寂しい心は、炉に火の燃える人の世の侘しさ、古さ、なつかしさ、暖かさ、楽しさを、慈母の懐袍のように恋い慕った。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに蕪村の俳句においては、すべてが魂の家郷を恋い、火の燃える炉辺を恋い、古き昔の子守歌と、母の懐袍を忍び泣くところの哀歌であった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "反対に蕪村は、どんな蕭条とした自然を見ても、そこに或る魂の家郷を感じ、オルゴールの鳴る人生の懐かしさと、火の燃える炉辺の暖かさとを感じている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "火赤く燃える火を見たり獸類の如く汝は沈默して言はざるかな。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ちあの蕭条たる自然の中で、たよりなき生の孤独にふるへながら、赤々と燃える焚火の前に、幼時の追懐をまどろみながら、母の懐中を恋するところの情緒である。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は荒寥とした枯木の中を、葱さげて家路に急ぐ人の姿は、さうした冬の季節の中で、ふしぎに物侘しく、孤独にふるへる生の果敢なさを感じさせ、何かしら或る暖かい、焚火の燃える家郷への、魂のノスタルヂアを追懐させる。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひらひらと紅の裙が燃える、女だ、若いぞ。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "燧の鉄と石の触れあう音、迸る火花、ホクチの燃えるかすかな囁き、附け木の燃えつくときの蒼白な焔の色と亜硫酸の臭気、こうした感覚のコムプレッキスには祖先幾百年の夢と詩が結び付いていたような気がする。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の中で火が燃えるもんか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やあ、燃える、燃える、大火事だ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という寛濶な衣であろう、それをまた……おそらく、谷初まって以来であろう、燃えるような、紫の風呂敷に包ませて、出かける。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "大裾野の草木が、めらめらと青く燃える。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛の毛色が燃えるやうに光つて見えた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思ったら、もう次から次から、たくさんのきいろな底をもったりんだうの花のコップが、湧くやうに、雨のやうに、眼の前を通り、三角標の列は、けむるやうに燃えるやうに、いよいよ光って立ったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもたしかに流れてゐたことは、二人の手首の、水にひたったとこが、少し水銀いろに浮いたやうに見え、その手首にぶっつかってできた波は、うつくしい燐光をあげて、ちらちらと燃えるやうに見えたのでもわかりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見て児童はどうして出来るかと質問したときに、教師がそれをいいかげんに答えるのはいうまでもなく悪いが、これを知っている場合に、何でもないことだ、アルコールの燃える際に生ずる水蒸気がビーカーにあたって露になって着くのだといって、あまり無造作に片づけてしまうのは面白くないと思う。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに (Skt.)jval は「燃える」である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "理論物理のような常識に遠い六かしい事を講義して、そして聴衆を酔わせ得るのは、彼自身の内部に燃える熱烈なものが流れ出るためだと云っている。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰の火鉢における効用は強い炭火を容器に密接させぬ事や炭をのせる台になる事の外に、炭が急に燃えるのを防ぎ、また熱の直接に空気へ放散するのを一部その中に貯えておく事である。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "炭の活け方には色々あるが、要するに炭を並べて真中に縦穴を作り穴の下の方に横穴を作れば全体が丁度ストーヴの煙突と同じ作用をして空気の流通を促し炭の燃えるのを助ける訳になる。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの心は恐れにふるえる、せつない、せつない、熱情のうるみに燃えるやうだ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそのときその女の燃えるやうな目ざしと、　食ひしばつてゐる白い齒とを見た。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、突然夕暮がやつて來て、公園のなかには燃えるやうな薄明を生じさせ、ゆるやかに水の漂つてゐる運河にはヴェネチア風の夢を與へ、それから戀人達には孤獨をもたらす……」",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに窓から見える病院の芝生の庭には一昨日のやうに、昨日のやうに、ぎらぎらした午後の太陽が照りつけ、處々に咲く松葉牡丹の花が陽炎の中に燃えるやうな紅を映してゐる、動く物一つない靜けさだ。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薪が燃える周囲の雪が少しばかり解けかける。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは黒い背筋の上に薄いレモン色の房々とした毛束を四つも着け、その両脇に走る美しい橙紅色の線が頭の端では燃えるような朱の色をして、そこから真黒な長い毛が突き出している。",
              "citation": {
                "source": "蜂が団子をこしらえる話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬は燃えるようなやかましさで吠えつゞけていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お日様はもえる宝石のように東の空にかかり、あらんかぎりのかがやきを悲しむ母親の木と旅にでた子どもらとに投げておやりなさいました。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
