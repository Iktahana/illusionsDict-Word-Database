    "definitions": [
      {
        "index": 1,
        "gloss": "unsatisfied",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "想像だけでは物足りない、確かな事実を捕えたいというのが学者の願である。",
              "citation": {
                "source": "天河と星の数",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦揺れの方は今日では別にこれを防ぐ工夫がないようで、物足りないが仕方がない。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが父の祖神の翁には物足りないものがあった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこれを読んだ時に何だか物足りないような気がした。",
              "citation": {
                "source": "鸚鵡のイズム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしなくてはやっぱり物足りない。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけに肩も凝らないがまたどっちもつかずで物足りない気もする。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏はいつでも頭で絵を描いているのを多とするが、しかし頭と心臓と両方が出ないとどこか物足りない。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイヨオルのものの見えないのが物足りない。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸体も美しいが、ずっと遠く離れて見ると、どこかしら、少し物足りない寂しいところがあるように感ずる。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "春ばかりでは物足りない。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり人間のあり來りの心的葛籐や、因果關係の紛糾に、ピストルだの短刀だのと單純に含ませた古い型の探偵小説では、一面に科學知識の可成り深くなつてゐる私達には物足りない。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり人間のあり來りの心的｜葛藤や、因果關係の紛糾に、ピストルだの短刀だのと單純に含ませた古い型の探偵小説では、一面に科學知識の可成り深くなつてゐる私達には物足りない。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か強い鋭い感激を與へられるやうに期待してゐた私の心は裏切られて、其處には或る物足りないやうな何物かが殘つた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、一方ではまた、反対に両側に人がいないとさびしく物足りないという人もかなりあるようである。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、話の筋が通らなくては物足りないという観客が多数にあるかもしれない。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう例はあげれば際限なくあげられるかもしれないが、しかし概して自動車の音、ピストルの響きの紋切り形があまりにうるさく幅をきかせ過ぎて物足りない。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロート張りの裸体の群れでも気のきいたところも鋭さもなくただ雑然として物足りない。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか少し物足りないような心持になって、そこらのバラックの街を歩いた。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはわれわれになんとなく物足りない感じを与える。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一方で歴史と称するものは通例王者、勝利者、支配者の歴史であって、人間の歴史としてははなはだ物足りないものである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上にあげたような一流の科学者のほかにたとえばフラマリオンやフルニエー・ダルベのような科学の普及や宣伝に貢献したよい意味でのジャーナリストもあるが、しかしそういうものは純粋の科学者から見ると、どうしても肝心のところに物足りないところのあるのはいかんともすることができない。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ一つの花はきれいであるがこのように人工的に寄せ集めたところになんとなく物足りない不自然さがあった。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それではあまりに物足りない。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもちゃその物の効果については時々教育家や心理学者の講話を新聞や雑誌で読んでみるが、具体的に何商店のどのおもちゃがいいという事を教えてくれないのは物足りない。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけに何か物足りない。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると私もそれが嬉れしいような気がして、その後はたびたび遊びに出かけて、おさよの顔を見ないと物足りないようになりました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれにしても当時耳にする機会の多かった本物の音楽に比べては到底比較にならない物足りないものだという気がした。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三色写真が絵画の複製術として物足りないごとく、蓄音機は名曲のすぐれた演奏の再現器として物足りないものである。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいて、これを省くと何となく物足りない感じがします。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、なんとなく、ものたりないな。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
