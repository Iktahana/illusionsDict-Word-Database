        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「ヤアヤア、それなる御方に物申す。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の家の主、左衛門尉渡どのに、物申す。",
              "citation": {
                "source": "袈裟の良人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "物申す」　大振袖に揚心流小太刀の名手の恐るべき腕前をかくして、殊のほか白ばくれながら訪ないました。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「物申す、義観と仰せられる方のお住居は」　微かに、部屋の中で、音がした。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「船山城中へ物申す。",
              "citation": {
                "source": "郷介法師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗黒であった谷の底ににわかに松火の光が射し、その辺りから山へかけて合図の号笛が鳴り渡り、「神保帯刀様ご嫡男、同姓市之丞様に物申す。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右京次郎の股肱の臣、筧白兵衛は群を脱け、城の大手の門へ行ったが、「城内の方々に物申す。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小笠原流に物申すぢや、聞えはしないやな。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "嫁の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "二「物申す、果合いか、ただしは喧嘩か」　声をかけると、取囲まれた若侍が、「や、闇討を、かけられました、御、御助勢を……御加勢を――」　悲痛に叫んだ。",
              "citation": {
                "source": "武道宵節句",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「出来る、迚も手に合わんぞ」　孫次郎はそう呟くと、二三間つかつかと歩み寄って、「慮外ながら物申す」　と声かけた。",
              "citation": {
                "source": "おもかげ抄",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれその口比賣歌ひて曰ひしく、山代の　筒木の宮に物申す　吾が兄の君は、涙ぐましも。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "常陸の国司維茂どのに物申す事のあって推参して候。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、傲慢不遜の大月玄蕃は、片手に木剣を引ッさげたまま、鳴りを鎮めた福知山方の桟敷に向って真ッ赤な大口を開け、矢来の果てまで届く大音声で、「やあ、松平忠房のご家中に物申す、馬扱いの儀はいざ知らず、武士の表芸たる剣道にかけては宮津京極丹後守が藩中の勝ちに極まったり。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「城方の衆へ物申すッ」　大音をはりあげて云いだした。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――城内の方へ物申す。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "『御隣家へ物申すっ』　塀際の下で、もう十内老人の声がひびいていた。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『――御隣家へ物申すっ』　と、十内はその太鼓声のことばをかさねて、『これは、浅野内匠頭が旧臣共でござる。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『――御寺内へ物申す。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしのしたことだ、わしが物申す」　すると、返辞は、足軽頭が奪い取って。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なに、物申すだと。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "はつかねずみのお宿まで、はつかねずみのお宿まで、そこで戸たたく、ものもうす。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            }
          ]
        }
