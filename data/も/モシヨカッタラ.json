        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もし良かったら離れまで一緒にお越しくだされば、きっと……」　ラルフの顔をじっと見て、言葉に詰まったようだ。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もしよかったら僕達と今日一緒に遊んで歩かないか。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしよかったら先生もお茶を召し食りに、お出でになって下さいません？",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからこんなものですけれど、もしよかったらこの部屋にお敷きになったらどうかと思って……。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私も使いがおそくなったんですが、もしよかったら自転車にお乗んなさい。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「使いがおそくなったんですが、もしよかったら自転車にお乗んなさい。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気のことには触れないようにして、例の不経済をたてに、もしよかったら実費で――全部で二十五円ばかりで――賄付にしてあげてもよいと、彼女は云い出してみた。",
              "citation": {
                "source": "変な男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしよかったら明日……」「どうしてそんなことが！",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "……どうです、もしよかったら、そのへんでビールでも……。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……でももしよかったら、今晩……、（すこし調子づいて）じつはね、さっき向うで相談したんですが、今晩、〈絲満南風太郎の参考人の会〉をやろうってことになったんです。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子は、外出のために露台のガラス戸をしめながら、「蜂谷さん、もしよかったら、またペレールへ逆もどりしましょうか」　ほかに仕方もあるまいという風に伸子は自分のまわりを見た。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしよかったら散歩に誘おうと思って来たんだけれど」　伸子は素子に待って貰い、支度をして家を出た。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしよかったら、そういう勉強もしてゆきたいと。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩波から野尻重雄という人の『農民離村の実証的研究』という本が出ていて買いましたが、統計が多くて今の私にはこなしてもらえないので、もしよかったらお送りします。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしよかったらそれをお送りします。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もしよかったら、また晩に、神様の音楽をききにいっしょに行こう。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにまた、もしよかったら僕は君を助けて強者にしたいために、やって来たんです。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしよかったら今試してみてもいいんですよ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしよかったら一日うちへ寄こしてみたらどうでしょう。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そして、定りがついたとはどういうことか、もしよかったら聞かせて頂戴」　孝之助は眼を伏せながら、おとなしく酒を受け、その盃を膳に置いた。",
              "citation": {
                "source": "竹柏記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいんだ、いいんだよ」芳造は手を振って云った、「門口まで送って帰るって云ったろう、それがつい、おばさんの顔が見たくなったもんであがり込んじまったんだ」「でも、もしよかったら」とおみきが口ごもった。",
              "citation": {
                "source": "枡落し",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしよかったら、お茶でも」「お茶を」「そして、ストーリーの話をしましょう」「ダイアモンド・ヘッドの南をぐるっとまわっていこうか」「そうしましょう」　三十分後には、ぼくたちは、ダイアモンド・ヘッドの南側から東をまわり、北側に出ていた。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが日に日にそうした疑念をおこす機会は増すばかりで、いよいよ疑う余地もなくなったので、とうとうお寺の坊さんに打ちあけ、誰でもいい正直にそのことを認めるならば、自分はこれをゆるすばかりでなく、もしよかったらその男と結婚してもよいと言った。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
