      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hasty conclusion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "気の毒だ、馬鹿だ、などといふのは、私たち俗人の勝手な盲断に過ぎない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのう新潟の砂丘で、私がひどくもったい振り、あれが佐渡だね、と早合点の指さしをして、生徒たちは、それがとんでも無い間違いだと知っていながら私が余りにも荘重な口調で盲断しているので、それを嘲笑して否定するのが気の毒になり、そうですと答えてその場を取りつくろってくれたのかも知れない。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもこの山水を贋物だと称する諸｜君子は、悉くこれを自分の負惜しみだと盲断した。",
              "citation": {
                "source": "鑑定",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗助はこの一語の中に、あらゆる自暴と自棄と、不平と憎悪と、乱倫と悖徳と、盲断と決行とを想像して、これらの一角に触れなければならないほどの坂井の弟と、それと利害を共にすべく満洲からいっしょに出て来た安井が、いかなる程度の人物になったかを、頭の中で描いて見た。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車はもうだんだん早くなって、すすきと川と、かはるがはる窓の外から光りました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらもうだんだん早くなったでせう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車はもうだんだん早くなって、すすきと川と、かわるがわる窓の外から光りました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら、もうだんだん早くなったでしょう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら、もうだんだん早くなったでしょう」さっきの老人らしい声が言いました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時はもうだんだん仕事が少くなって、又来春といふ約束で人夫もどんどん雫石から盛岡をかかって帰って行ったあとでしたし、第一これから仕事なかばでいつ深い雪がやって来るかわからなかったんですから何だか仕事するっても張りがありませんや。",
              "citation": {
                "source": "化物丁場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車はもうだんだん早くなつて、すすきと川と、かはるがはる窓の外から光りました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら、もうだんだん早くなつたでせう。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼より享くる所の静と、美と、高の感化は、世の毒舌、妄断（もうだん）、嘲罵、軽蔑をしてわれらを犯さしめず、われらの楽しき信仰を擾（みだ）るなからしむるを知ればなり。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は、これはもうだんだん時間がたつから、次の教室を案内しようかと云うのだろうと思って、ちょっとからだを動かして見せました。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の日が長いといっても、もうだんだんに暮れかかって来るのに、いつまで若い女のあとを追ってゆくでもあるまい。",
              "citation": {
                "source": "離魂病",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうだんだんに江戸に馴れて来た彼等は、去年の十一月のはじめに同じ家中の神崎郷助と茂原市郎右衛門のふたりを誘い出して、品川のある遊女屋へ遊びに行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓜の蔓に處々へ開いて行く葉の間から小さな花がぽつ／＼と見える頃になれば、瓜畑はもうだん／＼心配がありません。",
              "citation": {
                "source": "白瓜と青瓜",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時の平吉はもうだんだんに気が落ちついて来たので、あとさきを見廻しながら小声で言った。",
              "citation": {
                "source": "放し鰻",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうだんだんに夜が更けます。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらの前に燃えている焚火も、もうだんだんに消えかかって来た。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "じきにもうだんなさまがかわいくなりましてね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "山霧はもうだんだんに剥げて来ました。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子の本箱のなかには、別にハムやコオンビイフ、林檎、オレンジなどの食料品があり、もうだんだん寒くなって来たので、朝おきると顔も洗わずに、瓦斯ストオブをたきながら、軽い食事を取るのだったが、創作に悩んで来ると、庸三が邪魔になることもあった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうだんだんと夕暮になって来るのであろう。",
              "citation": {
                "source": "光の中に",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかりでちょうど百たび打った時、もうだんだん虫の鳴くような声でそれでもひいひいいっていた坊さんは、急に一声高く「ひひん。",
              "citation": {
                "source": "人馬",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうだんろの火はほそくなっていました。",
              "citation": {
                "source": "山の別荘の少年",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうだんだん夏になってくるから」　でもわたしはかれに、どうしてもこのままいなければならないと言った。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがどんな意味をもつかということは、私には計り知れないのだけれど、それでもそのことの予感はもうだんだんとつくようになっている。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "早梅や奥で機織長屋門　　　　吏明　もうだんだん少くなってしまったが、それでも古い屋敷などで長屋門を存しているところが、東京にもいくつかある。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその戴きが、すでに天秤棒をかつぎ、またはリヤカアを引張ってあるいている土地は、もうだんだんと多くなっているのである。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
