[
  {
    "uuid": "94d2175b-6c58-5185-beef-d51e9c81632a",
    "entry": "盲断",
    "reading": {
      "primary": "もうだん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
