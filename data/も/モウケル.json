    "definitions": [
      {
        "index": 1,
        "gloss": "to prepare",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "といふ制限を設けることから、翻訳の可能を説く人がある。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、個人が頼りにならないとすれば、政府の法令によって永久的の対策を設けることは出来ないものかと考えてみる。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）「悲歌」においては、生の肯定と死の肯定とが一つのものとなつて表示されてをります、その一方のもののみを他方のものなしに認めることは、我々がいま此處でそれを明らかにするやうに、すべての無限なるものを遂に閉め出してしまふやうな限界を設けることであります。",
              "citation": {
                "source": "ドゥイノ悲歌",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "歳のうちのある特定の日を限って「節約デー」を設けるという事は、従来の多くの日には節約をしていないか、もしくは濫費をしていたという事である。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じような例を挙げると、年中怠けてばかりいる学生が、一年に一日「勉強デー」を設けるのや、あるいは平生悪い事ばかりしている男が、稀に「善行デー」を設けるのと同じような事で、それも一応は誠にいい事だと思われる。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "法医工文理農あらゆる学問の小売部を設けることである。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府でも火災の軽減を講究する学術的機関を設ける必要のあることは前述のとおりであるが、民衆一般にももう少し火災に関する科学的知識を普及させるのが急務であろうと思われる。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪い心境ということについては二つの仮説を設けることが出来ます。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより、藩内の各地は頻りに造林につとめ、百有余所の大藩有林を設けるに及んだ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "至つて軽口の、捌けた、竹を割つた様な気象で、甚人に対しても牆壁を設ける事をしない。",
              "citation": {
                "source": "刑余の叔父",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月ばかり給金の借のあるのが、同じく三月ほど滞った、差配で借りた屋号の黒い提灯を袖に引着けて待設ける。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は言われた――西洋の修道院で設けるような厚い壁と、眼よりしか見えない穴窓という趣向より、この方が距てる力は心理的に喰い込んで、しんねり強いです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰度その頃、「現代公論」という政治雑誌が文芸欄を設けることになり、記者を募集しているのを新聞広告で知り、ことによったらと思って応募して見たらうまくパスし、探訪や編輯をやらされ、翌年の春まではそっちで食べていたようなものの、結局、得るところは四つか五つかの短篇を書き得たに過ぎなかった。",
              "citation": {
                "source": "骨を削りつつ歩む",
                "author": "――文壇苦行記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに右に引いた枝珊瑚珠の卷一をみると「惣別何にてもはやり事をし出せば設ける物也、織物にさへイチノヤ織サンヤレ織云々」とある。",
              "citation": {
                "source": "女順禮",
                "author": "並にサンヤレの事",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、それではいつまでも何も仕事が出来ないので、某所に秘密の仕事部屋を設ける事にしたのである。",
              "citation": {
                "source": "朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし南風氏がその製作にあたつて、『自然と彼』との関係に於いて、この男ほど垣を設ける作家はゐないのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論マクベスの発端のように行数は短かくても、興味の上において全篇を貫く重みのあるものは論外であるが、平々凡々たるしかも十行内外の一段を設けるのは、話しの続きをあらわすためやむをえず挿入したのだと見え透くように思われる。",
              "citation": {
                "source": "作物の批評",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　Ｋ氏は何かを待設けるもののように胸を躍らせた。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば、水力は、人間が全然これを利用し得なかつた時代には一つの自然力としては存在してゐたに相違ないに拘らず、社会的価値をもつてはゐなかつたが、人間がこれを水車に利用し、これを利用して発電所を設けるやうになると、社会的価値を獲得して来る。",
              "citation": {
                "source": "諸家の芸術価値理論の批判",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷吉がその前を通り過ぎて、物の小半町も行きかけると、後から、一人の男が、何か惡戲をして遁げて來たらしい容子で、息を切らしてあたふた走り過ぎたが、だれか追つかけて來るものを待ち設けるやうに後を振り返りながら、ついと横の小さい路地へ外れて暗がりに隱れた。",
              "citation": {
                "source": "赤い鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれども、これを亡き者と致すにかような怪しきカラクリ設けるには及びますまいぞ。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "とよ子のベッドが、じっと静まっていると、私まで再び待ち設けるものがあるように、深い沈黙におちてしまった。",
              "citation": {
                "source": "草藪",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京郊外にある自宅の天井を打ち抜いて、小さな撮影所を設ける。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "新たに建設された満洲国はどんな兵制を設けるか知らないが、在来の制度や組織を変革して、よく教えよく戦わしむれば、十分に国防の任務を果たし得る筈である。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈍帳芝居には本花道を設けることを許されないので、今日の帝劇の花道を更に短くしたようなものを、下手から舞台へかけて斜めに作ってある。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると、特に名題とか名題下とかいう区別を設ける必要はないようにも思われる。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "自宅のほかに「寮」すなわち別荘、控え家のたぐいをみだりに設けるのは贅沢であるというのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "河豚太鼓",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇商売の手伝いをして、一挙に数十万は楽にもうけるという、いわば目から鼻に抜けるほどの才物であった。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまに見たまえ、オツベルは、あの白象を、はたらかせるか、サーカス団に売りとばすか、どっちにしても万円以上もうけるぜ。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからおれがもうけるんじゃないと云うので、悪いことをぐんぐんやるのもあまりよくない。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
