        "examples": {
          "standard": [
            {
              "text": "モータウンというレーベルは、人種を問わず全米の若者に支持される音楽を作り上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は音楽雑誌の記事で、モータウンがポップミュージックの歴史に与えた影響を執筆した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "モータウンゆかりのアーティストたちが、創立記念の特別番組で素晴らしいパフォーマンスを披露した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
