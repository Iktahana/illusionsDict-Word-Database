    "definitions": [
      {
        "index": 1,
        "gloss": "gate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "〔郡属伊原忠右エ門〕宮沢賢治郡属伊原忠右エ門科頭にゴムの靴はきて冬の芝生をうちよぎり南ちゞれし綿雲に雨量計をぞさゝげたる天狗巣病にはあらねどもあまりにしげきこずゑかな",
              "citation": {
                "source": "〔郡属伊原忠右エ門〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭日〔二〕宮沢賢治アナロナビクナビ睡たく桐咲きて峡に瘧のやまひつたはるナビクナビアリナリ赤き幡もちて草の峠を越ゆる母たちナリトナリアナロ御堂のうすあかり毘沙門像に味噌たてまつるアナロナビクナビ踏まるゝ天の邪鬼四方につゝどり鳴きどよむなり",
              "citation": {
                "source": "祭日〔二〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自らその門弟と称したルモオルに於てであつたと告白してゐる。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「門司の旅館で船を待つ間、船の汽笛が鳴るたびに、火のつくやうに泣き出すのには閉口させられた。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さても私の境涯の、その最初の門出は「門司の旅館で船を待つ間、船の汽笛が鳴るたびに火のつくやうに泣き出」したのであり、「その日はそれに、吹く降るの日で」あつたのである。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは昔の旗本が住んでた屋敷で、大きな武家風の門があり、庭には蓮池などがあった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　羽左衛門の私生活なども書いてみたい。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」けれども、私は、男女川の小説も、羽左衛門の物語も、一生涯、書く事は無いだろう。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人たちは私を呼ぶのに佐野次郎左衛門、もしくは佐野次郎という昔のひとの名でもってした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が講義のあいまあいまに大学の裏門から公園へぶらぶら歩いて出ていって、その甘酒屋にちょいちょい立ち寄ったわけは、その店に十七歳の、菊という小柄で利発そうな、眼のすずしい女の子がいて、それの様が私の恋の相手によくよく似ていたからであった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い質問、「知ることは幸福であるか」　　佐野次郎左衛門様馬場数馬。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、この帝大生が佐野次郎左衛門さ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　登竜門ここを過ぎて、一つ二銭の栄螺かな。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "登竜門というものは、ひとを市場へ一直線に送りこむ外面如菩薩の地獄の門だ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "學校の廊下には、べたべた推薦のビラが張られて、選擧事務所なども、ものものしく、或るものは校門の下に立つて、登校の生徒ひとりひとりに名刺を手交し、よろしくたのみます、といつて低くお辭儀をして、或るものは、中學校の先輩といふ義理のしがらみに依つて、後輩を威嚇し、饗應、金錢、などといふばかな噂さへ立つた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただいま友人、大隅忠太郎君から、結納ならびに華燭の典の次第に就き電報を以て至急の依頼を受けましたが、ただちに貴門を訪れ御相談申上げたく、ついては御都合よろしき日時、ならびに貴門に至る道筋の略図などをお示し下さらば幸甚に存じます、と私も異様に緊張して書き送ってやったのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は汗を拭い、ちょっと威容を正して門をくぐり、猛犬はいないかと四方八方に気をくばりながら玄関の呼鈴を押した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしか友右衛門だつた筈です。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その反対に今の新人はその基本作因に自信がなく、ぐらついている、というお言葉は、まさに頂門の一針にて、的確なものと思いました。",
              "citation": {
                "source": "自信の無さ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしか友右衛門だった筈です。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし、紀の国屋文左衛門という人も、やはり、そのような意気込みを以て、紀の国の名を日本全国に歌わせたが、あの人は、終りがあまり、よくなかったようであります。",
              "citation": {
                "source": "砂子屋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「正門が立派でなければ愛校心が湧くものではない」といつて是迄の木の門は打倒され、石の門が建てられた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「門外漢の頭ではありますがァ」と云つて置いては、自分の選挙に対する意見を吐いた、彼は満足であつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかく門から建物までの花園は昔のまゝであつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は風のよく通る廊下で、随分淋しい思ひをしたもんだ。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、輝き出でるや、諸君は云ひます、「あれでああなのかねえ、不思議みたいなもんだねえ」。",
              "citation": {
                "source": "酒場にて（定稿）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａの方では「つまらない奴の所へ来たもんだ」と思ふ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際さういはれてみれば自分は無念さうな顔をしてゐたもんだと三造は思つた。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "イラ痒い瞼、ひえびえとする野面の風にひえびえとしたみすぼらしい顔の中から、この遠近を嘆賞するもないもんだなぞ、云つては呉れるな人々よ、自然の与件は、何時でも生理のまゝに享受してゐる者でこそあれ、希望を持つて生きてゐるとも云へるので、其の他はすべて、謂はば野心で生きてゐるのだ。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "病院は庭続きだつたもんだから。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
