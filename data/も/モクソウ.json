    "definitions": [
      {
        "index": 1,
        "gloss": "wooden vat (esp. for sake brewing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
