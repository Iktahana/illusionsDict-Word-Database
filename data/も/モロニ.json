        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "君と一諸に行きたいんだぞ。",
              "citation": {
                "source": "〔蒼冷と純黒〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼冷　俺等の心は、一諸に出会はう　俺は畑を耕し終へたとき、疲れた眼を挙げて、遠い南の土耳古玉の天末を望まう。",
              "citation": {
                "source": "〔蒼冷と純黒〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思はずジョバンニもカムパネル〔ラも一諸にうたひ出したのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕たちと一諸に乗って行かう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カムパネルラ、また僕たち二人きりになったねえ、どこまでもどこまでも一諸に行かう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこまでもどこまでも僕たち一諸に進んで行かう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カムパネルラ、僕たち一諸に行かうねえ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青き陽遠くなまめきて、　　　右に亙せる高原は、花崗閃緑　削剥の、　　　　　時代は諸に論ふ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "チエ子さんはあわてて瓶をさかさまにしますと、水と一諸に虻も流れ出て、ビショビショに濡れた羽根を引きずりながら苦しそうに地べたの上をはい出しましたが、やがて水のないところへ来て羽根をブルブルとふるわしたと思うと、「ありがとう御座います。",
              "citation": {
                "source": "虻のおれい",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さあ大変だあたし字なんか書けないわとひなげしどもがみんな一諸に思ったとき悪魔のお医者はもう持って来た鞄から印刷にした証書を沢山出しました。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小諸に至るに千曲川に會ふ。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その盃は清めてございませんよ」　一々底意ありて忽諸にすべからざる女の言を、彼はいと可煩くて持余せるなり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "杯を持ちながらの話のなかに、私が一度二度とこの小諸に來る樣になつてから知り合ひになつた友達四人のうち、殘つてゐるのはこのＭ―君一人で、あと三人はみなもう故人になつてゐるといふ事が語り出されて今更にお互ひ顏が見合はされた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "杯を持ちながらの話のなかに、私が一度二度とこの小諸に来る様になってから知り合いになった友達四人のうち、残っているのはこのＭ―君一人で、あと三人はみなもう故人になっているという事が語り出されて今更らにお互い顔が見合わされた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "高瀬は子安を待合せて、一諸に塾の方へ歩いた。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "生徒の家へ行って泊まって見たり……人に話し掛けて見たり……まあいろんな機会を見つけて、音さんの家の蒟蒻の煮附まであそこの隠居やなんかと一諸に食って見た……どうしてもまだ百姓の心には入れないような気がする」　こう高瀬は泉に話すこともあった。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お内儀さん、今日は何か有りますかネ」　と尋ねて、一寸そこへ来て立った高瀬と一諸に汽車を待つ客の側に腰掛けた。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "士族地の墓地まで、しとしとと降る雨の中を高瀬は他の同僚と一諸に見送りに行った。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "小諸に旦那様ほどの役者はないと言いました位です。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "七年の間、私は田舎教師として小諸に留まって、山の生活を眺め暮した。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人を始め、細君や子供まで集って、広い古風な奥座敷で、小諸に居る人の噂などをした。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、こんど暫く草津の湯にはいってから、小諸に仕事を求めるために、鋸をかついで街道を歩いてきた。",
              "citation": {
                "source": "逢魔の刻",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "が船が搖れたから、肩を辷つた手が、頸筋を抱いて、もろに、どさりと乘しかゝつた。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もろに揃へて腰を屈めて揉手をしながら、ふと見ると、大王の左右の御傍立。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "帯を掴んで、ぐい、と引いて、婦の膝を、洋服の尻へ掻込んだりと思うと、もろに凭懸った奴が、ずるずると辷って、それなり真仰向けさ。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽんと若い人が、その人形をもろに倒すと、むこうで、ばったり、今度は、うつむけにまた寝ました。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "負けたとなったら、今度はもろになぞえに凭れ込んで、内側から小股を掬い倒すつもりでもございましょうか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "突撃突撃、突撃するもの、突くなり、突きまくり、ひた刺し、刺しつらぬき、銃床｜逆手もろに飛び入り、はたきのめし、はたくや、たたき斃す、これのみ、ただこれのみ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "眞玉花瓶手もろに轉びがちなるならひや、あくがれ心の扉ふかく、齋きまつりし操の歸依しも未だ足らじや、わが道伴なき世にしあれば、うき身夜な夜な御影に、注ぎし涙は知ろしめさめ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "音と歓声で予告されたので、倒れはしなかったが、慶一はその濡れネズミを、もろに抱きかかえてしまった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
