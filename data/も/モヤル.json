[
  {
    "uuid": "7bcd7efc-44cc-53d0-8efe-516528143c60",
    "entry": "靄る",
    "reading": {
      "primary": "もやる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to become misty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」浦島は、いかにもやるせないやうな溜息をついて、「私にこんな綺麗な貝をくれたが、これはまさか、食べるものぢやないだらうな。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "親も子もやるところまでやりましょう。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫を此頃では寝返りができぬ故客の方へ向てでもなんでもやるより仕方がなくなった。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は幕末の革命に飛び出したり、時には辻斬強盜などもやる方だが、犀星のは本當の古武士であつて、君主の前で禮節正しく構へてゐる。",
              "citation": {
                "source": "室生犀星に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、自分もやることは恥かしくない訳だ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さ、これもやるよ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "金をくれさえすりゃ、頸でもやるんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の夜縄をやるのは矢張り東京のものもやるが、世帯船というやつで、生活の道具を一切備えている、底の扁たい、後先もない様な、見苦しい小船に乗って居る余所の国のものがやるのが多い。",
              "citation": {
                "source": "夜の隅田川",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし中には暇はあっても不精であったり、またわざわざ出かけるよりも室の片すみで茶をのんだりカルタでもやるほうがいいという人があるならばそれはその人々の勝手である。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はその時｜大に反対した、君｜止すなら止せ、僕は一人でもやると力味んだ。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はその時大に反対した、君止すなら止せ、僕は一人でもやると力味んだ。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "物ばかり喰つてしかたがないからと云つて、黒と云ふ犬を皮屋にやつてしまはうときめた時でも、お末はどうしてもやるのを厭がつた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆっくり休ませてもやるから、ぜひ行ってくれ」と頼んでも、「厭だ厭だ、ここで御免｜蒙るだ」と、いつまでもグズグズいっているので、吾輩大いに腹を立て、「勝手にしろ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "之が俺の本心である、どこまでもやると覚悟をしてしまへば、手形の形式はどうでもいい。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "（軍歌でもやるならまだの事、子守や手毬唄なんかひねくる様な奴の、弁当持って堪るものか。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、けふはなんとなく愉快だ、ダンスでもやるか！",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "一銭でもやるつもりなら、いくがええだ。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前たちが厭なら、俺は一人でもやる」と、顎髯の男が云いはった。",
              "citation": {
                "source": "岩魚の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は過日家を出てから、もうとても今じゃあ真当の事ア遣てる間がねえから汝に算段させたんで、合百も遣りゃあ天骰子もやる、花も引きゃあ樗蒲一もやる、抜目なくチーハも買う富籤も買う。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　木之助は、子供だから五銭もやる必要がないなどと思われてはいけないと、一層心をこめて胡弓を弾いた。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十一文字といふ制限が不便な場合にはどし／″＼字あまりもやるべきである。",
              "citation": {
                "source": "歌のいろ／＼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "爲方が無いから、自分の書いた物の載つてゐる雜誌を出して見せると、『お前はこんな事もやるのか。",
              "citation": {
                "source": "硝子窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に議院をアテにしないで直接行動をやらうといふのが、今の勞働組合の説ですから、やるなら直接行動をやるといふので、直接行動なら何でもやるといふのではありません。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちは何でもやるつもりですが仕事がありません。",
              "citation": {
                "source": "褐色の求道",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "横町の酒店の支部にしょっちゅう集まって支部旗の上げ下ろしの手伝いもやる。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉灸療法でもやることですな」　と、知っていたのか、簡単に皮肉られて、うろたえ、まる三日間二人掛りで看病してやったが、実は到頭中風になってしまっていた婆さんの腰が、立ち直りそうにもなかった。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
