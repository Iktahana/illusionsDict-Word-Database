    "definitions": [
      {
        "index": 1,
        "gloss": "to receive",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あくる日｜銭を貰うて先ず学校へ行ったが、教場でも時々絵の事に心を奪われ、先生に何か聞かれても何を聞かれたか分らぬような事もあった。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず裏の畑の茄子｜冬瓜小豆人参里芋を始め、井戸脇の葡萄塀の上の棗、隣から貰うた梨。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉庫から、ピークへは、「勝手に下りて貰う」より外に方法が無かった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それははやり唄うたいを巴里の表通へも流して出られるようドュフランにその筋へ運動して貰うことだった。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "泊めて貰うこともできなかったよ」　翁はこういって弟の岳神の顔を見た。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても殺して食べさせて貰う気なぞ出なかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それええだ、おらお蘭さ嫁に貰うべえ」　お蘭は呆れた。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こりゃ偉いわねえ」「おら貰うべえ」四郎は得意な顔つきをした。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたが私をお嫁に貰うには、もっと立派な賢い人にならないじゃ――ねえ、判って」　お蘭に取って、この言葉は一時凌ぎの気休めであり、また四郎への励ましに使ったものに過ぎないけれども、四郎は永く忘れなかった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋服を着て派手な舞台に立つことと嫁を貰う資格とを無理に結びつけて誰かがこの白痴の少年の心に深々と染み込ませたものらしい。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれはこの動物にとっては全く飼主の曲馬師から褒美の鮮魚一尾を貰うための労役に過ぎないであろうが、娯楽のために入場券を買ってはいった観客の眼には立派な一つの球技として観賞されるであろう。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時の間にか、眼が悪くなって府下の有名な眼科医三四人に診察を乞うて見ると、云うことが皆同じである、曰く進行近視眼、曰く眼底充血、最後に当時最も雷名ありし、井上達也氏に見て貰うと、卒直なる同氏はいう、君の眼は瀬戸物にひびが入った様なものじゃ。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいよいよ斎藤のおッ母さんに意見をして貰うということに相談が極り、それで家のお母さんが民子に幾度意見をしても泣いてばかり承知しないから、とどのつまり、お前がそう剛情はるのも政夫の処へきたい考えからだろうけれど、それはこの母が不承知でならないよ、お前はそれでも今度の縁談が不承知か。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚かなことでしょうがこの場合お前さんに民子の話を聞いて貰うのが何よりの慰藉に思われますから、年がいもないこと申す様だが、どうぞ聞いて下さい」　お祖母さんがまた話を続ける。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな手紙を貰うた人こそ災難だったろう。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その犠牲の報酬として年金千二百円ほどと一時金八千円くらいとを貰う事になったと伝えられる。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや、帽子が変ッてるぞ、Ａの奴だな」「班長殿、Ａ居ませんが、あの野郎、自分の帽子を間違えて、あ、それ」「写真をもう一枚、送って貰うんだな」　煙草出す。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともよは、店へ入って手ばやく店のものに自分の買うものを注文して、籠にそれを入れて貰う間、店先へ出て、湊の行く手に気をつけていた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "河鹿を籠に入れて貰うと、ともよはそれを持って、急いで湊に追いついた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺れゃ、家へ帰ったら、早速、嚊を貰うんだ。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、彼は種物を求めて来ると、「こっちの人は自分のしたチョウズまで銭を出して他人に汲んで貰うんじゃ。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも汚穢屋が来ると、「こっちの者は自分のしたチョウズまで銭を出して汲んで貰うんじゃ。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の日曜にでも連れて行って貰うか。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　両人は園子に案内して貰うのだったら全然気がすゝまなかった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　六「あれに連れて行て貰うよりゃ、いっそうら等二人で行く方が安気でえいわい。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "跛や、手なしや、片輪者にせられて、代りに目くされ金を貰うて何うれしいんだ！",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、病気だと云って内地米ばかりを配給して貰う者が出てくる──一度や二度はその病気の看板もきくがそうたび／＼は通らない。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "当人の腹では、色男の富蔵にたのんで、藤吉から売って貰うつもりであったんですが、あいにくに富蔵はどこへか出て行った留守で、川春の店にいない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し早いとお酌でもして貰うものを、惜しいことをしたっけな」と、半七はまた笑った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれはすぐに祈祷所へ駈けて行って、久次郎のゆくえを占って貰うことにした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
