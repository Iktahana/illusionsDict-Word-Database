    "definitions": [
      {
        "index": 1,
        "gloss": "to put back",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いつもの不機嫌そうな表情を、円滑に、取り戻すことができたのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は気が気でなく急いで持って行くと、父は眉を皺めて、私に戻す。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎蔵が、Ｔ「黙って居りゃ　いい気になって　よくも俺達の面に　泥塗って呉れた」　逃げんとする仲蔵の襟がみとって引き戻す。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前の位置へ戻すことさへ出來ない。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペピイは生涯｜大酒を飲み通したので、その飲んだ丈の酒の利足を痰唾にして、毎日大地に払ひ戻すのかと思はれる。",
              "citation": {
                "source": "老人",
                "author": "GREISE",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにこの夜空のところどころにときどき大地の底から発せられるような奇矯な質を帯びた閃光がひらめいて、琴のかえ手のように幽毅に、世の果ての審判のように深刻に、夜景全局を刹那に地獄相に変貌せしめまた刹那にもとの歓楽相に戻す。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉色に透き通るような柔らかい絹の靴下やエナメルを塗った高い女の靴の踵は、ブルジョア時代の客間と、頽廃的なダンスと、寝醒めの悪い悪夢を呼び戻す。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸国を旅してみてもいったん売った電車切符をまた取り戻すような国は稀であった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと似た事がもし適用するとすれば、濫費に偏しているものを一日だけ引き戻すのはかえって危険な場合があるかもしれない。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれも一日経ったらすぐ馴れてしまって日本人の吸う敷島の味を完全に取り戻すことが出来た。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、その樹を戻すには、折角建った門を、屋根瓦を引っぺがし、塗った壁を叩き落し、組立てた材木をばらばらにしてしまわなければならなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "親爺は、もう、彼の力では、大勢を再びもとへ戻すのは不可能だと感じたのに違いない。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　だが、その時、銃を取った大西上等兵と浜田一等兵は、安全装置を戻すと、直ちに、×××××××××をねらって引鉄を引いた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前の位置へ戻すことさえできない。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先方の買直がぎりぎりの処なら買戻すとする。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "婿君のふみながら、衣絵さんの心を伝へた巻紙を、繰戻すさへ、さら／＼と、緑なす黒髪の枕に乱るゝ音を感じて、取る手の冷いまで血を寒くしながらも、園は、謹で其の意を体したのである。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それやこれやを考え合わせますると真実の処、蔵元屋は、今申しましたような身代の左前を取戻すために、賭博の胴親をしているものと存じますので……ヘイ……」「フウ――ム。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台へ空の椅子を置いて、死人の魂を呼び戻すと称する集りなどが行われていた。",
              "citation": {
                "source": "噴水物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、人間は昔の完全な身体の機能を取り戻すために、時々獣類のように動くことを稽古しなさい。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "トシオは手の皮のにじむまで、欅の幹を叩きつけましたが、とうとう鳥を呼び戻すことは出来ませんでした。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮月の起きて居る姿を見て躊躇し引返しかけたが、また勇気を取り戻すに努める様子。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "呪術の誓いは縒りを戻すことは出来ないのだ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "気まり悪くなったのを押し包んで老人は「また、この鏨の刃尖の使い方には陰と陽とあってな――」と工人らしい自負の態度を取戻す。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "血迷うばかりの、清葉を遮って、突戻すためであった。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "金の力と權威を以て、見事に此の女祕藏し見すべし、再び是を阿母の胎内に戻すことこそ叶はずとも、などか其の術のなからんや、いで立處に驗を見せう。",
              "citation": {
                "source": "妙齡",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……然うかといつて、どこへ戻す所もないのである。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に、もとの山へ戻すやうに、と云つて、花屋の店へ返したが。",
              "citation": {
                "source": "玉川の草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、安行は市郎を顧って、「倅の云うには、それが為に忠一さんを態々呼び戻すにも及ぶまい。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ僕らはかつて僕らが忘れていた「人間」を、僕らの文学の中へ呼び戻すために、まずモンテエニュあたりから勉強のし直しをはじめるとしても、しかし、今日僕らの文学の足音が少しは乱暴に高鳴っても、致し方はあるまい――ということだけは、今ここで言い切れると思う。",
              "citation": {
                "source": "土足のままの文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "はや僕は己惚れを取り戻すのである。",
              "citation": {
                "source": "僕の読書法",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
