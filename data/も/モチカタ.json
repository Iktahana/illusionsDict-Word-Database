    "definitions": [
      {
        "index": 1,
        "gloss": "way of holding (a writing brush, chopsticks, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
