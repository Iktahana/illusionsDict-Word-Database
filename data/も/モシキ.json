          "literary": [
            {
              "text": "前に述べた模式図（※）。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "クレアチン生成の多くの模式が提案された。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽炎や名も知らぬ虫の白き飛ぶ更衣野路の人はつかに白し絶頂の城たのもしき若葉かな鮒鮓や彦根の城に雲かかる愁ひつつ岡に登れば花いばら甲斐ヶ嶺や穂蓼の上を塩車　俳句というものを全く知らず、いわんや枯淡とか、洒脱とか、風流とかいう特殊な俳句心境を全く理解しない人。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶頂の城たのもしき若葉かな　若葉に囲まれた山の絶頂に、遠く白堊の城が見えるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしきのう一つの生涯が済んだなら、その済んだ生涯を続けて、押し広めて行かなくてはならないでしょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とのたまう、たのもしき状よと思いてひたとその胸にわが顔をつけたるが、ふと眼をさましぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "舟はたちまち岸をはなれ岸の子供らはまだトランクのことばかり云ひ船頭もしきりにそのトランクを見ながら船を滑らせました。",
              "citation": {
                "source": "革トランク",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大臣の子もしきりにあたりを見ましたが、霧がそこらいっぱいに流れ、すぐ眼の前の木だけがぼんやりかすんで見えるだけです。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もしきりに胸騒ぎがする。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠はこのときまで、一箇の頼もしき馬丁としてその意中に渠を遇せしなり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫もしきりに鳴いている。",
              "citation": {
                "source": "九月四日",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御用人もしきりに心配しておいでなさる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "いのちともしきわれをよぶ　足だまりにしていた枯枝がぽきっと折れた。",
              "citation": {
                "source": "猿ヶ島",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾めは吉と申す不束な田舎者、仕合せに御縁の端に続がりました上は何卒末長く御眼かけられて御不勝ながら真実の妹とも思しめされて下さりませと、演る口上に樸厚なる山家育ちのたのもしき所見えて室香嬉敷、重き頭をあげてよき程に挨拶すれば、女心の柔なる情ふかく。",
              "citation": {
                "source": "風流仏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とのたまふ、たのもしき状よと思ひてひたとその胸にわが顔をつけたるが、ふと眼をさましぬ。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は故里に頼もしき族なしとのたまえば、この地に善き世渡りのたつきあらば、留まりたまわぬことやはある。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "沼井の方を見ると、沼井もしきりに鉛筆の芯をけずっているのだ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、もしきょうの夕方、あの男がもう一度様子を見にいって、やっぱりまだ空家のままだったら、お目にかかるよ。",
              "citation": {
                "source": "黄色な顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛布はふわふわで、ツバメが冷たい地面で寒くならないようにわきの下にもしきました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前さんはあの若い役者もしきりに睨んでいなすったが、あれにも何か仔細がありますかえ」「むむ、あいつも唯者じゃあねえな」と、半七は云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お師匠さんのおかげで助かります」と、お雪もしきりに礼を云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "話す人も聴く人もしきりに笑いながら猪口の遣り取りをしていると、三五郎はやがて少しまじめになって云い出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "異人の首",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は故里に頼もしき族なしとのたまへば、此地に善き世渡のたつきあらば、留り玉はぬことやはある。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は故里に頼もしき族なしとのたまへば、この地に善き世渡のたつきあらば、留り玉はぬことやはある。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "今月の「小旅行」などは力作でもなく彼としても別段快作といふほどのものでもなからうが、得てして斯様な雰囲気に附きまとふ鬱陶しさが無く、好もしき樸吶さに溢れて居り、わたしは早速と愛読したものであつた。",
              "citation": {
                "source": "浪曼的時評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えてみるとどこへも遠く離れて人声もしないこんな寂しい所へなぜ自分は泊まりに来たのであろうと、源氏は後悔の念もしきりに起こる。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "○…福田平八郎の人気を名づけて「好もしき人気」といつたらぴつたりしよう。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "『小夜嵐』三に、ぶたのもしき坊主とあるは頼みにならぬ坊主で豕に関係なし。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、不二雄さんもしきりに勧めました。",
              "citation": {
                "source": "停車場の少女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「治六さんもしきりに頼んでおります。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
