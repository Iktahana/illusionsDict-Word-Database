          "literary": [
            {
              "text": "――なる程、ものは考えようじゃ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったくものは考えようだて」　観念の眼を閉じて、薄荷のような匂いの鼻を衝くそのお酒をいっぺんに飲み干してしまうと今松、「ヘイ御馳走さま」　雫を切って海老団治のほうへと返した。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものは考えよう中谷宇吉郎　また夏がやって来て、新聞面には、時々水泳競技の話が出る。",
              "citation": {
                "source": "ものは考えよう",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するにものは考えようなのである。",
              "citation": {
                "source": "ものは考えよう",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがものは考えようだ。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「師匠、凶死だからのう、おめえも諦めが悪かろうが、ものは考えよう一つだってことよ、まあ、それがお美野さんの定命だったと、思いなせえ。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "宙に浮く屍骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "私からすると、無学文盲の人々ですら、こんな素晴らしく美しい品を生めるのだという点をこそ強調したかったので、「ものは考えようもあるものだ」と不思議に感じたのを、今も忘れる事が出来ぬ。",
              "citation": {
                "source": "四十年の回想",
                "author": "『民藝四十年』を読んで",
                "note": "青空文庫"
              }
            },
            {
              "text": "「波子はどうして、こんな俺なんかと結婚する気になったんだい」「今さら、何言ってんのよう」「こんなさみしい、みじめな暮し……」「いいえ、ものは考えよう。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしものはかんがえようだ。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
