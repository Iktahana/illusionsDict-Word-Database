        "examples": {
          "standard": [
            {
              "text": "明日はお祭りなので、物前の今日はどこの家も準備で忙しそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "物前ということで、商店街には晴れ着を買い求める人が溢れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祭りの物前の晩には、子供たちが興奮してなかなか寝ようとしない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
