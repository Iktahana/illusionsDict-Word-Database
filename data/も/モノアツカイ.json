[
  {
    "uuid": "dff528fd-3220-5a56-9d51-362da1eb1f86",
    "entry": "物扱い",
    "reading": {
      "primary": "ものあつかい",
      "alternatives": [
        "モノあつかい"
      ],
      "is_heteronym": true
    },
    "grammar": {
