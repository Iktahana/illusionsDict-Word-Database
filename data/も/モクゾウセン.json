        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "木造船が港のなかにごちやごちやともやつてゐた。",
              "citation": {
                "source": "屋久島紀行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人がいいあっているところは、その豆潜水艇がおいてある青木造船所の中です。",
              "citation": {
                "source": "豆潜水艇の行方",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄造船は同じ図体の木造船にくらべてかえって総重量は軽いことがわかった。",
              "citation": {
                "source": "黒船前後",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の技術をもってして鉄造船の場合船体および艤装を合わせて重量は排水トン数の三十パーセントで済んだが、木造船の場合は四十パーセントだった。",
              "citation": {
                "source": "黒船前後",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄造船は同一トン数の木造船より四分の一だけ軽く済んだ、したがってそれだけ貨物積載量が殖えた。",
              "citation": {
                "source": "黒船前後",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの木造船は完全に難破したがこの船だけは無傷だった。",
              "citation": {
                "source": "黒船前後",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで木造船では三百フィートというのが構造上の極限だった。",
              "citation": {
                "source": "黒船前後",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "何万トンという鋼鉄船があるわけでなく、木造船の手こぎの帆前船であるから、「われ三韓をまわる間、必ずご誕生はご無用に存じます」　と、腹を三べんなでたら、三年間生まれなかった。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローセンブームと青銅の人は、むかしの美しい木造船が一ばん気にいりました。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな木造船（十五トンから四十トン程度）で赤道をこえ（ただし昔の話。",
              "citation": {
                "source": "肝臓先生",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに巨きくとても木造船や皮革船である。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
