[
  {
    "uuid": "9f1a3bce-9347-5c6b-96d1-1e0e3e12cad9",
    "entry": "木版",
    "reading": {
      "primary": "もくはん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
