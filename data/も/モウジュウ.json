[
  {
    "uuid": "b81b8e54-2374-5ccf-987b-ac0d84a6afb9",
    "entry": "猛獣",
    "reading": {
      "primary": "もうじゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fierce animal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "魔術が曲馬に変形してそれが猛獣を呼出したと思われる。",
              "citation": {
                "source": "夢判断",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからやはり前夜の食卓で何かのついでから、ずっと前に動物園の猛獣が逃出した事のあった話をした。",
              "citation": {
                "source": "夢判断",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが猛獣肉薄の場面を呼出したかもしれない。",
              "citation": {
                "source": "夢判断",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめには負傷者の床の上で一枚の獣皮を頭から被って俯伏しになっているが、やがてぶるぶると大きくふるえ出す、やがてむっくり起上がって、まるで猛獣の吼えるような声を出したりまた不思議な嘯くような呼気音を立てたりする。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚は呻き騒ぎながら、彼等が追いかえそうと努めているのとは反対に、小屋から遠い野良の方へ猛獣の行軍のようになだれよった。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "李花は猛獣に手を取られ、毒蛇に膚を絡われて、恐怖の念もあらざるまで、遊魂半ば天に朝して、夢現の境にさまよいながらも、神崎を一目見るより、やせたる頬をさとあかめつ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばそれは小さいしかし恐ろしい猛獣がやけに檻にぶっつかるかと思うような音である。",
              "citation": {
                "source": "病院の夜明けの物音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧苦に沈んだ暗い声ではなくて勢いのある猛獣の吼声のようである。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来の猛獣映画に比べて多少の特色はあるようである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二　忠犬と猛獣　これも動物の芝居を見せる映画であるが、シェパードの芝居は象や馬の芝居に比べて、あまりにうま過ぎ、あまりに人間の芝居に接近し過ぎるので、感心するほうが先に立って純粋な客観的の興味はいくぶんそのために減ぜられるような気もする。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この映画のストーリーの原作では、たしか、最後に忠犬が猛獣を倒して自分もその場で命をおとすようなことになっているかと思う。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛獣の争闘のように血を流し肉を破らないから一見残酷でないようでありむしろ滑稽のようにも見えるが、実は最も残忍な決闘である。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてあっぱれ自然の暴威を封じ込めたつもりになっていると、どうかした拍子に檻を破った猛獣の大群のように、自然があばれ出して高楼を倒壊せしめ堤防を崩壊させて人命を危うくし財産を滅ぼす。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君、犬は猛獣である。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまは、あのように街路で無心のふうを装い、とるに足らぬもののごとくみずから卑下して、芥箱を覗きまわったりなどしてみせているが、もともと馬を斃すほどの猛獣である。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "飼い主でさえ、噛みつかれぬとは保証できがたい猛獣を、（飼い主だから、絶対に喰いつかれぬということは愚かな気のいい迷信にすぎない。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "けっして噛まないということは、科学的に証明できるはずはないのである）その猛獣を、放し飼いにして、往来をうろうろ徘徊させておくとは、どんなものであろうか。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くからその狂暴の猛獣性を看破し、こころよからず思っているのである。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりに犬の猛獣性を畏敬し、買いかぶり節度もなく媚笑を撒きちらして歩いたゆえ、犬は、かえって知己を得たものと誤解し、私を組みしやすしとみてとって、このような情ない結果に立ちいたったのであろうが、何事によらず、ものには節度が大切である。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにいよいよ隠してあった猛獣の本性を暴露してきた。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "血に飢えたる猛獣である。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ病んでいるとはいっても、相手は一種の猛獣である。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は恐るべき猛獣である。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那風の美人、美少女、美少年が、あらゆる残忍酷烈な刑に処せられて笞打たれ、絞め殺され、焙られ、焼かれ、煮られ、引き裂かれ、又は猛獣の餌食にあたえられて行く凄愴、陰惨を極めた場面の極彩色密画であった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "また芸術的実写映画としての山岳映画や猛獣映画のごときものについても一通り述べたかったのであるが、これらについても他日適当な機会に、他の場所で一応の考察を試みたいと思う。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の名僧などで、信念の凝り固まったものには、悪人強盗はもちろん、猛獣毒蛇でさえ近寄れなかったと言い伝えられています。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし猛獣毒蛇｜来らば、その眼玉で睨み殺して賜われ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛獣ならばその皮は吾輩有難く頂戴する。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛獣｜犠牲を獲て直ぐには殺さず暫時これを弄びて、早｜慊りけむ得三は、下枝をはたと蹴返せば、苦と仰様に僵れつつ呼吸も絶ゆげに唸きいたり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠のずぼんの裾が見え、樺色の靴を穿き、同一色の皮手袋、洋杖を軽くつき、両個の狼を前にしつつ、自若たるその風采、あたかも曲馬師の猛獣に対するごとく綽々として余裕あり。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
