      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "death in agony",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "或時は私は、もう悶死するのかとも思つた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "無理に耐へたら遂に悶死だ！",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等を眩惑して悶死させながら、平気で冷笑していた私こそ……ホントウの……生れながらの悪魔であった……。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで僕のやうな人間は、好運に恵まれて不運に終り、陽気盛んにして陰に喪はれ、才能あつて無能に終り、結局生涯得るところなく、碌々として不満の中に悶死するのだと言ふ。",
              "citation": {
                "source": "名前の話",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、そこへ彼の新公が悶死したと云う知らせが来た。",
              "citation": {
                "source": "妖蛸",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新公が悶死したことに就いていろいろの噂が伝わった。",
              "citation": {
                "source": "妖蛸",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はそれがために自殺したか、悶死したか、いずれにしても山岸の父を呪いつつ死んだ。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝統の文化から個性の文化へ導くべく悶死した鼻がありました。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "初め基督生れて正法大に興らんとした際邪鬼輩失業難を憂ひ相謀つて一の法敵を誕生せしめ大に邪道を張るに決し、英國の一富豪に禍を降し、先づ母をして其獨り息子を鬼と罵らしめて眠中其子を殺すと、母は悔ひて縊死し父も悲んで悶死した。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し与えられない為めに悶死する人がこの世の中には絶えずいるのですね。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜は腹の中の重味を持ち扱つて愚図／＼してゐる間に、激烈な神経衰弱に襲はれて、青い湖の傍まで差しかゝると列車が停止するやうに静かに悶死した。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "外記　　やれ、家柄の身分のと、さま／″＼の手械足枷で、人を責めようとする窮屈な世の中、蛛の巣にかゝつた蝶々蜻蛉もおなじことで、命とたのむ花の露も吸はれず、羽翅をしばられて悶死、あゝなんの因果で武士の子に生れたか。",
              "citation": {
                "source": "箕輪の心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのためお前は悶死した！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "完全を求めて得られんなら、悶死すべきでないか？",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに君は彼女と結婚して間もなく、彼女が肺病に罹ると、恰も紙屑を捨るように彼女を捨てしまい、彼女を悶死させたのだ。",
              "citation": {
                "source": "卑怯な毒殺",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｄ老人と立話する、或る老人の悶死、彼の後妻の薄情、等、等、等。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎなるザクシカというのは、早く言えば、若くして悶死した魚の腐肉だ。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は芦に串刺しにされて悶死したそうです。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一は直接法とでも謂う可き往き方で、アイネ・リィドに問題の非合法手術を施し、その結果悶死するのを冷然と眺めて、犯跡を隠すために屍体を潅木と岩の谷間へ投げ落して逃亡したのは、誰か？",
              "citation": {
                "source": "土から手が",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして最後の審判の絵のように川岸は悶死者の群で埋められたのだが……）　僕はあのとき、あの静かな川岸で睡って行ったなら、どんな夢をみたのだろうか。",
              "citation": {
                "source": "夢と人生",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、あつちからも、こつちからも、悶死者の顔や火の叫喚が僕をとりまいた。",
              "citation": {
                "source": "火の子供",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "賊は蓉子の声におどろいていきなり覆面用の黒布をとって蓉子の口へ押しこみ、同人を押し仆し両腕に力をこめてその咽喉をしめつけたため同人はもがきながら悶死した。",
              "citation": {
                "source": "黄昏の告白",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯彼の女房が産褥で悶死したことだけは、どうにか事実だと云われている。",
              "citation": {
                "source": "荷",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の牢死、母の悶死、兄の刑死、それを思うと松平家を呪わずにいるのが耐えられぬ苦痛。",
              "citation": {
                "source": "怪異黒姫おろし",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "血をふいて悶死したってビクともする大地ではないのです陳列箱にふかしたてのパンがあるけれど私の知らない世間は何とまあピヤノのように軽やかに美しいのでしょう。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く、暑くて悶死しそうだ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "血をふいて悶死したってビクともする大地ではないんです陳列箱にふかしたてのパンがあるが私の知らない世間は何とまあピアノのように軽やかに美しいのでしょうそこで始めて神様コンチクショウと吐鳴りたくなります。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "血をふいて悶死したつてビクともする大地ではないんです後から後から彼等は健康な砲丸を用意してゐる。",
              "citation": {
                "source": "蒼馬を見たり",
                "author": "蒼馬を見たり",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、どこからか迷い込んで来たポインター雑種の赤犬を一匹、台所のタタキの上に繋いで、バタを塗ったジレットの古刃を三枚ほど喰わせて、悶死させているのであった。",
              "citation": {
                "source": "冗談に殺す",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭はもんもんして手の中は熱い。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
