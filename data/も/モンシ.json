[
  {
    "uuid": "972b2200-570a-5456-a7a5-ae13aaf65b29",
    "entry": "悶死",
    "reading": {
      "primary": "もんし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
