    "definitions": [
      {
        "index": 1,
        "gloss": "flower arrangement in a built-up style",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "生け花の教室で、ダイナミックな盛り花の技術を学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "展覧会には、見事な盛り花が多数展示されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は華道家として、常に新しい盛り花の表現を追求している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "おかしいことには「ファイルシェン」という言葉が耳にはいってこの花の視像をそれと認識すると同時に、一抹の紫色がかった雰囲気がこの盛り花の灰色の団塊の中に揺曳するような気がした。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たうとう私達は盛り花のしてあるやうな家の閾をまたいだ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "花の盛り花の盛りはちんころぐさの花でさへ、ただもう、ふんはりとしましての、よいにほひの、好いたらしいよいおいろの、にくげといふものつゆもない。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と樽野は満腔の依頼をもつて、盛り花の上に盃をさゝげた。",
              "citation": {
                "source": "円卓子での話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "涼しく水を打った店さきに、早くも盛り花（塩）がしてあって、あけ放った入口に、短い紺のれんが出してある。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しいテーブル・クロスでおおった、大きな食卓の上には、美しい秋の盛り花がかざられ、めいめいの席には、銀のナイフやフォークが、キラキラと光っていました。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
