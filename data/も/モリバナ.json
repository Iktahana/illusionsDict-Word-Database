        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新しいお店の開店祝いに、友人が盛り花を贈ってくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "商売繁盛を願って、毎朝店先に盛り花を置いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "盛り花は、清めの意味合いも持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
