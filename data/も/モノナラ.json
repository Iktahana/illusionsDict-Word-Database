    "definitions": [
      {
        "index": 1,
        "gloss": "if I (we, etc.) could",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
