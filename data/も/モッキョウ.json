        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "新しい木橋を渡ると、道は二つに分れてゐた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木橋の、埃りは終日、沈黙し、ポストは終日｜赫々と、風車を付けた乳母車、いつも街上に停つてゐた。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "突落された丸木橋の流に逆らって出逢ったのである。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "山中に朽木の独木橋を渡り、アワヤ谷底へ真逆様にならんとせしは某君。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一〇）登山競争　町付村から、山道は漸く深くなり、初めは諸所に風流な水車小屋なども見えたが、八溝川の草茂き岸に沿うて遡り、急流に懸けたる独木橋を渡ること五、六回、だんだん山深く入込めば、最早どこにも人家は見えず、午後四時頃、常州第一の高山八溝山の登り口に達した。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "木場一圓、入船町を右に、舟木橋をすぎ、汐見橋を二度渡つて、町はまだ明いが、兩側は店毎軒毎に電燈の眩い門前町を通りながら――並んでは坐れず、向ひ合つた同伴と、更に顏を見合はせたが、本通りは銀座を狹くしたのとかはりのない、千百の電燈に紛れて、その蕎麥屋かと思ふ暖簾に、血の付いた燈は見えなかつた。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戀の歌を想ふにつけ、夕暮の線路さへ丸木橋の心地やすらむ。",
              "citation": {
                "source": "婦人十一題",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "燒杭を倒したやうな、黒焦の丸木橋も渡してある。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と手を擧げて留める間もなく、足許に、パツと火が燃えて、わツと飛び移つた途端に、丸木橋はぢゆうと水に落ちて、黄色な煙が――濛と湧立つ。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道を切って、街道を横に瀬をつくる、流に迷って、根こそぎ倒れた並木の松を、丸木橋とよりは筏に蹈んで、心細さに見返ると、車夫はなお手廂して立っていた。",
              "citation": {
                "source": "栃の実",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　電が、南辻橋、北の辻橋、菊川橋、撞木橋、川を射て、橋に輝くか、と衝と町を徹った。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この家だと思いながら私は前の溝川に架かった一間ばかりの木橋を渡った。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い姿が紫色の風呂敷包みを抱えて鶴原家の前の木橋の上に立っていた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、恋には丸木橋を渡って落ちてこそしかるべきを、石の橋を叩いて、杖を支いて渡ろうとする縁談だから、そこいら聴合わせて歩行く中に、誰かの口で水を注せば、直ぐに川留めの洪水ほどに目を廻わしてお流れになるだろう。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵に描いた木曾の桟橋を想わせる、断崖の丸木橋のようなプラットフォームへ、しかも下りたのはただ二人で、改札口へ渡るべき橋もない。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "荻尾花道、木の下路、茄子畠の畝、籔畳、丸木橋、……城ヶ｜沼に漁つて、老爺が小家に帰る途中には、穴もあり、祠もあり、塚もある。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「秋雄、ちょいと三味線を持って来て呉れよ」「珍らしいな、おじさん」　わが恋は細谷川の丸木橋、渡るにゃ恐し渡らねば、思うお方にゃ逢えはせぬ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "高津神社の裏門をくぐると、すぐ梅ノ木橋という橋があります。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夕、出でて見て、向ひ見て、丸木橋妻とわたりて、また見れば、まだかがやけり。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、遊廓の大通りへかかると、向うの木橋から、白い服の、そして胸高な青の袴の朝鮮の女が楚々として光って来た。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い帽子、黒い帽子、青い帽子ここは谷川、丸木橋。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夕、出でて見て、岨ゆ見て、丸木橋妻と渡りて、また見ればまだかがやけり。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにも川のむこうへ渡る二本の丸太を並べて架けた丸木橋があったが、彼はそれを渡らずに台地の方へ爪さきあがりの赭土を踏んであがって往った。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "徑路蛇行して或は密樹の下にいり、或は獨木橋の上に走する、之を久うして下りて流と會ふ。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "其所にも川の向ふへ渡る二本の丸太を並べて架けた丸木橋があつたが、彼はそれを渡らずに台地の方へと、爪先きあがりの赤土を踏んであがつて行つた。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い木橋は夢の国への通路のように、幽かに幽かに、その尾を羅の帳の奥の奥に引いている。",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と案内する……処に……丸木橋が、斧の柄の朽ちた体に、ほろりと中絶えがして折込んだ上を、水が糸のように浅く走って、おのれ、化ける水の癖に、ちょろちょろと可憐やか。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀形をした細長い田に、打ち渡した丸木橋を、車夫が子どもひとりずつ抱きかかえて渡してくれる。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其あとへ跟いて行くとすぐに長大な木橋がある。",
              "citation": {
                "source": "彌彦山",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「昇るに伴れて、屹度川の幅が狭くなるだらう――案外、丸木橋ぐらゐ見つけられるかも知れないよ。",
              "citation": {
                "source": "繰舟で往く家",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
