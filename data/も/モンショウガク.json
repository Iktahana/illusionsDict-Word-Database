        "examples": {
          "standard": [
            {
              "text": "紋章学はヨーロッパの歴史と密接に関わっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は紋章学の研究に情熱を傾けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その図書館には、紋章学に関する貴重な資料が多数所蔵されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし、福音書の写本などは一見して判るものじゃないから……」と云って、「一四一四年｜聖ガル寺発掘記」の他二冊を脇に取り除け、綸子と尚武革を斜めに貼り混ぜた美々しい装幀の一冊を突き出すと、「紋章学※」と検事は呆れたように叫んだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ウン、寺門義道の『紋章学秘録』さ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、珍しい紋章学の話を、家柄の自慢とともに、ウールの靴下をはいて、薪をストオヴに焚いているミセス・チャアチルから聞いた。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの・紋章学の術語で pennes sans fin と呼ばれる・羽根型の彫りのある指輪を見て、正しくその幅を識別する眼はないのである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
