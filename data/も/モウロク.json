[
  {
    "uuid": "fba19b6d-3846-5ba5-b530-324987e3f07d",
    "entry": "耄碌",
    "reading": {
      "primary": "もうろく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
