        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "正月の物日で満員の客に押されて漫才をきゝながら時間を費していたとは、如何にもうなずける事だが、彼の機嫌の良さは些か意外だった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "観世音は永久にうらわかい町の処女に依て斎がれ（各の町に一体づつの観世音を祭る、物日にはそれぞれある店の一部を借りて開帳し、これに侍づくわかい娘たちは参詣の人にくろ豆を配り、或は小屋をかけていろいろの催をする。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "花火はなくともきょうは川開きという書入れの物日に、彼女はふだん着の浴衣のままで家を飛び出して来たらしかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして歳の暮れの物日前だ。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "觀世音は永久にうらわかい街の處女に依て齋がれ（各の町に一體づつの觀世音を祭る、物日にはそれぞれある店の一部を借りて開帳し、これに侍づくわかい娘たちは参詣の人にくろ豆を配り、或は小屋をかけていろいろの催をする。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "觀世音は永久にうらわかい街の處女に依て齋がれ（各の町に一體づつの觀世音を祭る、物日にはそれぞれある店の一部を借りて開帳し、これに侍づくわかい娘たちは參詣の人にくろ豆を配り、或は小屋をかけていろいろの催をする。",
              "citation": {
                "source": "思ひ出",
                "author": "抒情小曲集",
                "note": "青空文庫"
              }
            },
            {
              "text": "物日の休みにも、日曜日にも、たいてい宿直室でくらした。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "終に秀真の鋳物日記に到る。",
              "citation": {
                "source": "明治卅三年十月十五日記事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般の買物日と定った日に纏めれば、多くの場合、場所により懸け値を少くよい物品を得られると云う訳なのです。",
              "citation": {
                "source": "男女交際より家庭生活へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし江戸ッ児には二十日正月までの物日はまだ乏しくないのだ。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪入と閻魔　藪入と閻魔とは正月と盆とに年二度の物日である。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝田君に最後に会ったのは今年の初夏、丁度ドラマ・リイグの見物日に新橋演舞場へ行った時である。",
              "citation": {
                "source": "滝田哲太郎君",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "○やはり年の暮らしく、又土曜日の買物日らしく、あちこちの店、賑やかに人の出入りあり。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は兎に角、此の頃では世の中せち辛くなって、物日にも稼ぐことが流行する。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山国にいたころの家族は、お正月とか物日とかでなければ塩ものの魚さえも味わうことができないのであった。",
              "citation": {
                "source": "うむどん",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついには道庵先生の庭から屋敷の前まで、露店が出て物日縁日のような景気になりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一条　長崎、函館を開く（函館は調印の日より十ヶ月後）二条　トン税――トン（六石四斗）銀五｜匁三条　船数並びに商売銀高ともその限を立つることなし、しかしながら持渡の貨物日本人｜好に応ぜず、或は代り品等｜差支る時は、交易を遂げざる儀も之有るべき事。",
              "citation": {
                "source": "空罎",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "同町では定まった漬物日があって年中行事の一つとなっており、その日に各家で漬物をする。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえに妓楼、酒店にありては、古のいわゆる門日、物日に比す。",
              "citation": {
                "source": "日曜日之説",
                "author": "柏原孝章",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸か不幸かその日は物日、客は朝から突っかけて、狭い化物小路は身動きもならぬ有様です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "幽霊にされた女",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかに「池田大助捕物日記」が約八十篇、韓信丹次、平柄銀次、隼の吉三などの捕物帳がそれぞれ五六篇ずつ、総計四百二三十の捕物小説を書いているだろうと思う。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "捕物小説は楽し",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事は一菜か一汁にかぎり、物日に干魚を焼くのが精ぜいだった。",
              "citation": {
                "source": "菊屋敷",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "座へ来てみると、月曜としては相当の入りだ、「芝居の世の中」は、物日の出しものじゃない、今日の客には実にピッタリ来るらしい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月三日（日曜）　出がけに母上と三楽病院へ鋭五氏を見舞ひ、物日故早く座へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月十七日（水曜）　甲子郎で昨夜おそくなり、ねたのが四時、大分のんだし一寸応へる朝、物日で早出だ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "川崎庸之氏の人物日本史などもそれをいっているが、この疑問へ、もっと具体的な推理を与えてみることは、作家でなければなしえない仕事だと思う。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学も草木ものびのびと自由に生長させる方がよいようである。",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔うたがふをやめよ〕うたがふをやめよ、　　林は寒くして、いささかの雪凍りしき、　　根まがり杉ものびてゆるゝを。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時がたてば、草ものびる、と、よく言われますが、アンネ・リスベットの子供も、そのとおり、すくすくと大きくなりました。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "永代橋を過ぎて後は四方のさま全く変りて、眼を障るものも無き海原の眺め、心ものび／＼とするやうなり。",
              "citation": {
                "source": "鼠頭魚釣り",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
