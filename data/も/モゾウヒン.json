[
  {
    "uuid": "60d25d8e-9f49-5aed-bcd2-6ec63c57fbf5",
    "entry": "模造品",
    "reading": {
      "primary": "もぞうひん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
