        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この船は、想像も出来ないような猛スピードで駛り出したらしい。",
              "citation": {
                "source": "地図にない島",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅行の疲れのせいではなくて、伊東の町に火事があって猛スピードで見物に行って水を浴びたせいであった。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽が東から昇って西へ沈む運行を猛スピードで繰り返しているのだ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "居眠り運転の対向車が車線へ斜めにはずれつつ猛スピードで突っこんでくるのをよけきれず、正面衝突した。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "追いこしてトロトロいくと、うしろから、猛スピードで、追いすがってくる。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーブを外側いっぱいにはらんで抜けていくトラックの内側を、白いライトバンが、ホーンの悲鳴を放ちつつ、猛スピードですり抜けていく。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月から四月まで、すでに半年以上の時間が、猛スピードでどこかへ飛んでいったのだ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して面倒はかけない」「だって、市内ではいくら飛ばそうたって、先がつかえてまさあ」　運転手はもうスピードを出しながら、どなり返す。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうスピード夫人とラルフが再会しても、命取りにはならないだろう。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
