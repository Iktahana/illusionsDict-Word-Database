[
  {
    "uuid": "c721555b-1549-5642-8693-4ea74480eb0c",
    "entry": "目前",
    "reading": {
      "primary": "もくぜん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
