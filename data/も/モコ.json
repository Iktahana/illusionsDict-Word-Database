[
  {
    "uuid": "0e837625-5129-5293-bcc8-3e6266f7fdcf",
    "entry": "模糊",
    "reading": {
      "primary": "もこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
