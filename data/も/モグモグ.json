    "definitions": [
      {
        "index": 1,
        "gloss": "mumbling",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "男は口を二三度もぐもぐさしたが、やはりいい出せなかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼等の脣が合はさり、もぐもぐ動くとき、一體、どんなことをひとりごちてゐるのか知ら？",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう十年も前から世界中の学者が口をもぐもぐさせて云おうとしていたが、適当な言葉が出て来ないので困っていたところへ、誰かが出て来て、はっきりした言葉でそれをすぱりと云って退ければ、世界中の学者は一度に溜飲が下がったような気がするであろう。",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中山服は、街をとび／＼して歩きながら、快活に口をもぐもぐさした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）嘉吉は用があったからこっちへ廻れといった風で口をもぐもぐしながら云った。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」飛騨はパンをもぐもぐ噛みかへしつつ口をはさんだ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "叱言を、と思う頬辺を窪めて、もぐもぐと呑込んで黙言の、眉毛をもじゃ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　矮小は唇を、もぐもぐと遣る。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "散々待たせて、あの人はのそっとやって来、じつは欠勤した同僚の仕事をかわってやっていたため遅れたのだ、と口のなかでもぐもぐ弁解した。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "御堂筋を並んで歩きながら、風がありますから今日はいくらか寒いですわねと言うと、はあ、寒いですな、風があるからと口のなかでもぐもぐ……、それでなくてさえ十分腹を立てていた私は、川の中へ飛び込んでやろうかと思った。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、いって、はじめの人に渡すつもりの金ゆえ、すぐよっしゃとはさすがに言えず、しばらくもぐもぐためらっている。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも尚だ床の中にもぐもぐしてゐると、「だツてさ、お前、其様なにお眠ツちや、瞳が溶けてお了ひなさるよ。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "向かふの細道行者がとほる……てなことを、口のなかでもぐもぐやつて、かねを鳴らせばごまかせます。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "下唇をもぐもぐ噛みながら。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどく酔っぱらった女給と、酔ってない女給と二人、寿司をもぐもぐ食っていた。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、口をもぐもぐ動かしつつ暫く思いに沈んだのだ。",
              "citation": {
                "source": "猿ヶ島",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かしらはそこで、何かいおうとして口をもぐもぐやりましたが、まだいい出さないうちに子供は、あちらの子供たちのあとを追って走っていってしまいました。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その部屋では、上品な洋服の、青白い顔をした十歳くらいの男の子が、だらし無く坐ってもぐもぐ菓子を食いながら、家庭教師に算術を教えてもらっていた。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事中に珍客があらはれた場合に、私はすぐに箸を投げ出し、口をもぐもぐさせながら玄関に出るので、かへつてお客に顔をしかめられる事がある。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婆はもう涙を滴して口をもぐもぐさしていた。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「牛肉と馬鈴薯」といえば、独歩の小説から連想しても、北海道には野となく丘となくふかし立ての馬鈴薯が雪のように積り、熊の毛皮を着た髭むじゃのアイヌやシャモが、その中に群居して埋まって、それらの窓や戸口から、手や頭やを出すとむくむくもぐもぐ馬鈴薯ばかりを食べているような気がした。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "女鬼たちは、そのたけのこを見ると、またさっそく引き抜いて、もぐもぐ食べだしました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本尊の御薬師様を持って往くのじゃない、おつきの不動様じゃ、おつきは他にもいるから、一人位は持って往ってもいいだろう」　住職は口をもぐもぐさすのみで何も云えなかった。",
              "citation": {
                "source": "不動像の行方",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、どうぞ」　権兵衛は口をもぐもぐさして飲んだ。",
              "citation": {
                "source": "海神に祈る",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、お婆さんは口をもぐもぐさせながら、「一銭の苞ですか、二銭の苞ですか。",
              "citation": {
                "source": "納豆合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奥様、騒がなくつても好んですよ、私は赤ん坊を見に来たのですから、」　細君は口をもぐもぐしてやつと彼女の顔を見直した。",
              "citation": {
                "source": "あかんぼの首",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "源吉は驚いて口をもぐもぐさした。",
              "citation": {
                "source": "海異志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳吉はいささか吃りで、物をいうとき上を向いてちょっと口をもぐもぐさせる、その恰好がかねがね蝶子には思慮あり気に見えていた。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとに楢雄が残り、かねがねお前は食事の時間が永すぎると父の小言の通り、もぐもぐ口を動かせてゐた最中ゆゑ、母の喜びを一身に背負つた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫く口をもぐもぐさせていたが、やっと、「嫌いやったら一緒に歩けしまへん」という言葉を考え出して、ほッとした。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
