        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ふぐ刺しには、たっぷりの紅葉おろしとポン酢が欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "揚げ出し豆腐に添えられた紅葉おろしが、ピリッとしたアクセントになっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大根に菜箸で穴を開け、鷹の爪を差し込んでからおろすと紅葉おろしができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "紅葉おろし、さらし葱、わけぎの薬味。",
              "citation": {
                "source": "海豚と河豚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "青紫蘇の葉を敷いた鯛のあらいも、藻魚の附合せの紅葉おろしも、みないい知れぬ哀愁を含んだ美しさで、やすと向きあって食事をしている杜松子の顔の中にもなにかしらそれと通じあうものが感じられ、愁いに似たやるせないほどの愛情で胸をつまらせた。",
              "citation": {
                "source": "ユモレスク",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
