        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もっとも、珈琲といえば、今日の大阪の盛り場（というのは、既にして闇市場のことだが）には、銀座と同じように、昔の香とすこしも変らぬモカやブラジルの珈琲を飲ませる店が随分出来ている。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしや古人の苦心なぞ理解し得ずとも、習った通りに演じておりさえすれば、トニモカクニモおまんまが喰って行けるのである。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何モカモ、私ガ修養ガ足リナイタメニ、起ッタ事デス。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "シカモカタカナノ問題ハ現在ノ私ノ生活ニスコブル密接ナ関係ヲ持ツ。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "スナワチ形カライエバ草書ト少シモカワリハナイノデアル。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢字ノ活字ガ楷書一ツデタクサンデアルヨウニ、カナノ活字モカタカナ一種類デタクサンデアル。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国ノ人タチナドモカナヲ一種類オボエレバイイコトニナレバ非常ニ助カルダロウ。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "シカシマズ最初ニ新聞ダケデモカタカナニナツテシマエバアトハ割合ラクデアロウ。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "少ナクトモカナヅカイノ問題ヨリハハルカニ単純デアル。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "土人教育など云つて道廳などが尤もらしく國費を無駄に使つてゐるが、アイノ人が教育されて半可通のシヤモカラになつたとて、何の效能もないこと。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの断髪嬢ならトモカク、あのテル子嬢の断髪なら、お母さん譲りだけあってナカナカ板に附いているぞ」「おかしいわねえ。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニルの沿岸に起伏する山脈が遠く姿を現わすのはその辺からで、行くに随って右手にはギゼのピラミッドが三つ並んで小さく見え出し、その先にはリビュアの沙漠が大洋の如く連り、左手にはアラビアの沙漠の裾が少しばかりのぞいて、手前にモカタムの岩山が横たわり、その端に聳えてるサラディンの城が目を見張らせる。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――秋グミ、大カメノキ、ツリガネニンジン、ゴマナ、ニガナ、ハタザヲ、ワレモカウ、ミヤマウド、ヒヨドリバナ、アキノキリンサウ、カウゾリナ、ヤマハハコ――自分の知つてゐるのは秋グミだけだつた。",
              "citation": {
                "source": "湖畔手記",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお結句を古義ではタマモカリハムと訓み、新考（井上）もそれに従った。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄がモカという上等の豆を食品屋で焙ってもらって宅で先程｜砕しましたのですから焙りたてのひきたてでございます。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "モカといって珈琲の上等を濃く出して五｜勺ばかりと牛乳を一合、玉子の黄身が二つ砂糖を山盛二杯、新鮮なクリーム二合とそれだけを混ぜて器械で寄せたのです」広海子爵「実に結構ですな。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユフガタ　メガサメテミルト、オホソウヂハ　モウドコヘイツタカ　カゲモカタチモアリマセンデシタ。",
              "citation": {
                "source": "オホサウヂ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソノマヒゴノヤウスノヘンテコリンナコトトイツタラ※　水ノ中ニムヤミト長クツカツテヰタトミヘテ、アタマノ毛ハ一本、一本、サカダチ、カホモカラダモマツサヲ、クチビルハムラサキ色。",
              "citation": {
                "source": "ウミベノマヒゴ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "“……高度二万八千メートルニ達セシトコロ、突然｜轟音トトモニハゲシキ震動ヲ受ケ、異状ニ突入セリ、噴射機関等ニマッタク異状ナキニモカカワラズ、速度計ハ零ヲ指シ、舵器マタキカズ、ソレニ続キ高度計ノ指針ハ急ニ自然ニ下リテ、ホトンド零ニ戻ル。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "噴射機関等ニマッタク異状ナキニモカカワラズ、速度計ハ零ヲ指シ、舵器マタキカズ。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "リュウとしたギャバジンの洋服のオモカゲどこへやら。",
              "citation": {
                "source": "神サマを生んだ人々",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「アメリカ物はきれえだよ」「コーヒーはアメリカ物じゃないわよ」「きッとか」「そうよ」「じゃアどこの物だ」「モカ。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、また暫く沈黙の後、次のように言いました、「考えさせられます、トモカク、我々の方で、君を引留める何物の力もないということがわかり出したようです、この上は、君の自由の行動と、意志の行動に干渉すべき限りではない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが宝塚の諸嬢は、そのバカなところまで上品で節度があるような温室の草木的オモカゲがはなれない。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺一体に蔓っている私娼、今も名付けてモカという。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからお前さん達モカ連が、一番利口者ということが出来る。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "他でもない、モカ達である。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大勢のモカ達を相手にし、薬草道人の人情哲学！",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでその理由を話すことにしよう」　ここでしばらく考えたが、一人のモカへ話しかけた。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はい」というとモカのお粂、即座に答えたものである。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
