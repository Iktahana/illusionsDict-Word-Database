        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ソレデ、コノ　ウグヒスハ、オカアサンヲ　ナクシタ　コドモノ　フク、カナシイ　ウグヒスブエノ　オトヲ　キクト、ナクシタ　ボウヤノ　コトヲ　オモヒダシマシタ。",
              "citation": {
                "source": "ウグヒスブエヲ　フケバ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "デモ　マダ　オメメヲ　トヂテ　ネネシテ　ヰルノデスヨ」　花タチハ　ウマノ　アカンボヲ　ミタイト　オモヒマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "コレハ　テツキリ、ジブンヲ　コロシテ　カネヲ　トルノダナト　オモヒマシタ。",
              "citation": {
                "source": "カゴカキ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "カタツムリガ　ツノヲ　フツテルノヲ　ミテ　ヰルト、王サマハ、子ドモノ　ジブン、何ダカ、カタツムリノ　ウタヲ　ヨク　ウタツタ　コトヲ　オモヒダシマシタ。",
              "citation": {
                "source": "カタツムリノ　ウタ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「デンデン　蟲々　ツノ　出セヤ　ダツタカナア」ト、イロイロ　カンガヘタガ、チツトモ　ソノ　ウタハ　オモヒダセマセンデシタ。",
              "citation": {
                "source": "カタツムリノ　ウタ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレデモ、オモヒダセナイノデ、トウトウ　オコツテ、カタツムリヲ　ツブシテ　シマハウト　シタ　トキ、フツト　オウサマノ　ココロニ、「デンデン　ムシムシ　ツノ　フレヨ、夜アケニ、ヌストガ　ヤツテ　クル」ト　イフ　ウタガ、ウカビマシタ。",
              "citation": {
                "source": "カタツムリノ　ウタ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレト　一シヨニ、ソノ　ウタヲ、ヨク　ウタツテ　下サツタ、ヤサシイ　オ母サンノ　コトモ　オモヒダシマシタ。",
              "citation": {
                "source": "カタツムリノ　ウタ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミチコサンハ、カワイイ　テダナト　オモヒマシタ。",
              "citation": {
                "source": "ミチコサン",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンザシヲ　ジブンノ　モノニ　シタイト　オモヒマシタ。",
              "citation": {
                "source": "カンザシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "サカナハ　タイヘン　トクヲ　シタト　オモヒマシタ。",
              "citation": {
                "source": "カンザシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "コレヲ　ナホスニハ、イタチサンニ　オモヒキリ　オナラヲ　サセルヨリ　シカタハ　アリマセン」　ヤレヤレ。",
              "citation": {
                "source": "ガチヨウノ　タンジヨウビ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソシテ　ヤツパリ　イタチハ　ヨブンヂヤ　ナカツタト　オモヒマシタ。",
              "citation": {
                "source": "ガチヨウノ　タンジヨウビ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "木造は、また、コモヒの町である。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "コモヒといふのは、小店の訛りであると一般に信じられてゐるやうだが、私は、隠瀬あるいは隠日とでもいふ漢字をあてはめたはうが、早わかりではなからうか、などと考へてひとりで悦にいつてゐる次第である。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのコモヒを歩いてゐたら、Ｍ薬品問屋の前に来た。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち寄らず、そのままとほり過ぎて、やはりコモヒをまつすぐに歩いて行きながら、どうしようかなあ、と考へた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この町のコモヒは、実に長い。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "津軽の古い町には、たいていこのコモヒといふものがあるらしいけれども、この木造町みたいに、町全部がコモヒに依つて貫通せられてゐるといつたやうなところは少いのではあるまいか。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ木造は、コモヒの町にきまつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく歩いて、やうやくコモヒも尽きたところで私は廻れ右して、溜息ついて引返した。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木造町のやうに、ここにも長い「コモヒ」があるけれども、少し崩れかかつてゐる、木造町のコモヒのやうな涼しさが無い。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日も、ひどくいい天気だつたが、日ざしを避けて、コモヒを歩いてゐても、へんに息づまるやうな気持がする。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――『慢性モヒ中毒。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはさながらにアル中、モヒ中の患者たちのように、そうした極端な刺戟をアトからアトから渇望し初めた。",
              "citation": {
                "source": "路傍の木乃伊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジフテリ程度の注射なら耳鼻科医でなくとも院内で遣っております」「成る程……」「それがヤット治癒りかけたと思いますと、今月の三日の晩、十二時の最後の検温後に、自分でモヒを注射したらしいのです。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "時としては勝手に患者の耳や鼻を掃除したり洗ったり、甚しい時は私に断らずにモヒの注射、その他の鎮痛、麻酔手段を取った事が爾後の経過によって判明した事もあったが、しかし、それにしても患者の喜びは大したものであったらしい。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "現ニ私ハ近ゴロ原稿ヲ書クニモ手紙ヲシタタメルニモヒラガナトイウモノヲ使ツタコトガナイ、ソレハナゼカトイウニ、我々仰臥シタママデモノヲ書クモノニトツテハ些細ナ力ノ消費モ大キナ問題トナル。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "□オモヒデはトシヨリのキヤラメル□意志を忘れて来た男　意志だけ持つてゐる女□老顔のよさは雨露に錆びた石仏のやうなものだらう、浮世の風雪が彼を磨いたのだらう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
