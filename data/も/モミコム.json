        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お肉を柔らかくするために、下味のタレをしっかりともみ込む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "洗髪後、頭皮に育毛剤を馴染ませるようにもみ込むのがコツだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "洗濯機に入れる前に、襟元の汚れに洗剤を直接もみ込んでおく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "胸に穴があいて、それがぐるぐる回り、錐をもみ込むように大きくなっていった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はじっと空間を見つめたまま、頭の芯へ錐をもみ込むようにして、何かを思い出そうとあせった。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなはずはないが、と思つて、がまんして、「くそツ、ちくりとも……」といひかけると、こんどは足の中へ錐でももみこむやうに痛くなつてきましたので、もうたへられなくなり、「あいててて、しイ――ツ。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
