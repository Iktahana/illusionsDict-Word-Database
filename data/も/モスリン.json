        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "暮れになって、呉服屋で誓文払をやりだすと、子供達は、店先に美しく飾りたてられたモスリンや、サラサや、半襟などを見て来てはそれをほしがった。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "染め絣、モスリン、銘仙絣、肩掛、手袋、などがあった。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は番頭に黙って借りて帰ったモスリンと絣を、どう云ってその訳を話していゝか思案している。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "北側の入口には赤と黒との縞のよごれたモスリンのカアテンがかけられ、そのうへの壁に、沼のほとりの草原に裸で寢ころんで大笑ひをしてゐる西洋の女の冩眞がピンでとめつけられてゐた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自信ありげに、モスリンのカアテンをぱつとはじいた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "北側の入口には赤と黒との縞のよごれたモスリンのカアテンがかけられ、そのうえの壁に、沼のほとりの草原に裸で寝ころんで大笑いをしている西洋の女の写真がピンでとめつけられていた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自信ありげに、モスリンのカアテンをぱっとはじいた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後にシャンパン半デシリットルを加えモスリンの布で漉す。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姫さまは、絹やモスリンの、りっぱな着物をいただきました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「京都のモスリン会社の別荘で」とＭ君が枝豆をつまむ。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "服の生地は絹モスリンで、首と袖口に綿毛のレース、光の洪水を浴びて、立ち姿がぼうっと浮かび上がり、片手を扉にかけて、もう一方の手は待ちかねたとばかりに、つと前に出している。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "むすめはやはりボール紙を切りぬいたものでしたが、それこそすずしそうなモスリンのスカートをつけて、ちいさな細い青リボンを肩にゆいつけているのが、ちょうど肩掛のようにみえました。",
              "citation": {
                "source": "しっかり者のすずの兵隊",
                "author": "DEN STANDHAFTIGE TINSOLDAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、ひいさまは、絹とモスリンの高価な着物をいただいて着ました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "上衣のすぐ下の着物は薄いモスリンであったが、この着物から幅十八インチの布片がすっかり裂き取られていた――たいへんまっすぐに、ひどく念入りに、裂いてあった。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "このモスリンの布片と、あのレースの布片とに、帽子の紐が結びつけてあり、それに帽子もついていた。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "布片は幅が十八インチもあったのだから、モスリンではあるが、縦に褶むとか、くしゃくしゃにするとかすれば、丈夫な紐になるだろう。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、彼女はあらゆる努力をしてこの口を閉じていようとし、また、新しく糊をつけてアイロンをかけてある屍衣でこさえた、顎のすぐ下のところまできている、白麻布モスリンの襞縁をつけた衣裳を着こんで、大いに威厳があるように見せようとしているのである。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "剃りたての顎はモスリンの包帯でしっかり結え上げてある。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "自転車や幌をした車やモスリン友禅の帯や派手なパラソルを載せて中流近く静かに動いて行く渡船が。",
              "citation": {
                "source": "ひとつのパラソル",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "西郷の港では、雨の土砂降りに降る中に尻からげをして白い脛を出してゐる娘達が友禅モスリンの帯の色彩をあたりに際立たせて迎ひに出てゐた。",
              "citation": {
                "source": "隠岐がよひの船",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっ白なモスリンの着物を着て赤い大きなリボンを装った少女たちや、水兵服で身軽に装った少年たちは葉子の周囲に花輪のように集まった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽がかげる頃に彼れは居酒屋を出て反物屋によって華手なモスリンの端切れを買った。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには華手なモスリンの端切れが乱雲の中に現われた虹のようにしっとり朝露にしめったまま穢ない馬力の上にしまい忘られていた。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "友禅モスリンの大きな派手な座蒲団を女はいつもＫに勧めた。",
              "citation": {
                "source": "田舎からの手紙",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「京都のモスリン会社の別荘で。",
              "citation": {
                "source": "日本ライン",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスリンとレースの袖口にくるまつてゐやしての、いつも日曜日の晩がくるちうと、十五里も遠方から俺らのやうな若いものをひつ張り寄せますだよ。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "久留米絣の元禄袖の着物に赤いモスリンの半幅帯を貝の口に結んだ跣足の娘の姿は、それなり上野から八時間ほど汽車にのせて北へ行った福島の田舎の祖母の黒光りのする台所へも現われた。",
              "citation": {
                "source": "青春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "布地にでも例えると、茶色っぽい綿モスリンのような雰囲気――つまり、どんなに燈灯が軒なみに輝いても、それを明快にキラキラ反映させる何かが無い、明るさを吸い込んでしまう。",
              "citation": {
                "source": "茶色っぽい町",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手織縞の單衣に綿繻珍の帶を締めて、馬鹿に根の高い丸髷に赤い手絡をかけた人が、友染モスリンの蹴出しの間から、太く黒い足を見せつゝ、後から二人を追ひ拔いて、停車場に駈け込んだ。",
              "citation": {
                "source": "東光院",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから自分も長椅子に腰をおろすと、モスリンの肩掛をぎゅっと緊め直しただけで、それきり眼ばたき一つしなければ眉毛ひとすじ動かさなかった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
