        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "イワス（岩壁の截り立っているところ）にぶつかると、水が深くて急であるから、森の中へ潜り込む、そうしてまた森から吐き出されては、谷の中へと飛び込む。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人の研究を記述した論文を如何によく精読したところで、その研究者自身の頭の中まで潜り込む事が出来ない以上は、その人の得た結果を採用するという事にはやはりこのイズムの匂がある。",
              "citation": {
                "source": "鸚鵡のイズム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三の石門には、扉のような大きな扁平い岩が立て掛けてあって、其下の裂目から蝦蟆のように身を縮めて潜り込むのである。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は直ちに其穴を見出して、蛇のように潜り込むと、暗い中で恰も彼の市郎に出逢ったのであった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔母や従同胞等は日が暮れて間もなく寝て了ふのだから、酔つた叔父は暗闇の中を手探り足探りに、己が臥床を見つけて潜り込むのだつたさうな。",
              "citation": {
                "source": "刑余の叔父",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下の熔岩の洞穴の廊下に潜り込むのだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "沈み込む程ふっくりした夜具に潜り込む時、彼は又ちょっと考えた。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同級生から一年遅れて一九七六（昭和五十一）年に大学を卒業したころ、考えていたのは、とにかく出版社に潜り込むことでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "――宇都の宮じゃないが、吊天井の下に誰か潜り込む奴があるかい。",
              "citation": {
                "source": "牢獄の半日",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "家には鼠が潜り込むほどの隙間もないぞ。",
              "citation": {
                "source": "蟹満寺縁起",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから××××をタップリと浸した綿で顔を蔽うて、積み重ねた燃料の下に潜り込むつもりです。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "見なさい、鉦たたきは、あの小高い木の枝でちんちんとお念仏の鉦を叩き続け、おかまこほろぎは、彼奴が大好きな人家に潜り込むことすら忘れて、あんなに機嫌よく踊つてるぢやないか。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "む、む、寒いなあとか私も言って、急いで帯をグルグルと巻いて床へ潜り込む。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "花聟はそれを聴いて、美しい女中頭が、どつさり「幸運」を背負つて、自分の大きな鼻の孔から身体のなかへ潜り込むやうに思つた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故、彼の行く道を跟いて行こうとすると、あがきがつかない程、ずぶりずぶりと潜り込む。",
              "citation": {
                "source": "心の河",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはお前が一人で敷布団と被布団との間に潜り込む時だ。",
              "citation": {
                "source": "復讐",
                "author": "BALTHASAR ALDRAMIN. KURZE LEBENSGESCHICHTE AUS DEM ALTEN VENEDIG.",
                "note": "青空文庫"
              }
            },
            {
              "text": "身の周囲を立ち籠めている霧が、領や袖や口から潜り込むかと思うような晩であるのに、純一の肌は燃えている。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "随分寒いのですぐ帰って蒲団の中に潜り込む。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間を生命からがら逃出して、小石の下に潜り込むと……ブルブル。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "グーンと沈んで甲板をザアザアザアと洗われながら次の大山脈のドテッ腹へ潜り込む。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、響で跡を消すといかんから、下の方の板をそっと切り破ろうじゃないか」　やがて、扉の下方に空けられた四角の穴から潜り込むと、法水は懐中電燈を点じた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "動機をしっくりと包んでいるその五芒星円には、いかなるメフィストといえども潜り込む空隙はございません。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小鳥までが臆病に、過敏になつて、ちよいとした風にも、あたふたと、うら枯れた茂みへ潜り込む。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "舟は砕けるほどの勢いに、波を呑む岩の太腹に潜り込む。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして便所から帰って夜具の中に潜り込む時、まあ当分休養する事にするんだと口の内で呟いた。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の女どもゝ驚いて下流しへ這込むやら、又は薪箱の中へ潜り込むやら騒いでいる中に、源次郎お國の両人は此処を忍び出で、何処ともなく落ちて行く。",
              "citation": {
                "source": "怪談牡丹灯籠",
                "author": "怪談牡丹灯籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よし、そこで当直将校、水中聴音機で探りながら、×の汽船の真下に、潜り込むのだ。",
              "citation": {
                "source": "太平洋雷撃戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "八時になると、もう床のなかへ潜り込む。",
              "citation": {
                "source": "飛沙魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の神經はむぐらもちのやうにだんだん深く地面の下へもぐりこむ。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日の旅につかれてしまったとみえて、相手の男は、床にもぐりこむとすぐに、大きないびきをかきはじめました。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
