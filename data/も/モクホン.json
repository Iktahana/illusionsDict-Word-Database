        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "恋人の三木本は約束の時間にやって来た。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとき思わず令嬢の顔を見た三木本の眉の根に面倒と怒りとで挟み上げられた肉の隆起を認めた。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三木本の帰ったあと遅く出た風の送る水仙草の匂いを嗅ぎながら広いサンルームでマーガレットは安楽椅子にくたりとした。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三木本が悦んで自分に世話をやく程度はトーストパンにすると六枚までである。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのパンの前の六枚を喰べずに一番あとの七枚目の半分だけで三木本の愛の分量の実験の効果を挙げる方法はなかったものか」　蒼空に乱れ始めた白雲を眺めながら彼女の頭脳の若さはこんな無理をしきりに考えた。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「木本です」「え、木本君※」　これが君なのか。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一月に自分の手から一票一票と三百万の票を党におくった人々の心に「風知草」が描いた代々木本部創立当時のおもかげは、何のよびかけももたないだろうか。",
              "citation": {
                "source": "事実にたって",
                "author": "――一月六日アカハタ「火ばな」の投書について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして注意しておきますが、御木本君のお姉様に与えたあなたの印象はよいものではありませんでした。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "附録　私が大塩平八郎の事を調べて見ようと思ひ立つたのは、鈴木本次郎君に一冊の写本を借りて見た時からの事である。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "御木本はこちとら貧画生にはあまり用はないが、しかし、世界的に有名な家である。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "先だって三木本の店員がトンカツをたべてあたって死んだというから、本当かと思ったら、洋食心中だなどと先日かつがれた。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「久能さんですか、あの人は三木本君と一緒に大阪の方へ行きましたよ」と、労働社同人の一人が教えた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜母上御木本からブローチのいいのを買っていらっしゃった。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事なら初めから此地に一泊する予定にして、此の新しく開けた吉敦線で大連の宇佐美さんが勧められたやうに老爺嶺までも行き、吉林をもゆつくりと見るのであつたと思ふが、長春では赤木本城の諸氏が夜食を共にして話す積りで待つてゐられる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "長春へ八時四十分に著き、それから某楼で赤木本城諸氏から支那料理の御招宴を受け、長春の近状に就ていろいろのお話を聞く事が出来た。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえりに、車をまたせておいて御木本によってバラさんのために指環を一つ見た。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一ツは御木本の真珠。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "至れりつくせり親切な交通公社の事務員も、御木本のことになると、顔を曇らせ、困りきってしばし口をつぐんだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいたい養殖真珠をやっているのは御木本だけではないけれども、世界各地の業者が技をこらしても、御木本ほどの真珠がつくれないのだそうだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が見たって、秘術を見破る眼力は全然ないのであるが、それに私が最も見たいのは養殖の秘術じゃなくて、御木本家に蔵するところの百七十グレーンという日本一の真珠なのだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "御木本の百七十グレーンという真珠は白蝶貝やアコヤ貝じゃなくてアワビの中から現れたというから日本的である。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "志摩の海女も、御木本の真珠もあきらめて松阪へ牛肉を食いに行く。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "標高の大なることがその一であり、夏なお多量の残雪を存することがその二であり、過去の氷河の遺跡であるといわれているカールの存在することがその四であり、山頂附近は大小の岩塊狼藉して、時に矮小なる木本或は草本等より成るお花畑を作り、または地衣類を産するのみなることがその五である。",
              "citation": {
                "source": "南北アルプス通説",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "之に反して北側は、岩峰の上まで鬱蒼たる樹林に掩われ、うす暗い谷に臨んで突立っている崖から、長い蔓性の木本が垂れ下って、吹きあげる風に揺れながら縺れ合っているさまをふと見ると、南国の山奥へでも入ったような気がする。",
              "citation": {
                "source": "奥秩父",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本谷山（駒ヶ岳）　下津川山から東北を指して少し下った所は黒い岩壁を裸出した小隆起で、夫を踰えると偃松は絶えて、短い木本や笹の生えた比較的狭い尾根上を一上一下しながら之字形に辿って行く。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其外は蔓性木本のように低く匐った楢や短い笹であるが、北側に廻ると一面の笹で、一尺から一尺五、六寸の長さに延びている。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂上から肩のあたりへかけて何処にもこれという程の露岩がある訳でもなく、例の如く短い木本や笹が生えているのみなるにも拘らず、山勢頗る峭抜して恐ろしく引緊った感じを与える。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白沢山の登りに懸るあたりからそろそろ陣竹や矮少な木本の藪が始まるけれども、僅ばかりの登りであるから直に三角点に達する。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
