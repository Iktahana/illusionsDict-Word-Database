        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たゞ水の東京に至つては、知るもの言はず、言ふもの知らず、江戸の往時より近き頃まで何人もこれを説かぬに似たれば、いで我試みにこれを語らん。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "アマチュアには、こわいもの知らずの糞度胸があるからかなわねえ。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう云えば、むす子の女性に対する「怖いもの知らず」の振舞いの中には、女性の何もかもを呑み込んでいて、それをいたわる心と、諦め果てた白々しさがある。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "天災の中に鑛毒が混つて來るから、十年ばかりと云ふもの知らずに居つた是れが一つ。",
              "citation": {
                "source": "公益に有害の鑛業を停止せざる儀に付質問書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "いままでの話でもわかるとおり、善くいえば勇猛果敢、悪くいえば変質者に近いほど怖いもの知らずのマタ・アリである。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "今にみんな、おそろしいたたりに泣き面をして暮らすようになるだべ」「子供たちによくいいきかしとけよ、子供は、こわいもの知らずだから、新興班について、幽霊屋敷の中へはいるかも知れんからな」「そうじゃ、うちの音松なんか、よろこんで時計屋敷の探険に行くちゅうだろう。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私ははじめは知らん顔をしていたが、お竜ちゃんがあんまり口惜しがったりすると、家のなかではこわいもの知らずの私は、「水ピストル」を手にして、向う見ずに細工場の方へ飛び込んでいって、それを佐吉にさしつけながら、頭から水をぶっかけた。",
              "citation": {
                "source": "幼年時代",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでまず見たものは、どんなこわいもの知らずでも、ぞっとして、骨までこおるようなものでした。",
              "citation": {
                "source": "眠る森のお姫さま",
                "author": "ペロー　Perrault",
                "note": "青空文庫"
              }
            },
            {
              "text": "日ごろ怖ろしいもの知らずの金持ちの鶏は、犬に向かって不意に飛びつきましたので、犬は怒りました。",
              "citation": {
                "source": "金持ちと鶏",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　世の中に、こわいもの知らずほど厄介なものはありません。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのが剣眼が、そこまでいっておりませんから、相手の偉さ、すごさというものがすこしもわからない……こわいもの知らずというのは、ここのことです。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その愚楽老人をつかまえて、「やあ、化け物がきてるな」　という泰軒先生、怪物の上をゆく怪物か、さもなければ、こわいもの知らずのよっぽどの馬鹿か。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "橘の刀を払い落として、難なく捕まえ、三郎　怖いもの知らずのことをする。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ニヤニヤ笑いながら）恐いもの知らずと言う奴だね。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿ですから怖いもの知らずです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "甲源一刀流の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "中肉中背で、どこにこれという特徴もなく、ただその眼つきや、ものの云いぶりなどに、あまやかされて育った人間の、権高な、こわいもの知らずといった感じが、露骨にあらわれていた。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "おくめ殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中ってものはそんなものですか」　孫軍曹は、自分のもの知らずを、悲しむかのように悄気返った。",
              "citation": {
                "source": "雲南守備兵",
                "author": "木村荘十",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて三上皇の御製に関する以外では、歌に関する限り、定家はこわいもの知らずの地位にあった。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「爺さんだって、怖いもの知らずの自信を持てばいいんだ」彼は言った。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い体をもちながら、三日すればやめられねえという諺どおり自堕落にまかせて、世の中に怖いもの知らずで歩いていたものだ。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間と思うと、持前の恐いもの知らずな性分が出ないとも限らないからである。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、恐いもの知らずの智深である。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先が儀式張ってござったところへ、こちらが恐いもの知らずの無法と出たので、さすがの舅どのも、度胆を抜かれたまでのことよ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "だのに、怖いもの知らずの若殿は、そういう異変の予報をうけた翌日、しかも逢う魔が時という夕暮をことさらに選んで、「べつに用もないのじゃが、退屈しのぎに、ちょッと染屋の観音まで歩いて行ってみる。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、なにも知らず十一にもなった不知哉丸は、わがままいッぱいで、恐いもの知らずな小暴君の性をいよいよつのらせていたのである。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本能のものしり」、「本能のものしらず」をこの前はぢめて読んだときには何といつていいか解らないほどびつくりしました。",
              "citation": {
                "source": "谷丹三の静かな小説",
                "author": "――あはせて・人生は甘美であるといふ話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "てめえの半殺しにした猫の化物を、吉浦さひっぱってって、見世物にしたら、さぞ見物がきて、もうかるべえなァ」　こわいものしらずの若者たちが、幽霊がでるの、怪猫の化物がでるのときかされて、いさみにいさんで内心大よろこびで、でかけてきているのですから、そのげんきのよいことといったらお話になりません。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい、灰色ネズミというのは、どんな苦しみでもがまんするし、どんなつまらないものにも満足する、こわいものしらずのネズミだったのです。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
