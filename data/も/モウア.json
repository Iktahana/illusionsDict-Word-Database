    "definitions": [
      {
        "index": 1,
        "gloss": "blind and dumb",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "薄ら闇、盲唖の院の角硝子暗くかがやく。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃霧はそそぐ……香の腐蝕、肉の衰頽、――呼吸深く※謨や吸ひ入るる朧たる暑き夜の魔睡……重く、いみじく、音もなき盲唖の院の氛囲気に月はしたたる。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "マチ擦れば火は風に消えて巻煙草のけむり一すぢのぼるほどにさみしき鐘は鳴る……盲唖院晩餐の鐘。",
              "citation": {
                "source": "春の暗示",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "マチ擦れば火は風に消えて巻煙草のけむり一すぢのぼるほどにさみしき鐘は鳴る――盲唖院晩饗の鐘。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "本郷臺の帝國大學、第一高等學校、上野臺の東京音樂學校、東京美術學校、目白臺の學習院、女子大學、早稻田より高田臺へかけての早稻田大學、市ヶ谷臺の陸軍士官學校、陸軍中央幼年學校、戸山學校、陸軍砲工學校、氷川臺の東京盲唖學校、小石川臺の高等師範學校、府立第二高等女學校、女子師範學校など、これ也。",
              "citation": {
                "source": "小日向臺",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖の下で、同じ職業をしている、盲唖学校の同窓の藤木という男が、三日にあげずに彼の家へ遊びにきた。",
              "citation": {
                "source": "二人の盲人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども地形の制限を受ける事多く、戦場ではほとんど盲唖である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "冴返るなどと云う時節でもないに馬鹿馬鹿しいと外套の襟を立てて盲唖学校の前から植物園の横をだらだらと下りた時、どこで撞く鐘だか夜の中に波を描いて、静かな空をうねりながら来る。",
              "citation": {
                "source": "琴のそら音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私共に応待した卓子の前にいた男は、立って行って、盲唖学校の近所にあるという一軒の家をサジェストした。",
              "citation": {
                "source": "思い出すこと",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前、西洋へ行くなら盲唖学校へはいって、あのそれ手真似、あいつを覚えときゃよかった。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れは隣村の鹿ヶ｜谷に盲唖院と云ふものを建てる趣意書を配つて応分の寄附金を勧誘する為であつた。",
              "citation": {
                "source": "蓬生",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は阿父さんの財嚢から沢山なお金、盲唖院の先生方の月給に差上げるお銭を持出して二｜月も帰つて来ないんだもの。",
              "citation": {
                "source": "蓬生",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お濱さんは居なかつたがおなじ様に鼠色の無地の単衣を着た盲唖院の唖者の男の子が二人、沼の岸の熊笹が茂つた中に蹲がんで、手真似で何か話し乍ら頷き合つて居た。",
              "citation": {
                "source": "蓬生",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "唖者の子等は人の気勢に駭いて、手に手に紅い死人花を持つた儘畑を横切つて、半町も無い鹿ヶ｜谷の盲唖院へ駆けて帰つた　貢さんは見送つて厭な気がした。",
              "citation": {
                "source": "蓬生",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "其内親分がある寡家に入り浸りになって、お広さんが其処に泣きわめきの幕を出したり、かかり子の亥之吉が盲唖学校を卒業して一本立になっても母親を構いつけなかったり、お広さんの末路は大分困難になって来ました。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "引き移つたばかりの阿佐ヶ谷の家から、歳男は、一週に三日、中野の盲唖学校へ点字を教へに出かけた。",
              "citation": {
                "source": "髪の毛と花びら",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗教団体、養老院、盲唖院、皇后が保護者となっている馬の休養所まで等しく「熱心に」「火急に」寄附を求めている。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二人の子供達は、上海の盲唖学校へ入れるように頼んで置こう」　孫永才は、流石に脱走となると、一抹の寂しさを感じない訳には行かなかった。",
              "citation": {
                "source": "雲南守備兵",
                "author": "木村荘十",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前は私共のお馴染であった、若い盲唖学校の生徒が、松村の肩につかまって、しきりと何か、持前のお喋りをやっているのであった。",
              "citation": {
                "source": "二銭銅貨",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポオの無韻詩「大鴉」の表現効果は、あのねえばあ・もうあとか、れのああとかいふ言葉の、寂しく遠い、墓場の中から吹いて来る風のやうな、うら悲しくも気味の悪い音韻の繰返す反響にある。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂書きの御婆さん「ヘー有難う、もうソチラの方は御済になりましたかなー、もうありませんかなー。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と彼女は云つた、奴はもうあのことを修道院の中に云ひふらしてゐる！",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "みじかい夏の夜はもうあけかかっていました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんたうにあなたのほしいものは一体何ですか、と訊かうとして、それではあんまり出し抜けだから、どうせうかと考へて振り返って見ましたら、そこにはもうあの鳥捕りが居ませんでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもあなたがたのいらっしゃる方なら農業はもうありません。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見えない天の川のずうっと川下に青や橙やもうあらゆる光でちりばめられ〔〕た十字架がまるで一本の木といふ風に川の中から立ってかゞやきその上には青じろい雲がまるい環になって后光のやうにかかってゐるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はもうあのさそりのやうにほんたうにみんなの幸のためならば僕のからだなんか百ぺん灼いてもかまはない。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕もうあんな大きな暗の中だってこわくない。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニはそのカムパネルラはもうあの銀河のはづれにしかゐないといふやうな気がしてしかたなかったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうあちこちで掘り出されました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
