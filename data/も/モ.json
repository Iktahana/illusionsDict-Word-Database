  {
    "uuid": "9ccff5aa-7d47-5cb7-8333-92e0bb9f3f69",
    "entry": "裳",
    "reading": {
      "primary": "も",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
