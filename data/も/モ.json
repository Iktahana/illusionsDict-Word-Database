[
  {
    "uuid": "4f36b411-17ac-542f-b5c1-a32cc5447c70",
    "entry": "喪",
    "reading": {
      "primary": "も",
      "alternatives": [
        "そう"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
