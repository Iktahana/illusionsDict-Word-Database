        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "mourning",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "みんなそれぞれ理由のある所であらうが、原因はいざ知らず、見渡した所感情が喪失されてある状態であること明らかであるやうである。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではそれは何時如何様にして喪失されていつたのであらうか。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "所でもし感情喪失が原因なれば、人は先づ退いて心身を休めるの必要があるのであらう点で、前二者とは趣を異にするのである。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自選詩集に採録されてる有明の詩は、彼の中での最も惡い作品であり、多くは修辭的の技巧に凝つて、リリツクの純眞性を喪失してゐるやうなものばかりである。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり言へば薄田泣菫氏や蒲原有明氏やは、或る若い時代だけ詩人であり、後に年を取つてからは、本質的にそのリリシズムを喪失してしまつたのである。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "以来、すべての物に喪の印の如く、私の目に停る所には何処にでも、その黒い汚点があるのを私はみる。",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら音楽が歌詞を本位とすればするほど、音楽としての散文化（リリシズムの喪失）を意味するからである。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に「あなたと呼べば」の如き唄が流行するのは、大衆が既にその心のリリシズムを喪失して、音楽でさへも、散文的な興味で聴かうとするところの、現代社会の時代的傾向を実証してゐる。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし現代の日本の子供が、果して或る人々の言ふ如く、本來の童話精神を喪失し、老成人の如く常識家化して居るならば、正にそれは日本文化の虚脱である。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし果して今の子供が、さうした眞の童話精神を喪失し、フアンタジイの夢を持たなくなつてしまつたことから、却つてその種の物への冷笑的態度を示すならば、正に大いに憂ふべき教育上の問題である。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我れは何物をも喪失せずまた一切を失ひ盡せり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも背広の片腕に黒い喪章を巻いていたような気がする。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、つひに、中國がその自らの獨立國としての存立を危くしてゐるのは、決して中國人たちの肉體の病氣の故ではなくして、あきらかに精神の病ひのせゐである、すなはち、理想喪失といふ怠惰にして倨傲の恐るべき精神の疾病の瀰漫に據るのであるといふ明確の結論を得るに到ります。",
              "citation": {
                "source": "「惜別」の意圖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "森々と青いこの対立、森々と…森々と……森森と青い………………………いつか向ふが人の分子を喪くしてゐる。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾日も喪心者のようになって彷徨したと云っている。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな目の子勘定をして紳士淑女の辛抱強いのに感心する一方では自分でこの仲間にはいろうという勇気を沮喪させていた。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術の世界に限らず科学の世界でも何か新しい事を始めようとする人に対する世間の軽侮、冷笑ないし迫害は、往々にして勇気を沮喪させたがるものである。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ちハイドがジキールにしたやうに、自己の一方の人格が、他の一方の人格を抹殺して、記憶から喪失させてしまひたいのだ。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした記憶の喪失ほど、不安で氣味のわるいものはない。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら或る時間内に於ける自己の行爲が、一切不明に失喪して、神かくしになつてしまふからである。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚かにも私は、また例の知覚の疾病「三半規管の喪失」にかかったのである。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "山で道を迷った時から、私はもはや方位の観念を失喪していた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その跡には、薄暗いベンチから身を起して、喪服を着た数人の婦人が続いた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョージ・佐野は喪心して夢遊病者のように部屋から出て行きました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "市内に行われていた全ての過去から続く催し物に喪が発せられ、結婚式の美しい半裸体の夜半の女の背中に機関銃の弾で穴だらけになったソビエットの赤い旗が迫って、宣伝隊の装甲自動車が租界内に侵入して宣伝ビラを配付した。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――夢も感激も喪つてゐながら、而も人間は容易に死ねやしない。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、私ははいる氣込をすつかり喪つてしまつた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それは女の身の上が餘に悲慘に過ぎてゐるためだつたらうか、それとも何か意識外の理由が働くためだつたらうか、女の話が進んで行くにつれて、私の心は初めの感動を喪つて、何故かだんだんに冷えて行くのであつた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "喪主らしい男は、一人だけ粗麻の喪帽をかむり、泣き女はわんわんほえながらあとにつゞいていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の野原を夏の風が行くに煙が去つた情熱の火が突進するブツカルものもなく――だから不可ない昔からあつたものだのに今新たに起つたものだそれを如何して呉れるい横から眺めてゐるな誰の罪でもない必要ぢやない欲しいだけだ",
              "citation": {
                "source": "情慾",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
