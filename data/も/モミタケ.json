        "examples": {
          "standard": [
            {
              "text": "標高の高いモミの林で、幻のキノコと言われる樅茸を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "樅茸は非常に大きく成長し、独特の強い香りと歯ごたえが特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "市場には滅多に出回らない樅茸を、地元の猟師さんから譲ってもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "足あとのにおいで主人を見つけようと思い、歩道の上をくんくんかぎまわってもみたけれど、その前にどこかのろくでなしが新しいゴムのオーバーシューズをはいて通ってしまったとみえて、今ではもう主人のかすかなにおいが、すっかりどぎついゴムのにおいにまざってしまって、何ひとつかぎわけることができなかった。",
              "citation": {
                "source": "カシタンカ",
                "author": "КАШТАНКА",
                "note": "青空文庫"
              }
            }
          ]
        }
