    "definitions": [
      {
        "index": 1,
        "gloss": "you",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この親不孝者どもが！",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵目ぼしい、小作人組合の主だった、（ならず者ども）は、残らず町の刑務所へ抛り込まれてしまった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そんなことはもう昔のことであつて、そして今はその長い、古い屋敷には見知らぬ者どもが住んでゐるのかと思ふと、私には大へん苦しかつた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "満洲や台湾の苦力や蕃人を動物を使うように酷使して、しこたま儲けてきた金で、資本家は、ダラ幹や、社会民主主義者どもにおこぼれをやるだろう。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "懐手をして、彼等を酷使していた者どものためだ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子の仕業でも無し、長屋の者どもの仕業でもないとすれば、猫婆の死は医者の診断の通り、やはり卒中の頓死ということに決めてしまうよりほかはなかったが、半七の疑いはまだ解けなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しこの場合、ほかに詮議のしやうもないから、差當つては先づ屋敷中の者どもを集めて問ひ糺してみようと云ふのであつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし義兄の手前、屋敷中の者どもの手前、なんとかをさまりを付けなければなるまいが、何うしたものでござらう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず行者一家の者どもを引き挙げて、それをぶっ叩いて白状させるよりほかあるまいと、かれは内々でその手配りにかかっていると、あしたが池上のお会式という日の朝、多吉があわただしく駈け込んで来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "焚火にあたっていた者どもや、部屋にいた連中が、車からおろされる武器をかつぎこんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "澄元契約に使者に行った細川の被官の薬師寺与一というのは、一文不通の者であったが、天性正直で、弟の与二とともに無双の勇者で、淀の城に住し、今までも度魔法に凝り募って、種下らない者どもだ、と見えたに疑ない。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "マタイ十章、二八、「身を殺して霊魂をころし得ぬ者どもを懼るな、身と霊魂とをゲヘナにて滅し得る者をおそれよ」この場合の「懼る」は、「畏敬」の意にちかいようです。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "因りて倩々案ずるに、國許に候恩田杢と申者、老職末席にて年少なれど、きつと器量ある者につき、國家の政道を擧げて任せ申さむと存ずるが、某も渠も若年なれば譜代の重役をはじめ家中の者ども、決して心服仕らじ、しかする時は杢が命令行はれで、背く者の出で來らむには、却て國家の亂とならむこと、憂慮しく候。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "綿のように疲れきって牢屋に帰ってくると、名主や役附の者どもは彼の剛胆を褒めそやして、総がかりで介抱してやった。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれが今日は海老責に逢うことを牢屋附の下男の内報によって、牢内でも薄々承知していたので、ひそかにその安否を気配っていると、かれは問い落されもせず、責め殺されもせず、弱りながらも無事に帰って来たので、牢内の者どもは跳りあがって喜んだ。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "牢内で役附の者どもは彼の最後を飾るべく、新しい麻の帷子に新しい汗襦袢と新しい帯と新しい白足袋とを添えて贈った。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏草や兵者どもの夢の跡――わたしも芭蕉翁を気取って、しばらく黯然たらざるを得なかった。",
              "citation": {
                "source": "九月四日",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "初七日や松茸飯に豆腐汁　家内の者ども打連れて青山へ墓参にゆく。",
              "citation": {
                "source": "叔父と甥と",
                "author": "――甲字楼日記の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿の実の紅きもさびし雑司ヶ谷　二十九日、英一の三七日、家内の者ども墓参にゆくこと例のごとし。",
              "citation": {
                "source": "叔父と甥と",
                "author": "――甲字楼日記の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは取り分けて寒い日であるのに、達者にまかせて老人が早朝から若い者どもと一緒になって立ち働いた為に、こんな異変をひき起こしたのであるが、さのみ心配することはない。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "城内には施薬院のやうなものを設けて、領内のあらゆる名医がそこに詰めあひ、いかなる身分の者でも勿論無料で診察して取らせる、投薬もして遣るといふのであるから、領内の者どもは皆その善政をよろこんで、名主や庄屋をたよつて遠方からその診察を願ひに出てくる者も多かつた。",
              "citation": {
                "source": "梟娘の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しみだりにこんなことを世間に発表してはならぬと、主人の大之進は家中の者どもの口を封じさせた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより直ぐに四条河原へ行って、今度、桂川を流れ下った長持の風説を、芝居に仕組んで興行することまかりならぬと、乞食役者どもへ固く申付けよ」と仰せられた。",
              "citation": {
                "source": "殺人迷路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての易者と星占家（家相家や、人相見や、八卦師や）は、かうした彼等の所謂亡者どもを濟度するため、矛盾にも此處で前説を豹變し、逆に今度は、意志の自由が運命を支配すること、自覺と心がけとによつて、何人も意識的に人相を變へ、惡しき手相を善き手相にし、自由に運命を支配し得ることを辯解する。",
              "citation": {
                "source": "易者の哲理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての易者と星占家（家相家や、人相見や、八卦師や）は、かうした彼等の所謂亡者どもを済度するため、矛盾にも此処で前説を豹変し、逆に今度は、意志の自由が運命を支配すること、自覚と心がけとによつて、何人も意識的に人相を変へ、悪しき手相を善き手相にし、自由に運命を支配し得ることを弁解する。",
              "citation": {
                "source": "易者の哲理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その噂は、このエルシノアの城下より起り、次第にデンマーク一国にひろがり、とうとう外国の大学にいる者どもの耳にまではいって来たものであります。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸の中に、いつも、うらみを抱いているように見えるものですから、城中の者どもにも、けむったがられ、あまり好かれないようじゃありませんか。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（縁側にどかりと腰をおろし）いかに我等国民学校教員が常に赤貧洗うが如しと雖も、だ、あに必ずしも有力者どもの残肴余滴にあずからんや、だ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪しきものども、何とてやはわれをみいだし得む、愚なる、と冷かに笑いしに、思いがけず、誰ならむたまぎる声して、あわてふためき遁ぐるがありき。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その青じろい月の明りを浴びて、獅子は檻のなかをのそのそあるいて居りましたが、ほかのけだものどもは、頭をまげて前あしにのせたり、横にごろっとねころんだりしづかに睡ってゐました。",
              "citation": {
                "source": "月夜のけだもの",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
