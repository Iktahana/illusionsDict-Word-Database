        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すると途中からもう一人同じ帽章をつけたのが乘り込んで、いきなり入口に近く腰掛けて居た一人の肩をたゝき「オイ、どうした」と聲をかけた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新喜楽のまえの女将の生きていた時分に、この女将と彼女と、もう一人新橋のひさごあたりが一つ席に落合って、雑談でも始めると、この社会人の耳には典型的と思われる、機知と飛躍に富んだ会話が展開された。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一人はなんだか元気がなくて襟頸もあまり焼けていない。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　娘は、十五でもう一人前の女になっていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「山路来て何やらゆかしすみれ草」でも、すみれと人とが互いにゆかしがっているのを傍からもう一人の自分が静かにながめているような趣が自分には感ぜられる。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいつも「おくにの話」をねだってはおしまいに「あたしもお国へ行きたいなあ」と一人が云うと、もう一人が同じ言葉を繰返すのである。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事かと思って出てみると、国際電報によって昨年度と今年度のノーベル賞金の受賞者の名前の報知が届いた、その一人はアインシュタインで、もう一人はコーペンハーゲンのニールス・ボーアという人だそうだが、このボーアという人はいったいどんな人でどういう仕事をした人かというのである。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一人の車掌もやって来て、同じ切符にもう一つ穴をあけた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも自分というものが二人居て、絵を描いている自分のところへ、ひょっくりもう一人の自分が通りかかって、ちょうどさっきの老人のように話をしかけたのだという気がする。",
              "citation": {
                "source": "断片（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そいつ一人ぎりか、ほかに連れはねえのか」「もう一人いるそうですが、そいつは今朝早くから山の手の方に商売に出たそうです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ又、もう一人、小柄な大褂児の支那人が、ひょこひょこッと這入って来た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰でもふとそんな気持に誘われるんじゃないか、というのですが、どうです、あなたはそうしたことをお考えにはならないですか」　もう一人の青年は別に酔っているようでもなかった。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくして私が眼を砂浜の方に転じましたとき、私は砂浜に私以外のもう一人の人を発見しました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "――両親、兄、Ｏ及びもう一人の友人がその時に手を焼いた連中です。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「動力じゃねえよ」ともう一人が答えました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "三「今にもう一人ここへ来て寝るそうじゃが、お前様と同国じゃの、若狭の者で塗物の旅商人。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小雨のかゝるやうに、水筋が立つほど、幾らでも、といふ……半から、緑蝶夫人は気を籠めて、瞳を寄せ、もう一人は掌をひら／＼動かし、じり／＼と卓子台に詰寄ると、第一｜番に食意地の張つてる家内が、もう、襷を掛けたさうに、「食べられるの。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのいわゆる実見談が、もう一人の仲介者を通じて伝えられる時は、もう肝心の事実はほとんど蒸発してしまって、他のよけいなものやまるで反対のものなどが入り交じってしまっている。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行ったら佐吉さんと、もう一人江島という青年が、にこりともせず大不機嫌で酒を飲んで居ました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一人の同宿者があった。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると途中からもう一人同じ帽章をつけたのが乗り込んで、いきなり入り口に近く腰掛けていた一人の肩をたたき「オイ、どうした」と声をかけた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのもう一人は歌人のＳ・Ａ氏である。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一人は悠然としてズボンのかくしに手を入れ空を仰いで長嘯漫歩しているふぜいである。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそのためにもう一人の委員と連れ立って始めて田丸先生の下宿を尋ねた。",
              "citation": {
                "source": "田丸先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ろくな元資も持たず七年前に富山から移住してきた男だったが、水田にかけては経験もあるし、人間もばかではないようだったから、……その……何んとかいったなあもう一人の養子は……何んとかいった、それにわしが推薦したのがもとになったんだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「若様もお待ちかねよ」　ともう一人のがいった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、このお爺さんの近所に、もうひとり、左の頬にジヤマツケな瘤を持つてるお爺さんがゐたのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼鏡をかけているのが、その顔役の人で、もうひとりの、色の白いのが撮影所の所長です。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなかにも子供がいるし、背中にひとりおんぶして、もうひとりの子の手をひいて、そうして自身もかぜ気味で、一斗ちかいお米を運ぶ苦難は、その涙を見るまでもなく、私にもわかっている。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうひとりまへだよ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
