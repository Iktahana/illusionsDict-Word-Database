        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「……追われているわけでもないんだな」　そう呟いた途端、角の家の門灯がすっと消えた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると半身を衛門の上に輝く煌々たる門灯に照し出された歩哨が、剣付銃をこっちへ向けて身構えをしていました。",
              "citation": {
                "source": "壊れたバリコン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "門灯の光りのとどかぬ雪の上には、矢代と医者と二人の通った跡だけ窪んで見えた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "便所の窓を明けると門灯がポカリとついて、むかあし山国で見たしゃくなげの紅い花のようで、とても美しかった。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず、簷の上には、思いきり大きな看板が二階をすっかり目隠しするように据っていたが、その簷のところには四角形の大きな門灯もあり、それから、静三が立っている脇にも、軒から吊るす板看板が三つ四つ並んでいて、路上には台八車が一台放ってある。",
              "citation": {
                "source": "昔の店",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "その、すばしこい微妙な動作は、静三が気がついた時には、もう次の家の軒に灯を入れているのだったが、簷の四角形の門灯に灯が点くともう夜の領分であった。",
              "citation": {
                "source": "昔の店",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "街灯と門灯だけが光っています”　報告は、櫛の歯をひくように、烏啼天駆のところへ集ってくる。",
              "citation": {
                "source": "烏啼天駆シリーズ・４　暗号の役割",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂下の或る門灯の光りが、ぼんやり見えてるきりで、坂全体が薄暗い。",
              "citation": {
                "source": "猫捨坂",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂の上に立つと、彼方の門灯の明りがかすかにさしてるだけで、御影石の敷石がほんのりと白み、コンクリート造りの崖とコンクリート造りの塀との間に、陰湿な気が深く淀んでいる。",
              "citation": {
                "source": "猫捨坂",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この門灯は直ぐ消えるようになっていますかッ」「ええ、直ぐ消えるように、なってますよ。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "意外にも、夫と隆夫とが、門灯の光を浴び、にこにこして肩を並べていたからだ。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場はもとより、宅の並びにも門灯の附いているのは一、二軒ですから、月もない頃で、下駄の音がまだ聞えるのに、もう姿は見えません。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "門灯の下で車夫は汗を拭き拭き笑っています。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜霧の中の小野医院の、赤い門灯が遠い所に浮かんでいるように思われた。",
              "citation": {
                "source": "夢幻泡影",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "門灯の光で、千種の風体には怪しいところは無いと見た様子ですが。",
              "citation": {
                "source": "音波の殺人",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "門灯の下で金を勘定して運転手を返した私が、玄関へ立つともう学校の早い子供たちも寝て、女中たちは勝手元で忙しかったとみえて、「まあ公一さん！",
              "citation": {
                "source": "逗子物語",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりは、まっくらですが、門灯の光で、かすかに見えるのです。",
              "citation": {
                "source": "妖星人Ｒ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "外に出て、門灯の光で、門の柱を見あげますと、そこに出ている表札には「目黒区｜上目黒六丁目一一〇〇、今井きよ」という女の名まえが書いてありました。",
              "citation": {
                "source": "大金塊",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりのこされた刑事は、まだしりもちをついたまま、きみ悪そうになわを引きよせて、その腕を手にとり、門灯の光にかざしてみました。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」刑事はふとあることに気づいて、急いで立ちあがると、しばられたままの両の手首を、近々と門灯にさしつけ、目をこらしてながめました。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、門灯のぼんやりした光の中へ、近づいたのを見ると、小林君よりもずっと小さい少年でした。",
              "citation": {
                "source": "夜光人間",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
