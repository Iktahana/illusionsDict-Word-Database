        "examples": {
          "standard": [
            {
              "text": "「物も言い様」とは言うが、そんなに冷たく断らなくてもいいじゃないか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼のアドバイスは正しいのだが、もう少し「物も言い様」で印象が変わるはずだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "物も言い様で、褒め言葉のつもりでも相手を怒らせてしまうことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "全く、丸い玉子も切りようで四角にも三角にもなるごとく、ものもいいようで角がたつのです。",
              "citation": {
