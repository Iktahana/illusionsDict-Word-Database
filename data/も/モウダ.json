          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "豚は彼の猛打を浴びて、またそこからワイシャツの方へ引っかえした。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャメル軍の猛打者桃山外野手の住居である。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲がもうだいぶ高くなつて、路にそつてる箇所はズツとホコリで殆んど黒くなつてるのが、熱い上に熱くした。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事を始めて気づいて驚いている私の鼻の先に突き出た楓の小枝の一つ一つの先端には、ルビーやガーネットのように輝く新芽がもうだいぶ芽らしい形をしてふくらんでいた。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源はもうだまつて居ることが出来なくなつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとしきり、そのやうに凄じくあばれて、さすがにもうだめだ、といふやうな疲れ切つた顏つきをして鎌を投げ捨て、「これ、見ろ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車はもうだんだん早くなって、すすきと川と、かはるがはる窓の外から光りました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがボートは左舷の方半分はもうだめになってゐましたから、とてもみんなは乗り切らないのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらもうだんだん早くなったでせう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子はいかにもつらさうに眼を大きくしても一度こっちをふりかへってそれからあとはもうだまって出て行ってしまひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしていよいよ寝込む頃にはもうだいぶ病気は亢進して危険に接近しているであろう。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、人には、もうだいじょうぶだ、癒った、と言った。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "近辺の葉はもうだいぶ喰い荒されているのであった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車はもうだんだん早くなって、すすきと川と、かわるがわる窓の外から光りました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがボートは左舷の方半分はもうだめになっていましたから、とてもみんなは乗り切らないのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら、もうだんだん早くなったでしょう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子はいかにもつらそうに眼を大きくしても一度こっちをふりかえってそれからあとはもうだまって出て行ってしまいました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（いえ、もうだいぶ勝手が分っております。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでもうだいたいできあがったと思うと、実はできあがっていないという証拠が足元から発見される。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのころからもうだいぶ悪くなっていた自分の胃はその日は特に固く突っ張るようで苦しかった。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベコニアはすっかり枯れて茎だけが折れた杉箸のようになり、蟹シャボの花も葉もうだったようにベトベトに白くなって鉢にへばりついている。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、もうだいぶ肩が凝って苦しくなって来たけれども奮発して直し始めた。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなって来るともうだいたいの経過の見通しがついたわけであるが、ただ大切なタンバックルの留め針金がどうして切れたか、またちょっと考えただけでは抜けそうもないネジがどうして抜け出したかがわからない。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日前に座席をとったのであるが、二階の二等席はもうだいたい売り切れていて、右のほうのいちばんはしっこにやっと三人分だけ空席が残っていた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうだいぶ長く雨風にさらされて白くされ古びとげとげしく木理を現わしているのであるが、その柱の一面に年月日と名字とが刻してある。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なるべく見ないように努めているんだけれど、いちど見ちゃったら、もうだめね。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがボートは左舷の方｜半分はもうだめになっていましたから、とてもみんなは乗り切らないのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら、もうだんだん早くなったでしょう」さっきの老人らしい声が言いました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子はいかにもつらそうに眼を大きくして、も一｜度こっちをふりかえって、それからあとはもうだまって出て行ってしまいました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
