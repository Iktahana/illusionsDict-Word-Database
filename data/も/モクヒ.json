[
  {
    "uuid": "36da05f5-a07d-591e-94a2-04d27a4863d4",
    "entry": "黙秘",
    "reading": {
      "primary": "もくひ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
