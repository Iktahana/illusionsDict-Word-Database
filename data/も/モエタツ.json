[
  {
    "uuid": "14dc4a2a-3256-54d1-8673-e23a1b4abb02",
    "entry": "燃え立つ",
    "reading": {
      "primary": "もえたつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "Godan verb with 'tsu' ending",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to blaze up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "中原〔逐〕鹿三十年、恩怨無別星花転、転と来て転句だ……おゝ何といふ向ふの眼、燃え立つやうな憎悪である。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（燃え立つ焔に包み取られて外道の論師は再び大地に没する。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　やがてお千世が着るようになったのを、後にお孝が気が狂ってから、ふと下に着て舞扇を弄んだ、稲葉家の二階の欄干に青柳の糸とともに乱れた、縺るる玉の緒の可哀を曳く、燃え立つ緋と、冷い浅黄と、段染の麻の葉｜鹿の子は、この時見立てたのである事を、ちょっとここで云って置きたい。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくして、その半眼に閉じた目は、斜めに鳴鶴ヶ｜岬まで線を引いて、その半ばと思う点へ、ひらひらと燃え立つような、不知火にはっきり覚めた。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "パッと燃え立つ毛氈に。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄金を溶す炎のごとき妙義山の錦葉に対して、ハッと燃え立つ緋の片袖。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども未亡人の燃え立つような美しさと、その眼に籠めた情火に打たれて意気地なくうなだれた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども姉はそんなに手きびしく断られるといよいよ総身が燃え立つように欲しくなり、妹に較べておとなしいとはいうものの、普段おとなしい子こそ思いつめた時にかえって残酷のおそろしい罪を犯す。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "花やかで美しかった、暖かで燃え立つようだった若い時のすべての物の紀念といえば、ただこの薄禿頭、お恰好の紅絹のようなもの一つとなってしもうたかとおもえば、ははははは、月日というものの働きの今更ながら強いのに感心する。",
              "citation": {
                "source": "太郎坊",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸で飛込んだ、侍方、船に寄りは寄つたれども、燃え立つ炎で手が出せぬ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然も燃え立つばかりの緋の扱帯は、今しも其の腰のあたりをする／＼と辷つた如く、足許に差置かるゝ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "輝く崖の上の麦畠、くわつと燃え立つ杉の木、松の木、朱欒の木。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "くわつと燃え立つ杉の木、松の木、朱欒の木。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "深く燃え立つ悲哀は彼らを擾す。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰻のすべるは蛇のすべるに異ならねど、こはもと海のものなれば、陸には馴れず、凡て寂しく、痛々しく、草につまづき、闇に燃え立つくれなゐの花にからまる。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "静けさや、壮厳微妙の夜の鰻、彼こそは実に光り滾るる力の電池、渾身これ滑りながるる精霊の姿そのまま、闇を飛び越え、また、燃え立つくれなゐの花を飛び超ゆ。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは燃え立つような細い赤い実のつやつやとむらがった名も知らぬ木の藪があった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまさかに、障子が橙色の灯影に燃え立つように明って見える二階はあったが、それでもまだ素見の客の姿も、そこらの格子戸の中には見透かせなかった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それは云い知れぬ思いに燃え立つ妖火のような頬の輝やき、眼の光り……と見るうちに懐中の匕首、抜く手も見せず、平馬の喉元へ突きかかった。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽や香のいい草のことなど忘れてしまひただかなしげに　きらきら　きらきら　灼けてゐた　※　溢れひたす闇に美しいものになら　ほほゑむがよい涙よ　いつまでも　かはかずにあれ陽は　大きな景色のあちらに沈みゆきあのものがなしい　月が燃え立つたつめたい！",
              "citation": {
                "source": "暁と夕の詩",
                "author": "立原道造",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑の幅もおほよそ二三町のもので、それが續きも續いたり、松原の見ゆる限りは同じ樣にこの燃え立つた花の畑が東西にかけてうち續いてゐるのである。",
              "citation": {
                "source": "樹木とその葉",
                "author": "春の二三日",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼の即興詩を作る燃え立つような神速さにいたっては、同じようには説明することができない。",
              "citation": {
                "source": "アッシャー家の崩壊",
                "author": "THE FALL OF HOUSE OF USHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔も手足も、それこそ雪のように真白く透きとおっていたが、それが黒い髪を長々とうしろへ垂らして、燃え立つような長襦袢を裾も露わに引きはえつつ、青白い光線をふり仰いで眼を細くした姿は淫りがましいと云おうか、神々しいと形容しようか。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、雪なす膚に、燃え立つ鬼百合の花は、吸消されもせず、しぼみもしない。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぱッと末枯の路の上に、燃え立つを見るや否や、慌ててくるりと背後向、踵を逆に回らしたのを、袖で留められた形になって、足も地にはつかずと知るべし。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすこのもみじは、実際、そこからが自慢なんですが、足も停めず、視めもせず、アーチ形に中の透く、燃え立つ炎のような中へ、消え失せた体に入ってしまった。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い葉が目に眩きばかり燃え立つて居る。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪のために薄くぼかされたまっ黒な大きな山、その頂からは、火が燃え立つように、ちらりちらり白い波頭が立っては消え、消えては立ちして、瞬間ごとに高さを増して行った。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は興奮に燃え立ついらいらした心でそこにいる事務長の姿をいろいろ想像していた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら、芸術は作者の内部に燃え立つて来た活動でなければならないから。",
              "citation": {
                "source": "三月の創作",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
