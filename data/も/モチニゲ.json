    "definitions": [
      {
        "index": 1,
        "gloss": "making off with (something)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "百円がところ品物を持ち逃げしやがった！",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつが四人分の弾丸や鉄砲を持ち逃げして土匪の仲間入りをしていたのを捕まえて来たんだって。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼の腕みたいに持ち逃げしません。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "紳士親娘の様子を考えると、船の持ち逃げでもあるまい。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はすぐ承知したが、それから二月たたぬ内に横堀は店の金を持ち逃げした。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が持ち逃げせる金の内には大功は細瑾を顧みずちょう豪語を楯となせる神奈川県の志士が、郡役所の徴税を掠めんとして失敗し、更に財産家に押し入りて大義のためにその良心を欺きつつ、強いて工面せる金も混じりしぞや。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の暮れ、丸多の手代が懸け金の持ち逃げをした時に、手先の亀吉が調べに来て、与兵衛や幸八らとも顔馴染になっているので、幸八がその使を云い付かったのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、例の五百両は郡兵衛が持ち逃げをしたわけです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺された郡兵衛は悪銭身に着かずで、持ち逃げの金はみんな道楽に使ってしまい、今では本郷辺の旗本屋敷の若党に住み込んでいて、その日は千駄ヶ谷辺の知りびとのところへ尋ねて行く途中、子供のみやげに柿を買っている処を、おのれ盗賊とばっさりやられたのですが、全く盗賊に相違ないのですから仕方がありません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分達がミヽヅクを持ち逃げして、皆なに迷惑をかけてバツが悪いもので、酔つた振りでもしたんでせう。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が病人であるのを幸いに、夜なかに持ち逃げでもされては大変である。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを承知で、持ち逃げをした奴もあるわけです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝蔵が持ち逃げかえ」「いえ、庭さきに捨ててありました」と、鶴吉は云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "吉良の脇指",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは誰かこまかくして来たらと気づいてもまた町中まで一人いってはそのまま持ち逃げされそうな気がされて誰も一人に許そうとはしないのだ。",
              "citation": {
                "source": "時間",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、その鼻氏とやらは、よほどの大金を持ち逃げしたんですか？",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十万円の金を持ち逃げして来た後めたさがあつたが、ゆき子は、伊庭も、成宗も、怖ろしいとは思はなかつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆき子を道づれにして、容赦なく、女の思ひ出の伴奏者になりおほせてはゐるものの、ゆき子の持ち逃げした金にも、多少の魅力はあつたかも知れない。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本なくて善人の神様を油揚げか何かで欺しておき、絵はほしいがどこで何を買ったらよいのか、不案内という愛好家や、少しも油絵などほしいとも思わない金持ちの応接室へ無理矢理に捻じ込むものがあったり、作品を持ち逃げしたりする高砂屋もあるらしい。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝石が、たまたま出るとそれを持ち逃げして追手を避け避け、外国船に売り込む……。",
              "citation": {
                "source": "一週一夜物語",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その前に、いくら夫婦の間でも金銭のことは明瞭にしておかなければならないとヘンリイが主張して、彼は、二年前に持ち逃げしたアリスの金にたいして、この時あらためて借用申候一｜札之事を入れている。",
              "citation": {
                "source": "浴槽の花嫁",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも困つたのは、変心した従者が薬品の箱を持ち逃げしたことでした。",
              "citation": {
                "source": "アフリカのスタンレー",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――上海からの手紙のことは真実で、あの時持ち逃げした金の残りで、一寸公言をはばかる非合法な仕事をやって、まあ相当の財産が出来たので、東京へ舞戻ったのだった。",
              "citation": {
                "source": "死の前後",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばかな、誰が持ち逃げなんかするものか。",
              "citation": {
                "source": "潮風",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "持ち逃げするような気のきいた品物が一つだってあるかい。",
              "citation": {
                "source": "潮風",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、今宿へ戻って検べてみると、庄左衛門は他人の金品まで持ち逃げしている！",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はソノ子をつれて三週間の出張旅行を共にしたが、出張とはデタラメで、公金を持ち逃げして、盲滅法逃げまわっていたのである。",
              "citation": {
                "source": "行雲流水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "まにうけて上野探訪にでかけたら、唖の女の子にはめぐり合わないし、お客を大切にして、ジャングルの平和をまもる情に溢れているどころか、一しょに泊った女の子に財布を持ち逃げされたよ、こまるじゃないか、アッハッハヽというようなわけだ。",
              "citation": {
                "source": "巷談師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
