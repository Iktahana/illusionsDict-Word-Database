    "definitions": [
      {
        "index": 1,
        "gloss": "being so content that one would not mind dying",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長年取り組んできたこの事業を無事に後継者に引き継げれば、私はいつ引退しても以て瞑すべしという心境です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "生き別れた娘に一目会うことが叶うなら、その時はもう、以て瞑すべき思いでこの世を去れます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "恩師の墓前でようやく成功の報告ができ、これで私も少しは以て瞑すことができる気がします。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "人を斬るのに、最も豊富な経験を持つ、近藤勇をして、この嘆声を発せしめたのであるから、殉難の志士も以て瞑すべしだ。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "客の他の一人、この蘭人や南蛮女も亦以て瞑すべしですか。",
              "citation": {
                "source": "長崎小品",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "友吉たるもの以て瞑すべしだろう。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "コイツが君の手にかかって物をいうとなれば、友吉おやじイヨイヨ以て瞑すべしだ。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "崔述は其の死後百五十年、海外の日本で、先生の如き有力なる知己を得た以上は、以て瞑すべしである。",
              "citation": {
                "source": "那珂先生を憶ふ",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
