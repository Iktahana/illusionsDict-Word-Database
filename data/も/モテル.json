        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「向うの座敷じゃ、大にモテるネ」　と榊は正太に言った。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中連サインブックを持ってつめかける、やっぱり映画の方が人気あり、藤山一郎より杉狂がモテる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
