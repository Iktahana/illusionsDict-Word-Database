    "definitions": [
      {
        "index": 1,
        "gloss": "cuff (of pants)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
