        "examples": {
          "standard": [
            {
              "text": "パンクロックのバンドのメンバーは、皆ド派手なモヒカンだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は成人式に気合を入れてモヒカンに挑戦し、周囲を驚かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "若い頃はモヒカンヘアに憧れたが、結局勇気がなくてできなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "アメリカのホーソーン（古典だけれど）に、「モヒカン族の最後――ラスト・オブ・ザ・モヒカンズ」というのがあり、インディアンをかいたものです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
