[
  {
    "uuid": "de62d892-8a64-5ec5-b02e-b73be1408464",
    "entry": "物語る",
    "reading": {
      "primary": "ものがたる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
