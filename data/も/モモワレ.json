    "definitions": [
      {
        "index": 1,
        "gloss": "hairstyle of Meiji and Taisho era, featuring a bun resembling a halved peach",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "どちらも都の者らしく、男は学生式のオールバックで、女は下町風の桃割れに結っていた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めから嘲弄されていたことがわかったので……同時に、横に居た桃割れも、ワッとばかり男の膝に泣き伏した。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きく結んだ背中の帯と、両方へ捌き拡げた両袖とが、ちょっと三番叟の形に似ているなと思う途端に、むくりと、その色彩の喰み合いの中から操り人形のそれのように大桃割れに結って白い顔が擡げ上げられた。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "節分の日、もうその歳ではいくらか気がさす桃割れに結って、源聖寺坂の上を、初枝が近所の桶屋の職人の新太郎というのと、肩を並べて歩いている姿を、他吉は見つけた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "初枝は桃割れに結って、口から下は写っていなかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、その娘と深い恋仲になっていたものであるが、或る夕方のこと、その娘が私に会いに来た時の桃割れと振袖姿が、あんまり美し過ぎたので、私は息苦しさに堪えられなくなって、彼女を郊外の××踏切り附近の離れ家に連れ込んだ。",
              "citation": {
                "source": "縊死体",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "未だ結婚前の写真らしく、そんなことから二人の仲がねんごろめいたのか、君枝の母親は桃割れを結って、口から下は写っていなかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "琴　学生時代には本郷へんの屋敷町を歩いているとあちらこちらの垣根の中や植え込みの奥から琴の音がもれ聞こえて、文金高島田でなくば桃割れ銀杏返しの美人を想像させたものであるが、昨今そういう山の手の住宅区域を歩いてみても琴の音を聞くことはほとんど皆無と言ってもいいくらいである。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がこの家にはじめて来たころはようよう十四五ぐらいで桃割れに結うた額髪をたらせていた。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い帯、頭のてっぺんに載っている桃割れ。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、もう十九にもなつたのだが、桃割れに結つたり、赤い帯を締めたりしてゐると伯五郎達が袖をとらへて酒の酌を強ひ、毒牙を研ぐので、止むなく髪をボーイツシユ・バヴに切り、徽章もバンドもついてゐない雪太郎の中学生時代の古帽子を眼深く被つてゐた。",
              "citation": {
                "source": "沼辺より",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "）すらりとした――桃割れ、白い歯Ｆさんの顔Ａ子さんの眼（オヤ！",
              "citation": {
                "source": "都会と田園",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "お君ちやんと呼ばれた娘の方を兵野が眺めると、丈のすらりとした細おもての、髪を桃割れに結つた、一見、場末の雛妓風に装つた小娘が、おでんの鍋の傍らで燗番役をつとめてゐた。",
              "citation": {
                "source": "露路の友",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は今日は珍しく桃割れに結って、やはり日本風に丸髷にあげた母親につれられていた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "店には綺麗な娘さんの売り子がいて、桃割れを緋もみの裂でつつんだりして帳場に坐っていた。",
              "citation": {
                "source": "四条通附近",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸髷、つぶし島田、先笄、勝山、両手、蝶々、三ツ輪、ふく髷、かけ下し、切天神、割しのぶ、割鹿子、唐団扇、結綿、鹿子天神、四ツ目崩し、松葉蝶々、あきさ、桃割れ、立兵庫、横兵庫、おしどり（雄）と（めす）とあり、まったく賑やかなことであって、いちいち名前を覚えるだけでも、大変な苦労である。",
              "citation": {
                "source": "髷",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は桃割れの髪をかしげて電車のガラス窓で直した。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "灯のつき始めたすがすがしい部屋に、私の胸に泣きすがったあのひとが、桃割れに結ったあの女優とたった二人で、魚の様にもつれあっているのを見たのです。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お糸さんは引きつめた桃割れをかしげて、キュキュと糸をしごきながら、見た事もないようなきれいな布を縫っていた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃割れに結ったお菊さんと、お君さんと私、バラックの女給部屋には、重い潮風が窓から吹きこんでくる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃割れにゆった女が自転車で廓の道を流しているので、男も女も立ちどまっては見て行くなり。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃割れに結って貰う。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はまだ桃割れの似合う若さだのに、いちょうがえしでなければならないときいてがっかりしてしまう。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "出て来たのは十六七ばかりの桃割れの少女であったが変につんつるてんな着物を着ている。",
              "citation": {
                "source": "魚の序文",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その娘は銀色の丈長と云ふのを掛けて、ひつつめの桃割れに結つてをりましたが、此島の置屋（芸者屋）の娘ででもあるのでせう、仲々はきはきとしたものごしで、何がをかしいのか、ラムネの栓を抜いてもくちにむせてばかりゐて、はかばかしくラムネの水が減つてゆきませんでした。",
              "citation": {
                "source": "小さい花",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、由はひな子に連れられて、町に一軒しかない銭湯から帰つて来ると、銀の丈長を巻いて髪結のすきてから桃割れに結つて貰ひました。",
              "citation": {
                "source": "小さい花",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お糸さんは引きつめた桃割れをかしげて、キュキュ糸をしごきながら、見た事もないような昔しっぽい布を縫っていた。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "灯のつき初めた、すがすがしい部屋に、私の胸に泣きすがったあの男が、桃割れに結った、あの女優と、魚の様にもつれあっている。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃い髪を前髪を大きめにとって、桃割れには四分ばかりの白のリボンを膝折り結びにかたく結んでかけてお出でした。",
              "citation": {
                "source": "大塚楠緒子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
