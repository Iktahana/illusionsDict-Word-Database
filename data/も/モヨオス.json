    "definitions": [
      {
        "index": 1,
        "gloss": "to hold (an event)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "草花に処々釣り下げたる短冊既に面白からぬにその裏を見れば鬼ころしの広告ずり嘔吐を催すばかりなり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽妙な仕上げを生命とする一派の人の眼で見ればあるいは頭痛を催す種類のものかもしれない。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどいのになると、穢い話だが嘔吐を催す。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の眠｜催す様なるこの水音を源叔父は聞くともなく聞きてさまざまの楽しきことのみ思いつづけ、悲しきこと、気がかりのこと、胸に浮かぶ時は櫓握る手に力入れて頭振りたり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ或は温泉で催すといふ花火会のことであるか、或はこれ郷土舞踊大会であるか。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じような起重機の空中舞踊でもいつか見たロシア映画では頭痛とめまいを催すようなものになっていたようである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時分からあれを見るとぞうっと総毛立って寒けを催すと同時に両方の耳の下からあごへかけた部分の皮膚がしびれるように感ずるのであった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのおりおり憶い起こして涙催すはかの丘の白雲、かの秋の日の丘なりき。",
              "citation": {
                "source": "詩想",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとしきり明るかった夕方の光は、早くも藻巌山の黒い姿に吸いこまれて、少し靄がかった空気は夕べを催すと吹いてくる微風に心持ち動くだけだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぬいはそのすえたような匂いをかぐと、軽い嘔気さえ催すのだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで錐を用意して置いて眠気を催す度に膝を刺して眼を醒すようにしたという事蹟であった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また彼方では、一團の水兵がワイ／＼と騷いで居るので、何事ぞと眺めると、其處は小高い丘の麓で、椰子や橄欖の葉が青々と茂り、四邊の風景も一際美はしいので、今夜は此處に陣屋を構へて、大祝賀會を催すとの事、其仕度に帆木綿や、檣の古いのや、倚子や、テーブルを擔ぎ出して、大騷ぎの最中。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから秋冷相催すと、次第に、燒芋の買ひツこ、煙草の割前で睨み合つて喧嘩をするのだが、――此の一篇には預る方が至當らしい。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夜はあたかも嫩会の若き人々わが家にあつまりて劇談会を催す例会の夕なりしかば、通知するまでもなく皆々来りあつまる。",
              "citation": {
                "source": "叔父と甥と",
                "author": "――甲字楼日記の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "英一世にあらば、僕も立見に行こうなどいうならんかと思いやれば、門を出でんとしてまた俄に涙を催す。",
              "citation": {
                "source": "叔父と甥と",
                "author": "――甲字楼日記の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十二月、柳亭燕枝、春風亭柳枝、桂文治らが、春木座にて落語家芝居を催す。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○坪内博士を会頭としたる文芸協会は、二月十七日の夜、芝公園の紅葉館において第一回の試演を催す。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○六月一、二日、本郷座にて清国留学生の春柳社演劇を催す。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○六月十七日、歌舞伎座にてコッホ博士歓迎観劇会を催す。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○三月、川村｜花菱主宰にて有楽座に土曜劇場第一回試演を催す。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "げに宿醉の朝に於ては、どんな酒にも嘔吐を催すばかりである。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪子はあらかじめぞりつと寒気を催すと共に、その不快な醜さによつてかの女の神経の肌質をさゝくれ立たされることを覚悟してゐたが、兄の手振りを見ておや／＼と思つて安心した。",
              "citation": {
                "source": "過去世",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "七日、丁酉、去る四日の弓の勝負の事、負方の衆所課物を献ず、仍つて営中御酒宴乱舞に及び、公私逸興を催す、以其次、武芸を事と為し、朝廷を警衛せしめ給はば、関東長久の基たる可きの由、相州、大官令等諷詞を尽さると云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿一日、戊申、将軍家、三浦三崎に渡御、船中に於て管絃等有り、毎事興を催す、又小笠懸を覧る、常盛、胤長、幸氏以下其射手たりと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "飽ける者は人の饑餓に臨めるを見ては、余計に之を哀れむの情を催す道理がある。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "食後に眠を催すに徴して此の事知るべしである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "試に思へ、彼の糞汁はいかむ、其心美なるにせよ、一見すれば嘔吐を催す、よしや妻とするの実用に適するも、誰か忍びてこれを手にせむ。",
              "citation": {
                "source": "醜婦を呵す",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "下　恁て、數時間を經たりし後、身邊の人聲の騷がしきに、旅僧は夢破られて、唯見れば變り易き秋の空の、何時しか一面掻曇りて、暗澹たる雲の形の、凄じき飛天夜叉の如きが縱横無盡に馳せ※るは、暴風雨の軍を催すならむ、其一團は早く既に沿岸の山の頂に屯せり。",
              "citation": {
                "source": "旅僧",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ああ、書きながらも嘔吐を催す。",
              "citation": {
                "source": "禁酒の心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "霰や雪をもよおす雲は空に低くかかり、大烏は羊歯の上に立って、「カオカオ。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            }
          ]
        }
