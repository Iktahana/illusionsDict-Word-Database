[
  {
    "uuid": "5ab3fdb2-d71c-520a-a2d0-2f1226459328",
    "entry": "持て成す",
    "reading": {
      "primary": "もてなす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
