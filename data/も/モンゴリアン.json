        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "サッカーの試合で、モンゴリアンの選手が見事なシュートを決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "モンゴリアンの友人と、伝統的なモンゴル料理を楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はモンゴリアンの血を引いていると話していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その皮膚は蒙古種族よりはズット黒いけれども、当時の日本人が夢想しているような裏も表もわからない黒ん坊とは違って、よく見なければ、西洋人でさえもモンゴリアンと見るほどに色彩が不鮮明ですけれども、たしかに蒙古種に属する印度人か、そうでなければ印度とそれに近い他人種との混血児に相違ない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
