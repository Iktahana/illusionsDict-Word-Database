[
  {
    "uuid": "f419de12-b14b-53ec-b060-5046d1f49844",
    "entry": "燃えつく",
    "reading": {
      "primary": "もえつく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
