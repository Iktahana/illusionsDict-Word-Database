      {
        "index": 1,
        "gloss": "holy men who abstain from meat and cooked food",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "木食上人が架けたというが、たぶん、南蛮式とでもいうのだろう。",
              "citation": {
                "source": "狐",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此日小高い山腹の曹洞宗木食上人道場自在庵を訪ふ。",
              "citation": {
                "source": "気仙沼",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "百年の後、木食上人の稚拙なる彫刻がもてはやさるるところを以て見れば、与八の彫刻にも取るべきところがあるかも知れないが、今のところではそう感心したものではありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "木食上人の作品を見、三階節の由来を聞き、佐渡ガ島を空しく海上面に求めて、この旅を終った。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "木食上人、ブレーク、アルトの歌手。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｙ氏の愛する木食上人の木像は、ああいう家に住む土豪にあって彫まれたものではなかったのですからね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、高野衆はこぞって、連署の誓紙をしたため――これを木食上人に託して、ひたすら秀吉の寛度を仰いだ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "高野が、難をのがれたのみでなく、以後、豊臣家の援護さえ約されたのは、これまた、木食上人の力によるところが大きい。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
