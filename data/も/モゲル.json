        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一里半ばかり、鼻のもげるような吹曝しの寒い田圃道を、腕車でノロノロやって来たので、梶棒と一緒に店頭へ降されたとき、ちょっとは歩けないくらい足が硬張っていた。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼につければ眼が潰れる、鼻へ付ければ鼻がもげる、耳へ付ければ耳髱が、木の葉のように落ちてしまう！",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日花を見た茄子が、明日はもうもげる。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ヘスペリディーズの庭へ行って、金の林檎をもげる者は、わしのほかに誰もない、』巨人は言いました。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで人形の腕がもげる様に、京子の手がスッポリと抜けてしまったのだ。",
              "citation": {
                "source": "恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
