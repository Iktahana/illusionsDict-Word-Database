[
  {
    "uuid": "4b53900a-5c98-5034-9253-7d74516bdd0a",
    "entry": "黙劇",
    "reading": {
      "primary": "もくげき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
