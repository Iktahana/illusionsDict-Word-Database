          "literary": [
            {
              "text": "「腐ッテタラ犬ニヤレバイヽジャナイノ、アナタ達ハ面白ガッテ何デモアレヘ投ゲ込ムンダネ、アンナモノヲ買ワナキャヨカッタ」ソウ云ッテ颯子ハ後悔シテイタ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "言語動作ガキビ／＼トシテ、目カラ鼻ヘ抜ケルヨウデ、ソレデイテ情味モアレバ愛嬌モアッテ人ヲ外ラサナイ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日モアレヲ着テ歩イテイル。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
