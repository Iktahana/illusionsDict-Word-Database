    "definitions": [
      {
        "index": 1,
        "gloss": "presenting no difficulty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "第八　芭蕉の葉色、秋風を笑ひて籬を蓋へる微かなる住家より、ゆかしき音の洩れきこゆるに、仇心浮きて其が中を覗ひ見れば、年老いたる盲女の琵琶を弾ずる面影｜凛乎として、俗世の物ならず。",
              "citation": {
                "source": "秋窓雑記",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "高尚なる人物ならずや。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に、この美き人も今は我物ならずと思へば、なかなか夢かとも疑へり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは勿論借りた後といへども良心を持たなければならんけれど、借りざる先の良心と、借りたる後の良心とは、一物にして一物ならずだよ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓢箪穴、巖石に瓢箪を倒さまにしたるが如き穴あきて、つき拔けたるが、金洞の奇にくらべては、物ならず。",
              "citation": {
                "source": "妙義山の五日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "世を捨てんまでに我を思ひ給ひし瀧口殿が誠の情と竝ぶれば、重景が戀路は物ならず。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今のうき名しばしきゆるとも」二人が生涯一人でいたりすれば「口清うこそ云へ何とも知れた物ならず」と云われるだろう。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "石敢当も亦実在の人物ならず、無何有郷裡の英雄なるべし。",
              "citation": {
                "source": "八宝飯",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "後でちゃんとしたこの歌詞を調べてみたら、「箱根の山は、天下の険、函谷関も物ならず、万丈の山、千仭の谷、前に聳え後に支う。",
              "citation": {
                "source": "箱根の山",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "其物ならずして、其物に酷似してゐると謂つた表現法を謂ふのである。",
              "citation": {
                "source": "副詞表情の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "400アカイア軍の寄する前、先に平和の日にありて、トロイア族の持てりてふ其珍寶の數々も、はた石がちの＊ピュートウの地の銀弓のアポローン・プォイボス神の殿堂の中に收まる珍寶も、わが見る所生命に絶えて優れる物ならず。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども此時の勢、ただ退かざるあるのみ、燕王の衆意を容れずして、敢然として奮戦せんと欲するもの、機を看る明確、事を断ずる勇決、実に是れ豪傑の気象、鉄石の心膓を見わせるものならずして何ぞや。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "豈寒心すべきものならずや。",
              "citation": {
                "source": "愛と婚姻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜘蛛の圍の幻は、却て鄙下る蚊帳を凌ぎ、青簾の裡なる黒猫も、兒女が掌中のものならず、髯に蚊柱を號令して、夕立の雲を呼ばむとす。",
              "citation": {
                "source": "月令十二態",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいて庭の面には黄ろい光線が重圧され、ビール壜を陽に透して覗くように池も中ノ島も築山も、この世のものならず松樹脂色に光り輝いております。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自殺は自ら殺すものにして人に害を与ふるものならず、人は之を尚ぶべきに、却つて人を害したる後に自ら殺すを快とす、奇怪なるかな。",
              "citation": {
                "source": "復讐・戦争・自殺",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "この血痕、この紅涙こそは、古昔より人間の特性を染むるものならずんばあらず。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "我に返りて後其声を味へば、凡常の野雀のみ、然るも我が得たる幽趣は地に就けるものならず。",
              "citation": {
                "source": "山庵雑記",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "人｜生ながらにして義務を知るものならず、人生れながらに徳義を知るものならず、義務も徳義も双対的の者にして、社界を透視したる後、「己れ」を明見したるの後に始めて知り得可き者にして、義務徳義を弁ぜざる純樸なる少年の思想が、始めて複雑解し難き社界の秘奥に接する時に、誰れか能く厭世思想を胎生せざるを得んや。",
              "citation": {
                "source": "厭世詩家と女性",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "余を以て是を見れば、我国の古神学は或は俗を喜ばすべき奇異譚を編むには好材料たるべきも、到底｜所謂幽玄を本とする想詩を構ふるに適するものならず。",
              "citation": {
                "source": "他界に対する観念",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ若し富人ならば、われ若し人の廡下に寄るものならずば、人々の旗色は忽ちにして變ずべきならん。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日マリアは我が往きて訪ふを待ちて、美しく愛らしきものならずやと云ひつゝ我手にわたし、ロオザ夫人は傍より、他日おん身の許嫁の妻に掛けさせ給ふべき品なり、作りし人もその心ありしなるべしと詞を添へつ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ感謝す、ああ感謝す爾は余のこの大試錬に堪ゆべきを知りたればこそ余の願を聴賜わざりしなり、余の熱心の足らざるが故にあらずして反て余の熱心（爾の恵によりて得ば）の足るがゆえにこの苦痛ありしなり、ああ余は幸福なるものならずや。",
              "citation": {
                "source": "基督信徒のなぐさめ",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は己の今日あるを致せし辛抱と苦労とは、未だ如此くにして足るものならずとて、屡ばその例を挙げては貫一を※し、飽くまで彼の意を強うせんと勉めき。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "事若し誤らば、この手証は生ながら葬らるべき罪を獲るに余有るものならずや。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は和泉の國に來ぬれば海賊ものならず。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おのれは地下に棲みなれて花のあぢ知るものならず；今朝わが家を立出でゝより、あさひのあつさに照らされて、今唯だ歸らん家を求むるのみ。",
              "citation": {
                "source": "北村透谷詩集",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "○立たんとすれば、あしはなえたり、　いかにすべけむ、ふしはゆるめり、　　　そこを流るゝ清水さへ、　　　今はこの身のものならず。",
              "citation": {
                "source": "北村透谷詩集",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "頓着なきものは福なり、知識あるものも亦た福なり、然れども之は世界的に福なるものにして、真に福なるものならず。",
              "citation": {
                "source": "実行的道徳",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命は糧よりも優り、身體は衣よりも優りたるものならずやと。",
              "citation": {
                "source": "美的生活を論ず",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
