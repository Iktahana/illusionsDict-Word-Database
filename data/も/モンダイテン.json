    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the problem (at issue)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "問題点は事実の骨組みだけを抜き出すこと――すなわち否定できない純然たる事実の骨子を粉飾まみれの論説報道から取り出すにある。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘッダの書名と章名が文字化けするといった明らかな問題点の解消に加えて、ツールキット日本語版が我が国の組み版のルールにどこまで対応してくれるかに、大いに期待したい。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし「読もうと思えば読める」と大きく気持ちを持てば許せるのですが、紙の世界のルールブックと引き比べて点検すると、不合格とせざるを得ない問題点が、なおたくさん生じました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "テキストを流し込めば、ほとんど一瞬に組版が終わる手軽さに注目するか、細かな問題点が数多く生じることを指摘するのか。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "指摘された問題点を克服するにあたって、当初彼らは、すでに日本語化したツールキットの改良を試みました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "完成がそこまで遅れるくらいですから、エキスパンドブック版の制作に取りかかった一九九四（平成六）年暮れの段階では、Ｔ※にはまだたくさんの問題点が残されていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで指摘された問題点の一つには、納得がいった。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やはりコンピューター化の新しい時代に入ったのだから、多少これまで通りいかない点は我慢してもらわないと」「もとがアメリカ生まれだから、日本語化するとどうしても問題点が残りまして」などと鼻毛を抜きつつそっくり返っていれば、アメリカ市場を抑えた標準の勢いがそがれてしまう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＣでそのまま日本語を走らせる際のさまざまな問題点を指摘しもしないであの馬鹿は何を浮かれている、ＰＣ―９８０１が抑え切った日本市場に対するリアルな観点を欠いているのではないかと、面と向かった批判を何度か浴びた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一企業の占有技術を標準にいただくことの問題点は、事件によってすでに明らかだった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒井三良氏の作品の問題点は、彼の画にはあの形式には、珍らしい強い物質性が出てゐるといふ点である。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "問題点は『柔らかい』といふことにある。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "その点に一つの問題点も隠れてゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は土牛、桂華二人展でもよく対照されるやうに桂華の絵はその土牛とはちがつて娑婆気の加はつてゐるところに彼の作品の良さといふより問題点が展開されてゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに問題点がある。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡された三冊にざっと目を通してから、僕は本をマシンで読むことの可能性と現状の問題点を整理した原稿を書いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ある統計によると、売れたマイコンキットのうち実際にいま稼働しているのは、三割に満たない」と断ったうえで、マニュアルやカタログの問題点に触れ、マイコンの勉強法を一くさり解説し、具体的な内容には「マイコンよ目をさませ」と題して入っている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "計算自体は高速化できても、ＥＮＩＡＣには配線に手間がかかるという問題点が残されていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大規模なソフトウエアに、プログラム上の欠陥であるバグや、処理速度の足を引っ張る問題点が数多く残されていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "システム１００の面目一新にあたって採用された対話型の操作環境を支えるＩＴＯＳは、当初は問題点を数多く残したまま出荷されたために全国でトラブルを引き起こした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが開発上の問題点は、すでに明らかだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "同誌の翌月号には、ラスキンがさまざまなキットや周辺機器の問題点を個々の製品ごとに詳しく指摘した長文の原稿を寄せているところを見ると、集会でラスキンに興味を持ったウォーレンがさっそく原稿を依頼したのではないかと推測できる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "先行して開発が進められたモデル１００では、全体をきわめてコンパクトに仕上げようとしたために、回路が発生させる電磁波によってメモリー内の情報が化ける可能性が生じるというあらたな技術的問題点も浮かび上がった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "小柄でいつもにこやかな笑みを浮かべ、言葉のはしに故郷の出雲の訛りを残す古山が、いったんシステム開発上のポイントや問題点を分析するとなると、鋭利なメスのような論理をふるって容赦なく切り込んでくることを浜田は痛いほど承知していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "古山はここまで自分が数え上げてきた互換ベーシック開発上の問題点など、浜田はとうに承知していたことに、あらためて気付かされた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三に、ＩＴＯＳの問題点を解析し、早急に手直しを行う。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがどこまで作業を続けても、なにか大きな問題点が隠されているのではないかとの不安は、古山の胸からいつまでも去らなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "サードパーティーに広く協力を求めれば、製品として出荷するまでには、ほとんどの問題点をつぶすことも可能だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで開発スタッフが自ら市販のアプリケーションをできる限りたくさん動かしてテストしてみたほか、基本ソフトウエア開発本部の他のセクションのスタッフにも協力を仰ぎ、彼らが持っているＰＣ―８８０１やＰＣ―８００１用のプログラムを走らせて問題点を拾い出していった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノース・テキサス・コンピューター・クラブのメンバーでアルテアを二人で買って持っているというディック・ホイップルとジョン・アーノルドは、それまでにも掲載されたプログラムの問題点を指摘する手紙を『ＰＣＣ』に送ってきており、記事に励まされてタイニーベーシックの開発を進めていると書き添えていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
