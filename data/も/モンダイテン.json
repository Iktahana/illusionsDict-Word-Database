[
  {
    "uuid": "7a793bf6-bd1f-5920-86a1-607ee28ff10a",
    "entry": "問題点",
    "reading": {
      "primary": "もんだいてん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
