[
  {
    "uuid": "5edb60a8-22a3-5e6e-8c93-4b855ce657b4",
    "entry": "裳階",
    "reading": {
      "primary": "もこし",
      "alternatives": [
        "しょうかい"
      ],
      "is_heteronym": false
    },
    "grammar": {
