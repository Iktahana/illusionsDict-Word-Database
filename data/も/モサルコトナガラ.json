    "definitions": [
      {
        "index": 1,
        "gloss": "one may well say so, but ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
