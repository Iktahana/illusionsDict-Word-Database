        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たうもろこしの葉が、風にさやさやと騷ぐのも、ながなか優雅なものである。",
              "citation": {
                "source": "金錢の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてちらっと大きなたうもろこしの木を見ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カムパネルラが「あれたうもろこしだねえ」とジョバンニに云ひましたけれどもジョバンニはどうしても気持がなほりませんでしたからたゞぶっきり棒に野原を見たまゝ「さうだらう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たうもろこしだって棒で二尺も孔をあけておいてそこへ播かないと生えないんです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然たうもろこしがなくなって巨きな黒い野原がいっぱいにひらけました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその鶴をもってこっちを見てゐる影ももうどんどん小さく遠くなり電しんばしらの碍子がきらっきらっと続いて二つばかり光ってまたたうもろこしの林になってしまひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俄かにピタッととうもろこしの粒の落ちて来るのがとまりました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "盆の十六日なので鉱山も休んで給料は呉れ畑の仕事も一段落ついて今日こそ一日そこらの木やとうもろこしを吹く風も家のなかの煙に射す青い光の棒もみんな二人のものだった。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてちらっと大きなとうもろこしの木を見ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カムパネルラが「あれとうもろこしだねえ」とジョバンニに云いましたけれどもジョバンニはどうしても気持がなおりませんでしたからただぶっきり棒に野原を見たまま「そうだろう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とうもろこしだって棒で二尺も孔をあけておいてそこへ播かないと生えないんです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然とうもろこしがなくなって巨きな黒い野原がいっぱいにひらけました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその鶴をもってこっちを見ている影ももうどんどん小さく遠くなり電しんばしらの碍子がきらっきらっと続いて二つばかり光ってまたとうもろこしの林になってしまいました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし豆ではなくてとうもろこしを細長い円錐形の紙袋につめたのを売っています。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "カムパネルラが、「あれとうもろこしだねえ」とジョバンニに言いましたけれども、ジョバンニはどうしても気持ちがなおりませんでしたから、ただぶっきらぼうに野原を見たまま、「そうだろう」と答えました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とうもろこしだって棒で二尺も孔をあけておいてそこへ播かないとはえないんです」「そうですか。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその鶴をもってこっちを見ている影も、もうどんどん小さく遠くなり、電しんばしらの碍子がきらっきらっと続いて二つばかり光って、またとうもろこしの林になってしまいました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たうもろこしには、もう頂上にひらひらした穂が立ち、大きな縮れた葉のつけねには尖った青いさやができてゐました。",
              "citation": {
                "source": "畑のへり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一｜疋の蛙が刈った畑の向ふまで跳んで来て、いきなり、このたうもろこしの列を見て、びっくりして云ひました。",
              "citation": {
                "source": "畑のへり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして大きくなったたうもろこしのかたちをちらっと見るや蛙はぎゃあと叫んで遠めがねも何もはふり出して一目散に遁げだしました。",
              "citation": {
                "source": "畑のへり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれはたうもろこしといふやつだ。",
              "citation": {
                "source": "畑のへり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにたうもろこしの娘さんたちの長いつやつやした髪の毛は評判なもんだ。",
              "citation": {
                "source": "畑のへり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たうもろこしは恐がってみんな葉をざあざあうごかしてゐるよ。",
              "citation": {
                "source": "畑のへり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほういまねえあの女の子がたうもろこしの娘さんの髪毛をむしってねえ、口へ入れてそらへ吹いたよ。",
              "citation": {
                "source": "畑のへり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
