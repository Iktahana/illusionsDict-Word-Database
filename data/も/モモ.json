    "definitions": [
      {
        "index": 1,
        "gloss": "peach (Prunus persica)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
