        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "日本民族の文化と大乗仏教の発達とは、持ちつ持たれつの関係でありました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに、寄席と芝居と、たがいに持ちつ持たれつの関係で、高坐の話が舞台に移植されたのである。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "も　持ちつ持たれつ。",
              "citation": {
                "source": "藤村いろは歌留多",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋し相持ちにして持ちつ持たれつするが人間最上の天職である。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稻造",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし相持ちにして持ちつ持たれつするが人間最上の天職である。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "近松のおさんは、愈その場に臨めば、小春と悶著をくり返しさうな女であり、近松自身の価値は、又そこにあるのだが、見物は、其をゆるめて見てゐる所に、作者と読者との、持ちつ持たれつの境地がある訣なのだ。",
              "citation": {
                "source": "街衢の戦死者",
                "author": "――中村魁車を誄す――",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校も一しょ、商業学校も一しょ、竹馬の友、助け助けられ、女房にはナイショのことも六人だけは打ちあけて、持ちつ持たれつの仲じゃないか。",
              "citation": {
                "source": "ニューフェイス",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、お前と己とは、言わば互に持ちつ持たれつで、しっかりくっついていなきゃいけねえ。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はあなたを国持大名にして、私はせめて家老ぐらゐに有りつきたい、ねえ、さうぢやありませんか、持ちつ持たれつといふものです」「君は正統派なんだな。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "知らねえや、勝手にしろ、と倉田はもうタヌキ屋の方へはめつたに現れず、東奔西走、持ちつ持たれつ家老の口といふ奴をあちらこちらに口をかけて極めて多忙にとび廻り飲み廻り口説き廻つてゐる。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、この三つは、互に持ちつ持たれつの関係にあるのです。",
              "citation": {
                "source": "文化とは",
                "author": "――力としての文化　第一話",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間の甘い考えでは人間は持ちつ持たれつ、情けは人の為ならずだが、平作の気持は生れつき違う。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二十　トンビ男",
                "note": "青空文庫"
              }
            },
            {
              "text": "教祖と信徒の関係は持ちつ持たれつの関係で、その限りに於て、両者の関係自体にインチキなところはない。",
              "citation": {
                "source": "安吾巷談",
                "author": "麻薬・自殺・宗教",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてキチガイの関係に属するものだが、一般の夫婦円満の根柢にも教祖と信者的な持ちつ持たれつの信仰の一変形はあるかも知れない。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その六　暗い哉　東洋よ",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりその、花に蝶々、水に魚で、持ちつ持たれつ、その味は辰つアんなんかにアわからないのよ。",
              "citation": {
                "source": "天國の記録",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間は持ちつ持たれつの協同生活で、好んで他を心苦しくするようなことはしてはならない。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐兵衛は年寄りで何にも知らず、和助はよく知っていたが、お妻と人目を忍ぶ仲で、主人とは持ちつ持たれつだ」「…………」　妾のお妻は屹と顔をあげて、平次を睨みましたが、平次の調子があんまり平らかなので、そのまま黙ってしまいました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "三千両異変",
                "note": "青空文庫"
              }
            },
            {
              "text": "政吉　　そんなに礼をいいなさんな、働きッとは持ちつ持たれつだあ。",
              "citation": {
                "source": "中山七里　二幕五場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "持ちつ持たれつが我々の標語です。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷主さんと、働く者とは、持ちつ持たれつ、なるほど、荷主さんあってはじめての私たちですけれど、これを逆に申しましたら、やっぱり、私たち働く者あっての荷主さんでありますし、荷主さんだけが肥え太って、働く者が、いつも、ぴいぴいで痩せとるというのは、正しいこととは思われません。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、仲よく、持ちつ持たれつ、喧嘩はせんで行こうや」　そんな茫漠とした言葉が、酒の中で、いく度となく、くりかえされた。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中の持ちつ持たれつという気持も引き出されるような気が致しますが。",
              "citation": {
                "source": "聖アンデルセン",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "この言葉は私がはじめて造ったといっていいのですが、これは、物と心とを一つのものに対する、二つの見方として、眺めてゆこうという、つまり、全体的立場、もちつもたれつという因縁の立場、縁起の意味においてこの二つのものを、一つのものの内容として見てゆこうというのです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちつもたれつとは、独り人間同志の問題ではありません。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間の一切の万物、皆もちつもたれつなのです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "相補性原理とは、もちつもたれつということです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名なアインシュタインはかつて相対性原理を唱えましたが、もはやそれは古典物理学に属するもので、今日ではすべてのものは、互いにもちつもたれつの関係にある、すなわち相補性原理こそが真実だといわれています。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇宙間の一切の事物もそうですが、特に人間はどこまでも、もちつもたれつ、生かし生かされつつあるべきです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが一切の万物は、もちつもたれつの存在であるばかりでなく、すべてのものは、ちょうど河の水のようにつねに流れているのです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "その関係を知っているものは、彼女たち姉妹のことを、もちつもたれつの仲であるといった。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
