        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「元彼との思い出の場所に新しい彼氏と行くのは、さすがに抵抗があるな」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "元彼から突然電話がかかってきて、心臓が飛び出しそうになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "別れてから3年経つが、元彼以上の人にはまだ出会えていない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一方、女性の父親は偽名で身を隠し、前述の息子に手紙を書き、自分の娘が元彼の所へ行ったように思わせた。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "といってとくにもとかれない、一層こだわるは知れている。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "花の青春に、英文学などひもとかれるよりも、ハンサムボーイの心臓とキンミツにレンラクをとられる方が淑女の道だと思うんだがなア」　と、内々の胸のうちをクスグッテあげる。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "世のあらゆるセシル・ボランヂュも法院長夫人も、学窓の頃からその師と共にかかる一書をひもとかれるがよい。",
              "citation": {
                "source": "思想なき眼",
                "author": "――「危険な関係」に寄せて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "母はもうゆるいナイトコートを着て房々した毛もとかれて居ます。",
              "citation": {
                "source": "無題（一）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
