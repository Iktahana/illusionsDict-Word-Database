        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「ヤアヤア、それなる御方に物申す。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては誰も物申に応うるものが無かったのであろう。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御庵主に物申したい。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の家の主、左衛門尉渡どのに、物申す。",
              "citation": {
                "source": "袈裟の良人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "物申す」　大振袖に揚心流小太刀の名手の恐るべき腕前をかくして、殊のほか白ばくれながら訪ないました。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "声の主に物申そうぞ。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの、物申します。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿下は知事の御案内で御仮屋へ召させられ、大佐の物申上る度に微笑を泄させられるのでした。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "食物の中に、胡麻のやうに黒みたる物あり、それは物云はぬ薬なり、さる物参らせたらば、食ふ真似をして捨てたまへ、さて人の物申さば、呻きのみ呻き給へ、さて後に、いかにもして逃ぐべき支度をして逃げ給へ、門を堅く鎖しておぼろけにて、逃ぐべきやうなしと、委しく教へければ、ありつる居所に帰り給ひぬ。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右源太は、褒美の金を、女の前へひろげて「何んしろ、大作って奴は、平の将門みたいに、七人も影武者があって――」「物申う」　お歌が「あい」　と、返事して「誰方かがお越しに」「金は仕舞っておくがいい」「ええ」　右源太が、立って行って「誰方」　と、聞いた。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「物申す、義観と仰せられる方のお住居は」　微かに、部屋の中で、音がした。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "成る程、さて、さて、素晴らしいお顔振れ、こうした方が、揃っての御見物では、こりゃ、うかとは、舞台が踏めませんわい」　雪之丞は、目を輝かして、師匠がさし示す見物申込の書き込を、のぞくのだった。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "日頃御厄介になっちょりますから今度見まいに参りましたついでに、ちょっとお物申そうと申しまするもので――」　自分母のうしろからおじぎをする。",
              "citation": {
                "source": "日記",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「船山城中へ物申す。",
              "citation": {
                "source": "郷介法師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗黒であった谷の底ににわかに松火の光が射し、その辺りから山へかけて合図の号笛が鳴り渡り、「神保帯刀様ご嫡男、同姓市之丞様に物申す。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右京次郎の股肱の臣、筧白兵衛は群を脱け、城の大手の門へ行ったが、「城内の方々に物申す。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小笠原流に物申すぢや、聞えはしないやな。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "嫁の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "日頃御厄介になっちょりますから今度見舞いに参りましたについて、一寸お物申したいと云って居りますから」云々。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "二「物申す、果合いか、ただしは喧嘩か」　声をかけると、取囲まれた若侍が、「や、闇討を、かけられました、御、御助勢を……御加勢を――」　悲痛に叫んだ。",
              "citation": {
                "source": "武道宵節句",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「出来る、迚も手に合わんぞ」　孫次郎はそう呟くと、二三間つかつかと歩み寄って、「慮外ながら物申す」　と声かけた。",
              "citation": {
                "source": "おもかげ抄",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれその口比賣歌ひて曰ひしく、山代の　筒木の宮に物申す　吾が兄の君は、涙ぐましも。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "常陸の国司維茂どのに物申す事のあって推参して候。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、傲慢不遜の大月玄蕃は、片手に木剣を引ッさげたまま、鳴りを鎮めた福知山方の桟敷に向って真ッ赤な大口を開け、矢来の果てまで届く大音声で、「やあ、松平忠房のご家中に物申す、馬扱いの儀はいざ知らず、武士の表芸たる剣道にかけては宮津京極丹後守が藩中の勝ちに極まったり。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「城方の衆へ物申すッ」　大音をはりあげて云いだした。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――城内の方へ物申す。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲れたとか、咽喉が乾いたとか思わせ振りなことを言うと、彼女は察して、お茶でものもう、と言った。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "芋大根の類、寒い時なら湯豆腐、香のものもうまいものだ。",
              "citation": {
                "source": "樹木とその葉",
                "author": "野蒜の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "山牛蒡の煮たものもうまかつた。",
              "citation": {
                "source": "山を越えて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁には烏の糞が白く見えて、鰐口のほつれた紅白のひものもう色がさめたのにぶらりと長くさがったのがなんとなくうらがなしい。",
              "citation": {
                "source": "日光小品",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "また曲面を持った舷のようなものもうつっていたが、これは本艇の一部であると分った。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
