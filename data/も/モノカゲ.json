[
  {
    "uuid": "c6d66c24-8818-5936-925b-d1e3c4929536",
    "entry": "物陰",
    "reading": {
      "primary": "ものかげ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "place hidden from view",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし蠅を取りつくすことはほとんど不可能に近いばかりでなく、これを絶滅すると同時に、蛆もこの世界から姿を消す、するとそこらの物陰にいろいろの蛋白質が腐敗して、いろいろのばいきんを繁殖させ、そのばいきんはめぐりめぐって、やはりどこかで人間に仇をするかもしれない。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物陰でましらの半次が気が気で無い。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の様子を物陰で見たお小夜と半次。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "物陰から現れた右門と伝六舟を見送る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "物陰の電燈に写し出されている土塀、暗と一つになっているその陰影。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしはえを取り尽くすことはほとんど不可能に近いばかりでなく、これを絶滅すると同時にうじもこの世界から姿を消す、するとそこらの物陰にいろいろの蛋白質が腐敗していろいろの黴菌を繁殖させその黴菌は回り回ってやはりどこかで人間に仇をするかもしれない。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども如何いうものか僕は小児の時分から学問が嫌いで、たゞ物陰に一人引込んで、何を考がえるともなく茫然して居ることが何より好でした。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "物の表は永劫の真昼に白み亘り、物陰は常闇世界の烏羽玉いろを鏤めている。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが茶室に懸って居た韓退之の詩の句を需められるままに読み且つ講じたので、物陰でそれを聞いた信長が感じて殺さずに終ったのである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月十八日、近藤が上京した帰途、伏見街道藤森に於て突如物陰から狙撃され、その右肩に重傷を負った。",
              "citation": {
                "source": "鳥羽伏見の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪量は物陰から物陰を伝ってそれに近づいて往った。",
              "citation": {
                "source": "轆轤首",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、正勝の姿が物陰に消えてから、紀久子は急所の重苦しい痛みに悩んでいる敬二郎を静かに部屋の中へ労り入れた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　入口に近寄ると、ふいに物陰から女が現れ、ランプの黄金色の光を背にして立った。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その物陰に素早く身を隠すと、階段から足音が聞こえ、寝室の戸が開け閉めされる。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は物陰でじっとしているのが精一杯だった。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "外から見えぬ物陰を選び、乾いた薪を少しく積み上げ、燃ゆる火を起こして父娘に身体を温めさせる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちには下卑た連中がうようよしている物陰があるし、――またこっちには神聖をけがされた神殿がある、というわけさ。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は今熾な暑い日を仰いだ目を放つて俄に物陰を探さうとするものゝやうに酷く勝手が違つたのである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚怖の餘り物陰に凝然と潜伏して居た鷄は次の朝漸く他の鷄の群に交つて歩いたけれど幾らかまだ跛足曳いて居た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "物陰に一｜夜保つてゆつくりした雪が慌てゝ溶けた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとあけてください」　葉子は手早く小机の上の紙を屑かごになげすてて、ファウンテン・ペンを物陰にほうりこんだ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうするとうしろの物陰からわしが出てきて、ピストルをつきつけて、手をあげろというからな。",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが不思議なことには、俺がこの面をこうつけて面をつける　このピストルをもって、ピストルをとりあげる　物陰から風のように現れると起ち上がる　亜細亜新聞記者東山一雄という俺の人格はすっかり消えてなくなって、仮面強盗という、正体のない、別個の人格が忽然と生まれてくるのだ。",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "――と見えたのはしかし二町足らず、ずかずかとふたたびかざり屋のかどまで引っ返してくると、ぴたり、そこの物陰に身を潜めながら、帰ると見せて立ち去ったお蘭の家の表のけはいに烱々と鋭いまなこを配り放ちました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると今度は第三の男が不意に物陰から現れつかつかと第二の男のそばへ寄ってゆきました。",
              "citation": {
                "source": "祭の夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は、五条油小路を中心として、手わけをして、路次という路次、軒下、物陰などを隅から隅まで探しましたがとうとう見つかりませんでした。",
              "citation": {
                "source": "祭の夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに、人通りの少ない路地などはもっとも念入りに捜さんといかんぜ」　それから約三十分、二人は区域を分担して物陰という物陰、溝渠という溝渠、塵芥箱という塵芥箱を残らず捜したがついに徒労に終わった。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の二",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえって別なる船一｜艘、ものかげに隠れていたろう。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、あたしは、ものかげにかくれて、誰にも知られずに、そっとおがんで、うれしいだろうなあ。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、あたしは、ものかげにかくれて、誰にも知られずに、そつとをがんで、うれしいだらうなあ。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
