    "definitions": [
      {
        "index": 1,
        "gloss": "copy (of the real thing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "同行の高頭君は、退屈紛れに、杖を沙上に揮って、それを模写していた。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョコンダの絵と、ルウベンスの模写が出ている。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "模写の出来る絵と出来ない絵とがあるとすれば、この二つはその代表者だと思う。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョコンダの模写を見ると本物の価値が始めてよく分るし、ルウベンスの模写を見ると、ルウベンスの大幅が到る処のギャレリイにのさばっている理由が明白になると思う。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "図画の先生に頼んで東京の飯田とかいううちから道具や絵の具を取り寄せてもらって、先生から借りたお手本を一生懸命に模写した。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日と今日は、床のそばに机を出して貰つて、レンブラントの素描を模写した。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは天王寺区○○町の田村克巳さんの邸宅のお庭にある地蔵さんで「阿砂龍石地蔵尊」といい、田村さんの仏壇の抽出に秘められている一巻の古い軸には、この地蔵さんが模写されていて、「宝亀五年三月二十四日聖徳太子御直作」と肩書があり、裾書に「鈴木町」とある。",
              "citation": {
                "source": "起ち上る大阪",
                "author": "――戦災余話",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラトンによれば、自然はイデヤの模写であるのに、美術はその模写を模写する故に、虚妄の表現であり、賤しく劣等な技術であるというのである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）これに反してアリストテレスは、同じく美術を自然の模写であると認めながら、それ故に真実であり、智慧の深い芸術であると考えた。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "永井氏の「フランス物語」の話、湯浅氏の模写のベラスケスなどについてみんなが話しあつたと記録せられてゐる。",
              "citation": {
                "source": "パンの会の回想",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからもう一人は、全く見知らぬ無言役者、――すなわち今夜の大活劇に、最も重要な役目を演じた、私の友人の蝋色の胸像――なるほど実に驚異すべきまでに、その真を模写していた。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となく動作のはしっこいこと、それをほかにもっとよい言葉がないので事務机風７と名づけてもいいが、それを除いては、これらの人々の身嗜みは、約十二か月ないし十八か月前にはこの上なく上品であったものの正確な模写であるように、私には思われた。",
              "citation": {
                "source": "群集の人",
                "author": "THE MAN OF THE CROWD",
                "note": "青空文庫"
              }
            },
            {
              "text": "「四十前後の町人風の男が二十三四の女と二人連れで参詣に来て、この絵馬の下に暫く立って眺めていましたが、女は矢立と紙を取り出して何か模写しているようでした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを模写して頂くわけにはまいりますまいか」　澹山は黙っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これを模写してどうするんです」と、彼はわざと落ち着き払って訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁天堂の奥に秘められていたマリアの絵像も、かれが模写した同じ絵像も、どうなったか判らない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "▼（同人）関兵衛君　『ポーズ』此女人裸像は模写にしては上手であるしモデルを描いたものとしては拙劣であるし醜い仕事である『玉葱のある静物』この絵に到つては評者は悲鳴をあげる、水彩『見世物風景』を描いた時代の関君は影も形もないといふものだ。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾来富山は益す傾慕して措かず、家にツィシアンの模写と伝へて所蔵せる古画の鑒定を乞ふを名として、曩に芝西久保なる居宅に請じて疎ならず饗す事ありければ、その返とて今日は夫婦を招待せるなり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その広間の左の壁には、ゴヤの描いた『踊り子』の絵の、可なり精緻な模写が掲げてあった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「模写ですね」と野々宮さんが原口さんに言った。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも模写ですがね。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬になつた男がはしやぎ出して、馬上の人となつたり、また駈る馬となつたりして坐つたままで身振りを繰り返してゐるのを見ると、丸い背中の騎手は僕であり、首を地に垂れて前脚を非常に高く挙げて駈るのはゼーロンの模写であることが連想された。",
              "citation": {
                "source": "沼辺より",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜叉王は筆を執りて、その顔を模写せんとす。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "文庫のなかには書き散らしの反古のようなものがいっぱいに詰めてあったが、その大部分はいろいろの地蔵さまの顔を模写したもので、問題の種になった村はずれの地蔵さまの顔は二十枚以上も巧みに模写してあったと伝えられている。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、その画を早速と例の硝子板に模写して、婆さんの枕元に写し出して、おどけた声色などをつかつた。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "フリガンの表情は、歓喜に炎えた時でも、悲境のドン底に墜落した時でも、或ひは稀にいさゝかの成功に反身になつた場合でも、常住不断に変化を知らぬ丸い眼と稍突り気味の口吻と、そして缶型の赤い帽子だけは決して落とさぬ姿勢なので、模写の手際も別段六ヶしいわけではなかつたのだ。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "物々しい番兵の交代はベルリン名物の一つであったが、実際いかにも帝政下のドイツのシンボルのように花やかでしかもしゃちこばった感じのする日々行事であった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "富蔵は案外に意気地のない奴で、ちょっと嚇かしたらすぐに何もかもしゃべってしまったばかりか、ほかに案外のことまで吐き出しました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっ黒くなめらかな烏の大尉、若い艦隊長もしゃんと立ったままうごきません。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土神は日光を受けてまるで燃えるやうになりながら高く腕を組みキリキリ歯噛みをしてその辺をうろうろしてゐましたが考へれば考へるほど何もかもしゃくにさはって来るらしいのでした。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
