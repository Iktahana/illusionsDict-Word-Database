        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大雨で屋根の隙間から雨水が漏れ落ちる音が聞こえた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女の目から、一筋の涙が静かに頬を漏れ落ちた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い水道管の継ぎ目から、水がポタポタと漏れ落ちていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "舌ざわり細やかな脂肪に富んで、串にさして榾火に当てれば、脂肪が灰に漏れ落ちる。",
              "citation": {
                "source": "魔味洗心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし実際においては、その手から金が漏れ落ちることはほとんどなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然の広大なる宝はわれわれの指の間から漏れ落ちる。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
