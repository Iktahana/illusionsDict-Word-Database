    "definitions": [
      {
        "index": 1,
        "gloss": "moa (extinct, flightless bird formerly found in New Zealand)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ママサマ、少シモアブナイ事ハアリマセン。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――僕はあなたの小説を読んだことはないが、リリシズムと、ウイットと、ユウモアと、エピグラムと、ポオズと、そんなものを除き去ったら、跡になんにも残らぬような駄洒落小説をお書きになっているような気がするのです。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユーモアを虐待することと、人格者であるといふことと、平和と苟安とは同義で通用する日本の、そして帝都は彼の育つた雰囲気であつた。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、「本當の意味のユーモアは、Ｋ君の持味だつた。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その尻尾の端には最後の息をしている馬がぶら下がっていた」というので馬鹿気ているが、何処かしら古代日本人のユーモアとウィットを想わせるものがあると思う。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、いいよ、いいよ、マドモアゼル。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでなかったらユーモアーというものが美学の対象などになりようはない。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまたチャム語でも「ナイ」は河または河辺の野であり、アイヌやサモア、マオリ語でも「アナ」は穴でもある。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マクスウェルのには理智が輝いており、ケルヴィンのには強い意志が睨んでおり、レーリーのには温情と軽いユーモアーが見えるような気がする。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊の撲滅　北米バルチモアーでは蚊のためにいろんな病気の流行るのを防ぐために一昨年市会で二万円ほど支出して撲滅にかかったが、結果がよかったので今年また一万円ほど支出したそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の「哲學」にはいつもいみじきユーモアがある。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る馬鹿正直の人間がもつやうな、眞面目すぎて可笑しくなるユーモアである。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上にも犀星らしき自然のユーモアが感じられ、ふしぎに人々の結ばれた心を解きほごした。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "懲罰日誌そのものゝなかには囚人の悲慘がユーモアに包まれて寫されてゐる。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのユーモアの一つは「錆びついた心」を持つた獄吏の戲畫的な存在である。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "スペイン女が、ヴェリストのアメリカ女が、権能を知る英国女が、ユーモアを感じさせるロシア女が、流行の尖端を自覚した日本女が、弛緩したような朝鮮女が、ニグロの女が、そしてノラの属する混血種の支那女が黄浦灘を横切って蘇州路へ、北京路へ、南京路へと立ち去って行く。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "本來氣質の暗い陰氣な人が明るい快活な文章を書かうとするのも嘘であらうし、頭のそこに至らない人が、無理に皮肉やユウモアに富んだ文章を書かうとしたら、それは大概鼻持ちもならぬものにならう。",
              "citation": {
                "source": "氣質と文章",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに出て来るライオネル・バリモアーの役が湿疹に悩まされていることになっていてむやみにからだじゅうをかきむしる。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョン・バリモアー役の主人公が「おれもそんなに忠実なコンパニオンがほしい」とはなはだ深刻な皮肉を言う場面がある。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "書き終へて讀みかへしてみたら、まるでもう滑稽物語になつてしまつてゐたので、これは當時のユウモア小説の俊才、伊馬鵜平君に捧げる事にしたのである。",
              "citation": {
                "source": "『玩具』あとがき",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば南洋エファテの Aso（燃える）Asua（煙る）サモアの Asu（煙）や、マレーの Asap（煙）（マレイでは火山は Gunong berasap すなわち煙山とも Gunong berapi 火山ともいう。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョン・バリモアーなどにもちょっと似ているのがある。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "対話のユーモアやアイロニーが充分にわからないのは残念であるが、わかるところだけでもずいぶんおもしろい。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "サモアにシヴァオフェという竹笛がある。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一方においては西欧のユーモアと称するものにまでも一脈の相通ずるものをもっているのである。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「絞首台上のユーモア」にはどこかに俳諧のにおいがないと言われない。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "輕妙に見えるユーモアと皮肉との後ろに、作者は個性と運命とに對する深い洞察と同情とを寄せてゐるではないか。",
              "citation": {
                "source": "水野仙子氏の作品について",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当時売り出した、バリモアというオペラ女優の身ぶりなどを巧みにまねながら貴女は手に持っていた薔薇を無意識に胸にさしてしまった。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――偶然というものは、ユーモアと共に人生に欠くべからざる要素である。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユーモアのない人生なんて、凡そ糞面白くないものだが、同時に、人生から偶然というものを取り除いてしまえば、随分味気ないことになるだろう。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
