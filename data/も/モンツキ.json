    "definitions": [
      {
        "index": 1,
        "gloss": "clothing (e.g. kimono) decorated with one's family crest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "赤黒い顔に鉄縁の眼鏡を掛け、紋付羽織が好きで何時もその広い胸ははたけられてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも黒紋付に、歩くときゅうきゅう音のする仙台平の袴姿であったが、この人は人の家の玄関を案内を乞わずに黙っていきなりつかつか這入って来るというちょっと変った習慣の持主であった。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "若先生も典型的な温雅の紳士で、いつも優長な黒紋付姿を抱車の上に横たえていた。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒紋付をちらと見たら蔦の紋であった。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紋付を着てキチンとやって出て行くのがあたりまへだ。",
              "citation": {
                "source": "ラジュウムの雁",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "紋付と黄の風呂敷）第二双の眼の所有者（大学生。",
              "citation": {
                "source": "電車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はいつのまにか紋付き袴の礼装をしている。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前夜の夕刊に青森県｜大鰐の婚礼の奇風を紹介した写真があって、それに紋付き羽織｜袴の男装をした婦人が酒樽に付き添って嫁入り行列の先頭に立っている珍妙な姿が写っている。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紋付きを着て撮った写真や、それをモデルにしてかいた油絵などを見ても、なんだかほんとうの祖母らしく思われないが、ただ記憶の印象だけに残っているこの「糸車の祖母像」は没後四十六年の今日でも実に驚くべき鮮明さをもって随時に眼前に呼び出される。",
              "citation": {
                "source": "糸車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また紋付きの羽織で、書机に向かって鉢巻きをしている絵の上に「アーウルサイ、モー落第してもかまん、遊ぶ遊ぶ」とかいたものもある。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚してまもなかった若い奥さんは黒ちりめんの紋付きを着て玄関に出て来られたこともあった。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おらは急いで舟だして、向こうの岸に行ってみたらば、紋付を着て刀をさし、袴をはいたきれいな子供だ。",
              "citation": {
                "source": "ざしき童子のはなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしに白襟紋付を着ろとおつしやるの……。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一儼然として絽の紋付を着たあんまだといふ、天の授くるところである。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "左に、腰元、木の芽峠の奥山椿、萌黄の紋付、文金の高髷に緋の乙女椿の花を挿す。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "着換えに紋付の一枚も持った、縞で襲衣の若旦那さ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "着換えるのも面倒で、昼間のなりで、神詣での紋付さ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "千代は型通りの黒紋付に前帯で、扇を持って出ます。",
              "citation": {
                "source": "米国の松王劇",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供たちは身分に応じて羽二重の黒紋付の小袖を着て、御目見以上の家の子は継、御目見以下の者は普通の麻を着けていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "又蔵は定紋付きの提灯をふり照らして先に立った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘や家内は浴衣がけてゐるといふに、これはまた尚だ木綿の黒紋付の羽織に垢づいた袷で、以前の通り堅くるしい態をしてゐた。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒紋付きに白襟をかけていたが芝居に出て来る女のように恰好がよかった。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまん中に、木綿の紋付き羽織を引っかけた不動様が坐って、恐ろしい顔で睨みまわしていたが、やがて、うしろの方に坐っている、紅化粧した別嬪をさし招いた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、船へは紋付の和服で出迎えて呉れたのであるが、そのときに較べて、いくらか精気を帯びて見えた。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人はその膳の前に紋付の羽織の襟を正しうやうやしく座つて白木の箸を取り上げた。",
              "citation": {
                "source": "雜煮",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒紋付を着た宜い老婢が一人、小婢を一人｜随へて、あとから静かに付き添つて来る、……やがて薄い涙で曇つた宗右衛門の眼に、拡大されて映つた二人の娘の姿が、静まり返つた人々の間を通つて、お辻の寝棺の傍に近づいた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台では菊五郎の権八が、したたるほどのみどり色の紋付を着て、赤い脚絆、はたはたと手を打ち鳴らし、「雉も泣かずば撃たれまいに」と呟いた。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとなの人々は、多くはその上に黒い紋付を羽織つて居たが、兔に角、七子か羽二重の紋付の裾から紅緑の彩色の高砂の尉姥、三番叟、龜に乘る人、「大漁」の扇を持つ人、また龍宮、寶船、七福神などの模樣の出て居る所は、また南國の海邊に似付かはしい「眞面目」の服裝であると頷かしめる。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人は紋付の羽織を着て袴を穿かぬ。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるじもんつきの羽織を娶にとりいださせて、哥のろくとて福一にとらせければ、膝にのせてなでさぐり、あやまちの高名しつとてゑみはうけてよろこびつゝ、めでたく歳越にきそはじめせんとて、羽おりきてなでさぐり、かたちをつくりて猶よろこびけり。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
