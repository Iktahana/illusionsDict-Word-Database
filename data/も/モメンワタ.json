        "examples": {
          "standard": [
            {
              "text": "「古い布団を打ち直しに出して、中の木綿綿を新しくした。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「手作りのぬいぐるみに、ふかふかの木綿綿を詰め込んだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「木綿綿は保温性が高く、冬の防寒着の中綿としても重宝される。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "亀蔵はその時茶の弁慶縞の木綿綿入を着て、木綿帯を締め、藍の股引を穿いて、脚絆を当てていた。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この目的には、天然痘膿疱の新鮮な内容で浸した木綿綿を接種する人の鼻の穴に入れる（男児は左、女児は右の鼻の穴）。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
