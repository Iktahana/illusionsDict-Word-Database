        "examples": {
          "standard": [
            {
              "text": "彼は刑務所内で模範囚として過ごし、早期釈放の対象となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "模範囚の振る舞いが、他の囚人たちにも良い影響を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長期の刑に服しながらも、模範囚として規則正しく生活を送っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "マルケット第一の模範囚徒だそうだ。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "今回当監獄所囚人ヘ落語無料長演シ奇特千万ニ付キ、模範囚人苦心調製の七宝製大メダル一箇贈呈ス石川島監獄所主事　　　　　　　　　　月　日猪熊秀範※　　　　　　　　　　橘家圓太郎殿　ウヘツ。",
              "citation": {
                "source": "圓太郎馬車",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても助かりましたし、模範囚も鎮圧に協力してくれました。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
