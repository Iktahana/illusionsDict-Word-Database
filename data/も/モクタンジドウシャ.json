          "literary": [
            {
              "text": "――木炭自動車も仲々馬鹿になりませんね。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、内地でも木炭自動車にどんどん切りかへてゐるさうですが、こつちぢやア早くからやつてゐるンですからね――。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは日本の木炭自動車で八百円。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガソリン自動車とか木炭自動車とか申しまして……」「えへん、えへん、ああ、もうそんな話はよそうや」　また博物館が話の中にあらわれた。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦後の予算の不足から起っている悲しい一つの発見であるが（木炭自動車が世界の驚異であるように）、書庫ができなくても、図書館機構が成立するという考え方である。",
              "citation": {
                "source": "国立国会図書館",
                "author": "中井正一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
