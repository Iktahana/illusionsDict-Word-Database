      {
        "index": 1,
        "gloss": "original packaging (e.g. box holding several cartons, each with individually packaged products)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
