          "literary": [
            {
              "text": "「オイ、もう直ぐだ。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪がもう直ぐに来るのです――そしてクリスマス。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう直ぐですわ……」と、武井さんは何でもない事のやうに答へた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂を下りて熊笹の繁る所に来ると彼は一寸立どまり「聞えるだらう、川の音が」と耳を傾けた、「ソラ……聞えるだらう、あれが空知川、もう直ぐ其処だ。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからもう直ぐ畑道だ、蛙が鳴いてゐる。",
              "citation": {
                "source": "散歩生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一度、全真という納所坊主がこの縁側から月をながめて、ああいい月だ、諏訪神社の祭礼ももう直ぐだなと云うと、住職の全達が笑いながら、諏訪の祭りが見たければ直ぐ出て行け、十月までには間に合うだろうと云って、みんなが大きい声で笑っていました」「諏訪の祭り……信州かな」と、松吉は口を出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうした悲しい移住者は、思ひきりよく故郷と縁を絶つては來たものの、一足都會の土を踏むともう直ぐその古びた、然しながら安らかであつた親讓りの家を思ひ出さずにはゐられない。",
              "citation": {
                "source": "田園の思慕",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだい／＼、やっと泣き止んだかと思うと、もう直ぐ人を使って、相変らずわが儘娘だなあ」　義光ちゃんは苦笑しましたが、それでも立上ると吉良に向って、ちょうど試合の場に臨むときにキャプテンが選手たちに与える眼くばせに似たような眼つきを与えて「行こう」とあっさり言いました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃあ、もう直ぐそこだ。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう直ぐに停車場へ着きますから。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを越えれば、もう直ぐだらうといふを力にして、やつとのことで山の背まで達し、それから勾配のゆるい下り坂になつたが、今度はまた非常に喉が渇き、からだ中びしよ濡れの汗が氣になる樣になつた。",
              "citation": {
                "source": "日高十勝の記憶",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「デイオゲネス先生の樽のやうに――」「もう直ぐだよ、あまり大声は止せよ。",
              "citation": {
                "source": "晩春日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まだ遠いの」と云うと、小女は、「もう直ぐよ」と云うような顔をして男の顔を見返った。",
              "citation": {
                "source": "水魔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう直ぐですよ、お父うさん。",
              "citation": {
                "source": "薔薇",
                "author": "ROSEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱いねえ、）（もう直ぐに快くなりますからね、）（ああ、）　と調子高に、しかし上の空のようにいって、少し気がついたか、落着いた声で、（熱いこと！",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺さんからきつぱりとした噺を聞された地主の心にはもう直ぐに「判斷」がつきました。",
              "citation": {
                "source": "白瓜と青瓜",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母さん、私もう直ぐ寝みます。",
              "citation": {
                "source": "秋雨の絶間",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いえ、もう直ぐにお見えになります」　綾衣の遅いのには少し面倒な子細があった。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「随分外は寒かつたでせう、もう直ぐ帰りますからまア少しお飲みなさい、風邪でも引くといけませんからね。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そら、もう直ぐそこだよ。",
              "citation": {
                "source": "白明",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう直ぐに来るよ。",
              "citation": {
                "source": "疳の虫",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だつてもう直ぐ御飯だぜ。",
              "citation": {
                "source": "砂浜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へゝえ、誰方ですか、もう直ぐこれへ歸つておいでになりますで、……實はあなたを探して一先づ瀧の方へおいでになりましたので、もう直ぐこれへお歸りで御座いますから、まア、どうぞお二階へ。",
              "citation": {
                "source": "熊野奈智山",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう直ぐ御飯でございますのに。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "上京して以来、彼等の生活に少しでも、苦痛の影が射すと、彼女はもう直ぐに自分の軽率を謝して居た。",
              "citation": {
                "source": "海の中にて",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さう言つてる内にもう直ぐでございますね。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は父の死亡と母の遁走を一通り悲しむと、もう直ぐそれを忘れる事が出来た。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう直ぐだ、あそこの角をまがると、刑務所の壁が見えるよ。",
              "citation": {
                "source": "独房",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうすぐみんなここへ来るよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしあさっての朝までに、お前がそうしなかったら、もうすぐ、つかみ殺すぞ。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
