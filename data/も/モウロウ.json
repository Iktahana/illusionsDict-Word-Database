[
  {
    "uuid": "50fbce2e-042b-5f2a-ac5a-5ee4feea9d41",
    "entry": "朦朧",
    "reading": {
      "primary": "もうろう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-たる",
