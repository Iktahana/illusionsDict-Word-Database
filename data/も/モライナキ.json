    "definitions": [
      {
        "index": 1,
        "gloss": "crying in sympathy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
