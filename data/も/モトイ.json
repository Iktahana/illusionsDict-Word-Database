[
  {
    "uuid": "312f964a-eb2a-50c8-8abc-6760eeda6275",
    "entry": "元い",
    "reading": {
      "primary": "もとい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "感動詞"
