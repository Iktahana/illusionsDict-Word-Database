    "definitions": [
      {
        "index": 1,
        "gloss": "water plant",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかしながら單純でなく、海底の藻草のやうに、章魚の吸盤のある足のやうに、意地惡くからみながら、内臟で呼吸して居るのである。",
              "citation": {
                "source": "本質的な文學者",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔小きメリヤス塩の魚〕小きメリヤス塩の魚、　　藻草花菓子烏賊の脳、雲の縮れの重りきて、　　風すさまじく歳暮るゝ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "藻草を纒ったような船夫達が何人も群れて、白く化粧した女を調戯いながら、よろよろと歩いていた。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗緑色に濁った濤は砂浜を洗うて打ち上がった藻草をもみ砕こうとする。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもの通りの銅色の顔をして無心に藻草の中をあさっている。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは彼の出来損じの名魚たちを、売ることも嫌い、逃しもならぬままに、十余年間捨て飼いに飼っておいた古池で、宗十郎夫婦の情で、ときどき餌を与えられていたのであったが、夫婦の死後は誰も顧るものもなく憐れな魚達は長く池の藻草や青みどろで生き続けていたのであった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう袂の底には、からからの藻草の切れと小砂とが残ったばかりである。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "妖女の王さまは、これではたまらないと言つて、いろ／＼に考へをこらしたあげく、とう／＼、水の中の藻草の茎をすつかり集めさせて、それでもつて湖水の天井へ一面にあついおほひをつくらせました。",
              "citation": {
                "source": "湖水の鐘",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえ、流沙河の水底では、何百かの世界観や形而上学が、けっして他と融和することなく、あるものは穏やかな絶望の歓喜をもって、あるものは底抜けの明るさをもって、あるものは願望はあれど希望なき溜息をもって、揺動く無数の藻草のようにゆらゆらとたゆとうておった。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく見ると小さな魚がその藻草の林間を逍遥している。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　例えば、菌、苔、藻草のような植物でも、その所生の境遇と外囲の関係とによって初めて私達の詩的感覚を打つのである。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この摩訶不思議な物語が荒れる天候から現れ出たかのよう――大時化の際の藻草が一面に押し寄せるがごとくで――そして今再び同じく退いていったかのよう。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには花も咲いていず、藻草も生えていません。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは佇立してアマルフイイの灣を憶ひ起しつゝ、目を轉じて身邊を顧みれば、波のもて來し藻草と小石との間に坐して、草畫を作れる男あり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "汀から急に深くなった水中の枯木の幹や枝には藻草が青く纏っていた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠浅な海では、引潮の場合にあまり遊びが過ぎて帰り遅れた魚や、海老などが、そこらの藻草や、砂の窪みにかいつくばって、姿を隠しているのがあるものだ。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "水影に透してじっと見つめていると、海老は尻尾から先に、浅く砂や藻草にもぐって、やがて背全体をも隠してしまうが、鼻眼鏡のような柄のついた二つの眼だけは外に出して、それとなく自分を驚かせた闖入者を見まもっている。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかを覗いてみると、なみなみと盛られた水の底に、青い藻草が漂っていて、そのなかを数知れぬ川海老が、楽しそうに泳ぎまわっていた。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒潮よどむ海の底、戀も、詩歌も、才も、名も、根なき藻草の一枝に、花を飾るに足らざらむ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪太郎の妹のお雪が歌ひながら汀にしやがんで藻草を掬つてゐるのだ。",
              "citation": {
                "source": "沼辺より",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "殯宮に通夜をしてゐるやうな赤楊よ、おまへの王樣は崩御になつた、赤楊の民よ、靜かな水底に冠の光を探しても、夜の宴の歌舞の響を求めても、詮ない事になつて了つた、赤楊の王樣、今、禍の方士の鬚である藻草の下、深淵の底に眠つてゐられる、忘却の花は、その眼の窩を貫いて咲いてゐる。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "諏訪湖の底は浅くて藻草が多い。",
              "citation": {
                "source": "諏訪湖畔冬の生活",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は、夏の土用中に、沢山の小石を舟に積んで行つて、この藻草へ投げ入れて置く。",
              "citation": {
                "source": "諏訪湖畔冬の生活",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "水のやうに透き徹つた、細身のしなやかな体を持つた白魚は、その咸陽宮の不思議な鏡をかりて照らすまでもなく、身うちに流るるかりそめの悲しみ、悦び、また藻草のなかでだしぬけに蟹に脅された当時の動悸といつたやうなものまでも、鱗のない柔肌を透して、ありのままに自分の小さな目で見ることができようといふものだ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "稍ともするとあたりの深緑樹が海底の藻草に化して彼の寝床を包んだ。",
              "citation": {
                "source": "籔のほとり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いそに漂着したる丸太や竹を梁や桁とし、芦を結んで屋根を葺き、苫の破片、藻草、松葉等を掛けてわずかに雨露を避けたるのみ。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "俊寛、藻草を敷き破れたる苫をかけてねている。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（よろめきつつ藻草をかきわけて小屋をいであたりをうかがい浜辺のほうに向かって退場）舞台しばらく空虚。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "藻草のかきわけてあるのを見る。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "藻草と海苔粗朶とが舟脚にからむ。",
              "citation": {
                "source": "伊良湖の旅",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
