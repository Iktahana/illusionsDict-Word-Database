    "definitions": [
      {
        "index": 1,
        "gloss": "the dead",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ヨハン爺いさんはとうとう総ての亡者に給仕をしてしまつて、フランス女の前に来た。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "環虫類も何だか虫の中では醜い衰亡者のように思えるし、鰻だとて、やはり時代文化に取り残されたような魚ではないか。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう連中は全く盲人というでもなく、さればといって高慢税を進んで沢山納め奉るほどの金も意気もないので、得て中有に迷った亡者のようになる。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "反対に乙型の人間から見れば甲型の人々は積極的なようではあるが、また無用な勢力の浪費者であり、人の迷惑を顧みない我利我利亡者のように見える。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青鬼に呼び止められた亡者のような悲し気な顔でチラリと、恐ろしそうに眉香子の顔を振り返っただけで……それでもイクラか落ちついたらしく、長椅子の上に引っかけた上衣を横筋違いに引被りながら、ヨロヨロと応接間を出て行った。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴嬢がわずかに頭をあげて、いなとかの君の問いに答えたまいたる、その声は墓のかなたより亡者や吹き込みし。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "花を尋ねたり、墓を訪うたり、美しい夢ばかり見ていたあの頃の自分には、このイタリア人は暗い黄泉の闇に荒金を掘っている亡者か何かのように思われた。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度何處か方角も知れない島へ、船が水汲に寄つた時、濱つゞきの椰子の樹の奧に、恁うね、透かすと、一人、コトン／＼と、寂しく粟を搗いて居た亡者があつてね、其が夥間の一人だつたのが分つたから、聲を掛けると、黒人が突倒して、船は其のまゝ朱色の海へ、ぶく／＼と出たんだとさ……可哀相ねえ。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「や、そんなら、お前様方は、亡者をお捜しなさりますのか。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その姿、あわれに寂しく、生々とした白魚の亡者に似ている。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "居所がわりになるんだけれど、今度は亡者じゃねえよ、活きてる娘の役だもの。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に住んでいる場所が場所だけに、村の人々の気持と全然かけ離れた別人種扱いにされながらも、平気で我利我利亡者に甘んじて、極めてヒッソリと暮しているのであった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての易者と星占家（家相家や、人相見や、八卦師や）は、かうした彼等の所謂亡者どもを濟度するため、矛盾にも此處で前説を豹變し、逆に今度は、意志の自由が運命を支配すること、自覺と心がけとによつて、何人も意識的に人相を變へ、惡しき手相を善き手相にし、自由に運命を支配し得ることを辯解する。",
              "citation": {
                "source": "易者の哲理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての易者と星占家（家相家や、人相見や、八卦師や）は、かうした彼等の所謂亡者どもを済度するため、矛盾にも此処で前説を豹変し、逆に今度は、意志の自由が運命を支配すること、自覚と心がけとによつて、何人も意識的に人相を変へ、悪しき手相を善き手相にし、自由に運命を支配し得ることを弁解する。",
              "citation": {
                "source": "易者の哲理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダンテは、地獄の様々の谷に在る数しれぬ亡者たちを、ただ、見て、とおった。",
              "citation": {
                "source": "思案の敗北",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "建文三年二月、燕王自ら文を撰し、流涕して陣亡の将士張玉等を祭り、服するところの袍を脱して之を焚き、以て亡者に衣するの意をあらわし、曰く、其れ一｜糸と雖もや、以て余が心を識れと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時その腐りかかった亡者が、嬉しゅうござんす定基さん、と云って楊枝のような細い冷い手を男の頸に捲きつけて、しがみ着いて来たら何様いうものだったか知らぬが、自然の法輪に逆廻りは無かったから、定基はあさましい其香に畏れ戦いて後へ退ったのである。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿あ吐かせ、三銭の恨で執念をひく亡者の女房じゃあ汝だってちと役不足だろうじゃあ無えか、ハハハハ。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯様いふ連中は全く盲人といふでも無く、さればと云つて高慢税を進んで沢山納め奉るほどの金も意気も無いので、得て中有に迷つた亡者のやうになる。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "好男子世に処して、屈託そうな面色で、露店の三世相を繰るとなると、柳の下に掌を見せる、八卦の亡者と大差はない、迷いはむしろそれ以上である。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあやし火の中を覗いて見ろい、いかいこと亡者が居らあ、地獄の状は一見えだ、と千太どんがいうだあね。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "石段下へ引寄せておいて、石投魚の亡者を飛上らせるだけでも用はたりましょうと存じますのよ。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴は、厠の窓から秋のドオウンの凄さを見て、胸が張り裂けそうになり、亡者のように顔色を失い、ふらふら部屋へ帰り、口をあけて眠りこけているスズメの枕元にあぐらをかき、ゆうべのウイスキイの残りを立てつづけにあおる。",
              "citation": {
                "source": "犯人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "恥じるというのは人間だけにある感情ですから）まるでもう地獄の亡者がつかみ合いの喧嘩をしているような滑稽で悲惨な図ばかり見せつけられてまいりました。",
              "citation": {
                "source": "貨幣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのうしろには、ものが言えない自己喪失の亡者が、十万、うようよして居ります。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "安永八年十月には桜島の大噴火があって、山麓の村落に火石熱土を流して、死亡者一万六千余人、牛馬二千余頭を斃した。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに越中立山の麓へ往けば亡者宿と云うものがあって、其処へ往って頼めば逢いたい亡者に逢えると云う者があった。",
              "citation": {
                "source": "立山の亡者宿",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「宵にも申しましたとおり、亡者が露われても詞をかけてはなりませんよ」　小八は頷いて店｜頭へ出た。",
              "citation": {
                "source": "立山の亡者宿",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おい、休もうじゃないか。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その辺の茶店で休もうじゃないか。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
