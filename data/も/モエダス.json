[
  {
    "uuid": "0b94c120-4c80-57e9-9b38-4a7555574956",
    "entry": "燃え出す",
    "reading": {
      "primary": "もえだす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to catch fire",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "火が、ぴしぴし、音を立てて、盛に燃え出すと、樺の立木の葉が、鮮やかに、油紙の屋根に印して、劃然とした印画が炙り出される。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "軒が燃え出すまでの、焔の順序が面白かった。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "濠の真中で燃え出すを合点の向には、幾度も拵へて乗せて進ぜる。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼が黒く光り出す、急に恐ろしくなつて粉紅の円い球をぐいと右の頬辺ににじりつける、と紅い日の丸の烙印が如何にも道化らしくパツと燃え出す、面白い、左へもひとつぺたりとにじりつける、あはは、泣つ面がやつと笑ひ出した。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまたこッそり乳くり合っているのかも知れないと思えば、急に僕の血は逆上して、あたまが燃え出すように熱して来た。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の色がだんだんに薄紫色に薄らいで行き、やがて東の空が橙色に燃え出すと多鶴子と別々にすごした悩ましい時間ももはやどこかへ消え去ってしまった想いで、じたばたと立ち騒ぐ心も諦めのなかに沈んでしまった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その寂かな村落にもく／＼と黒く黄い烟が立昇つて、ばち／＼と木材の燃え出す音！",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い木立の中に黒く光る甍と、白く輝く壁とが、西日を受けて、今にも燃え出すかと思はれるほど、鮮やかな色をしてゐた。",
              "citation": {
                "source": "東光院",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "稀には自由なのびのびとした気息が、その下から燃え出すことはあっても、すぐにぷすぷすとくすぶって、秩序とか経験とかいうものの重みの下に、押しつぶされ消し止められてしまう。",
              "citation": {
                "source": "都会に於ける中流婦人の生活",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ直覚的に相手を目当に燃え出すだけである。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日私の友人の一人がそれをやつたから、一見して置くに限ると思つて見に行つたが、何しろ団子ほどもあるもぐさ（決して誇張してゐない）がぶすぶす燃え出すのだから物凄い。",
              "citation": {
                "source": "癩院記録",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "与八に抱かれて行ったその子供が、雲に乗って天上へ舞いのぼると、その雲が火になって燃え出すのは、堪え難い執念です。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "知慮を※らすクロニオーン、　600燃え出す舟の猛焔を眺めんとして斯く待てり。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のうちにその不思議な炎がきざしてるのを見て、それが燃え出す様子を見守ることに、好奇な快さを感じた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずそれまでは、偶然に燃え出す一時の火、火災の余炎があるばかりで、それはただ輝いた暫時の光を発しては、そのまま燃料がなくて消えてゆくのだった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は火がふたたび燃え出すことを知っていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸城へ火をつけるつもりで、あの連中は忍び込んだのだな――なるほど、かんなくずかなにかに炭団を包んで、火をつけて置けば、念入りに燃え出す。",
              "citation": {
                "source": "大菩薩峠",
                "author": "みちりやの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "薪から着物に火が燃え移って、ジリジリジリジリと身体の膏が燃え出す。",
              "citation": {
                "source": "棚田裁判長の怪死",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は再び火が燃え出すのを感じた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
