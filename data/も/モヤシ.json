        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やがて、春がめぐってきたときに、緑色の芽を、哀れな曲がった枝に萌やしたのであります。",
              "citation": {
                "source": "親木と若木",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人はたしかに獣医の有本でも一人はさまざまのやつらのもやもやした区分キメラであった。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "果敢なき楼閣を空中に描く時、うるさしや我が名の呼声、袖、何せよ彼せよの言付に消されて、思ひこゝに絶ゆれば、恨をあたりに寄せもやしたる。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "奎吉は何だかもやもやしてゐるものゝ中に閉ぢ込められてゐる樣に思つた。",
              "citation": {
                "source": "奎吉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "向日性を持った、もやしのように蒼白い堯の触手は、不知不識その灰色した木造家屋の方へ伸びて行って、そこに滲み込んだ不思議な影の痕を撫でるのであった。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もやもやした霧の中から突然日輪でも出現したようにあまりにくっきりとそれだけが聞こえて、あとはまた元どおりぼやけてしまった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわれ、そのかぐわしき才色を今に語り継がれているサフォこそ、この男のもやもやした胸をときめかす唯一の女性であったのである。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、もやもやしている。",
              "citation": {
                "source": "待つ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "七枚の紙幣をろうそくの火でもやしたって、これほど痛烈な損失感を覚えないだろう。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今更政宗は仕方が無い、底倉の温泉の烟のもやもやした中に欝陶しい身を埋めて居るよりほか無かった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るい教室の中にはもやもやした生暖い空氣が一杯に罩め渡つてゐた。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "友と呼び愛人といふも、はしたなきもつれに脆くも水と冷ゆるは世の習ひなり、鷺を白しと云ひ、鴉を黒しといふも唯だ目にみゆるところを言ふのみ、人の心を尋ぬれば、よしなきことを諍ひては瞋恚の焔を懐にもやし、露ほどの恨みも長しへに解くることなく人を毀はんと思ふ。",
              "citation": {
                "source": "哀詞序",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪しといはば弁護もやしたまはむ。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪しといわば弁護もやしたまわん。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "風かそれとも、遠くの方を行く汽車の音とでも云ふやうな、平生も耳に這入つて来る雑音が聞えて来た暗いもやもやした憂鬱がこの雑音に絡らみついてしまつた。",
              "citation": {
                "source": "あかんぼの首",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の女王はそこにいて、まい晩、青い光を出す花火をもやしているのさ。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か、斯う、嬉しいんだか、悲しいんだか、わからないもやもやしたものが胸に一杯で――」　たうとうその晩、上田君と大田黒君とがわたしの宿に、飲み明すことになつて街を引きあげて来る途中、今度は妙にしつかりとしてゐるわたしの肩に大田黒君がつかまつて、月を見あげながら呟くのであつた。",
              "citation": {
                "source": "岬の春霞",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ眼のさきが、もやもやして、心臓がコトコトと響を立てて躍っているみたいな按配で、あれは、まったく、かなわない気持のものだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭脳が蛆でも湧いてゐるやうに、感覚がもやもやして来た。",
              "citation": {
                "source": "歯痛",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすこにいる蛾をもやもやした黒い影のように思ったりしていた事から考えてみると、いまいましさから自分は思わず背たけの低い女の幻影を見ていたのかもしれない。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "周囲だけが妙にもやもやして心のほうだけが澄みきった水のようにはっきりしたその頭の中には、貞世のとも、幼い時の自分のとも区別のつかないはかなさ悲しさがこみ上げるようにわいていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして家にはいって来ると、手分けをして、しとみ（雨戸のかわり）をおろしたり、台所へ行って、火をもやしたりして、食事の用意を始め、やがて美しい銀器に食物を盛って、主人の女にもこの男にも喰わせた。",
              "citation": {
                "source": "女強盗",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、病院から出られて間もないころ、夜中にそつと寝床を出ていくつかの手紙を火鉢でもやしてゐられたことがあつた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "25夜ふけてかへるふしどにかをるは酒か、もやしか、酒屋男のこころにそそぐは雪か、みぞれか。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "もやもやした白い湯気が瓦斯のひかりを陰らせて、夜ふけの風呂のなかは薄暗かった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは中学からすぐ東京に出て行く友だちの噂を聞くたびにもやした羨望の情と、こうした貧しい生活をしている親の慈愛に対する子の境遇とを考えずにはいられなかった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "わる者たちの方は、海べりにテントをはり、さかんに火をもやして、なにかうまそうなたべ物をにているようです。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "紳士はまたもやしばらく黙っていましたが、ちょっと軽い溜息をついて、「うっかりすると、意外な悲劇が起こらぬとも限らないからです」　と言いました。",
              "citation": {
                "source": "メデューサの首",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしたち二人の頭が、突然もやもやした、半透明の匂やかな靄に包まれたかと思うと、その靄の中で、近々と柔らかに彼女の眼が光って、ひらたい唇が熱っぽく息づき、歯がだんだん見えてきて、ほつれ毛が焼けつくようにわたしの頬をくすぐった。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
