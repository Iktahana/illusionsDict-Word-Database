        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから緋縅蝶、紋白蝶なども採集した。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、紋白蝶がヒラヒラ飛んで来た。",
              "citation": {
                "source": "焔",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "けふ始めてことしの蝶を見た、紋白蝶一羽。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩春初夏の後楽園野球場には、しばしば、可憐な紋白蝶が一匹或るいは二匹、ひらひらと飛んでいる。",
              "citation": {
                "source": "ジャングル頭",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "紋白蝶なんかは黒蝶よりもあさっぽい気がする。",
              "citation": {
                "source": "日記",
                "author": "一九一四年（大正三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒塀の外には春の日の光に銀の粉を浴びた紋白蝶が一羽、気楽そうにひらひら飛んでいます。",
              "citation": {
                "source": "白",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "畠の隅には、こぼれ生えの大根の花が咲き、紋白蝶が群り飛んでいる。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
