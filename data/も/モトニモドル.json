          "literary": [
            {
              "text": "（重兵衛はそのまま内へ引込むと、舞台は元に戻る。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "wot は、復活する・元に戻るの義で、常に交替して神事に奉仕する男子・女子が、wot-ko, wot-me なのであつた。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦方の町人や蜑は、職の上から平等ですし、田を班けられる村方の百姓は、均しくわりあてられる事になつて、二十三年目位には、一切の事情が元に戻るのでした。",
              "citation": {
                "source": "雪の島",
                "author": "熊本利平氏に寄す",
                "note": "青空文庫"
              }
            },
            {
              "text": "満潮になればバラスト水が自然に元に戻る。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく安静にすると元に戻る。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争、疫病、飢饉の三重の天罰はユスティニアヌスの臣民を苦しませ彼の治世は人口が目立って減少したという不名誉が与えられ地球上でもっとも美しいと言われた地方が元に戻ることはなかった。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然に開いて、ひとりでに元に戻るのが一番だ。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "押し上げても、押し上げても、元に戻るものだから、口を塞いでしまうのに、長い間かかった。",
              "citation": {
                "source": "蟲",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐ろしき借家人　お話は元に戻る。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは名士だし、少なくとも狂乱の沙汰が過ぎたら、また元に戻る。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんな場合は元に戻るのでしょう。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日――昨夜入浴せしため感冒ふたたびもとにもどる。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年たてば、殻物も古いのは食いつくされて新しいのが出てまいりますし、火を擦り出す木にしましても、四季それぞれの木が一巡して、またもとにもどるわけです。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴグルのふちによって切り取られた視界が、カーブに進入するにつれてやさしく左にかたむき、カーブを出ると、もとにもどる。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
