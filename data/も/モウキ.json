    },
    "definitions": [
      {
        "index": 1,
        "gloss": "blind turtle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれども、そのやうな事こそ凡慮の及ぶところではないので、あのお方の天与の霊感によつて発する御言動すべて一つも間違ひ無しと、あのお方に比すれば盲亀にひとしい私たちは、ただただ深く信仰してゐるより他はございませんでした。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは阿波の鳴門の渦に巻込まれて底へ底へと沈むようなもんで、頭の疲れや苦痛に堪え切れなくなったので、最後に盲亀の浮木のように取捉まえたのが即ちヒューマニチーであった。",
              "citation": {
                "source": "二葉亭追録",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "文治は盲亀の浮木に有附きたる心地して、　「正直の頭に神宿るとは宜く申した、我は生れて此の方、不正不義の振舞をした例はない、天我を憐みたまいてお救い下さるか、あゝ有難し辱けなし」　と喜んで居りますると、俄然一陣の猛風吹き起って、忽ち荒浪と変じました。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、女の方では、そんなこととは知らないから、世にも手頼りない身の盲亀の浮木に逢った気で、真心籠めて小平太に仕える。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "賢愚おしなべて哀れはかない運命の波に浮沈する盲亀の面貌である。",
              "citation": {
                "source": "美の日本的源泉",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "花がこの紳士を王様と呼ぶ以上、それは加十に違いないのだから、一同は盲亀浮木といった態たらく。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "盲亀の浮木、優曇華の花、お蔭で目的を果したという鄭重なお礼状が来た。",
              "citation": {
                "source": "首切り問答",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、一族大勢がやってきて、だんだんに智深の説得を聞き、盲亀の浮木で、ついに彼の策にすがった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――身は緑林におき、才は匹夫、押して申しかねますなれど、きょうの日は、てまえにとって、実に、千｜載の一｜遇といいましょうか、盲亀の浮木というべきか、逸しがたい機会です。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうきっと間違いない。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「民さん、もうきたかい。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "幅広に生えてゐる、白くなつた八字髭は根の処がもうきたない黄色になつてゐる。",
              "citation": {
                "source": "老人",
                "author": "GREISE",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあもうきっと僕は僕のために、僕のお母さんのために、カムパネルラのためにみんなのためにほんたうのほんたうの幸福をさがすぞ。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みそさざいならばからだをうごかすたびにもうきっと啼いているのだ。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "真相が少しわかりかけるころには読者も記者ももうきれいに忘れているのであろう。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはもうきのう、お餅をつくっているときから、ふたりがおかあさんにたのんで、かたく約束しておいたことです。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあもうきっと僕は僕のために、僕のお母さんのために、カムパネルラのために、みんなのために、ほんとうのほんとうの幸福をさがすぞ」　ジョバンニは唇を噛んで、そのマジェランの星雲をのぞんで立ちました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「裁判ももうきょうで三日目だぞ。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからあと、山ねこ拝というはがきは、もうきませんでした。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうきっと間違ひない。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、あたしもうきめたわ。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうきっとさう申し伝へて参ります。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "染めるんならもうきっと今すぐやって呉れ。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それはもうきっとさう行くね。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつはもうきっとなんだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどももうきのうで休みは終わりました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあもうきつと僕は僕のために、僕のお母さんのために、カムパネルラのために、みんなのために、ほんたうのほんたうの幸福をさがすぞ。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうきっとそう申し伝えて参ります。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それはもうきっとそう行くね。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつはもうきめているのだ」という意外な言葉。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
