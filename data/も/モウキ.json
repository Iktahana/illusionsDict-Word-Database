[
  {
    "uuid": "4b9b4f47-a7e1-5005-95fc-b7e1324841a7",
    "entry": "盲亀",
    "reading": {
      "primary": "もうき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
