    "definitions": [
      {
        "index": 1,
        "gloss": "to speak (of something)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "本田富次郎の頭脳が、兎に角物を言う事の出来た間中は、彼は此地方切っての辣腕家であった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "物を言う口付きが覚束なくて眼はどこを見ているかはっきりしないで黒くてうるんでいる。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "好意的な相関関係は贈物という具体的な形で物を言う場合がある。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえには歩くことよりも物を言うことよりももっとしないでいられないことがあった。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓは口ごもって、ひどくはにかんだように物を言う癖があったのである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　誤解されたトーキー　トーキーは物を言う映画だからと言っても、何もむやみに物を言わせる必要はない。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物を言わないで物を言うよりも多くを相手に伝えるこの西洋流のしぐさは、なんでもこくめいに言葉で言い現わしたがるドイツ人には珍しいと思われた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も一言も物を言う人もありませんでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なめくじはいつでもハッハハと笑って、そしてヘラヘラした声で物を言うけれども、どうも心がよくなくて蜘蛛やなんかよりは却って悪いやつだというのでみんなが軽べつをはじめました。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "掃溜が物を言う……」「ヘイ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この黒い血の痕跡と、女の髪の毛と、刀を拭いた汚れの痕跡と、風呂場の煤の跡が物を言う」「アハハハ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画が物を言うというノヴェルティに対する好奇心はほんのわずかの間に消え去ってしまうとともにあらゆる困難が続出して来て、映画芸術は高い山から谷底へ顛落した。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（口をもがもがさせながら物を言う）花田　　貴様、俺のチョコレットを食ってるな。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "がやがや物を言う声、それから「気をつけ」や「番号」や「右向け右」や「前へ進め」で狐の生徒は一学級ずつだんだん教室に入ったらしいのです。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これッ、人が物を言うに返事もしないか。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、今しがた誰も居ないのに声が懸って、人形が物を言うていこたあ無い筈だと思ったが、下枝の業であったかも知れぬわい。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅刻はするし、酔っぱらっては来るし、もうこんな人とは結婚なんかするものかと思ったが、そう思ったことがかえって気が楽になったのか、相手が口を利かぬ前にこちらから物を言う気になり、大学では何を専攻されましたかと訊くと、はあ、線香ですか、好きです。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして信吉に物を言う隙も与えずに、すっと立去ってしまった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、女の斜眼は面と向ってみると、相当ひどく、相手の眼を見ながら、物を言う癖のある私は、間誤つかざるを得なかった。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら笑っても愁いの除かぬ切れ目の小さい眼でちろり／＼わたくしを眺めながら物を言う間にも額口や袖口のカフスの中の手首をハンカチで拭く所作があります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度人に対して物を言う時に用いる反語のように、いっそ娘が憎くなったら好かろうと、心の上辺で思って見るに過ぎない。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "問う人も、答える人も無意識に含糊の態をなして物を言うようになったのである。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚金のお上さんなの」「なにまるで狸が物を言うようで、分かりゃあしない。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがきょう言われぬようでは、あの方に物を言う折は無くなってしまうかも知れない。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅を使にして何か持たせて上げようと思っても、それは出来ず、お目に掛かっても、物を言うことが出来なくては、どうにも為様がなくなってしまう。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "真っ直に巡査派出所の前を通り過ぎる時、僕はようよう物を言うことが出来た。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると弟はまっ青な顔の、両方の頬からあごへかけて血に染まったのをあげて、わたくしを見ましたが、物を言うことができませぬ。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "物を言うのがせつなくっていけない。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、口は物を言うたんびに横へまがる。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「体は大層好くなりましたが、なんだかこう控え目に、考え考え物を言うようではございませんか。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
