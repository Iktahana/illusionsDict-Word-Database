    },
    "definitions": [
      {
        "index": 1,
        "gloss": "babysitting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "然るに真実を守り、虚飾に関与せざらんはまた却々大した芸当である。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "万古の流れに洗はれて、土を守り、樹木を育ててゐる島である。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八、九のはてれ隠しに自分の守り児のかぼそい女の児を抱き上げて、　――芝居季節が近づいたんでこの子のお母さん巴里へ帰って来るってさ。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（引出しの分も拜借致し候　　　石之助）さては放蕩かと人々顏を見合せてお峯が詮議は無かりき、孝の餘徳は我れ知らず石之助の罪に成りしか、いや／＼知りて序に冠りし罪かも知れず、さらば石之助はお峯が守り本尊なるべし、後の事しりたや。",
              "citation": {
                "source": "大つごもり",
                "author": "一葉女史",
                "note": "青空文庫"
              }
            },
            {
              "text": "（引出しの分も拝借致し候　　　　　石之助）　さては放蕩かと人々顔を見合せてお峯が詮議は無かりき、孝の余徳は我れ知らず石之助の罪に成りしか、いやいや知りて序に冠りし罪かも知れず、さらば石之助はお峯が守り本尊なるべし、後の事しりたや。",
              "citation": {
                "source": "大つごもり",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が姉を見上げた時に、姉の後に襷を掛けた守りのお松が、草箒とごみとりとを両手に持ったまま、立ってて姉の肩先から自分を見下して居た。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は姉の可愛がってくれるのも嬉しかったけれど、守りのお松もなつかしかった。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其後自分は両親の寝話に「児供の余り大きくなるまで守りを置くのは良くない事だ」などと話してるのを聞いたように覚えてる。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私どもは、契沖は、昔の人が一度｜定めてそういう風に書いたのを後の人がずっと守って来たけれども、余り後の世になるとその定りを守り切れないで混同したのだと考えていたのであるらしく思うのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（引出しの分も拜借致し候　　　　　　　　石之助）　さては放蕩かと人々顏を見合せてお峰が詮議は無かりき、孝の餘徳は我れ知らず石之助の罪に成りしか、いや／＼知りて序に冠りし罪かも知れず、さらば石之助はお峰が守り本尊なるべし、後の事しりたや。",
              "citation": {
                "source": "大つごもり",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "年を取ってからはただその問題を守り立て、仕上げをかけるばかりだ」というのは、どうも多くの場合に本当らしい。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その東洋文人の修道院で、彼は、「身を修め藝を研く」の古訓を守り孜々として修養して來た。",
              "citation": {
                "source": "室生犀星に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にとつては永久に失ひたくない祖國にも等しい、貴方の恩惠を、何卒、私にお守り下さいますやうに。",
              "citation": {
                "source": "リルケ書翰（ロダン宛）",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、お母がこしらえてくれた守り袋を肌につけていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お守りが沢山慾張って入れてある。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お守りの中から金が出てきたが。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お守りの中から金が出てきたんだ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀州は源叔父が顔見て驚きし様もなく、道ゆく人を門に立ちて心なく見やるごとき様にてうち守りぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のわたくしとしては別にお礼の致しようもございませんが、これからは蔭ながらおまえさん方夫婦の身の上を守ります」　かれは足音もしないように表へ出て、その姿は五月の闇に隠されてしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを胸のポケットへ、畳んで、お守りのように大事に、しのばしている者もあった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい弟の子守りをしながら留守居をしていた祖母は、恥しがる京一をつれて行って、「五体もないし、何んちゃ知らんのじゃせに、えいように頼むぞ。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に女訓導は、　　　　　ショールを面に被ふれば、アラーの守りあるごとし。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母さんはぼくにお守りを借してくれた。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが故郷ではなく、勝子のお守りでもする気で出かけて行った北｜牟婁の山の中だっただけに、もう一つその感じは深かった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝軍地蔵はいつでも武運を守り、福徳を授けて下さるという信仰の対的である。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐懼修省の工夫が有れば、以て宗廟社稷を守り、以て祭主と為るべきである。",
              "citation": {
                "source": "震は亨る",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと始めのうちに同居していたたくさんの花瓶はだんだんに入り代わって行くのに、これだけは木守りの渋柿のように残っていた。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この本能を守り立てればアルピニストになれる。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "定員人数の制限を守りさえすれば墜落の恐れはめったにない。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹌踉めくままに静もりを保ち、聊か儀文めいた心地をもつてわれはわが怠惰を諫める、寒月の下をゆきながら、陽気で坦々として、しかも己を売らないことをと、わが魂の願ふことであつた！",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
