[
  {
    "uuid": "c749dacc-cbc9-5294-8e5b-50b7e98cb296",
    "entry": "守り",
    "reading": {
      "primary": "もり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
