    "definitions": [
      {
        "index": 1,
        "gloss": "to lean against",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "Ｔ「毎日　毎日　考えてるんだけれど」　「どんな定九郎を演ったらいいかなァ」と又力なく欄干に凭れる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「ココ此村……」　殴られた様にフラフラと我が家の入口に凭れる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と楽にさし寄って、袖を土手へ敷いて凭れるようにして並べた。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれもこれも一瞬時、得三は眼血走り、髪逆立ちて駈込つ、猶予う色無く柱に凭れる被を被りし人形に、斬つけ突つけ、狂気のごとく、愉快、愉快。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　宮子は急に立ち停って、橋の欄干に凭れる真似をしながら、鶴雄の行き過ぎるのを待った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私と庄亮とはＯ氏やＡ博士やＨ君夫妻を向う斜めに見わたせる、船舶課側の窓際のクッションに凭れる、末席の方だが、このテエブルには若い船医や京都府の警部さんのＡ君やと大概は同席である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "背の高い蝋細工の人形のような顔をした、黒い数多ある髪を束髪にした凄いように※な女が、障子の引手に凭れるようにして立っていた。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さながら竜の水を得たるが如く、又は虎の山に凭れるが如く無辺際に亘って活躍して、鼻以外の表現能力が発揮し得ない範囲にまでも遠く深く及ぶものであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は物足りないのでふらふらと出て来たものの他に行く所もないので橋の欄干へ凭れるともなしに凭れたところであつた。",
              "citation": {
                "source": "牡蠣船",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "背の高い蝋細工の人形のやうな顔をした、黒い沢山ある髪を束髪にした凄いやうに綺麗な女が障子の引手に凭れるやうにして立つてゐた。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は物たりないのでふらふらと出て来たものの、他に往くところもないので橋の欄干へ凭れるともなしに凭れたところであった。",
              "citation": {
                "source": "牡蠣船",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大きな腹を突き出して太政官は、椅子にもかゝらずに、杖に凭れるやうにして、太い息を助役の頭から吹きかけた。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だ、どうしたんだい」宮崎の腕にグングン引っぱられながら、後に凭れる様にして慎作は原因を探った。",
              "citation": {
                "source": "十姉妹",
                "author": "山本勝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁に凭れると男の匂いがする。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「又、しのび泣きなの、困るわね」　ミツシヱルは、寒子の描きかけてゐる画架に凭れると、暫時は、しのびなきの話に耽ける。",
              "citation": {
                "source": "瑪瑙盤",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを掻き分けて、ぐつと木柵に凭れるやうにして、河底を覗き込むと白つぽいものが、汚れた水の上に浮いてゐた。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子の寢姿に凭れるやうにして横になつた。",
              "citation": {
                "source": "雨",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まア、お待たせいたしまして、昨日から今日にかけて、澤山おひとが見えましてなア、あれこれとたてこんでゐまして、ほんとに、えらいことお待たせいたしました」　顎が二重にくびれてゐて、胸も腹もずんどうにつきでてゐる、まるでくゝり枕のやうな胴體を、卓子へ凭れるやうにして女は坐つた。",
              "citation": {
                "source": "風媒",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "繻子の模様も対とは思うが、日除の白蔽に、卸す腰も、凭れる背も、ただ心安しと気を楽に落ちつけるばかりで、目の保養にはならぬ。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "不図した些細なハヅミに由つて、私の凭れる廻転椅子は、睡りのやうにユラユラと滑り出しさうになり、そして、白い空虚な部屋の中には、此処にも矢張りもんもんと滾る蝉の音が木魂してゐた。",
              "citation": {
                "source": "蝉",
                "author": "――あるミザントロープの話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬耳は籐椅子に凭れる。",
              "citation": {
                "source": "麓",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏像は物置の奥手に、埃のいつぱい積つた長持に、凭れるやうにして立つてゐました。",
              "citation": {
                "source": "南風譜",
                "author": "――牧野信一へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえむしろ、その冷めたさに凭れることが、彼を休息させるのだつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "周囲二里の、絶望に凭れる森林に抱かれたる山頂の池は、千尺の崖下に万古の聖泉を撫しつつ昼は紺碧の空を宿し、岫を出づる白雲を泛かべ、夜は銀河の影を沈め、月光を祕するのであらう。",
              "citation": {
                "source": "八月の霧島",
                "author": "吉田絃二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みなが決闘に夢中になっている間に下手の幕のうしろの窓から出て上手の窓から入り、ハムレットが幕へ凭れるのを待っていたんだ」「小松の財産をとるつもりで、はじめから計画してやったことだったんだな」「そうだよ、相当長く研究した。",
              "citation": {
                "source": "ハムレット",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣紋竹に掛けてある着物ばかりは、室内の光景に不似合なものであった……お種は、何処へ行っても、真実に倚凭れるという柱も無く、真実に眠られるという枕も無くなった。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘も余に寄り添うて手摺りに凭れる。",
              "citation": {
                "source": "斑鳩物語",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥酔者ならばこんな状況で壁に凭れる筈はなく、また、解けかかった皮帯は、たいていそれ自身の重さで前の方へ垂れかかるか跳ねかえるか、いずれにせよ、背筋の真下などで壁に接する筈はありません。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人がその曲り角まで走って行くと、壁際に五十ばかりの、小さな丸髷を頭にのっけた老婆が壁に凭れるようにして寝ている。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈の高い男の嚴丈さうな腕に、もたれるやうに腰を抱きかかへられながら、女は踵の高い赤革靴の運び輕げに踊つてゐる。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
