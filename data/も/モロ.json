  {
    "uuid": "6386a166-a796-57d9-976a-626da9c2716c",
    "entry": "もろ",
    "reading": {
      "primary": "もろ",
      "alternatives": [
        "モロ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "conspicuously",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いまは、――年とって、もろもろの物慾が出て来て、お恥かしゅうございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "惡寒疼痛、二、三日は、夜もろくに眠れませんでした。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの、虎の皮のふんどしをした赤つらの、さうしてぶざいくな鐵の棒みたいなものを持つた鬼が、もろもろの藝術の神であるとは、どうしても私には考へられないのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな愚かな藝無しどもが、もろもろの藝術の神であるとは、どうしても私には考へられないのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとこの龍宮のお土産も、あの人間のもろもろの禍の種の充滿したパンドラの箱の如く、乙姫の深刻な復讐、或ひは懲罰の意を祕めた贈り物であつたのか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはどうしてこんなに涙もろいか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "舟も仲良くぴつたりくつついて、死なばもろとも、見捨てちやいやよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死なばもろとも、夫婦は二世、切つても切れねえ縁の艫綱、あ、いけねえ、切つちやつた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たうもろこしの葉が、風にさやさやと騷ぐのも、ながなか優雅なものである。",
              "citation": {
                "source": "金錢の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いのちの声　　　　　　　もろもろの業、太陽のもとにては蒼ざめたるかな。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の野になくてかなわぬすすきと女郎花は、うら盆のお精霊に捧げられるために生れて来たように、涙もろくひょろりと立っている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ意味からいって彼女の芸は巴里の哀れさ寂しさをしみじみ秘めた小さいもろけた小屋ほど適する。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし息子は、父親の神の遥々の訪れをそれと知るや、直ちに翁を家の中へ導き入れ、紹介せたその妻もろとも下へも置かない歓待に取りかかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてちらっと大きなたうもろこしの木を見ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カムパネルラが「あれたうもろこしだねえ」とジョバンニに云ひましたけれどもジョバンニはどうしても気持がなほりませんでしたからたゞぶっきり棒に野原を見たまゝ「さうだらう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たうもろこしだって棒で二尺も孔をあけておいてそこへ播かないと生えないんです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然たうもろこしがなくなって巨きな黒い野原がいっぱいにひらけました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその鶴をもってこっちを見てゐる影ももうどんどん小さく遠くなり電しんばしらの碍子がきらっきらっと続いて二つばかり光ってまたたうもろこしの林になってしまひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俄かにピタッととうもろこしの粒の落ちて来るのがとまりました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し彼はまた一面に非常に涙もろい處女のやうな優しい心をもつた男だ。",
              "citation": {
                "source": "室生犀星の印象",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕のもろもろの借金を（Ｐ・Ｃ・Ｌからなるせからの払ッて下さい。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもろいのなら儂に残して置いてほしい。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "案外もろく父もそこに陥ちいらぬとも限らない。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮気ものにインターナショナルの戦勝盃を与えて、お前涙もろい女、近代主義の楽天家、お前が私を愛する心、俺のためには死をも辞せない。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
