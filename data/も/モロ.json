[
  {
    "uuid": "6cfd14a5-869d-56e7-9a96-4f3b36193813",
    "entry": "諸",
    "reading": {
      "primary": "もろ",
      "alternatives": [
        "モロ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "接頭辞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "both",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "諸君は僕を、「ほがらか」でないといふ。",
              "citation": {
                "source": "酒場にて（定稿）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、輝き出でるや、諸君は云ひます、「あれでああなのかねえ、不思議みたいなもんだねえ」。",
              "citation": {
                "source": "酒場にて（定稿）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに猶、諸君も嫌ひではない冗舌は、此処に十分に按配されてをり、直き直きに抽象語を以てしなければ、かの「意味がない」と云つて嘯く、平盤な心情の人達のためには、十分哲学的学術的な言葉も此処には見出されるのである。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の我々の感性に近いもの、寧ろ民謡でさへある殉情詩が、此の殉情的な国で、今迄読まれなかつたなぞといふことは不思議だと、今度此の全集の第一巻が出た後では、諸君も必ずやさうお思ひになることと思ひます。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しその海の上にも星変り、月変つて、――と茲で、私の目は漸く海を去つて、なんだか海と空との中間の奥といつた感じの方角に、過ぎ逝ける諸世紀が、黒光りする中世の武具の色をして、堵をなして潜んでゐるやうに感じられる。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、いま新らしき遊戲は行はれ遠望の海さんさんたるにわれ諸君とゆびさし眺望してながく塔下に演説す。",
              "citation": {
                "source": "交歡記誌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "機会宮沢賢治恋のはじめのおとなひはかの青春に来りけりおなじき第二神来は蒼き上着にありにけりその第三は諸人の栄誉のなかに来りけりいまおゝその四愛憐は何たるぼろの中に来しぞも",
              "citation": {
                "source": "機会",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君がもし一個の林檎に如何にも惚れ惚れとしたら、それを描きたくなるであらう。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "要は、その林檎に如何にもほれぼれとしたら諸君は芸術家だといふことだ。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば、僭越乍ら、詩人諸氏が、何卒真率になられんことを希望してやまない。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく現に生存してゐる歌人諸氏が、最後的のものであらう。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等諸特質が彼女の詩をなすものであつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして向勢は諸物の形象を時間的に聚集する。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だ、そんなことかと諸君は云はれるでもあらうが、まあまあ鳥渡待つて下さい。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "直観といふ精神の実質的動機とも云ふべきものが稀薄となつては、作品も稀薄であらうし又諸々の議論も稀薄にならざるを得まい。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の書中の諸詩篇を、年代順に配列し直して読むならば、詩毎に、彼が駆廻つた短い道程、彼の旅行、彼の恋、彼の悲しい肉体を、熾な芸術家の申し分ない歎賞を以て、繰返す思ひがするのである。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "こまごまと情景を描いたりして諸君を退屈させようとは思はない。",
              "citation": {
                "source": "深夜の峠にて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉が如何に現実にとつてまどろつこしいものであるかは、諸君も先刻御承知であらうし、恐らく諸君が考へてゐられる以上にそれは事実だ。",
              "citation": {
                "source": "深夜の峠にて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いや、却々どうして、そんな単純なものではない、と諸君はさとして下さるのかも知れない。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君――つまり意識を以て生きてる諸君は、若し其の時、私がニコニコすれば私が元気だと思ふだらうし、六ヶしさうな顔をしてゐたら元気がないなと思ふのであらう。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした諸問題について、芥川君は非常に懷疑的であり、絶望的にさへニヒリスチツクであるやうに思はれた。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は佐藤春夫、室生犀星、北原白秋、千家元麿、高村光太郎、日夏耿之介、佐藤惣之助等の諸君の詩を、たいてい忠實に讀破してゐた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが不運にして芥川君は出席されず、歸途に驢馬同人の諸君に向つて、大いに私の論旨を演説した。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、人の世の諸現象の把握については、ヘエゲル先生を支持する。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、いまのこの世の中に最も適した表現を以て、諸兄に話かけているだけなのである。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、私の最初の短篇集『晩年』二百四十一頁を、たった三夜で書きあげた、といったら、諸兄は、どんな顔をするだろう。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、あれには十年たっぷりかかりまして、と殊勝らしく伏眼でいったら、諸兄は、どんな顔をするだろう。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "意の在るところの一端は、諸兄にも通じたように思う。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまは、――年とって、もろもろの物慾が出て来て、お恥かしゅうございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "惡寒疼痛、二、三日は、夜もろくに眠れませんでした。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
