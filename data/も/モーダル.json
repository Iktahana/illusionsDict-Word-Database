        "examples": {
          "standard": [
            {
              "text": "ウェブサイトでログインボタンを押すと、背景が暗くなってモーダルウィンドウが表示された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ユーザーに警告を促すため、この操作にはモーダルダイアログを使用することにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「モーダルを閉じないと他の操作ができないのは不便だ」とテスターから意見が出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "Ｂ・Ｂ・キングを頂点とするリード・ギター・サウンドをひとつにまとめてそこにホーンでハーモニックなバックをつけ、たとえばマディ・ウォーターズのようなミシシッピー生まれのシカゴ・ブルースマンの原始的なスタイルが持っているモーダルなフィーリングをつけ加えようとしたのです。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "モーダルなアプローチのほうが、力強くなるのです。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "不変な構造をモーダル・ノートで埋めていくわけだが、ひとつひとつのノートが持っている音声的なものへの関心をすてて、ただ早く演奏してしまう、ということになるのだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
