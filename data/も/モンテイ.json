        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自らその門弟と称したルモオルに於てであつたと告白してゐる。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれが、ひとりの門弟と論爭して、お膳のかながしらの頭をがりがり噛んで食べた、ことなど、かれの人となりを知るに最もよきエピソオドであらう。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "門弟と共に顔見合わせた。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と言い捨てて門弟と共に去ろうとする。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次が、Ｔ「伝八つあんと仰しゃるんでしょう」　棚倉さてはと思って門弟に合図する。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「不具戴天の父の敵覚悟しろ――」　棚倉呆れたが、門弟と共に刀の柄に手を掛けて見構える。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次飛退って、Ｔ「と近え中に乗り込むからそっ首洗って待ってなよ」　馬鹿にされて怒った門弟共の斬り込むのを三次逃げ廻って表へ飛び出した。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "側の門弟の一人が、さては、と意味あり気な顔で見合わす。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝お絹の家　棚倉伝八郎と門弟の一人がお絹を口説いて居る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝長屋の夜　棚倉一味の門弟がお絹を引抱えて無理に駕籠に押し込めて担ぎ去る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝棚倉の宅の一室　棚倉伝八郎門弟共に囲まれて、　ほくそ笑んで居る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝棚倉宅　三次門弟相手に、　滅茶苦茶に暴れ廻る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（若しくは　三四郎が伝八を斬った後、他の門弟大勢と立廻りの真最中にＦ・Ｏして下さい。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、その冴えが余に利き過ぎる時、例へば「枯野抄」の中で芭蕉の門弟達に放つた窺察、解剖の如きに到ると、恰も冷たいメスで人間の心理を切り分けてでもゐるやうな、甚だ人間的なものを欠いた、拵へものの心理になつてしまつてゐる。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "百貫目の利銀には今すこしは思ふまゝなるべきところを、いかな／＼然はせずして心を心にいましめ、なまなかの遊びを思はず、只花鳥に物好をあらためて、宗因の孫西山昌札の門弟となり、連歌を仕習ふ。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "三宅花圃女史もここの門弟であった。",
              "citation": {
                "source": "思い出草",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "新七は三代目を門弟の竹柴金作に譲りて、おのれは古河黙阿弥と改む。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士太夫の第一の門弟だという。",
              "citation": {
                "source": "庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "友だちや門弟もすこしはあつたが、表では体裁のいいつきあひはするものの、心は許せなかつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿日、丙※、晴、阿闍梨公暁、園城寺より下著せしめ給ふ、尼御台所の仰に依りて、鶴岳別当の闕に補せらる可しと云々、此一両年、明王院僧正公胤の門弟となりて、学道の為に住寺せらるる所なり。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はその手柄話を聞きたいが精神で、平馬殿に申し含めて、斯様に引止めさせた訳じゃが……門弟共の心掛にもなるでのう」「身に余りまするお言葉、勿体のう存じまする。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのような深い昏睡に陥って居られる、申さば断末魔の老先生が御門弟の謡の間違いを聞きわけられる。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず平日の心得方よろしく暮し向万事質素で、門弟の引立方等が深切に行届いている段が藩公の御耳に達し、奇特に思召され、御目録の通り下し賜わり、弥々出精せよという有難きお言葉である」という御沙汰であった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の御褒美の中に「平日の心掛｜宜敷」「暮し向万事質素」「門弟引立方深切」云々という事実は筆者等が翁の晩年に於ても親しく実見したところで、後に掲ぐる翁の逸話を一読されたならば思い半に過ぐるであろう。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "因に翁のこの時の帰郷の際には、藤堂伯、前田子、林皇后太夫、その他数氏の懇篤なる引留め運動があったらしいが、翁は国許の門弟を見棄てるに忍びないからという理由で聊か無理をして帰ったらしい。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその以前から内々で引続いていた野中、荒巻両家からの只圓翁に対する扶助はこの以後も継続されたので、国許の門弟諸氏はその意味に於て荒巻、野中両家に対し感謝すべき理由がある事をここに書添えておく。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治三十七年十月八日九日両日、門弟中からの発起で翁の八十八歳の祝賀があった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "門弟連中が又も舞台に招集された。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "急遽門弟を招集して評議した結果、翁の健康状態が許さぬ理由の下に翁を諫止してしまった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを慌てて又、口の中へ拾い込んで立って来るので、門弟連中の笑話になっていたが、その場になるとその見幕が恐ろしいので笑いごとどころではなかった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
