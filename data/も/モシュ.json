        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "喪主らしい男は、一人だけ粗麻の喪帽をかむり、泣き女はわんわんほえながらあとにつゞいていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "行儀正しくあとにつゞいている粗麻の喪主と、泣き女はくたびれると、欠伸をして変に笑った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "喪主仰天して彼を捉え打っていわく、汝死人に遇わば愍んで今後かかる事なかれと言うべきに多く祝するは何事ぞと。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "霊柩の直ぐ後の馬車から、降り立ったのは、今日の葬式の喪主であるらしい青年であった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "霊柩の直ぐ後の馬車から、降り立つたのは、今日の葬式の喪主であるらしい青年であつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　　　　＊　　　　＊　越えて二日目、葬式は盛んに営まれて、喪主に立った若後家のお光の姿はいかに人々の哀れを引いたろう。",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢代は玄関前の喪主の位置に立って来る人人に挨拶した。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "母と妹が家に残っていていない今の場合、矢代も親戚たちのことは気にしていられず、喪主の立場から選択して、二人を自動車へ乗せると、このことが何より今日父に報告すべき大切な事実のように思われて来るのであった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その悲しさの薄さはやむを得ないとしても、長い休息のその間を愉しそうにも出来ぬ二人の忍耐を思うと、喪主の疲れの鈍感さで、矢代もようやく二人が気の毒になって来た。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "葬列には職業的泣男まで加へるといふが、喪主その人は喫煙しつつ談笑するなど、われわれ日本人から見ると、腹立しく感ぜられる場合が多い。",
              "citation": {
                "source": "支那人の文弱と保守",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "喪主の長男は袴のひざに手を置いて、揺めくろうそくの灯を見つめていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "喪主の高倉祐吉は、若々しい黒い眉根をしかめて憚かるように腰をあげた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "其大意を述べると、動物園内で、一月二日第一月曜の休日（人間の縱覽を許さぬ日）に、猩々舊棲の鐵柵の前で、追善會を催うした云々、年番幹事の猪が喪主となり、親類總代の猿が弔文を讀み、つづいて鸚鵡は某氏の『星落秋風五丈原』の假聲をやつて、一篇の和讚を歌ふた……云々その和讚の題は『星落秋風動物園』である。",
              "citation": {
                "source": "新詩發生時代の思ひ出",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭官の祭詞を読む間も御玉串を供える時にも喪主になった私はいろいろの事を誰よりも一番先にした。",
              "citation": {
                "source": "悲しめる心",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉦、炬火、提灯、旗、それから兵隊帰りの喪主が羽織袴で位牌を捧げ、其後から棺を蔵めた輿は八人で舁かれた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の子供たちがいくたりか手をつないで駈けまわり、分別もなく歓声をあげたり、子供らしい好奇心から、この喪主の悲しみに目を見はったりしていた。",
              "citation": {
                "source": "寡婦とその子",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の埋葬の登録簿には、僧侶も、書記も、葬儀屋も、また喪主も署名した。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "型の如くに喪主の清作と外孫の当吉（十三）金次（十）が現れてフタをとじてクギをうった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十五　赤罠",
                "note": "青空文庫"
              }
            },
            {
              "text": "喪主小山内徹氏をはじめ遺族、近親、劇場代表者「三田文学」「子分の会」「劇と評論」各代表者が葬列に加わった。",
              "citation": {
                "source": "小山内薫先生劇場葬公文",
                "author": "久保栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十九日午前八時半、喪主、遺族、近親、築地代表者は四谷自宅を出発して、九時十分火葬場に到着し、骨上げの式を行った。",
              "citation": {
                "source": "小山内薫先生劇場葬公文",
                "author": "久保栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "たといその包みを拾ったものが、乞食でも、かったい坊でも、喪主のつぎ、会葬者の第一番に焼香する資格があるのだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "よって、これなる父上の御葬式に、ただいまよりただちに喪主として……」　室内の一同、声を失っている。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "よって、これなる父上の御葬儀は、ただいまよりただちに喪主として……」　源三郎のりっぱな挨拶に、室内の一同、声を失っている。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "市長は喪主菊子嬢と同列で親族席に坐っていた。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もと／＼無理な勘當と知つてゐるので、それを非難するものなどがあるわけもなく、其場から傳四郎は指導者とも喪主ともなつて、何くれと指圖をして居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "花見の果て",
                "note": "青空文庫"
              }
            },
            {
              "text": "親が死んだと聽いては、何が何んでも、喪主のお信乃をつれて來ないわけに行きません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "娘の守袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "はかばかしい喪主もなくて、まばらに人の坐っている寺の本堂を読経の声とともに風が通った。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お葬式は喪主があなたでしたから私の用も多かったわけでした。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――喪主が勤役ちゅうは帰国できるか否かわかるまで葬礼は延ばされるのが通例だった。",
              "citation": {
                "source": "落ち梅記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "半蔵と鉄之丞とは、喪主のように俯向いて歩いた。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
