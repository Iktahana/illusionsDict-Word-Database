    "definitions": [
      {
        "index": 1,
        "gloss": "Edo-era meat vendor (esp. of large game, e.g. deer, boar)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「江戸の街角にあるももんじい屋から、味噌煮の香ばしい匂いが漂ってくる。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「当時は四つ足の肉を食べるのはタブーだったが、ももんじい屋は賑わっていた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ももんじい屋の店先には、猪や鹿の肉が吊るされている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "辻倉の若い者に訊いたら、ここのおかみさんを乗せて行った先は、本所のももんじい屋の近所の錺屋だそうですよ」　ゆく先が錺屋というので、彼は大いに意気込んでいるらしいが、今の半七の考えはもう違っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「占めしめ、万事こう来なくっちゃならねえ、駒止橋の獣肉茶屋で一杯飲んで、帰りがけにももんじいやへ寄って、狐を一舟｜括らせて、これから巣鴨の化物屋敷へ乗り込むなんぞは、我ながら凄いもんだ」　何か嬉しくてたまらないことがあるらしく、しきりに独言を言い言い歩きます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "安房の国の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
