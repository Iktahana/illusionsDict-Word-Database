[
  {
    "uuid": "2a5c8342-75ff-56f0-9649-534af722e12e",
    "entry": "持ち込む",
    "reading": {
      "primary": "もちこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
