    "definitions": [
      {
        "index": 1,
        "gloss": "door(s) of a gate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
