    },
    "definitions": [
      {
        "index": 1,
        "gloss": "falsehood (as one of the five sins in Buddhism)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "門外漢の妄語として御聞き捨てを願います。",
              "citation": {
                "source": "御返事（石原純君へ）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妄語びおろんの胴の空間孕める牝牛の蹄眞實なるものには、すべて或る一種の憂鬱がある。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "『悪魔の腰掛け』だの、『髑髏』だの、『僧正の旅籠』だのというような、こんな妄語から、どうして意味をひっぱり出すことができるのかね？",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖賢何の求めるところあって、妄語・乱言をしようかと考え覚って、何はともあれ経典や手引書を学び味わって、我流に考える様なことをしないで、段々と手本を得てゆくべきなのである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならば、ご心痛なさるのもごもっとも至極、よもや、今のそのお話、うそではござりますまいな」「もってのほかのこと、不妄語戒、犯すほどのばち当たりでござりましたら、蓮信、この紫数珠を身につけてはおられませぬ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "一にも二にも異人を懼れて、外船と交易致さば神州を危うくするものじゃと愚かも甚しい妄語を吐きおるが、国が危ういと思わば内乱がましい内輪の争い控えたらよかろうぞ。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "隔離病舍に收容された晩などは知覺が朦朧になり、妄語まで言つた位。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏面から観察するとすれば酔漢の妄語のうちに身の毛もよだつほどの畏懼の念はあるはずだ。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "To speak……listen to it は字義の解釋を要せざるべきも、是れ佛教の所謂不妄語戒に含有するものにて、英語に謂ふ justice（不十分ながら、公正とか正義とか譯すべきもの）の精神を表明せるもの也。",
              "citation": {
                "source": "アーサー王物語",
                "author": "KING ARTHUR'S ROUND TABLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶一念迷ひ初め、自ら凡夫となるゆゑに、三毒五欲の情起り、殺生偸盜邪婬、慾惡口兩舌綺語妄語、瞋り恚ち愚癡我慢、貪り惜みて嫉み妬みだつた……。",
              "citation": {
                "source": "ボルネオ　ダイヤ",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "木枯しす妄語戒など聞く如く君と語らずなりにけるかな　五戒十戒何れの戒にも妄語戒はある。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄い舌でべらべら口から出任せの※を一夏しやべり続けた罰に凡ての木の葉を打ち落してしまふぞといふ木枯しの妄語戒は厳しい。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校の内、きわめて清楚、壁に疵つくる者なく、座を汚す者なく、妄語せず、乱足せず、取締の法、ゆきとどかざるところなし。",
              "citation": {
                "source": "京都学校の記",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ出家に妄語はないと日頃から思いこんだ婆さんの事でございますから、これを聞いて肝を消しますまい事か、『成程そう承りますれば、どうやらあの辺の水の色が怪しいように見えますわいな。",
              "citation": {
                "source": "竜",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "地獄の沿道には三途の川、剣の山、死出の山、老の阪、賽河原などがあり、地獄には叫喚地獄、難産地獄、無間地獄、妄語地獄、殺生地獄、八万地獄、お糸地獄、清七地獄等々があって、微苦笑させられるが、それらの地獄の名にも似ず、環境の美くしさにはまた驚かされる。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして私共の教では妄語を戒しめてをりますものを。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "冒頭に、霊魂、滅と云い不滅と云い皆痴人の妄語なりとか書いてあった。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一七六　一法を犯し、（且つ）妄語し、他世を信ぜざる人は惡として造らざるなし。",
              "citation": {
                "source": "法句經",
                "author": "荻原雲來訳註",
                "note": "青空文庫"
              }
            },
            {
              "text": "二二三　不忿を以て忿に勝て、善を以て不善に勝て、施を以て慳に勝て、實語を以て妄語者に（勝て）。",
              "citation": {
                "source": "法句經",
                "author": "荻原雲來訳註",
                "note": "青空文庫"
              }
            },
            {
              "text": "二四六　人若し動物を殺し、妄語を爲し、世の中に於て與へざるを取り、他の妻を犯し、二四七　※羅、迷麗耶酒に沈湎するならば、現世に於て既に彼は己の根を掘るものなり。",
              "citation": {
                "source": "法句經",
                "author": "荻原雲來訳註",
                "note": "青空文庫"
              }
            },
            {
              "text": "二六四　頭を剃ると雖も無戒にして妄語すれば沙門に非ず、欲貪を具ふるもの如何ぞ沙門ならん。",
              "citation": {
                "source": "法句經",
                "author": "荻原雲來訳註",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本を発つとき、「死ぬまでかかって」といったのは妄語ではなく、今生では父母兄弟師友に相見えないという請願の趣意も、それでつらぬいたことになる。",
              "citation": {
                "source": "新西遊記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "女帝は法均と清麻呂姉弟を妄語の罪によって神流しにされた。",
              "citation": {
                "source": "安吾史譚",
                "author": "道鏡童子",
                "note": "青空文庫"
              }
            },
            {
              "text": "否、彼はすでに愚鈍な技巧と真面目くさった態度の倫理家の妄語に苦しめられてはいない。",
              "citation": {
                "source": "あめんちあ",
                "author": "富ノ沢麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」こう云って、瑠璃光丸が上人の前に手をつかえて、生れて始めて不妄語戒を犯した事を懺悔したのは、千手が居なくなってから、十日程過ぎた後であった。",
              "citation": {
                "source": "二人の稚児",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……次の五戒とは、殺生、偸盗、邪淫、貪酒、妄語のことじゃ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その正面の青じろい時計はかっきり第二時を示しその振子は風もなくなり汽車もうごかずしづかなしづかな野原のなかにカチッカチッと正しく時を刻んで行くのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると鉛筆はまだキッコが手もうごかさないうちにじつに早くじつに立派にそれを書いてしまうのでした。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉱山も今日はひっそりして鉄索もうごいていず青ぞらにうすくけむっていた。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その正面の青じろい時計はかっきり第二時を示しその振子は風もなくなり汽車もうごかずしずかなしずかな野原のなかにカチッカチッと正しく時を刻んで行くのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
