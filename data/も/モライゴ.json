          "literary": [
            {
              "text": "もしかするてえと、もらい子じゃねえのかな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもこれも、みんなこのもらい子の娘ゆえ、千萩ゆえ、いいえ、実の子に跡をつがせたい親心の迷いからでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの子の父は私に生ませた子を、私からとりあげて、子供の生めぬ妻にもらい子したのだと与えたのでございます。",
              "citation": {
                "source": "女",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "リョウヘイはもらい子であったから、母にすかれなかったし、母はしかってばかりいた。",
              "citation": {
                "source": "ふたりのおばさん",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
