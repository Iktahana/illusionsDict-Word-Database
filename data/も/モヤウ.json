[
  {
    "uuid": "4e404096-3095-5658-9162-b5dd9fa1b012",
    "entry": "催合う",
    "reading": {
      "primary": "もやう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to co-operate (in enterprises)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　楢夫もやうやく泣きじゃくるだけになりました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄線蓮　てつせんは、詩にも歌にも遺れられて、物のもやうにのみ用ゐらるゝものなるが、詩歌に採らるべきおもむき無きものにはあらじ。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が一ぱいに射して絨緞の花のもやうが燃えるやうに見えました。",
              "citation": {
                "source": "黒ぶだう",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ところが早くも鳥類のこのもやうを見てとんびが染屋を出しました。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで娘もやうやく得心したので、親たちも町役人共もほつとした。",
              "citation": {
                "source": "梟娘の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "戀をうしなひし頼家は、こゝに新しき戀を得て、心の痛みもやうやく癒えた。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯を求める、湯を汲みささげる、湯を飮む、此の三つの動作の爲に、兩人ともやう／＼少しく此間のぶまを免れて、談話の端緒を開き得た。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生はそれにも承知の旨を答えたが、まだ東の空が白みかけたばかりであるので、又もやうとうとと眠っていると、かの婦人が三たび現われた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもやう／＼のことで目的の銀座に近づいた時には、そこに二人とも何かを期待するやうな心持ちであつた。",
              "citation": {
                "source": "散歩",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彦三郎　みなさんのお蔭樣で、わたくしの本望もやうやく達しまして、こんな嬉しいことはござりません。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶さへもやうやう滴るばかりに飲み尽しぬ。",
              "citation": {
                "source": "従軍紀事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もやうやくにして、私の句――ほんたうの句――水のやうな句――山頭火の句が作れるやうになつたらしい、何よりうれしいことである。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もやうやくにして私自身にかへることができた、どんなことがあつても、びくともしないおちつきを持つやうになつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の生活もやうやくにして、自分の本性にかへり、本調子になりつゝあるらしい、賀すべし、励むべし、けふも洗濯、縫物、そして揮毫（調子がよろしくなかつたが）。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にもやうやく一転化の機縁が熟しました、虚脱的雲霧が消散して、私本来の天地に立ちかへりました。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあたりもやうやく田植が初まつた、一日のうちにたちまち青田になつてしまつた、よい風景である。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、矢ツ張り、ここも雪もやうで、寒い風が吹いてゐた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もやうやく『行乞記』を書きだすことが出来るやうになつた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが続いて今年もやうやう五月といふ月に這入つて来た時に、五月といふ月は君が病気のため厄月ではないかと或る友人に驚かされたけれど、否大丈夫である去年の五月は苦しめられて今年はひま年であるから、などとむしろ自分では気にかけないで居た。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "（九月四日）百十六○暑き苦しき気のふさぎたる一日もやうやく暮れて、隣の普請にかしましき大工左官の声もいつしかに聞えず、茄子の漬物に舌を打ち鳴らしたる夕餉の膳おしやりあへぬほどに、向島より一鉢の草花持ち来ぬ。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで右筆もやうやく合点が行たといふことだ。",
              "citation": {
                "source": "黙々静観",
                "author": "勝海舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "今多くその文を引かむもやうなし。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　この最後のひと言にパラースカは、自分の頭に束ねられたリボンの色よりも濃く、頬を赧らめたが、暢気な父親もやうやく自分の帰宅した用件を思ひだした。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "――が、それもやうやつと、この夏の間に「若菜」二卷だけでもゆつくり讀み返すことにして置かうと、そんな情熱を抑へつけてゐるところへもつてきて、こんな文章を書かなければならない羽目になりました。",
              "citation": {
                "source": "若菜の卷など",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "惜しき頸輪我もやうやく街に立ち、物｜乞ふために歌ふなり。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝顔の花朝顔の花うらやまし、秋もやうやく更けゆくに、真垣を越えて、丈高き梢にさへも攀ぢゆくよ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "加茂堤の八重との色もやうなども、浄瑠璃で見ると、相当な立役に書かれてゐる。",
              "citation": {
                "source": "手習鑑雑談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "金の屏風の繪模樣は光琳もやう、花もやう。",
              "citation": {
                "source": "春鳥集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
