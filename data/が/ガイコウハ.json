        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ルノワールは、後期印象派とも言われるが、初期は外光派の画家として活躍した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この美術館には、著名な外光派の作品が数多く展示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「へぇ、あの画家、外光派だったんだ！だからあの絵はあんなに明るいのね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
