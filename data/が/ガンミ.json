[
  {
    "uuid": "86e275a5-5b45-5f70-b940-2bacb9838256",
    "entry": "含味",
    "reading": {
      "primary": "がんみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
