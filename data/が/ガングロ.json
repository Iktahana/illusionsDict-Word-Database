        "examples": {
          "standard": [
            {
              "text": "90年代後半に流行した顔黒ファッションは、当時若者の間でとても特徴的なスタイルだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "街で久しぶりに顔黒メイクの女性を見かけ、少し懐かしい気持ちになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は高校生の頃、日焼けサロンに通って顔黒ギャルを目指していたらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "時に、樹の蔭より、顔黒く、嘴黒く、烏の頭して真黒なるマント様の衣を裾まで被りたる異体のもの一個｜顕れ出で、小児と小児の間に交りて斉しく廻る。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
