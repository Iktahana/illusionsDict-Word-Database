    "definitions": [
      {
        "index": 1,
        "gloss": "area on the convex side of a mountain arc or a crescent-shaped archipelago",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
