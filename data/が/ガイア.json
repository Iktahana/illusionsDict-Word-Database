        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古代ギリシャ人は、ガイアを万物の母として崇めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "そのファンタジー小説では、女神ガイアの力が世界の均衡を保っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "環境活動家は、人類が母なるガイアを尊重する必要があると語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "ちよつとポストまで、ちよつと一杯ひつかけたが苦しかつた、何とニガイアルコールだらう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "或説は彼を海王ポセードーンの子とし、他はウーラノスと（天）ガイア（地）との子とし、又或説はポントスとタラッサとの子とす。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "バリー・マクガイアの『全壊の夜』は「詩」としての評価はしないとして、あのときのアメリカが自らを置いていた状況のなかでは、故意に意図されたとしか思いようのないほどに、見当ちがいだった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　ポセイドン（ネプチューン）と大地ガイアとの子であるアンタイオスのこと。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
