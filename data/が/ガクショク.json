[
  {
    "uuid": "fe11c5c6-bc80-5371-a071-0946d21271f7",
    "entry": "学殖",
    "reading": {
      "primary": "がくしょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
