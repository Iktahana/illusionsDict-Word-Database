      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "scholarship",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しからばあらゆる大学教授の学殖はすべて同一であるかというに、そういう事は不可能であるが、同じ物理学の中でもそれぞれの方面にそれぞれの権威があってこれらの人々の集団が一つの理想的な権威団を形成すると考えてよい。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれの才能にも、学殖にも絶望した一人の貧しい作家は、いまは、すべてをあきらめて、せめて長寿に依って、なんとか補いをつけようと心ひそかに健康法を案じている様子である。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "絢爛の才能とか、あふれる機智、ゆたかな学殖、直截の描写力とか、いまは普通に言われて、文学を知らぬ人たちからも、安易に信頼されているようでありますが、私は、そんな事よりも、あなたの作品にいよいよ深まる人間の悲しさだけを、一すじに尊敬してまいりました。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "司馬遷個人としては、父の遺嘱による感激が学殖・観察眼・筆力の充実を伴ってようやく渾然たるものを生み出すべく醗酵しかけてきていた。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "学殖は弟に劣っていても、才気の鋭い若者であったのに、とかく病気で、とうとう二十六歳で死んだのである。",
              "citation": {
                "source": "安井夫人",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "このころ仲平の学殖はようやく世間に認められて、親友にも塩谷宕陰のような立派な人が出来た。",
              "citation": {
                "source": "安井夫人",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人はことに深い学殖のある博士なのである。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "女主人公は、少佐位の未亡人で、男主人公は、学殖のある紳士――先づ資産のある大学教授位の位置とする、女主人公の未亡人と、此の大学教授の細君とは、学校朋輩で、殆んど姉妹同様の間柄、そして此の教授夫人は、基督教信者の、常に博愛事業などに奔走する立派な奥方でもあるのだ。",
              "citation": {
                "source": "未亡人と人道問題",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "公式や学殖というものも、批評に於ては印象からの抽象力として、一定の意義を有っている。",
              "citation": {
                "source": "所謂批評の「科学性」についての考察",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "公式主義やペダントリーのような弊害を理由にして、公式や教師的学殖の正常な役割を、観念的にゴマ化して了うことは許されない。",
              "citation": {
                "source": "所謂批評の「科学性」についての考察",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "批評の科学性の最も手近かな特色であったシステムから、教育可能な抽象力を見出したが、この先生味の勝った（ペダンティックな）システムは、現に、芸術史乃至文芸史の学殖に基く体系の如きものだ。",
              "citation": {
                "source": "所謂批評の「科学性」についての考察",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうアカデミックな学殖を背景とした批評家が、だから初めて、この段階の「科学的」批評家であるわけである。",
              "citation": {
                "source": "所謂批評の「科学性」についての考察",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが学殖を背景とすると云っても、この学殖だけで批評がやれるのではない。",
              "citation": {
                "source": "所謂批評の「科学性」についての考察",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術史的学殖がこの社会科学的認識と結びついた場合もあれば、結びつかない場合もある。",
              "citation": {
                "source": "所謂批評の「科学性」についての考察",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "学殖の深かった抽斎が、新奇を趁う世俗と趨舎を同じくしなかったのは無理もない。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐藤一斎、古賀※庵の門人で、学殖｜儕輩を超え、かつて昌平黌の舎長となったこともある。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此人の学殖があつて、画を善くするのを知つてゐたからである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "中に学殖あるものは「鈴木｜宜山、三箇角兵衛を推す」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「平生江戸にあつては、先生には学殖ある友人もあり、声望ある病家もある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしわたくしは学殖なきを憂ふる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この兄貴らしい心もちは、勿論一部は菊池の学殖が然しめる所にも相違ない。",
              "citation": {
                "source": "兄貴のような心持",
                "author": "――菊池寛氏の印象――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨハンの人品、彼の学殖、そして、彼の通るときに知人の彼へ示す挨拶の仕方などを察するとき、梶には、ヨハンがただ者でない名を秘めた人物だということだけは早くから感じられた。",
              "citation": {
                "source": "罌粟の中",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "三氏のような豊富な学殖を持たず、三氏のような博詞宏弁を能くし得ない鈍根な私の書いたものが、偶※三氏のお目に触れたというだけでも、私に取ってはかなり嬉しいことであるのに、「唯だ看て過ぎよ」とせずに、わざわざ私のために啓蒙の筆を執って下すったということは真に想いがけない光栄であると感じます。",
              "citation": {
                "source": "平塚・山川・山田三女史に答う",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は頭蓋骨の鑑定を命ぜられた斯学に学殖経験深き帝大医科の助手友長医学士で、一人は布地の鑑定を命ぜられた本郷の裁縫女学校長として令名高き田辺氏だった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ口が旨いから、空疎な講義の内容も、十分｜胡麻化されるし、学者仲間には兎も角、世間に対しては、いかにも学殖のある篤学の士のように見せかける事は、易々たる事である。",
              "citation": {
                "source": "血液型殺人事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより杏坪先生の如きは、その学殖詩藻すでに当時定評のあつた人で、山陽をまつて初めて顕れたものではないが併しその性格なり閲歴なりから見ると、何れかと云へば杏坪先生は、華やかに世間の表面に立つべき人ではなかつた。",
              "citation": {
                "source": "頼杏坪先生",
                "author": "中村憲吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "学殖は相当深いらしい。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "基俊の学殖と、古態の歌と、俊頼の今様の詠み口を併せて、更に其他の諸家の主張や、伝承を吸ひ込んだ。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "其には前に言うた信念と学殖とが、どうしても土台になければ、お話にはならない。",
              "citation": {
                "source": "神道の史的価値",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
