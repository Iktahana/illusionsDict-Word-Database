    "definitions": [
      {
        "index": 1,
        "gloss": "grandchild from a daughter married into another family",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "新築して外孫の内親王方の裳着に用いて、美しく装飾された客殿があった。",
              "citation": {
                "source": "源氏物語",
                "author": "花宴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、問題の人が明君の誉高き池田新太郎少将光政で、徳川｜家康の外孫の格。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "及外祖父母・外孫・若孫之婦。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "及外祖父母、外孫、若孫之婦。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "」しかも平氏が堂上の卿相四十三人を陟罰して、後白河法皇を鳥羽殿に幽し奉り、新院に迫りて其外孫たる三歳の皇子を冊立せし横暴は、更に、其亡滅の日をして早からしめたり。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "元国には男の子がなかったから、二人の間に出来た外孫をもって自分の子としてその後を嗣がせる時に源の姓を改めて漆の盛行と名付けた。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二児は主家の外孫に当る上に、主家の子供が病弱で次々と死ぬから、特に疎略にはできない。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十五　赤罠",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、彼の実子たる二人は主家の外孫で、それが主家の後嗣の最も有力な候補者であろうからである。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十五　赤罠",
                "note": "青空文庫"
              }
            },
            {
              "text": "型の如くに喪主の清作と外孫の当吉（十三）金次（十）が現れてフタをとじてクギをうった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十五　赤罠",
                "note": "青空文庫"
              }
            },
            {
              "text": "その娘が海老原という家にお嫁に行って産まれた外孫が、岡田君の細君になったわけであった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか、宇多天皇の女御に上って京極御息所と云われた女子があったが、これも短命を以て終り、他の一人の女子仁善子と醍醐天皇の皇太子保明親王との間に生れた康頼王は、時平の外孫に当り、保明親王の薨去後に皇太子に立ったが、これも延長三年六月十八日に、僅か五歳を以て薨じた。",
              "citation": {
                "source": "少将滋幹の母",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「烏帽子親は、松山のお祖父さまにお願いするのだと、仰しゃっておられました」　松山の祖父とは茂庭佐月のことで、母親の律が佐月の女であり、采女は佐月の外孫に当っていた。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "外孫韲臼」　と八字が書かれてあった。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "外孫は即ち女の子、これ『好』でありましょう。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨーロッパで社会主義者だと言っている人間は、まあ大がいそんなものと見ていい。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "万事ヤミの品物はたいがいそんな物でして、あいにく、あなた、運転手に鼻薬がなかつたもんで、そこからバレちやつたのですよ。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいがいそんな風に考えてるらしいんです。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
