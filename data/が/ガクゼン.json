          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の突然の訃報に接し、ただ愕然とするばかりだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "試験会場で問題を見た瞬間、あまりの難しさに愕然とした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長年信じていた友人の裏切りを知り、愕然として言葉を失った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "完成したはずのプロジェクトが白紙に戻されたと聞き、チーム全員が愕然とした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして從來の交際で、未だかつて知らなかつた或る新しい發見が、この天才的な文學者の本質にひそんでゐることを、朧げながらも自覺して愕然とした。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、それが朝の空に聳り立つてゐるのを見付けた瞬間、愕然と思ひ出した。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さうか、」と狸は愕然として、「知らなかつた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日ロダンさんの遺言書が発表されバルザックの寝巻姿と花子の首は日本女優花子に残さるべきものなり、と云う遺言書を見た巴里の市民は愕然としてしまったのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふとその完全な窒息に眼覚めたとき、愕然と私はしたのだ。",
              "citation": {
                "source": "器楽的幻覚",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と一言われ知らず、口よりもれて愕然たり。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに、ナーニ、俺が馬鹿なんだ、というこの一語でもって自分の問に答えたこの児の気の動き方というものは、何という美しさであろう、我恥かしい事だと、愕然として自分は大に驚いて、大鉄鎚で打たれたような気がした。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはある会合の席でプランクトンの調査に関する講演を聞いた時、「今回のわれわれの調査はまだ単に量的であって質的の点までは進んでいない」という言葉を聞いて愕然として驚いたのであった。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど絵の中から思いがけもなく父の顔がのぞいているような気がして愕然として驚いた。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「東京にはその手が多いからね」　筆者は愕然とした。",
              "citation": {
                "source": "恐ろしい東京",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "顕在的なる「我れ」のみの心理を学んで安心していたわれわれは、この夢の現象から潜在的「我れ」の心を学び知って、愕然として驚きまた恐れなければならなくなったようである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見たとき自分は愕然として驚いたのであった。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時、先生｜愕然として頸をすくめた。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　一言簡潔にして更に妙で、座客ぐうの音も出ず愕然としてこれを見れば、蓋し三味線が、割前の一座を笑ったのである。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "取留めのない夢の想で、拓はこの時少年がお雪に向ってなす処は、一つ一つ皆思うことあって、したかのごとく感じられて、快活かくのごとき者が、恋には恐るべき神秘を守って、今までに秋毫も、さる気色のなかったほど、一層大いなる力あることを感じて、愕然とした。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "途端に巌は地を放れて山を覆えるがごとく、二人の姿はもんどり打って空に舞い、滝の音する森の中へ足を空に陥ったので、あッと絶叫したが、理学士は愕然として可恐い夢から覚めたのである。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "』大佐も愕然として私の顏を見詰めたが『や、貴下は――。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ鉛筆の走り書きで、文字も今は朦朧となっているが、読む事数行にして、博士はにわかに愕然たる様子で、「ホー、怪異！",
              "citation": {
                "source": "南極の怪事",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大助は愕然として若様の面を瞻りぬ。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とへいげんは窓に立寄りて海を望み、たちまち愕然として退りぬ。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "慈善会場の客も主も愕然として視むれば、渠はするすると帯を解きて、下〆を押寛げ、臆する色なく諸肌脱ぎて、衆目の視る処、二布を恥じず、十指の指す処、乳房を蔽わず、膚は清き雪を束ね、薄色友禅の長襦袢の飜りたる紅裏は燃ゆるがごとく鮮麗なり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗吉は、愕然とするまで、再び、似た人の面影をその女に発見したのである。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同斉しく愕然として、医学士の面を瞻るとき、他の一人の看護婦は少しく震えながら、消毒したるメスを取りてこれを高峰に渡したり。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう何時か知らん」　思い寄らざりしわがかたわらに媚めける声ありて、「もうかれこれ一時ですよ」　馭者は愕然として顧みれば、わが肩に見覚えぬ毛布ありて、深夜の寒を護れり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分もひどく感動していたが、彼は捉えたその手の氷の様な冷たさに愕然とした。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「百万円を奪った犯人は、あなたの心のほかに居ります」　芳夫は愕然とした。",
              "citation": {
                "source": "夫人探索",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎者の自分が、愕然と眼をみはったくらいの、冷たく、ずるいエゴイズムでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何気なく手に取り、その箱にはられてあるレッテルを見て愕然としました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」という嗄れた声を、耳元に囁かれ、愕然として振り向くと、ああ、王子の髪は逆立ちました。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はがくぜんとして自分を省みた、そして恥ぢた、何といふ醜い私だつたらう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
