      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "solid",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この登山靴は、岩場でも安心して歩けるほど頑丈にできている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "祖父は80歳を過ぎても、まだまだ頑丈で畑仕事もこなしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "見た目は華奢だが、この椅子は意外と頑丈だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "引越し業者は、頑丈な体つきの男性たちだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしそれでゐて何か或る頑丈な逞しい姿勢の影に、微かな虫声に似た優しいセンチメントを感じさせる。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ、頑丈に釘づけしてあった。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "外交官の松岡は頑丈な顔を曇らせると眼を伏せてしまった。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が夜会服に替えてサルーンに設けられた席に着くと、金モールの事務長の植民地通いの海員らしい頑丈な腕がさしのべられて関西｜訛のある社交的なバスが、ようこそ、Ｙさん。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな眼に、すごい輝やきを持っている頑丈な老人が二人を取りおさえた者達に張りのある強い声で何か命令するように云った。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "造りが、頑丈に、──丁度牢屋のように頑丈に出来ている。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると軌道に沿ふて三｜人、田舍者が小田原の城下へ出るといふ旅裝、赤く見えるのは娘の、白く見えるのは老母の、からげた腰も頑丈らしいのは老父さんで、人車の過ぎゆくのを避ける積りで立つて此方を向いて居る。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "川春の亭主の宇三郎という奴は、ぼてえ振りの魚屋から一代でそれだけの店に仕上げたくらいの人間ですから、年はもう六十に近いのですが、からだも頑丈で気も強い。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれが引きまわしになる時に、一匹の犬も頑丈な口輪をはめられて、その馬のあとから牽かれて行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、頑丈で、闘志があって、米俵をかつぐ力持にかけては村中、誰も親爺に及ぶ者がなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頑丈な、蟇のような靴をぬいで、むせる足を空気にあてるひまもなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどき、彼女は、どうかすると、中津の濃い毛だらけの頑丈な二本の腕が、うしろから無遠慮に自分を抱きしめて、首筋のあたりを、熊のようになめやしないかと気にかかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士たちは、石の高い頑丈な家と塀とをまわって、広い荒らされた、草ッ原に出た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頑丈な格子戸がそこについていた。",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、背丈は、京一よりも低い位いだったが、頑丈で、腕や脚が節こぶ立っていた。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むやみにせいが高くて頑丈さうな曲った脚に脚絆をぐるぐる捲いてゐる人もあった。",
              "citation": {
                "source": "花椰菜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐吉さんは、そんなに見掛けは頑丈でありませんが、それでも喧嘩が強いのでしょうか、みんな佐吉さんに心服しているようでした。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時は、僕は、女って浅間しい虚栄の法螺を吹くものだと、ただ呆れていたんですが、そうですか、学校育ちですか、それなら、法螺じゃありません、小学校のあの階段は頑丈ですからねえ。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "永く満洲で軍隊生活をして、小さい時からの乱暴者の由で、骨組もなかなか頑丈の大男らしく、彼は、はじめてその話をケイ子から聞かされた時には、実に、いやあな気持がした。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　またひとりの若い頑丈そうな柏の木が出ました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん近くなりますと、それは頑丈さうな変に小さな腰の曲ったおぢいさんで、一枚の板きれの上に四本の鯨油蝋燭をともしたのを両手に捧げてしきりに斯う叫んで来るのでした。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋はずいぶん頑丈で、学校ぐらいもあるのだが、何せ新式稲扱器械が、六台もそろってまわってるから、のんのんのんのんふるうのだ。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "表紙はズット大型の黒い皮表紙なんで……ＨＯＬＹ・ＢＩＢＬＥと金文字の刻印が打込んであって、牛だか馬だかわかりませんが、頑丈な生皮の包箱に突込んであります。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "体格は骨太の頑丈な作り、その顔は眼ジリ長く切れ、鼻高く一見して堂々たる容貌、気象も武人気質で、容易に物に屈しない。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾度も玄関に出てその帰りを待っていたという婆やが、何か不吉の予感らしいものを顔に現わして園にその電報を手渡した時、園も一種の不安を覚えないではなかったが、まさかあの頑丈な父が死ぬものとは思っていなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頑丈な木造りの二三の椅子と卓子とが蹲る侏儒のやうにあるべからぬ所に散らばつてゐた。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　またひとりの若い頑丈さうな柏の木が出ました。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、そのころどこかからもらった高価な舶来ビスケットの箱が錠前付きのがんじょうなブリキ製であったが、その上面と四方の面とに実に美しい油絵が描かれていた。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "スカンディナヴィアの田舎には恐ろしくがんじょうで分厚でたたきつけても割れそうもないコーヒー茶わんにしばしば出会った。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、左の下あごの犬歯の根だけ残っていたのが容易に抜けないので、がんじょうな器械を押し当ててぐいぐいねじられたときは顎骨がぎしぎし鳴って今にも割れるかと思うようで気持ちが悪かった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
