[
  {
    "uuid": "b4808aef-224d-5da3-8140-0751f49c8bb0",
    "entry": "頑丈",
    "reading": {
      "primary": "がんじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
