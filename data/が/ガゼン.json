[
  {
    "uuid": "8ca103e5-7eea-5ac4-8252-fdd2f85f9558",
    "entry": "俄然",
    "reading": {
      "primary": "がぜん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
