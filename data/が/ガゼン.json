    },
    "definitions": [
      {
        "index": 1,
        "gloss": "suddenly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
