        "examples": {
          "standard": [
            {
              "text": "深夜の駅前にはガラの悪い集団がたむろしていて、通り過ぎるのが少し怖かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あそこの居酒屋、味はいいんだけど客層がガラの悪い人ばかりで落ち着かないんだよね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は見た目こそガラの悪い風貌だが、実は捨て猫を放っておけないほど心優しい青年だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "なんか、とてもガラの悪い女の人と一緒でね。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本館の大浴場へ、清も共に入る、ガラの悪い客が大声を出すので出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
