        "examples": {
          "standard": [
            {
              "text": "うちの祖父は江戸っ子気質のがらっぱちで、口は悪いが人情に厚い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「てやんでえ、そんなこと知るか！」と、彼は絵に描いたようながらっぱちな口調で言い返した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "一見するとただのがらっぱちだが、実は繊細で寂しがり屋な一面も持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "「猪之が嫁に欲しいというのは、同じ田所町にある居酒屋の娘でした」と藤吉は話し続けた、「年は十七だったでしょう、お孝という名で、顔も躯もまるまると肥えた、おそろしくがらっぱちな女でした」　藤吉は冗談はよせと云った。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "三度目の正直",
                "note": "青空文庫"
              }
            }
          ]
