        "examples": {
          "standard": [
            {
              "text": "図書館には、高校生向けの学習用参考書がたくさん揃っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このアプリは、隙間時間にできる学習用コンテンツが充実していて便利だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "受験生のために、過去問をまとめた学習用資料を作成した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このタブレット、子供の学習用に最適だよ。色々な教材を入れられるから。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "マイクロコンピューターの学習用ではなく、コンピューターとして使いたがっている人間が急増しているということか――。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤田は『精要算法』の作者にして、この書は学習用に極めて重きを成して、これがために藤田は大いに名望を博したのであるが、しかもその門下からは有力な数学者は出なかった。",
              "citation": {
                "source": "和算の社会的・芸術的特性について",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
