        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "不日拝謁万々賀儀可申陳候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝ハ吾ガ為メニ勤労シ吾レハ汝ニ頼テ衣食スルコト、茲ニ満三年ニシテ、本社改称節ノ賀儀ヲ挙グルモ既ニ四回ニ及ブ。",
              "citation": {
                "source": "祭活字子文",
                "author": "成島柳北",
                "note": "青空文庫"
              }
            },
            {
              "text": "時として椿山莊園遊會を見ることあるも、是れ大切なる外國の貴賓に敬意を表する場合か否らずむば一家の賀儀を機會として少數の親近者を招待する場合に行はるゝのみ。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "時として椿山荘園遊会を見ることあるも、是れ大切なる外国の貴賓に敬意を表する場合か否らずむば一家の賀儀を機会として少数の親近者を招待する場合に行はるゝのみ。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "車内が上下二段に仕切られたその上下に、生きてゐる肥つた白い豚がぎつしり詰まつてゐる。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの娘は、あまり偉くなりすぎたよ」　口惜しさと悔いがぎざぎざと胸を噛んだ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "格別の新しがらなくとも新らしい智識の洗礼を受けたのちの彼女｜等の素直さと女らしい愛らしさと皓潔な放胆がぎすぎすした理窟や気障な特別な新らしがりより新らしいのでしょう。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思ふうちに、魚の白い腹がぎらつと光つて一ぺんひるがへり、上の方へのぼつたやうでしたが、それつきりもう青いものも魚のかたちも見えず光の黄金の網はゆらゆらゆれ、泡はつぶつぶ流れました。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その時向ふ岸ちかくの少し下流の方で見えない天の川の水がぎらっと光って柱のやうに高くはねあがりどぉと烈しい音がしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "マストの上には銀河がぎらぎらと凄いように冴えて、立体的な光の帯が船をはすかいに流れている。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その世界では現在あるような活字で印刷した書物の代りに映画のフィルムのようなものが出来ていて、書庫の棚にはその巻物がぎっしり詰っている。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "みれば、ですくの上に突つ伏した大人の額を、いつのまにか蛇がぎりぎりとまきつけてゐた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだか体がぎごちなくなつたやうだ。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然さっき自分の這入って来た戸がぎいと鳴ったので、フィンクは溜息を衝いた。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてどこかで長椅子がぎいぎいいう。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、手術室にゐるお前の事がぎくりと思ひ出されたのだ。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がぎよツとして振り返る隙もなかつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小屋といふのも南の方は明けっぱなしで壁もなく窓もなくたゞ二尺ばかりの腰板がぎしぎし張ってあるばかりだった。",
              "citation": {
                "source": "花椰菜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その時向う岸ちかくの少し下流の方で見えない天の川の水がぎらっと光って柱のように高くはねあがりどぉと烈しい音がしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲妻がぎらぎらっと光ったと思うともういつかさっきの泉のそばに立って居りました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先方の買直がぎりぎりの処なら買戻すとする。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、左の下あごの犬歯の根だけ残っていたのが容易に抜けないので、がんじょうな器械を押し当ててぐいぐいねじられたときは顎骨がぎしぎし鳴って今にも割れるかと思うようで気持ちが悪かった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど兵隊のかたちが見えないねえ」　その時｜向こう岸ちかくの少し下流の方で、見えない天の川の水がぎらっと光って、柱のように高くはねあがり、どおとはげしい音がしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お日さんは　　はんの木の向さ、降りでても　　すすぎ、ぎんがぎが　　まぶしまんぶし。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぎんがぎがの　　すすぎの中さ立ぢあがる　　はんの木のすねの　　長んがい、かげぼうし。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぎんがぎがの　　すすぎの底の日暮れかだ　　苔の野はらを　　蟻こも行がず。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぎんがぎがの　　すすぎの底でそっこりと　　咲ぐうめばぢの　　愛どしおえどし。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「天気がよくて雪がぎらぎらしてました。",
              "citation": {
                "source": "化物丁場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その時向う岸ちかく、少し下流の方で、見えない天の川の水がぎらつと光つて、柱のやうに高くはねあがり、どおと烈しい音がしました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから谷の深い処には細かなうすぐろい灌木がぎっしり生えて光を通すことさえも慳貪そうに見えました。",
              "citation": {
                "source": "マグノリアの木",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
