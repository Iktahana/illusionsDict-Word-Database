[
  {
    "uuid": "0b8c057d-d853-5319-890d-cc466ea16556",
    "entry": "学芸",
    "reading": {
      "primary": "がくげい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "arts and sciences",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "とまれ、フォルムに就いての理念が生ぜざる限り、アマチュアであり、またアマチュアとしてさへが、文学芸術に興じたのではなく、知ることの喜びを文学に於ても得てゐるといふに過ぎないことを分らねばならない。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり文学芸術といふ観念が自己の胸底に十分に確立しなければならぬ。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして此所に詩といふのは、魂の渇きに水をあたへ、生活の枯燥を救つてくれる文学芸術を言ふのである。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　学芸の純粋な進展に対して社会的の拘束が与える障害について不満の意を洩らすのを聞かされた事も一度や二度ではなかったように記憶する。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、学芸にたずさわる団体は時々何かしらかなり根本的な革新を企てて風通しをよくし、黴の生えないようにする必要があるという至極平凡なことを、やや強く表現しようとしただけのことである。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人を生んだ自然とその中における生活とがあってしかる後に生まれ出た哲学宗教思想や文学芸術に関する詳細な深奥な考察については、私などよりは別にその人に乏しくないであろうと思われる。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二「今日本にあらゆる種類の全く無用な団体を作ろうとする熱、一種の狂熱がある……文学芸術の研究は決してかかる協会に伴なうものではない。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学芸術の研究は個人の努力と、それから独創的思索にたよるものだ。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二　日本人のした学芸上の仕事で、相当に立派なものがあっても、日本人の間では、その価値は容易に認められない。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正六年十一月、東洋学芸雑誌）",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は学芸新聞を創刊してインチキ病院や、インチキ興行をイジメてやるかな……それとも全然｜河岸を換えて最新式の安アパートでも初めながら、原稿生活を続けてやろうかナ……なぞと……。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一般平均から見ても、また個別的に見ても、学芸にかけての日本人の頭が少しでも欧米文化国民のそれに劣らないものだと信じて疑わないものである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今までのところでまだ学芸方面において世界第一人者として、少なくとも公認されたものの数のはなはだしく希少なことについては、これにはまたいろいろの「事情」があるようである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『お前は明後日の学芸会で、何を云ったらいいか考えているだろう。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっとあの生徒は学芸会でそれを云ったんだ。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先頃学芸会があったのでしたが、その時ちゃんと、狐に遭ったことから何から、みんな話していたのです。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「学芸会へ出ているようなものよ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "学芸会はみんな鼻の上に汗をためてるわ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "学芸部の委員なのかも知れません。",
              "citation": {
                "source": "みみずく通信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に成績がよくて学芸会に出ることを約束されてゐる児童達がさうだつた。",
              "citation": {
                "source": "登つていつた少年",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は誰と誰を学芸会に出すかを定めるためそんなことをしたのに違ひない。",
              "citation": {
                "source": "登つていつた少年",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「学芸会には何をしようか」と先生は嬉しさに輝き始めた少年と少女達の顔を見下してくすぐつたさうに言つた。",
              "citation": {
                "source": "登つていつた少年",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の前には白衣のツルが立つてゐたが、そこは観客の一ぱいゐる学芸会場であつた。",
              "citation": {
                "source": "登つていつた少年",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "むす子の画業は着々進んでいるらしく、ラントランシジャンとかそう云った手堅い巴里新聞の学芸欄に、世界尖鋭画壇の有望画家の十指の一人にむす子の名前が報じられて来るようになって来た。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "学芸会みたいな稚拙なところもある。",
              "citation": {
                "source": "芸術ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎左衛門のねえさんは、女学校でする学芸会の練習をしていたのである。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからしばらく、久助君は、太郎左衛門の屋敷の門の前を通るときにはきっと、ふじの花のさいている明るい昼間だというのに、ランプをつけて学芸会の劇を練習している、色の白いぶきみな少女のことを思い出したのである。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとどうしたわけか、学芸会のけいこをしていた太郎左衛門のねえさんを思い出した。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで何か随筆を書くよう学芸のものに頼んだところ大乗気で却って向うから是非書かしてくれということだ。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵野新聞社、学芸部、長沢伝六。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
