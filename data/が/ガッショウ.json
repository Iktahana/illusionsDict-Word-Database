[
  {
    "uuid": "f34164f5-b4b9-5f17-8249-2d8230be490f",
    "entry": "合唱",
    "reading": {
      "primary": "がっしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "singing together",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供たちの元気な合唱が、チャリティコンサートの幕を開けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この曲、みんなで合唱したら、きっと感動するよ。」と友人が提案した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "卒業式では、卒業生全員による合唱が体育館に響き渡った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "合唱コンクールで、私たちのクラスは優勝を目指して練習に励んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "――私は外に聞えます、おつ母さん、空の合唱隊が！",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして酒に酔つた時は、いつも大衆と一所にそれを合唱したくなるのである。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽といふものは、本来皆その精神に「合唱性」を持つてるものだ。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺の堂内には年取った婦人が大勢集まって合唱をしていた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは何の歌だか分らないが、二部の合唱で、靜かな穩かな清らかな感じのするものであつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "よほどの人数で合唱してゐるらしいのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たましひが耳をすますと、陰気くさい声をして、黄いろい娘たちが合唱してゐる、合唱してゐる、波止場のくらい石垣で。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "サルーンでは数人の英国人が別れの唄を合唱している。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞踊場で未来の墓誌銘に現代の道徳を刻んだ同志と、レムブルグ美容院の舞踊場の楽隊の奏でる哀悼歌に合唱して、米良は柩車のように螺旋をえがいて踊りながら、彼は絶えず東支那海の電信夫がもたらす秘密結社の女シイ・ファン・ユウの恋の便りを受取った。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれらの勇士を弔う唱歌の女学校生徒の合唱などがいっそう若い頭を感傷的にしたものである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはまずいいとしても、明治十年ごろに姉が東京の桜井学校で教わった英語の唱歌と称するものを合唱したりしたのは実に妙であった。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その包囲の真中から何かしら合唱の声が聞こえる。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを通り抜けて停車場の方へと裏町を歩いていると家々からラジオが聞こえ、それが今聞いた市役所の庭の合唱そのままである。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝夕に讃美歌の合唱が聞こえて、それがこうした山間の静寂な天地で聞くと一層美しく清らかなものに聞こえた。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "よほどの人数で合唱しているらしいのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからこれがこの地球に響いた最初の生の合唱だと思うといくらか壮烈な気がしないでもない。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼もやはりその合唱の波のなかに漂いながら、ある間をおいては彼の喉を震わせていたのである。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると彼はまた突然に合唱のリズムを紊しはじめた。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画はそれほどおもしろいとは思わなかったが、その中でトロイカの御者の歌う民謡と、営舎の中の群集の男声合唱とを実に美しいと思った。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハイデルベルヒの学生歌」（俗名、若きハイデルベルヒ）でも窓下の学生のセレネードは別として、露台のビア・ガルテンでおおぜいの大学生の合唱があって、おなじみのエルゴ・ヴィヴァームスの歌とザラマンダ・ライベンの騒音がラインの谷を越えて向こうの丘にこだまする。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシアでもドイツでも、男どうしがおおぜい寄り集まったときに心ゆくばかりに合唱することのできるような歌らしい歌をたくさんにもっているということは実にうらやましいことである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし上記のトーキーに出て来る二つの合唱だけに比べても実になんという貧しさであろう。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　やがてビイルが届き、様々の料理も来て、私達は何だか意味のわからない歌を合唱したように覚えて居ます。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よほどの人數で合唱してゐるらしいのでした。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはなんの歌だかわからないが、二部の合唱で、静かな穏やかな清らかな感じのするものであった。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともピアノなどにはしばしば相当長い独奏曲があるにはあるが、これはしかし、見方によれば常にあまたの同時に響く音の並行であって、肉声ならばちょうど四部合唱のようなものを一つの器械を借りて一人の手で奏しているようなものである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「スピード・アップ・ホー」の合唱のごときはなはだばかげていてノンセンスではあるが、そのノンセンスの中にはおのずからノンセンスの律動的な呼吸があるから、ともかくもあまり人を退屈させない。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず初めに「ありゃビルだ」の大がっしょう、それからひとりウサギの声、「受け止めるでおじゃる、生けがきのそばぞ！",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず初めに聞こえたのが「ありゃビルだ」の大がっしょう、それからひとりウサギの声――「受け止めるでおじゃる、生けがきのそばぞ！",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "ensemble singing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
