        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　支那人の大褂児の下では、剣ががちりと鳴った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "※たけた祖母の白い顔の、額の両端から小さい波がちりちりと起り、顔一めんにその皮膚の波がひろがり、みるみる祖母の顔を皺だらけにしてしまった。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうえ、からだじゅうに、ダイヤモンドや、ルビーや、サファイヤがちりばめてありました。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには、見るもかわいらしい、小さな緑のハエがちりばめてあって、宝石のようにキラキラしていました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨のために響きの悪い玄関のベルがちりと鳴って止むと、受信箱の中に手紙が落された音がした。",
              "citation": {
                "source": "快走",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Toron …… tonton …… Toron …… tonton ……色とにほひがちりかかる。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、みんながちりぢりに逃げまわるのを追っかけて、そこいらじゅうの坂の下や川の中へ、切り倒し突き落として、とうとう一人ももらさず亡ぼしておしまいになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "与茂七は主家が断絶して家中の者がちりぢりになった時、それに交って姿をかくしているところであった。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬で、手足がちりちり痛み、水洟をすすりあげてゐると、いやな熱が赤く来て、私はもうぐつたりとして、駒を投げ出す、――そんなある日、私はその観戦記を読んだのである。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、火切石にかねをぶつけたので、ぱっと火花がちりました。",
              "citation": {
                "source": "ひこうかばん",
                "author": "DEN FLYVENDE KOFFERT",
                "note": "青空文庫"
              }
            },
            {
              "text": "その足音に早くも気のついた七兵衛は、小膝をついて危く身をかわしたので、槍の穂先はがちりと土を縫った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "槍突き",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍬の先にがちりと中った。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "牡丹ほんにの、薄情な牡丹がちりかかる。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがちりちりと迫った。",
              "citation": {
                "source": "青空の梯子",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "お客人は気も魂も身に添わずというわけで、ころげ廻って逃げるうちに、力が尽きて地にたおれると、鬼はここぞと飛びかかって来るとき、たちまち柱に突き当って、がちりという音がしたかと思うと、それぎりでひっそりと鎮まってしまいました。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "夷堅志",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、間もなく、姉が帰って来て、家の者らがちりちりに生活しなくてもいいようになると思われた。",
              "citation": {
                "source": "火",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは人の歯にがちりとさわる。",
              "citation": {
                "source": "演技指導論草案",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さしみもうまいがちりもうまい、あつさりして、そしてコクがある。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "白秋のロマンティシズムに、九州柳川の日が照って、桐の花がちりかかっていたように、その頃の、きれいな本をつくりたい心、そういうきれいな本をもってみたい心は、日本の出版企業の、かつて初々しかった昔の物語である。",
              "citation": {
                "source": "豪華版",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処に　日が照り　香気がちり朽ちても　大地に種を落す命の　ひきつぎて　となり得るのだ。",
              "citation": {
                "source": "五月の空",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八つ時分三味線屋からことを出し火の手がちりてとんだ大火事」と云う落首があった。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "小倉の雪の夜に、戸の外の静かな時、その伝便の鈴の音がちりん、ちりん、ちりん、ちりんと急調に聞えるのである。",
              "citation": {
                "source": "独身",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "81尊い命の芽を摘みとられる日、身体の各部がちりぢりに分れる日、その土でもし壺を焼いたら、さっそく酒をついでよ、息を吹きかえすに。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　がちりと頭の中で石が音を立てたように久慈の表情は無くなった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――昔は、肉親たちがちりぢりに遠く散っていて孤独であったせいか、燃えあがるような気持ちだったけれども、いまは私の家にみんな集って来ているので、時々辛いなと思う時がある。",
              "citation": {
                "source": "生活",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに、盗人たちがちりぢりに、死人を残して引き揚げた小路は、月に照らされて、さながら霜を置いたようにうす白い。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その桜には朱がちりばめてあり、私の見た入墨の中で殊に美しいものの一つであり、その味は末期の浮世絵であり、ガラス絵の味さえあった。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時あの亀の目玉にはダイヤモンドがちりばめてあるのだという風評が立った。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
