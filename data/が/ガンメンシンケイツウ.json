        "examples": {
          "standard": [
            {
              "text": "昨夜から右の顔面神経痛がひどくて、まともに眠れませんでした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "顔面神経痛は、冷たい風に当たると悪化することがあるそうです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "治療のおかげで、顔面神経痛の症状が少しずつ和らいできました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの俳優さん、顔面神経痛を患っているとは思えないくらい演技が自然だよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "僕どうしたのか、顔面神経痛にかかったらしい。",
              "citation": {
                "source": "旅からのはがき",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどい顔面神経痛で、時々、ギクシャクと頬を痙攣らせる。",
              "citation": {
                "source": "犂氏の友情",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかり憔悴して、顔面神経痛ででもあるように、絶えず眼と口を引きつらしている。",
              "citation": {
                "source": "和製椿姫",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            }
          ]
        }
