        "examples": {
          "standard": [
            {
              "text": "この教材は、初心者学習者でも理解しやすいように作られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "インターネットの普及により、学習者は自宅で多様な情報にアクセスできるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "個々の学習者のレベルに合わせた指導が求められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "経験豊富な講師が、学習者の疑問に丁寧に答えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "このような時代においてもしある科学の全般にわたって間口も広く奥行も深く該博深遠な知識をもった学者があって、それが学習者を指導し各部分の専門的研究者や応用家の相談相手になって行くとすれば実にこの上もない事である。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし死体の解剖は学習者にとって必要である。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
