        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "政治の世界では、ガラス張りとも言える透明性が求められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "経営陣は、社員に対して会社の状況をガラス張りで説明する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "インターネットの普及で、個人の情報がガラス張りになりつつある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このプロジェクトでは、進捗状況を常にチーム全体にガラス張りで共有している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
