        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「なあ、聞いたか？今朝、汚職疑惑の議員事務所にガサが入ったらしいぜ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「やばい、もうすぐガサが来るかもしれん！証拠の品は全部処分しろ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "警察は、大規模な詐欺グループの拠点を突き止め、関係各所への一斉ガサに踏み切った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "僕のやうなガサツな田舍者には、洒落なんか解らないと思つたのだらう。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥えて居た方はことに衰へて、あのはち切れさうだつた血色のいゝ皮膚が、今はもうタブタブして居て、ガサガサした感じさへ与へて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩の上には、浦島ツツジ、ツガサクラ、コケモモなどが、平ッたくしがみついている、私は岩角に身を倚せて、眼下遥かに低い谷底を見た、雲と霧と入り乱れて、フツ、フツと山上目がけて来る、その裂け目から谷を隔てて赤石山脈の大嶺、その間に、また谷を隔てて早川の連嶺が、幾析となく重なって、不安な光輝を放っている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "天井がガサガサガサガサ云います。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一軒ではエラリイ・クイインの「エヂプト十字架の祕密」と「ロオマ劇場事件」と「支那オレンヂの祕密」の邦譯三册を、一軒ではアガサ・クリスチイの「ハゼルムウアの殺人事件」とカアメン・エデイングトンの「撮影所殺人事件」の二原書を買ひ求めた。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、ヨシナガサン！",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鈴薯は大抵倒れたりガサガサに枯れたりしてゐた。",
              "citation": {
                "source": "花椰菜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の物干しの暗い隅でガサガサという音が聞こえる。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿蘭陀の通事たちに、シロオテの日本へ渡って来たわけを調べさせたけれど、シロオテの言葉が日本語のようではありながら発音やアクセントの違うせいか、エド、ナンガサキ、キリシタン、などの言葉しか聞きわけることができなかったのである。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとカン蛙の載った木の葉がガサリと鳴り、カン蛙はふらふらっと一寸ばかりめり込みました。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天井がガサガサガサガサ云ひます。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空へ行った声はまもなくそっちからはねかへってガサリと樺の木の処にも落ちて行きました。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなガサガサガサガサさがしましたが、どうしてもそんなものはありません。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなはガサガサガサガサやりますけれどもどうもなかなか見つかりません。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっかさんの手はそんなにガサガサしているのでしょう。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
