        "examples": {
          "standard": [
            {
              "text": "手首にできたガングリオンは、見た目は気になったが、特に痛みはなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "指の付け根に小さなガングリオンができて、ペンを握るときに少し違和感がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "整形外科で診察を受けたら、関節の近くにできる良性の腫瘤、つまりガングリオンだと診断された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ガングリオンが神経を圧迫して痛む場合は、手術で除去することも検討される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
