    "definitions": [
      {
        "index": 1,
        "gloss": "painter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところで音楽批評家はといふと、「どうだ、夜の絵は――さう日光の御厄介ばかりならんで」なぞと画家に云ふ画家の叔父さんみたいな思ひ付きを並べるか、（まあその叔父さんなんざあ甥に親愛を感じて云つたのだからまあまんざら空無ではないがね。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "The Yellow Book の故智にならい、ビアズレイに匹敵する天才画家を見つけ、これにどんどん挿画をかかせる。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前は私も、たいへん画が好きで、画家の友人もたくさんあって、その画家たちの作品を、片端からけなして得意顔をしていた事もあったのですが、昨年の秋に、ひとりでこっそり画をかいてみて、その下手さにわれながら呆れてそれ以来は、画の話は一言もしない事にきめました。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の断じて立言し得ることは、蕪村が単なる写生主義者や、単なる技巧的スケッチ画家でないということである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "純粋に写生的の絵画句であって、ポエジイとしての余韻や含蓄には欠けてるけれども、自然に対して鋭い観照の目を持っていた蕪村、画家としての蕪村の本領が、こうした俳句において表現されてる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在のようなジャーナリズム全盛時代ではおそらく大多数のこうした種類の挿画や裏絵は執筆画家の日常の職業意識の下に制作されたものであろうと思うが、あの頃の『ホトトギス』の上記の画家のものはいかにも自分で楽しみながら描いたものだろうという気のするものばかりである。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不折ほど熱心な画家はない。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう今日の洋画家中唯一の浅井｜忠氏を除けばいずれも根性の卑劣な※の声を打消していった。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前田君は、画家として中村彝君を勧めてくれた。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大宮口の時は、友人画家茨木猪之吉君と、長男隼太郎を伴った。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "『近世画家論』第四巻で、山岳を讃美したジョン・ラスキン先生は、一方において、セント・ジョルジ・ギルドの創立者であるが、すべての工業はその動力を風と水とに借るべきであると力説せられた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「むすこは巴里の花形画家で、おやじゃ野原のへぼ絵描き……」　こんな鼻唄をうたいながら、お父様はこの頃、何を思ったかおまえの美術学校時代の壊れた絵の具箱を肩に担いでときどき晴れた野原へ写生に出かける。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "画家のいわゆるデッサンが正しいとか正しくないとかというものも、やはりこういう意味で心理的に真実な描写をするという意味らしく思われる。",
              "citation": {
                "source": "観点と距離",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "漫画家自身でもおそらく人によってこれに関する所見を異にするに相違ない。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "優れた観察力をもった漫画家が街路や電車の中で十人十色の世相を見る時には、複雑な箇体が分析されて、その中のある型の普遍的要素が自ずから見出される。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一方において漫画家の抽象は必ずしも直感のみによるとは考えられない。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して漫画家の対象は人間に関係したものであるために、このような分離が困難になり、表現は十人十種になって作者の個性の香が高くなるのは止むを得ない。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしあらゆる可能な漫画家を一団として見る時には、各画家を微分とした無限項の和としての積分は渾然たる一つの定まった極限値を有する「真の」一面と考えるに不都合があるだろうか。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "漫画家の言語たる線や点や色はこれに反して多次的な無限の「連続」を形成するものである。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで漫画家は言語では到底表わす事の出来ない観念の表現をするための利器を持っている。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その利器の使い方の巧拙はその画家の技能を評価する目標の一つになるが、それよりも重大な標準は、それによって表わすべきものの、真の種類や程度にある事は勿論である。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろあまりに悪達者な漫画家の技巧がその内容と反比例を示す場合も少なくないように見える。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに素人画家のスケッチのようなものだと思って読んでもらいたいのである。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年来急に世界的に有名になってから新聞雑誌記者は勿論、画家彫刻家までが彼の門に押しよせて、肖像を描かせろ胸像を作らしてくれとせがむ。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡田には梅がなかろうか……此草花は面白い　殊につくしがふるっている　なかなか趣向もある　日本画家などにはこれほどの趣向あるものもないなどと笑われた。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケルヴィンやキチナー将軍や画家のワッツなども顔を並べていた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処へやつて来た此の鉄色がかつた栗色の肌の牧野信一は、部屋に這入るなり進みもしないで坐つた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "みよ兄は手に水桃をささげもち、いつさんにきみがかたへにしたひよる、この東京の日くれどき、兄の戀魚は青らみてゆきて、日毎にいたみしたたり、いまいきもたえだえ、あい子よ、ふたり哀しき日のしたに、ひとしれず草木の種を研ぐとても、さびしきはげに我等の素脚ならずや。",
              "citation": {
                "source": "幼き妹に",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔このみちの醸すがごとく〕宮沢賢治このみちの醸すがごとく粟葉などひかりいでしはひがしなる山彙の上に黄なる月いざよへるなり夏の草山とになひてやうやくに人ら帰るをなにをかもわがかなしまんすゝきの葉露をおとせり",
              "citation": {
                "source": "〔このみちの醸すがごとく〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋し黄金万能主義的傾向に属することなのだらうが、Ｂの方では、Ａより貧しい条件の下に働いてゐるのに、Ａの方では、いつ知らず「俺の方が元金がかゝつてゐるのに……」といふ不平を抱いてゐるのである。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
