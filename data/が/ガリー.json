        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "雨季になると、この乾燥地帯には一時的に水が流れるガリーがいくつもできる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "トレッキング中、私たちは深いガリーを迂回しなければならなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あそこにできたガリー、まるで巨大な傷跡みたいだね」と、景観を眺めながら言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ハンガリーの夏は 〔nya'r〕（ニヤール）。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、ビルマや、タミール、シンガリースなどから、漸次西に向かって、ペルシア、アラビア、トルコ、エジプトへんをあさってみると、やはりいくらかの関係らしいものが認められると思った。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンガリーやセルボクロアチアンからフィンランドまで行ってみても同様である。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者はハンガリー人で、日本の留学生のことを仕組んだものだそうです。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばリュート類似の弦楽器として概括さるべきものに、トルコのコプズ、ルーマニアのコブサ、またコブズ、ロシヤ、ハンガリーへんのコボズなどがある。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろ見かけた珍しいものの一つとしてはサンスクリットで孔雀という意味の言葉を入り口の頭上の色ガラス窓にデワナガリー文字で現わしたのさえあった。",
              "citation": {
                "source": "カメラをさげて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻末の解説を読むと、これは、ドイツ、オーストリア、ハンガリーの巻であることがわかります。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸のあいた上着に、コールタールの染みだらけの袖、赤と黒の市松模様のシャツ、ダンガリーのズボン、ひどくすり切れた重いブーツといった格好だった。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンガリーの吸血鬼信仰。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリオストが記したヒポグリッフ、ハンガリーのタトス、古ドイツとスカンジナヴィアのファルケいずれも翼ありて空中を行く馬だ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてセイロンのシンガリース人は林中で猴が死んでも屍を見せぬといい、その諺に「白い鳥と稲鳥（パッジー・バード、鷺の一種）と直な椰樹と死んだ猴、それを見た人は死なぬはず」という。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三にセイロン特産のシンガリース藪鶏、また家鶏に似るが、胸赤く、冠黄で、縁赤く、頬と頷の垂嚢が紫赤し。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンガリー人も黒犬に斑犬を魔形とし、白犬は吉祥で発狂せぬと信ずる（グベルナチスの『動物譚原』二の三三頁注）。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし『ふた夜』には、同じドイツの味でも何処かオーストリア・ハンガリーの味や匂ひが残つてゐる。",
              "citation": {
                "source": "ペチヨリンとゲザ",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "バルザックがヴェニスやハンガリー、ポーランドやロシアなどで熱烈に愛読され、社交界の貴婦人、紳士がバルザックの作品に現れた人物の名を名乗ってその役割りに扮そうという言いあわせをして或るシーズンはランジェー公夫人だのラスティニャクが社交界に現れたということにふれ、サント・ブウヴは書き添えている。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のいたニューヨークに、昔オランダ人が上陸した当時から開かれたガリーンウィッチ・ビレージと云う街があります。",
              "citation": {
                "source": "アメリカ文士気質",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "次女モニカはハンガリーの美術史家の妻。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツ、オーストリー、ハンガリーなどの専制君主制は崩壊した。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンガリーのプロレタリア詩人カニャート。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツ語、ハンガリー語、英語、ロシア語。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツへ、チェッコ・スロヴァキアへ、イギリスへ、ハンガリーへ、日本へ！",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここには、壁新聞やピアノや、この前ハンガリーの共産青年同盟員が訪ねて来たときみんなでとったという写真や、シュロの植木鉢などが飾ってある。",
              "citation": {
                "source": "従妹への手紙",
                "author": "――「子供の家」の物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルガリータ・アリゲール。",
              "citation": {
                "source": "新世界の富",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その物語りを書いたマルガリータも亦、新しいソヴェトの娘である。",
              "citation": {
                "source": "新世界の富",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンガリー生まれのユダヤ人数学者で、ヒットラーのドイツを逃れてプリンストン大学に移っていたジョン・フォン・ノイマンは、マンハッタン計画に貢献するとともに、コンピューターの基本原理の確立においても決定的な役割を演じた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄色髪の方は、濃紺のハンガリー服を著ており、髪の黒い方は、あたりまえの縞の韃靼外套を羽織っていた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャンパンに次いでハンガリー酒が抜かれ、それで一層景気づいた一座は更に陽気になった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれはキエフではなく、キエフからは、シュームスクより更に遠く、もはやハンガリヤに程遠からぬガリーチの市であつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はさながら五体を焼かれ焙られる思ひで、この全世界を馬の蹄にかけて踏みにじり、キエフからガリーチまでの土地を人畜もろとも掴み取つて黒海の只中に沈めてしまひ度いやうな気がした。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
