    "definitions": [
      {
        "index": 1,
        "gloss": "foreign telegram",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "郊外電車の轍の音が、暗い、遠くの森の方でしてゐた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうの後場はもっと下るかも知れないが構わずに買え……外電のキューバ島の空前の大豊作は嘘だ……」　私はこの意味がちょっと解らなかった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "予の卓子の周圍には二人の人――マスター・オヴ・アーツの學位を有する外電係と新しく社會部に入つた若い、肥つた法學士――とが集つてゐた。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、卓子の端に腰かけて片足をぶらぶらさしてゐた外電係兼國際論文記者が口を開くべき機會を得た。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこはまた学園行の郊外電車にも近くありましたから。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "順作と女は柵のない郊外電車の踏切を越えて、人家と畑地の入り交った路を歩いて往った。",
              "citation": {
                "source": "藍瓶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は友人のウィルスン・ハーグリーヴへ外電を打ちました。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪朝日の待遇には余り平らかでなかったが、東京の編輯局には毎日あるいは隔日に出掛けて、海外電報や戦地の通信を瞬時も早く読むのを楽みとしていた。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "一面に狐色の枯草が蓬々と蔓つてゐるばかりの田甫に出ると見渡す限り一点の動くものゝ影だに認められなかつたが、やがて行手の眼界を水平に横切つて宙を飛ぶやうな郊外電車が現れると、あちこちから無数の鴉の群が竜巻の木の葉のやうに舞ひあがつた。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、だんだんと外電が入ってくるにおよんで、それはいっさい、望み得ないことが分ってきた。",
              "citation": {
                "source": "第五氷河期",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "うかうかしていると、もう郊外電車が動き出す時刻になる。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車不通10・21（夕）　郊外生活も可いが、今年のやうに洪水が出て、郊外電車が幾度となく不通となる様では実際郊外生活も厭になる。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "王栄老は郊外電車の不通に出会つた銀行員のやうに、荷物を横抱きにぶつぶつ呟きながら、河つ縁の宿屋に入つた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "造士新聞は今は大阪のある郊外電鉄の専務取締、その当時は弁護士の紀志嘉実氏が、貧しい青年学生を収容するために設けた造士寮の機関新聞でしたが、平尾氏は編輯するやうになつてからは、際だつて文藝の色が鮮やかに見られるやうになりました。",
              "citation": {
                "source": "恋妻であり敵であつた",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "訳者は一九一〇年夏ストックホルムに行ったついでをもって同市郊外電車のエキスペリメンタル・フェルデット停留場に近いノーベル研究所にこの非凡な学者を訪ねた。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂しい田舎道や、上り下りの臆劫な郊外電車や、森や田圃は彼女の性に合はなかつた。",
              "citation": {
                "source": "余震の一夜",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "北窓から眺めると欅の大木が一群れ秋空に色づきかかっていて、おりおり郊外電車の音がそっちの方から聞えてくる。",
              "citation": {
                "source": "新しい婦人の職場と任務",
                "author": "――明日の婦人へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月十二日の連合通信は、ロンドン十日発外電で、地獄の言葉をつたえている。",
              "citation": {
                "source": "平和の願いは厳粛である",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「｜太陽の岸」と呼ばれる海岸線ゆき郊外電車発着所の近くに、入江を抱くように手を拡げてる広場の一方が、ゆるい石段になってひたひたと水に接していた。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "××町の入口を貫いて、或る郊外電車が古くから通じていた。",
              "citation": {
                "source": "牡丹",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "模糊とした雑踏の中を、はる子は郊外電車の発着所に向いて歩いていた。",
              "citation": {
                "source": "沈丁花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち話をしている黒外套の従業員の前や後を、郊外電車から吐き出された人々が通る。",
              "citation": {
                "source": "沈丁花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵から降り出し、なほ子が十一時過て郊外電車に乗った頃、本降りになった。",
              "citation": {
                "source": "白い蚊帳",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それから時々、市外電話がかかって来ると、長兄は忙しげに出掛けて行く。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "市外電話で順一を呼出そうとすると、どうしたものか、その夜は一向、電話が通じない。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それから時々、市外電話がかかつて来ると、長兄は忙しげに出掛けて行く。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "市外電話で順一を呼出さうとすると、どうしたものか、その夜は一向、電話が通じない。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は自分の雜誌の用事を早目に片付けて午さがりの郊外電車にゆられて毎日通つた。",
              "citation": {
                "source": "足相撲",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "富山駅から堀川新へ行く郊外電車の中や南富山から千垣に行く県営電車の中で見る立山連峰はいつもながら雄大な眺めだ。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "客の込み合大きな郊外電車から、痩せ衰へたやうな小さな電車に乘り換へると、相客は多く草鞋穿きの道者連であつた。",
              "citation": {
                "source": "ごりがん",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
