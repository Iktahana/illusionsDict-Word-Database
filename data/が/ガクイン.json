[
  {
    "uuid": "64c4bc5d-d7e4-5ac2-9a6e-4c8b141fccc8",
    "entry": "学院",
    "reading": {
      "primary": "がくいん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
