          "standard": [],
          "literary": [
            {
              "text": "小学校では、毎年創立記念日に学童の作品展覧会が催される。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓五つなる学校に、　　　さびしく学童らをわがまてば、藻を装へる馬ひきて、　　ひとびと木炭を積み出づる。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しやうふを塗れるガラス戸を、　　学童らこもごもにのぞきたり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに比べて、求める心のないうちから嘴を引き明けて英語、ドイツ語と咽喉仏を押し倒すように詰め込まれる今の学童は実にしあわせなものであり、また考えようではみじめなものでもある。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "必ず比較をされなけれはならないいまの学童たちの内奥からの反響です。",
              "citation": {
                "source": "『注文の多い料理店』広告文",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "必ず比較をされなければならないいまの学童たちの内奥からの反響です。",
              "citation": {
                "source": "『注文の多い料理店』新刊案内",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他　　学童数名。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "」などという声と共に、上手のドアをあけ、国民学校教師、野中弥一が、ひとりの泣きじゃくっている学童を引きずり、登場。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "（野中自身の腰にさげてあるタオルを、学童に手渡す）（学童）（素直にタオルで涙を拭く）（野中）（そのタオルを学童から取って、また自分の腰にさげ）よし、さあ歌ってごらん。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "（言いながら、最前列の学童用の椅子に腰をおろす。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり観客に対しては、うしろ向きになる）学童は、観客に対して正面を向き、気を附けの姿勢を執り、眼をつぶって、低く歌う。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "（学童）（歌い終ってうつむく）（野中）（机に頬杖をつき）ありがとう。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "（学童）（首を振る）（野中）　誰も教えてくれなくても、自然に覚えたの？",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "（学童）（だまっている）（野中）　この歌の意味が、よくわかって歌っているの？",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "（学童）（うなだれたまま、だまっている）（野中）　決して叱りやしないから、思っている事をそのまま言ってごらん。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "（学童）（だまっている）（野中）　なんとか一言でいいから、言ってくれよ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "学童、無言で野中教師にお辞儀をし、上手の出入口から退場。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊代は学童の机の上に腰をかける。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊代、封筒を持てあまして、それを、傍の学童の机の上にそっと置く。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三の学童の口笛が聞える。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時、舞台｜下手より庭先へ、学童二名｜駈け込み、「先生！",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "学童二名、息せき切って何やら奥田教師に囁く。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "（学童たちに向い）さ、行こう。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥田教師、学童二名と共に舞台｜下手に走り去る。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "学童を愛する点に於いては、学童たちの父母に及びもつかぬし、子供の遊び相手、として見ても、幼稚園の保姆にはるかに劣る。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            }
          ]
        }
