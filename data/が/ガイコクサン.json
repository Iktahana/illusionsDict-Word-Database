    "definitions": [
      {
        "index": 1,
        "gloss": "foreign (product, esp. agricultural)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
