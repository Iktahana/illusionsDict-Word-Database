[
  {
    "uuid": "0d57eb34-4204-5c9f-96b1-2033932f62fe",
    "entry": "頑健",
    "reading": {
      "primary": "がんけん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
