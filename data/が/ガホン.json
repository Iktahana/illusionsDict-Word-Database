    "definitions": [
      {
        "index": 1,
        "gloss": "picture copybook",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供の頃、この画本を見ながら絵を描く練習をよくしたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔の画本には、素朴で可愛らしい挿絵がたくさん載っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この画本、お母さんが小さい頃に使っていたものと同じだ！」と娘は喜んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "図書館で懐かしい画本を見つけたので、借りて帰った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "西洋の画家が比較的近年になって、むしろこうした絵画に絵画本来の使命があるということを発見するようになったのは、従来の客観的分析的絵画が科学的複製技術の進歩に脅かされて窮地に立った際、偶然日本の浮世絵などから活路を暗示されたためだという説もあるようである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は画本の棚の前へ行ってみた。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前にはあんなに私をひきつけた画本がどうしたことだろう。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　笹村は少年時代に、ふと暗い物置のなかの、黴くさい長持の抽斗の底から見つけたことのある古い画本のことを思い出して、母親に訊ねるともなしに言い出した。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "笹村は姉の家の二階に預けてある、その古長持のなかにある軸物や、刀のようなものを引っくら返して見た時、その画本を捜して見たが、どこにも見つからなかったので、ふと母親に確かめてみる気になった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "背の低い私にかがみ込んで画本を示した彼女の眼が、どんなに飢えた、求める、人間ばなれのした光をもって私の瞳をのぞき込んだか。",
              "citation": {
                "source": "小景",
                "author": "――ふるき市街の回想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "次は英泉、北斎、其他の漫画本。",
              "citation": {
                "source": "十歳以前に読んだ本",
                "author": "――明治四十五年六月『少年世界』の為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのふ朝倉屋より取り寄せ置きし画本を碧梧桐らと共に見る。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは画本を見て苦痛をまぎらかしたこともある。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし如何に面白い画本でも毎日々々同じ物を繰返して見たのでは十日もたたぬうちに最早陳腐になつて再び苦痛をまぎらかす種にもならない。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "（七月三日）五十三○川村文鳳の画いた画本は『文鳳画譜』といふのが三冊と、『文鳳｜麁画』といふのが一冊ある。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃画本を見るにつけてこの陳腐な配合の画をしばしば見る事であるが、それにもかかはらず美しいといふ感じが強く感ぜられていよいよ興味があるやうに覚えたので、柳に翡翠といふのを題にして戯れに俳句十首を作つて見た。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はこの「お市さん」にいろいろの画本や玩具などを貰った。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に少年や少女などに画本や玩具を与える傍ら、ひそかに彼等の魂を天国へ誘拐しようとするのは当然犯罪と呼ばれなければならぬ。",
              "citation": {
                "source": "少年",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "角谷は自分の巾着から女児に鼠の画本など買って来た。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当日から信二の家が文化祭企画本部になって、青年団の幹事連中が集合する。",
              "citation": {
                "source": "文化祭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "段々進んで行くと、これで最後かと思われる手広い部屋があって、壁に「蘊藉詩情水雪椀、高間画本水雲郷」と書いた聯が二つ懸かっている。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "長崎ものがたり",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも書籍その他自分の入用品を買うことは少くて、子供達への土産の玩具や画本、ないしお弁当のおかずになりそうなものなど、すこぶるよき父親ぶりを発揮するのである。",
              "citation": {
                "source": "放心教授",
                "author": "森於菟",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　玉山｜翁が雪の図　さきのとし玉山翁が梓行せられし軍物語の画本の中に、越後の雪中にたゝかひしといふ図あり。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "マズレールの人の一生という極めて面白い版画本があります、それから『都会』という大きい本も。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "漫画本を読ませって下さい」　五郎は理髪台に乗った。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪を刈っている間、少年は背を曲げるようにして、漫画本に見入っている。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから東宝映画本社へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "東宝映画本社へ、森氏と会ふ、伊豆山行をすゝめる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから菊田・上山と揃って、東宝映画本社へ行く、森氏と会談数刻。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一時半に出て、東宝映画本社森氏のところへ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう中でも衣と住とは、偶然に絵巻画本の隅に写生かと思うようなものが見えるが、筆つきが簡素であるために材料までは確かめることがむつかしく、ただまず形の著しく今日と異なっていることに驚くのみである。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」の声がほんの一瞬戸惑った。",
              "citation": {
                "source": "一つの約束",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし生命の不思議がほんとうに味わわれるのはその日からであろう。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "足の裏と珠との間がほんのわづか隙いてゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
