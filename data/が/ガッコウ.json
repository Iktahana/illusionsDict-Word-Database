    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fun school (usu. involving experiential learning in the outdoors)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "地域主催の「森の楽校」では、子供たちが自然の中で思い切り遊んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夏休みに参加した田んぼの楽校で、泥だらけになって稲を植えたのが忘れられない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "週末は廃校になった校舎を使った「ものづくり楽校」へボランティアに行く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供向けの楽校プログラムは、体験学習が中心で人気が高い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "また、下谷から焼け出された或四十がっこうの一婦人は、本郷の大学病院の後までにげて来ると、火の手はだんだんにそこへものびて来そうになりました。",
              "citation": {
                "source": "大震火災記",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こまってしまって、　ホテルの　しはいにんに　そうだんしてみると、　ありがたいことに　じぶんの　むすこが　かよっている　がっこうの　せんせいの　おうちを　おしえてくれまして。",
              "citation": {
                "source": "ババールとサンタのおじさん",
                "author": "BABAR ET LE PERE NOEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽけっと小ぞうは、小がっこう四ねんせいですが、ようちえんのせいとみたいにからだが小さくて、ぽけっとにでもはいりそうだというので、こんなあだながついているのです。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとうさんはたけしくんと、いもうとのしょうがっこう一ねん生のきみ子ちゃんに、よくこんなふうにいってきかせるのでした。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
