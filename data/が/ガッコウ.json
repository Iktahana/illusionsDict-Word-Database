[
  {
    "uuid": "d5c82751-779a-5fd2-bd15-2299267bdc64",
    "entry": "学校",
    "reading": {
      "primary": "がっこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
