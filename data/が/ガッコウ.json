  {
    "uuid": "096bd1e0-ad03-56c8-ad40-06973e6726e1",
    "entry": "楽校",
    "reading": {
      "primary": "がっこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
