        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昨夜の豪雨で、山間部の道路に崖崩れが発生した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ええっ、崖崩れで通行止め？迂回ルートはどこだろう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この地域は、過去にも何度か崖崩れに見舞われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "大きな崖崩れで道路のこはれたあとがもう荒まし修繕が出来てゐた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖崩れを石垣で喰ひ止める爲に、金のかゝつた工事がしてある。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな崖崩れで道路のこわれたあとがもう荒まし修繕が出来ていた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば土地山川の高低図を作る際に、道路の小凹凸、山腹の小さき崖崩れを省略するに同じ。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓地の選定をなさんとする人には山腹の崖崩れは問題となるべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "礫の多い、凸凹のところどころ崖崩れのある変な道で、洋車は歩くよりも遅くしか進まなくなった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "可恐しい崖崩れがそのままになっていて、自動車が大揺れに煽った処で。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "横浜は被害が大きく、そこらじゅうで崖崩れが起きていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大魔神が、ジョンといっしょに、崖崩れを起こしそうな声で〈レイン〉を歌う。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、義雄等の聽かされたのに據ると、三石村の村長は、崖崩れの爲めにその乘り馬車が直下數十丈の荒磯へころげ落ちかかつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中にも横須賀の海軍経理部に沿ふた路傍の崖崩れは最も甚だしき被害を与へたもので、十ばかりの人命と三台の人力車とを一時に埋め去つたとは気の毒な次第である。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の日に掃除に來た時二人は屹立つた恐ろしい斷崖を見上げて氣臆がし、近くの眞砂町の崖崩れに壓し潰された老人夫婦の無慘しい死と思ひ合はせて、心はむやみに暗くなつた。",
              "citation": {
                "source": "崖の下",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖崩れに壓死するよりも、火焔に燒かれることよりも、如何なる亂暴な運命の力の爲めの支配よりも圭一郎が新しい住處を怖じ畏れたことは、崖上の椎の木立にかこまれてＧ師の會堂の尖塔が見えることなのだ。",
              "citation": {
                "source": "崖の下",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "列車が崖崩れの下になって修学旅行の小学生が多勢死んだのもその時季であった。",
              "citation": {
                "source": "その年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "道側の原の小さな崖崩れの上を飛び越しても、原へ立つても又原へ下りて往來へ出ても三人はいつも一緒になつてしまふ。",
              "citation": {
                "source": "自分は見た",
                "author": "千家元麿",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の兒と女の兒が小聲で話して居る男の兒はおとなしく默つて傍に立つて居る一人の女の兒が崖崩れに辷つて轉がつた手をかさうとすると一人で起き上つた。",
              "citation": {
                "source": "自分は見た",
                "author": "千家元麿",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸ひに三人とも怪我もなく半時ほどして出て來たが崖崩れが續き、五寸程の地割れが出來たりして、辛うじて芍藥畑の隅の山茶花の下に戸板を持つて來て老僧夫婦と自分との三人が寄りかたまつて、搖れて來る度に山茶花の幹にしがみ附いてゐた。",
              "citation": {
                "source": "蠢く者",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖崩れがそのまゝになつてるところもあるらしいから……。",
              "citation": {
                "source": "かへらじと",
                "author": "日本移動演劇連盟のために",
                "note": "青空文庫"
              }
            },
            {
              "text": "所々に崖崩れがしていた。",
              "citation": {
                "source": "道連",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に鍬で掻落した時は、崖崩れのやうな音して烈しく棺の蓋を打つ。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三の穴は六十余年前の崖崩れの為に埋まったそうで、今はその入口を見る事が出来ぬが、やはり山腹のやや低くなった場所にあって、ここのは石垣が三段になっている。",
              "citation": {
                "source": "周防石城山神籠石探検記",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷の様子はすっかり下流と変って、荒れた河床は勾配が著しく急となり、崖崩れの為に押倒された生々しい大木が、髪を乱したように入り交って横たわっている間を、水は逆落しになってたぎり落ちて来る。",
              "citation": {
                "source": "朝香宮殿下に侍して南アルプスの旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨が降るとすぐ川水が濁るのは、森林に乏しく崖崩れが多い為で、従って大洪水の原因となることが稀でない。",
              "citation": {
                "source": "渓三題",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "細い細い道を辿ってゆくと、時として杉の林の小暗きところに出る、時として眩しいような紅葉の明るいところに出る、宿から半道も来た頃、崖崩れのために道は絶えた。",
              "citation": {
                "source": "白峰の麓",
                "author": "大下藤次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "画きたい画きたいと、一度は三脚の紐を解いたが、帰り道の崖崩れを思うと、何となく急き立てられるようで、終に筆を採らずにしまった。",
              "citation": {
                "source": "白峰の麓",
                "author": "大下藤次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また身体の条件はよくとも、途中崖崩れがあって、一旦とんでも高所に登る必要があったりして、体力と時間を予定以上に消費する場合も、同じことになる。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "白茶色の土坡で崖崩れを防ぎ、広く前庭を取り廻わした、和洋折衷の瀟洒たる二階家、まず数段の石段を登る、玄関に通ずるコンクリイトの小径、その左手は若木の植込、その右手は書斎の外側、窓が二つ（？",
              "citation": {
                "source": "小酒井不木氏スケッチ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "釜沢も一昨年の十一月下旬の大雪に夥しく木が倒れて、新に崖崩れを生じ、両門の瀑壺は三分の二も埋もれ、其上流にあったヒョングリの滝は影も形も見えなくなっていた。",
              "citation": {
                "source": "思い出す儘に",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……晩の御飯を拵える事もできないだろうと思って、御寿司を誂えて御夕飯の代りに上げました……」　草平君は平生から崖崩れを恐れて、できるだけ表へ寄って寝るとか聞いていたが、家の潰れた時には、外のものがまるで無難であったにもかかわらず、自分だけは少し顔へ怪我をしたそうである。",
              "citation": {
                "source": "思い出す事など",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は急な斜面を谷へ降り、崖崩れの場所をやつと発見した。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
