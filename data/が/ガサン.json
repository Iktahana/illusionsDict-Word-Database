    "definitions": [
      {
        "index": 1,
        "gloss": "legend over a picture",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "到頭彼は乞ひによつて「門凉み」の画讃の軸の箱に字を題してしまつた。",
              "citation": {
                "source": "歯痛",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌年の夏、銀座の天金の主人から、暑中見舞いとして式亭三馬自画讃の大色紙の複製を貰った。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌年の夏、銀座の天金の主人から、暑中見舞として式亭三馬自画讃の大色紙の複製を貰った。",
              "citation": {
                "source": "我家の園芸",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九三六・一二）（六二号、一九三七・一・一）天然色映画讃――色彩映画の問題　劇と映画を比較することは、或いは無意味であるかも知れないけれども、私はと角二つを比較して見たくなる。",
              "citation": {
                "source": "『唯研ニュース』",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚕豆とおなじ折しも花さきて蔓に実をもつ豆の味はも画讃。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "人ごとに貴き卑しき品はあれど命の種によしあしは無しさがなくも人は言ふともよしゑやし我は黙して事なくぞ経ん否も諾もわれは辞へじかにかくに人の心は人に任せめ画讃。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に永正二年に没した日澄の著だという「日蓮注画讃」（享保二十一年版）には、その貫名氏の先祖調べを行って、日蓮本姓三国氏だと云い、父は遠州刺史、すなわち遠江守貫名重実の次子重忠までは前者と同一だが、さらにその先は聖武天皇の裔で、母は清原氏だと余程古いところまで及んでいる。",
              "citation": {
                "source": "旃陀羅考",
                "author": "日蓮聖人はエタの子なりという事",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでまず藤原氏という事はしばらく措き、さらに「注画讃」の三国氏説について考えてみるに、その先祖が聖武天皇の後胤だとあることとは両立し難い感がないでもない。",
              "citation": {
                "source": "旃陀羅考",
                "author": "日蓮聖人はエタの子なりという事",
                "note": "青空文庫"
              }
            },
            {
              "text": "「注画讃」にも、その父重忠が安房州長狭郡東条郷の片海、市河村の小港浦に流されて漁叟となるとあって、その漁夫の子たることを認めているのである。",
              "citation": {
                "source": "旃陀羅考",
                "author": "日蓮聖人はエタの子なりという事",
                "note": "青空文庫"
              }
            },
            {
              "text": "画讃の書も、他の陶人に見ることの出来ない乾山独特の権威ある書として、流暢な上に磅※の一気を添え、能書乾山の実を贏ち得ていると思われる。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚しい時には、人前もなく、細香女史の下手な墨竹などへ、山陽ともある者が、麗々とお惚気の画讃を書くことすらある。",
              "citation": {
                "source": "梅※の杖",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはたしか今は、持主が転じていると思うが、その図上に題してある「迷はずばたのしみ多き世ならまし、をどる布袋はさもあらばあれ」という一首の歌は、武蔵の自画讃ではなく、保科正之の筆であるといわれている。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一｜幅の画讃の祖師像を、或る時、出入りの経師屋が持って来て見せてくれたことからだった。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一声高く竹の裂るる音して、勢いよく燃え上がりし炎は足を焦がさんとす、されど翁は足を引かざりき。",
              "citation": {
                "source": "たき火",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さがすさがさんはこっちの考えだ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "風が青ぞらを吼えて行けば　そのなごりが地面に下って　クラレの花がさんさんと光り　おれたちの袍はひるがえる。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷馬車にひつかゝつて、法衣の袖がさん／″＼にやぶれた。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は老婢がさん／″＼小言を云つたやうなきつかけで却つて老婢の心にあの少女が絡み、せめて少女の名でも口に出さねば寂しいのではあるまいかとも推察した。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはと大きに驚き呆れて、推し剥がさんと力を出せど少しも離るることなければ、人を頼みて挽却らしめしも一向さらにその甲斐なし。",
              "citation": {
                "source": "印度の古話",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのためには、この旅行で貴子がさんざんたのしんでくれることが好ましい。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――飛びだして、山を越えて、あたたかい南の国へ、お日さまがさんさんと、さんさんと照り輝く場所へ飛んでいくことができる。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたほぼ絶望的な挑戦の先頭に立つという一文を盛り込んだ憲法を掲げてこそ、我が父や祖父がさんざっぱら蹂躪してきたアジアに生きる人の前にかろうじて立ちうるとオレは感じてきた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイテック日本がさんざ囃される中で、日本のパーソナルコンピューター産業は取り残されていったのだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兼ツつあんはおすがさんげばかし贔屓しねえでおら方へも來たらよかつぺなア」　といつたのはおすがの向うに居た女である。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "雛鳥の皷動はわたしの胸にチクタクと鳴り、島の真昼は底抜けの静寂さに、明る過ぎるひかりばかりがさんさんたる雨であつた。",
              "citation": {
                "source": "城ヶ島の春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "日当りのいゝ窓に置かれたカーネーシヨンの花に、香水の霧がさんさんと降り灑いだ。",
              "citation": {
                "source": "香水の虹",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "池のまはりをグル／＼回つて、二人がさん／″＼追ひ回つたがどうしても捕まらなかつた。",
              "citation": {
                "source": "池のまはり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "高く差し延べた腕の先には月光のやうな剣がさんらんと映え渡つてゐます。",
              "citation": {
                "source": "美智子と歯痛",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るい日光の降り注いでいる庭の樹立では、朝早くから蝉がさん／＼と鳴きしきっていた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "梢を見あぐれば有吻類の鳴き声がかまびすしく蝶のヒカゲ、キマダラ、カラスの類ひがひらひらと踊りまはり、見霞すむ稲田の上に眼を放つと蜻蛉の群がさんさんたる陽りに翅を翻して游泳してゐるのだ。",
              "citation": {
                "source": "ベツコウ蜂",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
