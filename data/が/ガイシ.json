  {
    "uuid": "ddda08ff-d74e-5361-a8b4-07dd6ee6388e",
    "entry": "碍子",
    "reading": {
      "primary": "がいし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
