        "examples": {
          "standard": [
            {
              "text": "試験に合格できるよう、神頼みで願立てをした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "故郷の神社で、病気の回復を願立ててきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、願いが叶うようにと、仏像の前で静かに願立てを続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "宝くじに当たるように、こっそり願立てしておいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "五年目毎に、太神楽が廻つて来て、天蓋で、村の青年を包んで、外気に触れさせず、食物も喰べさせないで、願立てをして、踊りまはる。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、心中には、尚ひそかに、願立てたことがあったが、それは、内深くひめて表には出さないでいた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは知っての通り関白の命乞いに来たので、この際母上には、三つばかり、願立てをされたのです。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "関白の母は、もちろん、心中ひそかに、願立てたことで、人にもらした覚えもなかったから、疑うことなくご託宣をうけ入れた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
