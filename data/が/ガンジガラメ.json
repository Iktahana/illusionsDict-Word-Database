        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その後には雁字搦めに縛られた男が、大勢の刑事に守られて立っていた。",
              "citation": {
                "source": "省線電車の射撃手",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりここでは生活を雁字搦めにして、手枷、足枷、首枷をはめたうえ天床へ吊し上げたというかたちらしい。",
              "citation": {
                "source": "三悪人物語",
                "author": "忍術千一夜　第二話",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場の附近は、土塁や、拒馬や、鉄条網で、がんじがらめにかためられていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那風の扉をつけた文求堂の裏口で車を停めると、中から店の人が、がんじがらめにした行李を一つ車の中へ運んでくれた。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々をがんじがらめに縛り付けていた巨大な価値が転倒し、空白の中で自ら立たざるを得なくなった。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻もちもならぬほど、貧民を軽蔑し、無学文盲をあなどりたい為に、いろんな規則ががんじがらめに製造される。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "がんじがらめの王国。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの荷物もがんじがらめな荷造りにされて、紙で封印がしてあつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "農村の人事は人間をがんじがらめにするのであろうか。",
              "citation": {
                "source": "田園の幻",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる種類の形式に囚われて、お父さんはがんじがらめになっておられる。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「家」の現実は、女を往々にして、がんじがらめにする。",
              "citation": {
                "source": "妻の日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしたわけで一門の大砲のまわりにこんなに大勢くっついているのやら、どうしてこんなに沢山の馬が、てんでに変てこな輓具でがんじがらめにされながら、一門の砲をえっさらおっさら曳きずって、まるでその砲が実際それほど重たい怖るべき代物であるかのような騒ぎを演じているのやら、そこがわからないのである。",
              "citation": {
                "source": "接吻",
                "author": "ПОЦЕЛУЙ",
                "note": "青空文庫"
              }
            },
            {
              "text": "でなければ、がんじがらめにして、この利根川の底へおつぽり込ませてやりますよ。",
              "citation": {
                "source": "天國の記録",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると舞台裏から、二人の黒衣の人物が現はれて、白い太い縄で、彼女のからだを脚から腰、腹から胸もとへと、両腕もろとも、がんじがらめに縛り上げる。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "女王をがんじがらめに縛りあげた縄の封印を、たしかめる為である。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「荒天浮錨、用意」　十人ばかりの船舶兵が下艙から駆りだされてきて、太い円材をおなじ長さに切って三角形の巨大な枠をつくり、帆布で包んでロープでがんじがらめにし、波のひいたところを見はからって海へ投げおろした。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ、あたしはこんなふうにがんじがらめになっているのですし、こんなはげしい流れなんだから、あたしは溺れて死ぬほかはない」　上のほうでは、押し殺したような含み声で、「誰も、殺すとは申しておらぬ。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "捨公方",
                "note": "青空文庫"
              }
            },
            {
              "text": "……落ちる途中で気を失ったとみえて、いいあんばいにあまり水も飲んでいない」　がんじがらめになっている繩を手早く解いて俯向けにして水を吐かせ、磧の枯枝や葭を集めて焚火を焚き、いろいろやっているうちに、どうやら気がついたらしく微かに手足を動かし始めた。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "捨公方",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと高手小手に、がんじがらめに縛り上げてしまえ。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "と考えて、下からそっと覆を押し上げていたが、中の女は知らないもののがんじがらめの締め緒に錠がかかっているから、持ち上がるどころか一分だって動かばこそ。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "慌てた平家方は、御所の囲りをがんじがらめに警戒し、一門は六波羅に集って、善後策を協議することになった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうですかと信じた時、がんじがらめに私どもを縛っていた縄が皆ほどけてしまう。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るい電灯の輝く八畳の整理箪笥の前に、細君は白い細紐でがんじがらめに縛られ、やや弓なりの姿勢で、真裸でじかに畳にころげている。",
              "citation": {
                "source": "愛のごとく",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれが五つの顔に近づくと、美女たちの十本の腕がヒトデの足のように伸びて、黒ビロードのからだを、四方からがんじがらめに捕えてしまった。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "人体解剖が宗教の観点で禁じられていたことは別として、その各ステップが推察的偏見によってがんじがらめになっていたら、解剖学は栄えることができるだろうか？",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九五〇年代のはじまりは、世のなかのひとりひとりが、社会と約束をとりかわし、その約束がゆえに社会のなかにがんじがらめにしばりつけられていくことのはじまりを予言していた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は何かにつけて規則々々のがんじがらめの理屈を捏ねて夫とは喧嘩ばかりしているってわけだ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うむ、頭ががんじがらめになったような感じだったけれど、今は自由になったよ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、かれらは細曳を手繰り、二つのつづらをがんじがらめにくくりだした。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "船路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづらは、がんじがらめのまま、さっき、原士たちが乗ってきた小舟の一つへつり下ろされた。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "船路の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
