    "definitions": [
      {
        "index": 1,
        "gloss": "reckless",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は合格のために、我武者羅に勉強を続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "若気の至り、我武者羅に突き進んで失敗した経験がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もうダメだ！」「いや、まだだ！我武者羅にやるしかない！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供がおもちゃを欲しがって、我武者羅に泣き叫んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "我武者羅に押通さうものなら、默つて聽いてはゐるが、『さういふけどなあ』とねちねちやつて來る。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その點だけでも、彼は僕にとつての益友だが、あんまり腕白小僧の我武者羅が強い時には、さすがに僕も腹が立つて、時々子供同士のやうな喧嘩をする。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その無鉄砲な我武者羅なところが喜多流だと思って喜んでいるのだから困りものですよ」　又、梅津利彦氏（現牟田口利彦氏）は翁の型についてこう語った。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に翁は間拍子のメチャメチャな所謂、我武者羅謡を推奨していたかのように誤解している間拍子嫌いの人も多かったらしいが、決してそんな事ではなかった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな次第であったから翁の門下の高足の人は、決して翁の歿後に福岡地方で流行したような我武者羅謡ではなかった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生のお宅の会の時ですら、あの人づゐぶん我武者羅に私にぶつ突かつた。",
              "citation": {
                "source": "草いきれ",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は下腹を我武者羅に抱へて、虎のやうに吠えはじめた。",
              "citation": {
                "source": "木枯の吹くころ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして死物狂ひになつて、しかし老人の特権を可也我武者羅に主張して、威張りくさつて、人を押退け／＼して遣つて来た。",
              "citation": {
                "source": "余震の一夜",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがタイタニック号であったことは言う迄もないが、キャリフォルニアン号から視ると、タイタニックの船体が斜めになって進航して来ているために、実際よりは非常に小さく見えて、グロウヴスは、その、はらはらするほど我武者羅に近づきつつある船を、自船と同じ位いの大きさの、精々五、六千噸の貨物船だと思った。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時分我武者羅の私が我慢しかねてその女と爭論し、それからその女の惡徳を算へて先生に追放を迫つた。",
              "citation": {
                "source": "永井荷風といふ男",
                "author": "生田葵山",
                "note": "青空文庫"
              }
            },
            {
              "text": "間に、一人がステッキを口へ突込んで吐かせようと、我武者羅にこじ廻したのだそうだ。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんな家みられて……」　ひどく、しゃくり上げる声がして、もっと何か云いながら裏口から我武者羅に駈け出す物音である。",
              "citation": {
                "source": "道づれ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今更こんなことをいふのはをかしいけれども、話などしてゐると我武者羅で圧倒されるが、彼女達は自分の弱点を少しも反省してゐない。",
              "citation": {
                "source": "女性風俗時評",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蛮カラ」とは、何れにしても、細節に拘泥せず、我武者羅であり、悪くいへば「野暮」であり「殺風景」であるが、時として、それを知りながら、わざとさうであることを努める。",
              "citation": {
                "source": "『ハイカラ』といふこと",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "中村君は婉曲な悪戯者であり、阪中君は我武者羅な人情家である。",
              "citation": {
                "source": "中村・阪中二君のこと",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもわたくしとしましては、あの我武者羅な押しの強い人柄を、あまり好きではございません。",
              "citation": {
                "source": "死因の疑問",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　奥から父親の、我武者羅な声が迎へました。",
              "citation": {
                "source": "けむり（ラヂオ物語）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "臆病なものには我武者羅になれと云ひ、神経質なものには図太くやれと、激励叱咤するのは、あながちわるいとは云ひません。",
              "citation": {
                "source": "青年の矜りと嗜み",
                "author": "――力としての文化　第四話",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕なんか、その点ぢや、随分｜我武者羅を通してるんだ。",
              "citation": {
                "source": "屋上庭園",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのとき死んであれだけが私であり書置きの通りれいれいしく世に現れたら滑稽な話であるが、こんな話で分るやうに、私の少年時代はただ我武者羅に自分の生命力を意識すること、また存在を残すことに狂奔してゐた。",
              "citation": {
                "source": "手紙雑談",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "文芸の道は天賦の才なくてはかなふべからず、その才なくして我武者羅に熱中するは迷ひにして自信とはいひがたかるべし。",
              "citation": {
                "source": "小説作法",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "我武者羅に押一手で成功するは唯｜地女を口説き落す時ばかり。",
              "citation": {
                "source": "小説作法",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "市中の電車に乗って行先を急ごうというには乗換場を過る度ごとに見得も体裁もかまわず人を突き退け我武者羅に飛乗る蛮勇がなくてはならぬ。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅くとった夏休みに、北アルプスの針ノ木岳に登り、妙な谷を我武者羅に大沢まで下った。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらたまったようすで、お褥の上に御紋付の膝をならべ、お脇息を引きつけているときは、兄対馬守とはまた別の、一風変わった貫禄がそなわっていて、我武者羅な若々しいなかにも、着飾った競馬馬のような男性美があふれるのですが。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い間は精一杯我武者羅に飛び廻ることだ。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "野蛮な舌を封じるのは、ただ、この野蛮な腕があるだけぢやありませんか」　彼は、さう云ひながら、千種の肩に両手をかけ、我武者羅にゆすぶつた。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は今度のことは自分の今迄のけちな量見を叩きのめすつていふやうな意味で、少しは我武者羅に振舞つた傾向がないとは云へないんです。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫陽花のような感じのする娘お妙が、不自由な足を引摺ってお勝手へ出て来ると、父親の袂を引いて、その我武者羅な強気を牽制しながら、「あの、竜吉さんは、本当に人手にかかって亡くなったのでしょうか」　涙を含んだ大きい眼が、平次を見上げて、父親の蔭からまたたくのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "凧の糸目",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし頭の悪い学者はそんな見込みが立たないために、人からはきわめてつまらないと思われる事でもなんでもがむしゃらに仕事に取りついてわき目もふらずに進行して行く。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
