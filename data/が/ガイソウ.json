        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "またこの外挿絵のうちに漆器や本の装幀等を入れ得なかったことを遺憾に思う。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "コクトオは気がちがいそうになって日がな一日オピアムばかりやってるそうだし、ヴァレリイは十年間、唖者になった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっとしていると気がちがいそうな鬱陶しさである。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔子と老子のちがいくらいにはちがいそうである。",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "足元からすこしだらだら下がりになり萱が一面に生え、尾花の末が日に光っている、萱原の先きが畑で、畑の先に背の低い林が一｜叢繁り、その林の上に遠い杉の小杜が見え、地平線の上に淡々しい雲が集まっていて雲の色にまがいそうな連山がその間にすこしずつ見える。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもは、こんな草原は、蛇がいそうな故を以て、絶対に避けて通ることにしているのであるが、いまは蛇に食い附かれたって構わぬ、どうせ直ぐに死ななければならぬからだである、ぜいたくを言って居られぬ。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男の家には、六つか七つぐらいの男の子がいそうな気がした。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう思いますと私は気がちがいそうにたまらなくなりまして、フイと顔を上げました。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやら番人がいそうもないので、高一は、もっていた懐中電灯をつけてみると、中には、船からもってきた荷物がたくさんつんであります。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となくムハメットがいそうな空の色と岩の色だ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前はヨーロッパを征服する奴は何者だと思う」「それは陛下が一番よく御存知でございましょう」「いや、余よりもよく知っている奴がいそうに思う」「何者でございます」　ナポレオンは答の代りに、いきなりネーのバンドの留金がチョッキの下から、きらきらと夕映に輝く程強く彼の肩を揺すって笑い出した。",
              "citation": {
                "source": "ナポレオンと田虫",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕はこのごろ本当のことを正直に云うと、日本の知識階級の中に世の中なんか滅ぼうとどうしようと、どうだってかまやしないと思っている人間がいそうに思えて仕様がないのだ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺の内はしんとして人がいそうにも思われぬ。",
              "citation": {
                "source": "日光小品",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その真暗の便所の壁に、どうやら何物かがいそうな気がしてたまらないのであった。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そう思うと、その辺に、父がいそうな気がして、顔を上げた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々のひいき眼では、日本には相当な作家や画家がいそうに見えますがな。",
              "citation": {
                "source": "MENSURA ZOILI",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、袋は大きくふくらんでそこに転がってるきりで、中にお爺さんがいそうなようすも見えません。",
              "citation": {
                "source": "お山の爺さん",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "農家の造りはたいがいそうだが、門をはいると五六百坪もありそうな殺風景な広場があって、もいない。",
              "citation": {
                "source": "女剣士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "議会の答弁や腹芸なぞと云われているものが大がいそうだ。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "またわれわれ文士が温泉なぞへ仕事に行くと、こんど新しい別館ができましたなぞと云って案内されるのがたいがいそうであるし、雑誌社や新聞社が仕事の都合で部屋を世話してくれるときも、静かな環境をと考えてくれるせいか、元何々邸という庭園のひろい旅館へ案内されることが多い。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の宿営地に近く、とても満々と水をたたえた淵があり、いかにも魚がいそうな場所だったし、魚なんて一年近くも食っていないので、やって見ようという訳で、敵機の来ぬ時を狙って野球選手（どこのチームか知らない）のＫ君が裸になって河に入り、手榴弾を叩きこんだ。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラネーフスカヤ　わたし、じっとしちゃいられない、とても駄目……（ぱっと立ちあがって、ひどく興奮のていで歩きまわる）嬉しくって嬉しくって、気がちがいそうだ。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂上へ行くには谷を渉り岩をよじ道なきところを這いまわらねば行かれないが、どこの山でも昔はたいがいそういうもの。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その七　石の下",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、気がちがいそうだ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ああ、気がちがいそうだ！",
              "citation": {
                "source": "熊",
                "author": "МЕДВЕДЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も相手がないときは――たいがいそうだったが――わたしは櫂で舟ばたをたたいて反響をおこし、円をなして外へひろがる音波を、周囲の森にみたした。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑い声のなかから、小枝が、「わたしだって、あやしいもんだわ」　思いもうけなかったところで、多計代とあんまりちがいそうもない自分を見つけ出したことにおどろいた眼だった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのどれもが、西から帰って行くひろ子と行きちがいそうに思えるのであった。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもここには秘密を隠そうとしている連中がいそうな気がします。",
              "citation": {
                "source": "手早い奴",
                "author": "THE QUICK ONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもそこにあの人がいそうな気がします」そう言うとブラウンは急いで浜のほうへ行つてしまつた。",
              "citation": {
                "source": "緑色の人",
                "author": "THE GREEN MAN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
