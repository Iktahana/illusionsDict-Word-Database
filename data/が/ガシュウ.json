[
  {
    "uuid": "62b8db13-772c-5380-8e4b-6d72e55c508e",
    "entry": "我執",
    "reading": {
      "primary": "がしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
