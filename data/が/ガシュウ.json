      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "egotism",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "我執を捨てて周囲の率直な意見に耳を傾けることで、停滞していた開発プロジェクトがようやく動き出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自分の正しさを証明しようとするあまり、彼の議論の進め方には強い我執が透けて見えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "仏教の修行では、あらゆる苦しみの根源は自己に固執する我執にあると説かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ＡはＢの百倍の理性を持つてゐても、ＡはまたＢの百五倍の我執を持つてゐれば、ＡはＢより「所謂感情的」である）。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿河原のぼろぼろの仇討決闘の話でも、我執無慙を非難すると同時にまた「死を軽くして、少しもなづまざるかたのいさぎよさ」を讃えている。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを通り越して来たものは人力の如何ともすべからざること、人力以上のもののあること、それらを体験的に弁えた人であるが故に、我執も除かれ、万事、実相に明らかな眼で誰人とも応酬出来る。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　さるほどに蝦蟇法師はあくまで老媼の胆を奪いて、「コヤ老媼、汝の主婦を媒妁して我執念を晴らさせよ。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "父といふ人は、強慾で、そして我執の念の強い、飽迄も物質｜慾の旺んな人物であツたらしい。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "神を恐れぬこの傲慢、痴夢、我執、人間侮辱。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、Ｙの持つて生れた度外れの気位と我執の性質から、たうとう長上と衝突して途中で辞めて仕舞つた。",
              "citation": {
                "source": "過去世",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪子はふと、母もなく我執の父の下に育つて、情のしこつた弟息子の親への甘えごころが、兄へかうも変つた形を採つて現はれるのではないかと気がついた。",
              "citation": {
                "source": "過去世",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、私の愛情は、私の盲目的な虫けらの愛情は、なんということだ、そっくり我執の形である。",
              "citation": {
                "source": "思案の敗北",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、そんな気持こそ、凡俗のとるにも足らぬ我執で、あさはかの無礼な歎息に違ひございませぬ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し是の如きの人には、ややもすれば我執の強い、古い言葉で云えば「カタムクロ」の人が多いものだが、流石に氏郷は器量が小さくない、サラリとした爽朗快活なところもあった人だ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべては、自身の弱さから、――私は、そう重く、鈍く、自己肯定を与えているのであるが、――すべては弱さと、我執から、私は自身の家をみずから破った。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが故人のかういふ功名心もあの強い押へることの出來ない樣な我執を不思議に沒却して居た根岸庵の時代に於ては寧ろ愛すべき美點となつてのみ現はれて居たやうである。",
              "citation": {
                "source": "記憶のまゝ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "生涯決してまだ大家と呼ばれる人々の門に膝を屈したことはないと壯語しつゝあつた故人が心底から服從した根岸の先生に對しては我執を沒却し得たのは當然のことである。",
              "citation": {
                "source": "記憶のまゝ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時丈はあの我執の強い人に心持よい程一點の邪氣も認められなかつた。",
              "citation": {
                "source": "記憶のまゝ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝頼は決して暗愚の将では無かったのだが、その機略威名が父信玄に遠く及ばない上に、良将を率い用いる力と眼識が無く、かく老将を抑えて自分を出そうとする我執がある。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "こはわが我執あるにはあらで、人々の我執あるにはあらざるか。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そを翻りてわれ我執ありといふは、わが人の恩蔭を被りたる貧家の孤たるを以てにあらずや。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "我執、理想、空想、煩悩、さういふものを数々押しつめて、そこから理解が生じて来たからである。",
              "citation": {
                "source": "自からを信ぜよ",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "我執のために緊張しきったその目は怪しく輝いた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大尉は、死際になってもまだ我執を捨てない中尉を心から卑しみ、心から憎んだ。",
              "citation": {
                "source": "ゼラール中尉",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去に執する勿れ、自我を捨てろ、我執放下着。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "とかく女が狭い生活にとじこめられていたために、人生の視野がせばまって、我執だの偏執だのが女につきものの気質のように見られた一方の、その対蹠的な要求とでもいうべきものだったのかもしれない。",
              "citation": {
                "source": "ものわかりよさ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、自己完成の願望の純粋な発露と、保身的な我執との間を、自身にたいしてきびしく区別しようとしていることです。",
              "citation": {
                "source": "一九四六年の文壇",
                "author": "――新日本文学会における一般報告――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作者が「暗い絵」で深見進介の自己完成のはげしい欲求と、我執とが妥協することをけっして許さず「科学的操作」で追いつめていったとしたら、主人公の自己完成の道はどんなところに展け、つきだされてゆくでしょうか。",
              "citation": {
                "source": "一九四六年の文壇",
                "author": "――新日本文学会における一般報告――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故「沃土」のような成功した例外のほかの多くの和田の作品は、その農民心理が我執とか所有欲などを本能にまで還元された上で、その葛藤を特定の条件によって設定して、その筋の上に発展させられている。",
              "citation": {
                "source": "昭和の十四年間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "怠惰と我執と傲慢とほど、私達を自己の本質の理解から遠ざけるものはない。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、憐れな魂は、暗澹たる故郷への郷愁と、懣怨と、一層深入りした我執との裡に転々して、呪を発するのでございます。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃は忙がしゅうてなあ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "つきましてでござりますが、ええ、夫人、唯今はどうも、とんだお騒がしゅう、さぞまあ吃驚、お驚き遊ばしましてござりましょう。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
