[
  {
    "uuid": "26333b8e-277f-500a-b50c-0cf7040240eb",
    "entry": "害する",
    "reading": {
      "primary": "がいする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-特殊",
