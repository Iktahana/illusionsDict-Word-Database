    },
    "definitions": [
      {
        "index": 1,
        "gloss": "on-screen",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "パソコンの画面上に、アイコンが散らばっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ゲームのキャラクターは、画面上を自由に動き回っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "指示は画面上に表示されるので、よく読んでから操作してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プレゼン中、重要なポイントが画面上に大きく表示された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "コンピューターの中の新しい本　画面上に開かれた新しい本を読み始めてすぐに、私は〈本〉という言葉の成り立ちが、自分の意識の中で変わり始めるのに気づきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "画面上の本を読み進むうちに、「コンピューターで読む新しいものが電子本なら、これまでの紙の本はそのうちに印刷本などと呼ばれるのかな」と思い始めました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙と比べれば、画面上の文字を長時間読み続けるのはかなりつらい。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "加えて、書く際にはがまんできる巻紙環境を読む際もそのまま流用してきたことで、画面上で読むという行為はかなりつらいものになってきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "スクロールがないぶん、画面上での改善は認められても、依然として紙とは大きな差があります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "流し読みの効かないテキストは、参考図書の参照機能を組み込んだ機械仕掛けの書見台の上で読むようになり、読んだ上で書くという連続的な作業が、一貫して画面上で進められるようになると考えました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした仕組みが普及すれば、コンピューターで作った雑誌をそのまま通信で送り、受け取った側の画面上で読むこともできるのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙から切り離し、画面上で読むと方向付けてみることで、決定的に新しいメディアの誕生を思い描いてみたかったからです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "簡単にルビを振れないのも評判が悪く、紙に比べると画面上の文字が実に淡泊で弱々しい点も、あらためて「こんなものか」と指摘されました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「パワーブックで読む、従来の本を画面上に移し替えたもの」としてエキスパンドブックを旗揚げした米ボイジャーもまた、そうした圧力を受けた一人でした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "画面上で、絵と文章を組み合わせてみたり、キャラクターを動かしてみたり。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、このものたちは、もともとここで生まれたんだな」と、画面上の『るじにっき』を見ていると、そんな感慨がわきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "行間を取らずに詰め込んだ画面上の小さな文字をスクロールさせながら読んでいくと、気づかないうちに、頭蓋骨の裏あたりに灰色の疲労の結晶が層を成していきます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど大まかなことしか指定しないＨＴＭＬでは、画面上での読みやすさが配慮できません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に長いものでは、画面上の文字を追い続けるのは禁物と、骨身に染みて知りました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに、これらのビュワーの中には、ＸＨＴＭＬ版に書き残された底本の組み版情報のほとんどを、画面上に再現するものまであらわれた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＢＢＡが想定していた画面上の拡大訳は、今や、これらのソフトの基本機能として実現されている。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "オレが鼻たれ小僧だったころには強力なメディアだった本物の紙芝居の機能に加え、電子化したＴＯＷＮＳ版にはいろいろなボタンを画面上に仕込んで任意のページに飛んだり、仕掛けておいた音を出したりといった機能が付け加えられている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この仕掛けが、ぱっと見て一目でわかるようアイコンと呼ばれる絵文字を利用し、やれることをメニューにして示し、画面上に複数の『窓』を開くウインドウ機能を備えるなど実に憎い仕上がりとなっていたことで、その後のパーソナルコンピューターの進化の道筋は、ここで事実上定まった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "３８６ＳＬ以上の32ビットを積み、画面上で「どうにかしたいのはここだ」と場所を指し示すポインティング・ディバイスが付き、Ｗｉｎｄｏｗｓがのる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "画面上の窓に複数のファイルや複数のアプリケーションを開いて、データを切り張りしながら仕事を進めることができる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本家の技をなぞったうえに、画面上での訂正や文書の保存、カット＆ペースト、欧文ならスペルのチェックと、従来のタイプライターをはるかに超えてみせた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ディスプレイ画面上の読書が紙と活字の本にくらべて、かけねなしに気持いいものになりえているなどとはとてもいえない。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙の本の場合、私たちは指でページをめくりながら読みすすむが、電子本ではディスプレイ画面上に複数のウィンドウ（伸び縮み自在の小画面）をひらき、それぞれに別のテキストや絵や図表やビデオ・ムービーやサウンドを呼びこんで、それらを自由に組み合わせながら読む（見る、聞く）ことになる。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "※ネットワークをつうじてデータを人手し、※それをディスプレイ画面上にデジタル文字として表示して、※複数のウィンドウを切り替えながら読む。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ディスプレイ画面上の文字はインクのしみではなく、かげろうのようにはかない一瞬の映像にすぎないのだ。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは画面上に「かつ消え、かつ結び」するだけで、原理的にも実際的にも、人間の不定形な想念をグイッとせきとめる強引な切断力をもたない。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現象的な表現力をのみ窺つて、画面上の効果のみを目的として、制作をすゝめてゐる作家は少くない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "描かれてゐる部分と、描かれてゐない部分との画面上での抱合、この巧みさは五雲独特なものがある。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
