    },
    "definitions": [
      {
        "index": 1,
        "gloss": "school register",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "休学しても学籍は残るけれど、復学の際に手続きが必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大学から送られてきた書類に、自分の学籍番号が記載されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ゼミの登録をする前に、自分の学籍情報をシステムで確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "転校の手続きのため、前の学校から学籍に関する書類を取り寄せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "二葉亭もまたその一人で、一時は商業学校に学籍を転じたが、翌十九年一月、とうとう辛抱が仕切れないで怫然袂を払って退学してしまった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "新入生の一人々々を、学齢児童調書に突合して、健はそれを学籍簿に記入し、孝子は新しく出席簿を拵へる。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯野はそこへ学籍を置きながら、月々の学費を取り寄せていた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "之も矢張り広い意味でアカデミーに学籍を置いている私の友人達又は知人達のことなのだが。",
              "citation": {
                "source": "友情に関係あるエッセイ",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "西山教頭が何度も電話口に呼び出され、ひるすぎには、五年全部の学籍簿を抱えて県庁に出かけた。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "学籍薄の整理上、いつまでも中途半ぱには出来ませんから。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "対蹠的な好敵手　大正九年であるから、私は二十三歳で、学籍はまだ早稲田大学に置いていた。",
              "citation": {
                "source": "叛骨・中野正剛",
                "author": "――主観的な覚え書き",
                "note": "青空文庫"
              }
            },
            {
              "text": "この何ほどかの幼稚な知識に因って、わたしの学籍は、後々日本のある田舎の医学専門学校に置かれることになった。",
              "citation": {
                "source": "「吶喊」原序",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちさとさんのお父さん、大工さんね」　すると千里は、松江そっくりの黒い目を見はって、「ううん、大工さんは、おじいさん」「あら、そうだったの」　しかし彼女の学籍簿には、彼女の父は大工とあった。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "名前や学籍番号などを、彼女は棚の引出しから出したノートに写した。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
