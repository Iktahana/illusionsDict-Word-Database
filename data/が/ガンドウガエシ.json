    "definitions": [
      {
        "index": 1,
        "gloss": "rotating stage machinery, which rolls backwards 90 degrees to reveal the next scene",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "歌舞伎の舞台で、背景がバタンと倒れて一瞬で城門から室内へと場面が変わる強盗返しに、観客から大きな拍手が湧いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "舞台監督は、強盗返しの仕掛けがスムーズに作動するか、開演前に何度も入念なチェックを行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「次は強盗返しだ、タイミングを逃すなよ！」と舞台袖で裏方たちが小声で声を掛け合う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "場面転換で使われる強盗返しは、大道具の自重を巧みに利用した江戸時代からのダイナミックな演出だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そこのかべが、「がんどうがえし」になっていたのです。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
