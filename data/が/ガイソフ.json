    "definitions": [
      {
        "index": 1,
        "gloss": "maternal grandfather",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
