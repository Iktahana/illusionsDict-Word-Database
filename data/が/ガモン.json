        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もうこうなれば、かれらの命令に従うのほかはないので、士はかれらに導かれて門を出ると、堂の東に節使衙門のような小さい門がみえた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この申出では快諾され、ブランドは總理衙門にも、また慶親王以下の軍機處の王大臣にも、アジア協會支部の希望を傳達した（41）。",
              "citation": {
                "source": "大秦景教流行中國碑に就いて",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "上天難欺」と題してある、所謂戒石の銘が各衙門の正面に刻されてあつても、古來の弊風は少しも改まらぬ。",
              "citation": {
                "source": "支那猥談",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツがこれを建設した当時、土民の乞いによって残されたという旧衙門と天后宮とだけが、旧支那式建設であって、他は悉く近代建築である。",
              "citation": {
                "source": "北京・青島・村落",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがこの都市にも、衙門や天后宮のような旧支那式建築が残っており、ピンカンウーリ（平康五里）の特殊な高楼がある。",
              "citation": {
                "source": "ピンカンウーリの阿媽",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」云々と言つて居るけれども、この草案を憲政編査館から内外各衙門に※はし、其意見を徴した所が、種々な反對論が出た、而して尤辨難の鋒が強かつたのは學部であつた。",
              "citation": {
                "source": "支那近世の國粹主義",
                "author": "狩野直喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月十四日聯合軍と共に日本軍も入城し、柴中佐等は順天府に警務衙門を設け、東四牌樓から北の治安と宣撫に當ることゝなり、籠城組から先生はじめ私達二三人も求められ參加することになつた。",
              "citation": {
                "source": "服部先生の思出",
                "author": "狩野直喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "郭門は城内の旧市街にいずれも通じているのであって、道台衙門のある所はすなわち東大門内である。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "知県衙門のあるところは小東門内の中央である。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼都自作別乾坤、繞屋林叢鎖世喧、九月米南春已満、椿紅藤紫擁衙門。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "其人が衙門へ指してお勤めに行く。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは駐蔵大臣の衙門からトモの城へ指して兵士の給料を持って行くので、大分に馬も空いて居る様子だからそれに積んで行って貰うたら都合がよくはないか。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "伏完の一門から穆順の一族縁類の端まで、総計二百何十人という男女老幼を、この日たった半日のまに残らず捕えて、宮衙門の街辻で、首斬ってしまった。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "とき建安十九年十一月の冬、天もかなしむか、曇暗許都の昼を閉じ、枯葉の啾々と御林に哭いて、幾日も幾日も衙門の冷霜は解けなかった。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そいつはいかん、僕がもんであげよう」　私は和智君を崩れた煉瓦の上へかけさして、くじいた足首のあたりを揉んだ。",
              "citation": {
                "source": "変災序記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嚊々殿は仏文の手紙と、若干金の学資とをもって神月を買ったものだと言わなけりゃなりません、そいつあ御免を蒙りたいな、仕送をしたっていくらがもんです。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その白犬がの、狂気になったかの、沖の方へ、世界の涯までと駈出すと思う時、水戸屋の乾の隅へ、屋根へ抜けて黄色な雲が立ちますとの、赤旗がめらめらと搦んで、真黒な煙がもんもんと天井まで上りました。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お聞きねえ、伺いやすがね、こう見渡した処、ざっとこりゃ一両がもんだね、愛吉一年の取り高だ。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蒟蒻はお品がもんだから、錢はみんなおめえげ遣つて置くべ」勘次は銅貨をぢやら／＼とお品の枕元へ明けた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして其の機嫌が恢復しかけたのを見て「どうした、それでも汝りや氣につたか、おつかゞ物はみんな汝がもんだかんな、俺ら汝ツ等がだとなりや幾ら困つたつて、はあ決して質になんざ置かねえから、大事にして汝能うく藏つて置いたえ」と彼は滿足らしく見えた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「藏つて置いて、俺らいまつと大く成つてから着べかな」「どうでも汝がもんだから汝が好きにしろな」勘次はおつぎの手が動くに從つて目を移した。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして毎日、新聞で見る今日の銃後の女としての服装もエプロン姿から、たとえそれがもんぺいであろうと、作業服式のものであろうと、ひとしくりりしい裾さばきと、短くされたたもととをもって、より戦闘的な型へ進んで来ているのである。",
              "citation": {
                "source": "新しい婦人の職場と任務",
                "author": "――明日の婦人へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲芸師のからだがとつぜん宙にはねとばされてまっさかさまに墜落し、同時にからっ走りした自転車がもんどり打って、観客席のまっただなかへ落ちこんできた。",
              "citation": {
                "source": "或る精神異常者",
                "author": "モーリス・ルヴェル",
                "note": "青空文庫"
              }
            },
            {
              "text": "きゃっと消魂る叫びとともに宙に飛んだ二つの首級がもんどり打って地面へころげ落ちると、さらさらという音がして、折れた麦穂を鮮血に染めた。",
              "citation": {
                "source": "麦畑",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の上にはいろんなものがごちやごちやと置いてあつたが、新しい糊の壺がもんの眼にとまつた。",
              "citation": {
                "source": "秋果",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十六にもなつて、弟はまだ嫁ももらはないで、いまだにかうしたアパート住ひをしてゐるのがもんには可哀想でならない。",
              "citation": {
                "source": "秋果",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "守一がもんの寢床を敷いてゐた。",
              "citation": {
                "source": "秋果",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "機械は、わかってるだべ、お前のもんでも、俺がもんでもねえ。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりの姿がもんどりうって倒れた。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯爵がもんどりうって海水の中に落ちたのであった。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
