        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "京都の嵐山は、紅葉シーズンになると多くの外国人旅行者で賑わう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "駅で困っている様子の外国人旅行者に、片言の英語で道を教えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "円安の影響で、日本を訪れる外国人旅行者の数が急増している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ホテル業界は、多様な文化や宗教的背景を持つ外国人旅行者への対応を進めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "同じことが日本を訪問する外国人旅行者の口から聞かれるのを私たちは知っている。",
              "citation": {
                "source": "レンブラントの国",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦敗国には、もちろん想像を超えたインフレーシヨンの波、正視できぬ飢餓の相貌、外国人旅行者の大尽遊び、街の女の氾濫、わけてもドイツでは、青壮年男子の著しい陰鬱な表情がわれわれの心を強く打つた。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
