    "definitions": [
      {
        "index": 1,
        "gloss": "Ono no Michikaze card in hanafuda (esp. when used as a wild card)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自分が学校で古いフィロソフィカル・マガジンを見ていたらレヴェレンド・ハウトンという人の「首つりの力学」を論じた珍しい論文が見つかったので先生に報告したら、それはおもしろいから見せろというので学校から借りて来て用立てた。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍浴場内に大の字に成ってへた張ったところ、三人して頭からガジャガジャ冷水の洗礼を見舞うとこ、たちまち家屋を震動せしむるウエーウエーの大声を連発する数回。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "創刊以来、世話になってきた『ザ・コンピュータ』とコラムを載せてもらった『パソコン・マガジン』も同時に廃刊になった。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九九〇年一月号から一九九二年三月号にかけて、同社の『パソコン・マガジン』に「インサイドウォッチャー」と題して連載していたコラムを、まとめたものだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本書はソフトバンク刊の『パソコン・マガジン』に「インサイドウォッチャー」と題して連載した時評コラムを、まとめ直したものだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "初代のパームトップが出た頃には、手書きなどできの悪いＳＦ映画から引っ張りだしてきた実用性のないガジェットだと言い張ろうと思えば言えたろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『パソコン・マガジン』第一回日米共同セミナーのパネル・ディスカッションの末席に加わることを、発病以前のオレは約束してしまっていたのである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さすが決戦だ、未来だ、新潮流だとあれやこれや思い付くかぎりのネタで大騒ぎしてきた高血圧マガジン！",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来なら引き続いて、両親の離婚騒動に胸を痛める全世界のまるちゃんへのメッセージなども書きたいところだが、今回ベスト１を書かずに終われば『パソコン・マガジン』にオレの席はない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊とこう書いた直後、世話になっていた『パソコン・マガジン』の編集部と大喧嘩して（一方的にオレが怒り狂っていただけだという噂もあったが）、読者への挨拶もなく本書のもとになった連載を打ち切った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "創刊以来、世話になってきた『Ｔｈｅ　ＣＯＭＰＵＴＥＲ』とコラムを載せてもらった『パソコン・マガジン』も同時に休刊になった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『パソコン・マガジン』への連載中は、同誌編集部の宮島淑子さんの励ましと助力を得た。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴェニス人プラガジニは有名な方士で、魔の力を借りて黄金を作り出すと誇り、一五九五年バイエルンで刑せらる。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガジガジと、インク壺の中へペン先を突き込む音がする、慌しく「ノート」の頁をめくる音がする。",
              "citation": {
                "source": "妄想患者",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二学期までは、この寮で漫画雑誌を見かけることはなかったが、最近はあちこちの部屋に、「サンデー」や「マガジン」が転がっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウチノナカガジトジトシテ、アルクト足ガタタミニネバル。",
              "citation": {
                "source": "テガミ",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガジャガジャと金具の音が起った。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことは昨年の三月二十七日発行の「ゼ・デテクチヴ・マガジン」にボドキン判事によって指摘され、同氏は、この自家撞着があるために、この作品に対する期待を打ち壊されてしまったと言っている。",
              "citation": {
                "source": "「マリー・ロオジェ事件」の研究",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑞典国ストックホルム市　ヤポンスカ・マガジネット支配人　　　エスキル・アルトベルグ　アルトベルグさんは学者肌の中老の紳士で、私達が戸を排したときは、ちょうどお客のお婆さんに日本の紡績｜絣を一尺ほど切って売っていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｅ・Ｄ・Ｓの沿岸船ベンガジ丸が、いまモザンビイクにはいってきたのだ。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "善玉悪玉嬢　ベンガジ丸には、ヤン・ベデーツというベルギー青年が乗りこんでいた。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "｜Ｅ・Ｄ・Ｓの沿岸船ベンガジ丸が、いまモザンビイクにはいってきたのだ。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ケガジ乞食にケエ。",
              "citation": {
                "source": "津軽地方特有の俚諺",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケガジは饑饉、ホイドは乞食、ケエは粥で発音は英語 cake（菓子）の ca に近い。",
              "citation": {
                "source": "津軽地方特有の俚諺",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分、まあ少しはものの足しになる存在と思って居たが、弟一人の力にさえならなかったか、自分のニェ・ガジッツアー〔役立たずの意〕の感に苦しむ。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
