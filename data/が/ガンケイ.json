        "examples": {
          "standard": [
            {
              "text": "猫のような切れ長の眼形が、彼女の魅力の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の眼形は、ぱっちりとした二重で、とても印象的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子どもの頃は丸い眼形だったが、大人になるにつれて少し細くなった気がする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "メイク一つで眼形の見え方が大きく変わるから不思議だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼の真像として伝来している大小両剣をひっ提げている立像を見ると、眉の先が刎ね上がって、鼻ばしらが高い、眼形は幾分か三角形であり、そして云い伝えられるところによれば、瞳はすこし茶色をおびていたということだ。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
