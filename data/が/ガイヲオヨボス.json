[
  {
    "uuid": "42cd20c0-8044-5147-a41d-17fdb020c6a7",
    "entry": "害を及ぼす",
    "reading": {
      "primary": "がいをおよぼす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
