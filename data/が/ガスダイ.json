        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "電燈料もガス代も水道税も三倍だ。",
              "citation": {
                "source": "ソヴェト労働者の解放された生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラントの計算では、風速一メートルの時幅五十メートル長さ六百メートルの滑走路上の霧を十分間消すのに、石炭ガスを燃すとすると、ガス代三十五ポンド程度の量が要るということになっている。",
              "citation": {
                "source": "霧を消す話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈料、ガス代、水道料、これらもひどく高くなる。",
              "citation": {
                "source": "現実の必要",
                "author": "――総選挙に際して――",
                "note": "青空文庫"
              }
            }
          ]
        }
