[
  {
    "uuid": "a2f34dd5-5708-55d6-b01d-1a7b227f5208",
    "entry": "学問的",
    "reading": {
      "primary": "がくもんてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
      ],
      "ctype": null,
