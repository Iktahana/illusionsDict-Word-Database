        "examples": {
          "standard": [
            {
              "text": "部活帰りの腹ペコな高校生たちが、大盛りの牛丼をガシガシとかき込んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「よし、明日までにこの参考書をガシガシ解いて終わらせるぞ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "泥だらけになったスニーカーを、硬いタワシでガシガシと力任せに洗う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ストーブに靴をのつけて、ガシガシと泥をかき落した。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "水葬の時に肴につつかれるのはそれ程でもないが、ガシガシと狼に食われるのはいかにも痛たそうで厭やである。",
              "citation": {
                "source": "死後",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガシガシで紙は益※ひどくては書くのに弱るから。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "（手のチューブを振りまわしながら出て行く）タン　へい、ありがとうござ――（途中で言葉を切って、ゴマ塩ひげの頬をガシガシ掻きながら学生を見送っている。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ガシガシと頭を掻く）農夫　弱ったちったって、あんた方あ、頭あ掻いてりゃ済むが、わしら百姓に肥料が足りねえと、これ、命取りだからね。",
              "citation": {
                "source": "鈴が通る",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「グレイロック」から約五キロの村までガシガシ雪原を渡るのだ。",
              "citation": {
                "source": "最愛の君",
                "author": "Ｈ・ビーム・パイパー　H. Beam Piper",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
