[
  {
    "uuid": "2f1c49ce-39cc-52f8-9085-ab7de972b271",
    "entry": "臥薪嘗胆",
    "reading": {
      "primary": "がしんしょうたん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
