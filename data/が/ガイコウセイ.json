        "examples": {
          "standard": [
            {
              "text": "彼の持ち前の外向性が、初対面の人ともすぐに打ち解ける秘訣だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "リーダーには、チームをまとめる外向性と、内省的な思考力の両方が求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は外向性が高く、常に新しい人との出会いを求めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃から外向性が強く、クラスの人気者だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "片親だけで子を育てる母たちが、勝気になり気質が外向性になる、といわれていることが実際であるとして、かりにもしその女親の境遇のあらゆる事情が今の世の中で女のありようと全くちがうほど進歩していたら、それでもなお女の親たちは勝気や男まさりで自分の気質をゆがめられるというようなことが起るだろうか。",
              "citation": {
                "source": "若い母親",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
