        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ブラジルの熱帯雨林を訪れた際、自生しているガラナの木とその独特な赤い実を初めて目にした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ガラナはアマゾン原産のムクロジ科の植物で、その種子にはコーヒー豆よりも多くのカフェインが含まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "植物図鑑を開くと、蔓性の低木であるガラナの形態や受粉の仕組みについて詳しく解説されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "アレガラナハン、家サ來ルヅギモ面白ガタンチェ。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "アレガラナハン、家サ来ルヅギモ面白ガタンチエ。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハヤク　イツテ、ドロノ　ナカニ　コロガラナクチヤ　タマラナイ。",
              "citation": {
                "source": "オホサウヂ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アンマリ大事ヲ取リ過ギルンダワ、アノクライ血ガ出タッテ、何モソンナニ恐ガラナイデヤッテ下サル訳ニ行カナイノカシラ」ト、佐々木ガヒソ／＼声デ云ッタ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五子ハ兎角引ッ込ミ思案デ、アマリ外ヘ出タガラナイ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体妻ハ来客ニ対シテハ不愛想デ、コトニ男ノ客人ニハ会イタガラナイノデアルガ、木村ニダケハ親シムノデアル。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
