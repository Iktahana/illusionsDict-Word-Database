        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「来年、休暇でガーナを訪れて、現地の文化に触れたいと思っているんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ガーナのチョコレートは、カカオの風味が豊かで美味しいと評判だ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ニュースでガーナの経済成長について特集していたよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「サハラ以南アフリカの国々の中でも、ガーナは比較的安定しているらしい。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "先年ガーナー博士がテレビジョン装置をつんだ無人ロケットを飛ばし、火星の上空から三週間観測したが、そのときの報告に、「水中にやや高等なる動物がいるらしい。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "火星の生物については、ガーナー博士はこのことだけを記している。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの人種で天然痘（南ガーナ）や蛇の噛傷にたいして接種が行われ、膿瘍の内容を皮膚の切り傷に摺りこんでいることは興味深い事実である。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "エロール・ガーナー。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼自身が一七九七年九月四日のクーデターによって仏領ガーナに追放された。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
