        "examples": {
          "standard": [
            {
              "text": "口の中をすっきりさせたくて、ミント味の含嗽剤を使っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歯科医におすすめされた含嗽剤を使い始めてから、口臭が気にならなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "風邪が流行る時期は、殺菌成分が入った含嗽剤で予防している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "旅行用の小さな含嗽剤は、荷物にならずに便利だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼は含嗽剤を用意してゐたが、食事をする時、少し難儀だつた。",
              "citation": {
                "source": "芭蕉と歯朶",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "手に提げたのは含嗽剤らしい。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りがけに玄関脇の薬局で、粉薬のまま含嗽剤を受取って、それを百倍の微温湯に溶解して、一日十数回使用すべき注意を受けた時、宗助は会計の請求した治療代の案外｜廉なのを喜んだ。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
