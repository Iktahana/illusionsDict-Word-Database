          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "床の間に飾られた四季折々の画幅が、訪れる客人の目を楽しませてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長い間仕舞い込まれていた古い画幅を、専門の職人に依頼して表具し直してもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "博物館の照明の下で、数百年の時を経ても色褪せない画幅の美しさに息を呑んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "もし真にわが一心をこの画幅とこの自然とに打ち込むなら大砲の音だって聞こえないだろうと。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時に画幅など見たって何の興味があろう。",
              "citation": {
                "source": "浜菊",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより転出したようなは、ブリタニーの天主教寺の縁日に壁に掛けて僧が杖もて絵解する画幅で、罪業深き人の心臓の真中にある大鬼を七動物が囲繞の体だ。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もその頃は今の展覧会向きのような大画幅を滅多に描くものはなかったが、殊に椿岳は画を風流とする心に累せられて、寿命を縮めるような製作を嫌っていた。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲林は人間の臭みが自然に沁み込むのをおそれて、自分の描く山水の画幅には、どんなことがあっても、人物を描き添えないというほどな泉石好きだった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく新画の展覧会へ出掛けると、一つの画幅の前で火喰鳥のやうな鋭い顔をした男が三四人、ぢやん拳をして、きやつ／＼乾躁ぎ散らしてゐるのを見掛ける事がある。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "此書院に古画幅を掛たり。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此段を書し畢つた後に、わたくしは林中将太郎さんの蔵する玉蘊の画幅に「平田氏之女豊」の印があることを聞いた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」是日阿部家に画幅の払下があつて、棠軒は数幅を買つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "梵字形の創傷も、流血の消失も、浄善の咽喉に印された不可解な扼痕も……それ等凡て一切合財のものが、孔雀に駕し四本の手を具えた、「孔雀明王」の幽暗な大画幅の中に語られているのではないか。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この劇場には形体も美もなく、云わば、幇間は如何なるものであるかと云う画幅に過ぎない――と」「幇間――。",
              "citation": {
                "source": "オフェリヤ殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その詩的な画幅が夢のような影を拡げて、それを観客席に押し出して行くのだった。",
              "citation": {
                "source": "オフェリヤ殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその庁堂の素壁へ、一幀の画幅を懸けさせました。",
              "citation": {
                "source": "秋山図",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の間の画幅は三百円の品を二百円の品に更ても生存上に影響はないから残の百円を以て勝手道具を買てみ給え。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "見上げるところの正面に、とても広大なる画幅がかかっていて、その周囲には、この脇侍をつとめるらしい一尺さがった画像があるのであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮世絵の板画が肉筆の画幅に見ると同じき数多の色彩を自由に摺出し得るまでには幾多の階梯を経たりしなり。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の家の床の間に画幅の掛けられているのを見て、直にその家の主人を以て美術の鑑賞家となす事の当らざるに似ているであろう。",
              "citation": {
                "source": "葛飾土産",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "清長一枚以上板物俊満※画幅。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之二大正七戊午年",
                "note": "青空文庫"
              }
            },
            {
              "text": "早朝より竹田屋の主人来り、兼て凖備せし蔵書の一部と画幅とを運去る。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之二大正七戊午年",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の間に渡辺省亭筆蜆の画幅をかけたり。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月廿二日　花月主人平岡氏、田中訥言の画幅を多く蔵せらるゝと聞き、徃きて観る。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "終日樹の下に画幅や古書を投棄てて置いても乾いた枯葉の為に少しも湿める虞がなかった。",
              "citation": {
                "source": "写況雑記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の間には松飾に雪のつもった画幅の懸けられてある下に、盆栽の木瓜がもう散るばかりになっている。",
              "citation": {
                "source": "春雨の夜",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　老妻は正月の画幅を下して箱の中にしまうと、老人は新に掛けた書幅の文字を読下しながら、「男爵も此の時分はまだ御盛であったな。",
              "citation": {
                "source": "春雨の夜",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "其奥に筋骨を剥き出した黒部五郎岳が火山のような長い美しい裾の斜線を見せて、秀麗な円錐形に聳えているのがこの大画幅に点睛の妙を極めて人を叫ばせずには置かない。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "くはしく云へば、退役軍人のひつそりした正房の壁にかゝつてゐる画幅の前で出逢つたのだ。",
              "citation": {
                "source": "南京六月祭",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその黒い眼の柔かに湿ったぼんやりしさ加減が、夢のような匂を画幅全体に漂わしていた。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "愁ひつつ丘に登れば花｜茨「愁ひつつ」という言葉に、無限の詩情がふくまれている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄いろのがだんだん向ふへまはって行って、青い小さいのがこっちへ進んで来、間もなく二つのはじは、重なり合って、きれいな緑いろの両面凸レンズのかたちをつくり、それもだんだん、まん中がふくらみ出して、たうたう青いのは、すっかりトパースの正面に来ましたので、緑の中心と黄いろな明るい環とができました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "面倒くさい靴下はポケットへ押し込め、ポケットがふくれて気持ちがいいぞ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
