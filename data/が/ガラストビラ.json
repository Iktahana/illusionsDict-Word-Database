  {
    "uuid": "20fa921c-890a-55e4-aa87-290fae1ff767",
    "entry": "ガラス扉",
    "reading": {
      "primary": "ガラスとびら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
