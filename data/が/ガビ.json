    "definitions": [
      {
        "index": 1,
        "gloss": "penciling eyebrows",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "平門の画眉涅歯も唯是瓦鶏土犬のみ。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "画眉鳥が杉や川楊などの最上端にとまって、青い天地を眺めつつ啼く声まで、我々にはイッピツケイジョウツカマツリソロというように聴えた。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野鳥雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "早天には普通百舌鳥の合間に、画眉鳥の声を聴いたものであった。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野鳥雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して画眉鳥の雄ばかりは、家庭を女に任せていつでも歌っている。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野鳥雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "和歌山県の日高郡、殊に山路と称する山中の村々では、スズメといえば我々のホオジロ（画眉鳥）のことで、鶯をホケジロといい、雀は即ちイタクラと呼んでいた。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野鳥雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "」不意に松本がびっくりして、割れるように叫んだ。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　膝の猫がびっくりして飛び下りた。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "白地の浴衣を着た女、酒屋の下女を啖い殺した女、小間物屋の女房を啖い殺した女、それが又もやここにあらわれて、赤裸の若い女を啖い殺したのであろうとは、誰の胸にもすぐに浮がび出る想像であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲間の工人から、工場での美人とされている、しかし、日本人が見ると、どうしても美しいとは思われない、平たい顔の紅月莪がびっくりして身を引いた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上へ、陰気くさい雨がびしょ／＼と降り注いでいた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里がびく／＼しながら、番頭の方へ近づくと、「あ、そうですか。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二人は変な顔をしながら黙ってしばらくその音を呼び寄せて聞いてゐましたが、俄かに善コがびっくりする位叫びました。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもてはうすくらくてみぞれがびちょびちょ降っていました。",
              "citation": {
                "source": "手紙　四",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると犬神はぎゅっとタネリの足を強く握って「ほざくな小僧、いるかの子がびっくりしてるじゃないか。",
              "citation": {
                "source": "サガレンと八月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し私にはそれがびんと響いた。",
              "citation": {
                "source": "矛盾の樣な眞實",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると人がびっくりして自分の顔を見るような気がするのである。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また映画ではここでびっこの小使いが現われ、それがびっこをひくので手にさげた燭火のスポットライトが壁面に高く低く踊りながら進行してそれがなんとなく一種の鬼気を添えるのだが、この芝居では、そのびっこを免職させてそれを第二幕の酒場の亭主に左遷している。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝露で、下駄がびしょぬれである。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとじいさんの眼だまから、虎のように青い火花がぱちぱちっとでたとおもうと、恭一はからだがびりりっとしてあぶなくうしろへ倒れそうになりました。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛙がちゃうど五百ばかりはねたときもう一ぴきの蛙がびっくりしてこっちを見てゐるのに会ひました。",
              "citation": {
                "source": "畑のへり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　白熊がびっくりして立ちどまりました。",
              "citation": {
                "source": "月夜のけだもの",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ラクシャン第一子がびっくりして叫ぶ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その声にラクシャンの第二子がびっくりして眼をさまし、その長い顎をあげて、眼を釘づけにされたやうにしばらく野火をみつめてゐる。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "グリーンランドの成金がびっくりする程立派な蛋白石などを、二週間でさがしてやらうなんてのは、実際少し軽率だった。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二人は変な顔をしながら黙ってしばらくその音を呼び寄せて聞いていましたが、俄かに善コがびっくりする位叫びました。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その声にラクシャンの第二子がびっくりして眼をさまし、その長い顎をあげて、眼を釘づけにされたようにしばらく野火をみつめている。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "グリーンランドの成金がびっくりする程立派な蛋白石などを、二週間でさがしてやろうなんてのは、実際少し軽率だった。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　楢夫がびっくりしました。",
              "citation": {
                "source": "さるのこしかけ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔が玉のような乳房にくッついて、緋母衣がびっしょり、その雪の腕にからんで、一人は美にして艶であった。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小十郎がびっくりしてうしろを見たらあの夏に眼をつけておいた大きな熊が両足で立ってこっちへかかって来たのだ。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
