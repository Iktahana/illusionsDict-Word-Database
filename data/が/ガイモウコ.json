        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "日本ガ東清鐵道ヲ取得シテ、極東西比利亞トヲ結合スル時、内外蒙古ハ支那自ラノ力ヲ以テ露國ノ侵略ヲ防禦スルヲ得ベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "露西亞ノ外蒙古進出ニ押サレテ日本亦内蒙古ニ進出シテ防備ヲ試ミントスル軍閥ノ支那保全策ハ、或ル程度ニ於テ支那ヲ保全シツツ或ル程度ニ於テ支那ヲ分割スル者。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "特ニ「セミヨノフ」輩ヲ用ヒテ内外蒙古ノ獨立ヲ策シツツアル如キハ誠ニ小策士ノ陰險手段。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「トルキシブ」ほど有名ではなくても中央アジア外蒙古の生産と文化開発の映画で世界に示されている。",
              "citation": {
                "source": "イタリー芸術に在る一つの問題",
                "author": "――所謂「脱出」への疑問――",
                "note": "青空文庫"
              }
            },
            {
              "text": "外蒙古と内蒙古の国境が北へ向かつて興安嶺につき当つた辺から東へ流れ出してゐます。",
              "citation": {
                "source": "朝おき雀",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　蒙古は外蒙古と内蒙古とに分れ、その境域は内蒙古だけでも約七万五千方里である。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒙古通の人達は云はれる、「外蒙古へ行かねば蒙古の真相は味はへない」と。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の蒙古に就ての予備知識はこんなに乏しいのであるが、一部の地方にせよ実際の風土に接して見ると、百聞よりも一見の感得の確実さが喜ばれ、また之に由つて外蒙古の事情も大いに想像の根拠が得られる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年は夏から晩秋へかけて満州の東西南北を釣りめぐり、外蒙古境まで魚影を慕って旅したほどである。",
              "citation": {
                "source": "わが童心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェート治下の外蒙古軍まで、越境の沙汰に屡々及んだことは周知の通りなのである。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハルハ地方の外蒙兵越境事件に就いて満州帝国が外蒙古と交渉中の処を、又々ハイラステンゴールに於ける同様な事件が惹き起こされた。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャハルに於ける日本軍の進出を検べるというらしかったが、特にチャハルは大分外蒙古に近いのだろう。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴィエト治下の外蒙古軍まで、越境の沙汰に屡々及ぶことは周知の通りなのである。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャハルに於ける日本軍の進出を検べるらしいが、特にチャハルは大分外蒙古に近いのだろう。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペートル大帝以降絶えず露国の人民は外蒙古に於て蒙古人、韃靼人と触接している。",
              "citation": {
                "source": "三たび東方の平和を論ず",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち外蒙古の如き、河に汽船が通ずる。",
              "citation": {
                "source": "三たび東方の平和を論ず",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
