        "examples": {
          "standard": [
            {
              "text": "旅行には、ポータブル充電器や小型カメラといったガジェットが欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しいスマートウォッチは、健康管理に役立つ様々なガジェット機能が搭載されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このガジェット、見た目は地味だけど、すごく便利なんだよ。」と彼は勧めてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は常に最新のガジェットに目がない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "初代のパームトップが出た頃には、手書きなどできの悪いＳＦ映画から引っ張りだしてきた実用性のないガジェットだと言い張ろうと思えば言えたろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
