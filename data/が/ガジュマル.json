    "definitions": [
      {
        "index": 1,
        "gloss": "Chinese banyan (Ficus microcarpa)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
