          "literary": [
            {
              "text": "十六　外人部隊　たいへんに前評判のあった映画であるが自分にはそれほどでなかった。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし陸軍少尉の制服ははじめて迢空の眼に、映画に見る好ましい外人部隊のある一士官の恰好を捉えることができた。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは荊州以来、禄を送って、領外の随所に養っておいた浪人部隊と、南方そのほかの異境から集めて、趙雲や馬忠などに、ここ一年調練させていた外人部隊とであった。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
