          "standard": [
            {
              "text": "複雑なネットワークの仕組みを、ホワイトボードに簡単な概念図を描いてチームに共有した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "企画書の冒頭に載せた概念図のおかげで、役員たちもすぐに新事業のメリットを理解してくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この図はあくまで概念図なので、パーツの細かい寸法や正確な配置は気にしないでください」と補足した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "教科書の隅にある概念図を眺めているうちに、ようやく光合成のプロセスが頭に入ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "自分は今までの諸記録、殊に『関西学生山岳聯盟報告』第二号のスケッチマップ、及び『山と渓谷』第九号の黒田正夫氏のものを参考とし、自分たちの観察した所に基いて概念図を作って見た。",
              "citation": {
                "source": "一ノ倉沢正面の登攀",
                "author": "小川登喜男",
                "note": "青空文庫"
              }
            }
          ]
        }
