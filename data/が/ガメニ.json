[
  {
    "uuid": "7b7c0b22-95af-512d-adf9-a05255b1c4b2",
    "entry": "がめ煮",
    "reading": {
      "primary": "がめに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
