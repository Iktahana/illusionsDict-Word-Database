        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新品の画学紙に、大きな構図を描き始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "先生が「この画学紙はデッサンに最適だ」と勧めてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "鉛筆で描いた絵が、画学紙の白い表面によく映える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は大切な作品を、質の良い画学紙に描いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」　かれは画学紙に描いた似顔画を、わたしに贈りたがつた。",
              "citation": {
                "source": "岬の春霞",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり厚い画学紙にすり切れた筆で乱雑にこう走り書きがしてあった。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時に、君は一冊のスケッチ帳（小学校用の粗雑な画学紙を不器用に網糸でつづったそれ）と一本の鉛筆とを、魚の鱗や肉片がこびりついたまま、ごわごわにかわいた仕事着のふところにねじ込んで、ぶらりと朝から家を出るのだ。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして粗末な画学紙の上には、たくましく荒くれた君の手に似合わない繊細な線が描かれ始めた。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔自分が柔い鉛筆と画学紙とを携え、築地の居留地の方まで橋や建物を写すことを楽みにして出掛けたところだ。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "引返して勝手の方へ行つて見ると、叔父さんは流許で雨を見て居るし、長ちやんは板の間へ画学紙と色鉛筆を持出して何かしきりと子供らしい画をかいて居る。",
              "citation": {
                "source": "出発",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十銭茂吉書物代画学紙共。",
              "citation": {
                "source": "念珠集",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "画学紙の絵を手にとって眺めながら母が、「うちのも、はやくこんなに描けるようになるといいんですけれど」　単にこれだけの事にすぎないが、妙にはっきり覚えているのだ。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
