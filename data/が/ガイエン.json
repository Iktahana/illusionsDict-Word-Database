    "definitions": [
      {
        "index": 1,
        "gloss": "outer garden",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "木綿をきり売りの手拭を下谷の天神で売出した男の話は神宮外苑のパン、サイダー売りを想わせ、『諸国咄』の終りにある、江戸中の町を歩いて落ちた金や金物を拾い集めた男の話は、近年隅田川口の泥ざらえで儲けた人の話を想い出させて面白い。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三造がはいって行くと、伯父は寝顔を此方へ向けて、真先に、ちょうどその頃神宮外苑で行われていた極東オリンピックのことを彼に訊ねた。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀杏の葉の散る神宮外苑をうそ寒く歩いてゐた時も、島民共と石燒のパンの實にむしやぶりついてゐる時も、お前は何時もお前だ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀杏の葉の散る神宮外苑をうそ寒く歩いていた時も、島民どもと石焼のパンの実にむしゃぶりついている時も、お前はいつもお前だ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　直きに外苑へ来た。",
              "citation": {
                "source": "女流作家",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "その左の方に外苑の時計台と枯木の梢が茫と冬日に煙ってゐた。",
              "citation": {
                "source": "残雪",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "新宿は特に帰えりに廻わってもらうことにして、自動車は淀橋から右に入って、代々木に出て、神宮の外苑を走った。",
              "citation": {
                "source": "独房",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで町の有志ともはかって、十万円ばかりの余算で、内苑外苑からすっかり改築して、伊勢まで行かれない人々は、此処へ来て、お参〔以下欠〕　四月二十七日　今日大学の大通りを散歩して、計らずも、久しい間求めて居たリビングストン伝を見出す事が出来た。",
              "citation": {
                "source": "日記・書簡",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨日の早慶戦では、住んでいるところが外苑から近いので、夕方五時すぎ用があって外出したら、後から後からひどい群集で、電車にものれず、暫く往来でこの人出を見物しておりました。",
              "citation": {
                "source": "現実の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "種々の点から、今東京に居遺る大多数は希望を持った熱心に励まされて働いているが、昨夜のように大風が吹き豪雨でもあると、私はつい近くの、明治神宮外苑のバラックにいる人々のことを思わずにいられなくなる。",
              "citation": {
                "source": "私の覚え書",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……病院を出ると、彼は外苑の方へふらふらと歩いて行つた。",
              "citation": {
                "source": "氷花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "新吉原は浅草公園を外苑地帯として根を張り、あとから移転していった芝居――山之宿の市村座、鳥越の中村座など、激しい時代転歩にサッサと押流され、昔日の夢のあとは失なってしまったが、堺町、葺屋町の江戸三座が、新吉原附近に移るには間があった。",
              "citation": {
                "source": "テンコツさん一家",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "――神宮｜外苑の方へ行く道の、一寸高い段々のある灰色の建物が警察だった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "音樂會がはてて暗い神宮外苑を伊津子はバスの停留所の方ヘ音樂會歸りの人たちにまじつて歩いてゐた。",
              "citation": {
                "source": "玄關の手帖",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二日ばかり前、或る対校野球試合が外苑グランドであった。",
              "citation": {
                "source": "一本の花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして明治神宮外苑のトラックに、スポーツの興味を集めている。",
              "citation": {
                "source": "四谷、赤坂",
                "author": "宮島資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、靄がこめて居る外苑内をぬけ塩町に散歩にゆく。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "安成君も一緒に、繁治さんに待って貰って外苑を三十分ばかり散歩した。",
              "citation": {
                "source": "日記",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○窓をあけて見ると、すぐ前の庭の上にはしずかに雨が降っているが、外苑の方を見ると、風で雨脚が白く吹きとばされるのが木立の前に見える。",
              "citation": {
                "source": "日記",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○むこうの外苑のこまかい椎の木の葉が澄んだ日の光にこまかく光って、小豆色っぽい光をてりかえしている。",
              "citation": {
                "source": "日記",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝窓をあけたら外苑の木立の間がうっすり紫っぽくけむっているようであった。",
              "citation": {
                "source": "日記",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いきの構造」　　「科学の詩人ファブルの一生」　　ストリンドベルグ「海辺の漁夫」四月十五日（水曜）　○春の外苑の風景。",
              "citation": {
                "source": "日記",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○栄さんと外苑を散歩。",
              "citation": {
                "source": "日記",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽をうけて光っている樫その他のこまかい葉の色の美しさ、遠くの外苑の木立の葉が深くかさなって小豆色っぽく反射している美しさ。",
              "citation": {
                "source": "日記",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔欄外に〕　十二時頃から四十分ばかり外苑のベンチで日向ぼっこをする。",
              "citation": {
                "source": "日記",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔欄外に〕　朝十時頃から例により外苑に出かけたところ、曇って風があるので二時間もたず、一時間でかえって来た。",
              "citation": {
                "source": "日記",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月二十四日（金曜）　○十一時すぎにスエをつれて外苑のいつもの円いところへゆきブラブラ歩こうとゆきかけると、右手のベンチに猪垣が和服を着て腰かけている。",
              "citation": {
                "source": "日記",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そういうひとも必要だということは分るが」云々　◎生活感情の中に共通な或感情、情熱を持たぬ男（Ｋ）　持つ男（父）〔欄外に〕　○外苑の楓、八分どおり新緑、美しい。",
              "citation": {
                "source": "日記",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時は外苑競技場が未完成で、日本の主要な競技会は駒場農大の二百八十米コースの柔くてデコボコだらけのところでやる。",
              "citation": {
                "source": "安吾巷談",
                "author": "世界新記録病",
                "note": "青空文庫"
              }
            },
            {
              "text": "爽凉の気、外苑あたりの叢園に漂ふ昭和二年の秋の一日である。",
              "citation": {
                "source": "呉清源",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
