        "examples": {
          "standard": [
            {
              "text": "コンクールで受賞した時の、額入りの賞状を壁に飾っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "友人へのプレゼントに、みんなで撮った額入りの写真を用意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "そのレストランには、有名な俳優のサインが書かれた額入りの皿が飾ってあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "お気に入りの映画の額入りポスターを自分の部屋に飾りたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "家具類はひどく古びた黄色い木製品で、ぐっと曲ったもたれのある大きな長椅子と、その前に置かれた楕円形のテーブルと、窓と窓との間の壁に据えられた鏡つきの化粧台と、壁ぎわの椅子数脚と、小鳥を持っているドイツ娘を描いた黄色い額入りの安っぽい絵――これが全部であった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "椅子、鏡、黄色い長椅子、額入りの画。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い造花や黒リボンのついた額入りの写真などが持ち込まれた。",
              "citation": {
                "source": "金山※話",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
