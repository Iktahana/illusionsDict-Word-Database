[
  {
    "uuid": "b6d4eccd-abe5-5d4f-9442-0153cff2d403",
    "entry": "凱旋",
    "reading": {
      "primary": "がいせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "triumphant return",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "首里に凱旋して来た謝源は今夜の宴を開いたのであつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちかく凱旋するのです。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽い水蒸気が、凱旋門からオベリスクの距離を実測よりやや遠く見せている。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る養殖家の話では巴里で一年に食べられる蝸牛の数は約七千万匹で、それを積み重ねると巴里の凱旋門よりも高くなるというから大したものである。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼女の凱旋門、恐るべきことがある。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩野泡鳴には凱旋将軍を讃美した詩がある。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等学校では私もよく食った凱旋饅頭を五十も食って、あとでビットル散をなめたりしていたらしい。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "採って来たたくさんの標本をもってその巨きな建物の間を自動車で走るとき、わたくしはまるで凱旋の将軍のような気がしました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇ましい凱旋だと云ひたいが実はすつかり参つて来たのだとにかくあすこは寒い処さ。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに脚気の原因があんまりこつちを追ひかけて砂を走つたためなんださうしてみればどうだやつぱり凱旋だらう。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀元千八百九十五年―月―日の凱旋祭は、小生が覚えたる観世物の中に最も偉なるものに候ひき。",
              "citation": {
                "source": "凱旋祭",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "凱旋門は申すまでもなく、一廓数百金を以て建られ候。",
              "citation": {
                "source": "凱旋祭",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こは月のはじめより造りかけて、凱旋祭の前一日の昼すぎまでに出来上り候を、一度見たる時のことに有之候。",
              "citation": {
                "source": "凱旋祭",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　あくれば凱旋祭の当日、人々が案じに案じたる天候は意外にもおだやかに、東雲より密雲破れて日光を洩し候が、午前に到りて晴れ、昼少しすぐるより天晴なる快晴となり澄し候。",
              "citation": {
                "source": "凱旋祭",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　別に凱旋門と、生首提灯と小生は申し候。",
              "citation": {
                "source": "凱旋祭",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉五郎は凱旋の将軍のように歓迎された。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は並木のシャン・ゼリゼーまで出たが闇一筋の道の両はずれに一方はコンコールドの広場に電飾を浴びて水晶の花さしのように光っている噴水を眺め、首を廻らして凱旋門通りの鱗のように立ち重なる宵の人出を見ると軽い調子になって彼女は言った。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が凱旋した時には、必ず添わしてあげるつもりだ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに東北が平定して官軍も凱旋した。",
              "citation": {
                "source": "掠奪した短刀",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お肯入れ無く、思切った業をなさりゃ、表向きに坐込む、と変った言種をしたために、奥さんも思案に余って、気を揉んでいなすった処へ、思いの外用事が早く片附いて、英臣さんが凱旋でしょう。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペテロやヨハネやバルトロマイ、そのほか全部の弟子共は、ばかなやつ、すでに天国を目のまえに見たかのように、まるで凱旋の将軍につき従っているかのように、有頂天の歓喜で互いに抱き合い、涙に濡れた接吻を交し、一徹者のペテロなど、ヨハネを抱きかかえたまま、わあわあ大声で嬉し泣きに泣き崩れていました。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "凱旋の女王の如く、誇らしげに胸を張って、ドミチウスや、おまえの世の中が来た、と叫び、ネロを抱いて裸足のまま屋外に駈け出し、花一輪無き荒磯を舞うが如く歩きまわり、それから立ちどまって永いことすすり泣いた。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里では凱旋門の方からシャンゼリゼーの右側の歩道を通って料理店ブーケの前を通って公園の方へ行こうとすると屹度こういう思いをした。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "聯隊長には上海よりの凱旋將校對座し、山田耕筰氏その左に在り。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "聯隊長には上海よりの凱旋将校対座し、山田耕筰氏その左に在り。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとお子さまは、ちゃんと筑紫へお凱旋になってからご無事にお生まれになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "荘王は、凱旋の時に夏姫を連れ帰った。",
              "citation": {
                "source": "妖氛録",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "元就は斯くて十月五日に二十日市の桜尾城に於て凱旋式を挙行しているが、彼は敵将晴賢の首級に対してもこれを白布にて掩い、首実検の時も、僅かに其白布の右端を取っただけで、敵将をみだりに恥かしめぬだけの雅量を示している。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "凱旋の翌日、獲た首を検したのに二千五百余あった。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "楠正成、名和｜長年以下の凱旋諸将を従えられ、『増鏡』に依ると、其の行列は二条富小路の内裏から、東寺の門まで絡繹として続いたとある。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
