    "definitions": [
      {
        "index": 1,
        "gloss": "orchestra",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "光輝あるわが金星音楽団がきみ一人のために悪評をとるようなことでは、みんなへもまったく気の毒だからな。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "金星音楽団の人たちは町の公会堂のホールの裏にある控室へみんなぱっと顔をほてらしてめいめい楽器をもって、ぞろぞろホールの舞台から引きあげて来ました。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃ僕はちょっと、あの（と歌声のほうを指さし）チンピラの音楽団のほうへ行って、妹をつかまえて、事の真相を問いただしてみましょう。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼は、土地の軍楽隊に籍を置いたり、けちな管弦楽団の臨時雇の指揮をしたりして、口を糊しながら、娘の寿子を殆ど唯一人の弟子にして「津路式教授法」のせめてものはけ口を、幼い寿子に見出して来たのであった。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "名前はジェイムズ・スミス、旧帝劇楽団の指揮者でした。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に又、ＭＭＭが飽かれたかして、後には単に「享楽団」と呼ばれるようになった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "男性の享楽団ＭＭＭも引っくり返ってＷＷＷ団となった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＭＭＭが地震と共に音も沙汰もなくなって、その代りに少女ばかりで組織された享楽団なるものが現われたのであった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途中の経過としてＭＷＷとか何とかいった時代があったかどうかわからぬが、男の享楽団の名は消え失せたらしく、どこの家庭にも、Ｍよりとか、Ｓよりとかいう名前の手紙が来たという事を聴かなくなった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、その享楽団の団長は一人の私立高女の上級生で、その団長の指揮に依ってその団員は盛に享楽事業を拡張しているという噂が、どことなく耳寄りの人に耳寄って来た。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その不良少女享楽団長の名前を聴くと、記者は思わず膝を打った。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "不良少女享楽団長　××女学校の名は日本中に響いている。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは東京随一の不良少女享楽団が全部揃いで持っているもので、どこかに合印か何かあるらしいがハッキリとわからない。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が支配している享楽団の性質を探って見ると、更に奇怪なことが多い、　第一、享楽団という名前が随分古くからあるが、これは仮りにその団体の正体を指した通り名で、実際は始終名前を換えているらしく、何を目標に、どこで会合しているのか、記者の力では探り得なかった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "享楽団というのは、名の通り少女達が男性を誘惑して享楽する団体で、それ以外の事は何もしないらしい。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の話によると、不幸な夢殿村には商店もあれば旅館もあり、労働者もいれば音楽団もあるが、皆温泉を中心にして同病のものばかりから成っていて、結婚も彼らの間で行われる習慣だから、ぼろぼろに朽ちた枯葉の中から若芽の燃え出たように新鮮な子供達も飛び廻っているという。",
              "citation": {
                "source": "馬車",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルでは音楽団が客に料理を運び出した。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもそういつてわるければ技術の貧困ならざる楽団は高価で雇いにくいからといいかえておく。",
              "citation": {
                "source": "映画と音楽",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば新交響楽団の演奏会のおりおり、ハープの弾奏者として舞台に現れる加藤泰通子夫人があります。",
              "citation": {
                "source": "現実の道",
                "author": "――女も仕事をもて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（こんにちではソヴェトからの帰還者のうちから、楽団を組織する人々があらわれ、捕虜生活という不自然な条件を通じてさえもなお社会主義社会のプラスを理解し、身につけて来た人々が日本の中にふえたが。",
              "citation": {
                "source": "「道標」を書き終えて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "並木道にも音楽堂があって、労働者音楽団の奏する音楽が遠くまで、夜おそくまで聞える。",
              "citation": {
                "source": "ソヴェト労働者の夏休み",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな連中が演奏しているかと見ると、鳥打帽をかぶったままの労働者音楽団です。",
              "citation": {
                "source": "ソヴェト同盟の音楽サークルの話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "メーデーのデモには、各工場が自分たちの音楽団を先頭に立て、勇ましい行進曲とともにやって来る。",
              "citation": {
                "source": "ソヴェト同盟の音楽サークルの話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "極く初歩的であったこの要求が、だんだん組織され技術的にも高まって、今日では自立音楽団と匹敵するほど自立劇団が生れている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "純音楽　日本の指導的なオーケストラは二〇年の歴史を持っている日本交響楽団がある。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このオーケストラは一二〇人の楽団員をもち三人の日本人指揮者によって指揮され、毎週二回のラジオ放送と月二回の定期演奏会を行っている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京フィルハーモニー・オーケストラはアーニー・パイル交響楽団となった。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーニー・パイル交響楽団はアメリカの許可によって第一回公開演奏会を行った。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽音楽　ダンス・ホール、キャバレー、ショウ、アトラクションなどとしての軽音楽は大流行で、無数の小軽音楽団体が出来ている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここがくだんの街だ。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
