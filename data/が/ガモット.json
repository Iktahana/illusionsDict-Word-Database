        "examples": {
          "standard": [
            {
              "text": "このモニターは、広大なガモットに対応しており、より豊かな色彩を表現できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プロのフォトグラファーにとって、カメラとプリンターのガモットの一致は重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "印刷では、ディスプレイで表示されるガモットと実際に印刷される色の範囲が異なる場合がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "次世代のディスプレイ技術は、さらに広いガモットを目指している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "予ハ鏡ノ中ノ顔ガモット醜悪デアッテクレタラ、颯子ガ尚コノ上ニモ優秀ニ見エタヾロウニト残念ニ思ウ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
