        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "地元のイベントで、似顔絵を描く画伯が出店していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人の画伯が個展を開くことになり、私も手伝いに行く予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は普段はサラリーマンだが、週末は画伯として絵を描く活動をしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
