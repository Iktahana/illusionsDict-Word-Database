    "definitions": [
      {
        "index": 1,
        "gloss": "master painter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あの画伯の作品は、見る者の心を惹きつける力がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は若くして画伯の称号を得て、美術界の期待の星となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "画伯の指導のもと、デッサンを学ぶ機会に恵まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "不折、黙語、外面諸画伯の挿画や裏絵がまたそれぞれに顕著な個性のある新鮮な活気のあるものであった。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしか浅井和田両画伯の合作であったかと思うがフランスのグレーの田舎へ絵をかきに行った日記のようなものなども実に清新な薫りの高い読物であった。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "出口へ出るとそこでは下足番の婆さんがただ一人落ち散らばった履物の整理をしているのを見付けて、預けた蝙蝠傘を出してもらって館の裏手の集団の中からＴ画伯を捜しあてた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミルネル画伯はあの令嬢に大相取り入るようだったなんぞと云っているのでございましょうよ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "関東地震の起った瞬間に私は上野の二科会展覧会場の喫茶店で某画伯と話をしていた。",
              "citation": {
                "source": "家庭の人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に画工――画家、画伯には違ひないが、何うも、画工さんの方が、分けて旅には親味がある（以下、時に諸氏に敬語を略する事を恕されたし。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから画伯デュラーの住居の跡も見ましたが、そこの入場券が富札になっています。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本でのんだいちばんうまいコーヒーはずっと以前にＦ画伯がそのきたない画室のすみの流しで、みずから湯を沸かしてこしらえてくれた一杯のそれであった。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに準社友の芋倉長江画伯を取り合わせると古今の名コンビで、弥次喜多以上の悲惨事を到る処に演出する。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ当の芋倉長江画伯が、死人のような青い顔に宗匠頭巾、灰色の十徳という扮装で茫々然と出社して来た。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "遣ったら、長江画伯イヨイヨ茫然とした淋しい顔になって眼をパチパチさせた。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいったい画伯とか先生とかのくっ付いた画かきが大きらいなんだけれども、……いやよ、ほんとうにあいつらは……なんていうと、お高くとまる癖にひとの体にさわってみたがったりして……けれどもお金にはなるわね。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に続く木川子、それにかく申す吾輩、殿軍としては五尺六寸ヌーボー式を発揮した未醒画伯、孰れも着茣蓙を羽織って、意気揚々｜塩原へこそ乗りこんだり。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "日光へ着くと、未醒画伯は弟妹首を延ばして待っている郷家へ一夜の宿り、吾々三人はボロ洋服に茣蓙を引っ掛けて小西別館へと入り込んだ。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "▲雨中の突進　翌朝、未醒画伯九時に雨を冒して来たり。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨が歇んだので未醒画伯戦場ヶ原の真中へ三脚を立て、悠々写生を初めたところが、折悪しく吹き捲くって来た一陣の烈風に、画板を吹っ飛ばされ、絵の具は躍り出す、いやはや大｜狼狽。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "一心に写生をやっている未醒画伯を指して「あれはなんだ」と聞かれ、将軍反り返り、得意になって曰く、「ヒー、イズ、アクター」　西洋人、目を丸くして未醒氏の顔を見る。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍、アーチストとアクターとを何の気なしに滑らして、色の黒い未醒画伯とうとう俳優となってしまった。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "▲未醒画伯、一命を棒に振らんとす　十九日、朝の内に付近の景勝を探ろうと、宿の女の子を案内に吹割へ行ってみる。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだ、一つ峠の凸凹道を馬上で越そうではないか」といい出したのは未醒画伯。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "先頭に立った吾輩は振り顧見ると、三番目に乗って来た未醒画伯、馬から真逆様に落ちて、大地へ四ツん這いになっておる。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの旅館丸杉は、以前未醒画伯の宿ったことがある家だという。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで未醒画伯と木川子が大角力に向い、吾輩と将軍が活動写真の方へ行った。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中より未醒画伯、髯将軍は白根噴火口へ回るという意気込み。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "白煙｜濛々と立昇る地獄穴｜溶岩を覗いて、未醒画伯と髯将軍、快哉を叫んで躍り上がったところが、忽ち麓から吹き上ぐる濃霧に包囲されて、危うく足踏み外し白煙中へ捲き込まれんとし、二人、一生懸命｜巌に獅噛み付いて、ようよう命を陥さずに済んだそうである。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "出発は八月十日、同行は差当り五人、蛮カラ画伯｜小杉未醒子、髯の早大応援将軍｜吉岡信敬子、日曜画報写真技師｜木川専介子、本紙記者｜井沢衣水子、それに病気揚句の吾輩である。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内に未醒画伯の巨大なる躯幹がノッソリ現われると、間もなく吉岡将軍の髯面がヌッと出て来る。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆゑ、絵本の画伯もつい、（蓬莱も竜宮も、同じ様な場所なんだから）浦島さんの案内役も、この石亀に違ひないと思ひ込むのも無理のない事である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉田老画伯は心利きたる人なれば、やがて屋台店より一本の小さき箒を借り来り、尚も間断なく散り乱れ積る花びらを、この辺ですか、この辺ですか、と言いつつさっさっと左右に掃きわけ、突如、あ！",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉田さん、どうか老生を殴って下さい、と笑いながら頬を差出申候ところ、老画伯もさるもの、よし来た、と言い掌に唾して、ぐゎんと老生の左の頬を撃ちのめし、意気揚々と引上げ行き申候。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
