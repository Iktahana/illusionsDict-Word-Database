        "examples": {
          "standard": [
            {
              "text": "バロック音楽のコンサートで、軽快なガボットが演奏され、会場は拍手で包まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "舞踏会では、貴婦人たちがガボットのリズムに合わせて優雅に踊っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は古い楽譜を見ながら、ピアノでガボットを完璧に弾きこなした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "セロのガボットが華やかに日光室から聞えて来た。",
              "citation": {
                "source": "花園の思想",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "花冷えにうす冷たく汗のひいて来たころ、梢に縛りつけられたラジオから、ガボットが聞えて来た。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
