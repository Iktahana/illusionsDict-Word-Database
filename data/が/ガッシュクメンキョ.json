        "examples": {
          "standard": [
            {
              "text": "夏休みに合宿免許を取得し、無事、運転免許証を手に入れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「合宿免許って、学科と技能の教習がギュッと詰まってるから、短期間で取れるんだよね。」「そうそう、計画通りに進めば、2週間くらいで卒業できるらしいよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "初めての運転で緊張したが、合宿免許の教官の丁寧な指導のおかげで、少しずつ自信がついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、運転に自信がなかったので、合宿免許でみっちり練習することにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
