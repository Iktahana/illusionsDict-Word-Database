        "examples": {
          "standard": [
            {
              "text": "大学の新入生歓迎会には、多くの学部学生が参加していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "研究室では、学部学生が大学院生のアシスタントとして実験を手伝っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "就職活動を控えた学部学生たちは、キャリアセンターで模擬面接を受けていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "最初は哲学部だけで大学院学生に文学と科学を教え学部学生のためのカレッジが付属していた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "」医学部学生は宮殿の前を散歩する積りで彼の腕をつかんで言った。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕達はいつだって友達だ」「それはいいとして」と医学部学生が答えた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし彼はあえいでるぜ」　医学部学生はこの言葉を冗談と捉えたが、それは冗談ではなかった。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "カラマツの脂と同じように下剤作用があるんだ」医学部学生が声を落として言った。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君は僕が確認に行きたいと思っていた疑念が根拠のあるものだということを明確にした」　法学部学生の長い散歩は厳粛だった。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポワレを除いた誰もが目配せで医学部学生の提案に同意した。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
