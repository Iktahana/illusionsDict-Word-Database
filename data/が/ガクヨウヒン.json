[
  {
    "uuid": "a4d14861-ef86-547d-a40b-6ecb3e50bd33",
    "entry": "学用品",
    "reading": {
      "primary": "がくようひん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
