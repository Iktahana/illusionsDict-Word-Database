    },
    "definitions": [
      {
        "index": 1,
        "gloss": "school supplies",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新学期が始まる前に、新しいノートやペンなどの学用品を買い揃えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地域住民からの寄付で、経済的に困難な家庭の子供たちに学用品が贈られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "娘はキャラクターものの学用品ばかり欲しがるので、困ってしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「それじゃお父つあん、町へいったらついでに学用品屋で由太に王様クレヨンを買って来てやってな。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しゆくと鉄柵でかこまれた大きい小学校があって、その前に学用品を売る店が道の方を向いていた。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それのみなら未だしも、成績の調査、欠席の事由、食料携帯の状況、学用品供給の模様など、名目は立派でも殆んど無意義な仕事が少なからずあるのである。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校は食事も勉強に必要な学用品類をも文部省から支給されている、子供は勉強に必要なものは学校へ行けば有る。",
              "citation": {
                "source": "露西亜の実生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "チリ紙、シャボン、マッチ、脱脂綿、ノート一冊からはじまる学用品のあれこれ、みんななくてはならない「ほしいもの」である。",
              "citation": {
                "source": "ほうき一本",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校生活で一番希望されていることは、学用品・運動靴の配給や、給食をもっとほしい、ということです、子供達が住んでいる町にのぞんでいる第一のことは、遊ぶところをつくってほしい、というねがいです。",
              "citation": {
                "source": "今年こそは",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "九年制にしてどの子供もその間は勉強出来るように国庫がその保証をしてやらなければこのインフレーションの中で月謝を払い御飯を食べさせ学用品を買ってやるということは益々貧困化して来ている親の多数にとって負担である。",
              "citation": {
                "source": "女性の歴史",
                "author": "――文学にそって――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二七年　　　　九九四二千人　一九三三年　　　一七〇〇〇千人　殆ど倍の千七百万という児童が、ソヴェト同盟では無月謝で、学用品、弁当まで国家の支給で勉強することが出来るのだ！",
              "citation": {
                "source": "五ヵ年計画とソヴェト同盟の文化的飛躍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "学用品から弁当、寒いところだから必要な防寒具まで小供のためには国家が出そうとしている。",
              "citation": {
                "source": "ソヴェト同盟の婦人と選挙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その部屋に学用品をのせた机もあるし、登美は、「どうしたのよう姉さん」とふくれ声を出して催促しながら障子をあけた。",
              "citation": {
                "source": "縫子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒坊主黒坊主と言つて私を嘲弄したことを、それから私が黒坊主と言ひそやされる反動で、奇妙な病気から鼻の両脇に六つの小鼻が鈴生に累結してゐる子供を鼻六ツ々々々と言つて泣かせ、その弱味につけこみ覗メガネの絵など高価に売りつけたり、学用品を横領したりしたことを。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどその頃、村の学用品店では、墨のようにすって使う新式の絵具を取り寄せて売っていた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく私にお菓子だの学用品などをくれもした。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘の頃は学用品や身の廻りの一寸した買物、女学校でも卒業すると、反物の選び方に腐心するやうになるが、家庭にはいつて、買物の範囲はグツとひろめられて来る。",
              "citation": {
                "source": "買ひものをする女",
                "author": "三宅やす子",
                "note": "青空文庫"
              }
            },
            {
              "text": "学用品、煙草、駄菓子を商ふ学校前の小店であつた。",
              "citation": {
                "source": "麓",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "春先から夏へかけての二回の洪水と、絶えざる降雨のために、田も畑も殆んど無収穫で、三人の子供らの学用品にさえ事欠くこの頃では、お義理のためにただ捨てる（実際、そう思われた）金など、一文も彼女は持たなかったのである。",
              "citation": {
                "source": "おびとき",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "学用品のない子ども。",
              "citation": {
                "source": "石をしょわずに",
                "author": "――わかい女教師の自殺",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでほかの学用品など買ってもらって、家へ帰ったけれど、やはり、やどかりの姿が目に残っていました。",
              "citation": {
                "source": "ある夜の姉と弟",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノートの書き方、本の扱い方、学用品の使い方の、上手下手、手入れのよしあしというようなことは、つまらないことのようですが、これがその人の勉強に対する心構えを養う大変大切なことなのです。",
              "citation": {
                "source": "鉛筆のしん",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "転校の手続きまでテキパキとやってのけ、娘達の着換えや学用品をつめたリュックを背負うと、じゃ、まいりますから、ごきげんよろしう、と二人の従妹の手をひいて、サッサと上野から発って行った。",
              "citation": {
                "source": "春雪",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡辺氏「山晴れ」は農村青年と売られて行く農村の娘との悲劇を牧歌的に抒した小篇、栗林氏「新学期」は農村学童が先生から貰った学用品を、泥棒したのだと思い込んだ両親にどやされるという短篇、どれも農村の現実的な矛盾を剔出しようとする判然とした思想と意志とを表わしている。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も文部省は被害学童へ七十万円の食事・被服・学用品・の復興費を予備金から支出したが、子供はそれでいいとして大人の方はどうなるのか。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻、何か学用品を買いに出て、戻って来たのだろう、突っ立ったまま、「今夜は午市なんだねえ、随分外は賑やかだよ」と息を弾ませて報告した。",
              "citation": {
                "source": "午市",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝起きるとすぐ、彼は、恭一の学用品を入れた雑嚢を抱えて、こっそり便所に行った。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、その翌日から、恭一は新しい雑嚢に新しい学用品を入れて、いつものとおり嬉しそうに学校に出て行くことになったからである。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三　蝗の首　由夫と竜一とは、学用品を入れた雑嚢を路に放り出して、蝗の首取り競争をはじめている。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、時として、絵本や、美しい箱入の学用品などを買って、町はずれまで、彼の帰りを見送ってくれることがあったが、そんな時には、彼は、お浜に逢っているような感じにさえなるのだった。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは学用品代として俊亮に貰ったもののあまりや、近所に牡丹餅を配ったりした場合、先方から使賃として一銭ずつ貰ったのを貯めておいたものである。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、家に帰ると、さっそく俊亮に教科書や学用品を買ってもらうようにねだった。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひととおり必要な教科書や学用品を買ったあと、次郎は絵はがきがほしいと言い出した。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
