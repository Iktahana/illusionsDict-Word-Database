[
  {
    "uuid": "cb6a54e5-c091-5ea9-be45-7c9f2347f3df",
    "entry": "ガット",
    "reading": {
      "primary": "ガット",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gut (used to make tennis rackets, violin strings, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "職人は、繊細なガットを使って古楽器の弦を丁寧に張り替えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このテニスラケットは、天然ガット特有の打球感が魅力だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "質の良いガットは、バイオリンの音色に深みを与えるとされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「フォア、ピーク（おもての空気室――船の云わば浮嚢――）のガットを開けろ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、病人の食事は、ガットから抛り込むことにするんだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気はガットで締められていたため、数年前と些も違わないで溜っていた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへは、縄梯子をガットにかけて下りるより外に方法はなかった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから病人や死体が、そこへ入るにしても、空気は、楕円形の三尺に二尺位の、ガットの穴から忍び込むより仕方がなかった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "レヤチーズたちの乗って行った船が、カテガット海峡に、さしかかると、いずこからともなく、ノーウエーの軍艦が忽然と姿をあらわし、矢庭に発砲したという。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一四六三年獨逸ノガットの堰を直すに乞食を大醉させて埋め、一八四三年同國ハルレに新橋を立てるに人民其下に小兒を生埋せうと望んだ。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "キンクスの〈ユー・リアリー・ガット・ミー〉や、ボビー・フラー・フォーの〈アイ・フォウト・ザ・ロウ〉のような、そして、この〈ゲット・オフ・オヴ・マイ・クラウド〉のような、ギターコードでゴリゴリ押しまくる曲は、慶一は、とりあえず無条件で好きになる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "〉、つぎが〈ルーズ・ザット・ガール〉、そのつぎが、えーと、〈ユーヴ・ガット・トゥ・ハイド・ユア・ラヴ・アウェイ〉、それから、アルプスだから、〈ティケット・トゥ・ライド〉で……」「そこまで！",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一はロッカーをあけて、じぶんのガットギターをひっぱりだしたが、ケースをあけるのは気がすすまない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こうでしょ」　苦労しながら、ガットギターの幅広なフレットで、佐藤は片桐のコードを再現する。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階はいいとしても、四階も三階も、ピックギターやガットギターでやるのは、「あんまり」な曲だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "フェンダー・ストラトキャスターを買う金があれば、慶一のガットギターを四〇本買って、おつりがくる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんといっても、ガットギターでロックンロールをやるわけにはいかない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈ユー……リアリー……ガット・ミー〉！",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が鮎川の大洋漁業で仕込んだ智識の中でコレハ、コレハとおどろいたのを二三御紹介に及ぶと、ラケットのガットはクジラのスジで作るものの由。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が二年ほど前、双葉屋へガットを代えてもらいに行ったら、原料不足だから本物のガットがありませんぜとナイロンのガットで間に合わされたね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "原料不足の段ではなく、日本はガットの原料国なのである。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこれを製する設備がないので、原料をアメリカへ送ってガットにして逆輸入するのである。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はガットンがバビロンの塋穴を発掘した時に、あの人と御一緒に居りました。",
              "citation": {
                "source": "金の十字架の呪い",
                "author": "チェスタートン",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以来私はミイラを発見してそれを保存しましたが全くゾッとしますわ」「ガットンはおもしろい男でした」と教授は言った。",
              "citation": {
                "source": "金の十字架の呪い",
                "author": "チェスタートン",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらたなレコーディングもはじまり、『アイ・ガット・ア・ウーマン』がヴィクターでの最初の吹きこみになった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
