[
  {
    "uuid": "9ca22d2b-8a98-56a0-96e6-5983fda23c53",
    "entry": "がれ場",
    "reading": {
      "primary": "がれば",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
