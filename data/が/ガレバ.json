    "definitions": [
      {
        "index": 1,
        "gloss": "scree slope",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "登山道の途中、大きな岩がゴロゴロ転がるがれ場を慎重に進んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この山の頂上付近はがれ場が多く、落石に注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夏でも雪が残るがれ場には、高山植物が可憐に咲いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の家は、昔がれ場だったところに建てられたらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そのとき彼はまだこの村で完全に不案内で、知る人も逃がれ場所もなく、旅のために疲れきって、まったく途方にくれてあの藁ぶとんの上に寝て、役所のどんな干渉にも身をまかせきりになっていたのだった。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、酒に限る――酒に落ちゆくよりほかののがれ場はないというに帰する。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "山谷堀に上がれば雨はら／＼と降り来るも場所柄なれば面白き心地もせらる。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く行て船室へ場を取りませねばと立上がれば婢僕親戚｜上り框に集いて荷物を車夫に渡す。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺田寅彦さんと云う方は御座らぬかとわめくボーイの濁声うるさければ黙って居けるがあまりに呼び立つる故オイ何んだと起き上がれば貴方ですかと怪訝顔なるも気の毒なり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "革鞄と毛布と蝙蝠傘とを両手一ぱいにかかえて狭き梯子を上って甲板に上がれば既に船は桟橋へ着きていたり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "はねあがれば馬は竜だ。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈の見えるところが崖の曲り角で、そこを曲がればすぐ私の旅館だ。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其雲先しりぞけば西風強く吹き、たちあがれば足をおろして雨となると伝ふ。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして夏の暑い日にその屋上へあがれば地上百尺、温度の一度や二度ぐらいは低い。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "』お絹にも話あり、いそいそと中庭から上がれば叔父の顔色ただならず、お絹もあらたまって『叔父さんただいま、自宅からもよろしくと申しました。",
              "citation": {
                "source": "置土産",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "むずかしく言えば一種霊活な批評眼を備えていた人、ありていに言えば天稟の直覚力が鋭利である上に、郷党が不思議がればいよいよ自分もよけいに人の気質、人の運命などに注意して見るようになり、それがおもしろくなり、自慢になり、ついに熟練になったのである。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひたといい出すお袋の事」と上がれば「よもすがら尼の持病を押えける」と下がるのである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小旗が風に靡いて拡がれば拡がったまま、風がなくなって垂れれば垂れたままで、少しの頓着もなく売声はもとより立てずに悠々と歩いていくのだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは宝の珠のように、かわいがればかわいがるほど光が出てくる人だってことを、私ちゃんと知っててよ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "追はうと馬にまたがればにはかに雪がどしやぶりだ。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」将軍は、急いで馬に鞍を置き、ひらりとそれにまたがれば、そこらあたりの病気の馬は、ひんひん別れの挨拶をする。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　みんなが馬にまたがれば、まもなくそこらはしんとして、たつた二疋の遅れた馬が、鼻をぶるつと鳴らしただけだ。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が夜の車室に立ちあがればみんなは大ていねむってゐる。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴婦人は恥じ且つ憤りて、頭を低れて無念がれば、鼻の先へ指を出して、不作法千万。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "恁て島田なり、丸髷なり、よきに従ひて出来あがれば起ちて、まづ、湯具を絡ふ、これを二布といひ脚布といひ女の言葉に湯もじといふ、但し湯巻と混ずべからず、湯巻は別に其ものあるなり。",
              "citation": {
                "source": "当世女装一斑",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "・晴れて風ふく春がやつてきた風で・日がのぼれば見わたせばどの木も春のしづくして・むのむしもしづくする春がきたぞな・木の実ころ／＼ころげてくる足もと・豚の子のなくも春風の小屋で・まがればお地蔵さまのたんぽぽさいた　三月八日降つても照つても、晴れても曇つても、風が吹いても、春が来てゐることに間違はない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲角を三つ曲がれば自転車屋であると正九郎は思った。",
              "citation": {
                "source": "空気ポンプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "羊の皮の手ざはりに金の箔押すわがこころ、思ひあがればある時は、紅玉サフアイヤ、緑玉、金剛石をも鏤めむとする、何んといふ哀しさぞや、るりいろ空に花咲かば忘れなぐさと思ふべし。",
              "citation": {
                "source": "「わすれなぐさ」はしがき",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "――蟹を召しあがれば買ってくるつもりなの？",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "斡旋の実が挙がれば良いと思う。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時の有様を『甲陽軍鑑』に、「敵味方三千七百の人数入り乱れて突いつ突かれつ伐つ伐たれつ互に具足の綿噛みを取り合ひ組んで転ぶもあり首をとつて立ちあがれば其首は、我主なりと名乗つて鑓つけるを見ては又其者を斬り伏せ後には十八九歳の草履取りまで手と手を取合差違へ候」とある。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりではなく、生活は雪達磨のように転がれば転がるほどしだいに大きくなるものだ。",
              "citation": {
                "source": "仮装観桜会",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が、もっと給料が上がれば、もっとどうかするから。",
              "citation": {
                "source": "機関車",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽があがれば野原に出て男達は木の根を掘っくりかえし、女達は土塊を打っ砕き、陽が沈めば小屋に帰って眠るのだった。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
