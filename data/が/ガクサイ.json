[
  {
    "uuid": "d520e114-5efd-5c0a-9985-e8522be9bb62",
    "entry": "学祭",
    "reading": {
      "primary": "がくさい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "school festival",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何故なら、それらの試合は全く時の三大統領の政戦に附随したもので、源はと云へば、覇者を讚へるための「大学祭り」に過ぎなかつたのである。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、科学祭りというものをだね。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒こげの材木が、積み木をひっくり返したように重なりあって、そこからけむりがくさいにおいといっしょにやって来た。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……とにかくさ、要するにロンドン港がくさい。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋がくさいばかりではない。",
              "citation": {
                "source": "格子縞の毛布",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このトタン塀はのぼれませんがね、　ちと此の門の方がくさい。",
              "citation": {
                "source": "盗難",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初に、この男の動静がくさいと気がついたのがパリーの第二号、洩れるべきはずのないことが、立派に洩れている。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて私の腹中のこぶは、この頃少しいい様で、この病院に入ってからもう二十日位だが、お小用がくさいのがへって来た。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛が多くて、革に似た皮膚をしていて、その上、臭がくさいのです。",
              "citation": {
                "source": "男ぎらい",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなも見たろうが、初代院長の聖骨をおさめてある壇、あの周囲がくさいと思うがどうじゃ」「小父さん、そうすると、四馬剣尺もあの塔を狙っているというのですか」「ふむ、たしかにそうだと思う。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから高度二万八千メートルのところがくさいことはたしかだ。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "よね　　それがくさい、此ん前、米ば積み出す時、ムツシユウ・真壁の握らせ方が足らんだつたけんたい。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "おチエは、からだがくさいから、いやだなあ。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えてみると、あの門之丞がくさい。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは又、明確には分らなくとも、誰がくさいとか怪しいとか、漠然と思っている方もあるかも知れません。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月十日（火曜）　宿の前の河をポン／＼船が通る、こいつで眼がさめちまひ、又ねる、今度は便所がくさい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小娘の挙動がくさいので責めているところ。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんそれは、今度の魏王｜顛覆計画の実際運動には加盟していない者だけであったが、いやしくも金※や耿紀の徒と、少しでも交渉があったとか、日頃の言動がくさいと睨まれている者は、ことごとく、市に引出して、その首を刎ねてしまった。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
