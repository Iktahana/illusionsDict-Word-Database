[
  {
    "uuid": "224ee735-29a7-59ea-a22d-6178c5068d9f",
    "entry": "学校教育",
    "reading": {
      "primary": "がっこうきょういく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
