    },
    "definitions": [
      {
        "index": 1,
        "gloss": "student affairs office",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「奨学金の申請書類、どこに出せばいいんだっけ？」「それなら、1号館にある学生課に行けば窓口で教えてくれるよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うわ、落とし物の財布が学生課に届いてるって掲示板に出てるぞ！心当たりあるなら早く行ってきなよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "部活動の部室使用許可をもらいに学生課へ行ったんだけど、担当の職員さんが結構厳しくて緊張したわ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "住所変更の届け出を忘れていたら、学生課から確認のメールが来て焦って手続きを済ませた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この思想統制内容の積極性は相当なものであったので、現に当時文部省に国民精神文化研究所なるものが出来たのでも知ることが出来るし、学生課がそれと同時に思想局となったことでも知れる。",
              "citation": {
                "source": "思想動員論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "文部省のかつての学生課は思想局となり、それが今年に至って教学局となったことは興味がある。",
              "citation": {
                "source": "一九三七年を送る日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノースウェスタンで学生課程を終えた後、修士をどこでやるか、大分迷ったらしい。",
              "citation": {
                "source": "娘の結婚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三沢氏も亦特色ある人物で、台湾高等学校の校長から、京都帝大の学生課長として乗り込んだ人である。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分赤色教授への重しの意味で勅任の学生課長を必要とする処から、選ばれたという噂であったが、学生課には過ぎ者の物判りの良さ（即ち自由主義）の所有者だったので、成城落ちをしたのだそうである、個人に就いての噂さはどうでもいいが、府の学務課から三沢氏排斥教員の解職を命じて来た点はここからも理解されよう。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に、先生を嘲笑された斎藤先生だとか学生課の二三の先生達、戦争中、まるで神がかりになって軍部や勤労動員の先頭に立たれた先生がたは、どうなります？",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
