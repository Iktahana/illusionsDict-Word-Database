[
  {
    "uuid": "9c3ed045-5ed8-5c60-99e3-a5fee868a4fb",
    "entry": "外庭",
    "reading": {
      "primary": "がいてい",
      "alternatives": [
        "そとにわ"
      ],
      "is_heteronym": false
    },
    "grammar": {
