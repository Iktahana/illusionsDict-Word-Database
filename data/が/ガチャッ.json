        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "玄関の鍵をガチャッと開けて家に入ると、愛犬がちぎれんばかりに尻尾を振って出迎えてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ガチャッという不穏な音がして扉が開いた瞬間、サプライズのクラッカーが鳴り響いたんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "受話器をガチャッと置いて大きくため息をつき、彼は再び山積みの書類に向き直った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "倉庫の鍵を外套から氷の上へガチャッと落した。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」彼は軍刀をガチャッと鳴らした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "園丁がいつか俄かにやって来てガチャッと持って来たものを置きました。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ガチャッと何かがころがる音がした。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロープは甲板の上に飛んで行き、先の釣が、ガチャッと、音を立てて、デッキの欄干に引っかかった。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまに、頭の上へはってきたなとおもって、体をよせていくと柱にしばりつけてある鎖がガチャッと鳴るので蝙蝠はびっくりして天井へはねあがる――が、六角形の密室なので、そとへはでずにまたバサバサと板壁に羽すべりをしてきた。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにをッ」　と叫ぶがはやいか、名刀｜般若丸を棒とおなじに心得て燕作の刀へわが刀をガチャッとたたきつけていった。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "市松はガチャッ、ガチャッと歩くたびに陣太刀が具足をたたく音をさせながら、巨石でたたみあげた石段をおりてきて、「遠路浜松城からおこしのお使者、ごくろうです。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "陣刀だの、具足だのが、その人の体で、羽ぶるいするようにガチャッと鳴った。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "うすうす事情を眺めていると、その当時、関屋孫兵衛というひとり息子、博奕は打つ、女色にはふける、手のつけられない放埒に、それが病のもとらしかった」　ガチャッと、何か金属性な音がしたので、世阿弥は突然言葉を切った。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "剣山の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
