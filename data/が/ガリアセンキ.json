        "examples": {
          "standard": [
            {
              "text": "世界史の授業で、カエサルの『ガリア戦記』を一部読んだことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "『ガリア戦記』は、カエサル自身の視点で書かれた貴重な戦史だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ラテン語の原書で『ガリア戦記』に挑戦するのは、なかなか骨が折れるだろうな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "『ガリア戦記』は、ローマ帝国の拡大期を理解する上で不可欠な史料だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼のリーダーシップと戦略は、『ガリア戦記』から学ぶべき点が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
