        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "翻訳界の危機　原物歪曲の懺悔多し　▼翻訳家の良心を、近頃いちばん感じさせた文章は、中公作年十二月号の土井虎賀寿氏の『翻訳論覚書』だらう。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "手近に聴くところがないから加賀寿々なんか聴きに、時々寄席へ行くのよ。",
              "citation": {
                "source": "草いきれ",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "此が短章となつて、恋愛味を離れて来ると、やはり国王の為の賀寿に傾くのである。",
              "citation": {
                "source": "組踊り以前",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿祭・室寿のうたは、家讃め・人讃め・※旅・宴遊のうたを分化し、鎮魂の側からは、国讃め、妻｜覓ぎ・嬬偲び・賀寿・挽歌・祈願・起請などに展開した。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケダシ賀寿ノ筵ヲ設ケテ以テソノ窮ヲ救ヘト。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、サモ※ールがじゅんじゅんたぎっとるばかりだ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "対岸の原の中でよしきりがじゅく／＼呟きます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実に関して正確たるのが本分であるのに、この頃の病気で揺らいでおり、このささいな出来事からも、友人は本調子からまだほど遠いことがじゅうぶんわかる。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るからに険のあるまなざし、傲然とした態度、何か尋ねたら、お直参であるのを唯一の武器にふりかざして、頭からこちらを不浄役人扱いしかねまじい不遜な節々がじゅうぶんにうかがわれました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯人はたしかにあの男であると推定されておりながら、その男がじゅうぶん計画をしてやったことでありますから、警視庁の人たちはその証拠をあげることができなかったのです。",
              "citation": {
                "source": "玉振時計の秘密",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "形も何もなくなった青草の小さな塊を、石炭で真っ赤に灼けている炉の中へ投げ込むと、敵がじゅじゅっと云って縮くれあがり、やがての果てにはふんわりした、雪のように白い一片の灰に化してしまうまで、彼は長いこと見守っていた。",
              "citation": {
                "source": "紅い花",
                "author": "КРАСНЫЙ ЦВЕТОК",
                "note": "青空文庫"
              }
            },
            {
              "text": "最高速度で追いかけるなら、追いつける自信がじゅうぶんにあった。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "みなさんがじゅうぶんに元気になられたら、わたしどもはみなさんがたに、ぜひ相談にのっていただきたいことがあるのです。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "また肥料もそれぞれの野菜に合ったものがじゅうぶんにあたえられ、植物ホルモンがうまく利用せられ、そのうえに、生長をたすける電波がかけられているので、野菜のできはいいし、その生長もたいへんはやい。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれがじゅうぶんに手当していますから」「夢だ。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、じっさい植物の補給がじゅうぶんでないために、われわれは近くこのジャンガラ星を運転して、もっとたくさんの植物が繁茂している遊星へ横づけにしたいと思っている」　二少年が見たところ、植物はそうとうしげっていた。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体どんなものをつかって、自分のからだを縛ってあるのか、それをたしかめるために、首をもち上げようとしたが、首がじゅうぶんに上らない。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷凍の常ながら冷たいまますぐ腐っていく可能性がじゅうぶんあるのである。",
              "citation": {
                "source": "大衆の知恵",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "認識能力として　前の節でいったように、カントの「悟性」の背景にはヴォルテール＝ヒューム的な英国の産業革命の精神がじゅうぶんに反映しているし、カントの「理性」の背景にはドイツの経済制度の立ちおくれによって起るユンカートゥム、田舎騎士的精神がほかの国にくらべて多くのこされている。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリスト教の起源の美しい物語や、キリスト生誕のときの田園の光景がじゅんじゅんと説かれる。",
              "citation": {
                "source": "クリスマス",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "光子さんは、こちらにぼんやりと立って、勇ちゃんがじゅず玉の茎を折ってくるのを待っていました。",
              "citation": {
                "source": "はちの巣",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がじゅず玉を取ってくれとたのまなければ、勇ちゃんは、はちになんかさされなくてもすんだのだと思ったからです。",
              "citation": {
                "source": "はちの巣",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「くれるんなら友達だ」そこで貧しい男はパンと肉をドーナルにくれて、ドーナルがじゅうぶん食べ終わると「今夜はどこに泊まるのかね」と聞いた。",
              "citation": {
                "source": "首なし",
                "author": "TRUNK-WITHOUT-HEAD",
                "note": "青空文庫"
              }
            },
            {
              "text": "この子がじゅうぶんりこうな子なら、わたしといっしょにいればこの国ばかりか、ほかの国ぐにまで見て歩けることがわかるはずだ。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくも露骨に命令がじゅうりんされたところをみると、そこに何かなければならない。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐ろしい速さで、ひざをすりむきながら、その血がじゅうたんをぬらすほども走りまわった。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、ぼくらの会社の営業がじゅうぶんなりたつというわけですよ」　もうささやき声ではなかった。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "やみに慣れた目には、その姿がじゅうぶん見わけられる。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士夫人の頼子さん同様、あんたも佐平治の血統として、怨霊にねらわれる危険がじゅうぶんにある」　だからあんたは、その若者たちを家へつれてかえったら……とまた博士にいわれるのです。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の林の中を懐中電灯やちょうちんの光がじゅうおうにとびまわりました。",
              "citation": {
                "source": "青銅の魔人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
