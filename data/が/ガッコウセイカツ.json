    },
    "definitions": [
      {
        "index": 1,
        "gloss": "school life",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「新しいクラスになじめるか最初は不安だったけど、今は気の合う友達もできて毎日学校生活が充実しているよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "規則正しい学校生活を送ることは、思春期の不安定な時期において、心身ともに健やかな成長を支える基盤となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「卒業アルバムをめくると、あんなに長く感じた学校生活も、終わってみればあっという間だったね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "部活動に全てを捧げたあの三年間は、僕のこれまでの学校生活において最も輝かしく、誇れる記憶だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そういう方面から考えて行くと、同時代に生れて同様な趣味や目的をもって、同じ学校生活を果した後に、また同じような雰囲気の中に働いて来たものが多少生理的にも共通な点を具えていて、そしてある同じ時期に死病に襲われるという事は、全く偶然の所産としてしまうほどに偶然とも思われない。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし中等学校を卒業しないうちに学校生活が一時中断するようになったというのは、彼の家族一同がイタリアへ移住する事になったのである。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "数学嫌いの生徒は日本に限らないと見えて、モスコフスキーの云うところに拠ると、かなりはしっこい頭でありながら、数学にかけてはまるで低能で、学校生活中に襲われた数学の悪夢に生涯取り付かれてうなされる人が多いらしい。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十年の学校生活に暇乞をしてから以来、何かの機会に『老子』というものも一遍は覗いてみたいと思い立ったことは何度もあった。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはおそらく私の長い学校生活の間に受けた最もありがたい教えの中の一つではなかったかと思う。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟の純次は低能に近いといっていいから尋常小学だけで学校生活をやめたのはまずいいとしても、妹のおせいに小樽で女中奉公をさせておかねばならぬというのは、清逸の胸には烈しくこたえていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "対手は老朽ちたものだけで、年紀の少い、今の学校生活でもしたものには、とても済度はむずかしい、今さら、観音でもあるまいと言うようなお考えだから不可んのです。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "次男の啓司はインテリ風の青年で主に東京にいて学校生活の経路に入っていた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の髪も長かったが、高等学校生活も長かったわけである。",
              "citation": {
                "source": "髪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私の髪の毛も長かったが、学校生活も長かった。",
              "citation": {
                "source": "中毒",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校生活を棒にしてしまったというのも、洒落だ。",
              "citation": {
                "source": "中毒",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生なら学校生活、職工ならその労働、会社員は会社の仕事、各々の生活をすればいい。",
              "citation": {
                "source": "小説家たらんとする青年に与う",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校生活についての私のいちばん古い思い出は、霧のかかったようなあるイングランドの村にある、大きな、不格好な、エリザベス時代風の建物につながっている。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして見たところ陰気なくらい単調な学校生活は、私が青年時代に奢侈によって得たよりも、あるいは壮年時代に罪悪によって得たよりも、もっと強烈な刺激に満ちていたのであった。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、学校生活の終りごろになると、彼の普通の出しゃばりはたしかにいくらか減ってはいたけれど、私の気持は、それとほとんど同じくらいの割合で、非常に積極的な憎悪を持つようになった。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "このイヴェントの精神を今後に活かそうという意気込みが語られますが、日常的な学校生活のリズムが戻ってくると、「あれはなんだったんだ」との悲鳴のような訴えかけが紙面を飾りました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "芳子は町の小学校を卒業するとすぐ、神戸に出て神戸の女学院に入り、其処でハイカラな女学校生活を送った。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "五年間の中学校生活、行田から熊谷まで三里の路を朝早く小倉服着て通ったことももう過去になった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　那覇での私の学校生活はほんの一、二カ月に過ぎなかった。",
              "citation": {
                "source": "私の子供時分",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう風であったから、最初の間首里の学校生活は愉快ではなかった。",
              "citation": {
                "source": "私の子供時分",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は満五カ年の小学校生活を切り上げて明治二十四年の四月に、いよいよ中学に這入るようになった。",
              "citation": {
                "source": "私の子供時分",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "この映画が、現代小学校生活にふくまれている諸問題を真面目に率直に披瀝して識者の関心に訴えようとせず、画面の小奇麗さ、子供らの整然さだけに観衆の興味を限ろうとしているのは遺憾であった。",
              "citation": {
                "source": "映画の語る現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊さんは可なりに愉快な人であって、私の学校生活や京都に関する話を、興味をもってきいてくれた。",
              "citation": {
                "source": "狂女と犬",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "四年の学校生活も追々と終に近くなって行った。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は学校生活の時代から一種の読書家であつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校生活で一番希望されていることは、学用品・運動靴の配給や、給食をもっとほしい、ということです、子供達が住んでいる町にのぞんでいる第一のことは、遊ぶところをつくってほしい、というねがいです。",
              "citation": {
                "source": "今年こそは",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分たちの生活の必要にたって、必要を整理解決してゆく政治の初歩的なそういう習慣が女学校生活の何年間かに養われるということは、将来に意味あることだろうと思う。",
              "citation": {
                "source": "女性の歴史の七十四年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄妹がいて、それぞれ学校生活をしていたり勤めたりしている人たちでも、なかなか互の友人たちを家庭の内で紹介しあって、淡白に愉快につき合ってゆくという習慣はできていない。",
              "citation": {
                "source": "異性の友情",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一一年（明治四四年）から一六年にかけての女学校生活には、現代の、とくに一九四五年八月以後の女学生には想像も出来ないような苦しさがあった。",
              "citation": {
                "source": "歳月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校生活の中にもある。",
              "citation": {
                "source": "歳月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
