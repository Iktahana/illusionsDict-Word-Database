[
  {
    "uuid": "57c30633-019e-5a11-994f-f7af7d2a07ec",
    "entry": "学校生活",
    "reading": {
      "primary": "がっこうせいかつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
