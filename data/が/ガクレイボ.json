        "examples": {
          "standard": [
            {
              "text": "教育委員会は、住民基本台帳のデータと照らし合わせながら、来年度の入学者を確定させるために学齢簿を整備する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "転居の手続きが遅れると、新しい住所地の学齢簿に名前が載らず、入学案内が届かないというトラブルが起きてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「先生、市役所から送られてきた学齢簿を確認しましたが、来年の新入生は今のところ30名の予定です」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "学齢簿は、国が定める義務教育をすべての子どもに等しく提供するための、極めて重要な行政書類だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "『老婆さん、いくら探しても、松三郎といふのは役場から来た学齢簿の写しにありませんよ。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がかつて或る県の漁村の小学校を視察に行った時に、女児の就学児童の極めて少いのに不審を起して、村の学齢簿を調査してみたところが、実際その村には女の児が少かった。",
              "citation": {
                "source": "特殊部落の人口増殖",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
