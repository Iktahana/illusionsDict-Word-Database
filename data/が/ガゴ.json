        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「いとをかし」は、平安時代の文学を代表する雅語の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "源氏物語を読むためには、注釈を頼りに一つ一つの雅語の意味を理解していく必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "古文の授業で、和歌に頻出する枕詞や掛詞といった雅語の技法について学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
