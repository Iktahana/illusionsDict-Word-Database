        "examples": {
          "standard": [
            {
              "text": "週末、地域センターで掘り出し物が見つかるがらくた市が開催される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "がらくた市で、思わぬヴィンテージの食器を格安で手に入れることができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「今度の日曜、がらくた市に行くけど、何か欲しいものある？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "独逸における現勢力としての猶大人・ジョルジ・サンの性格・倫敦の物価と税・シンガポウルのがらくた市場で買った時計の正確さ・ロココ式の家具・バルビゾンの秋――転々たる話題。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "生徒の母親たちの有志はがらくた市を開き、この年の利用料にあてようと三〇〇〇ドルを集めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
