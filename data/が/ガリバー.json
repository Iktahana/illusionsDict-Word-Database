    "definitions": [
      {
        "index": 1,
        "gloss": "Gulliver",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供の頃、ガリバー旅行記を読んで、小人の国や巨人の国にワクワクしたのを覚えてる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あのレストラン、料理の量がガリバーみたいにすごいらしいよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼のアイデアはいつも突飛で、まるでガリバーが空飛ぶ島を見つけたような話だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "汝等の国は近々にも訪れたいのだが予は、いつか生れて初めてマナヅルからアタミまで船に乗つた時に悶絶せんばかりに苦悶した経験を持つて以来、汝の国はガリバーの訪れた国よりも遥かになつてしまつた。",
              "citation": {
                "source": "消息抄（近頃書いた或る私の手紙から。）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、此処で、「ガリバー旅行記」「ラマンチアのドンキホーテ」「ピルグリムス・プログレツス」等の遍歴物語を読み、そして私にとつて、久しい懸案であつたところの「山彦の街」と題する至極浪漫的な創作の稿を起した。",
              "citation": {
                "source": "川を遡りて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガリバー旅行記の小人国や大人国の言葉を参考にして、よしツ、そいつは一ト月のうちに俺が拵へるよ、先づ幾通りかの暗号を――」　と森が讚同すると、村井も膝を打つて、「俺は、この附近の地理を験べてから、俺達にとつてだけ所用な個所に古代アテナイの花の名前を引用した符号をつけよう。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう体じゅうに網を張られた小人国のガリバーのように粘りの糸を引きながら起き上った。",
              "citation": {
                "source": "蠅",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "スウィフトの『ガリバー巡島記』にヒントを得たやうな『ニェルス・クリームの地下旅行』Niels Klims Underjodiska Reis といふ物語の如きは、餘りにも眞に迫つて、偶然事實と符合したので、これは自分のことを惡口したものだと、譏誹の訴へを起したものすらありました。",
              "citation": {
                "source": "スカンヂナヴィア文學概觀",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "名前はレミュエル・ガリバーと申します。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者から読者へに代えてあとがき　ガリバーは十六年と七ヵ月の間、不思議な国々を旅行して来ました。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガリバーはあべこべに小人の王様の家来にされてしまいます。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も子供のときリリパットの国の話を聞いて、縁側で蟻の行列を眺めていたら、自分がガリバーになったような気がしたものです。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、小人の国にも戦争があったり、政争があったりして、ガリバーはとうとうこの国を逃げ出してしまいます。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、その次にブロブディンナグ国へ来てみると、ガリバーはまず胆をつぶします。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度はガリバーの方が小人になっているのです。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら、ガリバーが強そうな振りをしても、自分の国の自慢をしてみても、この国の人から見れば、まるで虫けらのようなものです。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、ガリバーは箱に入れられて、カナリヤのように可愛がられています。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして、ガリバーは大人国ともお別れになります。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度はガリバーは飛島へやって来ます。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもそこには奇妙な人間ばかり住んでいるので、ガリバーはうんざりしてしまいます。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからガリバーははるばる日本へまでやって来ます。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後にガリバーは馬の国へやって来ます。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには人間そっくりのヤーフといういやらしい家畜がいるので、まずガリバーはそれを見てぞっとします。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからフウイヌムたちに会い、そこの言葉をおぼえ、そこの国に馴れてくるにしたがって、ガリバーはこの穏やかな理性の国がすっかり気に入ってしまいます。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから久し振りで人間と出会うと、ガリバーはたまらなくなって逃げ出そうとします。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、この『ガリバー旅行記』は一七二六年に書き上げられました。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "この『ガリバー旅行記』は、これまで広く世界中の人々に親しまれてきた本です。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガリバー探険物語にある学者の国のごとくに仕立て屋が六分儀や水準器を持ち出し、角度から割り出して仮縫いの寸法を取るようではいかなる洋服ができ上がるか分からぬ。",
              "citation": {
                "source": "我らの哲学",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――『世界お伽噺』では新版を本屋で買うと、先ずその挿絵を一通り見ることにして、ガリバーの絵だとか真黒学校の絵などは実に好きでした。",
              "citation": {
                "source": "少年の食物",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "スウィフトの『ガリバー旅行記』やモリエールの『人間嫌い』やゴーゴリの『検察官』が当時の社会との関係に於て極めて合理的で理性的で従って現実的であったように、王仁三郎の「大本教」も合理的で理性的で現実的な社会的根拠を有っている一つの風刺的存在だ、と云ってもいいだろうと思う。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "まえに「ガリバー旅行」のお話を読んだことがあります。",
              "citation": {
                "source": "魔法博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
