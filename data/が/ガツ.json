        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ここのお店のガツ刺し、鮮度が良くてコリコリした歯ごたえが最高にビールに合うよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "もつ鍋の中にたっぷり入ったガツが、出汁を吸って噛めば噛むほど味が出る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "焼肉屋で初めてガツを注文した友人が、「ホルモンってこんなに美味しいんだ」と驚いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "聞きながら、大きいガツテンガツテンを、アクセントをつけてやつてゐた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "名刺を読むと、しきりにまたガツテンガツテンをしながら私の顔をみて、それからタモトに入れたのであつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂとしたら、又してもガツカリだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は疲れてガツカリしながら従いて行つた。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "方針は立つたが、たつた十四行書くために、こんなに手数がかゝるのではとガツカリす。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房子に足をとられたり、ガツガツした胃袋に足をとられたり、そう云う、俺だって、ざまあねえや、今まで足をとられていたじゃねえか。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　リルケが晩年、ラアガツのホテルで、この小時の作品の思ひ出をトゥルン・ウント・タクジス公爵夫人に語つた一夜のことが、夫人の囘想記には興深く敍せられてゐる。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く峯にはまっ黒のガツガツした巌が冷たい霧を吹いてそらうそぶき折角いっしんに登って行ってもまるでよるべもなくさびしいのでした。",
              "citation": {
                "source": "マグノリアの木",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがまた、東京にゐて何時売れるともない原稿を書き、淋くなつては無理酒を飲む、しがない不規則な日々を考へると、ガツカリするのであつた。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と誰かがけたたましく叫んでいるようでしたが、ネネムはもう頭がカアンと鳴ったまままっ黒なガツガツした岩の上に立っていました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し海軍の事に通じた人は誰でも知つて居る、すでに海水中十四｜呎以下に沈んだる或物に向つては、世界最強力のガツトリング機砲でも、カ子ー砲でも、些少の打撃をも加ふる事が出來ぬのである。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "况んや此海底戰鬪艇は、波威に沈降する事三十｜呎乃至五十｜呎、其潜行を持續し得る時間は無制限であるから、一度此軍艇に睥睨まれたる軍艦は、恰も昔物語の亞剌比亞の沙漠の大魔神に魅られたる綿羊のごとく、遁れんとして遁るゝ能はず、鬪はんか、速射砲もガツトリング砲も到底力及ばぬ海底の此大怪物を奈何せん。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とはじめて氣が着いて、主人が渡して行つた鍵をガツチリ、狼狽眼で開いて見ると、這は如何。",
              "citation": {
                "source": "人參",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……車の眞似だか、あの、オートバイだか、電車の眞似だか、ガツタン、ガツタン、がう……」　と、その七つに成る兒が、いたいけにまた話した。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレハ　ハジメテ　ミル　セカイガ　イママデト　チガツテ　ピカピカ　ヒカツテ　ヰタカラデ　アリマス。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "デキアガツタ　クワガ　タクサン　ヘイタイノヤウニ　ナランデ　ヰマシタ。",
              "citation": {
                "source": "カナヅチ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "タケノコタチハ　トホクヘ　イキタガツテ　シヨウガ　ナイノデ、オカアサンノ　タケガ、「ソンナニ　トホクヘ　イツチヤ　イケナイヨ、ヤブノ　ソトニ　デルト　ウマノ　アシニ　フマレルカラ」ト　シカツテ　ヲリマシタ。",
              "citation": {
                "source": "タケノコ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケレド、二ツノ　ホシハ　ガツカリシマシタ。",
              "citation": {
                "source": "ナガレボシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレハ　オサムラヒニ　バケル　トキダヨ」　オカアサンノ　タヌキハ　ガツカリシテ　イヒマシタ。",
              "citation": {
                "source": "ゲタニ　バケル",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソシテ　ハンノキノ　シタニ　コロガツテ　ヰマシタ。",
              "citation": {
                "source": "ゲタニ　バケル",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "キノ　カゲカラ　コノ　ヤウスヲ　ウカガツテ　ヰタ　オカアサンダヌキハ　タイヘンナ　コトニ　ナツタト、メヲ　マンマルクシテ　オドロキマシタ。",
              "citation": {
                "source": "ゲタニ　バケル",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "スルト　ポストノ　ウシロニ　タツテ　ヰタ　ガイトウガ　カラ　カラト　ワラツテ、「ポストノ　カゲナラ、ポストノ　ウシロニ　コロガツテ　ヰル　ソノ　ブカツカウナノガ　サウヨ」ト　イヒマシタ。",
              "citation": {
                "source": "タレノ　カゲ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "御馳走を見ても、もう初めの頃のように浅間しくガツガツするようなことは無い。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
