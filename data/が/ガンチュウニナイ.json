[
  {
    "uuid": "549936b0-0e33-5e3e-97a1-911a6e355815",
    "entry": "眼中にない",
    "reading": {
      "primary": "がんちゅうにない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "形容詞"
      ],
      "ctype": null,
