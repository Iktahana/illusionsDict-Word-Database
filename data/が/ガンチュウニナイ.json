    },
    "definitions": [
      {
        "index": 1,
        "gloss": "taking no notice (of)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "会議で彼の意見は全く眼中にないように扱われ、彼は不満げだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "人気が出すぎて、以前のファンはもう彼女のことを眼中にないのかもしれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ライバル社の新製品は、我々の計画では眼中にない存在として、静観することにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの問題、もう解決したと思ってたよ。君はまだ眼中にないの？だから遅れてるんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "武士道と言えば、女は眼中にないような風に言われながら、正妻となるとなかなか格式を与えて十分な権利を主張せしめている。",
              "citation": {
                "source": "女性崇拝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "尠くともお酒が這入つてゐれば、淡白といふか愚かといふか、人が体面を慮つて遠慮するていのことくらゐは、ても眼中にないのである。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事は民力の発展などは眼中にない愚劣政治家共に話したとて分るまいが、真に国家の前途を憂うる人士は、大いに沈思熟考せねばならぬ問題であろうと思う。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "凹垂れ剛力などは眼中にない。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "小児なぞは眼中にない、男は二人のみだったから。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の関心は、東京の文化と、東京を通じて輸入される外来思想とのみに存して、自分たちの故郷の天地山川や人情風俗は、眼中にないかの如くである。",
              "citation": {
                "source": "東京文壇に与う",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "學校など眼中にないばかりでなく、廣い社會に對しても、おれ自身の發展擴張を抽象的な、從つて外形的な、淺薄な教訓のかたちを以てしたくないのだ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "その書物のあるところが、おれの家で、妻子など眼中にないのだから、これは前以つて斷わつて置くよ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "満蔵なんか眼中にないところなどはすこぶる頼もしい。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "負けぎらいな性質の人で更衣の死などは眼中にないというふうをわざと見せているのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "桐壺",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、ハツとして、六ヶ敷しい顔に戻り、ワザとそんな者は眼中にないといふ風に白々しく口笛を続けた。",
              "citation": {
                "source": "秋晴れの日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうなつて行くと、社会といふことなどは少しも眼中にないだらうと思ふ。",
              "citation": {
                "source": "社会劇と印象派",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人は、相手のそうした躊躇などは、眼中にないように、自由で快活だった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑠璃子には、青年の憤怒などは、眼中にないようだった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "御相宿なら半値に致スまするがいかがでござりまする」　しきりと慇懃に揉み手をしながら、天下の御直参もまるで眼中にないもののような容子でした。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「びくびく致すな、その方共なぞ、もう眼中にないわ。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは兎も角、彼はその辺一帯を占領して以来は恰で生れ変つた如き横風な人間と化して、多くの手下を引具して議員に候補したり、妾を蓄へたり、花合戦に一夜千両を賭けたりして、凄まじい大尽風を吹かすばかりか、果はあられもなく貴人を気どつて吾々などは頭から眼中にないといふ羽振りを示しました。",
              "citation": {
                "source": "船の中の鼠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人は、相手のさうした躊躇などは、眼中にないやうに、自由で快活だつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑠璃子には、青年の憤怒などは、眼中にないやうだつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぎごちない格構に見えるだらうが、それは僕一人の勝手なことなので……」「何も眼中にないといふことなの、此方のことは！",
              "citation": {
                "source": "山を越えて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前などは眼中にないんだよ。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の書物など、全く眼中にないようである。",
              "citation": {
                "source": "西田先生のことども",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "邪宗も、イスラム＊も、まして信仰や戒律どころか、神も、真理も、世の中も眼中にないありさま、二つの世にかけてこれ以上の勇者があったか？",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼等のことなどてんで眼中にないチチコフは、どうやら寄木の床を思う存分おどり※りたいという熱望に駆られているらしい、長い手袋をはめた金髪娘を、遠くから見つめるばかりであった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "判官忌避の如きはその成否眼中にない程彼は庄司氏の証言に絶望を痛感したのではあるまいか。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く博士は学問の研究にばかり没頭して、美しい夫人などは全く眼中にないようなのだ。",
              "citation": {
                "source": "血液型殺人事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺さんは、お縫など眼中にないふうで、市況放送がすむと、むっつりした面持のまま罫紙を畳の上からとりあげ、自分も体を起し、それを懐にしまって、隣りの部屋へいって、ラジオを消した。",
              "citation": {
                "source": "猫車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（葉子は、義公と一緒に行ってしまったのだ）（葉子は、お前なんか、もう眼中にないのだぞ――）　と思いながらも、やっぱり諦めきれぬ未練な黒吉であった。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
