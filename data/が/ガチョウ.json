[
  {
    "uuid": "96becd69-623f-56aa-b247-39ed2a256a46",
    "entry": "画帳",
    "reading": {
      "primary": "がちょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
