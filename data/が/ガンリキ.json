[
  {
    "uuid": "0312ab4e-fec1-540e-9290-1593957ec395",
    "entry": "眼力",
    "reading": {
      "primary": "がんりき",
      "alternatives": [
        "がんりょく"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "insight",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "弱点を見破る眼力はニーチェと同じ程度かもしれない。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お文の幽靈を草雙紙のなかから見つけ出した半七の鋭い眼力を、Ｋのをぢさんは今更のやうに感服した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その脳力も眼力も腕力も尋常一様の人ではない。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "むゝ、いや、土龍のやうな奴だが、此を美しいと目をつけた眼力だけは感心ぢやわ。",
              "citation": {
                "source": "麥搗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "モダンの富士｜詣でのような風をしていても、あんたがどんな人間か、眼力ひからす松王丸がちゃんと睨んでいるわ。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "商売の算段もなまり、倉々を見廻る眼力もにぶつたが、人知れず遠くから離れ家を見詰める宗右衛門の眼の色は、異様に光つた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼力、紙背を貫くというのだから、たいへんである。",
              "citation": {
                "source": "一歩前進二歩退却",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "考へてみると、あの入道さまの御眼力は、まことに恐るべきもので、将軍家は恋といふものをご存じなさらぬ、とためらはず御断言なさいましたが、和歌は心の鏡とか、そのお歌を拝読しただけで将軍家のあまりにも淡泊の御性情を底まで見抜いてしまつたのかも知れませぬ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し其説が真実であるとすれば、忠興が固辞したということは、忠興の智慮が中々深くて、能く己を知り彼を知って居たということを大に揚げるべきで、忠興の人物を一段と立派にはするが、秀吉に取っては第一には其の眼力が心細く思われるのであり、第二に辞退されて、ああ然様か、と済ませたことが下らなく思われるのである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれが天下を取る筈だわ、という意は人々の識力眼力より遥に自分が優って居るという例の自慢である。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此話に拠ると、会津に蒲生氏郷を置こうというのは最初から秀吉の肚裏に定まって居たことで、入札はただ諸将の眼力を秀吉が試みたということになるので、そこが些訝かしい。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の脳力も眼力も腕力も尋常一様の人では無い。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "王さまは大そうよろこんで、いろ／＼とほうびの品ものを下さり、これから先も、こまつたことが出来わいたら、おまへにたのむぞと言つて、しきりにイドリスのふしぎな眼力をおほめになりました。",
              "citation": {
                "source": "ダマスカスの賢者",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何にも驚き入つたる御眼力。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その眼力に男は気圧されている。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そういう事がらがそんなにひどく私を悩ませるということを彼が見抜いたのは、前に言ったように、まったく彼のなみなみでない眼力によるというよりほかはない。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "祇園精舎ついでに「平家物語」をさらにひもとけば、平清盛はしゃれこうべの千万の大目玉と睨み合い、眼力でこれを雲散霧消させてしまったという。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし溝口横綱の眼力パワーがフルに発揮されるに至るまでには、かなりの紆余曲折があった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "溝口横綱は目玉パワーの人であると同時に、実に誠実の人であって、その一本気な真面目さかげんが眼力光線に一層の凄みを与えるというメカニズムになっている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "お文の幽霊を草双紙のなかから見つけ出した半七の鋭い眼力を、Ｋのおじさんは今更のように感服した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してその妖巫の眼力が邪視だ。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に邪視を惧るる者、ことさらに悪衣を着、顔を穢し痣を作りなどして、なるべく人に注視されぬようにし、あるいは男女の陰像を佩びて、まず前方の眼力をその方に注ぎ弱らしむ。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "この論に、日の光が人の眼を眩ますを、邪視に比したは、古エジプトで諸神の眼力極めて強く、能く諸物を滅すとせるに似て面白い。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、古エジプトの神ホルスは、日を右眼とし、月を左眼とし、その眼力能く神敵たる巨蛇アペプを剄る。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "また神怒れば、その眼力叢林を剿蕩す。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "バシリスクの眼力鏡より反射して彼自身を殺すはずという。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな異常の精眼力には風中の雪の微分子ぐらいの運動の態が映ったかも知れず、豕が風を見るというのもまるで笑うべからず。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "予の眼力の驚くべく良かった事は、一九一四年『英国菌学会事報』七〇頁と、一九一八年『エセックス野学倶楽部特別紀要』一八頁に、故リスター卿の娘でリンネ学会員たるグリエルマ嬢が書き立て居る。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそのついでに、百という男は、がんりきと二つ名前の男で、切り落された片一方の手には甲州入墨……」「何を言ってやがるんだ」　下の男と女は、いさかいになったのを、米友は聞き咎めてしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌朝、あのがんりきの何とやらいう小悪党に会わなければならないのだなと思いながら、米友は下へ降りて見ると、お角と女中のほかには誰もいませんでした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
