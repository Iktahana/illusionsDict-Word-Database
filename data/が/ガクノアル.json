    "definitions": [
      {
        "index": 1,
        "gloss": "educated",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は若いのに言葉遣いが丁寧で、本当に学のある人だと感心した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「学のある人の話は、いつも奥深くて面白いね」と友人が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "どんな分野にも精通している彼女は、まさに学のある女性だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "学のある人は、とかく謙虚で、自分の知識をひけらかさないものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "気立のやさしい、膚も心も美しい人じゃによって、継母｜継児というようなものではなけれども、なさぬなかの事なれば、万に一つも過失のないように、とその十四の春ごろから、行の正しい、学のある先生様を、内へ頼みきりにして傍へつけておかしゃった。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に科学のあるところには、常に飛行機があり、磁力があり、ラジオがあり、電信があり、不断の新しき発明と夢とがある。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく講師の私を大いに学のある男だと思ったらしかったが、しかし、私は講演しながら、アラビヤに沙漠があったかどうか、あるいはまた、アラビヤに猿が棲んでいたかどうかという点については、甚だ曖昧で、質問という声が出ないかと戦々兢々としていたのである。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃ才のあるのも学のあるのもあろうけれど、出来のえい気に入った若いものといえば、あの男なんぞは申し分がない。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、明治が大正に変わろうとする時になると、その中学のある村が、栓を抜いた風呂桶の水のように人口が減り始めた。",
              "citation": {
                "source": "死屍を食う男",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学は哲学に負けるべきかどうかは私の知らぬところだが、文学には文学独自の哲学のあることは、文学者である限り何人も疑わぬところである。",
              "citation": {
                "source": "スフィンクス（覚書）",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都大学のある法学者は、家族がみんな不在になると、すつくと逆立になつて、書斎からのそり／＼這ひ出して来て、玄関から台所まで一廻り廻つて来る癖がある。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京大学のある教授で、西洋人の書いた書物から、しよつちゆう自分の生れた国の事を習ひ覚えてゐる若い学者がそれを読むだ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、側でそれを聞いてゐた文科大学のある教授は、眼を一銭銅貨のやうに円くした。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の思うには、語学校の卒業生は別に何かの才学のあるものの外は、実際において教師あるいは通訳の外にはほとんど役に立たぬ。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "本郷の帝国大学のある本富士警察の留置場、学校の多い西神田署の留置場などは、東京の警察の乱暴な留置場の中でも、最も看守の粗暴なところであった。",
              "citation": {
                "source": "誰のために",
                "author": "――インテリゲンツィアと民主主義の課題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争中評論について勉強してきた人々は、プロレタリア文学のあるままの歴史さえも手に入れることはできませんでした。",
              "citation": {
                "source": "討論に即しての感想",
                "author": "――新日本文学会第四回大会最終日に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "記録文学のあるものは、日本帝国主義軍隊の戦争、敗北、潰滅が、そのかげにかくしていたさまざまの歴史的事実を一般の人々の批判のあかるみにだし、侵略戦争の本質について考えさせ、まじめな役割を果した。",
              "citation": {
                "source": "ことの真実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "記録文学のあるものは、クラブチェンコの「わたしは自由を選んだ」を筆頭として、国際的にも一つの注目すべき反民主的利用の道をひらかれてきた。",
              "citation": {
                "source": "ことの真実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の担任の先生が、父よりも、あるいは私が知っているどんな人物よりももっと学のある人である、――世界中で最も畏敬を覚え、かつまたもっとも親切な人であると、その時は思いました。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "その秋、ゴーリキイは、遂に大学のあるカザンへ出発することにしたのであった。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその才学のある枳園の軽佻を忌む心が頗る牢かった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし懐疑主義は同時に又少しも信念の上に立たぬ哲学のあることをも疑うものである。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし懐疑主義は同時に又少しも信念の上に立たぬ哲学のあることをも疑ふものである。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もっともあなた見たいに学のあるものが聞きゃあ全く嘘のような話さね。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは犯人なんてモノじゃなくて、然るべき学のある御方があの男も可哀そうだ、世のため人のためてんで、はからって下さったんだ。",
              "citation": {
                "source": "ニューフェイス",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私立大学のあるものは、かゝる種類の学生を集めて、ひたすら、その歓心を買はうと努めてゐるのである。",
              "citation": {
                "source": "一国民としての希望",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは眼科医学のある書物をみると、「ヒステリイ性弱視」といふ病名が出て来る。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "学のある鼠サマだから癇癖が強いかも知れないよ。",
              "citation": {
                "source": "屋根裏の犯人",
                "author": "――『鼠の文づかい』より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二人のほかに近在に学のある者はいなかった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その九　覆面屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事の終りに、ユデタコのように赤くなった木々彦が一同によびかけて、「私はちかごろコクリサマという術を会得したから、皆さんに教えてあげたいと思うが、英信さん、あなたは特に学のある人だから、あなたの学がこの魔法をどういう風に解釈するかそれを承るのがタノシミなのさ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その九　覆面屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "停年でやめた大学教授でさ、いいかい、カサカサの乾パンでさ、おまけに学のある棒鱈ときている。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は大学で気象学を講ぜられ、藤原先生が師事されていた位だから、日本の気象学のある意味での開拓者の一人である。",
              "citation": {
                "source": "続先生を囲る話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一国の「文化」が高まり、個人の教養が深くなるにつれて、文学は随筆の形式をとるようになる、あるいはもっと精確にいえば、随筆が文学のあるかなり重要な領域を占めるようになる。",
              "citation": {
                "source": "文化史上の寺田寅彦先生",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし技術の伝統を見るという立場からいえば、この一つの方法の中にも、英国の科学のある面を見ることが出来そうである。",
              "citation": {
                "source": "実験室の記憶",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
