    },
    "definitions": [
      {
        "index": 1,
        "gloss": "painter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は生涯、世俗の欲に目もくれず、ただ一人の画人として深山幽谷の美を描き続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "近代日本画の夜明けを支えた画人たちの情熱が、この一枚の屏風からひしひしと伝わってくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あの方は単なる絵描きというより、孤高の画人と呼ぶにふさわしい佇まいをしていらっしゃいますね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "放浪の画人が遺したスケッチブックには、名もなき村々の日常が温かな筆致で記されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "日本映画人がかつてソビエト露国から俳諧的モンタージュの逆輸入を企て一時それに熱中したのはすでに周知の事実なのである。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画人が映画を見るのが何の道楽だ。",
              "citation": {
                "source": "気まま者の日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画人が映画を見、映画を作るのは仕事だ。",
              "citation": {
                "source": "気まま者の日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "四「京師に応挙という画人あり。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそれ秋の夕なんど天の一方に富士を見る時は、まことにこの渡の風景一刻千金ともいひつべく、画人等の動もすればこの渡を画題とするも無理ならずと思はる。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画人としてもドイツ人はやはり「あたまが悪く」て、その結果として物事を理屈で押して行く。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行くと、どうもアメリカの映画人のほうがよほど進んでいるといわれても弁明のしようがないようである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシア崇拝の映画人が神様のようにかつぎ上げているかのエイゼンシュテインが、日本固有芸術の中にモンタージュの真諦を発見して驚嘆すると同時に、日本の映画にはそれがないと言っているのは皮肉である。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん営利を主とする会社の営業方針に縛られた映画人に前衛映画のような高踏的な製作をしいるのは無理であろうが、その縛繩の許す自由の範囲内でせめてスターンバーグや、ルービッチや、ルネ・クレールの程度においてオリジナルな日本映画を作ることができないはずはない。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大雅、応挙、月渓などといふ画人が、急に世にときめき出したのも、癪に触つた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説家としての私の愚見も、あるいは、ひょっとしたら、ひとりの勇敢な映画人に依って支持せられるというような奇蹟が無いものでもあるまい。",
              "citation": {
                "source": "芸術ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼に言わせると、其角も一蝶も俳人や画人であると共に幇間でもあった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "教育映画の制作を通して、普段なら目に見えないものを映像で捉えるという仕事に携わってきた萩野さんは、技術の可能性を信じるタイプの映画人でした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に今より百年ばかり前のことをわれわれの目の前に活きている画のように、ソウして立派な画人が書いてもアノようには書けぬというように、フランス革命のパノラマ（活画）を示してくれたものはこの本であります。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "外見的に絵の幼稚さを見て、素人画家と断定し、たまたまその画家のすばらしい画人的なデッサンをみて、その画家を見直すといふ場合が、画家の世界には少くない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故に椿岳の生涯は普通の画人伝や畸人伝よりはヨリ以上の興味に富んで、過渡期の畸形的文化の特徴が椿岳に由て極端に人格化された如き感がある。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一　画人椿岳椿岳の画才及び習画の動機　椿岳の実家たる川越の内田家には芸術の血が流れていたと見えて、椿岳の生家にもその本家にも画人があったそうだ。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "椿岳は画人として応挙や探幽と光を争うような巨人ではない。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、落款があっても淡島椿岳が如何なる画人であるかを知るものは極めて少なく、縦令名を知っていても芸術的価値を認むるものが更にいよいよ少ないのだから、円福寺に限らず、ドコにあっても椿岳の画は粗末に扱われて児供の翫弄となり鼠の巣となって亡びてしまったのがかなり多いだろう。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　竹を描く度にこういった元の倪雲林は、竹が好きだっただけに、竹によく似た魂のすがすがしさと潔癖とを持っている画人だった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は梅の花のあの冷々とした苦い匂に、六如のもつてゐた尖鋭な気禀を嗅ぎ、楚といふ楚が、各自の思ふがままに真直に伸びて往くこの木の枝振りの気儘さと頑さとに、自ら風流第一と許した画人の、世間の規矩を超越した、自暴自棄にちかいまでの性癖と生活とを感じることが出来る。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人こそ、その人の名こそ、日本映画史にふたたび拭うべからざる汚点を残したものとして、日本に映画のあるかぎり、日本に映画人のあるかぎり、永く呪わるべきであろう。",
              "citation": {
                "source": "映画界手近の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分一個の不安もさることながら、それよりもまず、失業群としての、大勢の映画人の姿が、黒い集団となつてぐんと胸にきた。",
              "citation": {
                "source": "思い",
                "author": "――情報局の映画新体制案について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれを説明するために、まず順序として、私と自由映画人集団との関係を明らかにする必要を感じる。",
              "citation": {
                "source": "戦争責任者の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは自由映画人集団発起人の某氏から同連盟への加盟を勧誘するため、送られたものであるが、その文面に現われたかぎりでは、同連盟の目的は「文化運動」という漠然たる言葉で説明されていた以外、具体的な記述はほとんど何一つなされていなかつた。",
              "citation": {
                "source": "戦争責任者の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「前略、小生は先般自由映画人集団加入の御勧誘を受けた際、形式的には小生の名前を御利用になることを承諾いたしました。",
              "citation": {
                "source": "戦争責任者の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それは、御勧誘の書面に自由映画人連盟の目的が単なる文化運動とのみしるされてあつたからであつて、昨今うけたまわるような尖鋭な実際運動であることがわかつていたら、また別答のしかたがあつたと思います。",
              "citation": {
                "source": "戦争責任者の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日は京都画人の座談会という風なもので、一同時間を忘れ、いつか日が落ちて、あわてて座をたつといった、まことに和やかな風景でした。",
              "citation": {
                "source": "明治懐顧",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の幹がその特殊な皮はだをこれ見よがしに葉漏りの日の光にさらして、その古い傷口からは酒のような樹液がじんわりと浸み出ていた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "帯の下になった葉子の胸から背にかけたあたりは汗がじんわりにじみ出たらしく、むしむしするような不愉快を感ずるので、狭苦しい寝台を取りつけたり、洗面台を据えたりしてあるその間に、窮屈に積み重ねられた小荷物を見回しながら、帯を解き始めた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
