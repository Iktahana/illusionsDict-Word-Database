[
  {
    "uuid": "5f1f47da-e593-505a-b3b3-cdf6fd84ce70",
    "entry": "画人",
    "reading": {
      "primary": "がじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
