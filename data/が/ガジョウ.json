[
  {
    "uuid": "70c7a10b-7841-5669-b785-3fb9d1eee8dc",
    "entry": "我情",
    "reading": {
      "primary": "がじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
