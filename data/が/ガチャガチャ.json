    "definitions": [
      {
        "index": 1,
        "gloss": "with a clatter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "半次尚も、Ｔ「演じまするは　これ北辰一刀流　名代の踊り手　此村大吉が得意の壇上」　拍子木をガチャガチャガチャ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "便所のところで、剣が、ガチャガチャ鳴った。",
              "citation": {
                "source": "名勝地帯",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見わたすと、その檸檬の色彩はガチャガチャした色の階調をひっそりと紡錘形の身体の中へ吸収してしまって、カーンと冴えかえっていた。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもいいから思い切って自分をぶっつけてガチャガチャになってしまいたいんです」「アンタみたいな方は恋愛もなにも出来ないのね」「恋愛……恋愛なんて……ハハハハ」「マア。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどいまコウノトリがその上に立って、くちばしをガチャガチャやっていました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "すずの兵隊さんたちも、いっしょにあそびたくなって、箱の中で、しきりにガチャガチャやりました。",
              "citation": {
                "source": "すずの兵隊さん",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "お皿たちは、みんなよろこんで、ガチャガチャ言いました。",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど、そんなに、くさりをガチャガチャさせないでくれたまえ。",
              "citation": {
                "source": "雪だるま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど、そのかぎたばのガチャガチャいう音が聞えると、お花たちはすぐにひっそりとなって、長いカーテンのうしろにかくれてしまうんだよ。",
              "citation": {
                "source": "イーダちゃんのお花",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "あそこにガチャガチャがいますよ。",
              "citation": {
                "source": "がちゃがちゃ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな声をしているから遠くからでもわかりますよ」　と言う人間の声がすぐそばできこえましたので、これは大変と、急いでガチャガチャ言うのをやめていると、間もなく頭からポカリと袋をかむせられて籠の中へ入れられてしまいました。",
              "citation": {
                "source": "がちゃがちゃ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頭の上からサアベルのガチャガチャ言う音と、二人の男のヒソヒソした会話が聞えて来た。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……と思う間もなく古バケツの中へ編上靴の片足をガチャガチャと突込んだ。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い巡査は或る朝サアベルをガチャガチャいわせてそのお邸の門を潜った。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その背後から佩剣の音がガチャガチャと聞こえて来た。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "忙しゅうてどもならん」ガチャガチャ机の抽斗をあけたり、帳簿をくったりして、いかにも忙しそうな物音を立てていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そのとき突然、暴れて取っ組み合いになり、ガチャガチャという音と、ぎゃあという叫びが聞こえた。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "『小父さん、草の根がガチャガチャ鳴らしてゐるやうな響きがするよ』　小さな裸の児供は土から生へてゐる一本の草にそつと耳を当て地の底の唄ひ声に聞き惚た。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "習慣というものは恐ろしいもので、雄太郎君の予想通り実直な老配達夫は、もうポストの前へ屈みこんで取出口にガチャガチャと鍵をあてがっていた。",
              "citation": {
                "source": "石塀幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分の前に、山とつまれていた点数の札を、ガチャガチャかき廻した。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "羅生門から鬼の使者でも来やがったのかな」　ガチャガチャしてさえいたら、それでむしが納まるとみえて、しきりにひとりではしゃぎながら出ていったようでしたが、まもなく引き返してくると、鬼の首でもとったように手の中で一通の書状をひらひらさせながら、口やかましくいいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "青や赤やのいろいろ取り交ぜた布切れがたらりとさがっておって、それをひっぱるとガチャガチャボンボンと変な音を出すものがありまさね」「わにぐちか」「そうそう、わにぐちですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　年を取って指先きが顫えるらしく、それにかじかんでいるので、うまく鍵穴に鍵が入らずガチャガチャとそのまわりをつッついた。",
              "citation": {
                "source": "独房",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍帽を脇の下に挟んで、ピカピカした膝迄の長靴に拍車をガチャガチャさせて、壇に上ってくると、今迄ガヤガヤ騒いでいたのが、抑えられたように静かになった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガチャガチャ虫がひときわ高く鳴き立てている。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "清三の財布は銀貨や銅貨でガチャガチャしていた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガチャガチャと金属製の器具がすれ合う音を聞いていると、いよいよいけなかった。",
              "citation": {
                "source": "人体解剖を看るの記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ畳もすっかり入れてありません」　先生は隠居さんから受取った鍵で錠前をガチャガチャ言わせて、誰も留守居のない、暗い家の中へ高瀬を案内した。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
