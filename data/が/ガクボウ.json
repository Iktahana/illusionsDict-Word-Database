        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "入学式では、新入生全員に学帽が渡された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は大学時代の思い出として、古い学帽を今も保管している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "マーチングバンドは、ユニフォームの一部として特徴的な学帽を着用していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「運動会には学帽を忘れないでね！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "私の正面の壁に子供の小学校の霜降の服と、糊でビリビリの日覆をかけた小学帽とが掛かつてゐた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――植木屋、古本屋、万年筆屋、果物屋、支那人、大学帽……。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "梶が出て行ってみると、そこに高田が立っていて、そしてその後に帝大の学帽を冠った青年が、これも高田と似た微笑を二つ重ねて立っていた。",
              "citation": {
                "source": "微笑",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "学帽を脱いだ栖方はまだ少年の面影をもっていた。",
              "citation": {
                "source": "微笑",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一見彼女の弟かと見える槙三は、帝大の学帽のまま最初から稀に見る穏やかな笑顔をつづけて黙礼したきり、始終黙りつづけていた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の教師は学校以外の場所では中折帽をかぶったり鳥打帽に着流しで散歩することもあるが、校長だけは年百年中学校の制帽で押し通している、白髪のはみだした学帽には浦和中学のマークがいつも燦然と輝いている。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の上には、小さな四角い大学帽がのって、上から赤い房がたれている。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の上には、四角い大学帽のかわりに、白いヘルメット帽がのっている。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはじつに、ユークリッドの幾何学を超越し」　と、ここまでいうと、れいの花のような女助手が左右から雨谷のうしろにきて、雨谷のからだに、うらがまっかな大学教授のガウンを着せ、それから雨谷の頭の上に、ふさのついた四角い大学帽をのせる。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はちよつと町の通りに視線を走らせると、今にもそこへ、中学の霜降服を着た、学帽の少年がちよろちよろと小走りに現はれて来さうな気がしてならなかつた。",
              "citation": {
                "source": "青年",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の副室に退くや否や、或人は大学帽を被り、或人は獺の毛皮を襟に附けた外套を被り、或人は弁護士試験に応じる準備の筆記を入れた包を小脇に挟んで帰る。",
              "citation": {
                "source": "産褥の記",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三田の学帽をふつてゐる。",
              "citation": {
                "source": "暗い青春",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "傲岸な眼は六尺に近い大男であつたのに、破れた小倉のズボンや、汚い学帽によつて、まだ中学生の若さであることが分つた。",
              "citation": {
                "source": "傲慢な眼",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その子の小さな学帽が泥だらけになって地面に落ちていました。",
              "citation": {
                "source": "寡婦",
                "author": "モオパッサン",
                "note": "青空文庫"
              }
            },
            {
              "text": "天秤棒をキシませながら、ふれ声をあげて、フト屋敷の角をまがると、私と同じ学帽をかぶった同級生たちが四五人、生垣のそばで、独楽などをまわして遊んでいるのがめっかる。",
              "citation": {
                "source": "こんにゃく売り",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "学帽の庇が影をおとす端正な顔は、凛々しいほどにひきしまっていて、あのときの青年のような卑しげなところや、追いつめられたけだもののような、みじめな感じはなかった。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして美という徽章のついた学帽をかむつた彼等が私よりどこか大人めいていることと、その大人めいているものに対抗できない泥くささを私は自分に感じた。",
              "citation": {
                "source": "洋灯はくらいか明るいか",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の紹介でその弟の津村信夫が登場した軽井沢の家では、まだ白面豊頬の青年で慶応の学帽をかむり、いつも濶達に大声で談笑した青年であった。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "学帽白ガスリの青年が突然訪ねて、父、会社より急に帰宅、父子ハンケチで眼を拭う状を童心につよく印象づけられた。",
              "citation": {
                "source": "年譜",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいでしょう、どうぞ」と出てきた彼はいい、信二の学帽をみて笑いかけた。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つはベチャベチャな学帽。",
              "citation": {
                "source": "乞はない乞食",
                "author": "添田唖蝉坊",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し投げ込まれた物が白い色をしてゐると、彼はわざわざ風琴の手をやめて、冠ってゐる鳥打を脱いで、下の学帽に頭が届くまで最敬礼をする。",
              "citation": {
                "source": "乞はない乞食",
                "author": "添田唖蝉坊",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺がかった春服を着て、同じ色の学帽の様な一種の鳥打帽子の、深いひさしの下から、闇の中に柔軟な線の、ほの白い顔が浮上っていた。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
