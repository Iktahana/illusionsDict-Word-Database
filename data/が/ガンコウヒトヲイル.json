        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "剣道家は、試合前、対戦相手を眼光人を射るような鋭い視線で睨みつけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "尋問官の眼光人を射るような質問に、彼はたじろいだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "演説中、政治家は聴衆一人ひとりを眼光人を射るように見つめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の眼光人を射るような熱意に、周りの人々は動かされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この使が帰国しての報告の中に、秀吉の容貌｜矮陋面色｜※黒、眼光人を射るとある。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "会々宗徒の部将有江｜休意、黒髪赤顔眼光人を射る六尺の長身を躍して至った。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "髯鬚長く垂れて、眼光人を射る。",
              "citation": {
                "source": "白河の關",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
