          "literary": [
            {
              "text": "すると、とつぜん、頭巾が、がしゃがしゃと動きだし、すっーと長く伸びたかと思うと、その先端が、くるっと曲って本の方へのび、そして本のページを折ると、ばたりと本を閉じた。",
              "citation": {
                "source": "特許多腕人間方式",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋にはもう電燈がついて、その晩の食物を拵えるために、お島は狭い台所にがしゃがしゃ働いていた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "店の方へ行って、構うことはない、一升壜から冷酒をコップについで、それをあおりながら、がしゃがしゃ洗い物をした。",
              "citation": {
                "source": "花ふぶき",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "外輪の船はがしゃがしゃと、平らな水をきって、湖水の右左に寄り路をしてゆく、暢気な旅にはそれもうれしかった。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            }
          ]
        }
