    "definitions": [
      {
        "index": 1,
        "gloss": "with a swoosh",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "物陰から、がさっと音がして、黒猫が飛び出してきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "風が吹いて、藪ががさっと揺れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は落ち葉をがさっと一かき集めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "陽の光がさっと流れて入りました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がさっきほんとに情なくなってと言ったら、政夫さんは笑っておしまいなしたけど……」　面白く遊ぼう遊ぼう言うても、話を始めると直ぐにこうなってしまう。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからのことは妾がさっきお話したとおりです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、まもなくすぐそこの、今まで開いていた窓に青いカーテンがさっと引っぱられた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵でも描くような心持がさっぱりなくなってしまったので、総持寺見物のつもりで奥へはいって行った。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（ふん、あれがさっきの柳沢の杉だ。",
              "citation": {
                "source": "柳沢",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはけれども気持ちがさっぱりした。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三時ごろ水がさっぱり来なくなったからどうしたのかと思って大堰の下の岐れまで行ってみたら権十がこっちをとめてじぶんの方へ向けていた。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おみちがさっきのあの顔いろはこっちの邪推かもしれない。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "チュンセがさっぱりごはんもたべないで毎日考えてばかりいるのです。",
              "citation": {
                "source": "手紙　四",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "オレンジの混った弱い日光がさっと船を漁師を染める。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "根方の処の土が壊れて大鰻を捏ねたような根が幾筋ともなく露れた、その根から一筋の水がさっと落ちて、地の上へ流れるのが、取って進もうとする道の真中に流出してあたりは一面。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう見方からすれば、芸術的な高級演劇がさっぱり商売にならないで芸術などは相手にしない演劇会社社長の打つ甘い新派劇などが満員をつづけるのが不思議でなくなるようである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、この森が私へこの話をしたあとで、私は財布からありっきりの銅貨を七銭出して、お礼にやったのでしたが、この森は仲々受け取りませんでした、この位気性がさっぱりとしていますから。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷たい霧がさっと清作の顔にかかりました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那の地理のことを書いた本なら見たいなあと仔牛は思ひましたがもう狐がさっさと廊下を行くもんですから仕方なく又ついて行きました。",
              "citation": {
                "source": "黒ぶだう",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の光がさっと流れてはいりました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがさっきの歌はその子供らでもないようでした。",
              "citation": {
                "source": "マグノリアの木",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一人の子供がさっきよりずうっと細い声でマグノリアの木の梢を見あげながら歌い出したからです。",
              "citation": {
                "source": "マグノリアの木",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして陽がさっと落ちて来ました。",
              "citation": {
                "source": "谷",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒るも喜ぶも感情というものがさっぱり出ないんだ。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉次は投げるように身を横にして手荒く団扇を使いホッとつく嘆息を紛らせばお絹『吉さんまだ風邪がさっぱりしないのじゃアないのかね。",
              "citation": {
                "source": "置土産",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『先生どこを歩いていました今まで、幸ちゃんがさっきから待っていますよ。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは飲み干して自分の顔を見たが、野卑な喜びの色がその満面に動いたと思うとたちまち羞恥の影がさっと射して、視線を転じてまた自分を見て、また転じた。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、今まで素直に素直にとしていたらしいおぬいさんの顔色がさっと変って、死んだもののように青ざめた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "段へ、裾を投げ出して、欄干につかまった時、雨がさっと暗くなって、私はひとりで泣いたんです。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中になってから「とっこべ、とら子」とその沢山の可愛らしい部下とが又出て来て、庭に抛り出されたあのおみやげの藁の苞を、かさかさ引いた、たしかにその音がしたとみんながさっきも話していました。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時だ、何か黄いろなやうなものがさっとうしろの方で光った。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は実は宣伝書にも云って置いた通り充分詳しく論じようと思ったがさっきからのくしゃくしゃしたつまらない議論で頭が痛くなったからほんの一言申し上げる、魚などは諸君が喰べないたって死ぬ、鰯なら人間に食われるか鯨に呑まれるかどっちかだ。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
