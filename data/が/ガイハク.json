[
  {
    "uuid": "54cf0135-3923-5933-99bd-8b220b158855",
    "entry": "外泊",
    "reading": {
      "primary": "がいはく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
