        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女の指が奏でるガットギターの音色は、聴衆を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "静かなカフェで、ガットギターの生演奏が心地よく響いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は学生時代に憧れて、初めてのガットギターを手に入れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "慶一はロッカーをあけて、じぶんのガットギターをひっぱりだしたが、ケースをあけるのは気がすすまない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こうでしょ」　苦労しながら、ガットギターの幅広なフレットで、佐藤は片桐のコードを再現する。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階はいいとしても、四階も三階も、ピックギターやガットギターでやるのは、「あんまり」な曲だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "フェンダー・ストラトキャスターを買う金があれば、慶一のガットギターを四〇本買って、おつりがくる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんといっても、ガットギターでロックンロールをやるわけにはいかない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
