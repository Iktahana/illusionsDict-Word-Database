    "definitions": [
      {
        "index": 1,
        "gloss": "New Year's Day",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "元日の朝は、家族揃っておせち料理を食べるのが我が家の習わしだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "毎年元日には、近所の神社へ初詣に行くことにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "元日に届いた年賀状を一枚一枚読むのが楽しみだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "或る元日の朝、蕪村はその幼時の骨牌を追懐し、これを初日出のイメージに聯結させたのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝は宿で元日の雑煮をこしらえるのに手まがとれた。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く手廻しをすればよいのに、元日になってから慌てて書き始める、そうして肩を痛くし胃を悪くして溜息をしているのが、傍から見ると全く変った道楽としか思われないのであった。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来るならば暮の内に学校へ帰ってしまいたかったけれど、そうもならないでようやくこらえて、年を越し元日一日置いて二日の日には朝早く学校へ立ってしまった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お増も今年きりで下ったとの話でいよいよ話相手もないから、また元日一日で二日の日に出掛けようとすると、母がお前にも言うて置くが民子は嫁に往った、去年の霜月やはり市川の内で、大変裕福な家だそうだ、と簡単にいうのであった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年は元日以來一度も病臥に及んだ事なく、生れて初めての輝かしき記録だつたが、やつぱり一年間とは通せなかつた。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっこう元日らしいところはありません。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば小さい子供がおおぜいあるような家ではちょうど大晦日や元日などによくだれかが風邪をひいて熱を出したりする。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "船頭たちがなぜ素袍を着て、立烏帽子を被っていないと思うような、尊い川もござりまする、女の曳きます俥もござります、ちょうど明日は旧の元日。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに御老職末席なる恩田杢殿方は一家内能く治まり、妻女は貞に、子息は孝に、奴婢の輩皆忠に、陶然として無事なること恰も元日の如く暮され候。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の春着で、元日あたり、大して醉ひもしないのだけれど、目つきと足もとだけは、ふら／＼と四五人揃つて、神樂坂の通りをはしやいで歩行く。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天明六、丙午年は、不思議に元日も丙午で此の年、皆虧の蝕があつた。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初に申し上げました文久二年、この年はお正月の元日に大雪が降りまして、それから毎日風が吹きつづけて、方々に火事がありました。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "元日、とうぜんとしていたら、鴉が来て啼いた。",
              "citation": {
                "source": "雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "元日に、次男は郊外の私の家に遊びに来て、近代の日本の小説を片っ端からこきおろし、ひとりで興奮して、日の暮れる頃、「こりゃ、いけない。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑録でも短篇でも小説でも乃至は俳句漢詩和歌でも、苟くも元日の紙上にあらわれる以上は、いくら元日らしい顔をしたって、元日の作でないに極っている。",
              "citation": {
                "source": "元日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君子は已を得ず年にちなんで、鶏の事を書いたり、犬の事を書いたりするが、これは寧ろ駄洒落を引き延ばした位のもので、要するに元日及び新年の実質とは痛痒相冒す所なき閑事業である。",
              "citation": {
                "source": "元日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら初刷だって、そんな無駄話で十頁も二十頁も埋られた日には、元日の新聞は単に重量に於て各社ともに競争する訳になるんだから、其の出来不出来に対する具眼の審判者は、読者のうちでただ屑屋丈だろうと云われたって仕方がない。",
              "citation": {
                "source": "元日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も浮で来なかったので、一昨年の元日の事を書いた。",
              "citation": {
                "source": "元日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年の元日に虚子が年始に来たから、東北と云う謡をうたったところ、虚子が鼓を打ち出したので、余の謡が大崩になったという一段を編輯へ廻した。",
              "citation": {
                "source": "元日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の順で行くと此年は又去年の元日を読者に御覧に入れなければならん訳であるが、そうそう過去のまずい所ばかり吹聴するのは、如何にも現在の己に対して侮辱を加えるようで済まない気がするから故意と略した。",
              "citation": {
                "source": "元日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "元日新聞へ載せるものには、どうも斯う云う困難が附帯して弱る。",
              "citation": {
                "source": "元日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし世間が元日に対する僻見を撤回して、吉凶禍福共にこもごも起り得べき、平凡｜且乱雑なる一日と見做して呉れる様になったら、余も亦余所行の色気を抜いて平常の心に立ち返る事が出来るから、たとい書く事に酔払いの調子が失せないにしても、もっと楽に片付けられるだろうと思う。",
              "citation": {
                "source": "元日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もそうなれば、初刷の頁も平常に復する訳だから、とくに元日に限って書かねばならぬ必要も消滅するかも知れない。",
              "citation": {
                "source": "元日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも物淋しい様だが、昨今の如き元日に対して調子を合せた文章を書こうとするのは、丁度文部大臣が新しい材料のないのに拘らず、あらゆる卒業式に臨んで祝詞を読むと一般である。",
              "citation": {
                "source": "元日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年の元日の朝陽はさはやかであつた。",
              "citation": {
                "source": "雜煮",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其年は明けて天正十九年正月元日、氏郷は木村父子を携えて名生を発して会津へと帰る其途で、浅野長政に二本松で会した。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり　とちゅうで　ぶらぶら……」正月の　しゃれこうべ　あるとしの　正月の　がんじつの　ことでした。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
