[
  {
    "uuid": "e1eb6dc4-9285-5425-abe8-c8c9646d255d",
    "entry": "顔面蒼白",
    "reading": {
      "primary": "がんめんそうはく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
