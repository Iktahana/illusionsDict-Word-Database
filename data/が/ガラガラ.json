    "definitions": [
      {
        "index": 1,
        "gloss": "with a clatter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大きなトランクをガラガラと引きずって駅の改札を通った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "工事現場のトラックが、資材を載せてガラガラと音を立てて通り過ぎた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夜中に隣の部屋から物がガラガラと落ちる音がして目が覚めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "奴等の頭は言葉でガラガラになり、奴等の心は根も葉もないのだ。",
              "citation": {
                "source": "（辛いこつた辛いこつた！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ霰が降って来たので、隣家の鍋にガラガラ鳴って当るのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オイ、もう五尺は入っただろう」　ガラガラッとハンドルを廻しながら、六尺鑿を抜き出した。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、土方風の男が一人縄で何かガラガラ引きずりながら引っぱって来るのを見ると、一枚の焼けトタンの上に二尺角くらいの氷塊をのっけたのを何となく得意げに引きずって行くのであった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正池の畔に出て草臥れを休めていると池の中から絶えずガラガラガラ何かの機械の歯車の轢音らしいものが聞こえて来る。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどあのガラガラの音ぐらいでは三百六十五日浚ってみたところで梓川がただの一と雨に押し流してくる砂泥をすくい上げるにも足りないのではないかという気がするのであった。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "王蛇とガラガラ蛇との二つの世界は重なり合っている。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "王蛇のほうの神経の働く速度がガラガラ蛇のそれよりもほんの若干だけ早いために、前者の口嘴が後者のそれを確実に押えつけるものと見える。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガラガラ蛇が横ばいをするのも奇妙である。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、そのとき、入口の戸をガラガラと乱暴にあけて、茶色のジャケツをきた少年が手さげかばんを持ってはいってきました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に私の頭の中に高く高く積み重なっていた硝子器の山が一時にガラガラガラッと崩れ落ち始めたような気がした。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸の中がガラガラ鳴った。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "海水をのむと安心したのか、心が静まって、胸のガラガラ鳴る音が止んだ。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭をうしろへそらせて、しっぽの上においてみせたり、小さなガラガラのように、くちばしで鳴いてみせたりするのです。",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、何かやっていましたが、見ると、今度はガラガラを作りました。",
              "citation": {
                "source": "ブタ飼い",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、そのとき、入口の戸をガラガラと乱暴にあけて、茶色のジヤケツを着た少年が手提鞄を持つてはいつて来ました。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけにその頃の人力車の輪は、ガラガラと鳴る重い鉄輪だったのである。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "引き息で飛着いた、本堂の戸を、力まかせにがたひしと開ける、屋根の上で、ガラガラという響、瓦が残らず飛上って、舞立って、乱合って、打破れた音がしたので、はッと思うと、目が眩んで、耳が聞えなくなった。",
              "citation": {
                "source": "星あかり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見世物の大将を送って部屋から出られて、たちまち、ガラガラドシンの大音響、見事に階段を踏みはずしたのである。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもより不健康に濁った声が、夜更けの時間と、肩に掛けたアコーディオンの重さをガラガラと無気力に響かせていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイ、ダアーリングね」　バーテン台の中にいる夏子は、舌を噛みそうな外国語を、ガラガラした声で言って、不器用な手つきで京吉の肩をぶった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガラガラしたしわがれた声や、人一倍大きく突き出した鼻も、案外彼女のさびしい貞淑さを裏切っていなかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "五六ちゃん、おれたちもキャッキャッで行こうよ」　グッドモーニングの銀ちゃんがガラガラとパイをかきまぜながら言うと、祇園荘の女が、「キャッキャッって、一体何のことです……？",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "認識不足だわ」　どうも言っている言葉がいちいち場違いにチグハグだったが、それよりも、受話器を通すと、ガラガラした声が一層なまなましく乾いて、あわれな肉感味を帯びているのが、たまらなかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "空の車をガラガラひいて岸和田の駅まで来ると、電車の音がした。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、市中をガラガラ引き廻しながら、あやしげな名所案内の説明をやり、宿屋へ送りこむと、名所の説明代は一ヵ所五銭だ、六十ヵ所説明してやったから三円くれと、凄むのである。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
