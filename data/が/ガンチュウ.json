    "definitions": [
      {
        "index": 1,
        "gloss": "(one's) consideration",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は自分を全く眼中に入れていないようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "そんな些細なことは、私の眼中にはありません。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ライバルチームは我々を眼中になく、油断していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、新しいプロジェクトの提案を全く眼中に入れようとしなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "登山者の眼中には、金剛不壊の山の本体の前に、永久性の大鳥居がただ一つあるばかりだ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩尖、膝頭、臀部、あたま――翁の眼中、一々、その凸所の形に似通う山の姿が触覚より視覚へ通じ影像となって浮んで来た。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士道と言えば、女は眼中にないような風に言われながら、正妻となるとなかなか格式を与えて十分な権利を主張せしめている。",
              "citation": {
                "source": "女性崇拝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は何処までも快活な男で、放胆で、而も眼中人なきの様子がある。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下の百姓を見てもすぐと理屈でやり込めるところから敬して遠ざけられ、狭い田の畔でこの先生に出あう者はまず一丁｜前から避けてそのお通りを待っているという次第、先生ますます得意になり眼中人なく大手を振って村内を横行していた。",
              "citation": {
                "source": "初恋",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はその一二を受けながら、シナの水兵は今時分定めて旅順や威海衛で大へこみにへこんでいるだろう、一つ彼奴らの万歳を祝してやろうではないかと言うとそれはおもしろいと、チャン万歳チャンチャン万歳など思い思いに叫ぶ、その意気は彼らの眼中すでに旅順口威海衛なしである。",
              "citation": {
                "source": "遺言",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時若々しい希望に満ちて理想のほか何物も眼中になかった叔父と、そろそろ家庭以外の世界に目をあけかかった感受性に富んだ甥との間には、夢のような美しい空想の国が広がっていた事であろう。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "星野が衆評などをまったく眼中におかないで、いきなり物の中心を見徹していくその心の腕の冴えかたにたじろいたのだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尠くともお酒が這入つてゐれば、淡白といふか愚かといふか、人が体面を慮つて遠慮するていのことくらゐは、ても眼中にないのである。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "隨分無謀な事だ、今頃から斯る深林に向つて探險するのは、けれど興に乘じたる吾等の眼中には、向ふ處敵なしといふ勢で、二三｜里進んで、其深林の漸く間近になつた時分日は全く暮れた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "武村兵曹は眼中に無念の涙を浮べて、今も猶ほ多少仇浪の立騷いで居る海面を睨んで居る。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事は民力の発展などは眼中にない愚劣政治家共に話したとて分るまいが、真に国家の前途を憂うる人士は、大いに沈思熟考せねばならぬ問題であろうと思う。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "凹垂れ剛力などは眼中にない。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "松村君はえらくなつちまつて、俺なんぞ眼中に無いんだ。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　照子は眼中に涙を湛えて、屹と婦人を凝視ながら、「それでは。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とは、さてもさても気の着いた、しかも無類の容色好し、ただ眼中に凄味を帯びて、いうべからざる陰険の気あり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小児なぞは眼中にない、男は二人のみだったから。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "況て市郎は、最初から彼のお葉という女を意中は愚、眼中にも置いて居なかったのであるが、今日の一件に出逢って聊か意外の感を作した。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の関心は、東京の文化と、東京を通じて輸入される外来思想とのみに存して、自分たちの故郷の天地山川や人情風俗は、眼中にないかの如くである。",
              "citation": {
                "source": "東京文壇に与う",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論家の興廢などゝいふことは頭で眼中に置いてゐなかた。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "從ツて慘忍を極め辛辣を極めて、殆んど何物も眼中に置かず、眞箇シヤイロツク的人物となツて了ふ。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "女など眼中になかったのです。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生涯の大勢は構わないその日その日を面白く暮して行けば好いという人があるように、芝居も大体の構造なんか眼中におく必要がない、局部局部を断片的に賞翫すればよいという説――二宮君のような説ですが、まあその説に同意してみたらどんなものでしょう。",
              "citation": {
                "source": "虚子君へ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「学位令の解釈上、学位は辞退し得べしとの判断を下すべき余地あるにもかかわらず、毫も小生の意志を眼中に置く事なく、一図に辞退し得ずと定められたる文部大臣に対し小生は不快の念を抱くものなる事を茲に言明致します。",
              "citation": {
                "source": "博士問題の成行",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生観が是より以上に上れぬとすると是が絶対的に第一義かも知れぬが、もし生死の関門を打破して二者を眼中に措かぬ人生観が成立し得るとすると今の所謂第一義は却って第二義に堕在するかも知れぬ。",
              "citation": {
                "source": "高浜虚子著『鶏頭』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣食問題などは丸で眼中に置いていない。",
              "citation": {
                "source": "処女作追懐談",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼈四郎はこう思って来ると夫妻の権威は眼中に無くなって、肩肘がむくむくと平常通り聳立って来るのを覚えた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "真に思ひ切つたる豪胆無比の御裁決、三浦さまほどの御大身も何もかも、いつさい、御眼中に無く、謂はば天理の指示のままに、さらりと御申渡しなさる御有様は、毎度の事とは申しながら、ただもう瞠若、感嘆のほかございませんでした。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生の人格は、僕の眼中に於いて、また心裡に於いて、偉大である。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは当然の事で、私などには、それにこだはる資格も何も無いのであるが、とにかく、現実は、私の眼中に無かつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
