[
  {
    "uuid": "545c7756-90cb-5a83-9db7-5135708032e8",
    "entry": "眼中",
    "reading": {
      "primary": "がんちゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
