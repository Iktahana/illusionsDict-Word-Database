    "definitions": [
      {
        "index": 1,
        "gloss": "petitioner",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "村の代表として、彼は願人として藩庁へ赴いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "願人は陳情書を手に、ひたすら待っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "多くの願人が集まり、奉行所に詰めかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "願人　旗本小普請頭　大和田　十郎次右証人　　旗本　　　早乙女主水之介　大目付御係御中「どうじゃ。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "願人　旗本小普請頭　大和田　十郎次右証人　　旗本　　　早乙女主水之介大目付御係御中「どうじゃ。",
              "citation": {
                "source": "旗本退屈男",
                "author": "第八話　日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "――十軒店を左に折れて俗称願人坊主の小路といわれた伝右衛門横町、その横町の狭い路地をどんどん奥へはいっていくと、奇怪です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "願人坊雪のふる夜の倉見れば願人坊を思ひ出す。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "願人坊は赤頭巾、目も鼻もなく、眞白なのつぺらぽんの赤頭巾。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちよぼくれちよんがら、そもそもわつちがのつぺらぽんのすつぺらぽん、すつぺらぽんののつぺらぽんの、坊主になつたる所謂因縁きいてもくんねへ、しかも十四のその春はじめて」…………踊り出したる惡玉が願人坊の赤頭巾。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪のふる夜の倉見れば願人坊を思ひ出す。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "（けふは長屋の井戸がへにて、相長屋の願人坊主、雲哲、願哲の二人も手傳ひに出てゐる體にて、いづれも權三の家の縁に腰をかけて汗をふいてゐる。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉢卷をしたつて、すつとこ被りをしたつて、願人坊主の相場がどう上るものか。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この願人坊主め、早く行つて來い。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（與助は猿を縁におろして、怖々ながら留めようとしてゐると、上のかたより願人坊主の雲哲と願哲は商賣に出る姿にて、住吉踊の傘をかつぎて出で、これを見て騷ぐ。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "パチンコの発明　昭和二年実用新案広告第一一六七七号（類別第一十五類五、銃弓及射的玩具）――出願人、東京府下本田村立石、×田×次郎氏。",
              "citation": {
                "source": "発明小僧",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "芋焼器の発明　昭和五年実用新案広告第八八三四号（類別、第九十六類九、飲食物製造機雑）――出願人、山形市×澄町吹張、伊×長兵衛氏。",
              "citation": {
                "source": "発明小僧",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛馬両便器の発明　昭和二年実用新案広告第四二九四号（類別、第七十五類五、家畜用便器）――出願人、四谷区永住町、中×清氏。",
              "citation": {
                "source": "発明小僧",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "關東の眞中へ一大沙漠地を造られて平氣で居る病氣の人間が、殺されないやうにして呉れいと言ふ請願人を、政府が打ち殺すと云ふ擧動に出でたる以上は、最早自ら守るの外は無い。",
              "citation": {
                "source": "亡國に至るを知らざれば之れ即ち亡國の儀に付質問",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "」請願人がワイ／＼言ふのは皆な洪水を幸にして、あれも鑛毒是も鑛毒と、洪水の害を鑛毒へ引き付けるのだなど言ひ譯する。",
              "citation": {
                "source": "公益に有害の鑛業を停止せざる儀に付質問書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に茨田は瀬田の妻子を落して遣つた上で自首し、父柏岡と高橋とも自首し、西村は江戸で願人坊主になつて、時疫で死に、植松は京都で捕はれた。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸で願人坊主になつて死んだ西村｜丈は、浅草遍照院に葬つた死骸が腐つてゐたので、墓を毀たれた。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけにその手数料も、所長の指図で半額だけ出せばよいことになり、あとの半額は有耶無耶になって、いずれ他の請願人が穴埋めをさせられることになるのだろう。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "』などといふ調子なんだが、これがどうして、何か頼みこんで來る請願人と見れば、きれいに剥いて襯衣一枚にしてしまふのだ。",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前は、日本橋区の松島町とおなじ層の住民地で、多く願人坊主がいたのだそうだ。",
              "citation": {
                "source": "神田附木店",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "多寡は厭わぬ願人坊主じゃ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれど、そういう願人坊主が。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "物売りの部へ入れるのは妙だが、神田橋本町の願人坊主にも、いろいろ面白いのがいた。",
              "citation": {
                "source": "梵雲庵漫録",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "person who prays",
        "register": "standard",
