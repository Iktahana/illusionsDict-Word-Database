        "examples": {
          "standard": [
            {
              "text": "病院で処方してもらった含嗽薬で、喉の痛みがだいぶ和らいだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「この含嗽薬、ちょっと苦いけど、効き目は確かだから頑張って。」と薬剤師さんに言われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供が嫌がらないように、甘い味の含嗽薬を選んであげた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "医師の指示通りに、含嗽薬を水で薄めて使っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「は」　と奥さまは含嗽薬を持って行った。",
              "citation": {
                "source": "閣下",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
