        "examples": {
          "standard": [
            {
              "text": "歴史博物館の展示は、アウシュヴィッツ強制収容所のガス室の悲劇を伝えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は、ホロコーストに関するドキュメンタリーでガス室の映像を見て、言葉を失った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "その史跡には、かつてガス室として使われた建物が、歴史の証人として静かに残されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "ポーランドに有ったというドイツのガス室の件は本当か？",
              "citation": {
                "source": "ナショナリズムについての覚書",
