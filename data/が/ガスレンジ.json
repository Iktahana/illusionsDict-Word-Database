        "examples": {
          "standard": [
            {
              "text": "新しいガスレンジを買ったので、早速料理をしてみよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このガスレンジ、火力が強くて使いやすいわ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "一人暮らしを始めたばかりの友人に、ガスレンジをプレゼントした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔ながらのガスレンジで、おばあちゃんが毎朝パンを焼いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "台所は冷蔵庫も、ガスレンジも設けてあって、申しぶんなくできている。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "電気冷蔵庫も、ガスレンジも、もちろん便利なものであり、アメリカでは、生活必需品であるが、それよりももっと本質的なものは、温湯装置と煖房設備とである。",
              "citation": {
                "source": "ウィネッカの秋",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガスレンジじゃない、料理用じゃない、小箱もある。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
