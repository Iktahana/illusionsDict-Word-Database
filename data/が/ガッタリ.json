[
  {
    "uuid": "ce930ab3-b2fb-5790-af68-f348abe39498",
    "entry": "がったり",
    "reading": {
      "primary": "がったり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "suddenly (esp. falling)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あの山は眠ったことがないから、醒めたこともないというような、澄した顔つきをしている、私たちとの距離は、いよいよ遠くなった、その間を煙のように、眼先を霧が立って、右へ往きそうになったり、左へ思い出して、転がったりしている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "この曲線は上がったり下がったり、不規則な波状を画いているが、この波の一つの峰から次の峰までの文字数がかなり広い範囲内で色々に変っている。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い『フィル・マグ』〔Philosophical Magazine〕の中から「首釣の力学」や「人玉について」などという論文を発見してひどく嬉しがったりしたのもその頃であった。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "レーノルズの全集をひやかしてこの異彩ある学者を礼讃してみたり、マクスウェルの伝記中にあるこの物理学者の戯作ヴァンパヤーの詩や、それを飾る愉快に稚拙なペン画を嬉しがったりした。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾達の列車が巴里盆地にさしかかると、佐野は何の理由もなしに、巴里を極度に嫌がって、バルセロナを懐しがったりして、女のように神経質になっていました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、第一回は、はずかしがったり、気をもんだりしたすゞと、トシ子が、うまく、やすやすとやりおおせた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はね上がったり、すねを突いて、物置の奥へ手を突ッ込む拍子に、大褂児の裾から、フト軍服の※子がまくれ出た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、春だ、うたったり走ったり、とびあがったりするがいい。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうにもう、走ったりうたったり、飛びあがったりするがいい。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して、ギバがなんらかの空中放電によるものと考えると、たてがみが立ち上がったり、光の線条が見えたり、玉虫色の光が馬の首を包んだりする事が、全部生きた科学的記述としての意味をもって来る。",
              "citation": {
                "source": "怪異考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば化学的分子の立体的構造を考えていた化学者や渦動原子の結合を夢みていた物理学者にはルクレチウスの曲がったり角立ったりした元子は必ずなんらかの暗示を与え得たであろうと思われる。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時にはかなり無雑作に勢いよく筆をたたきつけるとおもしろいように目が生きて来たり頬の肉が盛り上がったりする。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、上着や靴や財布やネクタイピンは、あっちの枝にぶらさがったり、こっちの根もとにちらばったりしています。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角入れた乱杭もあっちへ向いたりこっちへまがったりです。",
              "citation": {
                "source": "化物丁場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いゝえ、まるでちらばってますよ、それに研究室兼用ですからね、あっちの隅には顕微鏡こっちにはロンドンタイムス、大理石のシィザアがころがったりまるっきりごったごたです。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の朝、授業の前みんなが運動場で鉄棒にぶらさがったり、棒かくしをしたりしていますと、少し遅れて佐太郎が何かを入れた笊をそっとかかえてやって来ました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえ、まるでちらばってますよ、それに研究室兼用ですからね、あっちの隅には顕微鏡こっちにはロンドンタイムス、大理石のシィザアがころがったりまるっきりごったごたです。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二楽章十二句になるとよほど活発にあるいはパッショネートになって来て、恋をしたり子をかわいがったり大病をしたり坊主になったりする。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはまた、粉々にくずれた煉瓦の堆積からむくむくと立派な建築が建ち上がったりする。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道庁から退けてきた人、郵便局、裁判所を出た人、そう思わしい人人が弁当の包みを小脇に抱えて、園とすれちがったり、園に追いこされたりした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいったい画伯とか先生とかのくっ付いた画かきが大きらいなんだけれども、……いやよ、ほんとうにあいつらは……なんていうと、お高くとまる癖にひとの体にさわってみたがったりして……けれどもお金にはなるわね。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "巫女　いやみ、つらみや、怨み、腹立ち、怒ったりの、泣きついたりの、口惜しがったり、武しゃぶりついたり、胸倉を取ったりの、それが何になるものぞ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいにはみんなの前を踏むようなかたちをして行ったり、いきなり喧嘩でも吹っかけるときのように、はねあがったり、みんなはそのたんびにざわざわ遁げるようになりました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからみなさんこの町で何か煮たものをめしあがったり、お湯をお使いになるときに、めまいを起さないように願います。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……チャンチキ、チャンチキ、ヒューラと囃して、がったり、がくり、列も、もう乱れ勝で、昼の編笠をてこ舞に早がわりの芸妓だちも、微酔のいい機嫌。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日すると銀子もようやく決心がつき、家へ手紙を書いたが、そうなるとせっかく馴染んだこの土地も、見るもの聞くものが、不愉快になり、東京から人の来るのが待遠しくてならず、気を紛らせに、家へ遊びに来る写真屋を誘い出して、最後の玉稼ぎに料亭へ上がったりした。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姫さまは、水の中へ深くもぐったり、大きな波のあいだに浮びあがったりしているうちに、とうとう、若い王子のところへおよぎつきました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍従は、階段という階段を、あがったり、おりたり、広間をかけぬけたり、廊下を走りまわったりしました。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
