  {
    "uuid": "684ede43-8cef-5f23-94e6-ca1372177fa2",
    "entry": "外部性",
    "reading": {
      "primary": "がいぶせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
