    "definitions": [
      {
        "index": 1,
        "gloss": "drying one's hair (with a hairdryer)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
