    },
    "definitions": [
      {
        "index": 1,
        "gloss": "principal and interest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女には、物事の本質を見抜く鋭い眼力がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ベテランの鑑定士は、その作品の価値を一目で見抜く眼力を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "初心者のうちは、経験豊富な先輩の眼力を借りて、良いものを見分ける練習をするといい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、市場の動向を正確に予測する眼力があり、投資で成功を収めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その監督の眼力は、無名の俳優を発掘し、スターに育て上げたことでも知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "その規約によると、誠心誠意主人のために働いた者には、解雇又は退隠の際、或は不時の不幸、特に必要な場合に限り元利金を返還するが、若し不正、不穏の行為其他により解雇する時には、返還せずというような箇条があった。",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そん代に貸した金千円、元利揃えてたった今貰おうかい。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "元利合計してまっさかいな。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ銀行上本町支店から児子権右衛門預金元利決算報告書が来て、権右衛門の預金が百万円に達したことが分ったからである。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ私の手当てを一躍五十円に引き上げたほかに、私がトックの昔に忘れていた、親孝行に対する新聞社の同情金を叔父が保管していたものが、元利合計二百何円何十何銭かになっていたので、プラチナの腕時計を一個買って下げ渡してくれただけであった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "質札の額面五円の着物ならば、古着屋へは十二、三円から十五円、二十円にも売れる故、質屋へ払う元利と質札を買った金を差引いても、残りの利益は莫大だった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことにそれが女房に貸しつけた金の元利計算と来ては、ぞくぞくするほどたまらない。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「済みません、済みません、この仕事が片づき次第に元利をそろへてお届けしますから、もう暫くの猶予をたのみます。",
              "citation": {
                "source": "沼辺より",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "せいぜい二｜歩か三歩でしたが、それでもだんだんに元利が溜まってしまいまして、今では七、八両になって居ります」「七、八両……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "給科はふいになるし、前借した金にゃ一ケ月三分の利子つけて、元利耳をそろえて返さにゃならねえんだぜ。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "返弁之儀当暮限壱割五歩之利足を加、元利共必然皆済可致、仍之借用始末｜如件候。",
              "citation": {
                "source": "手紙",
                "author": "文久元年十月十四日　田中良助あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "之を人に聞く、方今我國の外債凡そ千五百萬圓、元利共に償却して今後毎年二百萬圓づゝを拂ひ、凡そ二十年、共計四千萬圓の金を拂て皆濟たる可しと。",
              "citation": {
                "source": "亞細亞諸國との和戰は我榮辱に關するなきの説",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、借金は減る所か、月と共にグングン増えて、いつか元利積って二百円余りになった。",
              "citation": {
                "source": "罠に掛った人",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金高は元利合計で、二百二十八円と四十六銭じゃ」「よし」　友木は懐中から紙幣束を引摺り出して、覚束ない手つきで数え始めた。",
              "citation": {
                "source": "罠に掛った人",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "借りて、元利を幾分かずつ支払って行く大名には、豪商も直ちに需に応じたが、返し得ない貧乏藩が沢山あるので、そういうのに対しては、たやすくは応じなかった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年の終わりに二人はヤット元利合わせてすっかりの負債を消却することが出来た。",
              "citation": {
                "source": "頸飾り",
                "author": "モウパンサン",
                "note": "青空文庫"
              }
            },
            {
              "text": "六年目の今日、元利合計、九千なにがしになつてゐるんだ。",
              "citation": {
                "source": "雅俗貧困譜",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのタンポはこの豪華な屋敷ですから、これを元利六七百万で人手に渡すバカな話はないのです。",
              "citation": {
                "source": "能面の秘密",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "就而は此度歸省に付而は、是非亡父の思ひ煩ひ居候義を相解度｜念願に御座候而、元利相｜揃差上候こそ相當の譯に御座候得共、只今｜迚も多人數の家内を相抱居候上、全｜無高之事に候へば、十分之義も不相｜調候に付、何卒右｜邊之處御憐察被成下度奉希候。",
              "citation": {
                "source": "遺牘",
                "author": "西郷隆盛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蔭でいまでは随分の元利合計になっているであろう。",
              "citation": {
                "source": "荒蕪地",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "組合から、年度替りだとの理由で、親父の代にこしらえた借金、元利合計二千百三十円なにがしというものの催告である。",
              "citation": {
                "source": "瘤",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもここは少し大きく、元利合計三千百何円なにがし。",
              "citation": {
                "source": "瘤",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて田辺は農工銀行からも、無尽会社からも、年度替りを理由の催促を――それも前例を破って、いずれも元利合計……まるで破産の宣告でも受けるもののようだった。",
              "citation": {
                "source": "瘤",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の飛騨行き以来、半蔵は家政一切を宗太に任せ、平素くわしいことも知らない隠居の身であったが、それから十年の後になって見ると、青山の家にできた大借は元利およそ三千六百円ばかりの惣高に上った。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉原で相当格式のある貸座敷の主人がワケがあって近々廃業帰国することになり、家財も娼妓もついたまゝ八千円で売りに出ているが、この商売なら五年もかゝれば元利をきれいに返済出来る見込みがある。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十　冷笑鬼",
                "note": "青空文庫"
              }
            },
            {
              "text": "開業さえいたしますれば当日から相当に繁昌いたそうと思われますので、五年で元利の返済はむつかしいこととも思われません。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十　冷笑鬼",
                "note": "青空文庫"
              }
            },
            {
              "text": "志道軒と常友は当日約束の貸金元利とりそろえて持参のこと、いずれも、心得ましたという返事があった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十　冷笑鬼",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそのついでに、百という男は、がんりきと二つ名前の男で、切り落された片一方の手には甲州入墨……」「何を言ってやがるんだ」　下の男と女は、いさかいになったのを、米友は聞き咎めてしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌朝、あのがんりきの何とやらいう小悪党に会わなければならないのだなと思いながら、米友は下へ降りて見ると、お角と女中のほかには誰もいませんでした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "主膳の悪いのに引替えて、いつもこの場を浚って行くは、がんりきの百であります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
