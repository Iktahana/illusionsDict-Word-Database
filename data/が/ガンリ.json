[
  {
    "uuid": "ffbd69fa-0793-529b-a03d-141065d3816f",
    "entry": "元利",
    "reading": {
      "primary": "がんり",
      "alternatives": [
        "げんり"
      ],
      "is_heteronym": false
    },
    "grammar": {
