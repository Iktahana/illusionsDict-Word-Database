        "examples": {
          "standard": [
            {
              "text": "担任の先生が、一人ひとりの学籍簿を開いて出席状況を確認している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い学籍簿を整理していたら、卒業生たちの懐かしい顔写真が出てきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "入学式の後、自分の名前が記載された学籍簿を初めて見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "個人情報なので、学籍簿の閲覧は限られた職員しかできない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "新入生の一人々々を、学齢児童調書に突合して、健はそれを学籍簿に記入し、孝子は新しく出席簿を拵へる。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "西山教頭が何度も電話口に呼び出され、ひるすぎには、五年全部の学籍簿を抱えて県庁に出かけた。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちさとさんのお父さん、大工さんね」　すると千里は、松江そっくりの黒い目を見はって、「ううん、大工さんは、おじいさん」「あら、そうだったの」　しかし彼女の学籍簿には、彼女の父は大工とあった。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
