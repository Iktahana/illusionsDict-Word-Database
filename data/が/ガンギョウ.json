    "definitions": [
      {
        "index": 1,
        "gloss": "Gangyō era (877.4.16-885.2.21)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "元慶年間（がんぎょうねんかん）の記録によると、当時の都は賑やかだったらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この古文書は元慶の時代に書かれたもので、当時の社会情勢がよくわかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "歴史の授業で、元慶という元号について習ったのを思い出したよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "津軽蝦夷の称は、元慶二年出羽の夷反乱の際にも、屡々散見す。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "元慶四年十月の地震は、京都と出雲が震い、同年十二月には、京都付近が震うた。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "元慶元年四月の地震には、京中を垣墻悉く破壊し、宮中の内膳司屋顛倒して、圧死者を出した。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "元慶二年九月に相模、武蔵をはじめ関東一円に地震があった。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その中には、五百羅漢を彫った当羅漢寺の創建者である松雲｜元慶禅師の観音もありましたこと故、私の修業時代は、本所の五ツ目の五百羅漢寺といえば、東京方面における唯一の修業場であって、好い参考仏が一纏まりになって集まっているのでした。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "本所五ツ目の羅漢寺のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから羅漢仏師松雲元慶禅師の作がある。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "蠑螺堂百観音の成り行き",
                "note": "青空文庫"
              }
            },
            {
              "text": "これです」　私の撰み取ったのは、松雲元慶禅師のお作でした。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "私の守り本尊のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうこの元慶禅師のお作のこの観音は私の所有に帰したのだと思うと、心が躍るようでした。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "私の守り本尊のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "當時學問の造詣は如何と云ふに、都良香が貞觀十八年に大極殿が燒けた時に廢朝の事を議した文や、又元慶元年に夜の日食に就ての建議などは、いかにも其の該博を見して居る。",
              "citation": {
                "source": "平安朝時代の漢文學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐の則天武后の時代に、徐元慶がその父の仇と稱する趙師韜を殺害して自首した。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "この點よりいへば、徐元慶の行爲は、奬勵を加ふべきものである。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "この點よりいへば、徐元慶の行爲は、刑罰を加へねばならぬ。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上の二の理由を併せ考へ、徐元慶は死刑に處して國法を正し、然もその門閭や墓所に旌表を加へて、禮教を奬めるがよい。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "加部島には田島神社あり、狭依姫、湍津姫、田霧姫、三柱の姫神を祀る、天平十三年の創営なり、大同元年祭祀料十六戸を付せられ、貞観元年従四位下を贈られ、元慶八年従三位に進み、明治維新の後、国幣中社たるもの。",
              "citation": {
                "source": "松浦あがた",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "綿麻呂の頃から五六十年後の陽成天皇の元慶年間には、出羽方面において、今の秋田県地方の蝦夷が国司の悪政を恨んで暴動を起し、国司も如何ともする事の出来ない程の大騒動となりました。",
              "citation": {
                "source": "本州における蝦夷の末路",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この元慶の出羽の乱を最後として、直接蝦夷に関する事蹟は、中央の記録にはあまり多く見えてはおりません。",
              "citation": {
                "source": "本州における蝦夷の末路",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この元慶の乱から二三十年後、延喜の頃に藤原利仁、すなわち有名なる利仁将軍が、大いに蝦夷を征伐して、昔の坂上田村麻呂、すなわち田村将軍と相比すべき程の、征夷の勇将として伝えられているのでありますけれども、その征夷の事蹟は一向にわからないのであります。",
              "citation": {
                "source": "本州における蝦夷の末路",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "元慶二年出羽の夷俘の反亂あり。",
              "citation": {
                "source": "蝦夷とコロボツクルとの異同を論ず之に潜みて",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "天平の開通を距る約百四十年後の元慶四年において、出羽の国司はこんなことを上言している。",
              "citation": {
                "source": "春雪の出羽路の三日",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "元慶の当時なお仙北の地には、少からず生蕃がいたのだ。",
              "citation": {
                "source": "春雪の出羽路の三日",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに元慶八年七月二十九日の「太政官符」によると、神山四至の中で偸かに猪鹿を射るを厳禁せしむとある。",
              "citation": {
                "source": "濫僧考",
                "author": "河原者・坂の者・宿の者・非人法師",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓼科神（正六位上）　　　　　　　信濃国　　　　　陽成天皇元慶二年九月従五位下。",
              "citation": {
                "source": "山の今昔",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽成天皇元慶二年正月十三日に沙門三修が近江国坂田郡伊吹山護国寺を定額に列せんことを奏請せる条に、少年の時、落髪入道し、脚名山を歴て、周く尽さざるなし、仁寿年中此山に登り到る、即ち是七高山の其一也、其形勢を観るに四面斗絶し、人跡至る希なり。",
              "citation": {
                "source": "山の今昔",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "元慶二年（西暦八七八）及び大正十三年の地震はこの地域から発したもので、前者では相模・武蔵両国の民家がことごとく倒壊破損したと伝えられ、後者の場合には東京市内のみでも全壊二十五戸、半壊七十八戸を生じた。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その寺の五百羅漢は松雲元慶禅師の作で、関東では名作の一つとされて居りました。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "観音様の頬",
                "note": "青空文庫"
              }
            },
            {
              "text": "同十四年御年廿八御母｜伴氏身まかり玉ひ、　陽成天皇の元慶四年八月晦日御父｜是善卿も身まかり玉へり。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "その英賢の為に旌さるること此の如く、元慶八年勅して元慶寺伝法阿闍梨と為す」　これほどの大善智識でありながら、死後すでに一千年、誰もその徳を慕う者がないばかりか、その記念の塔ですらが、世間から冷遇されるとは何と不幸な聖ではないか。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "（こいずみ　しんぞう、東宮御教育参与・経博・元慶応義塾塾長、三二・一）",
              "citation": {
                "source": "庶民の食物",
                "author": "小泉信三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
