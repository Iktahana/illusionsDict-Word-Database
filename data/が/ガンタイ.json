        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "サッカーの試合中に顔を強打し、眼帯をして練習することになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "海賊のコスチュームは眼帯なしでは完成しない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "医者から、しばらくの間は眼帯をするように指示された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "オサダは眼帯をして変装した。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「美学療法っていうんだ」「でも、お母さまは、マスクなんか、きっとおきらいよ」　お母さまは、マスクに限らず、眼帯でも、眼鏡でも、お顔にそんなものを附ける事は大きらいだった筈である。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり私と同じように左の眼に白い眼帯をかけ、不快げに眉をひそめて小さい辞書のペエジをあちこち繰ってしらべて居られる御様子は、たいへんお可哀そうに見えました。",
              "citation": {
                "source": "燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼帯をかけたり、さうでないものは充血した赤い眼をしたりして、誰もまぶしさうに下を向いてゐた。",
              "citation": {
                "source": "外に出た友",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼帯をかけて貰ふと、私は片目になつて暗室を出て来た。",
              "citation": {
                "source": "外に出た友",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がボロ靴であることを意識しました――　眼帯をはづして、私はその手紙を読んだ。",
              "citation": {
                "source": "外に出た友",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は苛々して眼帯を幾度もむしり取つた。",
              "citation": {
                "source": "外に出た友",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "出がけに医者は白いガーゼと眼帯をくれた。",
              "citation": {
                "source": "眼帯記",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は生まれて初めての眼帯を掛けると、友だちを巡って訪ねた。",
              "citation": {
                "source": "眼帯記",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼帯など掛けたことのない俺が掛けているのを見ると、みんなびっくりしたり、珍しがったりして色々のことを訊くに違いない――と。",
              "citation": {
                "source": "眼帯記",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "たあいもないことであるが、我ながら眼帯を掛けた自分の姿が珍しかったのだ。",
              "citation": {
                "source": "眼帯記",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼帯なんか掛けて、ははあまた雨を降らせるつもりだな」　「うん？",
              "citation": {
                "source": "眼帯記",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると暑くもないのに体中にじりじり汗が出て頭に血が上り、腹が立って来て一日に十度も十一度も眼帯をむしり取る。",
              "citation": {
                "source": "眼帯記",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛色は夏冬によって、彩を異にし、冬毛は背中に白味が多く、腹の方は黒褐色を呈し、過眼帯は黒い。",
              "citation": {
                "source": "老狸伝",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の目に眼帯を掛けるのはかなり繊細な仕事だが、遂にやり遂げた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "大魔王ミノスは右目にドクロマークのついた眼帯をしている。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "右目にはドクロマークのついた眼帯をしている。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "早苗が見舞いにゆくと、磯吉は眼帯をした顔を膝につくほどうつむきこんで、いっそ死んだほうがよかったとしょげきっていたという。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼を洗ったり点眼水を挿したりしても良くならないので、宿の番頭に近所の眼医者へ案内して貰い、眼の中の物を除いて貰ったが、医者は今日一日だけこれを外さないようにと云って、右の眼に眼帯をさせ、明日もう一度いらっしゃいと云うのであった。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼帯は今日一日だけでええそうですけど、大事にせなんだら眼球に傷が行くよって、明日もう一遍見せに来なさい云われてますねん、朝早いのやったらどないしましょう、と云うと、眼エにゴミが這入ったぐらい何やねん、医者は銭取主義やよって大層そうに云うねん、そんなもん今日のうちに直ってしまうがな、と云って出かけた。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは丁度居合せて、据えつける場所を指図したのですが、何でも左の目にガーゼの眼帯を当てた髭面の男が、しきりと何か云っていたようです。",
              "citation": {
                "source": "悪魔の紋章",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一人は、アア、そうだ、どっちかの目に四角なガーゼの眼帯を当てた四十ぐらいの大男でした。",
              "citation": {
                "source": "悪魔の紋章",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "左の目に眼帯を当てた奴です」「すると、二人の掃除人夫は、犯人と犯人の相棒とにソックリじゃありませんか」「しかし、しかし、まさか掃除人夫が犯人だなんて、……それに、あいつらは外から入って来たのです。",
              "citation": {
                "source": "悪魔の紋章",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論何者とも判断がつかぬけれど、若しこれが妙子さんを誘拐した犯人の一人とすれば、あの背の高い方の、ガーゼの眼帯を当てていた男に違いない。",
              "citation": {
                "source": "悪魔の紋章",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は一方の目に大きな眼帯を当てた、無精鬚の大男、一人は黒眼鏡をかけた、痩せっぽちの小男だ。",
              "citation": {
                "source": "悪魔の紋章",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな探偵さんの云うままになった君の不運と諦めるがいい」　眼帯の大男山本始は、得意らしく種明かしをして、さも面白そうに笑うのだが、川手氏は、その言葉さえ殆んど耳に入らなかった。",
              "citation": {
                "source": "悪魔の紋章",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事件には最初から女性がいたのでしょうか、しかし、我々は眼帯の大男と、黒眼鏡の小男しか見ていないではありませんか。",
              "citation": {
                "source": "悪魔の紋章",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この殺人事件には、君とそっくりの男装の女が、度々顔を出しているのだが、その女にはいつでも左の目に眼帯を当てた大男がついている。",
              "citation": {
                "source": "悪魔の紋章",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼帯の男　それから十分余りの後、例の神社の鳥居の前で車を捨てた二人は、暗闇の森の中へ入って行った。",
              "citation": {
                "source": "悪魔の紋章",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗像さん、僕はさい前、中村君から、事件の経過を詳しく聞いたのですが、この事件には、男装の女らしい小柄な犯人の外に、もう一人、一方の目に眼帯をあてた大男がいるというではありませんか。",
              "citation": {
                "source": "悪魔の紋章",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
