        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "荒々しい波が岸壁に打ちつけ、白い飛沫を上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "断崖絶壁の岸壁が続く海岸線は、まさに自然の芸術だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの岸壁の上から見る夕日は、格別だよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
