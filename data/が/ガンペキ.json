    "definitions": [
      {
        "index": 1,
        "gloss": "quay",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "漁船が岸壁に横付けされ、水揚げ作業が行われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大きな客船が岸壁を離れ、遠い旅に出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "岸壁には、たくさんの釣り人が糸を垂らしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "これはたぶん横浜岸壁あたりで訣別の色テープの束の美しさを見て来てから考えたものらしい。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "清水で下車して研究所の仲間と一緒になり、新聞で真先に紹介された岸壁破壊の跡を見に行った。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸壁が海の方へせり出して、その内側が陥没したので、そこに建て連ねた大倉庫の片側の柱が脚元を払われて傾いてしまっている。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この岸壁も、よく見ると、ありふれた程度の強震でこの通りに毀れなければならないような風の設計にはじめから出来ているように見える。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この岸壁だけを見ていると、実際｜天柱は摧け地軸も折れたかという感じが出るが、ここから半町とは離れない在来の地盤に建てたと思われる家は少しも傾いてさえいないのである。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は青い窓から、マルセーユ岸壁の遙かに淡く浮き出た神秘なシャトウ・ド・ディフの牢獄の島を眺めているうちに、故国の姉を憶い出して感傷的になっていました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋上の眺めは左右に岸壁を見、白沫立つてたぎり流るゝ川に臨むのであるから、緑蔭水聲、おのづから兩袖に清風を湧かす概があつて、名も餘り高く無いところだが、小じんまりして溪谷美のあることを感じさせられる。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は天気が宜いから曳舟から岸壁の環へ洗濯｜紐を一ぱい張ってあるから歩き憎いよ。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "当の七日の正午には、私は桜木町から税関の岸壁を目ざして駛っている自動車の中に、隣国の王やアルスの弟や友人たちに押っ取り巻かれて嬉々としている私自身を見出した。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　岸壁の断層――数万羽のロッペン鳥、　画面を斜めに仕切った砂浜、　波打ち際の　噴水のごとき飛沫、飛沫、飛沫。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃霧だ、また、　岸壁の一角、　鳥。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸壁の洞穴に行いすます高名な魔術師も、年老いてアモン・ラーの心を体したといわれる高僧も、王子の問に答えることが出来ない。",
              "citation": {
                "source": "セトナ皇子（仮題）",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから正勝は、その死体の胴へ自分の身体に巻きつけてある綱の一端を結びつけておいて、下りてきたときの綱に掴まって岸壁を登っていった。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "船は、するする岸壁から離れたのだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "船はするする岸壁から離れる。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "西浦賀の岸壁に、シルエツトのやうな煤色に塗られた一艘の不思議な船を、誰でも見出すであらう。",
              "citation": {
                "source": "或るハイカーの記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "喬介に伴われた一行が、二号｜船渠の海に面した岸壁の辺りまで来た時に、どきまぎしながら彼等について行った私に向って、初めて喬介が口を切った。",
              "citation": {
                "source": "カンカン虫殺人事件",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "潜水夫は私達の立っている近くの岸壁まで来て、暫く何か喬介から指図を受けていたが、軈て二人の職工を呼び寄せると、気管やポンプの仕度を手伝わせ、間もなく岸壁に梯子を下げて、直ぐ眼の前の海の中へ這入って行った。",
              "citation": {
                "source": "カンカン虫殺人事件",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれ等は島の南のはづれにある大きな鐘乳洞にも行けば、鵜の鳥の糞の一面に白く附着してゐる岸壁をも伝つた。",
              "citation": {
                "source": "島からの帰途",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "一分でも一寸でも、岸壁の削り取られるごとに、彼は歓喜の声を揚げた。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "罐は製品倉庫から運河の岸壁で、そのまゝ荷役が出来るようになっていた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸壁につながっている艀はどの艀も死んだ鰈を思わせた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "パッキングされた函は、二階からエスカレーターに乗って、運河の岸壁に横付けにされている船に、そのまゝ荷役が出来る。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この次は、飛行島をヨコハマの岸壁につけたときに、乾杯しようや」「ああそれがいい。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "俊寛は、岸壁の上に立ちながら、身を悶えた。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、獣のように岸壁の上で狂い回るだけだった。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、その岸壁の上で、昏倒したまま、何時間眠っていたかは、自分にも分からなかった。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、岸壁の背後は、すぐ磽※な山になっているらしく、小川とか泉とかが、ありそうに思えなかった。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、それでも這うようにして、岸壁を降りることができた。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
