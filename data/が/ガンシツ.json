[
  {
    "uuid": "9a9f61b5-8693-5b40-85d5-90c08ce9355b",
    "entry": "眼疾",
    "reading": {
      "primary": "がんしつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
