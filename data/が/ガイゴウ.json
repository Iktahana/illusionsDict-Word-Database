        "examples": {
          "standard": [
            {
              "text": "水星が外合の位置にあるとき、地球から見て太陽の向こう側にあるため観測は難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "内惑星が太陽の向こう側で一直線に並ぶ現象を「外合」と呼ぶ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "次の金星の外合は来月観測される予定だが、太陽に近すぎるため肉眼では見えないだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "紺屋の白袴、医者の不養生ということもあるが、物理の学徒等が日常お互いに自由に話し合う場合の用語には存外合理的でないものが多数にあって、問題の「速度のはやい」などもその一例である。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "留置場の壁に自分で頭でもぶっつけて、自分自身が血まみれになりたい、そんなヤケクソの気持だったが、そんなヤケクソには、いっそこのバカバカしいオカズの話が案外合っているかもしれないのだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "特殊鍵だから俺の以外合わない。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
