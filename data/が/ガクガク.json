      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "trembling (with fear, cold, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして、胸から血潮を吹いてガクガクっとその下に蹲った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "重たい画帳を載せると同時に両方の膝頭がガクガクと戦いているのに気が付いた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手に燻りかえる安線香の束を持ち、左手に念珠を掛けながら、膝頭をガクガクさせて「南無南無南無」と言うばかり。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が試みると、左脚が棒の様に延びた儘で右脚は分廻しのやうに一方に反れて、それがたゞガクガクと跛足のやうに思はせ振りな動き方をするばかりだつた。",
              "citation": {
                "source": "明るく・暗く",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　村川のカーペットに置いている両足はガクガクとふるえた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は前からあの女……ユリ子を御存じなのですか」　私は思わず発したこの質問が、如何に前後撞着した、トンチンカンなものであったかを気付くと同時に、自分の膝頭がガクガクと鳴るのをハッキリと感じた。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗い、赤ちゃけた電燈の光で、父の頬がガクガクと深くけずり込まれていた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　停車場のあるＨ町から通っている幌のガクガクした古自動車が、青白いヘッドライトを触角のように長く振りながら、一直線に村道から市街地に入ってきた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――片腕の男※」　助役は、急にサッと顔色を変えると、物に怖けた様に眼を引きつけて、ガクガク顫えながら暫く口も利けなかった。",
              "citation": {
                "source": "気狂い機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇吉は膝頭をガクガク顫わしながら戸惑っていたが、不意に屈みこむと、「おやッ。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "積つたばかりの雪の上を歩くやうに、厭にガクガクする膝骨をしつかり爪先きと踵で踏み応えながら、夫々の脚に注意深さを注ぎながら。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は足がガクガクするように感ぜられて、室に帰って寐ると、やがて足は氷の如く冷えてしもうた。",
              "citation": {
                "source": "病",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランプに火を点けてお庄が呼び起しに行くと、叔父は顎の骨をガクガク動かして、細長い筋張った手を蒲団の外へ延ばして、ぐったり寝込んでいた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "頤の辺まで湯に漬りながら、下歯をガクガクと震わせながら、しかも彼は身動きすることを怖れて、数瞬じいっと耐えていた。",
              "citation": {
                "source": "電気風呂の怪死事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガクガクになった首をガーゼで巻いてある。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはガクガク動いてゆくものに押されて歩いた。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "この粉を水に溶く段取りになると、良人は手真似で、太い箸で器の向う側からガクガクと引っ掻くような仕草をする。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供たちは角に立って、ガクガクして飛んできておちくだける火の子の華を眺めていた。",
              "citation": {
                "source": "テンコツさん一家",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "木魚は小さいのは可愛らしいものであるが、大きなのが茵を敷いて座っていると、かなりガクガクとした平たい四角である。",
              "citation": {
                "source": "木魚の顔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "茫々とした二人の鮮人の頭の上に星が光っていて、妙にガクガク私たちは慄えていたが、二人共一円もらうと、私達の車の後を押して長い事沈黙って町までついて来た。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "店で茶をすゝりながら、老夫婦にお信さんと雑談していると、水色の蟹が敷居の上をガクガク這って行く。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "風が出たのか、ガクガクの雨戸が、難破船のようにキイコ、キイコゆれて、チェホフの小説にでもありそうな古風な浜辺の宿、十一月にはいると、もう足の裏が冷々とつめたい。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ガクガクの梯子段を上って、客引きが知らせに来ると、花火のようにやけた、縞のはいった、こうもりと、小さい風呂敷包みをさげて、波止場へ降りて行った。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ガクガクの障子をあけて、銀杏返えしに結った女が、そう言ったきり、薄い私の蒲団にもぐり込んで来た。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　三階建の此ガクガクのアパートが、火事にでもならないかしら。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の膝頭が我れ知らずガクガクと動いた。",
              "citation": {
                "source": "白菊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "椅子から立ち上ったパーポン氏は余りの恐ろしさに膝頭をガクガクと震わした。",
              "citation": {
                "source": "霊感！",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "膝頭が自然とガクガクし出した。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯の根がガクガク鳴り出して、手足がブルブル動き出すのをどうする事も出来なかったわ……だってその声っていうのは、ずっと前に一度オブラーコの酒場へ遊びに来て、散々パラ水兵たちにオモチャにされて外に突き出された、大きな嫌らしい黒ん坊の声だったんですもの。",
              "citation": {
                "source": "支那米の袋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
