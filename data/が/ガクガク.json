[
  {
    "uuid": "8ee3f3ee-38bc-52c7-93d5-9e8662d97dcd",
    "entry": "ガクガク",
    "reading": {
      "primary": "ガクガク",
      "alternatives": [
        "がくがく"
      ],
      "is_heteronym": false
    },
    "grammar": {
