    "definitions": [
      {
        "index": 1,
        "gloss": "Chandra (Hindu moon god also revered as one of the twelve devas in Shingon Buddhism)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "月天心貧しき町を通りけり　月が天心にかかっているのは、夜が既に遅く更けたのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我れを厭ふ隣家寒夜に鍋を鳴らす葱買ひて枯木の中を帰りけり易水に根深流るる寒さかな古寺やほうろく棄つる藪の中月天心貧しき町を通りけり　此等の俳句に現はれる、抒情味の本質は何だらうか。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "降り注ぐものは新鮮な竹の葉に雪のごとく結晶し、君を思へば蒼白い月天がいつもその上にかかる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "月天子山のはを出でんとして、光を放ちたまふとき、疾翔大力、爾迦夷波羅夷の三尊が、東のそらに出現まします。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう月天子がお出ましなのぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "月天子山のはを出でんとして、光を放ちたまうとき、疾翔大力、爾迦夷波羅夷の三尊が、東のそらに出現まします。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう月天子がお出ましなのじゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向った丘に、もみじの中に、昼の月、虚空に澄んで、月天の御堂があった。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "月天心の冬の町に、あたかもこれ凩を吹込む声す。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "月天心貧しき町を通りけり　といふ蕪村の句で、月が非常に大きな満月の如く印象されるのは、周囲が貧しい裏町であり、深夜の雨戸を閉めた家から、微かな灯が僅かにもれるばかりの、暗く侘しい裏通と対比するからである。",
              "citation": {
                "source": "月の詩情",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句がもし「月天心都大路を通りけり」だつたら、月が非常に小さな物になり、句の印象から消滅してしまふ。",
              "citation": {
                "source": "月の詩情",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕日天子、月天子、りりりと虫は鳴きまする。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "今宵まどけき月天子かぐや姫をか召したまふ。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一杯をつくして日天子を迎え、二杯を啣んで月天子を顧みる。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月天長節日曜と続いたを幸いに矢野は、中島木島らと、日光の紅葉狩りに行った。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "『礼記』に春を東郊に迎うるに青馬七疋を用いるの、孟春の月天子蒼竜（青い馬）に乗るなどとあり。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『厳神鈔』に「日吉と申すは七日天にて御す故なり、日吉の葵、加茂の桂と申す事も、葵は日の精霊故に葵を以て御飾りとし、加茂は月天にて御す故に桂を以て御飾りとす」など、日吉の名義定説なきも、何か日の崇拝に関係ある文字とは判る。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　一七　獄中の音楽囚人半月天を見ず。",
              "citation": {
                "source": "獄中生活",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」一七　獄中の音楽囚人半月天を見ず。",
              "citation": {
                "source": "獄中生活",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俊寛　（月をにらみつつ）いかに月天子、汝の照らすこの世界をわしは呪うぞよ。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「数試春衣二月天」の句がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此野遊の題の下に、七絶二、七律一、五律一が録存してあつて、数試春衣二｜月天は七律の起句である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩月人迷野　　月に歩して人は野に迷ひ、照人月度天　　人を照らして月天をわたる。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方は土手、一方は田、明月天に冲す。",
              "citation": {
                "source": "酒に死せる押川春浪",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んや俺の心境は明鏡止水、明月天に在り、水甕に在りだ。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "手綱よく締めよ左に馬置けと馬子の訓へを我も湯に読む　大正十二年一月天城を越えて南伊豆の初春を賞した。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピッカルダは月天にあり（天、三・三四以下參照）一六―一八【我等の姿】饑ゑてやつれてありし日の面影なければ、みる目に誰と知りがたし一九―二一【ボナジユンタ】ボナジユンタ・オリビッチアーニ・デーリ・オヴェラルディ。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "神は愛にましまし天堂擧りて己の如く愛に燃えんことを願ひ給ふ四六―四八〔尼〕vergine sorella（童貞尼）聖キアーラ（九七―九註參照）派の此丘尼四九―五一〔球〕月天。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "月天の諸靈のうち徳最も大いなればなるべし一一二―一一四〔聖なる首一一五―一一七〔良き習〕比丘尼の還俗を許さざる〔心の面※を〕心はいつも尼にてありたり一一八―一二〇〔ソアーヴェ〕シュヴァーベン、ドイツ西南の一州。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど　ぼうやが　目を　とじたまま、がってん　がってんを　したので　すばやく　ばけようと　しました。",
              "citation": {
                "source": "ひよりげた",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
