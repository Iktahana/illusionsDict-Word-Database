        "examples": {
          "standard": [
            {
              "text": "高速道路のインターチェンジ近くで、給油のためにガソリンスタンドに立ち寄った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最近はセルフサービスのガソリンスタンドが増え、自分で給油する機会が増えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「やばい、ガソリンランプ点いてる！次のガソリンスタンドまで持つかな…」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あのガソリンスタンドは洗車設備も充実していて便利だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ガードやガソリンスタンドなども両方にある。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "329　　　【１】（この近くにガソリンスタンドがある。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな山の中に、ガソリンスタンドがあるはずはなく、ガソリンが手にはいらなければ、自動車は動かないのです。",
              "citation": {
                "source": "鉄塔の怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
