    "definitions": [
      {
        "index": 1,
        "gloss": "under one's eyes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "河口湖の湖面は朝霧に覆はれ、白く眼下に烟つてゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩の上には、浦島ツツジ、ツガサクラ、コケモモなどが、平ッたくしがみついている、私は岩角に身を倚せて、眼下遥かに低い谷底を見た、雲と霧と入り乱れて、フツ、フツと山上目がけて来る、その裂け目から谷を隔てて赤石山脈の大嶺、その間に、また谷を隔てて早川の連嶺が、幾析となく重なって、不安な光輝を放っている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがまた驚くべく長大なる、最新の熔岩流をひろげて、下吉田の町まで肉薄する剣丸尾、青木ヶ原の樹海から精進村まで、末広がりに扉開きになる青木ヶ原丸尾を、眼下に展開する。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼下の梓川の眺めも独自なものである。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此室の窓から眼下に見える同じ宿の本館には團體客が續々入込んでゐるやうである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓のカーテンがひらいて眼下にヒビヤ・パークと警視庁の鉄筋の骨組が朝の太陽のもとに赤光をうけて眼ざめた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　ある朝、町からの往還をすぐ眼下に見おろす郷社の杜へ見張りに忍びこんでいた二人の若者が、息を切らし乍ら馳せ帰って来た。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはかねて世界最大の噴火口の旧跡と聞いていたがなるほど、九重嶺の高原が急に頽こんでいて数里にわたる絶壁がこの窪地の西を回っているのが眼下によく見える。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "階段をおりる時に、新刊雑誌を並べた台が眼下に見おろされる。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　草市　七月十三日の夕方哲学者のＡ君と二人で、京橋ぎわのあるビルディングの屋上で、品川沖から運ばれて来るさわやかな涼風の流れにしながら眼下に見通される銀座通りのはなやかな照明をながめた。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中部屋など従来入ったことも無かったのであるが、見ると高窓が二尺ばかり開け放しになってるので、何心なく其処から首をひょいと出すと、直ぐ眼下に隣のお源が居て、お源が我知らず見上た顔とぴたり出会った。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車が東京へはいって高架線にかかると美しい光の海が眼下に波立っている。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は話を途切らそうか続けようかと躇らった風だったが、きゅうに調子を変えて、中島の養子というのを眼下扱いにして話を続けた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木や草がうざ／＼と茂つた眼下の廣い谿谷の向ふには地平線に近く狹霧がかゝつて、停車場附近の電燈が間をおいて螢を併べたやうに幽かに光つてゐた。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "上目瞼は薄黒い皺のまま大きな眼球の上に高まって、鼻柱と頬骨との間の眼下の筋肉の著しいたるみは、丁度、色の褪せ切った青蚊帳の古い端片れを吊げた様に見えた。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "好接異客、は可いが、お追從連を眼下に並べて、自分は上段、床の前に無手と直り、金屏風に御威光を輝かして、二十人前の塗ばかり見事な膳、青芋※の酢和で、どぶろくで、「さ、さ、誰も遠慮せんで。",
              "citation": {
                "source": "畫の裡",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒浪の國の旗は、其竿頭から三方に引かれた綱に結ばれて、翩々と風に靡く、其頂上には我が譽ある日章旗は、恰も列國を眼下に瞰おろすが如く、勢よく飜つて居る。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "一貫目位の巌石がガンと一つ頭へ衝ろうものなら、忽ち眼下の谷底へ跳ね飛ばされ、微塵となって成仏する事｜受合だ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん山道を高く登れば、四方に聳ゆる群山は呼べば応えんばかり、今まで遥か高く見えた山々の絶頂も、いつの間にか視線と平行になり、更に登ればはや眼下に見えるようになる。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "見渡せば、群を抜ける八溝山の絶頂は雲表に聳え、臣下のごとき千山万峰は皆眼下に頭を揃えている。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし雲巌寺を出発してから行く途々、渓流に沿うて断岸の上から眼下を見れば、この渓流には瀑布もあれば、泡立ち流るる早瀬もあり、また物凄く渦巻く深淵などもあって、好奇に盥に乗って下ろうものなら、二人や三人土左衛門と改名したかも知れぬのだ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "とかねてより下枝を幽閉せる、座敷牢へ赴くとて、廻廊に廻り出でて、欄干に凭りかかれば、ここはこれ赤城家第一の高楼にて、屈曲縦横の往来を由井が浜まで見通しの、鎌倉半面は眼下にあり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "篝を焚き、舷を鳴して、眼下近く漕ぎ寄せたり。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩が常に俗衆を眼下に見くだし、時代の空氣に高く超越して、もつとも高潔清廉の氣風を尊ぶのは、それの本質に於て全く自然である。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱根を進発してすぐに峠にさしかかり、振りかへつてみると箱根の湖は樹間に小さくいぢらしげに碧水を湛へてゐるのが眼下に見えました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、水上のまちが、眼下にくろく展開した。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたたび箱根の山を越え、小田原のまちが眼下に展開して来た頃に、ぱかぱかと背後に馬蹄の音が聞えた。",
              "citation": {
                "source": "清貧譚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と私はその生徒と並んで立ったまま眼下の日本一の風景を眺め、「僕はどうも、景色にイムポテンツなのか、この松島のどこがいいのか、さっぱり見当がつかなくて、さっきからこの山をうろうろしていたのです。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山猫博士（立ち上がりながら）「おいおい、給仕、なぜおれには酒を注がんか。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいおい給仕、なぜおれには酒を注がんか。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
