    "definitions": [
      {
        "index": 1,
        "gloss": "musical tone",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "葵の上９・４（夕）　文学士｜富尾木知佳氏は東京音楽学校の教授で、兼てまた邦楽調査会の委員である。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その邦楽調査会の用事で、富尾木氏が京都にやつて来た事があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "序に代うるの詩二編孤独の楽調三味線の音が秋の都会を流れて行く。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "万物自から声あれば自から又た楽調あり。",
              "citation": {
                "source": "万物の声と詩人",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "宛として、神楽調である。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
