    "definitions": [
      {
        "index": 1,
        "gloss": "government office in charge of court music (ritsuryō period)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "船｜下ろしの最初の日は御所の雅楽寮の伶人を呼んで、船楽を奏させた。",
              "citation": {
                "source": "源氏物語",
                "author": "胡蝶",
                "note": "青空文庫"
              }
            },
            {
              "text": "御徒然なために雅楽寮の音楽専門家のうちのすぐれたのをお呼び寄せになり、芸事ばかりを熱心にお習いになって大人におなりになった方であるから、音楽にはひいでておいでになるのである。",
              "citation": {
                "source": "源氏物語",
                "author": "橋姫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大歌を扱ふ雅楽寮の日本楽部――或は其前身――の歌人・歌女が、声楽以外に詞章の新作に与つた様である。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四の方は、雅楽寮などに伝へたものらしい。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　雅楽寮と大歌所と大歌所関係の書類が、本集にとり込まれて居ると言ふ証拠は、大伴家持の身の上に絡んで、今一つある。",
              "citation": {
                "source": "万葉集のなり立ち",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "雅楽寮は、外国音楽部と日本音楽部とに分れて居た。",
              "citation": {
                "source": "万葉集のなり立ち",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈良朝以来、雅楽寮の事を歌舞所（本集）或はうたまひのつかさ（倭名鈔等）と言うたが、一つ処に両部を備へて居た為に、大歌所の事をも歌舞所で表すことの出来たものらしい。",
              "citation": {
                "source": "万葉集のなり立ち",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "雅楽寮の官人には帰化人が多かつた。",
              "citation": {
                "source": "万葉集のなり立ち",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑戸とは種々の技芸・工業・雑役等に従事するもので、例えば珠玉を造る玉造部とか、弓を造る弓削部とか、鎧を造る鎧作とか、雅楽寮の楽戸、主船司の船戸、造酒司の酒戸、典薬寮の薬戸、造兵司の雑工戸、主鷹司の鷹戸などとかいう様な、一定世襲の職業を持ったものを申すのであります。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者は唐舞師、笛師などとあるから、雅楽寮の役人であったかも知れない。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その船が大阪に入って来ますというとこれを迎えに出たのが行基菩薩、四天王寺にあった雅楽寮の楽師を率いて、海口に迎えました。",
              "citation": {
                "source": "東洋文化史における仏教の地位",
                "author": "高楠順次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことの名は、清原の藍子といい、雅楽寮の名手、清原｜恒成の妻であり、婚して、まだ、二年ともたたないうちに良人を亡くした若後家の君である。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "所は、法成寺址のさる伶人（雅楽寮の楽師）の家だった。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
