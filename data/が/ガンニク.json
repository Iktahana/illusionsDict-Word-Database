    "definitions": [
      {
        "index": 1,
        "gloss": "meat around the eyes of a fish",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
