[
  {
    "uuid": "25209c91-652e-552a-a9a3-1cc0b9fb7dd3",
    "entry": "頑愚",
    "reading": {
      "primary": "がんぐ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "obstinate and foolish",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "いくら説得しても自分の間違いを認めない彼の頑愚さには、周囲も匙を投げている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "頑愚な老主人の判断ミスが重なり、代々続いた老舗の屋台骨が揺らぎ始めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "無知と頑愚が結びつくと、論理的な話し合いで解決するのはもはや不可能に近い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「頑愚な振る舞いは身を滅ぼすぞ」と、かつての恩師に厳しく諭された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "又李白の子を祝する句に曰く、揚杯祝願無他語、謹勿頑愚似汝爺矣。",
              "citation": {
                "source": "聞きたるまゝ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も頑愚で人に自分の思うことを曲げられないあつかい難い女かも知れない。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、みんなが呆れてしまって、旧弊も旧弊、頑愚度すべからずと笑われていると消息して来た。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "トマス、アー、ケムピス　他人の忠告決して軽ずべきものにあらず、人は自身の面を見る能わざるがごとく社会における己の位置をも能く見ること能わざるべし、一切万事わが意を押通さんとするは傲慢頑愚の徴にして我らのよろしく注意すべきことなり。",
              "citation": {
                "source": "基督信徒のなぐさめ",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "四『お芳、御苦勞でもなあ、稻荷樣へお母さんの名代になつてお詣して來てくれろや、姉さんの命乞に……もしも快くなつたら旗を上げますつて願をかけて……』　老人の頑愚を嗤ふにはお芳はなほ幼かつた。",
              "citation": {
                "source": "四十餘日",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親は頑愚で、正直一図で、感情が粗く野生的ではあるが愛情は深い。",
              "citation": {
                "source": "神童の死",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "固より天性発明なる人（genius アル人）即ち天稟の聖人ならば山野に遊び江湖に泛びて高尚深遠の哲学を発明する所多かるべけれど、頑愚痴迂なる一寒性、いかんぞ古人の遺書によらずして秋毫の屁理窟だもひねくり出すことを得んや。",
              "citation": {
                "source": "読書弁",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわんや、世に頑愚固陋の徒あり、衆民多数の康福を主張するを指して叛逆不臣の説となす、世に狡獪｜姦佞の輩あり、国家権威の鞏固を唱道するを誣いて専権圧制の論となす、大識見を備うる者にあらざるよりは、それよく惑わすところとならざらんや。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十八から十を引いたお年なのであるが、もう晩年になった気があそばされて白楽天のその詩の続きの『慎勿頑愚似汝爺』を歌いたく思召したかもしれない。",
              "citation": {
                "source": "源氏物語",
                "author": "柏木",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯山客の頑愚なる、もしプロレタリアに急変したる小説家、批評家、戯曲家を呼ぶに赤大根を以てせんか、その論壇を占領し、又かの創作壇の一の木戸、二の木戸、乃至本丸さへ占領せんとする諸先生も赤大根にあらざるや否や、多少の疑問なき能はず。",
              "citation": {
                "source": "八宝飯",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに世間の父母たる者、よく子を生めども子を教うるの道を知らず、身は放蕩無頼を事として子弟に悪例を示し、家を汚し産を破りて貧困に陥り、気力ようやく衰えて家産すでに尽くるに至れば放蕩変じて頑愚となり、すなわちその子に向かいて孝行を責むるとは、はたしてなんの心ぞや。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "加之に、子供は多勢で、与太（頑愚）なものばかり揃つて居て――』『まあ、左様仰らないで、私に任せなされ――悪いやうには為ねえからせえて。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "百五十一　けれども自然は思ったより頑愚であった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりか、オタンチン・パレオロガスを教えて頂戴」「うるさい女だな、意味も何にも無いと云うに」「そんなら、品物の方もあとはありません」「頑愚だな。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "去る時に土地のものは彼を目して頑愚だと評し合うたそうである。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "頑愚と云われたる道也はこの嘲罵を背に受けながら飄然として去った。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "頑愚などと云う嘲罵は、掌へ載せて、夏の日の南軒に、虫眼鏡で検査しても了解が出来ん。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれはお前のしょうことなしの節制や喜びも悲しみも知らぬ、あの不自然な頑愚のおぞましい交わりを要しないまた、お前が強いて進取的なものよりもすぐれたりとする受動的な堅忍も欲しない。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "あに頑愚無知とならざるを得んや。",
              "citation": {
                "source": "教育談",
                "author": "箕作秋坪",
                "note": "青空文庫"
              }
            },
            {
              "text": "でなければ郷土の血液がよほど頑愚か、どっちかであるが、やはりここには人傑が出ていた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "水の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "時勢はすでに刻々と革まるを、汝ら、頑愚の眼にはまだ見えぬか」と、関城の下でどなった。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "籠城はただ頑愚なほどの辛抱にあるとおもう。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれも頑愚な凡石か、添い屈まっている駄石ばかりだ。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
