[
  {
    "uuid": "37e01ba7-2240-5611-a427-0d26b6216bc9",
    "entry": "外見上",
    "reading": {
      "primary": "がいけんじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
