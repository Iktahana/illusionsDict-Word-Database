        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「全く青空でがんがんやつたのがよかつた」然り「青空」はなによりも私達の腹を作つた。",
              "citation": {
                "source": "『青空』のことなど",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "己れや其の晩妙に瞼が合わ無えで、頭ばかりがんがんとほてって来るんだ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "足音と語ががんがん反響してやって来た。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」がんがんがん、「そりゃ、えらくなって来た。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、あらず、それも、後に思へば、火を防がんがために粉骨したまふ、焦身の仁王の像であつた。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "がんがんがんと、胸は早鐘、幽にチチと耳が鳴る。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、たまたまその島にがんが卵をうんでおりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇子は、日本でがんが卵をうんだということは、これまで一度もお聞きになったことがないものですから、たいそうふしぎにおぼしめして、あとで武内宿禰を召して、「そちは世の中にまれな長命の人であるが、いったい日本でがんが卵をうんだという話を聞いたことがあるか」とこういう意味を歌に歌っておたずねになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はまたまた苦しくなって、頭ががんがん痛んで来ます。",
              "citation": {
                "source": "指輪一つ",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「開けてくださいよ、開けてくださいよ」　甚九郎の耳はがんがんと鳴った。",
              "citation": {
                "source": "山姑の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸が、がんがんして来た。",
              "citation": {
                "source": "接吻を盗む女の話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こめかみは杭打ちのごとくがんがん脈打ってましたから、鼻血が垂れて我を取り戻してなくば、ある種の発作が起こっていたことでしょう。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいこでも、がんがんたたいて、あのこえの、きこえないようにしてくれ。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえ付けっぱなしのマシンが、がんがん電気を喰って暖房器代わりになるのではこれまたぞっとしない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの娘を貰うては……」　お菊は眼が眩みそうになって、耳ががんがん鳴って来た。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「がんがんやっていたかと思や、ひとりで急に笑いだしやがって、おめえくらいあいそのつきるやつは、ふたりとねえよ」「そうでしょう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとにまったく、がんがんしてくるじゃござんせんかい」「控えろッ」「え……？",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった今がんがんとやかましくがなってきたのに、なにを急にめそめそやるんだよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "お竹とかいったあの娘に、ぽうときたんですかい」「がんがんとやかましいやつだな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなところでがんがんいうやつあ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「がんがんいうやつたア何をぬかしゃがるんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月だから笑わなくちゃいけねえとやったその舌の根のかわかぬうちに、もうがんがんとお株を始めてどなりだしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなりゃ、もう先を急がなくちゃならねえんだから、がんがん鳴ると縁を切るぜ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "がんがんいう暇があったら寝りゃいいんだよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうとっくに今日さまはのぼったんですよ」　がんがんとやりながらはいってくると、鼻をつままれた寝ざめの悪さが腹にたまっているとみえて、頭ごなしにがなりたてました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "うれしがって金だらいまでががんがん鳴ってらあ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "がんがんいうばかりが能じゃねえや。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
