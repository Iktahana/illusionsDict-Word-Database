    "definitions": [
      {
        "index": 1,
        "gloss": "food sold with a toy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
