        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "腕力の強いガキ大将、お山の大将、乃木大将。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガキ大将にくっついて、ヤーッ、チャンチャン、バラバラ、とやるんじゃない。",
              "citation": {
                "source": "ソヴェトのピオニェールはなにして遊ぶか",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "役人と来ちやア、昔の代官と同じで、全く、子供のガキ大将と同じでさア……。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドストエフスキーとなると、不良少年でも、ガキ大将の腕ッ節があった。",
              "citation": {
                "source": "不良少年とキリスト",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年時代のガキ大将は珍しくないが、このオヤジは一生涯ガキ大将であった。",
              "citation": {
                "source": "安吾史譚",
                "author": "勝夢酔",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
