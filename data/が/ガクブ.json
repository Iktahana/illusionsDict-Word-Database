  {
    "uuid": "bd255b83-53d6-50aa-975b-f14a0799048c",
    "entry": "楽舞",
    "reading": {
      "primary": "がくぶ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "singing and dancing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "神社の祭礼では、神職による雅楽と舞が奉納された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "能楽の演目には、しばしば舞や歌といった楽舞の要素が含まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "平安時代の宴では、貴族たちが優雅な楽舞を鑑賞した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "上記の夢を見てから一と月も後に博物館で伎楽舞楽能楽の面の展覧会があって見に行った。",
              "citation": {
                "source": "夢判断",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵画彫刻でも音楽舞踊でも皆それぞれの「言葉」をもってつづられた文学の一種だとも言われるが、しかし、ここではそういうものは考えないことにする。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽舞踊はいかなる野蛮民族の間にも現存する。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜通しいろいろの音楽舞楽を広前に催して、神の喜びたもうようなことをし尽くした。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂言は一番目が「碁盤忠信」、二番目が「筆売幸兵衛」で、一番目には団十郎の「静の法楽舞」と「山伏摂待」という余り面白くないものが付いていた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭に田楽舞があつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽舞曲のほうのことは左大将が好意で世話をした。",
              "citation": {
                "source": "源氏物語",
                "author": "御法",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでこうしたおりごとに必ず集まって来て、音楽舞楽の何かの一役を勤める人たちの容貌や風采にも、その芸にも逢うことが今日で終わるのかというようなことばかりが思われる夫人であったから、平生は注意の払われない顔も目にとまって、少しのことにも物哀れな気持ちが誘われて来賓席を夫人は見渡しているのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "御法",
                "note": "青空文庫"
              }
            },
            {
              "text": "月見なり、花見なり、音楽舞踏なり、そのほか総て世の中の妨げとならざる娯しみ事は、いずれも皆心身の活力を引立つるために甚だ緊要のものなれば、仕事の暇あらば折を以て求むべきことなり。",
              "citation": {
                "source": "家庭習慣の教えを論ず",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（自注、此園、露国帝政時代、彼国将軍寳爾和徳所築、当時将校貴女、毎夕競集、開音楽舞踏会於園中、今無復当年盛観也）哈爾賓客中、呈古澤幸吉先生先生白髪未云還。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう言ふ関心を持ち出しかけたのは、先年、日本青年会館の「郷土舞踊・民謡の会」に、遠州周智郡奥山村｜西浦から、古い田楽舞ひの来たことがある。",
              "citation": {
                "source": "「八島」語りの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "又雅楽舞台の影響についても、何等根拠のない事です。",
              "citation": {
                "source": "能舞台の解説",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗ては、設楽と言ふ地名から、設楽舞ひを聯想した人もあつた様です。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "志多羅神を持つて歩く人――つまり、神を送る人達が、乱舞する、それを設楽舞ひと言うたのですが、何にしても、此は平安朝のものなのですから、あまりに時代が遠すぎる様です。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "家持が壮盛りに、出入した歌※所の内の後に（或は当時も）大歌所と言つた日本楽舞部の台本（伝来の大歌・采風理想から採集した民謡集）や、雑多な有名・無名の人の歌集や、家持自身大部分材料を蒐めて整理して置いた大伴集――仮りにかう名をつけておく。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の凍る夜に限つた楽舞が、夏にも行はれるやうになつたのである。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が国の文献時代には、まつるは既に世の中を自由にする・献る・鎮魂する・定期に来臨する神を待つて楽舞を行ふ、と言つた用語例が出来て居り、神意による公事を行ふと言ふ義は、古伝の詞章の上に固定して残つてゐたのらしい。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　夏祭り平安朝に著しくなつたのは、神は楽舞を喜ぶものと考へる信仰である。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其程、祭礼と楽舞との関係が離されなくなつた。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "其と共に、神楽の一方の起原になつてゐる石清水八幡の仲秋の行事の楽舞を、夏祓へにとり越して、学んだ形があるのだ。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、これは、常識的にも、截然と「演劇＋Ｘ」といふ判断ができる筈であつて、演劇的要素乃至方法の若干に音楽舞踊又は美術的要素が加つてゐる場合が多く、その意味で、「演劇」が従属的地位におかれてゐるものも少くない。",
              "citation": {
                "source": "演劇論の一方向",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "此牽き物に随ふ人々のする楽舞がすべてはやしと言はれたのだ。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この門入りこそは、延年舞に既にあつて、田楽舞の重要な部分になつた「中門口」の所作が出来たのと、根を一つにした「おとづれる神」の変形なのである。",
              "citation": {
                "source": "まれびとの歴史",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿楽能は山人舞の伝統を引くもので、社寺の楽舞に触れて変化し、民間の雑楽に感染してとり込み、成立後の姿からは、元の出処が知れぬ位に、変つてしまひました。",
              "citation": {
                "source": "翁の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽舞用具の一種として獅子頭の我が国に伝わった事は、すでに奈良朝の頃からであった。",
              "citation": {
                "source": "奥羽地方のシシ踊りと鹿供養",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "主張あり問題の提供ある所もあるが、要するに南島の神話伝説を探り、童謡｜俚諺を尋ね、あるいは古音旧辞を究め、歌詞楽舞を伝えて、古史研究に文献学に少からぬ寄与をされた功は特筆せねばなるまいと思う。",
              "citation": {
                "source": "南嶋を思いて",
                "author": "――伊波文学士の『古琉球』に及ぶ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽舞踊アカデミー設立が一六六一年で「人間悟性論」のロック（英）の愛人が、当時大人気者のサレーだったのだって。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月七日　〔巣鴨拘置所の顕治宛　駒込林町より（和田三造筆「戸穏神楽舞」の絵はがき）〕　三月七日　余り手紙のつきがおそいからこんなハガキさしあげて見ます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時から有楽座で、一座の研究生と青年部の音楽舞踊の試演会があり、それへ行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの家来も多く集まった中で、沢庵は、猿楽舞などを踊りだした。",
              "citation": {
                "source": "宮本武蔵",
                "author": "地の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
