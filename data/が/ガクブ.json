[
  {
    "uuid": "51efe144-0966-50c8-b1c3-92a3ef45044a",
    "entry": "学部",
    "reading": {
      "primary": "がくぶ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "faculty (of a university)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大学のオープンキャンパスで、各学部の説明会に参加した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "卒業後、私は〇〇大学の文学部でさらに専門分野を深めたいと考えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "友人は、将来は国際関係学を学ぶために、国際学部がある大学を選ぶと言っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "先生は、昨年の春、同じ学部の若い教授と意見の衝突があって、忍ぶべからざる侮辱を受けたとかの理由を以て大学の講壇から去り、いまは牛込の御自宅で、それこそ晴耕雨読とでもいうべき悠々自適の生活をなさっているのだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "建物の背後の、ブランコのある所を見たいと思つて建物の横を廻りかけたが、何しろ休暇中だし、朝の五時半であつたし、小使の女房か女学部の舎監であつたか知らないが、炊事場の小窓から一寸顔をのぞけて、ケゲンさうにこちらを見たから、諦めてコソコソと引返した。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからもう一枚哲学部長の署名のあるこれもラテン語の入学免状を貰った。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに助手の西田君が来て大学の医化学教室が火事だが理学部は無事だという。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方藤田君が来て、図書館と法文科も全焼、山上集会所も本部も焼け、理学部では木造の数学教室が焼けたと云う。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "工学部の課目中に物理実験を加えるようになったのも同君並びに同志の諸氏の考えが導因となったもののように記憶するが、この点は筆者の思い違いかもしれない。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和二年十二月、理学部会誌）",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　理学部会委員に約束しておいたのを忘れていて、今日最後の通牒を受けて驚いて大急ぎで書いたので甚だ妙なものになった。",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和三年九月『理学部会誌』）",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つ、これは未発表のものであるが、北海道大学理学部の米田勝彦氏が現に研究を続けている「粉の波」の現象がある。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくてその歳も暮れ、二十八年の春になって、彼は首尾よく工手学校の夜学部に入学しえたのである。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、これは夏目先生に関する一つの資料として保存しておけば他日きっと役に立つ機会があるであろうと思ったので、当時の大学理学部物理教室の自室の書卓の抽斗しの中に他の大事な手紙と一緒に仕舞い込んでおいた。",
              "citation": {
                "source": "埋もれた漱石伝記資料",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "関東震災のおかげで大学に地震研究所が設立されると同時に自分は学部との縁を切って研究所員に転じ、しばらくの間は工学部のある教室のバラックの仮事務所に出入りしていて、研究所の本建築が出来上がると同時にその方に引越した。",
              "citation": {
                "source": "埋もれた漱石伝記資料",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この観測に使った小船は、今は理学部の北玄関の壁に立てかけて乾燥状態にある。",
              "citation": {
                "source": "池",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正十三年十一月、理学部会誌）",
              "citation": {
                "source": "池",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで田丸先生の場合にしても、なくなられてまもない今日、こんなものを書く気になりかねるのではあるが、理学部会編集委員のたっての勧誘によって、ほんの少しばかり自分の高等学校時代の思い出を主にして書いてみることにした。",
              "citation": {
                "source": "田丸先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和七年十二月、理学部会誌）",
              "citation": {
                "source": "田丸先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、来年十九才で学校を出ると直ぐに今東京帝国大学の法学部に通っている従兄と結婚することになって居り、十六の少年など十も年下に見える姉さん振りが虚栄の一つであった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝大の医学部に在籍。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日、この地方の新聞社の記者だと称する不精鬚をはやした顔色のわるい中年の男がやって来て、あなたは今の東北帝大医学部の前身の仙台医専を卒業したお方と聞いているが、それに違いないか、と問う。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」青年は、或る大学の医学部の研究室に、つとめていた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」青年は、或る大学の医学部の研究室に、つとめてゐた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』文学部事務所にその掲示は久しくかけられてあった。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君、学習院の女学部だろう。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は来年十八歳で学校を出ると、いま東京帝国大学の法学部にいる従兄と結婚することになっており、十六の少年など十も年下に見える姉さん面が虚栄の一つだった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、隆太郎小学部六年に在り。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが五十四フランのがくぶちと五フランの石刷画（フリッペ）ですむんだ。",
              "citation": {
                "source": "「緑の騎士」ノート",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある町のがくぶちやさんへもじゃもじゃあたまの、きたない男がはいってきて、ショーウインドーにかざってあった、五、六さいのかわいいしょうねんの、くびだけのせっこうぞうをかっていきました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方のかべに、一メートル四方もある大きな鏡が、はめこみになって、まわりに、うつくしいがくぶちがついています。",
              "citation": {
                "source": "宇宙怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "小型自動車の横がわを見ますと、上のほうに、映画のスチールが、がくぶちに入れて、いっぱいならべてあります。",
              "citation": {
                "source": "魔法博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
