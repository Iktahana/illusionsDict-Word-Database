    "definitions": [
      {
        "index": 1,
        "gloss": "chattering (teeth)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "寒い朝、公園でバスを待っていたら、あまりの冷気に歯がガチガチ鳴り始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "怖い映画を見た後、一人で夜道を歩いていたら、恐怖で歯がガチガチ震えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "発表の順番が回ってきて、緊張で体が震え、歯がガチガチ鳴るのを止められなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "……天麩羅とも、蕎麦とも、焼芋とも、芬と塩煎餅の香しさがコンガリと鼻を突いて、袋を持った手がガチガチと震う。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉が薄く、鼻がひしゃげて、ソレその唇の厚い事、おまけに頬骨がギシと出て、歯を噛むとガチガチと鳴りそう。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中に谷へ飛降りて、田沢の墓へ噛みつこうか、とガチガチと歯が震える。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともすると、艀が舷側のブリッジの中程まで糶り上って、ガチガチとやると、すっと堕ち込んで離れてしまう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯の根がガチガチ鳴り出して、眼がポオとなってウッカリすると波に渫われそうになって来たので四人がだんだん近寄って来て……これはイカン。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……余は、馴れぬ手際で、乱暴にガチガチと錠前をねぢつた。",
              "citation": {
                "source": "余話（秘められた箱）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "六つ七つの子供の頃、母の腰のあたりに取りすがつて、齒をガチガチ云はせながら、山火事を遠く望んだ夜の事が思ひ出された。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "上下の歯がガチガチ鳴った。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼女も呆気にとられ、ぽかんとした顔で、寒さに歯をガチガチと打鳴らしながら、「すんまへん」と、云つた。",
              "citation": {
                "source": "釜ヶ崎",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兵隊辰やな」と、女装の男は、癖で歯をガチガチ寒さうにならしながら、小説家に説明して云つた。",
              "citation": {
                "source": "釜ヶ崎",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、赦されて部屋に上っても、ガックリと気抜けがして、ガチガチと歯の根が慄え、だるくて箸さえもとれなかった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯が金物のようにガチガチ鳴った。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙に体がガチガチふるえてくる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯がガチガチふるえる。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙に体がガチガチふるえる。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥歯がガチガチと音を立てはじめた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉巻をガチガチと噛んで、鬚をビクビク震わせている。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ウンザリしちゃって放ったらかして来ちゃったんです」「何故海に投り込まねえ」「それが誰にも見つからねえように放り込みたかったんで……親方や機関室の兄貴達にも申し訳ねえし、おまけに上海で、あっしが談判に行った時に船長が入歯をガチガチさして、こんな事を云ったんです。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガチガチと、歯の根も合わぬながらに、女房も、いくらか落ちついて、広海屋の指先の示すあたりに眺め入って、やっと泣き止んだころ、主人夫婦のすがたを見かけた手代、小僧、出入りの職人どもが、畳、屏風、火鉢なぞを、運んで来る。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――けだもののような人――何という浅間しい――　当然だ――と、いう気持になっていたが、歯の根も合わず、ガチガチと、上下の顎が、打ッつかって、立っていられぬように、脚部が力を失った。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにもこんなところの筆らしいガチガチになった筆の先をかんでふだんよりぎこっちない字でＨのところへ手紙を書き始めた。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀と間違えた甲虫というのは……」　彼はおのれの上下の歯がガチガチと戦慄を伝えてかち合う音を耳にした。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしは胸が苦しくって、歯がガチガチする。",
              "citation": {
                "source": "杜松の樹",
                "author": "グリム",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはまあ私の観た批判でありまして、好むところまた各々別でもよろしゅうございますが、比較上批判的に申しますと、ああいうふうなゆとりのない、ガチガチに行届いた字は、習う方にもよろしくないし、その結果はおもしろくないと思います。",
              "citation": {
                "source": "習書要訣",
                "author": "――美の認識について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルナアルさんはガチガチと歯の根を震わせ、冬の海の、煤黒色を混ぜたあの蒼黝い顔をして入って来る。",
              "citation": {
                "source": "葡萄蔓の束",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "漆黒の毛に蔽われた身丈ほとんど八尺もある類人猿がただ一匹樹枝を雷光のように伝いながら血走る両眼に獲物を見すえ黄色い牙を露出しにしてその牙をガチガチ噛み合わせながらこっちに向かって飛んで来る。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガチガチと歯音の聞こえたのは、「本郷の殿様」が口の中で、歯叩きをしたがためであろう。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉毛の濃い武士の切れの長い眼は、いつもの倍ほどに見ひらかれているし、富士型の額を持った武士の、鬢の後れ毛は顫えているし、端麗な鼻をした武士の頬は、いちじるしく痙攣を起こしているし、薄手の受け口めいた唇の武士は、ガチガチと奥歯を噛むようにした。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
