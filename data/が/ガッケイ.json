        "examples": {
          "standard": [
            {
              "text": "「学兄のご意見を伺いたい」と、教授は隣の席の彼に尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この難題を解決するには、学兄の知恵を借りるしかない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "先日お会いした学兄の研究には大変感銘を受けました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "学兄に再会でき、積もる話が尽きなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "哲学ハ、知ヘノ愛デハナクテ、真実ノ知トシテ成立セシムベキ様ノ体系知デアル、ヘエゲル先生ノコノ言葉、一学兄ニ教エラレタ。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お兄さん……ああ　こんな恍惚の夢のような日はどこの海辺で待っているのか昭和十九年五月三十一日向陵時報小唄水のほとりに立てばこころなぐさむわがうらぶれの姿さえやさしげにうかみいづるを（注）　「隅田川のほとりに立ちて清岡学兄と共に歌える小唄」。",
              "citation": {
                "source": "初期詩篇",
                "author": "原口統三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
