        "examples": {
          "standard": [
            {
              "text": "来年、祖父の喜寿だから、家族みんなで賀の祝いを盛大に開こうと計画中だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今年は叔母の還暦なので、親戚一同集まって賀の祝いをすることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "賀の祝いの席で、長寿のお祝いの言葉を述べる大役を任されて緊張した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかも動木喜兵衛といっしょにいるらしいんだ」「まさか、……あの汝生が」「動木というのは私の想像だが、汝生のことは間違いはない、なぜなら梅園女史が見て来たんだから」「小舘さんがですって、どうしてまた」　その年は藩主前田侯の賀の祝いに当っていた。",
              "citation": {
                "source": "雨の山吹",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
