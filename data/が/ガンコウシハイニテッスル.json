    "definitions": [
      {
        "index": 1,
        "gloss": "to (be able to) read between the lines",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の洞察力は、言葉の裏側、眼光紙背に徹するほどだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "報告書を読んだ上司は、数字の羅列から眼光紙背に徹するような真実を見抜いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "詩を鑑賞するには、書かれた言葉だけでなく、眼光紙背に徹する心が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "何せ、眼光紙背に徹する読者ばかりを相手にしているのだから、うっかりできない。",
              "citation": {
                "source": "一歩前進二歩退却",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、この眼光紙背に徹するといふ読方も、矢張観察力ばかりでは駄目である。",
              "citation": {
                "source": "小説新論",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "真偽の鑑定は眼光紙背に徹する底の識見なくんば不可なり。",
              "citation": {
                "source": "史論の流行",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭は四方の均整を引締めるために、眼光紙背に徹する底のまなこをもたなければならない。",
              "citation": {
                "source": "庭をつくる人",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼光紙背に徹するのも判りの良さも、共感の大きな能力も、理知的な自信も、皆ここから来る。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "平坦に叙してあってちょっと見たところでは平凡な句としか見えないが、それを平凡な句としてうっちゃってしまうのは鑑識のない人であって、いわゆる眼光紙背に徹するという人であって、はじめてその句の面白さを解することが出来るのである。",
              "citation": {
                "source": "俳句への道",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
