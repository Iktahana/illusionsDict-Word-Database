        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ゼミの最終課題として、メンバー全員で制作した作品の合評会が開かれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "出版社では、新刊の企画について複数の編集者が集まり、合評を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "批評家たちは、互いの作品を持ち寄り、率直な意見交換を行う合評を定期的に開催している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "たまたま『文章世界』第二巻第十三号で、片上天弦、前田木城、水野葉舟、吉江孤雁ら合評の紀行文家月旦が出た。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "話をしてみると、合評に根を持った反感がだいぶ消えた。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "合評会には出ておいででした。",
              "citation": {
                "source": "久保田米斎君の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾崎徳太郎君も私の内で雲中語といふ合評をする席へ、一度來てくれたことがある。",
              "citation": {
                "source": "長谷川辰之助",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その先のいろいろな賞揚言も、また、君達が認めぬ作家に対しての合評も――共に、またの機会にして貰はう。",
              "citation": {
                "source": "新興芸術派に就いての雑談",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日は、芝居の合評会へ行くのださうだつた。",
              "citation": {
                "source": "足袋のこと",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、合評会になると、割合にさういふことが言へる。",
              "citation": {
                "source": "通俗小説",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、「新潮」の合評会で不足だつたのは、その雑誌の性質上止むを得ないことかも知れないが、もう少し若い作者達のものを丁寧に批評したら何うかと思つたことであつた。",
              "citation": {
                "source": "通俗小説",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし好いものがあつたら、何んな雑誌に出てゐるものでも、合評に上せてやる方が好くはないか。",
              "citation": {
                "source": "通俗小説",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠には、何処に行つても何ういふ合評の席に行つても、一番先きに問題になるのは、その表現の巧拙乃至自然にあるやうである。",
              "citation": {
                "source": "手品",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "曾てさういふことをある合評会で言つて、文壇の人達に仙人だと言はれたが、仙人結構だと私はいふ。",
              "citation": {
                "source": "雑事",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "」（註――斯の国家の頃には、年々季を改めて王党の元老会が、騎士級の人々の持馬を検査する厳かな合評会があつた。",
              "citation": {
                "source": "くもり日つゞき",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "また農業に発した強い国家意義と狩猟生活の生んだ寄合評定によって、強大な政治力が養われ今日、世界に雄飛している民族は、すべて北種に属する。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "誠太郎の云ふ所によると、昨夕兄が宅へ帰つてから、父と嫂と三人して、代助の合評をしたらしい。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもこの間契月、未醒、清方、霊華などの合評を読んだら、フム、と感じるところもあった。",
              "citation": {
                "source": "金色の秋の暮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけのことでしょう」（群像十一月号「創作合評会」中村光夫）と総括して、その上での批評が果して現代文学の貧困を救う何事かであり得るだろうか。",
              "citation": {
                "source": "「下じき」の問題",
                "author": "――こんにちの文学への疑い――",
                "note": "青空文庫"
              }
            },
            {
              "text": "労働組合の方では、労働総同盟が分裂して組合評議会が誕生し、労農党の分裂は右翼に社会民衆党をつくり、中間に日本労農党を生み、左翼に共産党の萌芽をもった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、明治三十年、新小説、文芸倶楽部などに発表された小説を、鴎外、露伴、緑雨、紅葉、思軒などがよって合評したものだ。",
              "citation": {
                "source": "無題（五）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代の新潮合評のようなものか。",
              "citation": {
                "source": "無題（五）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "試写が終ると、演出課のルームで、だらだらと合評会がつづけられる。",
              "citation": {
                "source": "美しき死の岸に",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の目の前では試写の合評がだらだらと続いていたが、ふと誰かが立上ると、急に皆の表情が変っていた。",
              "citation": {
                "source": "死のなかの風景",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "送り届けられたすべてのパーツを分類した写真で特集の最後の見開きを飾ったあと、渡部は一ページ用意した総合評価欄で、「八ビットマシンの限界がＰＣ―８８０１だとすればＰＣ―９８０１は一六ビットのマシンのスタートラインを確かに通過した存在である」と位置づけた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "会長ペツク氏はこの時に当り、我等十七名の会員にこは心霊学協会の臨時調査会にして合評会にあらざるを注意したり。",
              "citation": {
                "source": "河童",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "合評会の席上で此事を話して、柳田先生から大分訓戒を戴いたが、どうも其気持ちは、やはり移らないで居る。",
              "citation": {
                "source": "感謝すべき新東京年中行事",
                "author": "――第四回郷土舞踊と民謡の会・批判――",
                "note": "青空文庫"
              }
            },
            {
              "text": "会長ペック氏はこの時にあたり、我ら十七名の会員にこは心霊学協会の臨時調査会にして合評会にあらざるを注意したり。",
              "citation": {
                "source": "河童",
                "author": "どうか Kappa と発音してください。",
                "note": "青空文庫"
              }
            },
            {
              "text": "誠太郎の云う所によると、昨夕兄が宅へ帰ってから、父と嫂と三人して、代助の合評をしたらしい。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはこの病院の患者達によつて組織されてゐる一団で、毎月一回か二回くらゐ各自の詩作品を持ちよつて合評し合つたり、詩壇の動向に就いて論じ合つたりするものだつた。",
              "citation": {
                "source": "キリスト者の告白",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、新潮の合評会記事を見ると、錚々たる文壇の識者が、おれを新感覚派にしてくれてゐる。",
              "citation": {
                "source": "自問自答",
                "author": "――所謂「新感覚派」の為めに――",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　アムステルダムの国立博物館では「夜警」（一六四二年）と「織物商組合評議員」（一六六一年）が有名であるが、そのほかに「エリザベト・バース」（老婦人の像）と「或る婦人の像」（中年の婦人の像）と火事で焼け残った「解剖講義」（一六五六年）の断片も忘られないものである。",
              "citation": {
                "source": "レンブラントの国",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "広津の「白霧」評、合評、その他、Ｙフンガイしてもう「浦島」をよまず。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
