        "examples": {
          "standard": [
            {
              "text": "「おいそこの餓鬼んちょ！勝手に人の家の柿を盗むんじゃない！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はいい大人になった今でも、中身はあの頃の生意気で負けず嫌いな餓鬼んちょのままだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "お隣の餓鬼んちょが、また公園の砂場で全身泥まみれになって遊び呆けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「へへっ、まいったか！」と、近所の餓鬼んちょが勝ち誇ったような顔で笑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "野尻湖近くの田口駅をすぎた頃、客車のしきりの扉が開いて、車掌がきんちょうした顔をして入ってきた。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
