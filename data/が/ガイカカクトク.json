        "examples": {
          "standard": [
            {
              "text": "政府は、観光立国を目指し、外貨獲得の強化を図っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この輸出プロジェクトは、年間数百万ドル規模の外貨獲得を見込んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "我が社は、海外市場への積極的な展開を通じて、継続的な外貨獲得を目指します。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "インバウンド需要の増加は、日本にとって大きな外貨獲得のチャンスだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "盛りの時は、キャバレーなんかよりつけられませんな、何しろ外貨獲得で一生懸命でしたもの、日本人なんか相手にしませんでしたよ。",
              "citation": {
                "source": "エキゾチックな港街",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            }
          ]
        }
