        "examples": {
          "standard": [
            {
              "text": "探査機は太陽系を離脱し、未知なる外宇宙へと旅立った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "SF映画で描かれるような、外宇宙からの侵略者に胸を躍らせたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "天文学者たちは、外宇宙に地球と似た環境の惑星が存在しないか探している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "ジュラ紀の間に古きものどもは新たな外宇宙からの侵略という不運にまたも見舞われた――今回は半ば菌糸のような、半ば甲殻類のような怪物どもで、近年冥王星の名で発見された遠隔の惑星からやって来た。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "人口の中の少ないパーセンテージながら常にある種の人々がおり、未知の外宇宙への身を焦がすような好奇心を持ち、既知の現実という牢獄から逃げ出して信じ難い冒険と限りない可能性をもつ魅惑の国へ行きたいという燃えるような願いを持っているのです。",
              "citation": {
                "source": "怪奇小説の執筆についての覚書",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
