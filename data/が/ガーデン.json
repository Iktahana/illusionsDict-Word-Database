        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "イギリスの田園風景には、手入れの行き届いた美しいガーデンがつきものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、自宅の裏庭に、家族みんなで楽しめるプライベートガーデンを作りたいと思っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このバラ園、本当に素敵なガーデンだね！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "週末は、都会の喧騒を離れて、郊外の静かなガーデンでピクニックを楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ボルシェヴィキに反対する白系露人が工部局のロシア義勇兵に続々加盟して、ガーデン・ブリッジ、四川路橋、蘇州橋等の橋上に哨兵小屋を急造して警戒を始めた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄浦口にのぞんだパブリック・ガーデン、そこでは四十幾種類かの人種がプラタナスの木蔭を逍遙している。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「コヴェント・ガーデンの売り子から二ダース卸してもらったんです。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　我々はホウボーンを通り過ぎてエンドル街へ入り、入り組んだ貧民街を抜けると、コヴェント・ガーデン市場へ出た。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『コヴェント・ガーデンのブレッキンリッジだよ。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはドレイパ・ガーデンズのコクソン＆ウッドハウスの店に職を持っていたんですけれど、この春先にご存じだと思いますけれどベネズエラ公債でやっちまいまして、どっと傾いてしまったんです。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三章　ローリストン・ガーデン事件　正直言って、かくもまざまざと見せつけられては驚くほかなかった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "親愛なるシャーロック・ホームズ氏　昨晩、ブリクストン通りにほど近いローリストン・ガーデンズ三番地に、よからぬ事件がありました。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローリストン・ガーデンズ三番地は禍々しく凄みがあった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四章　ジョン・ランスの言い忘れ　一時になり、我々はローリストン・ガーデンズ三番地を後にした。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、そのローリストン・ガーデンズには空き家がふたつあって、何でも大家が下水を修理しなかったもんで、片方に住んでた借り主が腸チフスで死んじまった、っていうんですよ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "テラス下は舗装され、コンクリートのベンチと大谷石のグリルのある、バーベキューガーデンになっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのバーベキューガーデンの両側からは、本棟への坂道、新寮敷地への坂道が、それぞれ延びている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "バーベキューガーデンのむこう側は、これはもうただの丘――このキャンパスを包囲する、圧倒的な自然の最前線で、学校の敷地ではない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "舗装の終わったところから、いきなり山が立ちあがっていて、繁みが垂れさがっていることから考えると、このバーベキューガーデンは、もとは池か沼だったのかもしれない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生、ぜんぜん寮にきたことないでしょう」「ええ、いつも、レッスンまえにきて、レッスンが終わったら帰るんだもの」「バーベキューガーデンができあがったんで、きょうがオープン」「そうなの。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どこいくんだよ」　高志はなにもいわずに、バーベキューガーデンにおりる階段に足を踏みだした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "倫敦市中にも無論に多く見られるのですが、わたしが先ず軽蔑の眼を拭わせられたのは、キウ・ガーデンをたずねた時でした。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その朝に高田商会のＴ君がわざわざ誘いに来てくれて、きょうはキウ・ガーデンへ案内してやろうと云う。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速に支度をして、ベーカーストリートの停車場から運ばれてゆくと、ガーデンの門前にゆき着いて、先ずわたしの眼をひいたのは、かのホース・チェストナットの並木でした。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日、近所の理髪店へ行って、きのうはキウ・ガーデンからハンプトン・コートを廻って来たという話をすると、亭主はあの立派なチェストナットを見て来たかと云いました。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速に支度をして、ベーカーストリートの停車場から運ばれてゆくと、ガーデンの門前にゆき着いて、先ずわたしの眼をひいたのは、彼のホース・チェストナットの並木でした。",
              "citation": {
                "source": "栗の花",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "送別会後、脇村氏を待って二人でウンテルデンリンデンを通り、チヤガーデンを歩く。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘇州河の数ある橋のうちでも、ガーデン・ブリッジは自動車の往来が最も頻繁であり、南北四川路をつなぐ橋は人間の往来が最も頻繁であり、この後者の橋の袂には、早朝から深夜に至るまで黄包車が群がっている。",
              "citation": {
                "source": "上海の渋面",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔無題〕黄味がかつた白い睡蓮、この花を見ると、直ぐ私の目に浮ぶのは倫敦のキウ・ガーデンの池、仏蘭西風と全くちがつた自然らしい公園の奥の池、あなたと私とは立止まり、さて其処に見た、羅衣に肌身の光る静かなる浴女の一群。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆっくりケンシントンガーデンで茶をのみ、タクシーで労働大学へ行って見た。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
