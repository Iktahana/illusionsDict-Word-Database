[
  {
    "uuid": "ee02e9b9-af4d-53e2-ab67-fad0d5eb077f",
    "entry": "がら落ち",
    "reading": {
      "primary": "がらおち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
