        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "初対面の人にいきなり年齢を尋ねるなんて、がさつな人だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は酔うと、がさつな言動が目立つようになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「人の気にしていることを平気で言うなんて、君はがさつだね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
      }
