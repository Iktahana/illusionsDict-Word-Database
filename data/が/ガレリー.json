        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「このホテルの最上階には、海を一望できるオープンガレリーがあるんだよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新作の絵画をガレリーに展示するため、朝からライティングの微調整を繰り返した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歴史ある洋館のガレリーを歩いていると、まるで19世紀にタイムスリップしたような気分になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "身躯の重みをちょっと寄せかけるや否や、音もなく、自然と身は大きなガレリーの中に滑り込んだ。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは去年のことだが、ベルリンに遊んでいた時分、ウンテル・デン・リンデンを通りぬけて、川向うのナツィオナール・ガレリーに行ったことがあった。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "またワシントンのフリヤー・ガレリーといふ美術館は、支那の古畫をもつて特色としてゐます。",
              "citation": {
                "source": "博物館",
                "author": "濱田青陵",
                "note": "青空文庫"
              }
            },
            {
              "text": "大入で這入れないからガレリーで立見をしていると傍のものが、あすこにいる二人は葡萄耳人だろうと評していた。",
              "citation": {
                "source": "倫敦消息",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "このカラカラ浴場の図書館遺蹟には写本やパピルスを展示するための何層もの円形のガレリーが存在する。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
