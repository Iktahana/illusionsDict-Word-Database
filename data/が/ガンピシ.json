      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "traditional Japanese paper made from the fibre of plant species Diplomorpha sikokiana (high quality, glossy)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "書道展で展示されていた作品は、どれも上質な雁皮紙に書かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "雁皮紙は、その光沢と滑らかな質感が特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この古い版画は、雁皮紙に刷られているから保存状態が良いね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "美術館で見た古い絵巻物、あれも雁皮紙だったのかな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "『ガリ版文化史』のもう一人の著者、田村紀雄によれば、「堀井父子は、伝統的な染物法の一つ捺染法と型紙にヒントを得て、雁皮紙に蝋を塗布し、台板（ヤスリの原型）に鉄棒で孔をあけるという方法を考案した」と言います。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "澹山は一々それを薄い雁皮紙に細かく書きとめて、着物の襟や帯の芯のなかに封じ込んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして軽く麝香の漂うなかで男の字のような健筆で、精巧な雁皮紙の巻紙に、一気に、次のようにしたためた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母様はその日からその五枚続きの絵を雁皮紙に写し取って、合わせ紙に貼り付けたり切り抜いたりして、お仕事にかかられまして五日目には立派に仕上ったのを楠の一枚板に貼り付けておしまいになりました。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "気に入った絵があると、母は、雁皮紙をその上にのせ、丁寧にしきうつしをして、後から色だけを自分のこのみに従って塗っていた。",
              "citation": {
                "source": "母",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "灯がその火屋の中にともるとキラキラと光るニッケル唐草の円いランプがあって、母は留守の父のテーブルの上にそのランプを明々とつけ、その上で雁皮紙を詠草のよう横に折った上へ、細筆でよく手紙を書いた。",
              "citation": {
                "source": "父の手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雁皮紙のごとき薄い紙でも表裏はある。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下で、雁皮紙を横綴にしたものへ、真書き筆で、こまごまと父への手紙をかく。",
              "citation": {
                "source": "中條精一郎の「家信抄」まえがきおよび註",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雁皮紙は何枚も厚く重ねてこよりでとじられた。",
              "citation": {
                "source": "中條精一郎の「家信抄」まえがきおよび註",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、子供らしくむっとして、其那頃まで待たされてはかなわない、という気がする母は、雁皮紙の便りに、この文章について何と書いたであろうか。",
              "citation": {
                "source": "中條精一郎の「家信抄」まえがきおよび註",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "御ひるっから二時頃までは何やら彼やらと下らない事を云ってすごしてしまったので大あわてにあわてて墨をすり筆の穂をつくろって徳川時代を書いた古風な雁皮紙とじたのと風俗史と二年の時の歴史の本と工芸資料をひっぱり出す。",
              "citation": {
                "source": "日記",
                "author": "一九一三年（大正二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこまで読みました」「はい、ここまで拝見しましたが」と言ってお松は、雁皮紙刷りの一種異様な古版本のある頁を開いて、駒井の方へ示しました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなふうに削ったのがいいだしになるかというと、削ったかつおぶしがまるで雁皮紙のごとく薄く、ガラスのように光沢のあるものでなければならない。",
              "citation": {
                "source": "だしの取り方",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなふうに削ったのがいい出汁になるのかと申しますと、削ったかつおぶしがまるで雁皮紙のごとく薄く、ガラスのように光沢あるものでないといけないのであります。",
              "citation": {
                "source": "日本料理の基礎観念",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "途次榛原帋舗の前を通過ぎし故、雁皮紙罫引帳面を購はむとせしに、近頃雁皮の製本をなす職人少くなり、又之を求むる顧客も稀になりたれば、出来合の品売切になりしまゝ備へ置かずといふ。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之五大正十年歳次辛酉",
                "note": "青空文庫"
              }
            },
            {
              "text": "製紙用ガンピ二種　雁皮紙をつくる原料植物、すなわちジンチョウゲ科のガンピには明かに二つの種類が厳存する。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに昨日の朝、幸吉さんの家の前でこんなものを拾つたんですが」　有太郎が取り出したのは、灰のやうな物を雁皮紙に包んだ、子供の拳固ほどの球でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鼬小僧の正体",
                "note": "青空文庫"
              }
            },
            {
              "text": "『邪宗門』を持っている者は北陸道では私一人であろうし、雁皮紙のように美しい四六倍判六号組みという高邁ハイカラな詩の雑誌『屋上庭園』を購読している者は私一人だったからである。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もっと思いも寄らぬ人だ」「誰でしょう、親分」「あの晩、この離屋に居た人間だ」「すると」　恐ろしい焦躁と不安に、植幸の唇は雁皮紙のように顫えます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "綾吉殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポチヤポチヤして可愛らしくて、若い男の心をひしと掴まずには措かない――といふ噂のお濱が、この物に怯えて雁皮紙のやうに顫へて居る娘とは思ひもよりません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "九百九十兩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポチャポチャして可愛らしくて、若い男の心をひしと掴まずにはおかない――という噂のお浜が、この物に怯えて雁皮紙のように顫えている娘とは思いもよりません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "九百九十両",
                "note": "青空文庫"
              }
            },
            {
              "text": "「解らん、俺には何も彼も解らん」　狭い演奏者休憩室の椅子に、投り出されたように腰を下した幾久雄の唇は、雁皮紙のように慄えて、その眼は無念の涙さえ含んで居りました。",
              "citation": {
                "source": "天才兄妹",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "封筒は行儀よく鋏で截られていて、なかに日本の雁皮紙にしんかきでぴっしり書き埋めた厚い手紙が入っていた。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔、泰造がロンドンに行っていた足かけ五年の間に、まだその頃三十歳にかかる年ごろだった多計代は、雁皮紙を横にたたんで、そこへしんかきのほそくこまかい字をぴっしりつめて、何百通もの手紙をかいた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若かった多計代は、そういうときは特別にピカピカ光るニッケル丸ボヤのきれいな明るい方のランプをつけ、留守中の泰造のテーブルに向って雁皮紙の手紙をかいた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまになって考えれば、その雁皮紙の手紙には、家計のせつないことから、姑が、父のいないうちに多計代を追い出して父の従妹を入れようとしていると、少くとも多計代にとってはそうとしか解釈されなかった苦しい圧迫などについて訴えられてもいたのだ。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに薄い雁皮紙でも、お粥の上皮でも皆厚みは持っている。",
              "citation": {
                "source": "面積の厚み",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉の外殻はうすい雁皮紙で一枚一枚｜貼って、金属のようになるまで根仕事で固めたものである。",
              "citation": {
                "source": "銀河まつり",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "原画は薄い雁皮紙にかぎられていて、桜の版木に直接ノリ貼りされた画稿の上から、小さい鑿のさきが、一線一線絵を彫り起してゆくのだった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
