[
  {
    "uuid": "8fdaa074-5aab-50b6-be0c-236e2db05b97",
    "entry": "雁皮紙",
    "reading": {
      "primary": "がんぴし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
