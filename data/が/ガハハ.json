        "examples": {
          "standard": [
            {
              "text": "「がはは！まさかこんな展開になるとはな！」と、彼は豪快に笑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冗談を聞いて、おじいちゃんが「がはは！」と声を上げて腹を抱えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "悪だくみが成功して、悪役が高笑いする声が「がはは！」と響いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "かれの詩は子供がははおやの白い大きい胸にすがるやうにすなほな極めて懐しいものも其疾患の絶え間絶え間に物語られた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで急いでそれを美濃紙に清書して、夜森博士邸を訪ね博士に之を示すと、それを閲読したあとで博士がはははははと笑れた。",
              "citation": {
                "source": "パンの会の回想",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい子もわりと揃えてたのよ」「京都には女の子つきで一晩いくらっていう宿屋があるときいてたけど、ははアん……」「何がははアんよ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを左りへ行けば直ぐ鹽山ステーシヨンで、片がはは桑畑、他の側の家並みは多く飮食店で、ところ／″＼の二階からはあやしげな女が首を出してゐた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車の走る道の両がはは大抵松ばかり茂つてゐた。",
              "citation": {
                "source": "歯車",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の霧　香ばしき昼の霧わがははの肩のあたりの霧爪は語らず陽もまばゆくて昼の霧よ五里霧中のなかに泳ぐ女だるまのすすりなく霧。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "村はづれの岡のふもとの、八｜幡様のわきの池で、片がはは木がこんもりとしげり、もう片一方は、草の生えた土手です。",
              "citation": {
                "source": "ふしぎな池",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたが昨夕、どこへも行かずに、おとなしく帰って下すったから、そのお礼心なのですよ」と言ったから、神尾がははあと感づきました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
