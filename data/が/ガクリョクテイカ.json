        "examples": {
          "standard": [
            {
              "text": "ゆとり教育の導入後、基礎的な計算能力や漢字の読み書きに不安を覚える層が増え、学力低下が深刻な議論を呼んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "授業時間を削って行事ばかり優先していたら、ダイレクトに生徒たちの学力低下につながってしまうよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「学力低下を食い止めるために夏休みの宿題を倍にする」なんて、生徒からしたらたまったもんじゃないね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スマホの使いすぎで読書時間が極端に減っており、語彙力の面からくる学力低下が全国的に懸念されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "戦争中、国民学校上級生から中学、専門高校の男女学生が戦争遂行のために様々の形で動員され一週間に学習する日は一日二日あるかなしの有様であったことを思えば全体の学力低下はさけられない結果であった。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず挙げられるのは、学力低下の問題である。",
              "citation": {
                "source": "六三制を活かす道",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "数学などは、もっとひどく、恐るべき学力低下ということである。",
              "citation": {
                "source": "六三制を活かす道",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
