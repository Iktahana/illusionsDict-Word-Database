    "definitions": [
      {
        "index": 1,
        "gloss": "quill pen",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔の詩人は、鵞ペンをインク壺に浸して、羊皮紙に詩をしたためていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "万年筆が普及する前は、鵞ペンが書記の必需品だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この美術館には、有名な作家が使っていたという鵞ペンが展示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わあ、すごい！本物の鵞ペンで書かれた文字だ！」と子供たちは目を輝かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "いつも言ってることなんですけどね」と、インキつぼは、鵞ペンだの、そのほか、机の上にのっている、耳の聞えるものたちにむかって、言いました。",
              "citation": {
                "source": "ペンとインキつぼ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいいち、あたし、そんなこと考えてもみなかったわ」「たしかに、あなたの言うとおりですよ」と、鵞ペンが言いました。",
              "citation": {
                "source": "ペンとインキつぼ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "鵞ペンだって、はがねのペンだって、どっちも、よく知ってるわ。",
              "citation": {
                "source": "ペンとインキつぼ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまだに彼女等がハリウッドへスターのサインを貰う為めに手紙を鵞ペンでなぞりなぞり書いてるような娘たちであったらこりゃむずかしい。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一は雑誌「詩と音楽」の鵞ペンであり、一は大震災前後の手記であつて、詩論集としてはいさゝかこれと趣きを異にしてゐるからである。",
              "citation": {
                "source": "文庫版「芸術の円光」覚書",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とホームズは言葉に合わせ、鵞ペンナイフを取り出した。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "インクと鵞ペン、それに吸い取り紙は自前でお願いしたいのですが、机と椅子は用意してあります。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも……朝になると、まぁとにかく一度行ってみるくらいはしてみようと、そう決心しましてね、インクの小瓶と鵞ペン、フールスキャップ判の紙を七枚買って、ポープス・コートへ出向いたんです。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓のところに、一本、ふるい鵞ペンがのっていました。",
              "citation": {
                "source": "ひこうかばん",
                "author": "DEN FLYVENDE KOFFERT",
                "note": "青空文庫"
              }
            },
            {
              "text": "卓子の上には切りたての鵞ペンと銀の透し彫りの墨壺がのって居る。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がエリザ式の半ズボンに絹の靴下を膝頭で結んだ右足を左りの上へ乗せて鵞ペンの先を紙の上へ突いたまま首を少し傾けて考えているところを想像して見た。",
              "citation": {
                "source": "倫敦塔",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、砂函とインキ壺を入れる正方形の枡穴があって、その二つの枡穴の中間には、鵞ペンや封蝋などといった細長い物を入れる長方形の溝が刳りぬいてある。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "チチコフは、すぐさま仕事に取りかかり、先ず鵞ペンを削って、書きはじめた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分の家には何がどれほどあるのやら、もうすっかり忘れてしまって、ただ憶えているのは、戸棚のどこかに、何かの浸酒の残りを入れた壜があって、それをこっそり誰かが盗んで飲まないように自分でちゃんと記号をつけておいたのと、それから鵞ペンや封蝋がどこにあるという位のことである。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、鵞ペンが一束に、まだ白紙のままの公用紙が一帖、半靴下が三足、ズボンからちぎれたぼたんが二つ三つ、それに読者諸君が先刻御承知の【半纏】――それだけであった。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ずこの男が使っている鵞ペンの削り方をよく調べて、それに傚って何本も鵞ペンを削っておき、始終それを相手の手許へ差し出すようにした。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸川乱歩は、昼間も部屋を暗くして、蝋燭をつけて小説を書くという噂が立ったが、この筆法で行けば、小栗虫太郎はレトルトや坩堝の並んでいる机の上で、鵞ペンを持って、羊皮紙の上に小説を書いているに違いない。",
              "citation": {
                "source": "「黒死館殺人事件」序",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つんとすましたＡの字はオリンプ山の頂に槍に代へたる銀白の鵞ペンの尖を立ててゐる。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "長椅子にゆったり腰かけながら、話しているのは昆虫館主人で、鵞ペンを指先で弄んでいる。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもその上には種々な貝殼を鏤めた筆立が置いてあって、鵞ペンでない只の美しい鳥の羽が四五本※っていた。",
              "citation": {
                "source": "運命のままに",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸のなかでは疲れた男囚たちがいびきをかき、鼠がストーヴのかげで鵞ペンをかじる。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君のところはいいな」と私は言葉をつづけた、「温かで、柔かくって、居心地がよくって……それに鵞ペンもある」とデスクの上に眼をやって笑いだした、「砂壺〔その頃は、砂を吸取紙の代用とした。",
              "citation": {
                "source": "妻",
                "author": "ЖЕНА",
                "note": "青空文庫"
              }
            },
            {
              "text": "己がおびき出して取った血の一滴が、鵞ペンの軸の奥深く詰まっている。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、ブルメナウ大尉から受け取った鵞ペンで、何か魚のようなものを描いて、しきりにそれを突くのであったが、今度はこちらにその意味がなんとしても通じなかった。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして老エフィゲニウスが眼に入れても痛くないほどに鍾愛している一人娘のロゼリイスは、芝生に坐って私のために鵞ペンを削りながら、絶えず涼しい微笑みを送ってくれ、遥か橄欖と糸杉の森の彼方では、侍女のオルフィスやピエラたちが、蕃紅花の花を摘んでは銀皿に盛って、この紫のインキを搾っていてくれるのです。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この函を拾った方は、どうぞ私の姉のところへお届け下さるようにと……そのお礼には、函の中の宝石をお取り下さるようにと……私、函の中へ、ミレネアの花瓶も……エスキリネの鏡も……金も銀も宝石も一杯に入れておきますわ」「…………」「私、貴方のために鵞ペンをたくさんに削りますわ。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙草にものを書くということは、まことに容易ならぬ苦労であって、慣れない私は、三行に一本くらいずつの割合で、ペンを潰してしまうのですが、ロゼリイスは約束のように私の傍に坐って、せっせと鵞ペンを削っていてくれるのです。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕃紅花の花を搾って、インキを作り、鵞ペンを削って、ロゼリイス姫が、これを手伝っていられました。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "（a）わたしは手紙にきちんと封をすることもできなければ、ついぞ鵞ペンがけずれたためしもないし、ご馳走によばれても何一つめぼしいやつを切り取ることができない。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "農鳥山の赭ッちゃけた壁には、白雪がペンキでも塗ったように、べッたりと光って輝いている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
