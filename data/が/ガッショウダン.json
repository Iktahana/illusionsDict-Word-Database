    "definitions": [
      {
        "index": 1,
        "gloss": "chorus group",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "そのプロ合唱団は、海外の音楽祭に招待され、見事な歌声で聴衆を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "地域の子供たちで結成された合唱団が、福祉施設を訪問して練習の成果を披露した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は大学時代、グリークラブという歴史ある男声合唱団に所属していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "市民合唱団の定期演奏会のお知らせが、市の広報誌に大きく掲載された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "（21）『マインツ教会合唱団による死者のための通夜』（22）mace ――先に鉤釘のついた矛で、片手で振り、甲胄を破るなどに用いられた中世の武器。",
              "citation": {
                "source": "アッシャー家の崩壊",
                "author": "THE FALL OF HOUSE OF USHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "観衆は襟を正し吹き靡く焔を見ている内に、静かに、徐々に、高く合唱団がリヒャルト・ストラウス作のオリンピックの歌曲を合唱する。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことしのメーデーに自立合唱団や劇団はどんな自分たちの催しものを、全勤労者のメーデーの賑わいに交える計画だろう。",
              "citation": {
                "source": "正義の花の環",
                "author": "――一九四八年のメーデー――",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年共産同盟の若々しい合唱団もトラックにのって来ていて、新協とかわりがわり歌をうたい、よろこびの日の賑わいを添えた。",
              "citation": {
                "source": "メーデーに歌う",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ボリス・ゴドノフ」にしろ、新しい舞台装置とこの群集＝合唱団の巧みな扱いかたで、新鮮さを出しているのだ。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ゴトブ」のオペラでもバレーでも同じように合唱団＝集団の統制を、こういう自主性をもって扱われることだと思っていたのだ。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベートーヴェンの第九シムフォニーのコーラスには専門学校の男女合唱団がしばしば参加する。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "説明といふから語弊があるのだが、あれは、歌舞伎のチヨボ乃至希臘劇の合唱団、まあそれと全然同じではないが、それに似た役割を演ずるやうになれば面白くもあり、有意義だと思ふ。",
              "citation": {
                "source": "映画素人談義",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "対話以外にそういう説明がいるときは、解説者を使うこともあるが、さまざまな音響効果、音楽、または、ギリシヤ劇風の合唱団を使つてもよい。",
              "citation": {
                "source": "ラジオ・ドラマ私見",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "数校の合併による、男女合唱団など作るのもよい。",
              "citation": {
                "source": "都市文化の危機",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、優秀なる吹奏楽団、合唱団等の総動員も計画通り実施する。",
              "citation": {
                "source": "空襲時に於ける興行非常対策について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "また「俳優」といふ言葉も羅馬以来現在使はれてゐる「アクタア」即ち「動作をする人」になつたのですが、希臘では「｜答へる人」――即ち「合唱団」と問答をする役であつた。",
              "citation": {
                "source": "演劇一般講話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめのうちは、一とこ二とこ、三とこ四とこ、さういふ風に聞えてゐた歌が、だん／＼、声の数が殖え、起る場所が拡がつて、しまひには、公園全体が、合唱団のやうになつた。",
              "citation": {
                "source": "遂に「知らん」文六（三場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて彼等の機関誌ができ、サロン風の例会が毎週欠かさず行はれて、まつたく自然の推移のうちに、会員達の有志によつて、候鳥アンサンブルや合唱団が組織された。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ近所の市立公園ではオーケストラが音楽を奏で、合唱団が歌をうたっていた。",
              "citation": {
                "source": "イオーヌィチ",
                "author": "JONYCH",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてヴェーラ・イオーシフォヴナがその手帳を閉じたとき、一同はものの五分ほど沈黙のままで、合唱団のうたっている『＊榾あかり』の唄に耳を傾けていた。",
              "citation": {
                "source": "イオーヌィチ",
                "author": "JONYCH",
                "note": "青空文庫"
              }
            },
            {
              "text": "二〇〇九年一〇月六日大久保ゆう（※なお、この台本は原楽譜入手を経た二〇一二年三月十八日、四街道少年少女合唱団によって第一幕の上演がなされました。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きくでぶでぶ太ってる俳優らの醜怪な様子、二列に並んでるどこから見ても無格好な合唱団、所作の幼稚さ、喚いて充血してる顔付、毛の乱れてる鬘、テナー歌手の高い靴の踵、種々な顔料で顔を彩色してるその恋女の粉飾、そういうものをも、子供の鋭い眼は見落としていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "メルキオルは自分の位置につき、ジャン・ミシェルは合唱団を指揮していた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――しかし、「南ドイツ男声合唱団」が現われた時、聴衆の注意は厳粛になった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の音楽は、唱応的の和音を弾じないし、人は音楽的の分節というものを、只の一つも思い出すことがなく、家庭で、或は家族がそろって歌うということも聞かず、学校の合唱団もなければ、男子の群が歌ったり、往来で小夜曲を奏じたりすることもない。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどい歌うたいの合唱団と、赤鼻の道化者じみた、しかしなぜか馬鹿に浮き立たない、酔っ払ったミュンヘン生まれのドイツ人が、精々見物のご機嫌を取り結んでいた。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "バカな間抜けがゾロフ夫人に魂を抜かれおって」「ブカレスト劇場の合唱団にいた女だ。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "このレコードについて私は繰り返して書いているが、管弦団と合唱団は英国のＢ・Ｂ・Ｃで、指揮はビーチャム卿、独唱者のうち、ソプラノのラベットと、バリトンのウィリアムスがわけてもすぐれている（コロムビア傑作集二一六、Ｊ八四五〇―六七）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちからきわめて興味の深いものだけを掲げるとしたら、コロムビアの、ティルの独唱した「わが心をとりたまえ」（第六五番）、「ああ不思議なる愛」（第八五番）（ＪＷ四五）、ラインハルト合唱団の「吾等病める足を持ちて雄々しくも急げり」（第七八番）（Ｊ八六四〇）、以上二枚は傑出したレコードと言えるだろう。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "レコードはやや吹込みの古きを我慢すれば、ビクターにアルバート・コーツがフィルハーモニック合唱団とロンドン交響管弦団を指揮した名盤がある。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「クリスマス聖譚曲」のうちからは「神に栄光あれ」と「感謝に満ちて」が、ゲオルク・シューマンの指揮で、ベルリン・ジング・アカデミー合唱団のがビクターに入っている（ＪＨ六三）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "マリア・テレジアの別荘に合唱団の一員として伺候し、精一杯の茶目振りを発揮して、マリア・テレジアに「あのブロンドの大頭」と指摘され、鞭のお仕置を受けたことなどもあった。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイドンは流浪のある日、教会の合唱団長に採用を拒絶されてしまったので、人知れずその合唱団の中に交り、いざ独唱というとき、独唱者の手から楽譜を奪い取って、朗々と歌い出したことがある。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
