        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は本当に頑張り屋で、いつも誰よりも遅くまで残って仕事をしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "小さい頃から頑張り屋だった彼は、どんなことでも諦めずにやり遂げる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "うちの娘は頑張り屋だから、きっと発表会も成功させるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「なかなか頑張り屋だのう。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし被害者が頑張り屋で、きちんとすることが好きな人間だったら、中毒症状を起しながらも懸命の努力を揮って吸殻を灰皿へ抛げこむだろう。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずいぶん、がんばりやさんだなあ」「なるほど。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "がんばりやだった青江三空曹の最期！",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "墜落　　　　　１　あれほどがんばりやだった青江三空曹も、鬼神ではなかったので、力も根もつきはて、ついに尊い犠牲となりました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなかがんばりやなのでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日校正わたしたら、あの岩波の小さい本を一気によんで、それから又『文芸』のつづきを一がんばりやって、二十日にはすっかりさばさばとなって、それから大した計画があるのよ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
