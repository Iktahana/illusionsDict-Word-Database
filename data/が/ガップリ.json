        "examples": {
          "standard": [
            {
              "text": "彼は敵の攻撃をがっぷり受け止め、微動だにしなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供は父親の大きな手にがっぷりとしがみつき、安心しきっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "重い荷物を運ぶ際、彼は腰を落としてがっぷりと持ち上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ただし容赦はなくても、ともかくも書き手と編集者はがっぷり四つに組む。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その進撃はあまりにも速く、はっと思う間に、もうビレラフォンは彼の敵とがっぷりと組んでいました。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "見れば二匹の蛾がお互いにがっぷり組んで、車輪となり、光りながらぐるぐる回っている。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            }
          ]
        }
