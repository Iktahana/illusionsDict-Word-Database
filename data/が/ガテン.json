[
  {
    "uuid": "c55432ae-5e93-56ac-9733-f143be4b5965",
    "entry": "合点",
    "reading": {
      "primary": "がてん",
      "alternatives": [
        "がってん"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "consent",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「なるほど、そういうことか！ 辻褄が合ってようやく合点がいったよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "理由を聞いて納得したおじいちゃんが、「合点だ、任せておけ」と威勢よく胸を叩いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「合点承知之助！ その件については、私の方で責任を持って手配しておきます」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし「胸黒じゃ」などと彼は独り合点をしているのである。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚕種検査の御役人が帰るのだなと合点がいった。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも合点の行かないことだと思う。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでやっと述べ得た事すらも多くは平凡でなければ不得要領であったり独り合点に終っているかもしれない。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かを考えつくと勝坊に、Ｔ「直ぐ帰って来るから此辺でじッと待ってるんだよ」　勝坊合点する。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーアーと勝坊合点して、　「この人が落したんだよ」　と商人を指で示す。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "と乞食は分らないが、　殿様の独り合点は尚続く。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにオリジナルな変異の産物でも当代の多数の観賞者が見てちっともおもしろくなかったり、ひとり合点で意味のわからないようなものは、わざわざ勦絶に骨を折らなくても当代の環境で栄えるはずはないであろう。",
              "citation": {
                "source": "俳句の型式とその進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは云うまでもなく、橋が多くの交通路の集合点であって一種の関門となっているからである。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　どうも敬四郎には合点がゆかぬ。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれも汚れてますで……」　姉が合点合点などしてゆっくり捜しかけるのを、じゅうじゅうと音をさせて煙草を呑んでいた兄は「扇子なんかどうでもええわな。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と幾度も一人で合点み、「ええ、織さん、いや、どうも、あの江戸絵ですがな、近所合壁、親類中の評判で、平吉が許へ行ったら、大黒柱より江戸絵を見い、という騒ぎで、来るほどに、集るほどに、丁と片時も落着いていた験はがあせん。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすりゃちっとあ念ばらしにもなって、いくらか彼奴らが合点しよう。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なあ、お香、いつぞや巡査がおまえをくれろと申し込んで来たときに、おれさえアイと合点すりゃ、あべこべに人をうらやましがらせてやられるところよ。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "境内の変にからりとしている訳もこれで合点が行って、あるべきものが亡せているのだなと思いながら、庫裡へと入った。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "和尚はその姓名を聞くと、合点が行ったのかして、急にくつろいだ様子になって、　アア、あの風吹烏から聞いておいでなさったかい。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この高慢税を納めさせることをチャンと合点していたのは豊臣秀吉で、何といっても洒落た人だ。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "川添いの地にいたので、何時となく釣魚の趣味を合点した。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分には合点が行かなかったから、　遊びじゃないように先刻お言いだったが、今の鮒なんか何にもなりはしない、やっぱり遊びじゃないか。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに至って合点が出来た。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し自修ばかりでは一人合点で済まして居て大間違いをして居る事があるものですから、そこで輪講という事が行われる。",
              "citation": {
                "source": "学生時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽田などの漁夫が東京の川へ来て居るというと、一寸聞くと合点がいかぬ人があるかも知れないが、それは実際の事で、船を見れば羽根田の方のは※の方が高くなって居るから一目で知れる。",
              "citation": {
                "source": "夜の隅田川",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵の具のほうですっかり合点してよろしくやってくれるのを、自分はただそこまで運んでくっつけてやっているだけのような気がする。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "肝心の要訣がぼかしてある場合が多いのは著者の故意か不親切かひとり合点かわからない。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャメラが一町とは動いていない場合に、面画は何千里の遠方にあるか想像もできないようなひとり合点の編集ぶりは不親切である。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまたこの事から、とんぼの止まっているときの体向は太陽の方位には無関係であるという結論を下したとしたら、それはまた第二の早合点という錯誤を犯すことになるであろう。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、新宿の若松屋のおかみさんは、僕の連れて行く客は、全部みな小説家であると独り合点している様子で、殊にも、その家の女中さんのトシちゃんは、幼少の頃より、小説というものがメシよりも好きだったのだそうで、僕がその家の二階に客を案内するともう、こちら、どなた？",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三島大社では毎年、八月の十五日にお祭りがあり、宿場のひとたちは勿論、沼津の漁村や伊豆の山々から何万というひとがてんでに団扇を腰にはさみ大社さしてぞろぞろ集って来るのであった。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならば或る者は宣伝の効果を主張し、或る者は商品販売の効果を重視し、或る者は教育上の効果を言い立て、各々の価値の批準がてんでにちがってくるから。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "興哥はがてんがゆかなかった。",
              "citation": {
                "source": "金鳳釵記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
