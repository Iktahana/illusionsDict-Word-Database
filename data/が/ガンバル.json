[
  {
    "uuid": "b47aeb50-6248-514b-a23c-ab88af018636",
    "entry": "頑張る",
    "reading": {
      "primary": "がんばる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
