    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to persevere",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新しい仕事を始めたばかりで、慣れないことばかりだけど頑張るしかない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今年は海外旅行に行くために、貯金を頑張るつもりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "チームのために、最後まで諦めずに頑張ると誓った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "どんなに辛くても、夢を叶えるために頑張る姿は美しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "お光が力付ける、Ｔ「頑張ってね」　と云われると、仲蔵自信ありげに、Ｔ「頑張る」　先程とは打って変って元気づいた。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おふみ　「嫌です」　と頑張る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げようとて逃がしてたまるか」と頑張るものがますます勢いを逞しくした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことしの夏は、東京に居残って頑張るのだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "預かった品やと言うて頑張るつもりやねン」「そんな嘘すぐはげるでしょう」　陽子が呆れると、チマ子はじれったそうに、「――そやさかい、行ってくれと頼んでるんやないの。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなことがあっても頑張る、どんな手段でも取る！",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も頑張るだけは頑張ってみたのだが、欠席日数があれではね」その癖その教授は彼等の落第を主張した一人だった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "頑張るのなら、皆んなで頑張らなくちゃ。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私はそれは違ふあの光りは下に、つまり街路へ向けて射してゐるのだと主張して譲らず、青木はその反対だと言ひ、どうしても頑張る、果ては私と青木は歩るきながら激論になつた、結局二人はその街燈の傍まで行つて勝ち負けを決めようではないかといふことになつた。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は前に、事があったら三日間だけは頑張ると云っていた。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "百合子さんが、若し貴宅を訪れましたらこのことゝ、そして、実家の思惑について依頼された守りに関しては、飽くまでも信用のある家庭教師が頑張るであらうから――とお伝へ下さい。",
              "citation": {
                "source": "女優",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「頑張るとか、埒があくとか俺にとつては、そんな類ひのものぢやないんだ。",
              "citation": {
                "source": "裸虫抄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁護士は俄に元気づいて、日本橋の北島町から浅草の蔵前まで、車を引ッ張って五分や十分じゃア絶対に行けないって頑張るんです。",
              "citation": {
                "source": "あやつり裁判",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以外は、どんなに不安に怯えるとも、博士を信頼して頑張ることになっていた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は一年ばかり叔父の家に顔出しをしなかったのです」「ではその間どこにいましたか」「どこにいたっていいではありませんか」「それじゃ、たしかにあなたは、一年ばかり藤田さんに会わなかったのですか」「会いませんとも」「そうですか、あなたがそれほど頑張るならば致し方ありません。",
              "citation": {
                "source": "自殺か他殺か",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "八十一　爺さんが来て、また帳場に頑張ることになってから、芳太郎はしばらく四ツ谷の媒介人の家に預けられた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "松やと一緒に寝かさうと思つても、何うしても厭だと言つて頑張るし、煙草でも買はせにやれば、入りこんで油を売つてゐるし、長くゐるうちには近所隣り何処へでも入りこんで、困ると思ふわ。",
              "citation": {
                "source": "チビの魂",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっとは苦しかろうが、生命と交換するのだと思って頑張るんだぞ。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――頑張れるだけ頑張る迄さ――　一階は相変らず男達の体臭で充満していた。",
              "citation": {
                "source": "罠を跳び越える女",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "空船は途中で迷っていたが、坊主がうんと頑張る途端に、艫の縄がぷつりと切れて、二人掛りの方が敗けた。",
              "citation": {
                "source": "死剣と生縄",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は「尾根にはまだ悪いところがありそうだから吹雪の止むまでここで待つか三、四のコルまで引返そうではないか」というと、吉田君は「もう一晩もこんなところにはいたくない、どんなことがあっても今日中に小屋へ帰ろう、悪いところはみんな自分が頑張るから」と。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……『昨夜、君の蒲団を引ったくった覚えはない』なぞと頑張る連中は、この第二箇条を厳守している正直者に相違ない。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "志村のぶ子という別嬪の旧教信者が居て熱心に布教しているだけだと、下らないところで頑張るのです」「僕の名前で命令したのか」「貴方のお名前でも駄目です。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "西木獣医は即刻釈放されるし、そうなると斎藤の後家さんも頑張る理由がなくなったので伜の結婚を承諾した。",
              "citation": {
                "source": "無系統虎列剌",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかにマン丸いお月様が出ておりました」　と落付いて頑張る表情が如何にも真剣で、不思議であった。",
              "citation": {
                "source": "Ｓ岬西洋婦人絞殺事件",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が支倉の居場所を知らないと云う筈がないじゃないか」「何と云ったって、知らないものは知りません」「ふゝん、未だ頑張るんだね。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "トコギリ庄司の不正をさらけ出して庄司を免職させなければならんのだが、あなた方の出ように依っては頑張る者ではない。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車が来る時、腕を下げないでがんばるなんて、そんなことあなたのためにも僕のためにもならないから僕はやりはしませんよ。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはほかのどんな手段ででも、その「やせ馬」どもが、すねてがんばる時は、そのとっときの鞭を一つ食らわせれば、それで万事はいいのだった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "小っぽけな子供なんぞ袖の下にはいってしまって、父は桟敷にがんばる。",
              "citation": {
                "source": "流れた唾き",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to insist that",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
