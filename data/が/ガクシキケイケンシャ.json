        "examples": {
          "standard": [
            {
              "text": "委員会のメンバーには、各分野の学識経験者が名を連ねている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい政策の策定にあたり、複数の学識経験者の意見を聴取した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は環境問題の学識経験者として、テレビの討論番組に出演した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼は、自分はプロヴィデンスの中でも特に優れた学識経験者十名ほどに対し個別にこの情報を伝え、彼らの見方を確認し、いかなるものであれアドヴァイスを受けるつもりである、と言った。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "総督は礼儀正しい学識経験者ということが分かり、探検に大きな関心を示し、娘のハイジも同様だ。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
