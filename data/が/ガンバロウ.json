    "definitions": [
      {
        "index": 1,
        "gloss": "pull together!",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「で、お前はどこまでも海事局で頑張ろうと云う積りかい？",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人の生産陣がいくら頑張ろうと、一週間に一隻の空母をこしらえるわけにはいかない。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはどこまでも頑張ろう。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の六（終局）",
                "note": "青空文庫"
              }
            },
            {
              "text": "庸三は長いあいだの荷物を卸して、それだけでもせいせいした気持だったが、当惑したのは子供のために頑張ろうとした姉と葉子との対峙であった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、Ｋは防空壕のところへ屈み、「ここで、頑張ろうか、水槽もあるし」と変なことを云う。",
              "citation": {
                "source": "夏の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し頑張ろう、という気らしい。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪の女が、どんなに頑張ろうとも、芝居はだんだん椅子風になって、食事と別になる事は明らかである。",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一頭とれば十分じゃないか――」　もっと頑張ろうという丹下船長に、村田氏はこういうのだ。",
              "citation": {
                "source": "鯨を釣る",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "質はともかく、せめて量目だけでも頑張ろうぜというしだい。",
              "citation": {
                "source": "明治の五十銭銀貨",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は、せいいっぱい頑張ろうって気が起こってるんだ。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、明日こそは、亀重君がなんと頑張ろうと、なんとかだましだましして、富士見町の兄さんの下宿まで是非彼のことを送り届けねばなるまいと、ぼくは、寝ながらそのように決心した。",
              "citation": {
                "source": "野宿",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもなお頑張ろうとするやつがたまにはいるけれども、そいつはまもなく躯じゅうから血を流し、毛を※り取られ、びっこをひきひき自分のおろかさや、大事な時間をむだにしたことを悔みながら、そこから逃げだしてゆくのであった。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも奴が頑張ろうとして、オールの足枷がうまく働いて、船が軽快さを失ったとしたらどうだ。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやキリシタンに相違ござらぬ」バカのくせに金弥がんばろうとする。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが労働者の運命なんだよ」という川原の言葉を思い出してがんばろうと思う駒吉の気持も、気持としてのところに止まる感じである。",
              "citation": {
                "source": "文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」答「私は飯田さんたちがすぐ釈放され、私もかくしとおしておけると信じてましたから、がんばろうと思ってウソをいったのです。",
              "citation": {
                "source": "それに偽りがないならば",
                "author": "――憲法の規定により国民の名において裁判する――鈴木裁判長",
                "note": "青空文庫"
              }
            },
            {
              "text": "がんばろうよ、ね」　組合の仕事をしている人との間では、仕事の関係上、結婚生活が従来の型では行われない場合が多いらしい。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "君がここでそうやって一人でがんばって見たところで、外の同志達はどうせ君ががんばろうなんぞとは思ってやしないんだから。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことではいけないと思い、なんとかして、黒川の手当の終るまで、がんばろうと、自分の気をはげましたのであった。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "道夫は、もっとがんばろうかとも思ったが、なにしろお腹はぺこぺこで、そして目の前の卓上にはおいしそうな卵の目玉焼きが、道夫の大好きなハムの上にゆうゆうと湯気をあげているので、もうがまんができなくて、思い切っていただいてしまうことにした。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふるいことはみんなわすれさって、かくごをあらたにしてがんばろうではないか。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ　３つと　はんぶんしか　おわってないし、　ほら、　それに　せめて　むだばなしで　てを　とめたりしなけりゃ　――　がんばろうよ、　こびとさん、　がんばってよ！",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "「がんばろう」　ひじょうな決心で、第二の井戸をほりはじめた。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "がんばろう」　といいながら昼飯に立ちあがった。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中村警部は八時ごろに帰れといいましたが、少年たちは八時半までがんばろうと、もうしあわせていたのです。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
