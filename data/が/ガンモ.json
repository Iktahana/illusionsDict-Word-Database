    "definitions": [
      {
        "index": 1,
        "gloss": "deep-fried tofu mixed with thinly sliced vegetables",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "おでんにはやっぱり、味がよく染みたがんもが欠かせないね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今日の晩ご飯は、がんもと大根の煮物にしようか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スーパーで出来立てのがんもを見つけると、ついつい買っちゃうんだよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ヘルシーなのにボリュームがあって、がんもはダイエット中の強い味方だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "殿、今もし此處におはしまして、例の辱けなき御詞の數々、さては恨みに憎みのそひて御聲あらく、さては勿躰なき御命いまを限りとの給ふとも、我れは此眼の動かんものか、此胸の騷がんものか、動くは逢見たき慾よりなり、騷ぐは下に戀しければなり。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿、今もし此処におはしまして、例の辱けなき御詞の数々、さては恨みに憎くみのそひて御声あらく、さては勿躰なき御命いまを限りとの給ふとも、我れはこの眼の動かん物か、この胸の騒がんものか。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレ、」「骨のあるがんもどきかい、ほほほほほほ、」と笑った、垢抜けのした顔に鉄漿を含んで美しい。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレ、」「骨のあるがんもどきかい、ほゝゝゝほゝ、」と笑つた、垢拔けのした顏に鐵漿を含んで美しい。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人の檀一雄などに、食通というのは、大食いの事をいうのだと真面目な顔をして教えて、おでんや等で、豆腐、がんもどき、大根、また豆腐というような順序で際限も無く食べて見せると、檀君は眼を丸くして、君は余程の食通だねえ、と言って感服したものであった。",
              "citation": {
                "source": "食通",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘助のがんもどきは割にうまいぞ――むむむむ割にうまいか、これは大沼勘六が事じゃ。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「烏賊があるなら、烏賊をもらおうか」「烏賊はおあいにくさま、がんもどきならありますが」「じゃ、がんもどきと、はんぺんにしてもらおう」　老人が鍋の中からがんもどきとはんぺんを挟んで山西の前へ出し、それから盃も出したところで、もうお燗が出来た。",
              "citation": {
                "source": "水魔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈を點けたり、電話をかけたり、流石のごりがんも征服されたかと思ひながら、電話口へ出ると、聲は老僧ではなくて、若い女らしく、「今夜これからお伺ひしようと思ふがいかゞでせう。",
              "citation": {
                "source": "ごりがん",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンニャク、がんもどき、竹輪につみれ、辛子のひりりッとしたのに、口にふくむような酒をつかって、青々としたほうれん草のひたしですか、元気を出しましょう。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おでん屋は皿ほどもあるがんもどきをつまみあげている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇さまに冷酒とがんもどきのおでんをさしあげたら、うまいものだねとおっしゃるに違いない。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず朝食に、丼いっぱいの御飯にがんもどきの煮つけ一皿。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "がんもどきの煮つけと冷飯。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「仕方がないさ、飯でも食べて、蓮子叔母さんとこへ行く事にしようや」　そういって、始めは遠慮っぽく蒟蒻や、がんもどきのたぐいをつっついていたのであったが、根が好きな酒だ。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンニャク、いゝね厚く切ってピンとくいちぎって見たい……がんもどき竹輪につみれ、辛子のひりゝッとした奴に、口にふくむような酒をつかって、青々としたほうれん草のひたしか……元気を出そう。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「がんもどき」を八十日に一度、粗悪な魚のきりみ一度。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "滅多に困っちゃ仕方がない」「すると僕なんぞも、今に、とおふい、油揚、がんもどきと怒鳴って、あるかなくっちゃならないかね」「華族でもない癖に」「まだ華族にはならないが、金はだいぶあるよ」「あってもそのくらいじゃ駄目だ」「このくらいじゃ豆腐いと云う資格はないのかな。",
              "citation": {
                "source": "二百十日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、がんもどきのおでんを一皿食べたところで、これも大なる負担ではあるまい。",
              "citation": {
                "source": "泡盛物語",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "どのがんも、これに対して不平をいったり、反対するものはありませんでした。",
              "citation": {
                "source": "がん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、Ｂがんがいうと、Ｋがんも、Ｓがんも、みんながその言葉に賛成しました。",
              "citation": {
                "source": "がん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこのごろのひどい霜夜、師匠の供をしてかえってくるとき、きっと師匠は途中でそばやへ入る、でなければやた一のおでんやへ飛び込む、そうして熱燗でいっぱいやりながらそばやなら鴨南蛮か天ぬき、おでんやなら竹輪かがんもへ辛子をコテコテと付けてさも美味しそうにそいつをたべる。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "遮莫、その小亀一座にはがんもどきと仇名打たれし老爺あり、顔一面の大あばた、上州訛りの吃々と不器用すぎておかしかりしが、ひととせ、このがんもどき、小亀社中と晩春早夏の花川戸東橋亭の昼席――一人高座の百面相に、その頃巷間の噂となりし小名木川の首無し事件を演じたりけり。",
              "citation": {
                "source": "随筆　寄席風俗",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "其或周に継がんものは、百世といえども知るべきなり。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうがんもおつゆにしたり、醤油で煮たりして食べる。",
              "citation": {
                "source": "チャンプルー",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "がんもどき　かつ子は十五歳になる。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やれ、やれ」とかなえは云った、「なんてぶきりょうな子だろう、まるで踏んつぶしたがんもどきだね」　かつ子は無表情にかなえを見返し、黙ったままゆっくりと立っていった。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
