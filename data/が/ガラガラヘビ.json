        "examples": {
          "standard": [
            {
              "text": "砂漠の乾いた岩陰で、毒々しい模様のがらがら蛇がとぐろを巻いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ドキュメンタリー番組で、がらがら蛇が尾を振って威嚇する様子が映し出された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「わっ、足元に！あれ、がらがら蛇じゃないか？！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それが有毒な敵で、その音こそあの有名ながらがら蛇の音だとは、私は少しも思ってもみなかった。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝六ならばいつやって参りますときでも、ガラガラとがらがらへびのようにからだじゅうを鳴らしながらやって来るのが普通でしたから、はてなと思いましてきき耳を立てていると、ところがどうしたことか、それがやっぱりあいきょう者なので、しかもほかになんびとか連れでもがあるらしく、やにわに奇態なことを促しました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "曲芸三人娘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
