    "definitions": [
      {
        "index": 1,
        "gloss": "(with a) slamming noise (door, telephone receiver)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "喧嘩の末、彼女はドアをガチャンと閉めて出て行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は怒りに任せて受話器をガチャンと置いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "強風で窓がガチャンと鳴り、思わず飛び上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "酔った勢いでグラスを落とし、ガチャンと割れてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "壁の電話がガチャンと鳴った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし昼間は、あの遠い所でする妙な音はいろいろな周囲の雑音に消されてしまうのか、ただすぐ自分の室のすみでガチャンガチャンと鳴るきわめて平凡で騒々しい、いくらか滑稽味さえ帯びた音だけが聞こえる。",
              "citation": {
                "source": "病院の夜明けの物音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また女の捨てばちな気分を表象するようにピアノの鍵盤をひとなでにかき鳴らしたあとでポツンと一つ中央のＣを押すのや、兵士が自分で投げた団扇を拾い上げようとしてそのブルータルな片手で鍵盤をガチャンと鳴らすのや、そういう音的効果もあまりわざとらしくないようにうまく取り入れられている。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、それでもきかずに、猶幾度か化物の折檻をこころみている中に、雄吉君はつい誤って、小石を硝子枠にぶつっけてガチャン！",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、自分はそれからすぐに、あのはにかむような微笑をする若い医師に案内せられ、或る病棟にいれられて、ガチャンと鍵をおろされました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガチャンガチャンと妹が縁先の小さい池に食器類を投入する音が聞えた。",
              "citation": {
                "source": "薄明",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその仕事は、スプリングか釘のようなものが、ガチャンと嵌まりこんだような音をたてて終った。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ガチャン☆）○やあ　出られたうれしーい○さあ　みんな集まれ！",
              "citation": {
                "source": "小熊秀雄全集−22",
                "author": "火星探検―漫画台本",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉が小さい室に風を煽って閉まると、ガチャン／＼と鋭い音を立てゝ錠が下り、――俺は生れて始めて、たった独りにされたのだ。",
              "citation": {
                "source": "独房",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯槽は小じんまりとしたコンクリートで出来ていて、お湯につかっていながら、スウイッチをひねると、ガチャン、ガタン、ガチャン、ガタン、ゴボン、ゴボンとスチームが入ってくるようになっていた。",
              "citation": {
                "source": "独房",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "一隊は三人で、先頭の看守がガチャン／＼と扉を開けてゆくと、次の部長が独房の中を覗きこんで、点検簿と引き合せて、「六十三番」　と呼ぶ。",
              "citation": {
                "source": "独房",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿りの看守がそれをガチャン／＼閉めて行く。",
              "citation": {
                "source": "独房",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉が突然ガチャン／＼と開いた。",
              "citation": {
                "source": "独房",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、直ぐにそのままよろめく気配がして表の硝子窓によろけかかり、ガチャンと云う激しい音と共にその窓｜硝子の真ン中にはまった大きな奴が破れおちると、そこから影法師の主の背中が現れた。",
              "citation": {
                "source": "銀座幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ガチャンと音がして、室の中の男が、ランプにぶつかって大きな影をゆららかしながら、向うへ飛び退いて行った。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはなぜです」「あの肉体も精神も弱いルナミは、音楽浴にすっかりのぼせ上ってしまって、観測などをするどころか、咽が裂けるような声で愛国歌を唄っては天文部の貴重な器機を片ッ端からスパナーでガチャンガチャン壊しては暴れ廻っています。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホーッともらす太い息、と、ガチャンと刀を捨てて、ピッタリ両手を突いたものである。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の瞬間彼女は悲鳴をあげて、ドアーを開けるべく力任せにゆすぶっていたが、やがてガチャンという物の落ちる音がして、そのままばったり静寂に返ったので、人々は気味が悪くなってドアーを開いてみると、哀れにも彼女は上から落ちて来たシビルの絵の額に脳天を打ち砕かれ血溜りをつくって死んでいた。",
              "citation": {
                "source": "怪談綺談",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪江さんが後から追蒐けて行って、また台所で一騒動やる中に、ガラガラガチャンと何かが壊れる。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然につく調子で、体をゆすぶりながら、かえしてゆくとき、鉄きゅうの上で鉄のせんべい焼道具がガチャンと鳴った。",
              "citation": {
                "source": "菊人形",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女でも、ひろい室の真中に一列に正座させて、どこにも背中のもたせられないようにし、すこし居眠りしていると監房の大きな錠前をひどい音でガチャン！",
              "citation": {
                "source": "本郷の名物",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――靴音はだんだん遠のいて、次の室を明けるらしいガチャンガチャンという音が聞えてきた。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてガチャンと言う硝子扉にうち当ったような音がきこえてきたが、そのままひっそりとしてしまった。",
              "citation": {
                "source": "階段",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さア、存じませんね」「硝子扉がガチャンと言ったでしょう」「ちっとも気がつきませんでしたよ」　女史は平然と答えた。",
              "citation": {
                "source": "階段",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二六時中ゲジゲジ野郎の相手がでけるけえ、ヘン　酔ぱらわなきゃ　俺アにはこの世の中が暮していけねえよ……」「……ま、一辺云ってみな、野郎……」　ガチャン　バタン　ガラ　ガラ　ガラ……　祭壇の壁一重隣りでは乱闘が始まった。",
              "citation": {
                "source": "反逆",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
