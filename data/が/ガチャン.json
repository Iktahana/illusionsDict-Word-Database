[
  {
    "uuid": "54ededf9-3af1-5b43-9b72-0901c09045e3",
    "entry": "ガチャン",
    "reading": {
      "primary": "ガチャン",
      "alternatives": [
        "がちゃん",
        "ガチン",
        "がちん"
      ],
