    "definitions": [
      {
        "index": 1,
        "gloss": "picture painted on glass",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
