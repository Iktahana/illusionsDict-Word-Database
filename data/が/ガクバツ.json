        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は入社後すぐに、社内の学閥の存在に気づいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "人事において学閥が影響を及ぼすことは、公平性を損なうと批判されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "残念ながら、この業界ではいまだに学閥が根強い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "胡麻塩頭の、金縁眼鏡をかけた、顔の白い、一寸学閥風の老紳士である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には官僚学閥の横暴なんて記事をかかげて博士を擁護する与太新聞も出てくるというしまつだった。",
              "citation": {
                "source": "或る探訪記者の話",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、博士の説はどうしたって正統派の医学者連と折れ合う気づかいはないので、博士はまもなく、「研究の自由を拘束する学閥への別辞」というセンチメンタルな文章を発表し教授の職を辞したのであつた。",
              "citation": {
                "source": "或る探訪記者の話",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、日本のあらゆる官僚機構と学界のすべての分野に植えこまれている学閥の威力は、帝大法科出身者と日大の法科出身者とを、同じ人生航路に立たせなかった。",
              "citation": {
                "source": "新しいアカデミアを",
                "author": "――旧き大学の功罪――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の大学は、人類の理性と学問に関するアカデミアであるより以前に、官僚と学閥の悪歴を重ねた。",
              "citation": {
                "source": "新しいアカデミアを",
                "author": "――旧き大学の功罪――",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治も中葉となれば、その官僚主義も学閥も黄金魔力に毒されてゆく。",
              "citation": {
                "source": "新しいアカデミアを",
                "author": "――旧き大学の功罪――",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に、それぞれの外国語で権威といわれる立場にいて後輩をもち、学閥をもっていた人々にとって。",
              "citation": {
                "source": "文化生産者としての自覚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "殆どギルド的な学閥を打破しなくてはならない。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故ならばこの委員会も従来の学閥ギルドそのままの選挙母体から選出されているからである。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の学術がその学閥ギルドから放たれて発展するためには、民間の諸会社、諸事業と結合することが予想されている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの二人が、久内の妻の敦子と久内の父の山下博士の学閥とのことで、のっぴきならぬ交渉関係に立たされる。",
              "citation": {
                "source": "「紋章」の「私」",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この割拠主義の一例としては、いはゆる「学閥争ひ」がどんなに日本の学問の進歩を阻害し且つ詰らぬ末梢的な感情的浪費に終始したかを見れば直ぐ分ることである。",
              "citation": {
                "source": "文化政策展開の方向",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに今度、親父の死、それに学閥なき者の出世の困難さにつくづく業を煮やしていた矢さきという条件も手伝って、祖先の地とその業務にかえる決意をしたので……　半年間は家産の再検討に過ごした。",
              "citation": {
                "source": "瘤",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしの父は、生前文部省の役人で一時帝国大学にも関係があったので、わたくしは少年の頃から学閥の忌むべき事や、学派の軋轢の恐るべき事などを小耳に聞いて知っていた。",
              "citation": {
                "source": "正宗谷崎両氏の批評に答う",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間また断えず主任教授の理不尽な圧迫が学閥なき私に加えられたので、今日その当時を回想すると面白かったとは冗戯半分言えない事も無いでは無いが、しかし誠に閉口した。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紆余曲折あるこんな空気の中に長く居りながら、何の学閥も無き身を以て明治廿六年就職以来今日まで実に四十七年の歳月が流れたのである。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "記者はその間のいきさつ或はその背後にある大学の内部事情、学閥などについて知り合の或学界通Ｂ君にくわしく質問して見たから読者諸君の御参考のために以下問答体でその話をなるべく正直に御紹介しよう。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第一部　牧野富太郎自叙伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間また断えず主任教授の理不尽な圧迫が学閥なき私に加えられたので、今日その当時を回想すると面白かったとは冗戯半分いえない事も無いでは無いが、しかし誠に閉口した。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第一部　牧野富太郎自叙伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "紆余曲折あるこんな空気の中に長くおりながら、何の学閥も無き身を以て明治二十六年就職以来今日まで実に四十七年の歳月が流れたのである。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第一部　牧野富太郎自叙伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁論大会のようなものをちょっと覗いてみると、髪をぼうぼうにした学生が、紋附の羽織などを着て、官学閥の打破とか、機会均等とかいうことを、大声疾呼して大いに熱弁をふるっていた。",
              "citation": {
                "source": "私の履歴書",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "内実は学閥外の天才者流たる会田安明が関流の学閥に反抗した真剣の争いであったと見たい。",
              "citation": {
                "source": "芸術と数学及び科学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "会田は山形の人、江戸に出て関流の数学を学ばんとしたが、覇気に富める彼は、関流の学閥に屈することができないで、藤田定資に対抗して一大論争を惹起するに至った。",
              "citation": {
                "source": "和算の社会的・芸術的特性について",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "会田の前には有馬頼算法』を公刊したこともあり、会田は関流の学閥に敵意をはさんでこれと争いつつ衆望を一身に集めることができて、その新流派ははなはだ栄えたばかりでなく、これから数学は著しく民間に普及するに至った。",
              "citation": {
                "source": "文化史上より見たる日本の数学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "研究室と研究室とは、二つの領主の領地と領地とのように対立し、外、学閥や時には閨閥のために尚武的攻主同盟を形成し内師弟関係の利害感情によって家庭的淳風を馴致している。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだその序文を私は見ないから、どういう点に氏の忿懣が集中されているか判らないのだが、助教授団や先輩団が、この問題をキッカケにして教授団攻撃や佐野善作学長の辞職勧告に進んで行く処を見ると、恐らく学閥とか学内セクト対立とかが、氏の私かに触れたい要点ではないかと想像される。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今は商大でも昔は高商さ」「しかしもうずっと以前に昇格しているんです」　と俊一君も学閥問題になると常にお父さんを遺憾に思っている。",
              "citation": {
                "source": "嫁取婿取",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
