        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "赤ん坊が、握ったおもちゃをがじがじと噛みしめている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "犬が、新しい骨を夢中でがじがじと噛み砕いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「痛い！ 歯がためをそんなにがじがじしないでよ！」と子供が訴えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼はストレスを感じると、無意識にペンをがじがじと噛む癖がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "慄える手に握られた彼の乳棒も、歯をすやすように、がじがじと気味悪く乳鉢の※面にすれていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一盞の葡萄酒が、圧し潰された彼の霊ををとろとろした酔いに誘って、がじがじした頭に仄かな火をつけてくれた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下足袋のうらには、じごくのようながじがじした、いやらしい蛇腹文様があって、土にくい込み、土を一どきにきざんでしまうからである。",
              "citation": {
                "source": "生涯の垣根",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその帰り道もおなじがじがじの雪を踏んで歩いた。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おばさま、其処の穴は欠け石でがじがじして危いったら。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "in constant pain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
