[
  {
    "uuid": "e2087cae-26d5-5c2d-ad6e-934f6fe5beb1",
    "entry": "賀表",
    "reading": {
      "primary": "がひょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "congratulatory card or letter sent to the Emperor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "信長は、朝倉退治のため、元亀元年四月、北陸の雪溶くるを待って、徳川家康と共に敦賀表に進発した。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにはまた、浦賀表へアメリカ船四｜艘、長崎表へオロシャ船四艘交易のため渡来したことが断わってあって、海岸｜防禦のためとも書き添えてある。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "公儀御目付役、戸川｜中務少輔様、松平｜十郎兵衛様、右御両人は異国船見届けのため、陣場見回り仰せ付けられ、六日夜浦賀表へ御出立にこれあり候。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それゃ君、泥棒猫だからさ」と小倉がひょうきんに答えた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、いったいがひょうきんなおじいさんのことですから、いつかこわいのも何も忘れてしまって、見世物でも見ている気で、おもしろがって鬼の踊りを見物していました。",
              "citation": {
                "source": "瘤とり",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきにドノバンがひょうにおそわれたとき、富士男は身をていしてドノバンを救うた、いまドノバンは、みずから傷ついて富士男を救うた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "みながひょうきんな叔父さんの顔を見て笑いました。",
              "citation": {
                "source": "二百十日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "同居の妹がひょうそうかなにかできて働けないからである。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "「十七歳と七カ月です」　田川さんがひょうきんな顔でいった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういった諭吉ですから、ある人が、諭吉のてがらをたたえて、政府がひょうしょうしなければならないといいますと、諭吉は、「とんでもない。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがひょうのおかげでその日はとうとう来たのだ。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽と歌にだけ様々な少女の気もちの表現を托していた伸子は、川辺みさ子がひょうそうで指をいためた間に、急速に小説にひかれて行った。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "遁走する蟹の大群の後方から、風がひょうひょうと音立てて吹きつけた。",
              "citation": {
                "source": "風宴",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "おせんは身を起こした、たぶん後架だろうと考え、そちらへ耳を澄ましていると、戸外のひどい風の音に気がついた、いつ吹きはじめたものかひじょうな烈風で、露次ぐちにある棗の枯枝や庇さきがひょうひょうとうめき、地震でゆるんだ雨戸や障子はもちろん、柱や梁までがみじめなほどきいきいと悲鳴をあげていた。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにひるんで、薛蘭が逃げ出してゆくと、曹操の陣後から、呂虔がひょうッと一箭を放った。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その時また、どこからか一本の矢がひょうッと飛んできた。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
