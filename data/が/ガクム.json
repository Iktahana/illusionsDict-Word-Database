    "definitions": [
      {
        "index": 1,
        "gloss": "school affairs",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学部長は、すべての学術的および管理上の学務の監督を担当している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "学生会は、様々な学生関連の学務の管理を支援している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この報告書は、過去の会計年度の主要な学務をまとめたものである。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「学校の学務に関する書類は終わった？」 「うん、学務はすべて最新の状態だよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "所が一日、予告もなく府庁の学務課から参観に来て、校長には二言三言だけ普通の話をして立去つた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ、おまえがあんまり痩せて行くもんだから学校の先生と学務委員たちの間で、あれは家庭で衛生の注意が足りないからだという話が持上ったのだよ。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が四十で浦和の学務部長をしていたときに私が生れて、あとにも先にも、子供といえば私ひとりだったので、父にも母にも、また周囲の者たちにも、ずいぶん大事にされました。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二博士が余の意見を当局に伝えたる結果として、同日午後に、余はまた福原専門学務局長の来訪を受けた。",
              "citation": {
                "source": "博士問題の成行",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外、当時の同級生には今の美術学校長正木直彦、専門学務局長の福原鐐二郎、外国語学校の水野繁太郎氏などがあって、それ等の人はなかなか出来る方であったが、私達遊び仲間の連中は総て不成績で、漸次、是等の諸氏と席の方が遠ざかるばかりであった。",
              "citation": {
                "source": "私の経過した学生時代",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の始めから町の学務委員と小学校の教員との間の相談で、早起の保健体操が校庭で行われることになったのでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の列は全くの大人で、その中にはこの催しの発起者である手前として学務委員も参加しています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "古着屋の娘は一学期出たきりで、ずっと学校を休んで薄暗い奥の部屋でねているのだが、父親が町内の有力者で、学務委員もしていた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹馬の友の万年博士は一躍専門学務局長という勅任官に跳上って肩で風を切る勢いであったから、公務も忙がしかったろうが、二人の間に何か衝突もあったらしく、緑雨の汚ない下宿屋には万年博士の姿が余り見えなかった。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "在郷軍人分会長、衛生部長、学務何々……と、肩書をもっているの旦那に会うと、村長や校長に会った時より、道をよけて、丁寧に挨拶した。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎が家を留守にしていたと云うのは、その頃県下の山間部に新しく開校された農学校へ、学務部からの指命を受けて学期末の一ヶ月を臨時の講師に出掛けていたのだった。",
              "citation": {
                "source": "寒の夜晴れ",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなかめんどうでしてな……昨夜の相談でもいろいろの話が出ましてな」こう言って笑って、「どうも村が小さくって、それでやかましい学務委員がいるから困りますよ」　校長は言葉をついで、「それで家のほうはどうするつもりです？",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "学務委員やら村長やら土地の有志者やら生徒の父兄やらがぞろぞろ来た。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで教員｜連は村長や学務委員といっしょに広い講堂にテーブルを集めて、役場から持って来た白の晒布をその上に敷いて、人数だけの椅子をそのまわりに寄せた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度は大高島の渡船の中で村の学務委員といっしょになった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "今では村会議員に学務委員を兼ねてゐる。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "『お戻しやれ、俺ア学務委員の一人として勧告しあんす。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "学年が進むと、級の日常生活は男女生徒の衛生委員、経済委員、学務委員、社会活動委員の活動によって実質的に進められてゆくようになるのだ。",
              "citation": {
                "source": "砂遊場からの同志",
                "author": "――ソヴェト同盟の共学について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "級全体が選挙して、文化委員、衛生委員、学務委員というものを何人かずつきめる。",
              "citation": {
                "source": "従妹への手紙",
                "author": "――「子供の家」の物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "文部省、内務省、知事、学務部長、視学、学校長等官僚体制が確立している。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他今の清浦子が県下の小学教員となり、県庁の学務課員となるにも、優の推薦が与って力があったとかで、「矢島先生｜奎吾」と書した尺牘数通が遺っている。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜松県の官吏は過半旧幕人で、薩長政府の文部省に対する反感があって、学務課長｜大江孝文の如きも、頗る保を冷遇した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "よんどころなく弁護士会長とか、市の学務委員とか、市参事会員とかにはなっていたが、恬淡な性質で、あばたがあるので菊石と号したりしたのを、小室｜信夫氏が、あまりおかしいから溪石にしろと言ったというふうな人柄だった。",
              "citation": {
                "source": "渡りきらぬ橋",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々や父兄は勿論のこと、学務課でも皆、非常に同情しているのだから……」　と赤ん坊を諭すように背中を撫でまわしたのであったが、しかし、そんな親切や同情が彼には、ちっとも通じないらしかった。",
              "citation": {
                "source": "木魂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "後方の席にいるはる子が、その時、「飯田さん、学務へ行ってきいて来なさいよ」　平静な、確信をもっている言調で云った。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日学務においてもっとも大切なることなれば、いささか余が所見を述ること左の如し。",
              "citation": {
                "source": "小学教育の事",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "授業時間問題のその後――コロンボ小学児童父兄会が朝の始業時間に関して、市学務課に陳情書を提出したことは本紙の昨夕刊が報道したとおりだが、同会実行委員はこれのみでは手ぬるしとなし、本日市庁に出頭口頭をもって、うんぬん。",
              "citation": {
                "source": "ヤトラカン・サミ博士の椅子",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、あたかも岩村氏の意に投じたので俄に抜擢されて十一等出仕の学務課勤務を命ぜられた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は、学務課長の肝付兼弘氏と、外に師範学校長の松本英忠氏及前にいった派駐訓導の一人を率いて出張する事になった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "この聯合教育会では、岡山県の学務課長加藤次郎氏というが洋行もした事があるというので、多くの人に知られていて最初の議長となった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
