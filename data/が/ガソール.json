        "examples": {
          "standard": [
            {
              "text": "地球温暖化対策として、ガソールの利用を推奨する動きが各国で見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "バイオマスから生成されるガソールは、持続可能な社会への貢献が期待されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この新型エンジンは、通常のガソリンだけでなくガソールでの運転も可能だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ガソールは、ガソリンと比べて環境への影響が少ないとされる代替燃料だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "フラウ・ゾルゲとハイマートとサンクト・ヨハニス・フォイエルとインガソールの文集とであつた。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
