        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ガチャリと硝子の壊れる音がして不意に冷たい手が私の両手を払い除けた……と思う間もなく眼を閉じた私の顔の上に烈しい接吻が乱れ落ちた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛声をかけたり、地謡を謡ったりしているうちに、翁の上顎の義歯が外れ落ちてガチャリと下歯にぶつかる事が度々であった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「衣笠山……ガチャリ。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "モグモグ……ムニャムニャ……面白の夜遊や……ガチャリ……モグモグ……ヨオチポポオポッポヨオイチョン……ホラホラしおりしおり……ガチャリ……モグモグ……ホオホオ」　といった調子であった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガチャリといふ音がして、板の間に倒れた時、ああ俺は人形だつたんだな――と気附いた。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからガチャリと皮革が垂れ下った。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番奥の解剖室の中で、ガチャリと金属の器具が触れ合う物音がした。",
              "citation": {
                "source": "俘囚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガチャリと鍵の音がした。",
              "citation": {
                "source": "俘囚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途端にジージーガチャリガチャリと機械の動き出す音が聞えだした、と思うと正面の鉄壁が真中から二つに割れ、静かに静かに左右へ開いていった。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして入口の錠をガチャリとかけ、その鍵を暗号金庫のなかに収った彼は自分の手がブルブル武者慄いをしているのに気がついた。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "△扉がガチャリとしまる音先生　えっへん一同、たちまちしーんと静粛になる（間）先生　（出席簿をバタバタ開けたりしめたりしながら）ああア皆さん。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」光線の関係で内部がよくは見えなかったのであろう、コトコトとノックする音が聞えたが、やがて焦立たしげにののしる声がきこえ、次に鍵がガチャリと鳴り、戸が開いた。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か聞いてみなければ心がすまないような気持で、ガチャリと鍵の音のした戸口に急いで戻って見た時には、もうコトコトと靴音が長い廊下の向うに消えかけていた。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は急ぎ机のところへ駈けよって、引出の鍵穴にガチャリと鍵をさしこむと、開いてみた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてピカピカ光る手術具をガチャリガチャリと音をさせながら、傷の手当に取懸った。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなところに変なものが……）とまでは聞えたが、そのあとはガチャリという音を残して、何も聞えなくなってしまった。",
              "citation": {
                "source": "人間灰",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガチャリ、ガチャリ、ゴーウウウ。",
              "citation": {
                "source": "空中墳墓",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうですか……ふん、ふん……さあ、それはどうもね……僕ですか、今行かれますよ、じやすぐ行きます」　彼はガチャリと受話機をおくと私の方に向きなおつた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうか、というのは社長、私の意思をお聞きなんですか」「そうだ」「それなら私は、始めたばかりのメディカルエレクトロニクスを続けさせていただきたいと思います」　小林はいかにも不気嫌そうな声で「そうか」とだけ答え、ガチャリと受話器を置いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に果物の籠の中でガチャリと音がした。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "魂のない風船娘にきまっているんだ」　吾輩がここで滔々と現代女性観を御披露しようとするところへ背後の扉がガチャリと開いて、思いもかけぬ警官が二人威儀を正して這入って来た。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "全速力で四五日分……」「……ヨシ……」　ガチャリと電話が切れたと思うと、やがて船腹を震撼する波濤の轟音が急に高まって来た。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "佩剣の※をガチャリと背後に廻して、悠々と白樺の林の外へ歩き出した。",
              "citation": {
                "source": "戦場",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガチャリガチャリと鳴る軍医大佐の佩剣の音をアテにして……。",
              "citation": {
                "source": "戦場",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
