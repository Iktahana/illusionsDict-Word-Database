      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "study",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は退職後、若い頃からの夢だった天文学の学問に静かに打ち込んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ただ知識を詰め込むだけでなく、それをどう社会に活かすかを考えるのが本当の学問だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "真理を探究するという学問の道は、決して平坦なものではない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "そこでその現状が、仮りに不安な現状であらうとあるまいと、学問、芸術の興隆に適してゐようとゐまいと、所詮致し方もないことである。",
              "citation": {
                "source": "山羊の言",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、学問にも世間常識にも煩はされてはゐない。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あなた学問ある時、私この本書けません。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた学問ない時、私書けました』と言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭はわるし、文章は下手、学問は無し、すべてに無器用、熊の手さながら、おまけに醜貌、たった一つの取り柄は、からだの丈夫なところだけであった。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を言ふかといふと形容詞的な余りに形容詞的なことか、それとも学問的な余りに学問的なことなのである。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "認識とは、元来、現識過剰に堪られなくなつて発生したとも考へられるもので、その認識を整理するのが、学問である。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に、芸術は、学問では猶更ない。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し学問を厭ふことが、何も芸術家の誉れでもない。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "学問なぞは、人が芸術家であれば、耳学問で十分間に合ふやうになつてゐる。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "認識対象が、実質的に掴めてゐれば、それに名辞や整頓を与へた学問なぞは、例へば本で云へば目次を見たりインデックスを見たりするだけで分る。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「道理は道理、学問は学問。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺小屋育ちの祖母には、中学の学問と言ふものが、非常な大した物と思はれるのであつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして母達には中学の学問その儘の延長が全ての学識だと思つてゐたのだ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局先生自身がその学問の奥底まではっきり突きとめて自分のものにしてしまっているせいだろうと思われた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ病気で身体が弱くなって、学問など出来ぬようになれば、それだけ自分の夢みているような無為の生涯に近づくのではあるまいかと考えたりした。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の才能もないし、学問もないし、社会人類、国家に尽す方法も持たないし、詰り人生の食ひ潰しであることを自認したのだつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "元は公卿の出ですが、子供の時から三要の手元に引取られて、坐禅学問を勉強しながら、高貴の客があるときには接待の給仕に出ます。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "教春の一人娘｜早百合姫は三年前、京都の戦禍がやや鎮まっていたとき、京都｜滞陣の父の館に呼び寄せられ、まだ十四｜歳の少女であったが、以来日々、茶の湯、学問、舞、鼓など師匠を取って勉強していました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「折角の学問の才を切れ端にして使い散らさないように――」　と始終忠告していた父が、その実意からしても死ぬ少し前、主人を養子に引取って永年苦心の蒐集品と、助手の私を主人に譲ったのは道理である。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は大学を出ると美術工芸学校やその他二三の勤め先が出来た上、類の少ない学問筋なので何やかや世間から相談をかけられることも多く、忙しいまま、東海道行きは、間もなく中絶してしまった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の能力を計らないで六かしい学問に志していっぱしの騎士になったつもりで武者修行に出かけて、そうしてつまらない問題ととっ組み合って怪物のつもりでただの羊を仕とめてみたり、風車に突きかかって空中に釣り上げられるような目に会ったことはなかったかどうか、そんなことを考えない訳にはゆかなかった。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人が学校で学問を教わるのは丁度このようなものである。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故にこの疑問を解くことは我国の学問の正常な発達のために緊要なことではないかと思われるのである。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、一番始末のいい場合は、学問の本山であるところの西洋の第一流の大家達の統括の下に開拓され発達させられた一つの明確な区劃内に限られた部門の中で、かの地の誰やかれが既にかなりまでつつき廻した問題の一方面に若干の確実な貢献をしたというような種類の仕事が学位論文として提出された場合である。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらはないが何の取り柄もない論文は百あっても学問は進まないであろう。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "学位を狙う動機がたとえ私利や栄達のためであろうが、ともかくも我邦で一人でも多く学問の研究に志し従事する人が多ければそれだけ我邦の学術は発達を刺戟される。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "水沢瀉、えご、夜這蔓、山牛蒡、つる草、蓬、蛇苺、あけびの蔓、がくもんじ（天王草）その他田の草取る時の邪魔ものは、私なぞの記憶しきれないほど有る。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「千菊さまが　これから　うんと　がくもんして、えらい人に　なったら、きっと　お母さまが　あいにきて　くださります。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、大よろこびで、「しゅうけん、これからも　よくよく　がくもん　して　りっぱな　そうりょに　なれよ。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
