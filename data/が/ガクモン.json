[
  {
    "uuid": "a65d7add-8446-5714-91e4-034da870e8f2",
    "entry": "学問",
    "reading": {
      "primary": "がくもん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
