    "definitions": [
      {
        "index": 1,
        "gloss": "with a bang",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鳴く間がたんだん迫って来たのである。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓがたんせいして世話したおかげで無事に三冬を越したのが三尾いた。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はびっくりして、互によりそって、扉をがたんと開けて、次の室へ入って行きました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とつぜん、右手のシグナルばしらが、がたんとからだをゆすぶって、上の白い横木を斜めに下の方へぶらさげました。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "数字がたんなる数字ではなくなった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "厳めしく道庁や鉄道管理局や区役所の役人が見て居る前で、少し型の変つた荷馬車が、わざと造つた障害物をがたん／＼音を立てながら動いて行くのは、面白くも何ともなかつたけれども、久し振りで野原に出て学校友達と心置きなく遊ぶのは、近頃にない保養だつた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と叫んで、飛上ると、蜜柑の空箱を見事に一個、がた、がたんと引転覆して、松小僧は帳場口へどんと退って、「女房さん！",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はびつくりして、互によりそつて、扉をがたんと開けて、次の室へ入つて行きました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とつぜん、右手のシグナルばしらが、がたんとからだをゆすぶつて、上の白い横木を斜めに下の方へぶらさげました。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今時バアで醉拂つて、タクシイに蹌踉け込んで、いや、どツこいと腰を入れると、がた、がたんと搖れるから、脚を蟇の如く踏張つて――上等のは知らない――屋根が低いから屈み腰に眼を据ゑて、首を虎に振るのとは圖が違ふ。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根をはがれたトタン板と、屋根板が、がたん、ばり／＼と、競を追つたり、入りみだれたり、ぐる／＼と、踊り燥ぐと、石瓦こそ飛ばないが、狼藉とした罐詰のあき殼が、カラカランと、水鷄が鐵棒をひくやうに、雨戸もたゝけば、溝端を突駛る。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中には、かれらの兄らしい青年がたんぽ槍を掻い込んでいるのもあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い煉瓦造りの壁面を蔦蔓がたんねんに這い繁ってしまっている。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとは大阪堂島の、相当戸前も張つて居る商家のお家はんであつたのを、秋成がその店を引受けてから急に左り前になつたその衰運をまともにつきあひ、わびしいめに堪へながら、秋成がやつとありついた医業にいくらか栄えが来て、楽隠居にして貰つたところで、また、がたんと貧乏｜住居に堕ちたのだつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の老若男女の乗客があっけにとられて見ている中で、大声でわめいて互いに揖譲して終らぬうちに、がたんと車体が動くと同時に、その一団は折りかさなって倒れる。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東坡巾先生は味噌は携えていなくって、君がたんと持って来たろうと思っていたといって自分に出させた。",
              "citation": {
                "source": "野道",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　がた、がたんと音がする。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――やがてだわね、大きな樹の下の、畷から入口の、牛小屋だが、厩だかで、がたんがたん、騒しい音がしました。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐらり、がたがたん。",
              "citation": {
                "source": "城崎を憶ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、それは黒鬼のしたことか、それとも風のせいか、その窓のがらす戸がふいにがたんとはねあきました。",
              "citation": {
                "source": "一本足の兵隊",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも善い事ならいいが、ろくでもねえところなんだから、堪らねえ」　鴉と田螺　麗かな春の日永を、穴から這ひだした田螺がたんぼで晝寢をしてゐました。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人はその跡を見送って、「あいつの云う通り、僕は厭世気違いやも知れんけど、僕のは女房の器量がようて（奥でくすッと笑う声がした）、子供がかしこうて、金がたんとあって、寝ておられさえすれば直る気違いや。",
              "citation": {
                "source": "戦話",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　紀久子はがたんと銃を取り落とした。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が指でそれをぐつと推した時不思議や棺の横はがたんと下へ下りた。",
              "citation": {
                "source": "殺人行者",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "）勢に乗じて、妹は縁の真正面へ、蚊帳の黒雲を分けたように、乳を白く立ったのですが、ごろごろごろ、がたん。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "片輪車の変化が通るようで、そのがたんと門にすれた時は、鬼が乗込む気勢がしました。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから直治がお母さまとお二人で水いらずで暮して、そうして直治がたんとたんと親孝行をするといい。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
