        "examples": {
          "standard": [
            {
              "text": "定期健診で眼底検査を受けたが、幸いにも特に問題はなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "糖尿病の合併症がないかを確認するため、医師は眼底検査を勧めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この病気は初期段階では自覚症状がないため、定期的な眼底検査が重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "さて、私は、外来診察所から廻されて来た件の女患者に病室を与え、附添の看護婦を選定した後、視力検査を行い、次に眼底検査を行うために彼女を暗室に連れて行きました。",
              "citation": {
                "source": "痴人の復讐",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            }
          ]
        }
