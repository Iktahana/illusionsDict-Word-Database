        "examples": {
          "standard": [
            {
              "text": "会議が白熱し、途中から意見がぶつかり合ってがちゃつき始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "イベントの準備が遅れ、スタッフが慌ただしく動き回りがちゃついている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "突然の来客に、部屋の片付けもそこそこに家の中ががちゃついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の発表は、専門用語ばかりで内容ががちゃついていて理解しにくかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
