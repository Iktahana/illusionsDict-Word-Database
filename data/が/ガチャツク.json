        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供が玩具で遊んでいると、時々床に落としてがちゃつかせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い洗濯機は、脱水時にガタガタとがちゃついてうるさい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は鍵を探しながら、ポケットの中の小銭をがちゃつかせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "△洋服をぬぎ、洋服かけがちゃつく。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "重い扉の開いたり閉じたりする音、鉄の閂や海老錠のきしる音、看守の帯にさがってる鍵束のがちゃつく音、階段の上から下まであわただしい足音、長い廊下の両端から互いに呼び合い答え合う声、などが聞こえた。",
              "citation": {
                "source": "死刑囚最後の日",
                "author": "LE DERNIER JOUR D'UN CONDAMNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
