        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "足音と語ががんがん反響してやって来た。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――食べなんしたことががんすのかいの」「食べるけど、あれは厄介なばかりでしかたがないや」「おいしいものですけれどね」「それはうもうがんすえの。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はまたまた苦しくなって、頭ががんがん痛んで来ます。",
              "citation": {
                "source": "指輪一つ",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "南は頭ががんとなって気を失った。",
              "citation": {
                "source": "竇氏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるときはその象牙のはしから話しかけてみると、なるほど下女のいうごとく、かれががんじょうな顔にしろりと笑いを動かした。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの娘を貰うては……」　お菊は眼が眩みそうになって、耳ががんがん鳴って来た。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、妙なやつががんくびを並べているね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "うれしがって金だらいまでががんがん鳴ってらあ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾の全身の血液は一度に頭へ上がって、頭ががんがんしてきた。",
              "citation": {
                "source": "オパール色の手紙",
                "author": "――ある女の日記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（思慮ある人々でも私のような軽率なことをしたとして）私はこれまでに読んだ小説や新聞種の中から、私の場合に似たような三角関係の例を思い出そうとしたが、頭ががんがんして何も思い出せなかった。",
              "citation": {
                "source": "秘密",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "掘りはじめは不成績であったので放棄する意見が技術委員会の大半を占めた、その時、数人の若い連中ががんばって遂にこんなに豊富な源泉に当った。",
              "citation": {
                "source": "石油の都バクーへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、何だか藤村においては都会の小市民的なもの（教養）の底から根づよい中農性ががんばり、顔を出しているように思います。",
              "citation": {
                "source": "「夜明け前」についての私信",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "数秒間そうしているうち突然に耳ががんと鳴って、頸筋を強か打たれたと思ったら、それっきり気絶してしまいました。",
              "citation": {
                "source": "十時五十分の急行",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "よけい頭ががんがんと痛むし、咽喉がつまつたやうでいくら咳いても痰が容易に切れない。",
              "citation": {
                "source": "現代詩",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、セリファンをやって門を探させたが、もしこれが門番がわりに猛犬ががんばっていて、思わず指で耳に栓をしなければならないほどワンワンと人の来た時に吠えたてるロシアでなかったなら、彼は屹度いい加減手間どったに違いない。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻もちもならぬほど、貧民を軽蔑し、無学文盲をあなどりたい為に、いろんな規則ががんじがらめに製造される。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "君がここでそうやって一人でがんばって見たところで、外の同志達はどうせ君ががんばろうなんぞとは思ってやしないんだから。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケプナラ、ザンベック両君に避難しろって」「ああ、あんなこと」と、おのぶサンはケロッとして、「あたし、なんだか忘れてしまったらしいよ」「馬鹿っ」と怒気心頭に発した折竹ががんと一つ殴りつけ、「なんのために……。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま『太平洋漏水孔』中にある独逸人キューネより――とあります」　太平洋漏水孔――たった一字だががんと殴られた感じだ。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで訳がわからんね」「泥棒かしら……」「まさか」　納屋の二階を見上げて、ひそひそ話し合っていると、突然ゲンのけたたましい吠え声――、続いて誰かが床板に叩きつけられる様な音にまじって、鋭い怒声罵声ががんがん響き、えらい騒ぎになって来た。",
              "citation": {
                "source": "睡魔",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道頓堀の櫓々にはまだ、数人の仕打ちががん張つてゐて、三栄・大清の対抗時代は過ぎても尼野・高木・尾張屋等の競争が、五つの櫓を、ともかくも空ける事なく、多くの役者をとり捌いてゐた時代はよかつた。",
              "citation": {
                "source": "街衢の戦死者",
                "author": "――中村魁車を誄す――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、中にはたくさんの機械人間ががんばっていて、警官隊を中に入れまいとした。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、頭がきりきり痛み、そして耳ががんがん鳴りだした。",
              "citation": {
                "source": "氷河期の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが悪戯が、己れと掛け離れた別人の頭の上に落した迷惑はともかくも、この迷惑が反響して自分の頭ががんと鳴るのが気味が悪い。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "果ては口々に自分勝手な唄を喚きながら、台所から持ち出されたバケツががんがんと叩かれるのであつた。",
              "citation": {
                "source": "盂蘭盆",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、思はず大声をあげました、しかし、海の底にひとりゐて、潜水｜兜をかぶつてゐるのですから、誰に聞える筈もなく、只自分の耳ががん／＼鳴つただけです。",
              "citation": {
                "source": "動く海底",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、叫びますと、耳ががん／＼鳴つて、目がくら／＼して、気が遠くなつてしまひました。",
              "citation": {
                "source": "動く海底",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここをよく考えてください」メリー号の人たち　事務長クーパーの船室には、三人の男ががんばっていた。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、操縦室には三根夫ががんばっていますよ。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
