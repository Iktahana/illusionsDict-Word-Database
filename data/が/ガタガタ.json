        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ガタガタ／＼トラックの荷物の中に挟まつて揺られながら、僕は久々で午前の西武電車の沿線といふものを眺めたのだ。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "温室の中からガタガタと下駄の音を立てて、田舎のばあさんたちが四五人、きつねにつままれたような顔をして出て来る。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして卓をガタガタゆすってゐた。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　進藤、ガタガタ震え出す。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "）寒くてガタガタする。",
              "citation": {
                "source": "柳沢",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若僧はそこらに何かしているのだろう、しばらくは消息も絶えたが、やがてガタガタいう音をさせた。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　狐がガタガタ顫へながら云ひました。",
              "citation": {
                "source": "月夜のけだもの",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれが悪魔の聖書とでもいったものでしょうか……これこそ世界中にタッタ一冊しかないと噂に聞いたシュレーカーのＢＯＯＫ　ＯＦ　ＤＥＶＩＬ　ＰＲＡＹＥＲ（外道祈祷書）かと思うと私は気が遠くなって、真夏の日中にガタガタ震え出したものでげす。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は眉香子の中でガタガタと震え出した。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐怖の眼をマン丸く、真白くなるほど見開いて、窓の外の光明を凝視したまま、顎をガタガタと鳴らし始めた。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう夜が明けておるのに……バ……バ……バケモノとは……」　方丈の明障子をガタガタと押開けて大兵肥満の和尚が顔を突出したが、これも見かけに似合わぬ臆病者らしく、早や顔色を失って、眼の球をキョロキョロさせていた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝、早よう……孫の墓へ参りました帰り途に、裏通りを近道して、祇園町へ帰ろうと致しましたれば……あ……あの桃の花の上がっておりまする、蔵元屋の……お墓の前で……」　すこし落着きかけた婆さんの歯抜け※が又もガタガタ言い出した。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頬冠りの蔭の物凄い眼付を見ると和尚が又もやガタガタ震え出した。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした門構えを入ると、本堂の阿弥陀様と背中合わせの板敷土間に破れ畳の二畳敷、竹瓦葺の板廂、ガタガタ雨戸に破れ障子の三方仕切は、さながらに村芝居の道具立をそのまま。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "すたれ釘世をすぢかいになり下る　　　　　　　　底抜け徳利のチリンカラカラ古釘と底抜け徳利の風鈴は　　　　　　　　　　阿弥陀も知らぬ極楽の音　その蒲鉾板の裏表を手に取って引っくり返して見ながらニッコリと笑った良助は、その前の雨戸をガタガタと叩いた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "博多の町の南の出外れ、万延寺の本堂と背中合わせの竹瓦に板庇、板敷土間に破れ畳二枚、ガタガタ雨戸の嵌め外しがやはり二枚という、乞食小舎の豪華版から、墓原越しに見晴らす筑紫野は、これも晩春の豪華版であろう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガタガタ慄へながら下宿に帰つて、大急ぎで服を脱いで、十五分もボンやりと部屋の真ン中で煙草を吹かしてゐると、電報が来た。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひばりの子は草の上に倒れて、目を白くしてガタガタ顫えています。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥箱先生も、今度といふ今度は、すっかり怒ってしまって、ガタガタガタガタふるへて叫びました。",
              "citation": {
                "source": "鳥箱先生とフウねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねずみ捕りの方も、痛いやら、しゃくにさわるやら、ガタガタ、ブルブル、リュウリュウとふるえました。",
              "citation": {
                "source": "ツェねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その人は興奮の為にガタガタふるえてそれからやけに水をのみました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "シグナルはぎょっとしたように胸を張って、しばらく考えていましたが、やがてガタガタふるえだしました。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "シグナルはもううれしくて、うれしくて、なおさらガタガタガタガタふるえました。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネネムは小さなマミミとただ二人、寒さと飢えとにガタガタふるえて居りました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ありがとう」雨の音で消されてしまうくらいの小さな声で言って、娘は飛びつくように、レインコートにくるまってしまうと、ほっとしたようだったが、しかし、なお恐怖の去らぬらしい険しい表情を、眉に見せて、「…………」　小沢にすがりついて、ガタガタ顫えていた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
