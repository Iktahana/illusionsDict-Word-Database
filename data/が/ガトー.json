        "examples": {
          "standard": [
            {
              "text": "記念日に、彼女が焼いてくれたチョコレートのガトーは最高の味だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この店は季節ごとに限定のガトーを出すので、いつもチェックしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "フランスの伝統的なガトーは、見た目も美しくて食べるのがもったいないくらいだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "クリスマスの食卓には、豪華なガトーが欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "バタを、ふんだんに使った、ガトーの味は、リッチな感じで、贅沢なものだった。",
              "citation": {
                "source": "甘話休題",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
