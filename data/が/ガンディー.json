        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ガンディーの非暴力不服従運動は、世界中の人々に深い影響を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ガンディーの平和へのメッセージは、今なお多くの人々に引用されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "歴史の授業で、ガンディーの生涯とその思想について詳しく学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ガンディーみたいに、争いのない世界を目指す人になりたいな。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "なかに、ホテルについて、マジェスティックが東洋第一といいながら、ボルト酒のよいのを持たない、「長崎のジャパン・ホテルにだって一九一一年のブルガンディー酒があるくらいだのに」云々とある。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルガンディーの王、グンテルの妹である。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガンジーと藤井の思想的交流については、例えば外川昌彦「ガンディーと共に暮らす」（http://repository.dl.itc.u-tokyo.ac.jp/dspace/bitstream/2261/43635/1/ioc159010.pdf）で触れられています。",
              "citation": {
                "source": "日本の全ての方々へ",
                "author": "マハトマ・ガンジー　Mahatma Gandhi",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃でこそ一般の日本の婦人が、オルガンディーやジョウゼットや、コットン・ボイルや、ああ云うものを単衣に仕立てることがポツポツ流行って来ましたけれども、あれに始めて目をつけたものは私たちではなかったでしょうか。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
