    "definitions": [
      {
        "index": 1,
        "gloss": "glass door",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "縁側のガラス戸を開けると、庭の緑が目に飛び込んできた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔ながらの日本家屋では、障子の代わりにガラス戸が使われることも増えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "夕暮れ時、ガラス戸に映る自分の姿を見ながら、今日一日を振り返った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "台風が近づいているので、窓やガラス戸をしっかりと閉めておく必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "しやうふを塗れるガラス戸を、　　学童らこもごもにのぞきたり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう夜を呼ぶばかりの凩に耳を澄ましていると、ある時はまだ電気も来ないどこか遠くでガラス戸の摧け落ちる音がしていた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしただ書棚の中に並んでいる書物の名をガラス戸越しにながめるだけでも自分には決して無意味ではなかった、ただそれだけで一種の興奮を感じ刺激と鞭撻を感ずるのであった。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして棚のガラス戸におぼろげに映る自分の顔をひそかに注意して見た事もある。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このつかまえにくい頭としっぽをつかまえようというのではないが、世間にうとい一学究の書斎のガラス戸の中からながめたこの不思議な現象のスケッチを心覚えに書きとめておこうというのである。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "重いガラス戸をあけて中へはいりますと、おじさんがひとり、たたみのしいてあるところに、あおむけにひっくり返って、新聞を読んでいました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきは、入口のガラス戸の下までさしていた日ざしが、いまは、上の方に忘れられたように、ほんのすこしのこっているだけです。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから私は、鏡に映ってゐる海の中のやうな、青い室の黒く透明なガラス戸の向ふで、赤い昔の印度を偲ばせるやうな火が燃されてゐるのを見ました。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき風がどうと吹いて来て教室のガラス戸はみんながたがた鳴り、学校のうしろの山の萱や栗の木はみんな変に青じろくなってゆれ、教室のなかのこどもはなんだかにやっとわらってすこしうごいたようでした。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「月」は毎句にあり、「ガラス戸」が六、「鳥かごの屋根」と「森」と「ランプ」が各二あるが、そのほかにもいろいろの景物が点綴され、ほととぎすや白雲や汽車やブリキや紙や杉木立ちやそういうものの実感が少しずつ印象され、また動作や感覚の上でもだいぶ変化が見えている。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから私は、鏡に映っている海の中のような、青い室の黒く透明なガラス戸の向うで、赤い昔の印度を偲ばせるような火が燃されているのを見ました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "卓の上には地球儀がおいてありましたしうしろのガラス戸棚には鶏の骨格やそれからいろいろのわなの標本、剥製の狼や、さまざまの鉄砲の上手に泥でこしらえた模型、猟師のかぶるみの帽子、鳥打帽から何から何まですべて狐の初等教育に必要なくらいのものはみんな備えつけられていました。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき校長室のガラス戸棚の中に入っていた、わなの標本を五つとも持って来たのです。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長はだまってそれをガラス戸棚にしまいました。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兩人の裾の所が、床の間横、一間に三尺、張だしの半戸だな、下が床張り、突當りがガラス戸の掃だし窓で、そこが裏山に向つたから、丁どその窓へ、松の立樹の――二階だから――幹がすく／＼と並んでゐる。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして再び窓ぎわにかけ寄ってガラス戸を押し開いてみた時には、もはや、戸外の闇の中には何ものの気はいもありませんでした。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、この前のクリスマスのときに、お金持の商人の家で、ガラス戸ごしに見たのよりも、ずっと大きくて、ずっとりっぱに飾りたててありました。",
              "citation": {
                "source": "マッチ売りの少女",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下のガラス戸から朝日がさし込み、障子をあかるくしている。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手のガラス戸から、斜陽がさし込んでいる。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下のガラス戸から海が見える。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "野中教師ゆっくり教壇から降り、下手のガラス戸に寄り添って外を眺める。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "（菊代のほうに向き直り、ガラス戸に背をもたせかけ、笑いながら冗談みたいな口調で）めぐり来れる春も、このくたびれ切った枯葉たちには、無意味だ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下のガラス戸越しに、空を眺めても、星一つ無かった。",
              "citation": {
                "source": "故郷",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いけない、と思つて入口のガラス戸に走り寄つたら、果して、その戸に小さい南京錠が、ぴちりとかかつてゐるのである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "他のガラス戸にも手をかけてみたが、いづれも固くしまつてゐる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、ガラス戸をたたき、越野さん、越野さん、と呼んでみたが、もとより返事のある筈は無かつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と勇気百倍、グワラリといふ品の悪い形容でも使はなければ間に合はないほど勢ひ込んでガラス戸を押しあげ、「ごめん下さい、ごめん下さい。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ、このように働くのを自分の運命だと、君枝はなにか諦めていたようだったが、けれどただひとつ、昼間客のすくない時の退屈さは、なんとも覚えのない悲しさで、ガラス戸越しに表通りを見るともなく見て、無気力な欠伸をはきだしていると、泣きたくなった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、いつかしくしく泣きながら居眠ってしまうのだが、そんな時いつも起してくれるのは、ガラス戸の隙間にシュッと投げ込まれる夕刊の音だった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "透明なかげを投げあっているガラスどもの上に、十月下旬の午後の光線がさしていた。",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
