[
  {
    "uuid": "2053b8aa-00d2-5c9e-b554-076ef0c986bc",
    "entry": "画聖",
    "reading": {
      "primary": "がせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
