    "definitions": [
      {
        "index": 1,
        "gloss": "wife's mother",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "妻の母親である私の岳母が来週、私たちを訪ねてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "岳母に初めて会うときは、いつも少し緊張する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供が小さかった頃、岳母が育児を手伝ってくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「お母さん、お母さんのお母さんと最近話した？」 「うん、昨日は岳母と話したよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "孔生は岳母の死を悼み、また嬌娜の結婚を悦んだ。",
              "citation": {
                "source": "嬌娜",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この寺の先々住の日照というが椿岳の岳母榎本氏の出であったので、俗縁の関係上、明治十七、八年ごろ本堂が落成した時、椿岳は頼まれて本堂の格天井の画を描いた。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　次に「大下の岳母樣」が亡くなつたと聞いたのに、弔書を遣らなかつたわびが言つてある。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "大下の岳母が何人かと云ふことは、棠園さんに問うて知ることが出來た。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ための父｜即ち堂の岳母は蘆庵の妻すなである。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて大下の岳母すなは文政十年九月十二日に沒した。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "どびんのふたのように、一方がくぼんでいる。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "長寿の印しといわれる、長くぴんと突き出た眉の下に、大きい眼がくぼんでいる。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "髭がぼうぼうと生えて、眼がくぼんでいる。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今夜はＨさん、貴方が大変すきですの、どうしてか知らないけれ共――でももうねましょう、これよりおきてると私はあした目がくぼんでしまいますもの……」「それじゃねましょう、阿母さんを起してやさしくして御あげなさいよ、サ」　千世子はいい気持そうにして居る母親をおこして寝室につれて行った。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は尖った顔の中でそれだけがくぼんでいる目を大きく見開いたが、全然そこには情熱もなく、物を云う目でもなかった。",
              "citation": {
                "source": "牛",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒョロ長い痩せた男で、毛髪が赤く、鼻が高く、眼がくぼみ、まるで混血児のやうだつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼窩がくぼんで蔭をなしている。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日まで生きいきと輝いていたお顔が、一日の内にすっかり肉が落ちて、目がくぼんできた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第六巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女らは頬がくぼみ、唇と頬骨とがつき出て、ダ・ヴィンチ式のしかも多少卑しい微笑を浮かべ、その粗雑な話し方と激しい笑いとは、穏やかなおりの顔の調和を不幸にも常に破っていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "目がくぼみ色が青ざめていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "痩せて――眼がくぼんで――日に焦けて、すっかり変ってしまったが、その石曳きは、本位田又八だった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "老執事はジョージ卿より取り乱していなかったが、目がくぼみ憔悴しており、明らかに寝ていない。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
