    "definitions": [
      {
        "index": 1,
        "gloss": "history of diplomacy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
