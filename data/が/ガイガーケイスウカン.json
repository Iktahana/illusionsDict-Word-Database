        "examples": {
          "standard": [
            {
              "text": "実験室にあるガイガー計数管は、微量の放射性物質も検知できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は古い放射線探知機からガイガー計数管を取り出して、修理を試みた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このガイガー計数管、ちょっと調子悪いみたいだね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ガイガー計数管の仕組みを学んで、放射線の検出原理を理解した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "私もガイガー計数管を信用して大いに食っているのである。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「水上氏とあなたが、千九百四十九年のウラニウム・ラッシュにうかされて、ガイガー計数管を持って、カナダの国境に近いほうへ出かけて行ったところから、はじまっています」　坂田は、手をあげて、冷淡にさえぎった。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
