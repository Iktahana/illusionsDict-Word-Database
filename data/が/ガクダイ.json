    "definitions": [
      {
        "index": 1,
        "gloss": "Tokyo Gakugei University (abbr.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私の兄は、学大の教育学部に通っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "学大出身の先生は、教育実習の指導がとても丁寧だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "学大のキャンパスは緑豊かで、散歩するだけでも気持ちいい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "三月九日帰朝早々から風邪を引き、軽い肺気腫の兆候があるというので大事を取って休養していたが、一度快くなって、四月五日の工学大会に顔を出したが、その翌日の六日の早朝から急性肺炎の症状を発して療養効なく九日の夕方に永眠した。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい二十世紀の文明国と名乗る国がらからすれば、内閣に一人や二人のしかるべき科学大臣がいてもよさそうであり、国防最高幹部にすぐれた科学者参謀の三四人がいても悪いことはなさそうに思えるのであるが、これも畢竟は世の中を知らぬ老学究の机上の空想に過ぎないのかもしれない。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはどこかの化学大学校を出た方ですね。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「面白い小説を書こうとしていたのはわれわれの間違いでした」と大衆文学の作者がある座談会で純文学の作家に告白したそうだが、純文学大衆文学を通じて、果して日本の文学に「アラビヤン・ナイト」や「デカメロン」を以てはじまる小説本来の面白さがあったとでもいうのか。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦乱｜罷んで泰平の来る時、文運は必らず暢達すべき理由あり、然れども其理由を外にして徳川時代の初期を視る時は、一方に於て実用の文学大に奨励せらるゝ間に、他方に於ては単に快楽の目的に応じたる文学の勃として興起したるを視るべし。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "碩学大儒の哲学者王たるべきが如く、批評家王たるべきものもあろう。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "近世欧米で民俗学大いに起こり、政府も箇人も熱心にこれに従事し、英国では昨年の政事始めに、斯学の大家ゴム氏に特に授爵されたり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八世紀の仏国植物学大家ジュシューいわく、いわゆる植物羔とは羊歯の一種でリンナースが学名をポジウム・バロメツと附けた。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説家の文学者先生、荒尾角也｜此咄を聞くと大喜びで、何が扨て文学大好きの嬢様なれば文壇にたづさはる自分は必定御覚え目出たかるべしと早合点した。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "よいよい、信徒を荒し霊地を荒す鼠賊めを、霊地を預かり信徒を預かる院代が匿もうて、五万石の寺格が立つと申さるるならば、久方ぶりに篠崎流の軍学大出し致してつかわそうぞ。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　批評壇の問題　形式主義の問題が一段落をつげ、プロレタリア文学大衆化の問題がうやむやに葬られ、今年は、批評界では、いわゆる、政治的価値と芸術的価値の問題が最も活発に論じられた。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の仕事は、星学大系といふ出版物の一部分であつた。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「星学大系」の翻訳を、夏のうちに片づけて、矢張り皆なと一処に間もなく新しい生活を目指して東京へ出発する筈だつたから――。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "村井の「南方の騎士」にしろ、滝本の「星学大系」にしろ相当の報酬が得られる筈なんだから、もう隠退することに決めたラツキイを今更レースになんて出さない方が好からうと皆なが忠告するのも諾かず武一は、堀口や篠谷達への手前にも、何うしてもラツキーを勝たさずには置かない――と無闇に躍起となつてゐるのであつた。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "『放送された遺言』は、僕の書いた科学小説の第二作であって、昭和二年「無線電話」という雑誌に自ら主唱し、友人｜槙尾赤霧と早苗千秋とに協力を求めて、三人して「科学大衆文芸」というものを興したが、そのときに書いたものである。",
              "citation": {
                "source": "『地球盗難』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも勿論、同誌の科学大衆文芸欄に出たものである。",
              "citation": {
                "source": "『地球盗難』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（日本近代文学館・小田切進編、講談社発行「日本近代文学大辞典」昭和53年１月18日第三刷を参照した。",
              "citation": {
                "source": "風狂私語",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ずおんみ自身を知れ――運命判断で将来の行路を定めようとする方は、ブダペストの星占学大家ホフマン教授を訪問して下さい。",
              "citation": {
                "source": "生きている戦死者",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユーザーに迫られ、サードパーティーに押し上げられ、東京電機大学の安田寿明や東京大学大型計算機センターの石田晴久らのパソコンイデオローグたちにあおられ、いや何よりも一つの革命が進行しつつあるのだという自らの直観を信じて、渡辺たちは目の色を変えていたのである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この選択によって彼は、ベトナムに送られる代わりシリコンバレー近くの海軍大学大学院でコンピューターを教えながら研究を続ける道を確保した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆者は、当時東京大学大型計算機センターの助教授だった石田晴久。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京大学大型計算機センター助教授の石田晴久は、『ＰＣＣ』が呼びかけた当初から、タイニーベーシックの手作り運動を興味深く見守っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "のちに東京大学大型計算機センターの石田晴久によって翻訳される、デニス・リッチーとブライアン・カーニハンの『プログラミング言語Ｃ』という本が存在していることを知り、日本橋を探し回った挙げ句見つけられずに、結局アメリカから取り寄せた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "……然るにだ……ここで吾輩の脳髄探偵小説は、こうした世界的の大勢を横眼に白眼んだ一人の青年名探偵、兼、古今未曾有式超特急の脳髄学大博士を飛び出させているのだ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこの三箇条の加入規約は、人間の全身三十兆の細胞が、祖先伝来の不文律として、非常識なほど極端に遵奉しているものであるが、しかもこの簡単な三箇条が呑み込めさえすれば、諸君はモウ立派な一人前の、押しも押されもせぬ脳髄学大博士になれるのだ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何千年か昔のことでもあり、また、昨日、いや、毎日の出来事でもある天文と、観測と、碩学大家どもと、彼らの白髪と白髯は、豪雨と、暴風の、鳥獣の苦悶と、人民の失望と、日光の動揺と植物の戦慄と、鉱石の平伏といっしょに、宇宙へ四散した。",
              "citation": {
                "source": "ヤトラカン・サミ博士の椅子",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "（終り）底本『大衆文学大系12』一九七二年三月　講談社刊",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から三十年前、物理学者は、このような機械が、将来必ず出現するだろうと、理論のうえから推理をして、一部の世人を愕かしたものだが、それ以来、わが国では、新体制下の科学大動員によって、極秘に研究をつづけ、そしてようやく五年前、その最初の機械を試作したのであった。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなわけで、ブラウンはすばらしい早さで飛び起きて、服の中へ飛びこむようにして、例の大きなゴツゴツのこうもり傘をつかむと、大急ぎで往来に出た……わびしい真白な朝霧がくだいた氷のようにとぎれ勝ちに目の前の巨大な黒いビルディングのまわりにただよつていた。",
              "citation": {
                "source": "ピンの先き",
                "author": "THE POINT OF A PIN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
