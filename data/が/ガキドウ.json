    "definitions": [
      {
        "index": 1,
        "gloss": "hungry ghost (preta) realm",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もう炎天と飢渇の為に人にも鳥にも、親兄弟の見さかひなく、この世からなる餓鬼道ぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう炎天と飢渇の為に人にも鳥にも、親兄弟の見さかいなく、この世からなる餓鬼道じゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』胸わるき油煙のにほひ女子らが汗に蒸されて、焦熱のこころあかあか火の車、または釜うで、餓鬼道の叫喚さながら人人が苦悩を醸す。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "修道の一念甚だ危ふく、あはや餓鬼道に迷ひ入らんとせし事もあり、天地の間に生れたるこの身を訝かりて、自殺を企てし事も幾回なりしか、是等の事、今や我が日頃無口の唇頭を洩れて、この老知己に対する懺悔となり、刻のうつるも知らで語りき。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "まる三週間近く、水の他何にも摂れないので、まるで生きながら餓鬼道に堕ちたようなものであった。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「公（忠直）は湯漬飯を命じ近侍｜真子平馬に膳を持たせ、立ながら数椀喫せられ、食終て公舒々と諸軍に向い、最早皆々満腹すれば討死しても餓鬼道へは堕ちず、死出の山を越して直ちに閻魔の庁に入るべし」と。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "手桶薬缶抔を提げたる人だち我も我もと押し掛くる事故我ら如き弱虫は餓鬼道の競争に負けてただ後ごみするのみなれば何時飯を得べくとも見えざるにぞ思ひかねて甲板の右舷より大廻りして他の口に行けばここも同じ事なり。",
              "citation": {
                "source": "従軍紀事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてめいめい別な大きな茶碗の中に円錐形の大きな塊に盛りあげられている飯を、大急ぎに、餓鬼道の亡者というのはこんなものだろうと思われるように、掻きこみ始めた、どんぶりから茶碗へ飯を移す、それを口に掻きこむ、呑みこむ、また掻きこむ、呑みこむ。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしの境涯は餓鬼道より少しもまさってはいない。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは餓鬼道へでも迷って来たのではあるまいか。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "『宗教は偉人の形骸である』とカライルは云つたが、この樣なあはれな状態に墮落したら、他の宗派と同樣、徒らに信者の數をむさぼる餓鬼道である。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大欅の竝木は、東京に、その類なき奇觀なるが、餓鬼道の亡者には、名物の燒鳥あるべし。",
              "citation": {
                "source": "飛鳥山遠足",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "修羅や畜生、餓鬼道越えて。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草を吸う人は皆経験しているであろうがこんな時には燐寸一本のために、大の男が餓鬼道に墜ちるものである。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "明末の流賊李自成の爲に、長い攻圍を受けて、糧食に盡きた開封の城民は、父は子を食ひ、夫は妻を食ひ、兄は弟を食ふといふ、戰慄すべき餓鬼道に陷つた有樣は、當時の籠城者の一人なる李光※の日誌に備載されて居る。",
              "citation": {
                "source": "支那人の食人肉風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば餓鬼道の苦しみは目前の飯を食おうとすれば飯の上に火の燃えるたぐいである。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし地獄に堕ちたとすれば、わたしは必ず咄嗟の間に餓鬼道の飯も掠め得るであろう。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば餓鬼道の苦しみは目前の飯を食はうとすれば飯の上に火の燃えるたぐひである。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし地獄に堕ちたとすれば、わたしは必ず咄嗟の間に餓鬼道の飯も掠め得るであらう。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば餓鬼道の苦しみは目前の飯を食はうとすれは飯の上に火の燃えるたぐひである。",
              "citation": {
                "source": "芥川龍之介論",
                "author": "――藝術家としての彼を論ず――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし地獄に墮ちたとすれば、わたしは必ず咄嗟の間に餓鬼道の飯も掠め得るであらう。",
              "citation": {
                "source": "芥川龍之介論",
                "author": "――藝術家としての彼を論ず――",
                "note": "青空文庫"
              }
            },
            {
              "text": "遙か離れた往来の人混みの中から鼓の音が、餓鬼道の巷に彷徨っている血眼の人達の心の中へ平和と慰安と勇気とを注ぎ込もうとするかのように穏かに鳴るのが聞こえては来たが……。",
              "citation": {
                "source": "開運の鼓",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「寺々の女餓鬼」というのは、その頃寺院には、画だの木像だのがあって、三悪道の一なる餓鬼道を示したものがあったと見える。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕のところぢや専ら中毒患者とギリギリの餓鬼道で折衝してるんだから、アルコールの売買以外に風流のさしこむ余地有りやしないね」「なるほどなア。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "時代はたうとうギリギリの餓鬼道でアルコールの取引をするところまで来たのかなア。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しアルコールも亦餓鬼道の取引だといふ先生の思想ならメチルによつて餓鬼の二三十匹引導を渡してみるのも壮快でせう。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルコールの取引はたゞ餓鬼道の折衝あるのみといふ、これが夜の王様の威厳にみちた大性格であることをたゞの今まで気付かなかつたとは赤面の至りです。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の貧乏は本人が覚悟の上のことであるから何でもないけれども、戦争の貧乏は人々がそれを欲していないのに身にふりかかってきたことで、しかも全く餓鬼道の底に達した貧苦であるから哀れである。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
