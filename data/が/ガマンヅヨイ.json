[
  {
    "uuid": "d3b07b07-2bc3-5937-ba85-029184b09a02",
    "entry": "我慢強い",
    "reading": {
      "primary": "がまんづよい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
