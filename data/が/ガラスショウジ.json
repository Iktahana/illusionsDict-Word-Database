    "definitions": [
      {
        "index": 1,
        "gloss": "glazed sliding door",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
