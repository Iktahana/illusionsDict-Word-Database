[
  {
    "uuid": "4a8b84b4-cb03-5712-b5d0-a85b3b7831d5",
    "entry": "臥する",
    "reading": {
      "primary": "がする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-特殊",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to lie down (in bed)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "源叔父の疾みて臥するは稀なることなり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "息苦しきため横臥する能はず。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田｜稔麿に対しても、市中の宿屋に泊らず、藩邸に起臥するやうに、勧告したが、容れられず、宮部鼎蔵等にも外出を極力制止してゐたのである。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｍ――君はその本宅と道路を中にさし向つた別莊の雨戸をあけて、『こちらが靜かですから……』　自由に起臥する樣にと深切に氣をつけて呉れた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "島三題",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて二十頭の牛は水上五寸の架床上に争うて安臥するのであった。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて二十頭の牛は水上五寸の架床上に爭うて安臥するのであつた。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房は横臥することも其の苦痛に堪へないで、積んだ蒲團に倚り掛つて僅に切ない呼吸をついて居た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は毎日辨當が濟めば屹度そこに横臥する。",
              "citation": {
                "source": "旅の日記",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "室内の用具も簡単な物ばかりで、起臥する部屋も客の座から残らず見えるのである。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "清澄山は烏帽子の如く、富山は二峯に分れ、一峯は草、一峯は樹林を帶びて、恰も獅子の臥するが如し。",
              "citation": {
                "source": "鹿野山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰も巨人の臥するが如し。",
              "citation": {
                "source": "箱根神社祈願の記",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠き峯巒は、天半に連亙して、自然の墻壁を作り、近き群峯、脚下に起伏糾紛して、峯勢縱横、走るもの、蹲まるもの、臥するもの、立つもの、一に群獸の陸梁跳躍するが如く、峯と峯との間、即ち谷と云ふべきものの多きこと、啻に九十九にして止まらず。",
              "citation": {
                "source": "房州紀行",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　天幕の一夜五六人臥するに足るだけの天幕を持ち行きけるまゝにて、之を用ゐたること無かりしに、西村醉夢來り訪ひ、氣を吐いて曰く、寶の持腐れといふことあるが、天幕の持腐れは氣の利かぬ話也。",
              "citation": {
                "source": "北條より一ノ宮へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "青木が、近藤家に寄寓して、雄吉と同室に起臥することになったのは、それから間もなくのことであった。",
              "citation": {
                "source": "青木の出京",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "仰臥すると視野はもう空の一色であった。",
              "citation": {
                "source": "窓",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "畳の上に坐臥する日本の風習は彼らのわらいを買うからおもしろくない。",
              "citation": {
                "source": "映画と民族性",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどもこの命令のために更に居場所を狭められて大方の荷物は皆天井につるし肩掛革包を枕とし手を縮め足をすぼめて海鼠の如く伏し居るほどに余の隣に起臥する騎兵の上等兵は甲板より帰りぬ。",
              "citation": {
                "source": "従軍紀事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ如何せしやと思ひ居るほどに上等室に行き見れば食卓の後、即ち船の最後部にあたりて少し高くなりて円く卓を並べたる処に彼六人の神官僧侶の起臥するを見たり。",
              "citation": {
                "source": "従軍紀事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京で世話をしてやった友人が町でかなりな歯科医の玄関を張っている、そこへ行くか、亡くなった妻の実家の持ち家が少しばかりある、その中の一つを借りて起臥するかよりほかなかった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々はその上に横臥することなく、我々は運動を續行する。",
              "citation": {
                "source": "唯物史観と現代の意識",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその脇に横臥するようにして声をかけた。",
              "citation": {
                "source": "美しき死の岸に",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらは炎塵の巷に起臥するをも苦とせねば、静閑の境に悠遊するにも億劫でない。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからは三人が摂津国屋を出て、木賃宿に起臥することになった。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "五百が早く本丸に入り、また藤堂家に投じて、始終家に遠かっているようになったのは、父の希望があり母の遺志があって出来た事ではあるが、一面には五百自身が牧と倶に起臥することを快からず思って、余所へ出て行くことを喜んだためもある。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "安政三年以後、抽斎の時々病臥することがあって、その間には書籍の散佚することが殊に多かった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "路傍に醉臥することが僕の癖なることは、君も承知せる所ならずや。",
              "citation": {
                "source": "酒に死せる押川春浪",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の心は、今夜からこの眼の前に聳えて居る大きな家の人となり、多くの見知らぬ人々の間に起臥するのだといふ漠然とした不安や恐怖やで一杯になつて居た。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで是れは人の起臥する帳幕の話でありますが、蒙古人だつて身分に應じていろいろの寶をもつて居る者もありますから、さういふものを臧むるには倉庫がある。",
              "citation": {
                "source": "元時代の蒙古人",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの「包」に四五人が起臥し、寝るには毛氈の上に衣服を夜具として横臥する。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく、グロース、ウエップ、イルコックの三名も、いまとおく左門洞の楽園をはなれて、ひとりせきばくたる、この樹下に横臥するとき、さきにこの樹下にねむりし人をおもい、左門洞のことを思えば、その心の奥に一まつのくゆるがごとき、うらむがごとき、一種の念のきざすのを禁じることができようか。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
