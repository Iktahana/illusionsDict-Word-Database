        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「わあ、素敵なガラス器！」思わず声を上げてしまうほど、その江戸切子の輝きは繊細だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夏の食卓を涼しげに演出するため、今日は冷やしそうめんを透明なガラス器に盛り付けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "不注意で棚から落としてしまった思い出のガラス器は、修復不可能なほど粉々に砕けていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "アンティークショップの隅で見つけた古いガラス器には、気泡が混じっていて独特の味わいがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それを、リキュールの杯ぐらいな小さなガラス器に頭を丸く盛り上げたのが、中学生にとってはなかなか高価であって、そうむやみには食われなかった。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀器の光、ガラス器のきらめき、一輪ざしの草花、それに蜜蜂のうなりに似たファンの楽音、ちょうどそれは「フォーヌの午後」に表わされた心持ちである。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳から上だけの人間が黄色い液体の充たされた大きなガラス器の中に漬かっていた。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は心の中で、「そんなに何喰わぬ顔をして居たとて駄目だよ、今にびっくりさせられるから覚悟をするがよい」と呟き乍ら、例の如く腸を切り出してガラス器に取りつけました。",
              "citation": {
                "source": "三つの痣",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっと云う間もなく、彼は腸のはいったガラス器をめがけて突きかかりました。",
              "citation": {
                "source": "三つの痣",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には、おなじようなガラス器があり、それの中に見られたものは、よく見ないとわからないほどの細い針金でもって、だ円形のかごのような形を、あみあげたものだった。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きれいなんだが、やっぱりこれではだめなのか」　彼は、それをガラス器に入れて、棚の上においた。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお……」　彼はその関節が砕けるかと思うばかりに両手を打ち鳴らすと、店全体がびりびりと震えて、棚のガラス器や帳場はがたがたと揺れた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "廃宅",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら位かな、三留位だろうな」やはりゲルセン街で、1.30のバター入れのガラス器、十一｜哥の皿三枚、エハガキなど買った。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日も、私は診察後、耳と腕から血を採られ、検尿のため、私の名前が貼ってあるガラス器に尿をとった。",
              "citation": {
                "source": "日を愛しむ",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "吊り下げられた、ガラス器の中の注射液が徐徐に低下して行く。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "水が完全に透明であることを判断するには、ある量の水を深いガラス器具に入れて、かなりの量の液体を垂直に見下ろすことである。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "（以下　献辞を省略）ガラス器具その他の化学装置や機械は次に述べる団体から購入できる。",
              "citation": {
                "source": "食品とその混ぜ物処理",
                "author": "FOOD AND ITS ADULTERATIONS; ANALYTICAL SANITARY COMMISSION OF \"THE LANCET\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "たみ、急いで茶箪笥のガラス器の中からゴムの乳首を出して来る。",
              "citation": {
                "source": "宵（一幕）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてさとうづけの果物のはいったガラス器を、たがいに取りまわしていた。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "その紙雑貨店の店先には、ガラス器にはいった赤や緑のボンボンだの、手も足もないボール紙の人形などが見えていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女のほうでは、店先の二つのガラス器にいっぱいはいってる種々な色のボンボンを、少し彼に与えた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかに素晴らしい磁器やガラス器、豪華な皿の収集品があった。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "オーク材や甲冑がきらり、銀器や高価なガラス器がぴかぴか、背後には花々や、羽根状のシダがある。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "聴診器が発見され、尿を入れたガラス器具が中世の医師のシンボルであったように聴診器はその後の医師のシンボルになった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "暖炉棚の上にはガラス器の中に、銀糸とオレンジの花とのついた女の帽子が一つあった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡、水晶器具、ガラス器具、皿、磁器、陶器、土器、金銀細工物、銀の器具など、すべてが輝き笑っていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方の窓に面して大きな白木の化学実験台があり、その上に大小様々のガラス器具、顕微鏡などが置かれ、一方には夥しい瓶の並んだ薬品棚が立っている、化学実験室と調剤室とを一緒にしたような眺めだ。",
              "citation": {
                "source": "悪魔の紋章",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "野菜サラダを、ガラス器ごと。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "純白の敷布や透明なガラス器、冷えて新鮮なサラダが、銀製の大うつわに盛ってある。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
