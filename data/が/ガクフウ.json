    "definitions": [
      {
        "index": 1,
        "gloss": "academic traditions",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "自由な議論を重んじる学風が、この大学の特色となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "伝統あるこの大学の学風は、多くの学生を惹きつけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの教授は、既存の学風にとらわれず、新しい研究分野を切り開いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そのせいでもあるまいが当時ドイツの風俗、人情、学風に対する色々な不満を聞かされた記憶がある。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう事を研究することを喜ばないような日本現時の不思議な学風がそういう研究の出現を阻止しているのではないかと疑われる。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学上ではなんらかの画紀元的の進展を与えた新しい観念や学説がほとんど皆すぐれた頭脳の直観に基づくものであるという事は今さらに贅言を要しない事であるにかかわらず、昔も今も通有な一種の偏狭なアカデミックの学風は、無差別的に直観そのものを軽んじあるいは避忌するような傾向を生じている。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらを埋めて活溌な足取りで流れとなり幅となって動いている行人の群は、ソルボンヌの典雅な学風を背景にして国際的な空気を揺曳している。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恵心はもとより緻密厳詳の学風の人であったから、寂照はこれに従って大に益を得たことでもあろう、それで寂照を恵心の弟子のように云伝えることも生じたのであろう。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るを何者の偏視眼者流ぞ、徒らに学風を煩瑣にし、究理と云ひ、探求と称して、貴とき生命を空しく無用の努力に費やし去る。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "学風の新鮮を保ち沈滞を防ぐためにはやはりなるべく毛色のちがった人材を集めるほうがかえっていいかもしれないのである。",
              "citation": {
                "source": "相撲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "句読訓詁などと豪語してゾンザイな学風を身に浸みさせて仕舞うのも決して宜しくはない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "王陽明（中国の明代の儒学者）の学風は、仏教の禅家の教に似たところがあって、「儒教を遠ざかり仏教に近づくこと程子（中国宋の儒学者）や朱子（中国宋の儒学者、朱子学の創始者）にも過ぎる」と言われたほどの人だが、この人をしてこの様な言葉がある。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "また象山｜嘗て自ら説く、「虚が幾ら有っても一ツの実も生まれない、吾が平生の学問、他無し、ただ是一実」と、またその日常の言葉に言う、「道の外に物事無く、物事の外に道無し」と、象山の学風はこの様である。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に「博く学んで篤く志し（博学篤志）」「切に問いて近く思えば（切問近思）］の二句は、先生の学風を明らかに仕尽くしている。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "子貢より以下は遂に一人も一貫の趣旨に関与した者は無い」という宋学風の話を非難して、哀公のような下劣な君主にさえ「一以貫之」の趣旨を孔子は示されたでは無いかと、『中庸（二十章）』を引いて論じたところは、全氏の立派なところで、そこは確かに好い説である。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、それよりもなおヨリ多く諸生を心服さしたのは二葉亭の鼓吹した学風であった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も普遍的なる学問すらも社会的因襲を脱しない（今日各国に学風というものがあるのはこれが為である）。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピタゴラスは紀元前六世紀の後半（五六〇―四九〇年）の人でいわゆるピタゴラス学派の元祖であるが、この人となるとまたエジプトの学風の余弊がかなりに強くひびいているようである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "生来美術心に乏しき人、または漢学風の疎大に失する人は往々にしてこの種の趣味を解せざる者あり。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の芸術の伝統における粋の諸要素を、幾何学風な図解まで添えて説明しようと試みられているのであるが、その科学的分析の努力を氏自身が結論において謂わば自ら放棄しているところは興味がある。",
              "citation": {
                "source": "文学上の復古的提唱に対して",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが技術を或る特定な意味で、実践的に考えたいのは、多くの哲学的な（解釈論哲学風の）技術観念の急所の一つで、之また相当に苦労した上で例の第三領域論に帰るものである。",
              "citation": {
                "source": "技術と科学との概念",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人は女大学風に育てられ、媒介によって、家から家に嫁して来て、妻となり、母となってその婦徳と才能のかぎりを尽したのであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち自由と創造と闘いとの気魄のない官学風の教育の無力であること。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "既にして保は慶応義塾の学風を仄聞し、頗る福沢諭吉に傾倒した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち尋常為政者の喜ぶ所となるべき学風である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "松田氏の蔵する所に柏軒の筆蹟があるが、亦その内経を崇尚する学風を見るべきである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊沢氏の学風は李朱医学の補血益気に偏したものではなかつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "綱浄は独り五行配当の物理に背き、同僚の学風の実際に切実ならざるを論じ、張仲景の一書を以て立論の根拠とし、自ら「疾医某」と称して自家の立脚地を明にした。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関を上がつて右が旧塾と云つて、ここには平八郎が隠居する数年前から、その学風を慕つて寄宿したものがある。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この論派は英国・米国の学風より生出したりといえども、あえて学者の理論を標準として政治の事を説くものにあらず、彼実に日本の現状に応じて説を立て、政法上道理に合うと否とを問わず、事情の許す限りはこれを利用して実益を生ぜしむることをその標準となしたるがごとし。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "国権論派とも称すべき他の一派は欧州大陸の学風を承けて発生したり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "然る時にあたりて、全国の学校はその時の政府の文部省に附属し、教場の教員にいたるまでも政府の官吏にして、政府の針路一変すれば学風もまた一変するが如き有様にては、天下文運の不幸これより大なるはなし。",
              "citation": {
                "source": "学問の独立",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん、でたらめの朝鮮語ではありますが、ともかくも、日本語でないことばでいろごとをしようというのですから、かりにも江戸一円の警察権を預かっている八丁堀のおだんながたがくふうした趣向にしては、まことに変わった思いつきというべきでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
