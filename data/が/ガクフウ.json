[
  {
    "uuid": "38e04b1b-eb96-51ec-9689-e8aceff761af",
    "entry": "学風",
    "reading": {
      "primary": "がくふう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
