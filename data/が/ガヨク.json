    },
    "definitions": [
      {
        "index": 1,
        "gloss": "selfishness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "我欲に囚われると、正しい判断ができなくなることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の行動は我欲に基づいていると批判された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "政治家たるもの、我欲を捨てて民のために尽くすべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "我欲を抑え、他者を思いやる気持ちが大切だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "眼前のいろいろのものを、惜しみ、欲しがる我欲です。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまよりは海の眞幸も、我欲りのまゝ。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "第七には、人は皆我欲を持っているので、知られることがない。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "我欲にのみ着してゐる。",
              "citation": {
                "source": "孤独と法身",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "我欲刻亡弟信卿遺稿。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "凹巷は「命駕我欲西、好侶況相追、君亦出都門、望々幾翹跂」と云つてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "我欲な戦闘的な蕭殺とした私の心の緊張はやわらかに弛み、心の小溝をさらさらとなつかしき愛の流れるのを感じた。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫉妬・我欲等の利己の動機から出るものは、かしり（動詞かしる）と言ふ語であつたと考へられる。",
              "citation": {
                "source": "「ほ」・「うら」から「ほがひ」へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し棄鉢といふよりも、確信的なものであり、責任を持たないことの反対の、万事自分で背負ひきつて一向他の容喙を顧慮せぬ底の根強い自信で、私は多く精神的な難関を斯様な我欲的な確信によつて誤魔化す習慣があつたのだ。",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然の美に見とれて、物質的我欲を忘れてしまうというようなことは、まあ俗人には出来ない。",
              "citation": {
                "source": "よい書とうまい書",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗衆の我欲がこの帽子を拵えて、長の年月の間にずっと私を強いて無理に額眉深にそれを被らせて来たものだ。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の制度はみな人間の本来の性質に基因することで、人間がおのれの欲せざるところを他に施すという我欲を生まれながらに持っている以上は、法律も警察も必要であり、宗教も道徳も廃するわけにはゆかぬ。",
              "citation": {
                "source": "理想的団体生活",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかるありさまを実現しようと企てるには、まずその前に人間の生まれつきの性質を鋳直し、その我欲を去って苔虫同様なものとなす必要があるが、これは人間に対して人間ならざるものとなれと注文することにあたるゆえ、むろん不可能である。",
              "citation": {
                "source": "理想的団体生活",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その秘図一つに、いまや柳生一藩の生命がかかり、また、いつの世も変わらぬ我欲妄念の渦がわきたっているのだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄金のうずたかきところ、醜きまでにあらわな我欲｜迷執の集まることは、古今その軌を一つにする。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "評判の貧乏旗本で身持ちの悪い鈴川様が、どうして五十とまとまったものを調達できたのか、これが第一の不審だが、それはそれとしても、我欲に眼のくらんだおさよが、選りに選って自分のところへ交渉方を持ちこんで来たのは、富五郎にとってはこのうえもない幸であった。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "押しあい、へし合い、肩を揉み足を踏んづけあって、執念我欲の図……。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "『虞美人草』に至っては鮮やかな類型的描写によって、卑屈な利己主義や、征服欲の盛んな我欲や、正義の情熱や、厭世的なあきらめなどの心理を剔抉した。",
              "citation": {
                "source": "夏目先生の追憶",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」これらはすべてなお我欲名利の心に根ざしたものである。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）個性と愛とを大きくするための主我欲との苦闘。",
              "citation": {
                "source": "「ゼエレン・キェルケゴオル」序",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "主我欲を征服し得ないために日々に起こる醜い煩い。",
              "citation": {
                "source": "「ゼエレン・キェルケゴオル」序",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "主我欲の根強い力と、それに身を委せようとする衝動と。",
              "citation": {
                "source": "「ゼエレン・キェルケゴオル」序",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中がどれほど金と我欲と騙りで出来ているか、彼は骨身にしみて味あわされている、それなのにこんな大枚の金を道の上で、処も名も素性も知れぬ者にことづける人間があるだろうか。",
              "citation": {
                "source": "金五十両",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "５日　夜　罪と我欲を捨てれば、心は不滅の喜びを取り戻す。",
              "citation": {
                "source": "朝に想い、夜に省みる",
                "author": "MORNING AND EVENING THOUGHTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "至純の人生を理解し、その原則に従い、我欲という暗路・大迷宮へと足を踏み外さぬ者ならば、害の及ばぬところにも立てる。",
              "citation": {
                "source": "朝に想い、夜に省みる",
                "author": "MORNING AND EVENING THOUGHTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "13日　夜　すりつぶされるような苦しみがいつまでも続くのは、取り除かれるべき我欲という殻が何かしら残っているからだ。",
              "citation": {
                "source": "朝に想い、夜に省みる",
                "author": "MORNING AND EVENING THOUGHTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "我欲があらゆる争いと苦しみの根源であるのと同様、愛はあらゆる平安・幸福の根源である。",
              "citation": {
                "source": "朝に想い、夜に省みる",
                "author": "MORNING AND EVENING THOUGHTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "不純な欲も、その光の衣を汚すことあたわずして……望みさえすれば誰でも入れるが、その代償を支払うのが決まりである――我欲を完全に捨て去ることだ。",
              "citation": {
                "source": "朝に想い、夜に省みる",
                "author": "MORNING AND EVENING THOUGHTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "我欲を越えて自分を完全に捨てきることができれば、天国入りできる。",
              "citation": {
                "source": "朝に想い、夜に省みる",
                "author": "MORNING AND EVENING THOUGHTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなるときも、我欲が好き勝手しないか見張ること、同時に、自己犠牲の精神をしっかりと胸に刻み込んでおくこと。",
              "citation": {
                "source": "朝に想い、夜に省みる",
                "author": "MORNING AND EVENING THOUGHTS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
