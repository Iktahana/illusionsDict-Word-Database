[
  {
    "uuid": "2979146d-ae8c-51a7-b5e0-29e58f2f9cf2",
    "entry": "我欲",
    "reading": {
      "primary": "がよく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
