        "examples": {
          "standard": [
            {
              "text": "犯人はロープで雁字搦みに縛り上げられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は多額の借金で雁字搦みになり、身動きが取れない状態だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "過去の失敗に対する後悔の念に雁字搦みにされ、新しい一歩を踏み出せないでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "がんじがらみに逢つて身動きが出來ず、結局敗けてしまふことになりはしないか？",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは、その手｜頸足頸まで、がんじがらみにして、林冲を大樹の幹に縛し終ると、やにわに、「よしっ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてがんじがらみにした男の体を鞍の上にくくしつけ、両側から柴の薪束を抱き合せてある。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "孟獲だっ」　喚きもがくのを、遮二無二、がんじがらみに縛って、「浅慮者め、われわれは馬岱軍の一手だ。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
