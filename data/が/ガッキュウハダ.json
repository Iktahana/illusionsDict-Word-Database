        "examples": {
          "standard": [
            {
              "text": "彼は研究室にこもりっきりで、まさに学究肌の人物だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "私の教授は典型的な学究肌で、休日に家族サービスすることはめったにない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "世間的な名声には興味がなく、ひたすら真理を探求する学究肌の学者だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの人は、実用的なことより理論的な探求を好む、生粋の学究肌だよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "だが「ＭＳ―ＤＯＳベースで視覚的な操作環境を備えたワードプロセッサーを書いてくれないか」と申し入れてきた古川を、学究肌の技術者集団による武家商法でこの後名を馳せることになる管理工学研究所は、まったく相手にしようとしなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者の当人が学究肌だから、それが非常に不服であったほどで、こっちへ来てから表面従順ではあったが、ソリが合わなかった。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "学究肌の木ベエは、女性的に執念深く、一つのことに深くこだわるタチであった。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
