    "definitions": [
      {
        "index": 1,
        "gloss": "screen (of a TV, computer, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「朝からずっとパソコンの画面を見続けているせいで、目がショボショボする。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「最新のスマホに買い替えたら、画面が驚くほど鮮やかで感動したよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「映画館の最前列だと、画面が大きすぎて首が痛くなってしまう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「テレビの画面に埃がたまっているのが気になって、思わず掃除を始めた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "会話が、少しもわからず、さりとて、あの画面の隅にちょいちょい出没する文章を一々読みとる事も至難である。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "画面の視野が広く、パノラマ風であり、前に評釈した夏の句「鮒鮓や彦根の城に雲かかる」などと同じく、蕪村特有の詩情である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、自分はこの絵を見る度に静かな田舎の空気が画面から流れ出て、森の香は薫り、鵯の叫びを聞くような気がする。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "竪一尺横一尺五寸の粗末な額縁の中にはあらゆる幼時の美しい幻が畳み込まれていて、折にふれては画面に浮出る。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう光景が一つの古い煤けた油画の画面のような形をとって四十余年後の記憶の中に浮上がって来るのである。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「垢抜」した湯上り姿は浮世絵にも多い画面である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "この画面が進行していたとき、自分の前の座席にいた男の子が突然大きな声で「アー、大掃除だ」と云った。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体に青味の勝った暗い絵で、顔が画面一杯に大きくかいてあった。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "全十二巻の詞書というものを売っていたので買ってみると、詞書の上段に若干の画面の写真版が並んでいて、その中には上記のカットされたもののうちの二、三があるので大抵の想像が出来る。",
              "citation": {
                "source": "山中常盤双紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "煎じ詰めた、而も、たまらなく美感と滋味のこもった言葉が小癪なほど豊富に飛び出し、而もそれ等が一つ残らず（画面）の底にとけて流れて行く。",
              "citation": {
                "source": "気まま者の日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「旦那に金がないと　知ると、急に　手の掌かえして　水臭くなりやがって、　果は情夫と手に手を　とってドロン……」（次の画面へダブル）　＝大吉の浪宅　（前の字幕からダブって）　遺されたおきよの書置き手に呆然自失、ドッカと座敷に坐った儘の大吉、　やる瀬なくその手紙胸に抱いて、Ｔ「おきよ！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次、Ｔ「昨夜、芝居が　果ててから　帰りを急ぐ仲蔵　の駕籠を……」（此のタイトル次の画面にＯ・Ｌして）　＝深夜の街　帰りを急ぐ駕籠一丁。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおぜいの登場者の配置に遠近のパースペクチーヴがなく、粗密のリズムがないから画面が単調で空疎である。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてかの有名な高山寺蔵の絵巻物の画面を思い起こしながら、「絵巻物と活動時代」という一つの論題に思い及んだ。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへいよいよ次の画面が現われて観者の頭脳の中の連続的なシーンと「コインシデンス」をする。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "職業的美術批評家の目で見ると日傘や帽子の赤が勝って画面の中心があまり高い所にあるとも言われる。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、この映画を撮影している人々が画面の此方に大勢いるはずである。",
              "citation": {
                "source": "鴉と唱歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一通り画面を塗りつぶして、さて全体の効果をよく見渡してからそろそろ仕上げにかかろうというときの一服もちょっと説明の六かしい霊妙な味のあるものであった。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に鏡と画面とから離れて空で考える時には、鏡の顔はいつでも影が薄くて絵の顔のほうが強い強い実在となって頭の中に浮かんで来るのである。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "画面連続の時間的分配を少しでも誤れば効果は全然別のものになるであろうと思われる。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "画面の灰色の雰囲気が水のようにも思われる。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他の曲にはなかなか複雑な仕組みのものもあったが、たとえば大小の弦楽器が多くは大小の曲線の曲線的運動で現わされ真鍮管楽器が短い直線の自身に直角な衝動的運動で現わされたり、太鼓の音が画面をいっさんに駆け抜ける扇形の放射線で現わされたりする場合が多いようである。",
              "citation": {
                "source": "踊る線条",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、少し見ているうちに、まず一番に目についたのは、画面の中央の下方にある一枚の長方形の飛び石であった。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこの「秋庭」の画面にはそれが見えないのは当然である。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に目についたのは画面の右のはずれにある石燈籠である。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この梧桐は画面の外にあるか、それとももうとうの昔になくなっているかもしれない。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "画面の左上のほうに枝の曲がりくねった闊葉樹がある。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが反対に画面の右端を左へ向いて駆けって行くのでは迫った感じが出ないであろう。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝飯をたべて自分が近所へ遊びに出ようとすると、お松はあわてて後から付いてきて、下駄を出してくれ、足袋の紐を結び直してくれ、緩んだへこ帯を締直してくれ、そうして自分がめんどうがって出ようとするのを、猶抑えて居って鼻をかんでくれた。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲を一、乙を二、丙を三と順々に置き換えてしまえば、たとえば二十三と言う代わりに乙丙と言っても文字がめんどうなだけで理屈は同じである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
