    "definitions": [
      {
        "index": 1,
        "gloss": "small scale production model kit (e.g. for figurines)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "休日はガレキの制作に没頭して、気づけば夜中になっていることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新作のキャラクターが発表されて、イベントでは多くの人がガレキを求めて列を作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このガレキはパーツが非常に細かく、組み立てにはかなりの集中力が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "初めて作ったガレキは少し失敗したけど、愛着が湧いているよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ボンド通りの損傷はそれほどひどくなかったが、昇降口はガレキが埋まっており、通路を切り開いて駅に侵入する必要があり、やっとトンネルへ辿り着いた。",
              "citation": {
                "source": "見えざる力",
                "author": "THE INVISIBLE FORCE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
