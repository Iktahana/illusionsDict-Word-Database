        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "海岸には潮に打ち上げられた瓦礫が散乱し、清掃活動が必要だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "不法投棄された瓦礫のせいで、そこは以前の美しい森の面影もなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "工場跡地には、使い物にならない機械の瓦礫が放置されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
