[
  {
    "uuid": "74ab890e-d9fe-514c-95b5-ea16bebade6d",
    "entry": "瓦礫",
    "reading": {
      "primary": "がれき",
      "alternatives": [
        "がりゃく"
      ],
      "is_heteronym": false
    },
    "grammar": {
