        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「おいおい、そんなにすぐ諦めるなよ！ここでもう一踏ん張り、ガッツを見せろ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "泥臭いプレーでボールを追い続ける彼の姿には、数字以上のガッツが感じられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "逆境に立たされても決して折れない、彼のガッツにはチーム全員が脱帽した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "徹夜明けのプロジェクト会議で、新人がガッツのある代案を出して場を盛り上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "近頃読んだ本でありませんがマンテガッツァの『フィジオロジー・エンド・エキスプレション』という本の中にイミテーションということについて例を沢山挙げてありましたが、私は今｜一々人間という者は真似をするものであるということの沢山な例を記憶しておりませんが、茲処に二つ三つあります。",
              "citation": {
                "source": "模倣と独立",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "このフリント市から少し離れた Oak Hill 町の矢張り墓地で、マアサ・ガッツという附近の牧師の家の女中が、手巾で覆面をした労働者風の背の高い男に襲われて、この時は、奪われるものを奪われた丈けで生命には別条なかった。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　おなじく十二月二十六日、オウク・ヒル町墓地におけるマアサ・ガッツ強姦事件。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろイタリヤの Fogazzaro（アントニオ・フォガッツァーロ）が死んだ。",
              "citation": {
                "source": "文芸の主義",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "Il Santo（フォガッツァーロの小説）あたりであらわしていた、カトリック教に同情した心持を寺院の側からの抑圧を受けて、いっそう保守的にあらわそうとして、死ぬる前に一の小説を書いた。",
              "citation": {
                "source": "文芸の主義",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに、一口にいえば、こんな風にガッツいていないタイプの組長に逢って、私は嬉しかった。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "またホウガッツァロの『聖者』のなかに描かれたる老牧師と少女との恋を思う。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "劇場の職員が謝罪をさせてほしいと私を追ってきたが「いえ、へっちゃらです」と私はガッツポーズをして預けていた荷物を受け取り、総合コンヴェンションセンターの外へ出た。",
              "citation": {
                "source": "グローバルタワーにて",
                "author": "福永信",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
