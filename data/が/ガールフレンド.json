        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "過去を語りたがらないジョブスではあるが、その夏、彼はサンタクルーズの小さな山荘でガールフレンドと共同生活をしたことを告白している。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんぼくも同年輩の男たちと同様ガールフレンドを持ち、リーベとよべる仲になったこともあります。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は前節に「ぼくも同年輩の男たちと同様ガールフレンドを持ち、リーベと呼べる仲になったこともあります」と、明確にガールフレンドとリーベを区別している。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてリーベになったというのは肉体的な交渉をもつに至ったガールフレンドという意味であるらしい。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "特派員なんぞで出張すると、汽車へ一回乗るごとに、必ず一人はガールフレンドをひろって来た。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐川君のあまたあるガールフレンドのひとりだ。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒビングでの、ボブのハイスクール時代のガールフレンド）８　奨学金を得てミネソタ大学に入った。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小川のガールフレンドといっしょに、冬美をつれて浅間までツーリングに出たのは、去年の夏のはじめだった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホーンを鳴らし、歓声と共に走りぬけていくのを見ると、小川も、うしろのシートのガールフレンドも、すっ裸だった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の夏には、ぼくは沢田冬美を乗せ、小川はガールフレンドをつれて、浅間へいった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "清のガールフレンド今木さんが来てゝ食事を共にする。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
