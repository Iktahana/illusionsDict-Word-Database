        "examples": {
          "standard": [
            {
              "text": "トークショーでは、撮影中の失敗談など、キャストの面白い楽屋話がたくさん飛び出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "引退したプロ野球選手が、お酒の席で現役時代の貴重な楽屋話を語ってくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女の自伝には、これまで語られることのなかった芸能界の楽屋話が赤裸々に綴られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "かういふ楽屋話はどちらかと云へば作者の恥さらしだが、しかし、私は、わが国現代の戯曲作家のすべてが、かゝる矛盾と悩みとをもつものであることを、一般演劇愛好家に訴へたいのである。",
              "citation": {
                "source": "「速水女塾」あとがき",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "言わば、そういう楽屋話を、さも、鬼の首でも取ったように、楽屋の外へ吹聴する「芝居の専門家」の心事は、まことに憫笑に値するものである。",
              "citation": {
                "source": "あるニュウ・フェイスへの手紙",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "図書館法楽屋話中井正一　この議会で図書館法が通過したことは、全図書館人にとって、まことに感慨深いものがあるのである。",
              "citation": {
                "source": "図書館法楽屋話",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうようなことで、字句のことやらなにやらで、天手古舞いをした結果、漸く元日に発布されたが、楽屋話をすると、前日の三十一日まで、この字句は適当でない、これは間違っているということを話し合って、木下侍従次長に陛下のところに正誤のお許しをお願いして頂いたというようなこともあったように覚えている。",
              "citation": {
                "source": "「人間宣言」のうちそと",
                "author": "前田多門",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽屋話を披露すると、なるべく融通のきくように、なんとでもなる題名を選んだつもりだ。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時すぎに出て、伊藤松雄を訪問、落語家の楽屋話を脚色してみないかと言っとく。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
