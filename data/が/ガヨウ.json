        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もしそれが知れ渡ったら、琉球の瓦窯にはもっと烟が黒々と燃え上るでしょう。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれらの窯場の中で最も見事なのは、北京城外東方にある瓦窯であって、その規模の厖大なる、真に驚くべきものがあります。",
              "citation": {
                "source": "北支の民藝（放送講演）",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭がようやく冴えて来た、足許の岩では、偃松が近くは緑に、遠くは黯くなって、蜿ねっている、天外絶域の、荒れはてた瘠土にまで、漂って来た、緑の垂直的終点を、私は今踏んでいるのだ。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂を下りて見ると不忍弁天の社務所が池の方へのめるように倒れかかっているのを見て、なるほどこれは大地震だなということがようやくはっきり呑込めて来た。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢のように二里の路を走って、太陽がようやく地平線に現われた時分に戸村の家の門前まで来た。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてお祖母さんがようよう話を次ぐ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃海外では農芸に電気を応用する事がようやく盛んになろうとしているから、稲妻の伝説と何か故事つけが出来そうである。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで、この場でそうまであそばさない方がようございましょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもあんまり失礼だと思いまして」　貝原がようやくまともに向けた顔を真直ぐに見て、さびしい声で小初は云った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これで菜物がよう出来るぞ！",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "地理的条件のために長い間鎖国状態を保って来た日本がようやく世界の他の部分と接触するようになったのは一つには科学の進歩によって交通機関が次第に発達したおかげであるとも見られる。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私は暗と寒気がようやく私を勇気づけて来たのを感じた。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――錯覚がようやく成功しはじめると私はそれからそれへ想像の絵具を塗りつけてゆく。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸外へは近うござんすが、夏は広い方が結句宜うございましょう、私どもは納戸へ臥せりますから、貴僧はここへお広くお寛ぎがようござんす、ちょいと待って。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな実例から見ると、こうした種類の涙は異常な不快な緊張が持続した後にそれがようやく弛緩し始める際に流れ出すものらしい。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい鳶は手が長いので鳥を染壺に入れるには大へん都合がようございました。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "以てとは、これに乗じてというがようの意味じゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お役目柄がよう出来た。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで御用聞きがよう勤まる」「又、悪口が始まった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は僕にすり寄って、「サア、なんでもごちそうしますとも、坊様、何がようございますか」と女は優しく言って、にっこり笑った。",
              "citation": {
                "source": "少年の悲哀",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの仕事しながらの会話によって対岸の廃工場が某の鋳物工場であった事、それがようやく竣成していよいよ製造を始めようとするとたんに経済界の大変動が突発してそのまま廃墟になってしまった事などを知った。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが食堂で夜ふけまで長時間続いていた傍若無人の高話がようやく少し静まりかけるころに始まるのが通例であった。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "発声映画　無声映画がようやく発達して、演技や見世物の代弁の地位を脱却し、固有の領域を設定しかけたときに、突然発声映画の器械が市場に現われた。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこの上に多大の苦心をしていわゆる立体映画がようやく成功したとしても、その効能はおそらくそう顕著なものではあるまいという気がする。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もっともあれはあれで親切人だから、そのことを根に持つような人柄ではないが、俺は頑固な昔気質だから、どうも寝ざめがようないのだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かすかな瑠璃色がようやく空一面と空間の或る部分にまで行きわたり、下界にまでは光がとどかなかった。",
              "citation": {
                "source": "窓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "幽霊などと動揺きしがようやくに静まりて、彼方へ連れ行き介抱せんと、誘い行きしを聞澄まし、縁の下よりぬっと出で蚊を払いつつ渋面つくり、下枝ならむには一大事、とくと見届けてせむ様あり、と裏手の方の墓原へ潜に忍び行きたりける。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）七左　おふくろどの、主がような後生の好人は、可厭でも極楽。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車がようよう止まると、馬丁は馭者台から飛び降りて来た。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがようやく薄れて来て、あたりが自然の夕暮れのけしきに戻ったとき、重兵衛の家の入口に倒れているおせんの姿が見いだされた。",
              "citation": {
                "source": "深川の老漁夫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
