    "definitions": [
      {
        "index": 1,
        "gloss": "no sooner ... than ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
