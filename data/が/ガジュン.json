        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の書く文章は、常に雅馴な表現で読者を魅了する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その歌人は、雅馴な言葉遣いで和歌を詠むことで知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔の貴族の会話は、現代人には理解しがたいほど雅馴だったと聞く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "雅馴な趣のある庭園で、静かに茶を嗜んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "故に史記はそれを取るについて、雅馴といふことを主として取つた。",
              "citation": {
                "source": "支那史學史概要",
                "author": "――史記より清初まで――",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めわたくしは松陰が文を撰ぶに当つて、文字を雅馴ならしめむとして改めたものかと疑つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "保守的な支那人は、かかる雅馴ならざる熟字を排斥せんと計畫したこともあるが、すべて無效であつた。",
              "citation": {
                "source": "東洋史上より觀たる明治時代の發展",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "序文は文章｜雅馴ならずして、間々欧文を直訳せる如き語法を交へ、一見その伴天連たる西人の手になりしやを疑はしむ。",
              "citation": {
                "source": "奉教人の死",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし原文の平易雅馴なる筆致にして、甚しく毀損せらるる事なからんか、予の幸甚とする所なりと云爾。",
              "citation": {
                "source": "奉教人の死",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがさう言ふ事を重ねて行つてる間に、地方的言語の総体感が、幾分づゝか雅馴なものになつて行つたことだけは疑はれない。",
              "citation": {
                "source": "「さうや　さかいに」",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那は所謂文字の國であつて、文章に用ゐる語は雅馴を以て主とする。",
              "citation": {
                "source": "支那近世の國粹主義",
                "author": "狩野直喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち第一は卑俗にして雅馴ならざるもので國體、國魂、膨脹、舞臺、代表等である、第二は支那でも從來使はないことはないが、意義が違ふもので犧牲、社會、影響、機關、組織、運動等は是である。",
              "citation": {
                "source": "支那近世の國粹主義",
                "author": "狩野直喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "地理土地共に同じ事なれど、熟字としては地理の方が慥に雅馴に聞ゆる。",
              "citation": {
                "source": "日本國見在書目録に就いて",
                "author": "狩野直喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "南郭龍門の二家は不忍池の文字の雅馴ならざるを嫌って其作中には之を篠池と書している。",
              "citation": {
                "source": "上野",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治の初年詩文の流行を極めた頃、小野湖山は向島の文字を雅馴ならずとなし、其音によって夢香洲の三字を考出したが、これも久しからずして忘れられてしまった。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠元も即非も木庵もそれぞれに面白味はあるが、高泉の字が一番｜蒼勁でしかも雅馴である。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二つは突差の用語だからもっと雅馴なものがあれば改めるが、つまり限界と面積とを持つ地名と、単にあのあたりと指していうのみで、詳しく尋ねるとどこで終りになるかの不確かな地名とである。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「秋の昼寐」などは言葉も雅馴であるし、そう無理に取ってつけたような感じでもない。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉は雅馴であって、内容に一種の新しい感じがある。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、サモ※ールがじゅんじゅんたぎっとるばかりだ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリスト教の起源の美しい物語や、キリスト生誕のときの田園の光景がじゅんじゅんと説かれる。",
              "citation": {
                "source": "クリスマス",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
