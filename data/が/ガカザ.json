        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "少女等がかざしの玉の赤玉に似たるいちごを採りつゝありく奧山の道のへに咲く草花をうらめづらしみ見せまくもとなおぼつかなき歌なり。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁と天井には目のさめるような絵がかざってありました。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "つき当りの窓に水栽培のヒヤシンスの瓶などがかざってある。",
              "citation": {
                "source": "従妹への手紙",
                "author": "――「子供の家」の物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あこには天皇さんの長寿祈願の位牌がかざったるそうな」　たけをは冷淡に、「ふーん」と答えた。",
              "citation": {
                "source": "だるまや百貨店",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉ちやんは大臣や、陸海軍の大将の服でも、こんなに沢山金モールがついて、勲章がかざつてあるとは思ひませんでした。",
              "citation": {
                "source": "夢の国",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐物屋だの呉服店などに、どんなにきれいなものがかざってあっても、今の清造にはなんの興味もありません。",
              "citation": {
                "source": "清造と沼",
                "author": "宮島資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕の空に現はれて微笑める光に塵の世を慰めてらす星あらば君がかざしの珠とせむ。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "イェーナ、ワグラム（七）雲暗しフリードランド（八）風あらしいかづち落つる砲彈の渦卷く烟かきわけて君がかざせる鷲の旗飛電のつるぎ閃めけば列王つちに膝つきて見よもろ／＼の國たみは震ひどよめり海のごと。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけでも、通る人々の足をとめて、目をひくに十｜分といえますが、もう一つ、この窓の内へ、セルロイド製の、大きなはだかのキューピーがかざられて、いっそうの注意をひきました。",
              "citation": {
                "source": "戦争はぼくをおとなにした",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ、なにかあるかと、あたりを見まわすと、おくの方の台に、赤いさらがかざってありました。",
              "citation": {
                "source": "太陽と星の下",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台には季節にふさわしい、夜桜の景がかざられてあった。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその手には、いますばやく仙之助から奪いとった抜き身の一刀がかざされているのだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂糖菓子の聖者像や金ぴかのキリスト像がかざられたりもしました。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A Dog of Flanders",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほら、もうお食事だろう、あそこに、白い布がかざられたし、みんなが御馳走をこさえている、見えるか。",
              "citation": {
                "source": "後の日の童子",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "万葉の詩人は、あぶらの火に見ゆるわがかざらし、と、素朴な全生活の明暗を髣髴させてうたいました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "日あたりのいいお座敷の正面に高く雛段をこしらへて立派なお雛様がかざつてあつた。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁には彫刻がほどこされ、絵がかざりつけられていたことでしょう。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "劇場の前や、舞台の両袖、花道にまで、無数といってもよい花輪がかざられ、そのなかには、それぞれ、ひいきの芸者を名ざしにしたものも多かった。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しいテーブル・クロスでおおった、大きな食卓の上には、美しい秋の盛り花がかざられ、めいめいの席には、銀のナイフやフォークが、キラキラと光っていました。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人のうしろのほうに、古いよろいがかざってありました。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その広い廊下のすみに、西洋のむかしのよろいがかざってあります。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
