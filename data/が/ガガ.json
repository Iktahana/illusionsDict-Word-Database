    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rugged (mountains)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「またその身に蘿また檜榲生い」というのは熔岩流の表面の峨々たる起伏の形容とも見られなくはない。",
              "citation": {
                "source": "神話と地球物理学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、しかしその一つ一つが、峨々たる巌、森とした樹立に見えた。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大熊山は三次郡の西方にある巌石の峨々と聳えた山で、五十丁ばかりも登った処に三｜次若狭守の館の跡だと云う千畳敷と呼ぶ処があった。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御先祖の霊前に近く、覚悟はよいか、嬉しゅうござんす、お妻の胸元を刺貫き――洋刀か――はてな、そこまでは聞いておかない――返す刀で、峨々たる巌石を背に、十文字の立ち腹を掻切って、大蘇芳年の筆の冴を見よ、描く処の錦絵のごとく、黒髪山の山裾に血を流そうとしたのであった。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "之を見るに四方は峨々たる岩石を以て圍まれたるもの、平地ありて之が底をなす。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "その家は北面の背後を、旭岳に続く峨々たる山脈に囲まれている一方に、前面は切立ったような、石狩本流の絶壁に遮られていて、人間｜業では容易に近付けない位置に在るので、ツイこの頃まで、誰にも発見されないままになっていたものらしい。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その岩石何ぞ峨々たる。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョオゼフ・グランヴィル　私たちはそのとき峨々としてそびえ立つ岩の頂上にたどりついた。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "こは明らかに、渦巻の底の峨々たる岩石より成り、そのあいだにこれらの木材のあちこちと旋転することを示すものなり。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬱蒼たる森林地帯を通り抜けると、巌石峨々として半天に聳ゆる崑崙山脈に攀じ登って、お茶の樹を探しまわるのですが、崑崙山脈一帯に叢生するお茶の樹というのは、普通のお茶の樹と種類が違うらしいのです。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "巖石峨々たるの處、瀑かゝり、池あり。",
              "citation": {
                "source": "宗吾靈堂",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "堂の後ろも、巖石峨々として、石段左右に通ず。",
              "citation": {
                "source": "宗吾靈堂",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "その名を、岳陰荘と呼び、灰色の壁に這い拡がった蔦葛の色も深々と、後方遙かに峨々たる剣丸尾の怪異な熔岩台地を背負い、前方に山中湖を取｜繞る鬱蒼たる樹海をひかえて、小高い尾根の上に絵のように静まり返っていた。",
              "citation": {
                "source": "闖入者",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "峨々たる淡褐色の岩山だ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "峨々たる灰藍色の山峰湧くが如し。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤沢あたりから海岸の風景が殊によろしくなる、茫々たる海、峨々たる巌、熱川温泉に安宿があるといふので下つて行つたが断られた、稲取へ暮れて着いて宿をとつてほつとした、行程八里強。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、一つの金じきりを距てた此方の三井寺の鐘楼をのせた山は、峨々としてそびえ立つ、北清の山嶺に似て居る。",
              "citation": {
                "source": "一九二三年夏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "峨々たる白氷の高山が、暖潮に乗って遠く、欧米二大陸を繋ぐ主要航路附近にまで南下して来るのだ。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "誠やこゝは天然の庭園にて松青く水清くいづこの工匠が削り成せる岩石は峨々として高く低く或は凹みて渦をなし或は逼りて滝をなす。",
              "citation": {
                "source": "かけはしの記",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぬかづいて飯繩の宮の寒きかな鳴雪屋の棟に鳩ならび居る小春かな御格子に切髮かくる寒さかな木の葉やく寺の後ろや普請小屋　山の頂に上ればうしろは甲州の峻嶺峨々として聳え前は八百里の平原眼の力の屆かぬ迄廣がりたり。",
              "citation": {
                "source": "高尾紀行",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "肌は咲き初めた紫陽花のように、濃い紺青や赤紫やまたは瑠璃色やまたは樺や、地味地層の異うに連れて所｜斑らに色も変わり諸所に峨々たる巌も聳え曲がり蜒った山骨さえ露骨に、遠く離れて望んだと違い醜い所も窺われたが、尚｜類なく美しかった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "突兀とした熔岩は角立った頂きを空へ向け、峨々累々と重なり合っている。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家のすぐ後には、峨々とした南畫風な高い山々が連なり、この山岳を八重嶽の總稱で呼ぶのもうべなるかなと思へた。",
              "citation": {
                "source": "屋久島紀行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何處まで行つても、右手は峨々とした南畫風の山が連なり、高い山は千九百五六十米もあるのださうだ。",
              "citation": {
                "source": "屋久島紀行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "吊橋の上に峨々とそびえてゐた山々は、いつの間にか、乳色のもやの中へ姿を没してゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "峨々たる高山の連なりのせゐか、一日中に、晴曇雨が交々来るところで、颱風の通路にあたるせゐか、屋久島は一年中、豪雨に見舞はれ、村の財政は、窮乏に追ひこまれ、治水対策が、はかばかしく運ばれてゐないところであつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方は峨々たる絶壁半天に懸れり。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "青根の奥深く、蔵王の麓でもあらうか峨々といふ恐ろしく熱い山の温泉のあることを聞いて少し心を動かしたが、車でなど行かれる所でもないので問題にはならなかつた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "抑、此山と申すは、南は野山｜漫々として百餘里に及び、北は身延山高く峙ちて白根が嶽につづき、西には七｜面と申す山｜峨々として白雪絶えず、人の住家一｜宇もなし、適、問ひくるものとては梢を傳ふ※猴なれば、少も留ることなく還るさ急ぐ恨みなる哉。",
              "citation": {
                "source": "尼たちへの消息",
                "author": "――よく生きよとの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "北には身延嶽天をいただき、南には鷹取が嶽雲につづき、東には天子の嶽日とたけをなじ、西には又、峨々として大山つづきて白根の嶽にわたれり。",
              "citation": {
                "source": "尼たちへの消息",
                "author": "――よく生きよとの――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
