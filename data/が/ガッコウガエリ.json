    },
    "definitions": [
      {
        "index": 1,
        "gloss": "on the way home from school",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学校帰りの子供たちが、公園で元気いっぱいに遊んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ねえ、学校帰り、ちょっと寄り道しない？」と友達が誘った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "学校帰りにコンビニに寄って、新しいお菓子を買うのが楽しみだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ランドセルを背負った学校帰りの小学生が、道を横切った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "すると愕ろいたことは学校帰りの子供らが五十人も集って一列になって歩調をそろへてその杉の木の間を行進してゐるのでした。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると愕ろいたことは学校帰りの子供らが五十人も集って一列になって歩調をそろえてその杉の木の間を行進しているのでした。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六　暑いある日の午後、白絣に袴という清三の学校帰りの姿が羽生の庇の長い町に見えた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが都合よく学校帰りの子供が一人そこを通りかゝつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ折よく学校帰りの小娘が通り掛つたので、この大学教授は又しても「門百屋」の在所を訊いた。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二　Ｋ―は、郷里では名門の子息で、稚い時分、笹村も学校帰りに、その広い邸へ遊びに行ったことなどが、朧げに記憶に残っていた。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校帰りに、私より年下の友だちと喧嘩しました。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校帰りの学生、事務所をしまった人々、職人、交換手、そういう種々雑多な人々が、各自に違った汗を掻きながら、泥を白い足袋の上にハねかえし右往左往するのを思うと、今斯うやって、静かな水の辺で、電車の音もきかずに居るのは感謝すべきである。",
              "citation": {
                "source": "樹蔭雑記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校帰りの子供が一銭くらい出して飴湯などを呑んでいるのを見ると、改めて支那人の胃袋について奇異の感をいだく。",
              "citation": {
                "source": "余齢初旅",
                "author": "――中支遊記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨上りの泥濘道を学校帰りの子供達が群れて来た。",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校帰りの子供達が、渡し船を待っていた。",
              "citation": {
                "source": "風琴と魚の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校帰りの子供がつくしを沢山とって帰っている。",
              "citation": {
                "source": "田舎がえり",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茶の水の橋のところにたって学校帰りに御目にかかったとき御話したことを又話してきかせる。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう夕御飯を食べますから、明日の学校帰りましてから書く事にいたします。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "七八歳の頃、兄弟連れ立っての学校帰りに、川泳ぎして居た悪太郎が其時は一丈もあろうと思うた程の大きな青大将の死んだのを路の中央に横たえて恐れて逡巡する彼を川の中から手を拍って笑った。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――或る日、私はその小さな村を真ん中から二等分している一すじの掘割に、いくつとなく架けられている古い木の橋の一つの袂に、学校帰りらしい村の子供たちが一塊りになっているのを認めた。",
              "citation": {
                "source": "三つの挿話",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "同級というだけで、ふだん余りに言葉も交わさないでいた間柄であったが、読みたさの一念から学校帰りに臆面もなく、その家を尋ねて行ったのである。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物人の中に、学校帰りの少年が二人いました。",
              "citation": {
                "source": "すずめ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前稽古に来る小娘達が帰つて後午過には三時過ぎてからでなくては、学校帰りの娘達はやつて来ぬ。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前稽古に来る小娘たちが帰って後午過には三時過ぎてからでなくては、学校帰りの娘たちはやって来ぬ。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、田舎の停車場にゐた学校帰りらしい数人の女学生に、ストラツトフオードへ行くには、どの汽車に乗つたらいゝかと訊くと、「それは今度此処を出る汽車に乗つて、一度乗り換へねばならぬ。",
              "citation": {
                "source": "幼少の思ひ出",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫くすると、学校帰りの子供等の一隊が土堤を占領してデモごっこをはじめた。",
              "citation": {
                "source": "鋳物工場",
                "author": "戸田豊子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると袴をはいた学校帰りの姿が、廊下の角にチラと見えることはあつたが、それもすぐに下座敷の寂びた状態に吸ひ込まれてしまふのが常だつた。",
              "citation": {
                "source": "朧夜",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "神学校帰りがありますね』　小僧が下からお茶を運んで来た。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校帰りにはアケビば取つてくれては、私の口に入れてくれた。",
              "citation": {
                "source": "妻恋行",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何日目かでやっと若様にお目にかかれました、それはランドセルを背負った学校帰りの可愛いいお姿でした、飛び付きたいような心をジッとおさえ、甦ったような喜びに胸を跳らせながら花はお顔を見詰めて居りました。",
              "citation": {
                "source": "美人鷹匠",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからふだんから考えておいた質問を、学校帰りの子供四、五人に、答え易い、考え易い言葉で話しかけて見ることにしている。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　日毎に彼は青沼の学校帰りが待たれると同時に、親友の顔を日の光のなかに見てみたいと思う心が劇しくなりはじめた。",
              "citation": {
                "source": "あめんちあ",
                "author": "富ノ沢麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　浜は学校帰りの子供たちをまじえてだんだん活気づいてきた。",
              "citation": {
                "source": "大根の葉",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校帰りの女の子がおおぜいつながって、電車通りを横切っていった。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
