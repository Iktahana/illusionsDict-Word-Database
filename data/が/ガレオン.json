        "examples": {
          "standard": [
            {
              "text": "歴史映画で、大航海時代のガレオン船が大海原を力強く進むシーンに感動した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "博物館には、17世紀に実際に使われていたガレオンの巨大な模型が展示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "海賊の物語を読むと、いつもガレオンに乗り込んで宝探しに出かける想像をする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "港に停泊しているガレオンは、その堂々たる姿で訪れる人々を魅了していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "スペイン無敵艦隊の壊滅後、ガレオン船の生存者から学びました。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "この模様はスペイン無敵艦隊が負けた後、難破したガレオン船からもたらされたものです。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
