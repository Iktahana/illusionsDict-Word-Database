          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "水をがぶがぶ飲みすぎて、お腹の中で音がする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「うわ、お腹で水ががぶがぶ言ってるよ」と、弟が笑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大量のスープを飲んだ後、走るとお腹の中でがぶがぶと液体が揺れるのが分かる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
