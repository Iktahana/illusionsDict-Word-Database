[
  {
    "uuid": "62c79cbd-c15e-5ebd-b5f4-82e243864021",
    "entry": "がぶがぶ",
    "reading": {
      "primary": "がぶがぶ",
      "alternatives": [
        "ガブガブ"
      ],
