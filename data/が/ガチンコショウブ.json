        "examples": {
          "standard": [
            {
              "text": "サッカーの決勝戦、両チームとも譲らず、まさにガチンコ勝負になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "格闘技のタイトルマッチで、チャンピオンと挑戦者がリングでガチンコ勝負を繰り広げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "会議で新企画の承認を巡り、賛成派と反対派がガチンコ勝負を繰り広げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供たちが公園で「どっちが強いか」と、取っ組み合いのガチンコ勝負を始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それが乗り込んできた本流のコンピューター屋が作ったＰＣ―９８０１と同門のガチンコ勝負となって、破れ去った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
