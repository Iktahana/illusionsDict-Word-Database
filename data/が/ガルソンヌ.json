        "examples": {
          "standard": [
            {
              "text": "彼女のショートヘアとパンツスタイルは、まさにガルソンヌ風の粋な着こなしだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「最近、ガルソンヌ系のファッションがまた注目されているみたいだよ」と、雑誌で読んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このジャケット、ちょっとボーイッシュでガルソンヌっぽいね」と、試着しながら鏡を見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "前大戦の後ではフランスが今の日本と同じことで、ガルソンヌなどゝいふ実験少女が現れたものだ。",
              "citation": {
                "source": "破門",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "実験から実験へ、更により良き結果をもとめて、その生涯を実験室で終るやうなガルソンヌはめつたにゐない。",
              "citation": {
                "source": "破門",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
