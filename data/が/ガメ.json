    "definitions": [
      {
        "index": 1,
        "gloss": "Gamay (wine grape variety)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ボジョレー・ヌーヴォーに使われるブドウ品種は、ガメだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この赤ワインは、ガメ種特有のフルーティーな香りが特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ガメ種のワインは、軽やかで飲みやすいから、食事にも合わせやすいよね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "けれども、或る静かに晴れ渡った午後の事、ウミガメの卵を焼いて食べたあとで、二人が砂原に足を投げ出して、はるかの海の上を辷って行く白い雲を見つめているうちにアヤ子はフイと、こんな事を云い出しました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしておけば、救いの船が来ても通り過ぎて行くだろう」　こう考えて、何かしらゲラゲラと嘲り笑いながら、残狼のように崖を馳け降りて、小舎の中へ馳け込みますと、詩篇の処を開いてあった聖書を取り上げて、ウミガメの卵を焼いた火の残りの上に載せ、上から枯れ草を投げかけて焔を吹き立てました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレカラ　花タチハ　ジブンタチノ　スガタヲ　ナガメアヒ、ジブンタチカラ　ナガレデル　ニホヒヲバ　カギアツテ、ジブンタチガ　ミナ　オナジヤウニ　キイロイ　キモノヲ　キテ　ヲリ、ホカノ　木ヤ　クサニ　マケナイホド　ウツクシイノヲ　シツテ　イツソウ　ヨロコビアヒマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつはタガメだ」　こういう評判が金魚家仲間に立った。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "タガメは金魚に取付くのに凶暴性を持つ害虫である。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "トリツク怒濤、実ハ楽シキ小波、スベテ、コレ、ワガ命、シバラクモ生キ伸ビテミタイ下心ノ所為、東京ノオリンピック見テカラ死ニタイ、読者ソウカト軽クウナズキ、深キトガメダテ、シテハナラヌゾ。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、少女サビツがギルガメシュを慰めた言葉をも諳んじている。",
              "citation": {
                "source": "文字禍",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "読み、諳んじ、愛撫するだけではあきたらず、それを愛するの余りに、彼は、ギルガメシュ伝説の最古版の粘土板を噛砕き、水に溶かして飲んでしまったことがある。",
              "citation": {
                "source": "文字禍",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この多那川橋の附近に定住の乞食は文公の外に新参のわたくしを入れて六人いますが、文吉が始終関心を持つのはタガメと通称されるタカリ専門の乞食と、ヅケを貰って歩くお三という母子乞食でした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "川下のは長門といってそこに毘沙門堂があってタガメが住んでいます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文吉は一度もその所業を受けたことはないが「ぐず／＼言うと水｜雑炊を喰わすぞ」という言葉はタガメの口からよく聞いています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとタガメは「ふう、感心なやつだ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとタガメは手を離して、「はあ、ばか面がちっとは緊ったようだ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文吉はまるで旋風に見舞われたあとのようにぼんやりするだけですが、タガメは人間の思わぬ急所を知っている怪物のようで、出来ることなら避けたがっています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も文吉は、また川下のタガメを警戒するように密閉した真菰の塀から覗き、川上の母子乞食の方を覗きしながら食事を終えました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "くの字に曲って来て、お秀の貸船屋の前の淵に突当った水は、その反動でタガメの住む対岸の毘沙門堂の洲を作り、またこちらの岸にうち当てゝ象の鼻の瀞となっています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃物の乞食の中から花田は、わたくしを倶楽部の娘に拾い上げたように、この町の乞食の、子持ちのお三も、タガメも、たんばも、瀬戸勘も、髭の兵庫島も――みな、それ／″＼拾い上げて花田と啓司の指図の何かしらの職持ちになったのは、二人の慈善心より、より多く市に人手｜払底のためでしょう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――バクチは負けるほど、面白いんだ」　半ば自分に言いきかせながら、京吉はガメっていたが、テンパイになった途端に、いつも上りパイを押えられていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで上り框に腰をかけて懐中からその貰うた指環をば出いて、掌の中央へ乗せて、タメツ、スガメツ引っくり返いておりますと、背後からヌキ足さし足、覗いて見た親父が、大きな拳骨で私の頭をゴツウ――ンと一つ啖らわせました。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大映系は『大魔神』と『ガメラ対バルゴン』で、これも見にいった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ガメラ』のほうは、慶一としては、もう、こういう映画に関心がなくなったのだ、とじぶんを納得させるしかないような代物だった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねばれる蛇の卵見ゆ、かつは臭のくさければガメノシユブタケ顰めつつ毛根を水に顫はす。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "２．ガメノシユブタ。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねばれる蛇の卵見ゆ、かつは臭のくさければ＊ガメノシユブタケ顰めつつ毛根を水に顫はす。",
              "citation": {
                "source": "思ひ出",
                "author": "抒情小曲集",
                "note": "青空文庫"
              }
            },
            {
              "text": "２．　ガメノシユブタ。",
              "citation": {
                "source": "思ひ出",
                "author": "抒情小曲集",
                "note": "青空文庫"
              }
            },
            {
              "text": "他家が三飜ものを三副露して或る種の牌が包となっているために場が緊張しているとか、又は自分でも一生懸命大きい役をガメクッているとか、兎に角三百｜符乃至満貫近いものが出来ようとしている場合に、一人の面子が「ハイッ和り、二十二」と和っちまう。",
              "citation": {
                "source": "麻雀インチキ物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "町には、貝がらだの、珊瑚だの、極楽鳥の標本だの、大きな剥製のトカゲだの、きれいにみがいてあるべっこうガメの甲羅などを売っていて、みんなほしくなった。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの臭ガメに至つては二月に入つてからあらはれた。",
              "citation": {
                "source": "ジガ蜂",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "臭ガメのあの臭い汁も今ではもう蒸発し切つてゐるやうだつた。",
              "citation": {
                "source": "ジガ蜂",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷村さんは、強度の近眼鏡をずり上げて、まず、その髪の毛が、太つちよの下女のであろうか、干鮭のようなスガメの下女のであろうかと、箸を持つた手でそツと蜆汁の中から引き上げて見ました。",
              "citation": {
                "source": "清修館挿話",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
