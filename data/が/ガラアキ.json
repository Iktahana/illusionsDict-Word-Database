        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "相手チームの守備はがら空きで、簡単にゴールを奪えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの部署は人員不足で、セキュリティにがら空きの部分がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "油断して中央をがら空きにしたため、一気に攻め込まれてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
