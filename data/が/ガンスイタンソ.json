        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "栄養学の古い文献を調べていると、「含水炭素」という言葉が使われていることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "教授は、含水炭素が今日の「炭水化物」と同じものを指す言葉だと説明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "成分表示をよく見たら、専門用語で「含水炭素」と記載されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "（明治四十一年一月一日『東京朝日新聞』）　　　　　　　　　五十九　　　　　　結核病と食物　結核菌を接種した動物に種々の食物を与えて病の経過を試験した結果によると、脂肪分を主に与えたものは四十日くらいで死し、含水炭素殊に砂糖を多く与えたものは八十七日くらいで死んだ。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も動物性食品には含水炭素が殆んどないからこれは当然植物から採らなければならない。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次にその残りの各々から蛋白質脂肪含水炭素の可消化量を計算してそれから各の発する熱量を計算して合計します。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛋白質は十八ポイント五パアセント、脂肪は九ポイント三パーセント、含水炭素は一ポイント二パーセントもあるのです。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "成分は蛋白質が二二パアセント、脂肪が十八ポイント七パアセント、含水炭素が零ポイント九パアセントですが、これは只今ではあんまり重要じゃありません。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人体は蛋白質と脂肪と、含水炭素とから成立つてゐるだけだと云つてゐる。",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "その衛生講演会の壇上に現れたのは、近頃売出しの若い衛生学者で、蛋白質と澱粉と含水炭素と等分に混ぜて模範的に試験管のなかで拵へたやうな身体をしてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "○黒豆は蛋白質四割、脂肪壱割八分、含水炭素弐割弐分あり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛋白質弐割四分、脂肪五割、含水炭素壱割二分ありて滋養分多し。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "○薩摩芋は蛋白質一分五厘、脂肪二厘、含水炭素三割、繊維弐分四厘ほどあり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "○里芋は蛋白質弐分、脂肪二厘、含水炭素壱割五分、繊維七厘なり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本葱は蛋白質一分五厘、脂肪二厘、含水炭素四分八厘を含む。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "球葱は蛋白質一分六厘、脂肪一分、含水炭素八分三厘を含む。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "○豌豆は蛋白質弐割弐分、脂肪二分、含水炭素五割あり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "○赤茄子は蛋白質八厘八毛、脂肪一厘、含水炭素三分六厘ありて九割余は水分なり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "食物の成分として十九貫目の人は一日に蛋白質百十八｜瓦即ちおよそ三十｜匁、脂肪が五十六瓦即ち十四匁、含水炭素が五百瓦即ち百二十匁にその余は水分とこう極めてある。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人は通常十三貫目位の平均だから一日に蛋白質二十匁脂肪九匁含水炭素八十匁位が適当だ。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛋白質と脂肪は重に肉や乳にあって含水炭素は野菜や穀物にあるから肉と野菜の分量もその割合で定めなければならん。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "○医学博士ケルネル氏は日本人のために日本風の献立表を蛋白質と脂肪と含水炭素の割合にて左の如く定められたり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにて蛋白質が二十二匁ほど、脂肪が六匁ほど、含水炭素が百十匁ほどとなる。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ジャガ薯は蛋白質二分三厘、脂肪三厘、含水炭素二割あり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "○蚕豆の上等は百分中に蛋白質が弐割八分余、脂肪が一分三厘、含水炭素が四割九分、繊維が一分二厘、余は水分なり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "○百合は百分中蛋白質三分三厘余、含水炭素二割四分なり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "○南京豆は蛋白質二割四分、脂肪五割、含水炭素一割二分、繊維四分あり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "○人参は蛋白質一分二厘五毛、含水炭素七分四厘、繊維一分一厘等にて殆ど九割は水分なり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "上等品にて蛋白質一分八厘、含水炭素二分七厘、繊維七厘、水分九割四分なり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の本望は達したよ」と聞いて大原立上って雀躍し「ありがたい、モー病気全快だ」○人参は蛋白質一分二厘五毛、脂肪三厘五毛、含水炭素七分四厘、繊維六分八厘、他は水分なり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ホウレン草は蛋白質二分三厘、脂肪二厘七毛、含水炭素一分六厘五毛、繊維五厘七毛、鉱物質一分三厘、他は水分なり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ジャガ芋は蛋白質二分三厘、脂肪三厘、含水炭素弐割、繊維一分、鉱物質一分、他は水分。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "○パンは日本製にて蛋白質五分五厘、脂肪二厘、含水炭素五割五分、繊維一分九毛、鉱物質七厘三毛、水分三割七分三毛なり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
