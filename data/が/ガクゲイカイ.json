        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『お前は明後日の学芸会で、何を云ったらいいか考えているだろう。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっとあの生徒は学芸会でそれを云ったんだ。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先頃学芸会があったのでしたが、その時ちゃんと、狐に遭ったことから何から、みんな話していたのです。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「学芸会へ出ているようなものよ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "学芸会はみんな鼻の上に汗をためてるわ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に成績がよくて学芸会に出ることを約束されてゐる児童達がさうだつた。",
              "citation": {
                "source": "登つていつた少年",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は誰と誰を学芸会に出すかを定めるためそんなことをしたのに違ひない。",
              "citation": {
                "source": "登つていつた少年",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「学芸会には何をしようか」と先生は嬉しさに輝き始めた少年と少女達の顔を見下してくすぐつたさうに言つた。",
              "citation": {
                "source": "登つていつた少年",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の前には白衣のツルが立つてゐたが、そこは観客の一ぱいゐる学芸会場であつた。",
              "citation": {
                "source": "登つていつた少年",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "学芸会みたいな稚拙なところもある。",
              "citation": {
                "source": "芸術ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎左衛門のねえさんは、女学校でする学芸会の練習をしていたのである。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからしばらく、久助君は、太郎左衛門の屋敷の門の前を通るときにはきっと、ふじの花のさいている明るい昼間だというのに、ランプをつけて学芸会の劇を練習している、色の白いぶきみな少女のことを思い出したのである。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとどうしたわけか、学芸会のけいこをしていた太郎左衛門のねえさんを思い出した。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂの表紙には、プラトンがオリムピツクの学芸会で「芸術否定論」を発表してゐる姿、裏は――未だ無地で、何を描かうかと此頃でも考へてゐる――「喜劇論」に関する抜萃帳である。",
              "citation": {
                "source": "真夏の夜の夢",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――じゃ、小山に入ってもらうか」　英語劇「ジュリアス・シーザー」――それが近づく学芸会に、女学部三年が出すプログラムだった。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの学芸会の練習のとき、あたしが誰かに殺されてしまったと思ったお話を、もう一度してちょうだいナ」　ミチミは、テーブルの向うから、杜の顔をのぞきこむようにして囁いた。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時か、饗庭芳子が、学芸会の席で、鎌倉を暗誦して読みあげたことがあったが、実にいい声であった。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちようど、夜のまどゐに、学芸会に、日頃の覚えを語りだす情熱あふれる若人達の物語のやうに。",
              "citation": {
                "source": "かげろふ談義",
                "author": "――菱山修三へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくプルウストやバルザックが婦人達にその物語を披露するとき、その精神も情熱も、学芸会の若人以上に高遠であつたとは言へますまい。",
              "citation": {
                "source": "かげろふ談義",
                "author": "――菱山修三へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は少年の頃、学芸会の余興なんぞに、落語を語るのが得意でしたつけ。",
              "citation": {
                "source": "かげろふ談義",
                "author": "――菱山修三へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "女子大在学中既に油絵を画いていたらしく、学芸会に於ける学生劇の背景製作などをいつも引きうけて居たという事であり、故郷の両親が初めは反対していたのに遂に画家になる事を承認したのも、其頃画いた祖父の肖像画の出来栄が故郷の人達を驚かしたのに因ると伝え聞いている。",
              "citation": {
                "source": "智恵子の半生",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女子大在学中既に油絵を画いてゐたらしく、学芸会に於ける学生劇の背景製作などをいつも引きうけて居たといふ事であり、故郷の両親が初めは反対してゐたのに遂に画家になる事を承認したのも、其頃画いた祖父の肖像画の出来｜栄が故郷の人達を驚かしたのに因ると伝へ聞いてゐる。",
              "citation": {
                "source": "智恵子抄",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとその年の小学校の学芸会に、ばくちの最中にふみこまれてあげられるという劇がでた。",
              "citation": {
                "source": "中庸",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから学芸会だの、おひな祭りなどには、講堂の舞台上で活躍をした。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "学芸会に独唱をしたり劇に出たりした。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校復興のバザーだとか学芸会音楽会がしきりにもよおされるようになった。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "学芸会の大がかりな余興のような乳くさいところがあっても、そこにコンゼンたる構成があってオヤジが娘の出来栄えにハラハラしなければならないような危ッかしさがなければ何よりの娯楽の一ツに数えうるであろう。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに大がかりで、良く出来た学芸会というのが今までの宝塚の性格なのである。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "学芸会などでは、委員ぶりがなかなか鮮やかで、参観人がよく先生と間違へるといふほどの凜々しさであるが、梨枝子と二人きりの時は、まるで行儀がわるく、大胆な議論を吹きかけるかと思へば、急に、コケチッシュな身ぶりで彼女を面喰はせる。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　学芸会の時、気の合った友達と計画的なことをして、一人は、有産階級の存在を攻撃する熱弁をふるって「弁士中止」をくらい、他の一人は、白髪の校長を骨董品にたとえて攻撃し、これもまた「弁士中止」をくらった。",
              "citation": {
                "source": "初恋のやり直し",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
