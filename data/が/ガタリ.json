        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "重い本棚が崩れ、本が床にがたりと散らばった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "突然、トラックが電柱にがたりとぶつかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は驚きのあまり、持っていたカップを床に落とし、がたりと音を立てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "扉が風で激しく打ち付けられ、がたりと大きな音がした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "三味も同じこと、琴は西片町あたりの垣根ごしに聞たるが、いと良き月に弾く人のかげも見まほしく、物がたりめきて床しかりし。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはれかかる夜よ、歌よむ友のたれかれ集ひて、静かに浮世の外の物がたりなど言ひ交はしつるはと、俄かにそのわたり恋しう涙ぐまるゝに、友に別れし雁｜唯一つ、空に声して何処にかゆく。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（板を壁にがたりと寄せ掛く。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "からくみやこにたどりける、　　　芝雀は旅をものがたり、「その小屋掛けのうしろには、　　寒げなる山によきによきと、立ちし」とばかり口つぐみ、　　　とみにわらひにまぎらして、渋茶をしげにのみしてふ、　　　　そのことまことうべなれや。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ほんとうに、こんなオホーツク海のなぎさに座って乾いて飛んで来る砂やはまなすのいい匂を送って来る風のきれぎれのものがたりを聴いているとほんとうに不思議な気持がするのでした。",
              "citation": {
                "source": "サガレンと八月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "座頭、琵琶箱を負ひて、がたりびしりと欄干を探り居たり。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――琵琶箱負ひたる丈高きしたゝかな座頭一人、人通もなき闇川橋の欄干を、杖以てがたりびしりと探る――其の頭上には怪しき雲のむら／＼とかゝるのが自然と見える。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "分けて爰に、がたりびしりは、文章の冴で、杖の音が物凄く耳に響く。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あつ、」と越中、がたり鐙を投り出し、馬にひらりと乗るより疾く、一｜散に遁げて行く。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは團水が、朝顔の花につけ、面白く想を構へて作り出せるものがたりなり。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "花もめでたし、ものがたりもめでたし。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "睛、沁芳の泉、楓露の茗四つのものを捧げ、嘔心の文を念じつ祭りしといへるものがたりいとをかし。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、わたくしは、これらのちいさなものがたりの幾きれかが、おしまひ、あなたのすきとほつたほんたうのたべものになることを、どんなにねがふかわかりません。",
              "citation": {
                "source": "『注文の多い料理店』序",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、わたくしは、これらのちいさなものがたりの幾きれかが、おしまい、あなたのすきとおったほんとうのたべものになることを、どんなにねがうかわかりません。",
              "citation": {
                "source": "『注文の多い料理店』序",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸はがたりとひらき、犬どもは吸い込まれるように飛んで行きました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でんしんばしらはしずかにうなり、シグナルはがたりとあがって、月はまたうろこ雲のなかにはいりました。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉の方は、天か地か、まるで幽明処を隔つ、遠い昔のものがたりの中に住むか、目近に姿ばかりの錦絵を見るようだろう。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と見る、目の前へ、黄色い提灯の灯が流れて、がたりと青く塗つた函車を曳出すものあり。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "草履を土間に脱いで、一渡店の売物に目を配ると、真中に釣した古いブリキの笠の洋燈は暗いが、駄菓子にも飴にも、鼠は着かなかった、がたりという音もなし、納戸の暗がりは細流のような蚊の声で、耳の底に響くばかりなり。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　表の戸をがたりと開けて、横柄に、澄して、「おい、」　　　　　　　二十三　声を聞くとお雪は身を窘めて小さくなった。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨が続いて泥濘になったのを見澄して、滝太が手で掬い、丸太で掘って、地面を窪めておき、木戸に立って車の来るのを待っていると、窪は雨溜で探りが入らず、来るほどの車は皆輪が喰い込んで、がたりとなる。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "若ばけものは、がたりと椅子から落ちました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "５　水仙月の四日赤い毛布を被ぎ、「カリメラ」の銅鍋や青い焔を考えながら雪の高原を歩いていたこどもと、「雪婆ンゴ」や雪狼、雪童子とのものがたり。",
              "citation": {
                "source": "『注文の多い料理店』新刊案内",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "月は慘たり、月下の海上に砲火迸り、硝煙朦朧と立昇る光景は、昔がたりのタラント灣の夜戰もかくやと想はるゝばかり。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "表に人のくるけはひがして、がたりと轅棒の下りた音がした。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸はがたりとひらき、犬どもは吸ひ込まれるやうに飛んで行きました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でんしんばしらはしづかにうなり、シグナルはがたりとあがつて、月はまたうろこ雲のなかにはひりました。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と度外れの大声に耳を驚かして眼を開けば、梶棒をがたりと下して、「夫人提灯を点けますからちょいとどうぞ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大棍元教の大先達が百ものがたりの、はなれ屋の破行燈で、塔婆を抱いて寝たと言えば、可恐さを恐れぬ、不気味さにひるまない、行力法力の功徳として一代記にかき込まれるんだ。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
