        "examples": {
          "standard": [
            {
              "text": "「あの不動産屋、がめついこと言って手数料を上乗せしてきやがった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「そんなにがめつく稼いで、一体何に使うつもりなんだ？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おっ、がめつくおかわりを狙ってるな？まだ鍋の底に鶏肉が残ってるぞ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「がめつい商売を続けていると、そのうち誰にも相手にされなくなるぞ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "こんながめつい世の中で、われ関せずに出会おうとはそうあることじゃない。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "依頼人はとてもがめついですよ。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "シティ界隈でエリクソン社の両人以上にがめつい卑劣漢はいなかった。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            }
          ]
        }
