        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夏の暑さをしのぐために、通気性が良く、ゆったりとしたガウチョパンツを購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "リゾート地では、リラックスした雰囲気を演出するガウチョパンツを履いた観光客を多く見かけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このガウチョパンツ、本当に動きやすくて、普段使いにぴったり！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
