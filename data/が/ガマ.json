    "definitions": [
      {
        "index": 1,
        "gloss": "common cattail (Typha latifolia)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "池のほとりには、背の高い蒲の群生が風に揺れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、川辺で蒲の穂を摘んで、ふわふわした部分で遊んだ記憶がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "蒲の葉で編まれたむしろは、昔から日よけや敷物として重宝されてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "やや長じて後は、蒲原有明氏や北原白秋氏の作を讀んだ。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "この自選詩集に對する不滿は、蒲原有明氏についても同じであつた。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり言へば薄田泣菫氏や蒲原有明氏やは、或る若い時代だけ詩人であり、後に年を取つてからは、本質的にそのリリシズムを喪失してしまつたのである。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうこの部屋で海賊の打ち合せをしようと思ってね」　私は馬場の興奮に釣られてうろうろしはじめ、蒲団を蹴って起きあがり、馬場とふたりで腐りかけた雨戸をがたぴしこじあけた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時頃、私は私の蒲団だけさきに畳む事にした。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言って、また蒲団を頭からかぶった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲団だけは今晩荷を解かなければならないと思ふことが、異常な落胆を呼び起すのであつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐは蒲団の上に仰向きになれなくて、暫くは枕に肘を突いてゐたが、つらいことだつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺がみんなと、もう一足といふ所で捏造になる所まで喋舌ることを耕二は知つてゐるからだ」と兄はさう考へると今暗い部屋の中に、小さな蒲団にくるまつて寝てゐるであらう耕二がとてつもなく気味の悪いものに思へた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏祭の日には、家々の軒に、あやめや、菖蒲や、百合などの草花を挿して置くので、それが雨に濡れて茂り、町中が忽ち青々たる草原のようになってしまう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲公英の忘れ花あり路の霜　小景小情。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽春の日に、蒲公英の咲く長堤を逍遥するのは、蕪村の最も好んだリリシズムであるが、しかも都会の旗亭につとめて、春情学び得たる浪花風流の少女と道連れになり、喃々戯語を交して春光の下を歩いた記憶は、蕪村にとって永く忘れられないイメージだったろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春風馬堤曲に歌われた藪入りの少女は、こうした蕪村の詩情において、蒲公英の咲く野景と共に、永く残ったイメージの恋人であったろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "読み終わった本を枕もとへ置いて、蒲団をかぶって聞いていると、音楽の波に誘われて物語の幻は幾度となく繰り返し繰り返し現われた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今でもこの曲を聞くと、蒲団の外に出して書物をささえた私の指先に、しみじみしみ込むようであった春寒をも思い出すのである。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲団を積んだ手荷車が盲長屋の裏を向うへ、ゆるやかな坂を向うへ上って行く。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どう考えてもこの蒲団の行方は分からない。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "余所の蒲団の行先は分からない。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雀が来てそれを食うと間もなく酔を発して好い気持になり、やがてその柿の葉を有合わせの蒲団にしてぐっすり寝込んでしまう。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには蒲や菱が叢生し、そうしてわれわれが「蝶々｜蜻蛉」と名付けていた珍しい蜻蛉が沢山に飛んでいた。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜明けの三時までさまざまの議論をいたしましたが、雌雄決せぬままに蒲團にぶつたふれて寢てしまひました。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも力無い咳をして、さうして顏色も惡く、朝起きて部屋の障子にはたきを掛け、帚で塵を掃き出すと、もう、ぐつたりして、あとは、一日一ぱい机の傍で寢たり起きたり何やら蠢動して、夕食をすますと、すぐ自分でさつさと蒲團を敷いて寢てしまふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お照さんは小さい赤い絹蒲團を掛けて寢てゐた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "花袋は、その後「蒲団」や「一兵卒」など自然主義派の見本のような小説を作って、国木田独歩、岩野泡鳴ら同主義の作家と呼応して、自然主義を文壇思潮の主流たらしめ、硯友社その他の既成老衰作家などを、ひとたまりもなく押し流してしまった。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀明水に達したるは午後七時に垂んとす、浅間社前の大石室に泊す、客は余を併せて四組七人、乾魚一枚、麩の味噌汁一杯、天保銭大の沢庵二切、晩餐の総べては是の如きのみ、葉マキ虫の葉を綴りて寝ぬる如く、一同皆｜蒲団に包まりて一睡す。",
              "citation": {
                "source": "霧の不二、月の不二",
                "author": "――明治三十六年八月七日御殿場口にて観察――",
                "note": "青空文庫"
              }
            },
            {
              "text": "小渋川よりも、川幅が狭くて、谷地が、かえって濶いだけに、徒渉の回数は少い、深山の渓流としては、先ず安楽な方で、小渋川や、槍ヶ岳の蒲田谷などとは、深さと、急と、嶮しさとにおいて、到底、比べられない。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十三日　蒲田谷に下り、右俣に入りて、蒲田温泉に一泊。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十四日　蒲田より白水谷を渉り、中尾を経て、割谷に沿い、焼岳（硫黄山）の新旧噴火口を探りて、再び上高地温泉に一泊。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中からは、ざんざ降りで、尾根伝いの笠ヶ岳登りを見合せて、蒲田谷へ下りるより、外にしようはなかった。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもおまへはわがままに親しい人だと歌つてきかせる。",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
