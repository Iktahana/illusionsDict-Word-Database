    "definitions": [
      {
        "index": 1,
        "gloss": "with a clashing or clanging sound",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "車のドアをガチッと閉めたら、隣で驚いた顔をしてた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "リュックのバックルをガチッと留めて、さあ出発だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "鍵を差し込んで、ドアをガチッと施錠した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その男は、ガチッと引鉄を引いた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "数言の強迫的な文句の後、かんぬきが、ガチッとはずされた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うの隅でも銃を取って立ちあがると、ガチッと遊底を鳴らして弾丸をこめる者があった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」彼は、ガチッと下駄を踏み鳴らした。",
              "citation": {
                "source": "失題",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "射術にかけては、少年の間は勿論大人のアイヌの間にも有名なキクッタですから、大熊はその場に地響きさして、ぶつ仆れた――はずですが、不幸、ガチッと音がして、不発でした。",
              "citation": {
                "source": "熊捕り競争",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と叫んで再び斬込み、ガチッと音がして、吉村の刀が仙太の刀にからみついたようになって、そのまま間。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と叫んで再び斬込み、ガチッと音がして、吉村の刀が仙太の刀にからみ付いたようになって、そのまま間。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガチッと、掌のなかで、錠の角が刎ねた。",
              "citation": {
                "source": "雲霧閻魔帳",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三度、四度失敗したあとで、ガチッと、手ごたえがありました。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、かぎが、へいのうらの出っぱりに、ガチッと、ひっかかり、いくらひっぱっても、はずれないようになったのです。",
              "citation": {
                "source": "鉄塔の怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口のドアに近よって、とってをまわしてみると、ガチッと音がして、たやすく開いたではありませんか。",
              "citation": {
                "source": "魔法人形",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
