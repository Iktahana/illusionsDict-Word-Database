    "definitions": [
      {
        "index": 1,
        "gloss": "where one has gone to",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（こんなことに馴れ切っているのかしら、それとも止むを得ぬ外出先なのだろうかしら）などと、新子は去った夫人と残っているご良人とのことを等分に考えていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "とこう書いた途端にオレの脳裏には、「通信可能の我がマシンとどこがどう違うわけ」とガンをとばすネットワーカーの凶相が浮かんだが、ここで言う電話とは、外出先に番号ごと付いてきてくれる無線電話である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その當時の或る夜自分は十時頃でもあつたか外出先から歸つて來た。",
              "citation": {
                "source": "一家",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "外出先で一泊して、あくる日帰ろうとすると、いつの間にか馬も供人も居なくなっている。",
              "citation": {
                "source": "女強盗",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――が、再び引き返して、眼鏡を執りあげて見ると、丁度其処に外出先から娘が戻つて来たところであつた。",
              "citation": {
                "source": "風媒結婚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "外出先きから戻る時に、吾家の門をくゞる十間前から「貧・福、貧・福、貧・福。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日の日課のために、外出先から歸つて來なければならぬといふことが、不機嫌のたねであるらしかつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "家に居ても、外出先でも、たえず酒につかって居た。",
              "citation": {
                "source": "犬神",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは外出先きから帰って来られた塾の人の跫音だったのです。",
              "citation": {
                "source": "絹と紙の話と師弟の間柄の話",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月のはじめ、外出先から私が帰つて来て門の郵便箱を開けて見ますと、そこにまた三角形の印のついた手紙が来ています。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしどんなに心配したかしれなかつたの」　外出先から歸つて來た親を出迎へる邪氣ない子供のやうに千登世は幾らか嬌垂ながら圭一郎の手を引つ張るやうにして、そして二人は電車通りから程遠くない隱れ家の二階に歸つた。",
              "citation": {
                "source": "業苦",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルファベット四〇字を八行表示できる大型の液晶ディスプレイを備えた八ビット機で、これにワードプロセッサーと通信のためのソフトウエア、モデムを組み込んでおき、外出先で書き終えた原稿をそのまま電話で送れるようにするという。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベニ、外出先からすぐ帰って来る。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "外出先から帰宅すると、先ず第一にその安否を確かめる。",
              "citation": {
                "source": "同感",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が外出先から帰って来るときには、家に入らない前に咳でわかる、と亡妻はいっていたし、私が在宅か否かは咳が聞えるかどうかで判断することができる、と隣の人たちはいっている。",
              "citation": {
                "source": "思索者の日記",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "当人は外出先から帰る途中、筋向うの荒物屋へ立寄て煙草を買い、それから家へ帰ると表戸が閉っていたので、暫時戸を叩いたが返事がなかった。",
              "citation": {
                "source": "秘められたる挿話",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "「外出先から帰宅せられたあなたは、家政婦を呼び出して、コップへ水を一ぱい持って来るように命じ、家政婦が勝手の方へ行った留守の間に、あなたはピストルを持って家政婦の居間へ入り、それをしたのです。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し頭をぼつとさせて、外出先から家に歸りつくと間もなく、有島壬生馬さんの令弟のＹ君が見えた。",
              "citation": {
                "source": "七月七日",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "外出の際に踏むに限つて居ないで、外出先でも踏む。",
              "citation": {
                "source": "「とこよ」と「まれびと」と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふむ」行事を行うた処には、悪霊が居なくなると言ふ考へから出たもので、外出先で行うた僅かな例の方が、寧古風なのである。",
              "citation": {
                "source": "「とこよ」と「まれびと」と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝに哀れなのは富子で、ある日外出先から戻つてみると、着物が全部なくなつてゐる。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年探偵の三浦三吉は、今しも外出先から汗まみれになって帰って来たところだ。",
              "citation": {
                "source": "地中魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いで言ふが、私もたまには外出先でふとその気になつたり、変つた土地へ旅に出たりすると、ちよつとした土産を買つて帰ることがある。",
              "citation": {
                "source": "一つの挿話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この前は、うちの家内の神経のせいじゃろうと、あまり問題にもしないでいましたが、こうたびたび現われるようだと、あれは本当に幽霊かもしれんですなあ」　外出先から帰ってきた雪子の父親武平がさわぎの仲間に加わって、こんな感想をのべた。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……大抵、神父様お一人で毎日のお弥撒をなさいます」　私達がそんな立ち話をし出しているところへ、丁度外出先からその独逸人だとかいう神父が帰って来た。",
              "citation": {
                "source": "風立ちぬ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "めっきり元気がありませんね」「別にどうということもないが、外出先で例のオナラの方に気を配っているのでな」「それは気がつきませんでした。",
              "citation": {
                "source": "お奈良さま",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一軍の将たらんとするもの、この悪習を一日も早く脱せねばならぬ、という風なのはまだ罪のないところだが、――余は本日、日曜の外出先に於て旧友と会し、たまたま彼が軍人を誹謗する言辞を弄するを聴き、痛憤に堪えず、遂にその頭上に鉄拳を加えたり。",
              "citation": {
                "source": "いわゆる「反省」は我々を救うか",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "グズ弁は諸般の状況判断や実地偵察等によって、ミヤ子の昼の外出先が中井のアパートであると突きとめたとき、直ちにこれぞ真の大敵であると直覚した。",
              "citation": {
                "source": "都会の中の孤島",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねてこういう疑いをいだいていたから、グズ弁はミヤ子の昼の外出先を突きとめるために異様な執念をもって行動した。",
              "citation": {
                "source": "都会の中の孤島",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "家をでる時はまだ雨も降っていなかったが、途中、彼のところへ寄り道して、山中生活の細い注意をきいたので時間をくい、（彼が外出先から戻るのを待っていたので時間をくったのだ）青梅の駅へ降りた時には猛烈なドシャ降りである。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
