        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "図書館の書庫には、歴史家の論文合集が厳重に保管されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この研究室には、戦前の文学作品の合集が多数収蔵されており、貴重な資料となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古文書の合集を紐解きながら、当時の人々の暮らしぶりを想像してみる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、大学図書館のOPACで、江戸時代の俳諧に関する合集を探している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "レヴューでは人間の集団で作った斑点や線条が舞台の上で離合集散いろいろの運動をする。",
              "citation": {
                "source": "踊る線条",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、少くとも僕は、他人の夫婦の離合集散や恋愛のてんまつなどに、失敬千万な興味などを持つような、そんな下品な男でだけは無いつもりだ。",
              "citation": {
                "source": "女類",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、その間に、詩集としては長歌の多くを收めた『觀想の秋』、長歌の綜合集『篁』及び短歌の選集『花樫』或は現代短歌全集中の『北原白秋集』等の刊行があり、『白秋全集』の歌集第二にも新作の一部は編入されてあるが、何れも單行の新作集でなかつた。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、その間に、詩集としては長歌の多くを収めた『観想の秋』、長歌の綜合集『篁』及び短歌の選集『花樫』或は現代短歌全集中の『北原白秋集』等の刊行があり、『白秋全集』の歌集第二にも新作の一部は編入されてあるが、何れも単行の新作集でなかつた。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大は歴史の推移転変から小は個人同士の離合集散まで、殆どこの「鼻の表現」に依って影響され支配されぬものは無いときまったら、そもそもどんな騒ぎが持上るでしょうか。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、かかる社十三、四を一所に合集せしめ、その基本財産を作れとて件の老樟をことごとく伐らしむ。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男の住居が黒島で、そこへその晩泊りますが、心あての俳友は大病、思いがけないその兄の内へともなわれる……何となく人間の離合集散に、不思議な隠約があるように思われて。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "離合集散、ともに自由にならない。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上の諸氏に對して心よりお禮を申述べ、併せてこれまでの詩集出版元が、この合集刊行について、快く同意せられたのに對し感謝いたします。",
              "citation": {
                "source": "詩集の後に",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち、その時代に、ギリシャに自然哲学者が出まして、宇宙及び人類の生成について考え万物の本源を地水火風の四元素に帰し、この四元素が離合集散して万象を形成して居るのだという所謂機械説を樹てたのであります。",
              "citation": {
                "source": "人工心臓",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "同宿四人、その一人は旅絵師で川合集声といふ老人、居士ともいふべき人物で、私が旅で逢つた人の中で最も話せる人の一人だつた、話が面白かつた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――離合集散の激しい食堂で、窓ぎはの涼しい場所に、何時も変らない顔が一人だけあつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "政党への訣別　これ以後の政治界は、「条約励行」を楔子にして、離合集散が行はれた。",
              "citation": {
                "source": "自由の使徒・島田三郎",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "既成政党員の離合集散、醜態の極みではありませんか。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "離合集散の過程はあるけれども、大きく別ければ、新協劇団系と築地座系とである。",
              "citation": {
                "source": "新劇の黎明",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとなればかの百貨の離合集散するゆえんのものはただこの機関あるがゆえなればなり。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこれらの諸元素が物理化学的方法によって離合集散するのが人生である。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "以来、新撰組の離合集散出処進退は、この両名が代表する社会的地盤に照すことなしには理解されない。",
              "citation": {
                "source": "新撰組",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "大庭先生に、よろしくね」　青木は思わずホッとして、のぼせた頭に、血がクラクラと離合集散、彼は冷汗をふいて、冷茶をグッと一パイのみほした。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "多数の噴湯丘を取り巻いて、離合集散する曲線と化した地獄谷内部の残雪のむれは、依然として縄紋土器に見られるような模様を現わしていた。",
              "citation": {
                "source": "黒部川を遡る",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "虚実烏鷺談議　離合集散ただならぬ関の孫六の大小、夜泣きの刀……。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "哲学者はこの世界が元子の離合集散に過ぎないこと、現世の享楽の前には何の恐るべきものもないことなどを答える。",
              "citation": {
                "source": "『偶像再興』序言",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三五二　愛欲を離れ、取なく、詞の訓釋に通達し、字の合集と（字の）前後とを知る人あらば、其の人こそ最後身を有する大慧者と謂はる。",
              "citation": {
                "source": "法句經",
                "author": "荻原雲來訳註",
                "note": "青空文庫"
              }
            },
            {
              "text": "この連中は、人生の離合集散も、哀別離苦も、さのみ問題にはしていない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "みちりやの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために排他的な徒党がうまれ、それが離合集散をくりかえし、反目と誹謗がいりみだれて、事が起こっても、殆んどその是非の判断がつかないようなありさまであった。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "無数の田氏が離合集散している世の中であった。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "乱雲の模様のように、地上の乱にうず巻く時の武族の離合集散ほど、はかり難いものはなかった。",
              "citation": {
                "source": "私本太平記",
                "author": "筑紫帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
