        "examples": {
          "standard": [
            {
              "text": "最近、思春期の息子ががさついていて、どう接すればいいか分からない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女は普段おとなしいのに、お酒を飲むと少しがさつくことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「若い頃は少しぐらいがさついてる方が、元気があっていいさ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
