        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「そんなにがっつくと喉に詰まらせるわよ。おかわりはあるから、ゆっくり食べなさい」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "お腹が空いていたのか、彼は運ばれてきた山盛りの唐揚げに子供のようにがっついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "目先の利益にがっつくあまり、彼は長年築き上げてきた顧客の信頼を失ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新しい知識を吸収しようと、彼は図書館の古い文献にがっつくように読み耽っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そういうことでがっつくのはけちくさいと思うけれど、やっぱりこの心持は消すことは出来ないことね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにせよ私は、あなたから色々のお祝を戴きためてあるから、その日になってにわかにがっつくこともありません。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
