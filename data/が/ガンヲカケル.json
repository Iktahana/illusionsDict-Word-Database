    "definitions": [
      {
        "index": 1,
        "gloss": "to make a wish (to a god)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "どうしても第一志望の大学に合格したくて、地元の天満宮で願をかけてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「もし宝くじが当たったら、あの高いギターを買うんだ」と、彼は密かに願をかけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "試合の日は必ず左足から靴下を履くのが、彼なりの願をかけるルーティンらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その理由は、この町の守り本尊に聖マルティンというえらい聖者の木像があって、それに願をかけると、どんな病気でもかたわでもすぐなおってしまうからでした。",
              "citation": {
                "source": "かたわ者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその神神の祠は、それに祈願をかける人人の、欲望の大小に比例してゐる。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんの僅かばかりの、愼ましい祈願をかける人人の神神は、同じやうに愼ましく、小さな些やかな祠で出來てる。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのため、木太刀をさし上げて、願をかけると、何んな願ひごとでも成就するつて言ひ伝へてあるので御座います』『へえ！",
              "citation": {
                "source": "知多の野間で",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてはいつでも願をかけるようにそんな事は夢にも思い出すまいと心に誓った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「観音様へ願をかけるのも考え物だとな。",
              "citation": {
                "source": "運",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために、世界じゅうの海という海を渡って、神様を願をかけるやら、お寺に巡礼をするやらで、いろいろに信心をささげてみましたが、みんな、それはむだでした。",
              "citation": {
                "source": "眠る森のお姫さま",
                "author": "ペロー　Perrault",
                "note": "青空文庫"
              }
            },
            {
              "text": "榛名様に願をかける。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポリポリポリポリとかじりながら願をかけると、よろずかなわぬものはないぞ。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "兆青流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って彼らは、痛みを覚えた幼児が泣き叫んで母を求めるように、病めば必ず熱心に願をかける。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "餘程念入りな願をかけるんでせうね」「面白いな八、明日は俺が行つて、娘の所作を見極めよう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "第廿七吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "よほど念入りな願をかけるんでしょうね」「面白いな八、明日は俺が行って、娘の所作を見極めよう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "第廿七吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "えやみや足なえ憑きものの類が、ふしぎに願をかけると癒るということだった。",
              "citation": {
                "source": "天狗",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の欲しい金額と姓名生年月日などを小石に書いて、ここへ納め、願をかけるのだそうである。",
              "citation": {
                "source": "日本文化私観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのさきに粋筋の人たちがよく願をかける被官稲荷がある。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
