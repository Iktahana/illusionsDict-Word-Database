[
  {
    "uuid": "629ad992-df2f-5e9c-944a-c23bb48ec48f",
    "entry": "合切",
    "reading": {
      "primary": "がっさい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
