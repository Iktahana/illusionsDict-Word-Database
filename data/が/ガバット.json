        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ゴーシュが窓のわくをしきりにがたがたしているうちにまたかっこうがばっとぶっつかって下へ落ちました。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "がばっとはねおきるや、カンカラとうち笑っていましたが、ずばりと小気味よげに言い放ちました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがばっと煙をあげて、いきなり船を放れたのには驚いた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、服も脱がずに、ベッドへがばっと倒れ伏して、やすらぎのない眠りにおちた。",
              "citation": {
                "source": "井戸",
                "author": "Ｗ・Ｗ・ジェイコブズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "がばっと、真っ先に、一角が、「丈八郎」　と、蒲団を刎ねて――「起きているか」「お……。",
              "citation": {
                "source": "無宿人国記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "えーいっ」　ふた声、寝言で人を斬るような気合をかけたので、若者部屋の者が、がばっと、総立ちに起き上がって、夜半に、大笑いをしたこともあった。",
              "citation": {
                "source": "べんがら炬燵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "がばっと真赤な口があいて、首が――ころりと穴のなかに落ちるはずなのに、そのままぶらんとなって、「なんだ、こりゃ」　皮膚を切り残したらしく、その皮膚で首がつながっている。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まだ、知らないのかしら」　寝ている者の抱いている木剣を、彼女が取りのけようとするのと、がばっと、武蔵が刎ね起きたのと、一緒だった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふいに、がばっと、清十郎は起ち上がった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "がばっと、縁に、首を垂れてしまった。",
              "citation": {
                "source": "山浦清麿",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不落の城　夢でもみたのか、相木熊楠は、『八雲っ』　と、大きな声で云って、自分の声に驚いたように、がばっと、楯のうえに起き直った。",
              "citation": {
                "source": "篝火の女",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『殿ッ』　わらわらっと、その中へ、駈けこむがはやいか、磯貝十郎左も、建部喜六も、片岡源五右衛門も、がばっと、俯つ伏したきり、地へ食い入るような嗚咽をしていた。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "弾正大弼は、がばっと、衾を刎ねて、『な、なにっ？",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
