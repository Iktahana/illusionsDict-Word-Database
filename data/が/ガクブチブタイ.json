        "examples": {
          "standard": [
            {
              "text": "劇団は、新しく開場した劇場で、広々とした額縁舞台を用いた壮大な演劇を上演した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "舞台美術家は、観客の視線を中央に集めるため、額縁舞台の装飾に工夫を凝らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "オペラハウスの古典的な額縁舞台は、その歴史的な雰囲気をさらに際立たせていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "額縁舞台には緑色の薄紗が幾重にも垂れ下っている。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくは、耳を済ませて立止っているが、斧の音に吸い寄せられるかのように、額縁舞台の方へ歩み寄って行く。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
