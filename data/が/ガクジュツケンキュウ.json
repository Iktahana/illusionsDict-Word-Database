[
  {
    "uuid": "0b2f6529-d232-52f6-bfc0-f5a7a37b1100",
    "entry": "学術研究",
    "reading": {
      "primary": "がくじゅつけんきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
