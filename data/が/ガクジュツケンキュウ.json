    },
    "definitions": [
      {
        "index": 1,
        "gloss": "academic study",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は長年にわたり、このテーマに関する学術研究を続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "学術研究の成果は、しばしば社会に大きな影響を与える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "大学院では、各自が専門分野の学術研究に没頭する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この論文は、最新の学術研究の動向をまとめたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "こういう風に考えてみると、博士濫造の呼び声の高くなるのは畢竟学術研究者の総数の増加したことを意味し、従って我国における学術研究熱の盛んになったことを意味し、我学界の水準の高まったことを意味するのではないか。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果は研究者の増加を促し翻っては一国の学術研究熱を鼓吹することになるであろう。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "船の名はシビリアコフ号、これがソビエト政府の北氷洋学術研究所所属の科学者数名を載せて北氷洋をひと夏に乗り切ったものであるということが新聞で報ぜられた。",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし少なくとも学術研究の方面で従来この二つのものがあまり尊重されなかったことだけは疑いもない事実である。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで博士の良人が死んで以来、或る学術研究会の調査部に入り、図書の整理係として働らいていた。",
              "citation": {
                "source": "ウォーソン夫人の黒猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葡萄牙のピントー以来日本に渡来した外人は数限りも無いが、真に学者として恥かしからぬ造詣を蓄えて、学術研究の真摯な目的を抱いて渡来し、大にしては世界の学界に貢献し、小にしては日本の文明にも亦寄与したものはシーボルト一人であった。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "学術振興会・学術研究会議・学士院・貴族院・等に於ける半政治的な仕事では大きなファクターであるが、本質は不覊奔放な研究家という処にあるだろう。",
              "citation": {
                "source": "日本の頭脳調べ",
                "author": "――特に自然科学者に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが機関誌の編集方針を一層学術研究雑誌として徹底することにしたことは、本来の面目を重ねて明らかにしたものにすぎない。",
              "citation": {
                "source": "『唯研ニュース』",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "天分があり、才能があり、而して意志のある者なら、自分の望む限り、学術研究に携っても実務に就ても発展することが出来る。",
              "citation": {
                "source": "男女交際より家庭生活へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の官学学術機関である帝国学士院、学術研究会議、日本学術振興会などの長老組織を改組する目的で一五名の委員が選ばれたが、学界一般の輿論を反映するものでなかったので一九四六年十二月この委員会は解散した。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九四七年に入ってから民主的な学術研究組織を持つための運動が起り文部省科学教育局長の肝入りで「学術研究体制世話人会」がつくられた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして（一）新しい学術研究体制を確立する準備として全国的な審議会を組織する。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の新しい綜合的学術研究体制の企画立案はすべてこの審議会で行う。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……むろん内科や外科なぞいう処ではコンナ必要がないかも知れないが、精神病科に限っては、その主任教授の脳髄も研究材料の一つとして取扱わなければならぬ……徹底的の研究を遂げておかねばならぬ……というのが吾輩一流の学術研究態度なんだから仕方がない。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、今日まで二人とも独身生活を続けまして、学術研究の一方に生涯を打ち込んでおりますところまで、そっくりそのまま、似通っているので御座いましたが……しかしその正木先生の頭脳の非凡さと、その資産の莫大さとの二つの点に到っては、トテモ私どもの思い及ぶところでは御座いませんでした。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通人が見る、普通の夢でさえも、今日までその正体が判然っておりませぬのに、況して今から二十年も昔に遡った……貴方がお生れになるか、ならない頃に、学術研究の論文として斯様な標題が選まれたのですからね。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に、後に名総長と謳われました盛山学部長が裁決をしまして、この『胎児の夢』の一篇を、一個の学術研究論文と認める旨を宣言しまして、やっとこの日の会議を終る事になりました。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学の中だけは学術研究の安全地帯だと思っていたのが、豈計らんやのビックリ箱と来たもんだからね。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……しかし……先生の、そうした治療の実験は、純粋な学術研究の目的でなさるのですか、それとも……」「……無論……むろん純粋の学術研究を目的としているんだよ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれ自分が学士になって大学に奉職する事にでもなったならば、その時に大学の権威で、学術研究の材料として提供させても遅くはないであろう。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして彼の学術研究……断頭刃磨ぎを断然打切るべく、彼が母校に提出した学位論文の根本主張は、何であったか……曰く……『脳髄は物を考える処に非ず……』」「……………」「……かくしてＭの個人としての煩悶は遂に、学術の研究慾に負けた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただその児が、確実に呉家の血統を引いた男の児でさえあれば、学術研究上、申分ないと思っていただけなのだ」　今度こそは最早、とても我慢出来ない戦慄が、私の全身に湧き起った。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩と若林とが、あの呉一郎と瓜二つによく似ている君を換え玉か何かに使って、虚偽の学術研究を完成して、それを又、虚偽の方法で発表しようと試みているかのように誤解されるかも知れない。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "学術研究のためだった……と云って、心からお二人であやまって下さい……」「……………」「お願いというのはそれだけです。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "…………何もかも真実であった……虚偽の学術研究でも、捏造の告白でもなかった。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
