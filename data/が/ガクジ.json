    "definitions": [
      {
        "index": 1,
        "gloss": "educational affairs",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学事課では、学生の履修登録や成績管理などの事務手続きを行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "学事日程を確認して、試験の準備を進めよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "学事報告会では、今年度の大学運営に関する詳細が説明された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「ええと、失礼ですがお職業はやはり学事の方ですか。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉田玄白の「解体新書」や「蘭学事始」などもその中にあった。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "がっちりした物理学事典も求めました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて女史は給料の余りを以て同志の婦女を助け、共に坂崎氏の家に同居して学事に勉めしめ、自ら訓導の任に当りぬ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら文学事業にいたっては社会はほとんどわれわれの自由に任せる。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうは、杉田玄白の「蘭学事始」に就いてお話して下さった。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜もベツトに腰かけながら、夜おそくまで彼等四人の子供達の気質や学事や前途について、Ｈ青年と久しく話に耽つた。",
              "citation": {
                "source": "芭蕉と歯朶",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "話は横道へそれるが、ヴォルテールの哲学事典の「姦通」の項を開いて見ると、これとちょっと似た面白いことが書いてある。",
              "citation": {
                "source": "男女関係について",
                "author": "女房に与えて彼女に対する一情婦の心情を語る文",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお、学校設立の理由は右太政官布告第二一四号「学事奨励に関する被仰出書（おうせいだされしょ）」（学制序文）に示されている。",
              "citation": {
                "source": "赤い婚礼",
                "author": "RED BRIDAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一女子は家の内事を司どるの務あるが故に学事勉強の暇少なし。",
              "citation": {
                "source": "新女大学",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は時勢もちがい、かかる奇話あるべきようもなしといえども、もしも幸にして学事会の設立もあらば、その権力は昔日の林家の如くならんこと、我が輩の祈るところなり。",
              "citation": {
                "source": "学問の独立",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の如くして、文部省はまったく廃するに非ず、文部省は行政官にして、全国の学事を管理するに行政の権力を要するもの、はなはだ少なからず。",
              "citation": {
                "source": "学問の独立",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを要するに、学問上の事は一切学者の集会たる学事会に任し、学校の監督報告等の事は文部省に任して、いわば学事と俗事と相互に分離し、また相互に依頼して、はじめて事の全面に美をいたすべきなり。",
              "citation": {
                "source": "学問の独立",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただに実際に心配なきのみならず、学校の官立なりしものを私立に変ずるときは、学校の当局者は必ず私有の心地して、百事自然に質素勤倹の風を生じ、旧慣に比して大いに費用を減ずべきはむろん、あるいはこれを減ぜざれば、旧時同様の資金をもってさらに新たに学事を起すに足るべし。",
              "citation": {
                "source": "学問の独立",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "相撲と碁将棋とは、その事柄において、これを政事に比して軽重の別あるがゆえに、その軽重の差にしたがいて、双方の長と長と比肩するを得ざるものなりといえども、今一国文明の進歩を目的に定めて、政事と学事と相互に比較したらば、いずれを重しとし、いずれを軽しとするは、判断においてはなはだ難き事ならん。",
              "citation": {
                "source": "学問の独立",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏蘭西の大学校にて、第一世ナポレオンはその学事会員たるを得たれども、第三世ナポレオンはついにこれを許されざりしという。",
              "citation": {
                "source": "学問の独立",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが日本の文明も、そのはじめは朝鮮・支那より来たり、爾来わが国人の力にて切磋琢磨、もって近世の有様に至り、洋学のごときはその源遠く宝暦年間にあり〔『蘭学事始』という版本を見るべし〕。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵馬｜騒擾の前後に、旧幕府の洋学校は無論、他の私塾家塾も疾く既に廃して跡を留めず、新政府の学事も容易に興るべきに非ず、苟も洋学と云えば日本国中｜唯一処の慶應義塾、即ち東京の新銭座塾あるのみ。",
              "citation": {
                "source": "〔気品の泉源、智徳の模範〕",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の慶應義塾を見るに、その学事は凡そ資金の許す限りに勉めざるはなし。",
              "citation": {
                "source": "〔気品の泉源、智徳の模範〕",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "否な、世間普通の官私諸学校に比すれば資力以外の事にまで着手して見るべきものありと雖も、天下の時勢、尚お未だ独立の学校事業に可ならずして、経済の不如意と共に学事も亦不如意の歎を免かれず。",
              "citation": {
                "source": "〔気品の泉源、智徳の模範〕",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "又教場の学事は殆んど器械的の仕事にして、僅に銭あれば以て意の如くすべしと雖も、我党の士に於て特に重んずる所は人生の気品に在り。",
              "citation": {
                "source": "〔気品の泉源、智徳の模範〕",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち今の版本蘭学事始上下二巻、是れなり。",
              "citation": {
                "source": "蘭学事始再版之序",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "数千部の再版書を普く天下の有志者に分布するは即ち蘭学事始の万歳にして、啻に先人の功労を日本国中に発揚するのみならず、東洋の一国たる大日本の百数十年前、学者社会には既に西洋文明の胚胎するものあり、今日の進歩偶然に非ずとの事実を、世界万国の人に示すに足るべし。",
              "citation": {
                "source": "蘭学事始再版之序",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "数千部の再版書を普く天下の有志者に分布するは即ち蘭学事始の万歳にして、啻に先人の功労を日本国中に発揚するのみならず、東洋の一国たる大日本の百数十年前、学者社会には既に西洋文明の胚胎するものあり、今日の進歩偶然に非ずとの事実を、世界万国の人に示すに足る可し。",
              "citation": {
                "source": "蘭学事始再版序",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かように大人中間に入ったので明教館の漢学はいよいよ励まねばならず、また由井、錦織、籾山などの学事の交際や、郊外散歩なども相変らずしていた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく大区を合して区域を広められた際、私は松山以外の郡部の学事をも担当することになったが、これまでに例のない小学校というものを創設するのだから、なかなか困難であった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も気がくじけて手紙をかくのも物憂くて、こんな御無沙汰になりました。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は云わないが、　彼が、私が会うと心がくじけることをおそれ、又自分も、戻したい気になると思って行かないのか。",
              "citation": {
                "source": "一九二三年夏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こう和尚さんにいわれると、さすがに傲慢な悪右衛門も、少し勇気がくじけました。",
              "citation": {
                "source": "葛の葉狐",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "己惚れの強さがくじけてしまう。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
