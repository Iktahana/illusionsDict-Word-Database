        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "冬の白川郷を訪れ、雪化粧した合掌造りの家々がライトアップされる幻想的な風景に見とれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "合掌造りの急勾配の屋根は、豪雪地帯で雪下ろしの負担を軽減するための知恵だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "旅行で訪れた合掌造りの集落で、今も人々が生活を営んでいることに感銘を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この資料館は、移築された合掌造りの家屋で、当時の農家の暮らしを体験できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "一行は両兜合掌造りの田舎家に泊り、鱒料理を賞味した。",
              "citation": {
                "source": "滝しぶき",
                "author": "吉野秀雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くの白河郷には有名な大家族の家が残るほどで、大きなゆったりした合掌造りの家々が見られます。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "合掌造りの大きな家が群をなして村を形づくる様も壮観であります。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
