    "definitions": [
      {
        "index": 1,
        "gloss": "traditional style of Japanese architecture with a steep thatched roof",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
