          "literary": [
            {
              "text": "精巧をきわめたガラス細工の花と真実の花との本質的な相違はこういう点にもある。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウェーバーには、ガラス細工や金ぴか、心の乾燥、頭だけの情緒。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるでイミテーションのガラス細工が本物のダイヤモンドより美しく見えてしまうことがあるように、どこか芝居じみているが現実の笑顔より血の通った生気に満ちている。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
