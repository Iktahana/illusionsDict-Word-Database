        "examples": {
          "standard": [
            {
              "text": "彼女はショーウィンドウに飾られた繊細なガラス細工に目を奪われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は週末になると、趣味で精巧なガラス細工を作っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この店は、オリジナルのガラス細工を専門に扱っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "师傅は巧みな技で、あっという間にガラス細工の動物を作り上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "精巧をきわめたガラス細工の花と真実の花との本質的な相違はこういう点にもある。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウェーバーには、ガラス細工や金ぴか、心の乾燥、頭だけの情緒。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるでイミテーションのガラス細工が本物のダイヤモンドより美しく見えてしまうことがあるように、どこか芝居じみているが現実の笑顔より血の通った生気に満ちている。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
