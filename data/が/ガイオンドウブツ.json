        "examples": {
          "standard": [
            {
              "text": "へぇ、トカゲって外温動物なんだ。だから日向でじっとしてるんだね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "爬虫類や両生類は、ほとんどが外温動物に分類される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "外温動物は、体温を一定に保つために、環境に合わせて行動を変える必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "冬眠する動物の多くは外温動物で、気温が下がると活動を停止する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
