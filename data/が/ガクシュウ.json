    "definitions": [
      {
        "index": 1,
        "gloss": "learning",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "このような時代においてもしある科学の全般にわたって間口も広く奥行も深く該博深遠な知識をもった学者があって、それが学習者を指導し各部分の専門的研究者や応用家の相談相手になって行くとすれば実にこの上もない事である。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガドルフの百合宮沢賢治［表記について］●底本に従い、ルビは小学校１・２年の学習配当漢字を除き、すべての漢字につけた。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな空想はどうでもよい事にして、平凡な実際問題として見た時にも、数学の学習と語学の学習とは方法の上でかなり似通った要訣があるようである。",
              "citation": {
                "source": "数学と語学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "インドラ［※１］の網宮沢賢治［表記について］●底本に従い、ルビは小学校１・２年の学習配当漢字を除き、すべての漢字につけた。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は西洋文化からも大いに学ぶべきところのあることを堅く信じている者で、私の生活の一半は西洋文化の学習に捧げているようなものである。",
              "citation": {
                "source": "伝統と進取",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、このまちへ来てから、自分の学習は順調である。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君、学習院の女学部だろう。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹の卒業アルバムで、僕は君の写真を見ましたよ」「…………」「学習院で妹と同じクラスだったそうですね」「たぶん、他人の……」「……空似だなんて、随分君らしくもないエスプリのない科白ですね。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は学習院にいたとき、これで伊豆半島一周の遠乗りをしましたよ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "断裁された初めての本　受験ものの雑誌や学習参考書の老舗だった版元は、一時期、一般書への進出を狙って、さかんに色々な分野の本を出しました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした学習環境を作るにあたってケイは、大規模な画像のデータベースを提供してくれるヴィデオディスクに注目していました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴィデオディスクとコンピューターを組み合わせた学習環境に携わったスタインは、こうしたシステムを一般向けに提供する会社を作ろうと考えるようになります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "――――――――――――――――　秀麿は学習院から文科大学に這入って、歴史科で立派に卒業した。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "――――――――――――――――　綾小路は学習院を秀麿と同期で通過した男である。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "学習の二字が鳥のことに用いられた例は『礼記』に見えて、『礼記（月令）』季夏之月の条文に、「鷹即ち学習する」とあり、また人のことに学習の二字が用いられた例は、同じ『礼記（月令）』孟春の条文に、「この月や楽正（音楽を司る役人の長）に命じ、入って舞を学習させる」と見える。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "前節はただ学習の事を説明し、この節はただ朋友の事を説明すると看るのでは妙味が無い。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "学習する後世の人もまた精神というものを、直接にはどの様にして受け取ることができよう。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鷹｜乃ち学習する」とあるように、幼鳥が飛び初めの時に、しばしば羽搏くのが習うである。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ語学は先ず民族の研究から初めなければならない必要と、日露の地理的関係から生ずる露語学者の特殊の使命というような事を語学を教授する傍ら常に怠たらず力説し、尋常語学の学習以上に露語学者としての特殊の気風を作るに少からず腐心した。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ学習院の制服を着ている此青年の背丈が、国府津で見たその人の兄よりも、一二寸高いように思われた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は今年の四月学習院の高等科を出ている。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "『学校を出ると云うことが、学習院を出ることを、意味するなら。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は学習院の女子部にいた頃から、同窓の人々の眉を顰めさせるほど、虚栄心に富んだ女であった、と。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手がしきりに止めるものを、強いて学習の方法などをきくわけにもいかなかった。",
              "citation": {
                "source": "蘭学事始",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしも軍学習うたつもりじゃが、若い者の智慧には敵わぬわい。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
