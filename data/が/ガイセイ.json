[
  {
    "uuid": "9f4f0ac3-c00b-59cc-b346-208fc1a73f41",
    "entry": "外征",
    "reading": {
      "primary": "がいせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
