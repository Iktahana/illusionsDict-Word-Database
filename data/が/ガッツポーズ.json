        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "逆転ホームランを放った瞬間、彼はベンチに向かって力強くガッツポーズをした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「やった！第一志望に合格だ！」と叫びながら、自室で派手にガッツポーズを決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "審判の判定が覆った時、選手たちはグラウンドで一斉にガッツポーズを繰り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最後のパットがカップに沈んだ瞬間、彼は噛みしめるように小さくガッツポーズを作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "劇場の職員が謝罪をさせてほしいと私を追ってきたが「いえ、へっちゃらです」と私はガッツポーズをして預けていた荷物を受け取り、総合コンヴェンションセンターの外へ出た。",
              "citation": {
                "source": "グローバルタワーにて",
                "author": "福永信",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
