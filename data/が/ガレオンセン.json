        "examples": {
          "standard": [
            {
              "text": "カリブの海賊が、財宝を満載したガレオン船を襲撃する物語は今でも人気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供のころに読んだ冒険小説には、幾多の困難を乗り越えて進むガレオン船が登場した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "博物館で見たガレオン船の設計図は、当時の造船技術の高さを示していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夕暮れの海に浮かぶガレオン船のシルエットは、絵画のように美しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "スペイン無敵艦隊の壊滅後、ガレオン船の生存者から学びました。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "この模様はスペイン無敵艦隊が負けた後、難破したガレオン船からもたらされたものです。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
