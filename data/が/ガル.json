  {
    "uuid": "9f753d99-0167-5a42-921f-bd2cc0a5b089",
    "entry": "ガル",
    "reading": {
      "primary": "ガル",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gal (unit of gravitational acceleration)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自分ノ身体ヲ可愛ガルヨウニ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのチヨツと下の大きな所はガルシヤと申します。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ティアガルテンの冬木立や、オペラの春の夜の人の群や、あるいは地球の北の果の淋しい港の埠頭や、そうした背景の前に立つ佗しげな旅客の絵姿に自分のある日の片影を見出す。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "沢瀉久孝博士をして「何デー」「何デー」「ナンデイ」「ナンデイ」「ナニヲ云ッテヤガルンデイ」、日の神の「日」という美しい言葉を持ちながら何を苦しんで「デー」などという紅毛の国のダミ言葉を使うのかと憤慨させるのも誠に道理がある。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとはポルトガル語だといい聞かされて初めてそうかと知るくらいのものである。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和八年四月、鉄塔）三　春（ハル）のラテン語が ver であるが、ポルトガル語の 〔vera:o〕 は夏である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルムコルフコイル、グローヴ電池、無定位電流計、大きな電磁石、タムソンの高抵抗ガルヴァなどを買入れた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いにジェームス・スチュアルト教授の器械工場の援助を得て、簡単で安いガルヴァなどを沢山作らせることが出来た。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからセネガル地方では米に土を交ぜて食うが、これは単に腹を膨らせるためで味がよいためではないらしい。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十一月十六日『東京朝日新聞』）　　　　　　　　　三十九　　　　　　赤茄子の伝来　洋食に用いるトマトの来歴を調べた人の説によると、この植物は十六世紀の中頃に南米ペルーからスペインあるいはポルトガルに渡りそれから欧洲に拡がったものである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女皇陛下の電話　昨年の暮ポルトガルの女皇アメリー陛下がパリに御滞在中の出来事である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでターバンを巻いた印度人、皮膚の色褪せたペルシヤ人、半黒焼のマレー人、亡国的なポルトガル人などの群に交って北京を出発してから半ヶ月後、支那の現代のシステムに出現した支那女との恋を棄てて北京以来の友である陳子文と米良は病み疲れていた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのなあ、蒙古人がやってきはって、ピダホヤグラガルチュトゴリジアガバラちゅうのや。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画俳優はアドルフ・マンジュウとグレタ・ガルボが好き。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお、戦争に関する詩歌についても、与謝野晶子の「君死にたまふことなかれ」、石川啄木の「マカロフ提督追悼の詩」を始め戦争に際しては多くが簇出しているし、また日露戦争中、二葉亭がガルシンの「四日間」を訳出している。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し、以上見て来たところのものを西欧の近代の戦争文学と比較するならば、トルストイの「セバストポール」や「戦争と平和」は勿論、ガルシンの「四日間」「兵卒イワノフの手記」「卑怯者」でも、またアンドレエフの「血笑記」でも、モウパッサンのへんぺんたる短篇の戦争を扱ったものでも、やはり遙かに上にある。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "トルストイは見習士官としてセバストポールの戦争に参加したが、ガルシンも露土戦争に参加した。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒竜江は、どこまでも海のような豊潤さと、悠々さをたたえて、遠く、ザバイガル州と呼倫湖から、シベリアと支那との、国境をうねうねとうねり二千里に渡って流れていた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな話をしていたらある人がアヴァンガルドという一派の映画がいくらかそういう方向を示すものだと教えてくれたが、まだ実見することができない。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アヴァンガルドというのは未見であるが、ともかくもわれわれはフランス映画の将来にある期待をかけてもいいように思われる。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝展には少ないが二科会などには「胃病患者の夢」を模様化したようなヒアガル系統の絵がある。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "月光に洗われたベンガル湾が見える。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アポリネエル、ジヤコブ、コクトオ、ブルトン、エリュアル、――それからマチス、ピカソ、シヤガル、アルキペンコ等々の畫家についてもそれは同樣なのであつた。",
              "citation": {
                "source": "詩集『戰爭』",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またガニミード神話の反映をガンダラのある彫刻に求めたある学者の考えでは、鷲がガルダに化けた事になっている。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしておもしろい事にはその彫刻に現わされたガルダの顔かたちが、わが国の天狗大和尚の顔によほど似たところがあり、また一方ではジャヴァのある魔神によく似ている。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴォルタの電盆や電堆、ガルバニの細君の発見と言われる蛙の実験いずれも質的なる画期的実験である。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は結婚後まもなく夫のドクトルに死なれ、退役軍人の父親と、夫の忘れがたみで、当時十四ぐらいであった娘のヒルデガルトと二人でさびしく暮らしていた。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日われわれお弟子仲間二三人でこのヒルデガルトを連れて、ルイゼン座のおとぎ芝居を見に行った事がある。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、桃太郎が生まれなかったらそのかわりに栗から生まれた栗太郎が団子の代わりにあんパンかキャラメルを持って猫やカンガルーを連れてやはり鬼が島は征伐しないでおかないであろう。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
