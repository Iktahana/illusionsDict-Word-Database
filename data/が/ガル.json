[
  {
    "uuid": "ef4f8d91-d1f1-5920-a7ef-6afb449dfc5e",
    "entry": "がる",
    "reading": {
      "primary": "がる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "接尾辞",
        "動詞-五段-ラ行"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to show signs of being",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そしてヒステリーは現実よりも表現を名称を吟味したがるんだ。",
              "citation": {
                "source": "不可入性",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "見よやわが十指は晶結し背にくりいむは瀧とながるるごとししきりに掌をもつて金屬の女を研ぎ胴體をもつてちひさなる十字を追へば樹木はいつさいに※轉し都は左にはげしく傾倒す。",
              "citation": {
                "source": "受難日",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんな奴が、段々偉くなりやがる」、ハテ面妖なとＡの方で思ふのだが、Ｂとしたら、変な話ぢやないか。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が其処で暮し、其処で耕した所から花が咲いたのに、別の所で暮し、別の所で耕してた奴が、その花を面妖がるのが変な話でなくてなんとしようぞ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "返事をしないとしたらあの男はひどく残念がるのだし、しまひには腹をたてる。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――女はクセのない男つて嫌がるものよ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "燃えあがるやうなさかんな熱情。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人は立派な文明を持っていながら好んで野蛮人の真似をしたがると、彼は常に不満を述べていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで式のある日などには、夫人が無理に押えつけ、女中までが手伝って騒ぎながら、まるで駄々ッ子を扱うように、あやしたりすかしたりして、厭がるのを強いて着せねばならなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を言ってやがると思う。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろはがるたや、川柳や、論語などに現わされている日常倫理の戒津だけでは、どうも生き難い。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る種の作家は、本気に書くつもりの小説を前もって広告する事を避けたがるものである。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉毛は太く短くまっ黒で、おどおどした両の小さい眼を被いかくすほどもじゃもじゃ繁茂していやがる。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉毛を描いて眼鼻をくっつけ、そうして知らんふりをしていやがる。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅君には、学生時代から少し威張りたがる癖があった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の弱い、情に溺れ易い、好紳士に限って、とかく、太くたくましいステッキを振りまわして歩きたがるのと同断である。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「縁談などの時には、たいてい自分の地位やら財産やらをほのめかしたがるものらしいが、小坂のお父さんは、そんな事は一言もおっしゃらなかった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも、同じクラスの者は大学を出てからも、仲の良いくせにつまらないところで張合って喧嘩をしたがる傾向がある。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――余りに実利的な一般人が、形式論（原理）と実地とを直接連つたものと考へたがる。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんなこと言ひやがる」と思つた兄は一寸調子外れをした、兄は父の居間との境の襖の方に目を移した。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親が子を可愛がると言ふのが……さあ如何言はうか……意志的意識の世界で三文の値打があるだらうかてなあ――そりやあ親が子を可愛がるやうになつてることも必要でせう、併しそれが人間の口から如何の斯うのつて問題になるべき性質のものぢやないなあ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――またあんたも曲がるのかい。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんな好い詩を書く俺を落第生だとたゞ思つてやがる。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「常に孤独で居る人間は、稀れに逢う友人との会合を、さながら宴会のように嬉しがる」とニイチェが云ってるのは真理である。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やもりは雨のふる夜ごとに暗闇阪の街燈に出ているが、いつ何処から這い上がるとも知れぬ。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八分の一の低音の次に八分の一の休止があってその次に急速に駆け上がる飾音のついた八分の一が来る。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒板へ書いている数式が間違ったりすると学生が靴底でしゃりしゃりと床をこするので教場内に不思議な雑音が湧き上がる。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暖かい湯気が立上がる。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆々思わず起き上がる。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
