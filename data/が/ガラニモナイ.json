[
  {
    "uuid": "46df43bf-b3ef-5e8f-8d14-84ba48f36f58",
    "entry": "柄にもない",
    "reading": {
      "primary": "がらにもない",
      "alternatives": [
        "ガラにもない"
      ],
      "is_heteronym": false
    },
    "grammar": {
