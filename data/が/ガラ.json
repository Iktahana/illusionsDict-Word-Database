  {
    "uuid": "f1de4d3f-1a0e-5088-a7a3-95fc1ebf4d6a",
    "entry": "殻",
    "reading": {
      "primary": "がら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
