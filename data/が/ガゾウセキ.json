      {
        "index": 1,
        "gloss": "stone with a picture carved into it (ancient China)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
