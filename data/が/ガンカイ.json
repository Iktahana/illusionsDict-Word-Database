[
  {
    "uuid": "cf936b31-8b2b-592f-bfaf-2da386fd6d88",
    "entry": "眼科医",
    "reading": {
      "primary": "がんかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
