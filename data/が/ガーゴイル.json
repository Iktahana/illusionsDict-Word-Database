        "examples": {
          "standard": [
            {
              "text": "古い教会の屋根の端で、翼を広げた不気味なガーゴイルが街を見下ろしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "廃墟となった洋館の門柱には、石造りのガーゴイルが番人のように鎮座していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ファンタジー映画の中で、石像だと思っていたガーゴイルが突然動き出し、侵入者に襲いかかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "じゃあゴヤ以前はというと、ノートルダムやモン・サン＝ミシェルのガーゴイルやキメラを作った連中まで戻らなきゃならない。",
              "citation": {
                "source": "ピックマンのモデル",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "花崗岩の天井からは荒く彫られたガーゴイルがニタニタと笑いかけていた。",
              "citation": {
                "source": "千里眼の村",
                "author": "クリスマス・ストーリー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
