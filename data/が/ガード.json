[
  {
    "uuid": "d712f3f8-bc76-5a5c-80ec-ea4b62c18018",
    "entry": "ガード",
    "reading": {
      "primary": "ガード",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "guarding",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "試合終了間際、選手たちは必死で相手の攻撃から自陣ゴールをガードしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その貴重な美術品は、厳重なガードのもと、美術館に展示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しいセキュリティシステムは、個人情報をオンラインでの脅威からガードしてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供たちが危険な場所に近づかないよう、親は目を離さずにガードしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "停車場のガードをくぐつて坂を登ると、暗い煤ぼけた古道具や、安物の足袋など店に竝べた、昔の宿場そつくりの町がある。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもガードを一つ距てて、淀橋の向ふに二幸や三越のビルヂングが壘立し、空には青い廣告風船があがつて居る。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガードやガソリンスタンドなども両方にある。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日目に、彼は、津浦線ガードの東北の畑地で、新しく盛られた土饅頭の下から、埋められた惨殺体を発見した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まるでジョン・ヒルガードそっくりだ。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ジョン・ヒルガードって何です。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもヒルガードには眉間にあんな傷痕がありません。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おやおやみんな改宗しましたね、あんまりあっけない、おや椅子も丁度いい、はてな一つあいてる、そうだ、さっきのヒルガードに似た人だけまだ頑張ってる。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は或はご承知でしょう、ニュウヨウク座のヒルガードです。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ヒルガードは一礼して脱兎のように壇を下りただ一つあいた席にぴたっと座ってしまいました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近は……尤も震災前だが……土橋のガード下を護謨輪で颯と言ふうちに、アツと思ふと私はポンと俥の外へ眞直に立つて、車夫は諸膝で、のめつて居た。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど数寄屋橋を渡って、最近出来たばかりの省線のガードの手前を左へ入った処に、その骨相家の看板が出ていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "感違いの感違い　駐在巡査が夜ふけて線路の下の国道を通りかかると、頬冠りをした大男が、ガードの上をスタスタと渡って行く。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お安婆さんの茶店は、鉄道の交叉点のガードの横から、海を見晴らしたところにあった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "省線のガードが見える。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄道線路のガードの下を潜り橋を渡りました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは尚それまで、振り払うようにして来たわたくしの袂の端を掴む二本の重い男の腕を感じておりましたが、ガードを抜けて急に泥のにおいのする水っぽい闇に向き合うころからその袂はだん／＼軽くなりました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは尚それまで、振り払うようにして来たわたくしの袂の端を掴む二本の重い男の腕を感じておりましたが、ガードを抜けて急に泥のにおいのする水っぽい闇に向うころからその袂はだん／＼軽くなりました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて天満から馬場の方へそれて、日本橋の通りを阿倍野まで行き、それから阪和電車の線路伝いに美章園という駅の近くのガード下まで来ると、そこにトタンとむしろで囲ったまるでルンペン小屋のようなものがありました。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、拾い屋をはじめてから十日ばかりたったある朝、ガードの近くの百姓家へ井戸水を貰いに行っていると、そこの主人が拾い屋もいいが、一日三十七銭にしかならぬようではしかたがない。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、三月ばかりたつと、亀やんはぽっくり死んでしまったので、私はまた拾い屋になろうと思って、ガード下の秋山さんを訪れると、もう秋山さんはどこかへ行ってしまったのか、姿を消していました。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで、ライダー・ハガードの世界だ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ハガードといえば、今、彼の弟が土地管理委員としてアピアの街に住んでいる。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひきかえして、省線のガード下を折れて行くと、薄汚いしもた屋の軒に「日本畳新聞社」と小さな看板が出ていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "今宮のガード下で……」「へえ……？",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガード下の空地に茣蓙を敷き、ゴミ箱から漁って来た残飯を肴に泡盛や焼酎を飲んでさわぐのだが、たまたま懐の景気が良い時には、彼等は二銭か三銭の端た金を出し合って、十銭芸者を呼ぶのである。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
