        "examples": {
          "standard": [
            {
              "text": "脱税の容疑で、早朝から会社にガサ入れが入った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "警察は、押収した証拠を元に、関係先のガサ入れに踏み切った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「明日の朝、A商事にガサ入れだ。準備はいいか？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "「もう邸内はガサ入れしたのか。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "指揮官に、ガサ入れしたらすぐ電話で知らせるように頼みました」　フィールド警部補がじれて叫んだ。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "サザックからの電話で、ガサ入れの様子を詳しく教えてくれました。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "本官が電話で、君らの警部にガサ入れを頼んだ」　牧師姿の男が震え声で言った。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、ジョリ商会をガサ入れして、そこにいた仲間を拘束しました。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "時期が来たらガサ入れする場所も分った。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
