        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ああして月給取も店員も運転手も職工も小僧も女事務員も町娘も女給も仲居もガソリンガールも一緒になって踊っているのは何と美しく善いことだろう。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "機械的文明の発達は人間のこうした慾望の焔にガソリン油を注いだ。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのガソリンは、モーターに超高速度を与えて、自動車を走らせ、飛行機を飛ばせる。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴男は、ガソリンの響にもまして不幸な人なのですが、それでいて自分では幸だと思っていらっしゃるのです。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枚の小切手が一かたまりの紙幣となって出納口からでてくると、銀行を背負ったような女は、ふたたび銀座方面へガソリンの尾を曳いた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガードやガソリンスタンドなども両方にある。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍国の兵力の強さもある意味ではどれだけ多くの火薬やガソリンや石炭や重油の煙を作り得るかという点に関係するように思われる。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またたとえばガソリンが地上にこぼれたときいかなる気象条件のもとにいかなる方向にいかなる距離で引火の危険率が何プロセントであるかというようなことすらだれもまだ知らないことである。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "製本されて纏まった文章になって、蒸気とガソリンの速力で全国の読者に配布されても地名や人名は仮名になっているし、標題に含まれている暗示もよほど注意深く新聞を読んでいる人か、又は実地を調査した係官の中でもかなり職務に忠実な人間でなければわからないようにしておいた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車のガソリンの煙だけでも霧の凝縮核を供給することはたいしたものであろう。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガソリンの音も聞えます。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……午後、ハガキを投凾すべく、石油を買ふべく街へ出かける、小郡にもガソリンガールが出現した、その軽快愛すべしであつた。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "……続いて起る砂ほこり……ガソリンの臭い……４４４４の番号と、赤いランプが見る見るうちに小さく小さく……。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "艇が何度の角度で沈んだ、ガソリンが室内に充ちた、チエインが切れた、電燈が消えた。",
              "citation": {
                "source": "艇長の遺書と中佐の詩",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガソリンのようなにおいがしますね。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "五所川原駅からガソリンカアで三十分くらい津軽平野のまんなかを一直線に北上すると、その町に着くのだ。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おひる頃、中畑さんと北さんと私と三人、ガソリンカアで金木町に向った。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガソリンカアは、のろのろ進み、金木駅に着いた。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでふだんガソリンの用意なぞはなくガソリンを自分で持って来た客だけにモーターボートを貸すことにしています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "河岸に繋いであるモーターボートを見ると、急に思い立ったものと見え、運転手に町のスタンドからガソリンを買わして来てまでして、ボートを借りて出船して行きました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、今日この頃は、ガソリンの統制で、人力車を利用する客もふえて来たのを倖い、「世の中てほんまにうまいことしたアる」　と、喜んで、また俥をひいて出ていたのだった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰が考えついたのか、同一方面の客を割前勘定で一ツ車に詰めこめば、ガソリンが節約でき、客も順番を待つ時間がすくなく、賃金も安くつくという、いかにも大阪らしい実用的な思いつきだった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちの自動車は、思わぬこの娘子軍の出現にいきなり前方を塞かれて、たじたじとなるとガソリンの爆音のみ、いたずらに我が天心へ反響さして、さて停ると、ますます燥いで、浮かれて、ひっかかえたペコペコ三味線の連れ弾きと来た。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、水筒に水を入れ替えて、またガソリンの爆音を立てさせた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "アトからガソリンの臭いと、たまらない屍臭とがゴッチャになってムウとするほど鼻を撲つ。",
              "citation": {
                "source": "書けない探偵小説",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見上げているうちに、私はだんだんと大胆になって来たらしく、やがて、いつもポケットに入れているガソリンマッチの事を思い出しました。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその凹地のまん中でいく度もいく度も身を伏せて四方のどこからも見えないことを、たしかめますと、すぐに右のポケットからガソリンマッチを取り出して、手元を低くしながら、自動点火仕掛の蓋をパット開きました。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その光りをたよりにソロソロと頭を擡げて、まず鼻の先に立っている、木の幹かと思われていた白いものをジッと見定めましたが、間もなく声も立て得ずにガソリンマッチを取り落してしまいました。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもガソリンマッチは地に落ちたまま消えませんでした。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
