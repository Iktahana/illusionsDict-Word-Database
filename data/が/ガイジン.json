[
  {
    "uuid": "3657951a-6663-57d9-9f18-fca65176d58f",
    "entry": "外人",
    "reading": {
      "primary": "がいじん",
      "alternatives": [
        "ガイジン"
      ],
      "is_heteronym": false
    },
    "grammar": {
