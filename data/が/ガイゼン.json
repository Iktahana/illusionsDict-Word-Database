[
  {
    "uuid": "1803d582-f464-5c78-a9ed-3814e2528733",
    "entry": "慨然",
    "reading": {
      "primary": "がいぜん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-たる",
