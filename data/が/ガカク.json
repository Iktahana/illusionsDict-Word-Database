[
  {
    "uuid": "89c14cc6-f76b-5650-a3b2-5d3ebdb98f5d",
    "entry": "雅客",
    "reading": {
      "primary": "がかく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "man of letters",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "風流雅客を嘲るもの、邦家を知らざるの故を以て彼等を貶せんとする事多し。",
              "citation": {
                "source": "富嶽の詩神を思ふ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "慾も得もない書放しで、微塵も匠気がないのが好事の雅客に喜ばれて、浅草絵の名は忽ち好事家間に喧伝された。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村もと名利を厭い聞達を求めず、しかれども俳人として彼が名誉は次第に四方雅客の間に伝称せらるるに至りたり。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村もと名利を厭ひ聞達を求めず、しかれども俳人として彼が名誉は次第に四方｜雅客の間に伝称せらるるに至りたり。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し其の方法にして獨りこゝに遊ぶ人間に對して訓示するのみに止まらず、進んで草木その物に對しては恰も農夫の稻に於けるが如く學者の書卷に於けるが如きものありとせば其の恩澤を蒙むるものは啻にわが國内の雅客のみならず世界の旅行者も深く其の勞を謝するであらう。",
              "citation": {
                "source": "十年振",
                "author": "一名京都紀行",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、この『北越雪譜』の著者鈴木牧之｜翁は、越後の塩沢の商人で、時々商用で上京した時に当時のいわゆる文人雅客と交りを結んではいたものの、その全生涯は殆んど越後の雪の中で送られたものと見て差支えない。",
              "citation": {
                "source": "語呂の論理",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶんさうした文人雅客の愛誦語でもあらうか、ある中華料理店の聯に、林泉、市ニ近ク、幽、更ニ幽　と、書いてあつた。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "取り拡げた品物を片付け乍ら最後に、ちよつとしめやかな口調で、「かう云ふ物などをもて遊んで、雅客を迎へるのも実に久し振りだなあ。",
              "citation": {
                "source": "芥川龍之介を憶ふ",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども文人雅客とか幾らかひねった趣向を好む人々は、つまり具眼の士は感服した。",
              "citation": {
                "source": "寒橋",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「書画琴棋の慰みなどは、玄徳の心に何のひびきもない」「彼は世外の雅客ですが、あなたにまで、風月に遊べとおすすめ申すのではありません。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しそれは彼の夢想が余りにありの儘の現実を扱ひ得るからで、夢想がかくも現実的であるといふ点で、高橋新吉は人類中非常に特異なものなのだ。",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして仮りにもし「いき」がかくのごとき漠然たる意味よりもっていないものとすれば、西洋の芸術のうちにも多くの「いき」を見出すことができるはずである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく科学者と称する人々の中でも各自の専門に応じて地震というものの対象がかくのごとく区々である。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度この三次がかくれて居る前辺りで鉄五郎呼びかけられて立ち止る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞬間の嬉びが永遠に悲しみとなってしまう、チャイコフスキーの狂気音楽がかくまで近代を支配する。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "我彼の父とならば、彼我の子となりなん、ともに幸いならずや」独語のようにいうを人々心のうちにて驚きぬ、この翁がかく滑らかに語りいでしを今まで聞きしことなければ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に、そこから僅かばかり隔った亜細亜タンクの附近にも六名の死体がかくされてあった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士達は、小屋にパルチザンがかくれていて、不意に捨身の抵抗を受けるかもしれないと予想した。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人の××ばかりでなく、キキンの郷里から送られる親爺の手紙にも、慰問袋にも××××がかくされてあるのに気づいた中隊幹部は非常にやかましくなってきた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひばよりも暗く、榧よりももっと陰気で、なかには、どんなものがかくれているか知れませんでした。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ゆえその空想がかくも自分を悲しませ、また、かくも親しく自分を呼ぶのか？",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子ねこがかくしから首と前足を出して見物しているのが愉快である。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「胃の腑」と「詩」との間にはまだだれも知らないような複雑微妙の多様な関係がかくされているのではないかと思われる。",
              "citation": {
                "source": "詩と官能",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」伯爵の二番目の女の子がかくしから黄いろのリボンを出しながら云ひました。",
              "citation": {
                "source": "黒ぶだう",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして雷竜の太い尾がまづ見えなくなりその次に山のやうな胴がかくれおしまひ黒い舌を出してびちょびちょ水を呑んでゐる蛇に似たその頭がかくれると大学士はまづ助かったといきなり来た方へ向いた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "清夫はお母さんのことばかり考へながら、汗をポタポタ落して、一生けん命実をあつめましたがどう云ふ訳かその日はいつまで経っても籠の底がかくれませんでした。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして雷竜の太い尾がまず見えなくなりその次に山のような胴がかくれおしまい黒い舌を出してびちょびちょ水を呑んでいる蛇に似たその頭がかくれると大学士はまず助かったといきなり来た方へ向いた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "林と野とがかくもよく入り乱れて、生活と自然とがこのように密接している処がどこにあるか。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど片目の十蔵がかく語りしものを痛きことかなと妹は眼をみはり口とがらせ耳をおおいて叫びぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "――大事のお月様雲めがかくす。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
