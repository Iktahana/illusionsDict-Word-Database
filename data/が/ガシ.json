[
  {
    "uuid": "abcfc382-21a8-5ae0-aa8f-635fe3dbd7c8",
    "entry": "画紙",
    "reading": {
      "primary": "がし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
