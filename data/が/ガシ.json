    },
    "definitions": [
      {
        "index": 1,
        "gloss": "drawing paper",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「この画紙、水彩の吸い込みが早すぎてグラデーションが作りにくいなあ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "コンクール用の大きな画紙を丸めないように慎重に自宅まで持ち帰る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "鉛筆の跡が残りにくい、表面が滑らかで厚手の画紙を選んでデッサンを始める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "自分もこの展覧会に出品するつもりで画紙一枚に大きく馬の頭を書いた。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "レンズが肉体に化した木崎の写真は、印画紙からニヒリズムの体臭が漂うくらい、個性が強く、彼のねらう構図にはつねに夜が感じられて、ふとデカダンめいたが、今夜の陽子と茉莉の写真も「夜のポーズ」という彼の好みのテエマにふさわしかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでなら、絵は紙やキャンバスの上、写真は印画紙、動画はフィルムやビデオテープ、音はレコードやＣＤと、それぞれ専用の〈器〉におさめられていた。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一字一字印画紙に文字を撮影していく写植オペレーターの都合を考えて、そんなときは、変化する字詰めに合わせて区切りを入れた原稿用紙に文章を書き写したりしました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一字一字文字を選び、指定の字詰めに合わせて仕上げた印画紙を台紙に張り込み、訂正の求めに応じて手作業で文字の張り替えを進めます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええたびたび」とよし子は依然として画紙に向かっている。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラフなブロマイト印画紙のような肌は、もう近在から出る地卵とそっくりであった。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "……恰度、あの写真の現像をする時にですね……私は、あれが道楽なんですが……赤い電気の下で、現像に夢中になっていると、不意に、直ぐ自分の横へ確かに置いた筈の赤い紙に包んだ印画紙が、どこかへ消えてしまって、すっかり面喰ってしまうことがよくありますね。",
              "citation": {
                "source": "銀座幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで三ちゃんは、水洗をいい加減にして急に乾かすと、それを印画紙にやきつけた。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手には写真の印画紙らしいものを二三枚もっているが、いま水から上げたばかりと見えて水滴がぽたぽた床のうえに落ちた。",
              "citation": {
                "source": "什器破壊業事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「えゝ度々」とよし子は依然として画紙に向つてゐる。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにある」湯河原中佐が、クルクルと捲いてある細長い印画紙を机の上に、展げて見せた。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "年ちゃんは、図画紙の上へ、さびしいお母さんのお顔を描きました。",
              "citation": {
                "source": "さびしいお母さん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十センチに二十センチ位の土の塊で凍上を生ぜしめ、左右の側に小さい板を埋め込んで、その動きを鏡で拡大して廻転ドラムに巻いた印画紙上に描かすのである。",
              "citation": {
                "source": "低温室だより",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに印画紙を使うので、全体を黒い幕で蔽って、室の片隅に急造暗室を作ったような恰好でやらなければならない。",
              "citation": {
                "source": "低温室だより",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "店員は仔細らしくその写真器を調べている間に、先生は印画紙の見本に掲げてある額を眺めておられる。",
              "citation": {
                "source": "先生を囲る話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともこの写真は色々細工がしてあって、不完全な結晶は継ぎ足したり、また乾板上で目的とする結晶の縁に沿って膜面を切り取って、印画紙に焼くと黒地に白く結晶が焼き出されるようにしたりしてある。",
              "citation": {
                "source": "雪の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃外国の良い印画紙が段々輸入されなくなって、国産品を使ってみるとつくづく感ずるのであるが、どうも色調が悪いようである。",
              "citation": {
                "source": "墨色",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういえば外国の良い印画紙には黒色の非常に豊富な種類があって、青墨の墨色にも油煙墨の墨色にも似た色調のものが幾種類もある。",
              "citation": {
                "source": "墨色",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの印画紙の色の加減が分るまでは、日本の写真材料もまだ本当のものにはなっていないといわれても仕方がない。",
              "citation": {
                "source": "墨色",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの名印画紙とも称すべきものの蔭に隠れている色調の研究をどういう風にしてやったかを知りたいものである。",
              "citation": {
                "source": "墨色",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう――その印画紙は背景を写したものじゃなかったんだ、結局。",
              "citation": {
                "source": "ピックマンのモデル",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女は手脚を折り曲げられ、顔が崩れ、剥がれた皮膚に点々と蛆が湧いて、それが大きな四つ切りの印画紙いっぱいに拡大され、私の鼻さきで慄えているのでした。",
              "citation": {
                "source": "恐怖の正体",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "目下ノトコロ好事ノ士ガ稀ニ用イルノミデ一般ニ普及シテイナイガ、普通ノ手札型ノロールフィルムニ印画紙ガ重ネテアルモノデ、容易ニ日本デハ手ニ入ラズ、一々アメリカカラ取リ寄セルノデアル。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白黒の写真を僕はカラー・リヴァーサルで複写し、カラー印画紙にプリントした。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "印刷したものではなく、印画紙にプリントしたものだ。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "印画紙にプリントした白黒の写真のなかへは、こんなふうにしてルーペで入りこんでいくことができる。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は昨日までの雨に拭はれて、すがすがしく、それは海の方まで続いてゐることが分ります。",
              "citation": {
                "source": "死別の翌日",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "格別細い感じがした。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨、魂はにがい深淵だぞといふやうなことを我々日本人が云ふと、一寸そぐはない感じがしよう。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
