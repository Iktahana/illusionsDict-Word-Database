[
  {
    "uuid": "f406e36a-a3c3-5b14-8f74-6b79b8784f10",
    "entry": "ガラッと",
    "reading": {
      "primary": "ガラッと",
      "alternatives": [
        "がらっと",
        "ガラっと"
      ],
