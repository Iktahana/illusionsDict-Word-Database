        "examples": {
          "standard": [
            {
              "text": "「ごめん、高速でガス欠になっちゃって…今、JAFを待ってるところ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ツーリングの帰り道、仲間の一人がガス欠で立ち往生してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "レンタカーを返却する前に、ガス欠にならないよう近くのスタンドで給油した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "あ！ガソリンの警告灯が点滅してる。このままだとガス欠になるかもしれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "そこにキューバからとんずらしてきたミグ15がガス欠でイエロー・キャブめがけて落下し、オレ様はついにインドネシアの運ちゃん、キューバの亡命パイロットと共に一命を落とすといった事態も論理的に皆無であるわけではない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車なしでは日常生活が成り立たないアメリカでは、石油の払底によってガス欠による交通事故や雪に閉じ込められた車中での凍死事故が起こるや、緊急時の連絡手段としてＣＢ用トランシーバーが注目を集め、需要が爆発的に急増しはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
