    "definitions": [
      {
        "index": 1,
        "gloss": "scientific name (of a species)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
