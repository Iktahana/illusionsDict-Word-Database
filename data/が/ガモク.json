        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "スルトソノ時不意ニ清三ガ目ヲサマシテ誰ダト叫ンダノデス。",
              "citation": {
                "source": "彼が殺したか",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "出シ物ハ「恩讐の彼方へ」「彦市ばなし」「助六曲輪菊」デアルガ他ノモノハ見ズ、助六ダケガ目的デアル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "己ニソレヲ見セルノガ目的デプールヲ作ルヨウナモノナンダ」「ソレデモソレハイヽコトデゴザイマスワネ、自分ノ家ニプールガ出来タラ経チャンダッテ喜ブデショウシ、………」陸子ガ云ウト婆サンガ云ッタ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女ハ足袋ヲ穿イタ時ニ踝ノ突起ガ目立タナイノガ自慢ナノデアル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅ト白トノコノ対照ヲ五子ノ前デ見セビラカスノガ目的ダッタノデアロウカ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕ハ必ズシモ睡ラセルノガ目的デ飲マシタノデハナイ。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大満員と見たはヒガ目、今日あたりより空席大分ありたる由。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "疑説、ここに生じて、彼を天皇の子となす説、女御が通じていた悪僧の子とする説など、はしなくも、二十年後の貧乏平氏の家庭に、紛々をかもし、スガ目の忠盛にあきたらぬこと年久しく――しかもなお虚栄に富んで女の晩春に恋々たる彼の母は、四人の子をのこして他家へ去る。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
