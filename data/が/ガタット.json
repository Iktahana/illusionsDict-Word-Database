    },
    "definitions": [
      {
        "index": 1,
        "gloss": "with a clunk",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は疲れてソファにがたっと座り込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は鞄を床にがたっと置いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ドアが勢いよく閉まり、がたっと大きな音がした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "待ちくたびれた彼は、椅子にがたっと身を投げ出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "山の中の小さな驛を素通りするたんびにがたっと横にゆれながら、汽車はいっしんにその七時雨の傾斜をのぼって行きました。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キッコの机はたびたび誰かにぶっつかられて暗礁に乗りあげた船のようにがたっとゆれました。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　その雲のどこからか、雷の一切れらしいものが、がたっと引きちぎったような音をたてました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのたびに車はがたっとゆれました。",
              "citation": {
                "source": "車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学士はひどくびっくりしてそれでも笑ひながら眼をさまし寒さにがたっと顫へたのだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学士はひどくびっくりしてそれでも笑いながら眼をさまし寒さにがたっと顫えたのだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　いきなり奥の扉が、がたっとあきました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も呑んで、がたっとふるえました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると八時過ぎて玄関でがたっと自転車を置いた音がしてそれからシラトリ属がまるで息を切らして帰って来たのです。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから又五六日たって、フウねずみが、いつものとほり、大いそぎで鳥箱先生のそばを通りすぎようとしますと、先生が網のチョッキをがたっとさせながら、呼びとめました。",
              "citation": {
                "source": "鳥箱先生とフウねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本線シグナルつきの電信柱は、がたがたっとふるえて、それからじっと固くなって答えました。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春吉君は、がたっとこしかけをうしろへのけ、直立不動のしせいをとり、読本を持った手を、思いきり顔から遠くへはなした。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫁の顔は不味くとも、月日がたっといつの間にやら氏育ちが顔形に出てゆくからな。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、からだががたっとのめりかけて馬車がガラガラ動き出した。",
              "citation": {
                "source": "帰途",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の足が私の家の古い階段をがたがたっと駆け上る音が私に聞えた。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルック先生は、とりなすように、「アメリカのおじょうさんがたは、先祖がそうであったように、独立し自活することがたっとばれるのです。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあと　いきなり　がたっと　ゆれて、　ぱかぱかという　うまの　ひづめの　おと。",
              "citation": {
                "source": "まちねずジョニーのはなし",
                "author": "THE TALE OF JOHNNY TOWN-MOUSE",
                "note": "青空文庫"
              }
            },
            {
              "text": "善く読むこと――ほんとうの書物をほんとうの精神で読むこと――はけだかい仕事であり、今日の慣習がたっとぶいかなる課業よりも読者の骨折りを要求するものである。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「騙されるということは、気のつかない間は男に媚びているみたいなものよ、気がつくと、がたっと何処かに突き堕された気がしてしまうんです。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとがたっと音がしてこの前のように開いた。",
              "citation": {
                "source": "奇巌城",
                "author": "アルセーヌ・ルパン",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲霧は、がたっともいわせず、風呂場からぬっと這入ると、手拭で顔をつつみ、袷の裾を横に端折りあげた。",
              "citation": {
                "source": "雲霧閻魔帳",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが不破数馬はがぶ飲みの故か、俄かにがたっと参ってしまって、畳に伸びてしまった。",
              "citation": {
                "source": "ボロ家の春秋",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと晩に簪の二つや三つ、泥まみれになるのは江戸じゃあ珍しかあねえ」「全くよ、珍しかあねえ」「だから見ねえつもりでいな、若いの」　と亭主が圧えつけるように云う、刹那、正吉の足がたっと亭主の股間を蹴上げた。",
              "citation": {
                "source": "お美津簪",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "声はかれ、眸はかすみ、さしも意志のつよい範宴もその夕がたには、がたっと、痩せおとろえた細い手を床について、しばらく、意識もなかった様子である。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房へ下げるその手を、どうして御仏さまには下げられないのでござんすか」「お……お吉」「いってくれますか」平次郎は、突っ張っていた肩を、がたっと落して、「……いう、いう……」と、顔をおおった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、その時、縁側の戸が、がたっと鳴った。",
              "citation": {
                "source": "宮本武蔵",
                "author": "地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして門までの暗い飛石づたいを、足さぐりに歩いてゆくと、がたっと、袖垣の蔭にあたって、不自然な雨戸の音がし、たしかに人間らしいものが、そこらの庭木をくぐって、塀のミネへ登っていた。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おさらば」　がたっと、障子の桟がつよく鳴った。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『上様っ、上様っ』　次の御着更え部屋の化粧｜扉が、がたっと、鳴った。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "the sound of a sudden decrease (in profits, vigor, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "景気の急激な悪化で、株価ががたっと下落した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼のやる気は、試合に負けた途端にがたっと失われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "突然の寒波で、室温ががたっと下がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "期待していたニュースが流れてこず、彼の顔から血の気ががたっと引いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
    ],
