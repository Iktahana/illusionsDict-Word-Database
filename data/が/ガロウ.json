    "definitions": [
      {
        "index": 1,
        "gloss": "art gallery (esp. artworks for sale)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし浴場に附属した礼拝堂と図書館と画廊と音楽堂と運動場の建築が必要であると云って、それで三人でこの仮想的浴場のプランを画いてみたりした。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "到る処に穂芒が銀燭のごとく灯ってこの天然の画廊を点綴していた。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど西洋の画廊で古い絵ばかり見て、日本へ帰って始めてキュービストやフュチュリストを見せられたような心持ちがする事がある。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの国の有名な画廊にある名画の複製や、アラビアンナイトとデカメロンの豪華版や、愛書家の涎を流しそうな、芸術のための芸術と思われる書物が並んでいて、これにはちょっと意外な感じもした。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "画廊へ、お金を受取りにおいでになれば、三日目くらいにお帰りになりますが、そんな時でも、深夜、酔ってがらがらと玄関の戸をあけて、おはいりになるや否や、おい、三百円あまして来たぞ、調べて見なさい、等と悲しい事を、おっしゃいます。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和五年十一月、渋柿）女の顔　夏目先生が洋行から帰ったときに、あちらの画廊の有名な絵の写真を見せられた。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケーテ・コルヴィッツの死がつたえられるとニューヨークのセント・エチェンヌ画廊で、ケーテの追悼展覧会が開かれた。",
              "citation": {
                "source": "ケーテ・コルヴィッツの画業",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう日、塩野の写真展が資生堂の画廊で展かれることになった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "互いに慄える手を探り合って握りつつも、どこかに身の近づけぬもののある画廊ながら、矢代は、もしこれで千鶴子にいのちを失う踏絵のような場合が来れば、あの、細川ガラシヤの死の苦痛を軽めで死んだ小笠原少斎のように、自分もともに千鶴子と死ぬかもしれないと思った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそのソファに腰を降ろしてみているうち、画廊で戯れたさきの木山老人の姿を想い出して傍の千鶴子を仰いだ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　離れの洋館の中へ這入ったとき、田辺侯爵は資生堂の昼間の画廊のときとは違い、打ち解けた笑顔の挨拶だった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この遊部は資生堂の画廊へ昼間来ていた藤尾みち子と結婚して外国へ二人で行ったのだが、帰るとすぐ二人は別れてしまった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "法水は、画廊の両壁を観賞してゆくような足取りで、ゆったり歩を運んでいたが、その背後から検事が声をかけた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、僭越ながら、敢て岡田君の先輩知友に謀り、来る七月一日から四日間銀座西日動画廊で、同君の個展を開くやう取計ひました。",
              "citation": {
                "source": "岡田※君の個展",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私初めてあの人と、マドリッドの画廊で逢いました。",
              "citation": {
                "source": "西班牙の恋",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "卵色の陽光が窓から射して、しんと静かな画廊へ来た時、たった一匹だけ毒蛇を描いた小さい額を見付けました。",
              "citation": {
                "source": "西班牙の恋",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより、袋物の店か、画廊……。",
              "citation": {
                "source": "女心の強ければ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年、同じ画廊でさゝやかな個展をやつたが、世話役の私が不慣れで、宣伝も思はしくできなかつたに拘はらず、相当の成績を挙げ得たのは、素人の眼をも十分楽しませる率直な、健康な、本格的な美の要素を、彼の絵が備へてゐるからだと思ふ。",
              "citation": {
                "source": "岡田君のこと",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "二日　土　今日、サロン・ドートンヌ〔秋の画廊〕の招待日だ。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月十五日（日曜）雨　九段画廊に中村氏遺作展覧会アリ、今日ギリ。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにいるうちに前年面識のあった大阪島の内柳屋画廊の女店員でＡという娘と文通しだし、家庭生活に絶望していた私は、西下して忍び逢ったが、彼女の日記が寄宿先の伯母に発見され、たちまち郷里である山口県へ帰されてしまった。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "われはヴェルレエヌの如くにカッフェーの盃をあげレニエーの如くに古城を歩み、ドーデの如くにセーヌの水を眺め、コッペエの如くに舞蹈場に入り、ゴーチエーの如くに画廊を徘徊しミュッセの如くにしばしば泣きけり。",
              "citation": {
                "source": "矢立のちび筆",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかリュキザンブルの画廊だと覚えている。",
              "citation": {
                "source": "砂糖",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある時は、平生｜活人画以上の面白味は解せないくせに、歴代の名作のある画廊を経営していた。",
              "citation": {
                "source": "世界漫遊",
                "author": "ダウィット　Jacob Julius David",
                "note": "青空文庫"
              }
            },
            {
              "text": "その月の二十七日の午後、私はルーヴルの大玄関をはひつて直ちに右に折れ、Galerie Mollien を突当つて同じ名を負ふ階段を二階に上り、左折して仏蘭西初期の画廊に入ると間もなく、又三階に上る階段を踏んで Collection Camondo に到達した。",
              "citation": {
                "source": "帰来",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけのことだ…… 〔ou avaient e'te' de'vorse's par Les survivants. C'est tout.〕」　ルゥヴル博物館の第三室といっている画廊に、漂流中の筏をテーマにしたジェリコォの大画がある。",
              "citation": {
                "source": "海難記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰西画廊へでも、行きますか」　このひとはあとを尾けまわして、一日の行動を見ていた。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「芳夫のタンテイ趣味には、家じゅうが悩まされているのよ……いつだったか、泰西画廊であなたを見つけて、あとを尾けたんですって……あなたがお友だちの厄介者になっていることまでしらべあげてあるの……バカよ、あのひとは」　マジマジと、シヅの顔を見て、「飯島の……方だったわね。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "トンネルの闇におししずめられた目には、泰西画廊で見た、たれやらの「花火」の絵のように、あざやかだった。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎朝この画廊の世話人は壁のうえの古い画をはずし、一層かがやかしく、もしくは一層調和に富んだ色彩をもった新しい画を代りに懸けたのである。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
