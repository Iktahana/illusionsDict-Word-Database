        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は書家として活動するにあたり、師から「清風」という雅号を授かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "その絵師は生涯で何度も雅号を変えており、作品の署名から制作時期を特定する手がかりとなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "夏目漱石という名はペンネームであり、本名は金之助だが、俳句を読む際には「愚陀仏」という雅号も用いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "中には「朔太郎」といふのが本名か雅号かなどと問ふ人もあるが、紛れもなく、親のつけてくれた本名である。",
              "citation": {
                "source": "名前の話",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い時の僕は、その平凡さが厭やだつたので一時雅号をつけようとさへ思つた。",
              "citation": {
                "source": "名前の話",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（その頃は、文人の間に雅号をつけることが流行した。",
              "citation": {
                "source": "名前の話",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北原白秋、室生犀星、山村暮鳥等、皆雅号である。",
              "citation": {
                "source": "名前の話",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）だが考へて見たら、一人前の文士にも成らないものが、麗々しく雅号をつけるなんかテレ臭いので到頭本名で通してしまつた。",
              "citation": {
                "source": "名前の話",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人前の文士になり、世間に名を知られてしまつてから、後で雅号をつけたところで通用しない。",
              "citation": {
                "source": "名前の話",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が少女時代、文学雑誌に紫苑という雅号で、しきりに詩を発表していた文人があった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このあいだも話した通り、僕の家の六代前の主人は享保から宝暦のころに生きていたのだそうで、雅号を杏雨といって俳句などもやったらしい。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "名乗は秀実、雅号は有年といって、文学の素養もふかく、馬琴とも親しく交際していた。",
              "citation": {
                "source": "魚妖",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十歳まで大学に通ってベースボールをやる必要なんか無論ないよ」「其日庵という俺の雅号の由来を知っているかい。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは表札が家不相応にしゃれた篆刻で雅号らしい名を彫り付けてあるからである。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「再度生老人」という、彼の雅号まで知っていた。",
              "citation": {
                "source": "再度生老人",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と訊ねると、いや、それは雅号……「何といふ？",
              "citation": {
                "source": "彼に就いての挿話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一言附け加へるならば、その画家時代に用ひた雅号を私はその後再三訊ねるのであるが、決して返事しないところを見ると帝展落選の話もまた遊蕩の話しも悉く彼の空想であつたのかも知れぬ――そは、彼のみぞ知る。",
              "citation": {
                "source": "彼に就いての挿話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "）雅号だけは麗々と「朶雲」と貰つた。",
              "citation": {
                "source": "気狂ひ師匠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏と対座してゐるときの印象では、言葉を忘れた病人、「失語症」の人のやうに、沈黙の行をやる、土牛といふ雅号にふさはしく鈍重で動作ものろく、こちらで物を言はなければ千年も黙つてゐさうである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず万事がこういった素豆腐式若旦那調子で、雅号を見ても素晴らしいのになると「唖連美也散生」というような歯の浮くようなのがある。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でこそ謹厳方直な道学先生となって門下に煙がられている坪内博士も、春廼舎朧時代にはやはりこの気分が濃厚であったのは雅号でも推量られよう。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "下には零余子と雅号を使っている。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでながら、この前、私が江戸川氏を評した時に、江戸川乱歩というペンネームの由来について下した推測は全く間違いで、氏はポーに最も傾倒しておられるために、その音をとって雅号とされたのだということです。",
              "citation": {
                "source": "愛読作家についての断片",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "雅号を孔堂と申して、わが家中では名を売ったものじゃが、どうしてまたそれがわかった！",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句の雅号を金華と称して、あっぱれの宗匠顔をしているのである。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "名乗りは秀実、雅号は有年といつて、文学の素養もふかく、馬琴とも親しく交際してゐた。",
              "citation": {
                "source": "魚妖",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は本名よりも、その雅号の元遺山をもって知られて居ります。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "続夷堅志・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は町の煙草屋の息子で、雅号を冬坡という青年であるらしかった。",
              "citation": {
                "source": "鴛鴦鏡",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "団洲は団十郎の雅号で、つまりは入場料二銭の劇場の団十郎という意味である。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛里とは常陸牛久沼の里の地名から付けた雅号であらうと思はれる。",
              "citation": {
                "source": "小川芋銭先生と私",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はこれでも雅号を米水と云つて、小室翠雲さんのお弟子だよ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "広業と鰕11・20（夕）　画家寺崎広業氏の許へは、色々の人が画を頼みに来るが、そのなかには氏の画風が好きなからといふよりも、広業といふ雅号が縁喜がよいからといつて出て来る人も少くない。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラツクウツド雑誌に立て籠つて、クリストフア・ノウスといふ雅号で、何でもござれといつた風に、いろんな方面に得意の才筆を振つた男だ。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
