    "definitions": [
      {
        "index": 1,
        "gloss": "illustrated news magazine",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祖母の家には、古い画報が何冊も置かれていて、当時の人々の暮らしぶりがよく分かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "週刊誌よりも、詳細な写真や図解が多い画報の方が、事件の背景を理解しやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔の画報をめくっていると、懐かしい広告や風景が次々と目に飛び込んできた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの画報、廃刊になったらしいね。残念だな。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "室へ入ろうとするといつの間にか商人｜体の男二人その連れらしき娘一人室へいっぱいになって『風俗画報』か何か見ているので、また甲板をあちこち。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また最近にタイムス週刊の画報に出た、彼がキングス・カレッジで講演をしている横顔もちょっと変っている。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治時代の「風俗画報」がわれわれに無限の資料を与え感興をそそるのもそのためであろう。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私はふと、いつか幼年画報に出ていたたけしという人の狐小学校のスケッチを思い出しました。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "出発は八月十日、同行は差当り五人、蛮カラ画伯｜小杉未醒子、髯の早大応援将軍｜吉岡信敬子、日曜画報写真技師｜木川専介子、本紙記者｜井沢衣水子、それに病気揚句の吾輩である。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時から常陸山中の大子駅に至るまでの間の事は、既に日曜画報にも簡単に書いたので、日曜画報を見た諸君には、多少重複する点のある事は御勘弁を願いたい。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十年（丁未）　一九〇七○一月、演芸画報社より『演芸画報』第一号を発刊。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年の後、『演芸画報』に合併す。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は自分の文学にうぬぼれているわけではないが、しかし、「世相」や婦人画報の「夜の構図」などの作品が、もし僕以外の作家によって書かれたとしたら、誰も「悪どい」という一語では片づけなかっただろう。",
              "citation": {
                "source": "文学的饒舌",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お神は裏木戸の瀬川に余分の祝儀をはずみ、棧敷の好いところを都合させて、好い心持そうに反り返っているのだったが、銀子もここへ来てから、ようやく新聞や画報で見ていた歌舞伎役者の顔や芸風を覚え、お馴染の水天宮館で見つけた活動の洋画から、ついに日本の古典趣味の匂いを嗅ぐのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "）三人連で、軽井沢、碓氷のもみじを見た汽車の中に、まさしく間違うまい、これに就いた事実があって、私は、不束ながら、はじめ、淑女画報に、「革鞄の怪。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小田島は近頃、巴里で読んだ巴里画報の記事を思い出した。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "路傍にねむる戦争画報を見てひた疲れ、ああ、このごと路の端にねむる人、命なり、赤き陽にこんこんとうち伏しぬ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "半時間も早く出頭するのは癪だとふと思ったから、門からひきかえして近所の五銭喫茶店へはいって、演芸画報を見たり、新聞の就職案内欄を写したりして時間を潰し、きっちり午前九時に、受付へ出頭して葉書を見せると、可愛い少女の給仕に二階の粗末な応接間へ連れて行かれた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて『風俗画報』で、泉州に二十余年前まで差当りと称え、年頃の娘に良縁なき時、差当りこれをその叔父に嫁して平気な所ありと読んだが、すなわち系統を重んずるの余習で、国史を繙く者は少なくとも鎌倉時代の末まで邦人殊に貴族間に同姓婚行われたと知る。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正一四・二・演芸画報）（昭和三十一年二月、青蛙房刊『綺堂劇談』所収「甲字楼夜話」より）",
              "citation": {
                "source": "小坂部伝説",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の母親が酷く勿体振つた態度で、婦女画報に載つてゐる結婚写真を彼に示して、何か得意気なことを云つたことを彼は覚えてゐるが、自分は何んな心地がしたかも、彼は、今はもう知らないのである。",
              "citation": {
                "source": "小川の流れ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "………………　彼が茶の間へ入つて行くと照子はたつた独りで、長火鉢と離れた灯火の下で瀬戸物の火鉢に凭り掛つて演芸画報を見て居た。",
              "citation": {
                "source": "公園へ行く道",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の見舞に来てくれたのは演芸画報社の市村君で、その住居は土手三番町であるが、火先がほかへそれたので幸いに難をまぬかれた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日前荻生さんから借りた戦争画報を二三冊また借してやったが、それについてのいろいろの質問が出る。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵本がまずほろび、次に番附が亡びて、江戸以来のおもかげは消滅してしまったのであるから、今後の研究者は筋書に拠るか、あるいは『歌舞伎新報』とか『演芸画報』とか『歌舞伎』とかいうような劇専門の雑誌によるのほかはあるまい。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の見舞に来てくれたのは演芸画報社の市村君で、その住居は土手三番町であるが、火先がほかへ外れたので幸いに難をまぬかれた。",
              "citation": {
                "source": "火に追われて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "実をいえば、これを書いたのは昭和二年のはじめであって、書いた動機は、その頃「科学画報」に科学小説の懸賞募集があったので、それに応じたというわけであった。",
              "citation": {
                "source": "『地球盗難』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が科学画報の宮里さんに連れられて初日の四時頃行ったときには、ロボット先生出てこなかった。",
              "citation": {
                "source": "人造物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝は、ツル子達を伴れて一度Ｋ町の見物に出かけて画報や雑誌を買つたり、散髪をしたり、すしを食つたりしたことがあつた。",
              "citation": {
                "source": "山を越えて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二グループ女人芸術、婦人之友、婦人公論、婦人サロン、婦人画報等。",
              "citation": {
                "source": "婦人雑誌の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "子福者歴訪、俳優画報、出征将軍の家庭。",
              "citation": {
                "source": "婦人雑誌の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり鏡というものを見る機会のない私は、ある朝偶然｜縁側の日向に誰かがほうり出してあった手鏡を弄んでいるうちに、私の額の辺に銀色に光る数本の白髪を発見した。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それにしても息子はどうしたんだろう」　盤台や天秤棒がほうり出してあるのを見ると、七之助はもう帰って来たらしいが、どこに何をしているのか、この騒ぎのなかへ影を見せないのも不思議に思われた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "またたとえば忠犬美談で甲新聞が人気を呼ぶと、あとからあとからいろいろな忠犬物語がほうぼうから出て来て、日本じゅうが犬だらけになり昭和八犬伝ぐらいはまたたくひまに完成するのである。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
