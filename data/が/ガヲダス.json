    "definitions": [
      {
        "index": 1,
        "gloss": "to insist on one's own ideas",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
