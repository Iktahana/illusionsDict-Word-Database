    "definitions": [
      {
        "index": 1,
        "gloss": "outfield",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「風に乗った打球は、外野のフェンス際で失速してレフトのグラブに収まった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「雨上がりで外野のコンディションが悪く、足を取られる選手が続出した。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「プロの球場の外野は、テレビで見るよりもずっと広大に感じられた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "橋なくて日暮れんとする春の水　こうした春の郊外野景を描くことで、蕪村は特殊の画才と詩情とを有している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村はこうした郊外野望に、特殊のうら悲しい情緒を感じ、多くの好い句を作っている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしてもいもりの黒焼きの効果だけは当分のところ、物理学化学生理学の領域を超越した幽遠の外野に属する研究題目であろうと思われる。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一には、ホームラン性の打球を追って、フェンスによじのぼった外野手が見える。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホームランをキャッチしてしまった外野手が、高だかとグラヴをさしあげる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "外野のホビイストの目には、ビル・ゲイツはユーザーに誠実に対応するための体制作りを放棄し続けたＭＩＴＳとぐるとしか映らなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "五大洲がバットをふったかと見ると球は左翼の頭上はるかに飛んだ、外野手は走った、内野手も走った、陣営｜騒然とみだれた、小原はあっけに取られてマスクをぬぎ捨てたまま本塁に立っている。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月二十五日　月曜　アサとぶボールをおっかけて、“外野”“ネットバック”なかなか活躍。",
              "citation": {
                "source": "日記",
                "author": "一九五〇年（昭和二十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "このスカパフロー湾は、相手国たる独国の海軍｜根拠地ウィルヘルムスハーフェンを去ること実に五百六十｜哩の遠隔の地にあり、独国軍艦にお目にかかるのには、外野席以上の遠方の地点で、これほど縁どおいところはない。",
              "citation": {
                "source": "沈没男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには案外野々宮もゐるかも知れない。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしラッキーストライクに大鹿が加入して、三番にピースの国府一塁手、四番にキャメルの桃山外野手がとれたら、攻守ともに百万ドル。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャメル軍の猛打者桃山外野手の住居である。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "当日のメンバーは河野泉谷のバツテリーに遊撃橋戸、一塁森本二塁押川三塁小原に、外野は猪瀬久野鈴木の三人であつた。",
              "citation": {
                "source": "野球界奇怪事　早慶紛爭囘顧録",
                "author": "吉岡信敬",
                "note": "青空文庫"
              }
            },
            {
              "text": "早軍の泉谷君二ストライクの後、憤然カツと飛ばした熱球砂を噛んで外野に飛び、遂に貴重なる一点を獲得し、茲に早軍は見事三回競技に勝利の栄冠を得たのである。",
              "citation": {
                "source": "野球界奇怪事　早慶紛爭囘顧録",
                "author": "吉岡信敬",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外苑の木立がいま、外野席の向うに、濃緑の帯のように見える。",
              "citation": {
                "source": "昼の花火",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャッチボールのパスボールを取ってきてくれるのは大変便利であるが、歌笑が連れて神宮外苑の野球場に中等学校の試合があったときに、外野で例の通り綱をつけずに見ていたが、センターへヒットがきたのをグランドへ飛び降りてそのボールをくわえてしまった。",
              "citation": {
                "source": "犬",
                "author": "三代目　三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "外野手が見ると、一見恐ろしい顔したブルドックなので手がだせない。",
              "citation": {
                "source": "犬",
                "author": "三代目　三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより、連子形の飛び飛びの空間から、視野をほしいままにするわけにはゆきませんが、さっと窓を開いて、そうして、流れ渡る月光の外野を見ると、特に何物をか、しかと認め得たというわけではありませんが、なんとなく、いよいよ米友をして安心せしめざるところのものがある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "外野の声援者のようなものだ。",
              "citation": {
                "source": "押入れ随筆",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お手を、よごすのがいやなのさ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はだしで歩くと、足の裏がいやにぬらぬらする。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは狸汁にされるのがいやだつたから、それで婆さんをやつつけたんだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「世の中の人は皆、嘘つきだから、話を交すのがいやになつたのさ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな若いのが出來たら、私のやうな婆さんと話をするのがいやになるのも、もつともです。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、それがいやらしくて仕樣が無かつたんですよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もしおいぼれがいやだなんて云ったらぶんなぐっても連れていくよ。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠には土間がいやに寂かだし主人のめだまは黄金のやうだしさ。",
              "citation": {
                "source": "丹藤川〔「家長制度」先駆形〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは、からだが上流の方へ動いているような気持ちになるのがいやなので、水を見ないで、向うの雲の峰の上を通る黒い鳥を見ていた。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし豆畑へはいるのがいやでわざわざ殺されたというのが本当だとすると、それは胃に悪いとか安眠を害するとかいうだけではなくて、何かしら信仰ないし迷信的色彩のある禁戒であったであろう。",
              "citation": {
                "source": "ピタゴラスと豆",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の奴らに逢うのがいやだから、僕は一足先に出て銀杏の下で民さんを待っていたんでさア。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
