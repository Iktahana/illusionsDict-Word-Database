        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうなると両端から包囲するように、中央部までを喰い取って刳るから、一方の外壁を残して一方を欠いた噴火孔のようになる。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "三隅さんのお袋とおぬいさんとは、妹を連れてきたおたけさんと一かたまりになって、混雑を避けるように待合室の外壁に身をよせて立っていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外壁破れ、ひとへにあはれ深し。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒田邸の外壁にさしかかつた時、それに添ふて掘れてゐる大きなどぶがあつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といいながら腕組をして外壁に附着いたままで居る。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "底力のこもった鈍い空気が、音もなく重苦しく家の外壁に肩をあてがってうんともたれかかるのが、畳の上にすわっていてもなんとなく感じられた。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうなると思ってたんだよ」　高志が、デッキチェアの背を、四〇一の外壁にななめにもたせかけ、手すりのたての細い鉄棒に脚をかけて、頭のうしろに両手を組みながら、ふんぞりかえってこたえた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛びしさった広太郎、家の外壁へ背をつけた。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "辻の四方を見廻してから、家の外壁へ背中をつけ、そのままゆるゆると横歩き、辻を一方へ曲がって行った。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "槍だ槍だ槍が出た」　家の外壁へ背を持たせ、いわれるままにうしろを見た。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "不自然に眞白く塗つた外壁がかへつてこゝでは無氣味な感じを與へてゐるのである。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "不自然に真白く塗った外壁がかえってここでは無気味な感じを与えているのである。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "植木屋の亭主は早速私を迎えて、沢山盆栽などの置並べてある庭の内で、思いの外壁の乾きが遅かったことなぞを言った。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "その悩みと望みと、クレムリン宮殿の外壁と劇場広場の鳩とに、資本家のない国はあたらしいダイナモのような力と、生硬と、自己期待と、宗教的感激とをもって沈黙のうちに運転している。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "外壁に立って呶号する町の英雄、こわごわ露台から覗いている王女の姿が一つぽっちりと見える――時間こそは何という淋しい魔術であろう。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "女にしてみれば、まるで部屋の外壁へ微風が当っているようにしか感じなかったことでしょうから。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "復活祭・降誕祭は、反宗教宣伝の日となり、クレムリンの外壁にあった辻堂などもとりはらわれた。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "外壁に沿った裏通りに古本屋が露店を出し、空屋に店を出して居るところにモーランの夜開く、武郎の或女、ゾラの小説がさらしてあった。",
              "citation": {
                "source": "一九二七年八月より",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "門口を這入って左側が外壁で、家は右の方へ長方形に延びている。",
              "citation": {
                "source": "鶏",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは爺さんが飼っているので、巣は東側の外壁に弔り下げてあるのであった。",
              "citation": {
                "source": "鶏",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この旅館のおもてつきが又、いかにもその内部にふさわしく、無闇に間口ばかり広い二階｜建で、一階の外壁は漆喰も塗らないで赤黒い煉瓦が剥き出しになっているが、もともと汚ならしい煉瓦が烈しい天候の変化に逢って一層くろずんでいる。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒つぽい褐色のぬり色が風雨に曝されて如何にも古めかしい色をしたのも、丸太を横に積み重ねたやうなその外壁の上の棟近くにある僅かに光りを採るばかりの、まるで動物の檻のような感じの四角な横木をはめた小な天井裏の窓も、Ｅが不断から云ひ馴らしてゐる『牢屋』と云ふ感を其のまゝ現はしてゐるとしか見えなかつた。",
              "citation": {
                "source": "監獄挿話　面会人控所",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然主義が、一方では作者自身の心意の熱を枯渇させ、他方では現実の外壁につき当って行き詰った時、そこに当然新たな途が要求される。",
              "citation": {
                "source": "現代小説展望",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大鎌が二ちょう、白壁が落ちて赤煉瓦の出た低い小舎の外壁にもたせかけてある。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "教会の外壁をまわって通る電車の窓ガラスと、向う側の食堂の扉が、ガーン、ガーン重くけたたましく鐘の音響によって絶えずふるえた。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "収拾のつかない破綻が落ちている倉の外壁や青草にまで滲み出ているようなのに、順平は、町から買って来る繻子足袋をはいて、そこだけはしっかりしている新建ちの座敷で、小さい急須から小さい茶碗にとろとろと茶を注いでのんでいた。",
              "citation": {
                "source": "猫車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日光はあたたかく真上から市街を照らし、建物の錆びた赤や黄色の外壁をぬくめているが、ふと行きずりの通行人の外套からは、もう何処かに消えない霜があることを知らせる匂い、懐しい毛皮の匂いなどが軽く空気の中に漂っている。",
              "citation": {
                "source": "広場",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い矩形に作られている本館の中央は、半円形に突出していて、左右に二条の張出間があり、その部分の外壁だけは、薔薇色の小さな切石を膠泥で固め、九世紀風の粗朴な前羅馬様式をなしていた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから外壁の回転窓が見えるのだから、あれがちょうど階段の天井に当っているのだよ。",
              "citation": {
                "source": "聖アレキセイ寺院の惨劇",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
