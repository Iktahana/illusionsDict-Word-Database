          "standard": [
            {
              "text": "期末試験に向けて、化学の「学習参考書」を何冊か買ってきて対策しているところだよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "数学の難しい問題に当たった時は、いつも隣に置いている「学習参考書」を頼りにしているんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "書店に行くと、たくさんの「学習参考書」が並んでいて、どれを選べばいいか迷ってしまうね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "高校生の時に使っていた英語の「学習参考書」が、今でも語学学習に役立っているよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "断裁された初めての本　受験ものの雑誌や学習参考書の老舗だった版元は、一時期、一般書への進出を狙って、さかんに色々な分野の本を出しました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
