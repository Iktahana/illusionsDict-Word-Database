        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あ、やばい。財布の中に学生証を入れたまま、家に置いてきちゃった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "学割で映画を見るときは、チケット売り場で学生証を提示してくださいね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この図書館、学生証がないとゲートが開かない仕組みになってるんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「学生証の写真を撮り直したいんだけど、これって四年間ずっと同じなの？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "長髪に眼鏡は共通していても、学生証からはぎ取ってきたような松本のものとは対照的に、西の写真からはすでに青年実業家のにおいが立派に漂っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを聞かさないんなら、月謝納めないぞ）　いろいろと理由をつけてみたが、理由よりも、何よりも納める事が出来ぬ状態になってしまったから（見つかって学生証見せろと云われりゃ、其時の事だ）　と、度胸をきめてしまった。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校の学生証と電車の定期券とを正枝に示した。",
              "citation": {
                "source": "浅間噴火口",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は学生証をだしてみせた。",
              "citation": {
                "source": "孤独閑談",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "金策のため帰郷し、滞納の授業料を納めて学生証を貰つて来たのである。",
              "citation": {
                "source": "孤独閑談",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「学生証を写させて」　彼は学生証を取り出し、彼女に手渡した。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして学生証を彼に返し、「いつから来てくださるの？",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
