    "definitions": [
      {
        "index": 1,
        "gloss": "life in a foreign country",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
