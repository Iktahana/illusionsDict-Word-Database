        "examples": {
          "standard": [
            {
              "text": "いつかダーウィンが進化論の着想を得たというガラパゴス諸島へ行って、野生のゾウガメを見てみたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ガラパゴスの豊かな生態系を守るため、観光客の入域制限や持ち込み品へのチェックが厳格に行われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "テレビの特番で、ガラパゴスに生息するウミイグアナが荒波に耐えながら海藻を食べる姿が映し出された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
