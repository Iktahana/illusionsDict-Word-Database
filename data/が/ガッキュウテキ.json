[
  {
    "uuid": "a4a9c24d-d480-5fad-b9fb-51650ae38357",
    "entry": "学究的",
    "reading": {
      "primary": "がっきゅうてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
