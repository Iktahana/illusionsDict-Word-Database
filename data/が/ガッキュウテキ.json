    "definitions": [
      {
        "index": 1,
        "gloss": "scholastic",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は常に新しい知識を追求する、非常に学究的な姿勢を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その論文は、学究的な深さと独創性を兼ね備えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女の学究的な探求心は、周囲の学生たちにも良い影響を与えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "学究的な議論は好きだが、実践的な応用には興味がない人もいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "これはむしろ学究的の詮索に過ぎて、この句の真意には当たらないかもしれないが、こういう種類の考証も何かの参考ぐらいにはなるかもしれないと思って、これだけの事をしるしてみた。",
              "citation": {
                "source": "伊吹山の句について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　活動ファンと云うものは、一方ならず学究的素質を持っているものだと僕は思った。",
              "citation": {
                "source": "牛込館",
                "author": "映画館めぐり（十）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その伯父のすぐ下の弟――つまり三造にとっては斉しく伯父であるが――の、極端に何も求むる所のない、落著いた学究的態度の方が、彼には遥かに好もしくうつった。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄よ、如何にか思ひ給ふ、小生の如き一面随分批評的、学究的精神をもてるものに、このやうな東洋的、中世紀的とも申すべき神秘的実験あるべしとは、如何にもあり得まじき不思議事と思ひ給はずや。",
              "citation": {
                "source": "予が見神の実験",
                "author": "綱島梁川",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど大体に於て、説明的学究的の弊に堕して居るのを飽足らず思つた。",
              "citation": {
                "source": "文壇一夕話",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "」などゝ学究的な質問を放つた。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこの反対が今日まで学究的な形の哲学としては、認識論や科学論としては、ほとんど現われていない、というまでなのだ。",
              "citation": {
                "source": "生産を目標とする科学",
                "author": "――再三「科学と技術」とについて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の批判主義が学究的又スコラ的（学校的）概念によって立つものではなくて、世界概念によって立つものであることは、周知の通りだが、こうした世界への関心は、同時に社会への関心をも意味している。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点、批判主義に対する学究的批判によって往々忘れられるのだが。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "印象批評にとって気に入らないのは、あらかじめ文献的に設定された芸術法則を以て、様々の姿態の下に刻々現われる作品に天下り式に臨むという、あの文献学的クリティシズムの学究的な愚かさである。",
              "citation": {
                "source": "哲学の現代的意義",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の科学的乃至学究的な文化の独立化や向上の最近の遽かな結果である、と見るべきかも知れない。",
              "citation": {
                "source": "友情に関係あるエッセイ",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四に、このヒューマニズムの傾向は学究的な人々の間で「教養」という観念から「文化」という観念に変り「文化主義」などという言葉もできた。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえ、それらの冷静の中には、殺人鬼の持つ惨酷味などは、一点といえども含まれてはいず、むしろそこには科学者だけが持つ、学究的冷酷というようなものが、多分に含まれているのであった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上、私は声を大にして、真の大衆作家の普通の教養としての学究的研究、考証的知識の必要、具備を叫んで来たのであるが、併しながら、この史的知識の涵養ということは、殊に日本に於て甚だ困難なのである。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者メレヂコフスキイが、かくの如く当時の空気を彷彿せしめることを得たのは、一つには彼が南欧地方を巡遊したと云う経験を持っていたと云うことにもよるであろうが彼の学究的態度なり、その深奥な考証的知識なりは実に感嘆すべきものである。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤山君は事務家にして学究的な所を兼ねた人である。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも平氏は独り、公卿の反抗を招きたるのみならず、王荊公に髣髴たる学究的政治家、信西入道が、袞竜の御衣に隠れたる黒衣の宰相として、屡※謀を帷幄の中にめぐらししより以来、寒微の出を以て朝栄を誇としたる院の近臣も亦、平氏に対する恐るべき勁敵なりき。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、この部屋にあるものと云えば、学究的の静寂である。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此比較能力の程度が、人々の、学究的価値を定めるものである。",
              "citation": {
                "source": "古代研究　追ひ書き",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘がヤミの女になったりするのも、肉欲的な衝動よりも、冒険とかヤケとか腹いせとか境遇とか気質的な諸要素によるのが多く、学究的に処女を失ってみようというような型まで有りうる。",
              "citation": {
                "source": "貞操の幅と限界",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「演劇」はいくぶん学究的であるかも知れぬが、あくまでも書斎的であることに甘んじてはならぬ。",
              "citation": {
                "source": "「演劇」巻頭言",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（すなわち、積極的に出れば必ず勝つということなのだな）　彼は、本来が学究的の性格だったので、剣道を修めるにも、道場へ通って、竹刀や木刀で打ち合うことだけでは満足しないで、沢庵禅師の「不動智」とか、宮本武蔵の「五輪の書」とか、そういう聖賢や名人の著書を繙くことによって、研究を進めた。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時或る新聞に、気象台はあまり学究的に過ぎるという議論が出ていたので、思い出したわけである。",
              "citation": {
                "source": "科学と国境",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "台風十五号の時にも、予報が完全とはいえなかったが、それは「学究的に過ぎた」からではなく、過ぎなかったからである。",
              "citation": {
                "source": "科学と国境",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五号台風の詳細な気象調査は、まだ印刷になっていないので、詳しいことは分らないが、本当に台風の予報を精確にやろうと思えば、台風の機巧そのものを、もっと学究的に研究する必要があることには間違いがない。",
              "citation": {
                "source": "科学と国境",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当否は別として、前の「気象学が進歩したら、予報はあたるか」という質問や、この「学究的に過ぎるから」という議論などが、案外端的に、日本人の科学に対する考え方を物語っているように思われる。",
              "citation": {
                "source": "科学と国境",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは学究的に孤独な兄に同情が強いためと誰にも肯ずかれた。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこの書は時事問題を論ずるいわゆる試論であり、学究的なまたは philosophical な論究ではない。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
