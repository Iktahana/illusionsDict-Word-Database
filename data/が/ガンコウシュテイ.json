    "definitions": [
      {
        "index": 1,
        "gloss": "able to criticize but not to create (criticise)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の評論は眼高手低で、具体的な改善策は示されなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "企画会議で眼高手低な意見ばかりが飛び交い、議論は進まなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの監督は、他人の作品には厳しいが、自分の作品は眼高手低と言わざるを得ない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "理論ばかりで実践が伴わない彼は、まさに眼高手低の典型だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "眼高手低の一書生として映つたのである。",
              "citation": {
                "source": "私の考へてゐる事",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてその自信が又一方では、絶えず眼高手低の歎を抱いてゐる我々に、我々自身の自信を呼び起す力としても働いてゐた。",
              "citation": {
                "source": "あの頃の自分の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "語学でも分るやうに特異な頭脳であつたが、週期的な精神錯乱のせゐなどあつて、構成や表現が伴はず、眼高手低、宿命的な永遠の傑れたディレッタントであつた。",
              "citation": {
                "source": "篠笹の陰の顔",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、ディレッタント式の宿命的な眼高手低は、生理的にどうすることもできなかったのである。",
              "citation": {
                "source": "長島の死",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、ディレッタント式の宿命的な眼高手低は、生理的にどうすることもできなかつたのである。",
              "citation": {
                "source": "長島の死",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "語学でも分るように特異な頭脳であったが、週期的な精神錯乱のせいなどあって、構成や表現が伴わず、眼高手低、宿命的な永遠の傑れたディレッタントであった。",
              "citation": {
                "source": "篠笹の陰の顔",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼高手低が、あの人の恐らく一生の癌だね、と左門は卓一に語つてゐた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の生涯は眼高手低といふていいのか。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり頭は進んでいても眼高手低をまぬがれない。",
              "citation": {
                "source": "戦後合格者",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを子供の時からその世界で叩きあげている「歌舞伎」にくらべると、新劇の眼高手低の甚しさがハッキリする。",
              "citation": {
                "source": "戦後合格者",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼高手低は芸術にならないのである。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
