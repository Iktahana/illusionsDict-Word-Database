[
  {
    "uuid": "3337e7f8-a0b4-5738-9357-f75064ab22bd",
    "entry": "雅量",
    "reading": {
      "primary": "がりょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
