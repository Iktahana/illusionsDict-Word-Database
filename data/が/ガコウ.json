        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "締め切り直前、漫画家はアシスタントたちと徹夜で画稿を仕上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "美術館の特別展で、巨匠の若き日のものとされる未公開の画稿が展示された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "編集者は、新人イラストレーターから送られてきた画稿の瑞々しい感性に目を見張った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "建築家は、クライアントへのプレゼンテーションのために、建物の完成予想図の画稿を何枚も用意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "（一九三五年二月「自由画稿」より）",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "且つ画稿では見立たなかつた平行線のゆがみが気に懸つて見え出した。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもデパート展などは画稿料を払つたとしてもそれは一部の画家に過ぎないだらうし、多くは委托販売の形式になるのだからあくまでせいぜい売れる絵の出品を企て売つた方がよい。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に描く意りの画稿のことを私は思い詰めていたのでした。",
              "citation": {
                "source": "温室の恋",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその画稿が紙面に現われた時の感じというものは、また別の趣きを現すものである。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "予と船を同じうして欧洲に遊び、予より一年遅れて帰つた徳永｜柳洲君が、在欧中の画稿から諸種の面白い材題を撰んで此書の挿画と装幀とに割愛せられたのはかたじけない。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼は社の用で、急ぎの画稿を北村のところへ頼みに行った。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と須田は改めて画稿のことを頼んだ。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「田圃で官兵に捕まったよ」「えッ」「上野で散々官兵を斬ったことを知って居る者があって、其場でなぶり殺し同様」「じゃ、矢張り」「これを見ろ」　芳年は、ポンと画稿を投げました。",
              "citation": {
                "source": "芳年写生帖",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えッ、畜生」　およつは画稿を叩き付けて、いきなり芳年に武者振り付きました。",
              "citation": {
                "source": "芳年写生帖",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "原画は薄い雁皮紙にかぎられていて、桜の版木に直接ノリ貼りされた画稿の上から、小さい鑿のさきが、一線一線絵を彫り起してゆくのだった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あ、描けているよ』　春作は、ふた晩も寝ていない眼をして、十数枚の画稿を、すぐそこへ持って来て渡した。",
              "citation": {
                "source": "魚紋",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべも、一昨日の晩も、この画稿のために、夜を更かしていたので、そのせいかとも思った。",
              "citation": {
                "source": "田崎草雲とその子",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれからです、さっそく画稿にとりかかり、いくたびか描きあらためて、ようやく、下絵が成ったので、ここへ持ってまいりました。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "はからずもその記憶が役だって、画稿の線のひとつひとつになろうとは。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも長持のなかには、武蔵が書損じた画稿の反古が、元結で束ねてあったりしたものだそうである。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと束に、丸めてあった画稿という中には、達磨の図とか、達磨の顔とか、肩のあたりまでとか、未完成で反古とした書損じが、同じ図ばかり何枚となく一まるめにしてあり、花鳥画ならば、やはり同様に三筆四筆落して途中で止めた物が、幾つか束になったまま、長持の蝕むに任せてあったということである。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第九回の見返しの画稿を携帯されるのではないかと思う。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがこういう場合にお定まりであるようにいろいろに誤解され訛伝されている。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘のような話だがこういう話が残っている。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしの子鳥達がこういうんです――」　ドュフランはいつも彼の世話子達をこういう言葉で呼んだ。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった一台交通規則を無視した車がいたため数十台が迷惑するというのがこういう場合の通則である。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がこういう感じを始めてはっきり自覚したのは外国から帰った当座の事であった。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西鶴がこういうテクニカルな方面における「独創」を尊重したのみならず、それをもって致富の要訣と考えていたことも彼の著書の到る処に窺われる。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこういう風の調査をあらゆる万葉仮名についてしたものがあったことがわかったのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこういう場合に、仮名で書き表わすのに「ン」を表わす仮名がなかった。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々に先立った人がこういう風にして吾々に残した。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかく、グロテスク美術が自然や文明の脅威から生れるものとすれば、あらゆる意味で不安な現代日本で産み出される絵画がこういう傾向をとる事は怪しむに足らないかもしれない。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑談は置いて、わたしがこうやってここへ来るのなんぞも、同じ道理かも知れないでしょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の方がたいてい大人しくしおらしくて女の方がたいて活溌で度胸がいいのがこうした群に共通な現象のようである。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
