        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はトランプの裏側に目立たない傷をつけて、特定のカードに密かにガンを付けていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "カジノのディーラーは、客がカードにガンを付けてイカサマをしていないか常に監視している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「これ、ガンを付けてあるから気をつけて」と、仲間のギャンブラーが耳打ちしてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
