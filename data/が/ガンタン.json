    "definitions": [
      {
        "index": 1,
        "gloss": "New Year's Day",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "元旦は家族みんなで初詣に出かけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "元旦の朝、初日の出を見るために海岸へ行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "多くの店が元旦は休業し、2日から初売りを始める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "――大正四年元旦――",
              "citation": {
                "source": "竹",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の光今朝や鰯の頭より　正月元旦の句である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明くれば元旦である。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に一月元旦に降ったからとて、必ずしも初雪とはいわず、前年の九月や十月頃に降った方のを、かえって初雪と称する。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "『その次は今から五年ばかり以前、正月｜元旦を父母の膝下で祝ってすぐ九州旅行に出かけて、熊本から大分へと九州を横断した時のことであった。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴風の跡の銀座もきたないが、正月｜元旦の銀座もまた実に驚くべききたない見物である。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和六年の元旦のちょうど昼ごろに、麻布の親類から浅草の親類へ回る道順で銀座を通って見たときの事である。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一　腹の立つ元旦　正月｜元旦というときっときげんが悪くなって苦い顔をして家族一同にも暗い思いをさせる老人があった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが年の始めのいちばんだいじな元旦の朝となると、きまってきげんが悪くなって、どうかすると煙草盆の灰吹きを煙管の雁首で、いつもよりは耳だって強くたたくこともしばしばあった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その老人のむすこにはその理由がどうしてもわからなかったのであったが、それから二三十年たってその老人もなくなって後に、そのむすこが自分の家庭をもつようになって、そうして生活もやや安定して来たころのある年の正月｜元旦の朝清らかな心持ちで起床した瞬間からなんとなく腹の立つような事がいろいろ目についた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "きれいに片付いているべき床の間が取り散らされていたり、玄関の障子が破けていたり、女中が台所で何か陶器を取り落としたような音を立てたり、平生なら別になんでもないことが、その元旦に限ってひどく気になり、不愉快になり、やがて腹立たしく思われて来るのであった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一方ではまた、きょうは元旦だから腹を立てたりしてはいけないという抑制的心理が働いて来る、そうするとかえってそれを押し倒すような勢いで腹立たしさが腹の底から持ち上がって来るのであった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、その瞬間にはじめて今までどうしてもわからなかった、昔の父の元旦の心持ちを理解することができたのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "元旦だからというのでつい医者を呼ばなかったばかりに病気が悪化するといったような場合もありうるであろう。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等学校時代のある年の元旦に二三の同窓といっしょに諸先生の家へ年始回りをしていたとき、ある先生の門前まで来ると連れの一人が立ち止まって妙な顔をすると思ったら突然仰向けにそりかえって門松に倒れかかった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いにまもなく正気づきはしたが、とにかくこれがちょうど元旦であったために特に大きな不祥事になってしまったのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月元旦は年に一度だから幸いである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一〇年の元旦にこの火山に登って湾を見おろした時には、やはりこの絵が眼前の実景の上に投射され、また同時に鴎外の「即興詩人」の場面がまざまざと映写されたのであった。",
              "citation": {
                "source": "青衣童女像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから病みつきで、なんということか、明けて元旦から松の内の間一日も缺かさず、悲しいくらい入りびたりだった。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "電報織田作之助　私は気の早い男であるから、昭和二十年元旦の夢をはや先日見た。",
              "citation": {
                "source": "電報",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて昭和二十年の元旦の太陽が前方の海に昇りはじめる頃、いきなり、「照井さアん！",
              "citation": {
                "source": "電報",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年から元旦には訪問客に酒を出すことになり、「まあ、一つやっとくなはれ」と朝から客の相手をして来たので、大分廻っているのである。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　その元旦の夜、権右衛門夫婦はいつ迄も眼覚めていた。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくるとしの元旦には、もっとめでたいことが起った。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "千羽の鶴が東の空から飛来し、村のひとたちが、あれよ、あれよと口々に騒ぎたてているまに、千羽の鶴は元旦の青空の中をゆったりと泳ぎまわりやがて西のかたに飛び去った。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年は「元旦」と見出を置いて一寸考えた。",
              "citation": {
                "source": "元日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "元旦、二日、三日、四日は遊んで暮してしまった。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちどは十九歳の元旦。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九歳の元旦のできごとから物語らう。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
