    "definitions": [
      {
        "index": 1,
        "gloss": "to be disappointed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なんだか、がっかりした。",
              "citation": {
                "source": "六月十九日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は、つまらない男であるから、逢えばきっとがっかりなさるでしょう。",
              "citation": {
                "source": "六月十九日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどくがっかりして、しかし結局あきらめて辛抱して待って、さてもういいかと思って催促すると、今度は何とかがどうとかして何とかで工合が悪いからもう二、三日待てという、その何とかが実に尤千万な何とかで疑う余地などは鷹の睫毛ほどもないのだから全く納得させられる外はなかった。",
              "citation": {
                "source": "鷹を貰い損なった話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やり切れねえなあ、嬶は又腹を膨らかしやがったし、……」彼はウヨウヨしている子供のことや、又此寒さを目がけて産れる子供のことや、滅茶苦茶に産む嬶の事を考えると、全くがっかりしてしまった。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "よだかはがっかりして、よろよろ落ちて、それから又二へん飛びめぐりました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　よだかはがっかりして、よろよろ落ちて、それから又、四へんそらをめぐりました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東北｜庁」　私はがっかりしてしまいました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "達二はがっかりして、黒い道をまた戻りはじめました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人にこだわりながら花見をして帰ると頭が疲れてがっかりしたものである。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山左がっかりして、Ｔ「致し方御座らん」○＝表　山左二両持ってトボトボと出て行きました。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへがっかりして腰を下した。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "大西は、いつもの元気に似ず、がっかりして、ベッドに長くなった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」がっかりしたような声でいって、藤二はなお緒を引っぱった。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれ男爵、ただ酒を飲み、白眼にして世上を見てばかりいた加藤の御前は、がっかりしてしまった。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "がっかりしたのも無理はない。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そことは君が号外を前へ置いてひどくがっかりしているところだ」「それはいけない、そんな気のきかないところは御免をこうむる。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「号外から縁がなくなって、君ががっかりしておるところが君の君たるところじゃアないか。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それじゃア諸君は少しもがっかりしないのか」と加藤君大いに不平なり。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そら見たまえ、僕ばかりじゃアない、決してない、だから、喜んでいるところを彫るのが平凡ならばだ、がっかりしているところだって平凡だろう、どうですね、中倉の大先生、」と「加と男」やや得意なり。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃア僕ががっかりの総代というのか」と加藤男また奇抜なことをいう。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "加藤君この時、椅子から飛び上がって、「さすが、中倉大先生様だ、大いによかろう、がっかりしたところ、大いによかろう、ぜひ願います、題して号外、妙、妙、」と大満足なり。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座は銀座に違いないが、なるほどわが「号外」君も無理はない、市街までがっかりしているようにも見える。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "話してしまってから、さもがっかりしたように枕によりかかったまま目をねむって黙ってしまったので、長座は悪いだろうと思って遠慮してすぐに帰って来た。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上等兵は、ここで自分までも上官の命令に従わなくって不具者にされるか、或は弾丸で負傷するか、殺されるか、――したならば、年がよってなお山伐りをして暮しを立てている親爺がどんなにがっかりするだろうか、そのことを思った。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼は、頭を両肩の中へ落しこんでしまう程がっかりした。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんにもないと、がっかりした顔つきをしたり、ぐず／＼云ったりした。",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
