    "definitions": [
      {
        "index": 1,
        "gloss": "bigoted",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の頑迷な考え方には、もう誰もついていけない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "伝統を守ることは大切だが、頑迷になりすぎると新しいものを受け入れられない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの老人は、頑迷なまでに自分の意見を曲げようとしない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "頑迷な態度が原因で、会議は一向に進まなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "こうした人々の談話の中には、農民一流の頑迷さが主張づけられていた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより、これは諷刺に非ず、格言に非ず、一篇のかなしき物語にすぎず、されど、わが若き二十代の讀者よ、諸君はこの物語讀了ののち、この國いまだ頑迷にして、よき通事ひとり、好學の白石ひとりなきことを覺悟せざるべからず。",
              "citation": {
                "source": "「地球圖」序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野暮な常識臭いものを固く執つて動かない蘆庵の頑迷｜不遜が彼の感興を醒した。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧弊な家風に反抗し、頑迷冷酷な義父と戦い、自由を求めて再び大学へ帰って来た、真実の友、正義潔白の王子として接吻、乾盃の雨を浴びるでしょう。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私、幼くして、峻厳酷烈なる亡父、ならびに長兄に叩きあげられ、私もまた、人間として少し頑迷なるところあり、文学に於いては絶対に利己的なるダンディスムを奉じ、十年来の親友をも、みだりに許さず、死して、なお、旗を右手に歯ぎしりしつつ巷をよろばいあるくわが身の執拗なる業をも感じて居るのだ。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生とは本来、青いマントを羽織ったチャイルド・ハロルドでなければならぬと、私は頑迷にも信じている者であります。",
              "citation": {
                "source": "心の王者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿な、頑迷のこの音楽を、聞きたい人だけは聞くがよい。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頑迷その物の化身かと思はれるやうな教頭がゐた。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "極度に気が弱って、いまは、無智な頑迷の弟子たちにさえ縋りつきたい気持になっているのにちがいない。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと、日本中に類のない愚劣｜頑迷の御手簡、ただいま覗いてみました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしかういふ極端に頑迷な思想は、或る新聞などによつてやや誇大に吹聽されてゐるに拘らず、ごく少數者の頭脳を司配してゐたに過ぎなかつた。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "深夜火器を弄して閨中の人を愕かせしバイロン、必らずしも狂人たりしにあらざる可し、蓋し女性は或意味に於て甚だ偏狭頑迷なる者なり、而して詩家も亦た、或点より観れば之に似たる所あるを免れず。",
              "citation": {
                "source": "厭世詩家と女性",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "――左う思ふと私は返つて今更の如くトシの魅力を明らさまにさせられるやうだつたが、それは私にとつてはやはり飽くまでも客観的のもので、私は久しい前からの自分の「女人厭悪症」とでも云ふべき頑迷な固疾から追はれてはゐない思ひが、奇妙に嘆かはしかつた。",
              "citation": {
                "source": "二日間のこと",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "此ノ歴史ト現代トヲ理解セザル頑迷圃體論者ト歐米崇拜者トノ爭鬪ハ實ニ非常ナル不祥ヲ天皇ト國民トノ間ニ爆發セシムル者ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等ノ信仰ガ強固ニシテ犧牲ヲ甘ンズル事例ヲ擧ゲテ對抗スルナラバ宗教ノ低級ナル者ニ於テ斯ル例ノ他ニ無數ナル者ヲ擧グ可ク、更ニ斯ク頑迷移サザル者多キガ故ニ殺スベシト云フ囘教ノ信仰ニヨリテ答ヘザルベカラズ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の頑迷を醜くゝ思つた彼だつたが、母にも増した小賢しい、小人の心の動きを圧えることが出来なかつた。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "厭だと云へば誰が何と云つても動かない、その代り自分から云ひ出せば相手がどうであらうと云ふことは諾かぬ――常々西岡はさうした頑迷さを自ら誇つてゐた。",
              "citation": {
                "source": "坂道の孤独参昧",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去の勢力は之を軽んずべからず、然れども徒らに過去の勢力に頑迷して、乾枯せる歴史の槁木に夢酔するは豈に国民として、有為の好徴とすべけんや。",
              "citation": {
                "source": "国民と思想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し村瀬は、単なる結婚などゝいふことでこの頑迷な病ひが救はれるとは何うしても考へられなかつた。",
              "citation": {
                "source": "女に臆病な男",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は自分でもその頑迷さが解らなかつた。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の父も、若い頃その父が大変頑迷だつたので屡々業を煮やして、この彼の祖母から金を借りて、秘かに村の茶屋で遊蕩に耽つたといふ話である。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界で一番頑迷なトーキー反対論者、（彼が明治維新に遭遇したら明治三十年ごろまでちよんまげをつけていたにちがいない）チャップリン。",
              "citation": {
                "source": "ルネ・クレール私見",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親は頑迷のため職をくび切られ、この一家もまた庄原の町から立ち退かねばならなくなってしまった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その病的な性格、頑迷な主我心、つまらない、せせこましい日常行状にもかかわらず、そうした自分が許されて救われていることだけは確信していたのだ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父さえその不幸な、一種の変質的な、頑迷な性格を持っていなかったら、家の中は裕福ではないながらも、明るく、楽しく暮らせたのは確かであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の渾沌たる智は、「今」に発育しつつある文明の急速な変転を知り、理解するには余り頑迷でございます。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し日本の官権の頑迷は今はじまつた事ではない。",
              "citation": {
                "source": "編輯室より（一九一五年五月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "スヰデンボルグの熱烈な科學的研究が、つひに頑迷な宗教家を生み出すに至つたのは、從來の習慣的宗教並に哲學の到底度すべからざるを證明して居るのである。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、この頑迷不霊な長官は、何人にとっても恐ろしい脅威であった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
