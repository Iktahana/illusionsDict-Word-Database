[
  {
    "uuid": "32aac692-af27-5e84-9bc9-079b8e89d28b",
    "entry": "慨嘆",
    "reading": {
      "primary": "がいたん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
