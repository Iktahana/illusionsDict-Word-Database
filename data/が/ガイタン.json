    },
    "definitions": [
      {
        "index": 1,
        "gloss": "deploring",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かうした工事が天然の風致を破壊すると云つて慨嘆する人もあるやうであるが自分などは必ずしもさうとばかりは思はない。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした工事が天然の風致を破壊するといって慨嘆する人もあるようであるが自分などは必ずしもそうとばかりは思わない。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう珍しい千代紙式に多様な模様を染め付けられた国の首都としての東京市街であってみれば、おもちゃ箱やごみ箱を引っくり返したような乱雑さ、ないしはつづれの錦の美しさが至るところに見いだされてもそれは別に不思議なことでもなければ、慨嘆するにも当たらないことであるかもしれない。",
              "citation": {
                "source": "カメラをさげて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者はこの老人が此夜に限らず時々得意とも慨嘆ともつかない気分の表象としてする仕方話のポーズを茲に紹介する。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "金力の跋扈、ことに下等獣類に等しき工夫共の手により質朴なる田舎に撤かるる悪銭は、実に慨嘆に堪えぬ。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "真に慨嘆に堪えない現状と云わなければならぬ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝廷に租税を収めない荘園の激増は、北畠親房もその神皇正統記に於て、乱国の始めだと云つて慨嘆してゐる如く、当時に於ける国家の大患であり、武士がその勢力を獲たのも、荘園が、その根拠を与へたからである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "三郎と六朗のことはさておき、その場の鱒二の姿には慨嘆に堪えぬものを覚えさせられた。",
              "citation": {
                "source": "喧嘩咄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、単に私自身を軽蔑し、慨嘆する溜息であつた。",
              "citation": {
                "source": "川を遡りて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――などと思つてゐたので、私は一層私自身に軽蔑と慨嘆とを覚えずには居られなかつたのである。",
              "citation": {
                "source": "川を遡りて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云つて慨嘆したりしたのだ。",
              "citation": {
                "source": "松竹座を見て（延若のこと）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその運命に就いても、かれは決して慨嘆の声を発してゐない。",
              "citation": {
                "source": "西鶴小論",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "」なんて慨嘆に似た声を出して見たのです。",
              "citation": {
                "source": "美智子と日曜日の朝の話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "楠殿が高時の酒九｜献肴九｜種を用ゆるを聞いて驕奢の甚だしいのを慨嘆したといふは、失敬ながら田舎侍の野暮な過言だ子。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今夜の会で自分たちの科の不振の事をしきりに慨嘆するから、三四郎もいっしょに慨嘆しなくってはいけないんだそうだ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "不振は事実であるからほかの者も慨嘆するにきまっている。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に国家の青年の風紀上慨嘆に堪えぬ次第であります」　これに対し学生の方はこう云う。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の前途のため実に慨嘆の至りだ」　こう両方で慨嘆されては手の付けようがない。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く慨嘆の至りである。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫く郎党と遠ざかつて、自ら「高尚なる趣味」に専念したせゐか、余程弁説の悪達者や嫉妬深さなどがなくなつたのに、又もとのもくあみだとわたしは慨嘆した。",
              "citation": {
                "source": "茜蜻蛉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「しかし……」　その時、砂日傘の下でポータブルの鍵を巻いてゐたひよろ長い男が厭に沁々とした口調で、「これだけ達者な面々が、いつも顔をならべてゐて誰一人として、これといふほどのラヴ・アツフエアを起さないなんて、考へて見ると実に慨嘆のいたりぢやないか。",
              "citation": {
                "source": "まぼろし",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「斯んなに騒いでゐる俺達の誰ひとりもが、彼女の脚にさへも触れることなしに……」「慨嘆も好いが、きはどい感情に走るな――左う聞いたゞけで俺の胸から腹へかけて、突如、稲妻のやうな冷いものが猛烈な勢ひで駆け抜けたわい！",
              "citation": {
                "source": "まぼろし",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、思はずもそんな連想を劃てる自分を秘かにウソ寒く慨嘆しながら、幾組となくつくつた連続画の憶ひ出を、どうやら益々詳細に吾阿父の上に対照せずには居られなかつた。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "『真心の何物をも持たない』と言つてフロオベルは慨嘆した。",
              "citation": {
                "source": "J. K. Huys Mans の小説",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "『私は此儘此寺の生活に入つて了ひたいが、しかし僧侶となるには、まだ余に文学者だ、さうかと言つて、文学者としては余りに思想が僧侶になりすぎてゐる』かう言つて Durtal は慨嘆して、『巴里に帰れば、仲間の文学者に逢はない訳には行かない。",
              "citation": {
                "source": "J. K. Huys Mans の小説",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまらんな、年を老ってしまったとつくづく慨嘆する。",
              "citation": {
                "source": "少女病",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "主僧はそれと心を定めたらしく、やがて、「人間というものはいつ死ぬかわかりませんな」と慨嘆して、「ちょっと病気で病院にはいってるということは聞きましたけれど、死ぬなどとは夢にも思わなかったですよ。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へばボートの選手が、クラッチがいたんだンで俺は負けたんだ、さもなけあ勝つに決つてたんだがと嘆くとする、するとボートの漕げない奴が、クラッチのいたんだことを経験出来るだけでも仕合せだ、それで嘆くなんて、てんで漕げもしない俺なんざ、そいぢやァどうして呉れるんだといふのと同しぢやないか。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "掃除は早いが畳がいたんだり障子｜唐紙へ穴をあけるのでは少なくも日本の女中の登用試験では落第であろう。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "村を出てしまったころに、松吉は、じぶんの右手がいたんでいることに、気がつきました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
