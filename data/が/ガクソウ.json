[
  {
    "uuid": "76380bd8-2170-59fb-80ff-8abdb7783b8f",
    "entry": "学僧",
    "reading": {
      "primary": "がくそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "learned priest pursuing his studies",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "若い学僧たちは、仏教の教えを深く理解するため日々研鑽を積んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの寺には、海外から来た学僧が何人も滞在して修行しているそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "師は、その学僧の熱心な姿勢を見て、さらなる教えを授けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "学僧が書いた仏教哲学に関する論文が、専門誌に掲載された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "真の学僧｜気質で、俗気が微塵ほども無く、深く名利を悪んで、断岸絶壁の如くに身の取り置きをした。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　　　　　＊　　　　　＊　　　　　＊下手より五六の学僧（学頭、所化長順、所化乗円其他）登場。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（完）（付）虎が人に方術を教えた事『日本紀』二四に、皇極天皇四年四月、〈高麗の学僧ら言さく、「同学｜鞍作得志、虎を以て友として、その術を学び取れり。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが邦でも昔は兎を八｜竅と見た物か、従来兎を鳥類と見做し、獣肉を忌む神にも供えまた家内で食うも忌まず、一疋二疋と数えず一羽二羽と呼んだ由、古ギリシアローマの学者またユダヤの学僧いずれも兎を両性を兼ねたものとしてしばしばこれを淫穢不浄の標識とした（ブラウン『俗説弁惑』三巻十七章）。",
              "citation": {
                "source": "十二支考",
                "author": "兎に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "学僧だけを選んで討論をさせて聞いたりした。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "邦俗ホンダワラてふ藻を神馬草というは、その波に揺れながら枝葉間に諸生物を安住せしむる状を件の神馬王の長毛に比して学僧輩が名づけたのかも知れぬ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて沖縄の方では古来国子監や福建あたりで学んで帰った久米村人が支那思想の代表者で鹿児島で学んで帰った留学僧の連中が日本思想の代表者であったが、慶長の頃に至ってはこの儒者と僧侶が銘々の職業を離れて政治に嘴を容れるようになっていたのであります。",
              "citation": {
                "source": "琉球史の趨勢",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧は名を聞きしことある学僧にて、倉光治文師に候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その坊さんが若くて、学僧らしい顔付きをしていると人気があった。",
              "citation": {
                "source": "西川小りん",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "其子孫は固より、学者・学僧等が、此為事に当つた。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで博多聖徳寺の学僧玄蘇を正使に立て、義智自身は副使になつて渡韓した。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の学僧ボッスュエは、演劇の風教問題を論じ、俳優稼業の卑むべきを述べて、かう結んでゐる。",
              "citation": {
                "source": "仏蘭西役者の裏表",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡来僧か、こちらから行った留学僧かがその称呼をあらわす文字をその実物と共に持って来たものに違いない。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "質問を受けた当の案内役は、以前のこましゃくれた、肖ている小坊主ではありません、しとやかな学僧の一人で、且つ、極めて無口の若者でありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくに、拝観人から、それだけの質問の口火を切れば、それをきっかけに、学僧によっては、滔々と知識を振蒔いて見せる、諄々と豪者を啓くの態度を取ってみたりする学僧もあるのですが、この学僧には絶えてそういう好意がなく、衒う気もありませんから、お銀様はそれ以上に知識を要求するの機会を失いました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "此世紀の生活からさへ絶縁された、森の奥の、陰鬱な僧房に住みふるした学僧だとは思はぬかもしれない。",
              "citation": {
                "source": "クラリモンド",
                "author": "LA MORTE AMOUREUSE",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの人々には全く無意味に思はれる是等の凡ての事が、昨日始めて恋に落ちた、経験も無く、金も無く、美しい着物も無い燐れな学僧のわしには、偉大な事のやうに思はれたのである。",
              "citation": {
                "source": "クラリモンド",
                "author": "LA MORTE AMOUREUSE",
                "note": "青空文庫"
              }
            },
            {
              "text": "推古天皇朝の留学僧｜新漢人日文を後に旻法師ともいっている。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば他の諸山からも、心ある学僧の一慶様の講莚に列なるものが多々ございました。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "屈強な学僧づれを頼んで、文庫も燃させることではないぞ」などと、仰せになったものでございます。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中を、どこをどう廻って来られたものか、松王さまは学僧衆三四人と連れ立たれて走せつけて下さいました。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "物を問おうにも学僧衆はおろか、承仕法師の姿さえ一人として見当りません。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "屈強な学僧づれを頼んで、文庫も燃させることではないぞ」などと、仰せになつたものでございます。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中を、どこをどう廻つて来られたものか、松王さまは学僧衆三四人と連れ立たれて走せつけて下さいました。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "物を問はうにも学僧衆はおろか、承仕法師の姿さへ一人として見当りません。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の南蛮宗の論師は、学僧フルコム伴天連。",
              "citation": {
                "source": "ハビアン説法",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "金剛寺の若い学僧たちも、肩をいからして、道ばたに立ちならんでいた。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの辺は水道が大変よくなくてお茶がくそうございます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
