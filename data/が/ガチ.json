  {
    "uuid": "697e6a2e-bc8d-5f20-a99d-f86532a7c87e",
    "entry": "がち",
    "reading": {
      "primary": "がち",
      "alternatives": [
        "ガチ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "serious",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「次の試合、俺はガチで勝ちにいくからな。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「え、それガチで言ってるの？冗談かと思った。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女は普段おとなしいけど、ゲームのことになると途端にガチになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "何故なら詩性に乏しい現今は、兎角、あまりに貧弱なモチーフを取上げることから、多くの詩が妙な複雑に堕しがちである。",
              "citation": {
                "source": "菊岡久利著「貧時交」",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ私たちのかうした友情は、世にも珍なる彼のはればれしき男性的性情と、やや女性的で憂鬱がちなる私の貧しき性情との奇蹟めいた会遇によつて結びつけられた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "平常の紳士的な芥川君とは、全で態度がちがつてゐる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その時芥川君の顏には、ある悲しげなものがちらと浮んだ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつき経ち、ふたつき経って、そろそろ百日目がちかくなって来ても、私たちはだまって見ていなければいけません。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "コクトオは気がちがいそうになって日がな一日オピアムばかりやってるそうだし、ヴァレリイは十年間、唖者になった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって、桜には、においがちっとも無いのだもの。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "短歌や俳句がちやんとした娘ならば、詩の多くは云つてみればおひきずりであつた。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くいふは世人屡々芸術作品を以て、箒なら箒、手拭なら手拭といふ一定のテーマがあつて、それの種々なる解説（インタプリテイション）が彼是の作品だとなしがちだからである。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり名辞以前の世界が閑却されがちである。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だつて此の人は行き方がちがふんぢやないの」　Ｓ子が従兄に言つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただロマンチシズムとリアリズムとは、主観の発想に関するところの、表現の様式がちがうのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶯のあちこちとするや小家がち「籬落」という題がつけてある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつどこかスタイルがちがっており、句の心境にも芭蕉風の静寂な主観が隠見している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句もやはり、そうした主観的郷愁の一咏嘆であるが、特に心の詩情を動かしやすく、ロマンチックで夢見がちな初夏の季節を、更衣の季題で捉えたところに、句の表現的意義が存するのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし夏の湿気がなく、家屋の構造がちがってる外国人にとって、こうした俳句は全然無意味以上であり、何のために、どうしてどこに「詩」があるのか、それさえ理解できないであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月雨や御豆の小家の寝覚がち「五月雨や大河を前に家二軒」という句は、蕪村の名句として一般に定評されているけれども、この句はそれと類想して、もっとちがった情趣が深い。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に夏の部で評釈した句「五月雨や御豆の小家の寝醒めがち」も、どこか色っぽい人情を帯びてはいるが、詩情の本質においてやはりこれらの句と共通している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水鳥や朝飯早き小家がち　川沿いの町によく見る景趣である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村の俳句においては、この点で表現の様式がちがっている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば鶯のあちこちとするや小家がち　　　蕪村春の海ひねもすのたりのたり哉　　　蕪村　の如く、「あちこちとするや」の語韻から、鶯のチョコチョコとする動作を音象し、「のたりのたり」の音調から春の海の悠々とした印象を現わしているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その建築の家屋の上に、雪がちらちら降ってるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "武雄の温泉宿で泊ったのがちょうど大晦日の晩であった。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十二年の暮には南ドイツからウィーンを見物してヴェニスに泊ったのがちょうどクリスマスであった。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがいろいろ様式がちがう。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手の車庫のトタン屋根に雀が二羽、一羽がちょんちょんと横飛びをして他の一羽に近よる。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツ生れのＯ夫人がちゃんと時刻をたがえずやって来て一つの鍋のロースを日本の箸ではさんでいた。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉の大木の下に床几を積み上げたるに落葉やゝ積りて鳥の糞の白き下には小笹生い茂りて土すべりがちなるなど雑鬧の中に幽趣なるはこの公園の特徴なるべし。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その傍に立った丸髷の新婦が甲斐甲斐しく襷掛けをして新郎のために鬚を剃ってやっている光景がちらと眼前に展開した。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらの氷店へはいって休んだ時には、森の中にあふるる人影がちらついて、赤い灯や青い旗を吹く風も涼しく、妹婿がいつもの地味な浴衣をくつろげ姪にからかいながらラムネの玉を抜いていた姿がありあり浮ぶ。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
