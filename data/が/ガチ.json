[
  {
    "uuid": "bb4ece26-bc4e-5a77-906a-216d18fe5e5f",
    "entry": "雅致",
    "reading": {
      "primary": "がち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "artistry",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その庭園は、隅々まで手入れが行き届いており、雅致に富んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女の生ける花は、素朴ながらも独特の雅致を感じさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "古い書道具には、現代の製品にはない雅致がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "それに好い加減古びてゐるのと場所柄とで、何となく物寂びた雅致を帯びて、静かな廃屋といつたやうな情趣がある。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四畳半とし云へば、何やら茶人めいたる清淡雅致の一室を聯想すべけれど、我が居室は幸にして然る平凡なるものにあらず。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下に大学の臨海実験所の白い雅致のある洋館がある。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "外人が、常にギリシア・ローマの古書にのみ載せられて今の欧米に見る能わざる風景雅致を、日本で始めて目撃し得、と歎賞｜措かざるところたり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "只海邊に自然に生長して居るだけ枝も葉もひねびて一段の雅致を帶びて居る。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱海の梅園は、山腰に據り、清溪流れて、雅致あり。",
              "citation": {
                "source": "久地の梅林",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑の松、紺碧の海原、白く輝く砂、雲の影もなく晴れた空、雅致ある漁船――至るところに好画題が満ち溢れてゐた。",
              "citation": {
                "source": "清一の写生旅行",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉蟲染の天鵞絨のやうな薔薇の花、紅と黄の品格があつて、人の長たる雅致がある玉蟲染の天鵞絨のやうな薔薇の花、成上の姫たちが着る胴着、似而非道徳家もはおりさうな衣服、僞善の花よ、無言の花よ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに雅致掬すべき街だ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは／＼雅致のある音が出ますね。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村の句時に譬喩を用いるものありといえども、譬喩奇抜にして多少の雅致を具う。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村とは天王寺｜蕪の村ということならん、和臭を帯びたる号なれども、字面はさすがに雅致ありて漢語として見られぬにはあらず。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "南宗を学びしはその雅致多きを愛せしならん。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳画は蕪村の書きはじめしものにして一種摸すべからざるの雅致を存す。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "真面目な雅致のある方の句はわかって居るが微細な点に意を注いだ句の味は少しわかりかねるようである。",
              "citation": {
                "source": "病牀苦語",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の宗匠者流は繊細に偏してしかも雅致を解せず、俗趣を主とす。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "「白眼看他世上人」と言へば「世上人」は極めて俗なる者なれども「白眼看」の三字を添へて無上の雅致を生ずるが如し。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "その事物如何に雅致ある者なりとも、十七字に余りぬべきほどの多量の意匠を十七字の中につづめんことは殆んど為し得べからざる者なれば、古来の俳人も皆これを試みざりしに似たり。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "雅致のある支那風な桃色の用箋にそれが認めてある。",
              "citation": {
                "source": "食堂",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはまた支那人の部屋にあつてこそよく調和するやうな赤と黄の色に塗つたもので、自分の部屋などには不似合な調度ではあつたが、支那風な好みの形にも雅致があり、寢心地も惡くない。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "装飾としても好ましい、古く手摺れて反って雅致のある色彩を集めた書棚の前を往ったり来たりして見る序に、捨吉は教員室の入口に近い壁のところへも行って立って見た。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "無器用なようで雅致のある支那風の陶器とか、刺繍とか、そんな物まで未だ山本さんの眼についていた。",
              "citation": {
                "source": "船",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "古びて荒れが見えてはいるが、※などにはない雅致が家のすべてにあった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは京の名所を一々に写生したもので、その画に雅致のあることはいふまでもなく、その画がその名所の感じをよく現はして居ることは自分のかつて見て居る処の実景に比較して見てわかつて居る。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただその筆つきに至つては、広重には俗な処があつて文鳳の雅致が多いのには比べものにならん。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに銀杏の葉といふものも形の雅に色の美しきのみならず虫さへ食はぬほどの清潔な者であるから何かこれを装飾に利用したら雅致のある者が出来はすまいかと思はれる。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蟇というものは一見すると無気味じゃが、よく見ると仲々雅致がある。",
              "citation": {
                "source": "高島異誌",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも明石はなれなれしさの過ぎるほどにも出過ぎたことなどはせず、紫夫人はまた相手を軽蔑するようなことは少しもせずに怪しいほど雅致のある友情が聡明な二女性の間にかわされていた。",
              "citation": {
                "source": "源氏物語",
                "author": "藤のうら葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら詩性に乏しい現今は、兎角、あまりに貧弱なモチーフを取上げることから、多くの詩が妙な複雑に堕しがちである。",
              "citation": {
                "source": "菊岡久利著「貧時交」",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ私たちのかうした友情は、世にも珍なる彼のはればれしき男性的性情と、やや女性的で憂鬱がちなる私の貧しき性情との奇蹟めいた会遇によつて結びつけられた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
