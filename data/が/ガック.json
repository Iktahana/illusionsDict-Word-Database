[
  {
    "uuid": "f5cbc5b8-f4e5-5d05-b3a1-3abc9e420974",
    "entry": "学区",
    "reading": {
      "primary": "がっく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
