    "definitions": [
      {
        "index": 1,
        "gloss": "evacuation of school children (from major cities to more rural areas, esp. during late World War II)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "戦争中、都市の子供たちは安全な地方へ学童疎開しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖母は「学童疎開で初めて故郷を離れた」と、当時の寂しさを語ってくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "当時の日記には、学童疎開先での集団生活の様子が詳細に記されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "学童疎開の経験が、彼の人格形成に大きな影響を与えたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "疎開の意味で、高子には五日市町の方へ一軒、家を持たす、そして森家の台所は恰度、息子を学童疎開に出して一人きりになっている康子に委ねる、――そういうことが決定すると、高子も晴れがましく家に戻って来て、移転の荷拵えをした。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "康子の荷物は息子の学童疎開地へ少し送ったのと、知り合いの田舎へ一箱預けたほかは、まだ大部分順一の家の土蔵にあった。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "次兄の息子も二人、学童疎開に行っていたが、汽車が不通のためまだ戻って来なかった。",
              "citation": {
                "source": "廃墟から",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "次兄の息子も二人、学童疎開に行つてゐたが、汽車が不通のためまだ戻つて来なかつた。",
              "citation": {
                "source": "廃墟から",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "疎開の意味で、高子には五日市町の方へ一軒、家を持たす、そして森家の台所は恰度、息子を学童疎開に出して一人きりになつている康子に委ねる、――さういふことが決定すると、高子も晴れがましく家に戻つて来て、移転の荷拵へをした。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "康子の荷物は息子の学童疎開地へ少し送つたのと、知り合ひの田舎へ一箱預けたほかは、まだ大部分順一の家の土蔵にあつた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "罹災以来、私と一緒に次兄の許で厄介になつてゐた妹は、既にその頃、他所へ立退いてしまつたが、それと入れ替つて、次兄の息子たちが、学童疎開から戻つて来た。",
              "citation": {
                "source": "小さな村",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "学童疎開に行つてゐた二人の弟たちが還つて来ると、狭い家のうちはごつた返し、暮しは一層苦しくなつてゐた。",
              "citation": {
                "source": "星のわななき",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "学童疎開の問題について、校長から父兄に話があるといふので、矢代初瀬も出席した。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "学童疎開などの関係あり、汽車頗る混む。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に今は学童疎開で、その制限が一層なのに。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "学童疎開がやかましくなり、博雄の学校も長野県の田沢へ疎開することになった。",
              "citation": {
                "source": "親は眺めて考えている",
                "author": "金森徳次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "学童疎開は強制的ですらあった。",
              "citation": {
                "source": "親は眺めて考えている",
                "author": "金森徳次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうの学童疎開の日は、二三日さきのことだ。",
              "citation": {
                "source": "親は眺めて考えている",
                "author": "金森徳次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そのまえ、彼は学童疎開で仙台の松島へいっていた。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
