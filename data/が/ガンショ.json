        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「こちらに祈願の願書をお書きください。お願い事とお名前を記入して、あちらの箱に納めていただきます」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は自らの決意を神様に伝えるため、静かな境内の片隅で、一字ずつ丁寧に願書を書き上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "奉納された数多くの願書には、病気平癒や商売繁盛など、参拝客たちの切実な願いが込められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
