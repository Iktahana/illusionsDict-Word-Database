        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「おお、久しぶりに君からの雁書を手に取ったよ。遠く離れた地で元気にしているようで安心した」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は旅先での見聞を美しい文章にまとめ、故郷で待つ許嫁への雁書として託した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "電子メールが当たり前の時代だからこそ、丁寧に認められた雁書には、送る側の温もりと品格が宿る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ついお囃子に浮かれ出いて、お社の神様、さぞお見苦しい事でがんしょとな、はい、はい。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「森々としたもんでがんしょうが。",
              "citation": {
                "source": "栃の実",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでも洋服とは楽でがんしょうがの」と、初やが焜炉を煽ぎながらいう。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "手近い家に声を懸けて唐松尾への道を聞くと、黒暗天女のような顔をした四十｜許の女が出て来て「わしは知らねえだよ、一ノ瀬へ行って聞いたらようがんしょう」といわれて、早々に逃げ出す。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お化けか、そうでなければ天狗様のいたずらでがんしょう」「お前は、それを調べてみましたか」「いいえ、そういうことはしてみましねえ」「さまで遠くはないようだ」　　　　　　　　　九　けれども、響きがあって物のないという道理はありますまい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "何方が徳でがんしょう？",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何方が悧巧でがんしょう？",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
