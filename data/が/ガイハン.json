[
  {
    "uuid": "27dcff6e-b2ef-5112-a8e9-069c0b58bc10",
    "entry": "外販",
    "reading": {
      "primary": "がいはん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "outside sales",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "自社製品の認知度向上のため、来月からは本格的な外販戦略を展開する予定です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このソフトウェアは、当初社内向けに開発されたが、その後、外販も成功している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "小売店だけでなく、企業への外販チャネルも強化していく必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「うちの技術、外部に売ってみない？」「いいね！外販の担当者と話してみよう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "これが案外販路がひらけて、四、五年の後には、この方が九谷焼としてより多く認められるようになって来た。",
              "citation": {
                "source": "九谷焼",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
