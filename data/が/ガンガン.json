        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あの蒼白い美しい柱時計がガンガンガンガン六時を打ちました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、ガンガン硝子戸を叩いた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのガドルフの頭と来たら、旧教会の朝の鐘のようにガンガン鳴っておりました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そばにあった鉄の棒でガンガンと軽く鳴らして見せました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体中がガタガタと慄えて、頭が物に取り憑かれたようにガンガンと痛み出した。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "承知で貰うた婿じゃけに、今更、苦情は云われんけんど、タッタ三｜室しかない家の中が、ガンガン云うて八釜しうてなあ……それにあのラジオの鳴りよる間が、養子殿の極楽でなあ。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの音のガンガン鳴り続けいる中なら、妾たちがドンナに無残い殺されようをしても村の人には聞えやせんでなあ。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬほどイヤなお提灯記事、御機嫌取り記事、尻拭い原稿なぞいうものを、電話や靴の音がガンガンガタガタと入り乱れるバラックの二階で、一気に、伸び伸びと書き飛ばし得る神経になり切っていたのです。",
              "citation": {
                "source": "スランプ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこも三高生の寮歌がガンガンと鳴り響いていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソフト側では文書と図形のエディターに通信ソフトをあらかじめ持たせ、モデム、ハードディスクを標準で付けて文書作成と通信にガンガン使ってくれという仕立だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この手のマシンはきっと「Ｗｉｎｄｏｗｓくらいガンガン走らせまっせ」と言ってくれるだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "男らしくねえことはするな」　口癖のように、怒鳴る忠次の声が、耳のそばで、ガンガン鳴りひびくような気がした。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、ふたりの者には来ない理由がよくわかっているとみえて、必死に人込みを押し分けながら、岸べまで駆け降りていった様子でしたが、伝六が例の調子で、ガンガンとどなりながらいいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、面を向けるには向けても、いっこう気がなさそうに、ゆうぜんとあごの先をなでさすったままでしたから、あいきょう者がたちまちガンガンとやりだしたのは当然でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガンガンいうと人だかりがするから、黙ってついてきたらいいじゃねえか」「じゃ、なんですかい、だんなの目にゃ、この大川が上へ流れているように見えるんですかい」「うるせえな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "みっともねえ、ガンガン大きな声を出すなよ」「声のでけえな親のせいですよ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうまあガンガン安鳴りさせずと、その足もとをよくみろよ」　いわれて足もとの流し口をなにげなく見ると――、こはそもいかに！",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お人さまがいらっしゃるのに、そうガンガン鳴るな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「耳もとでガンガンとうるさくほえるなといってるんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたしはあの声を聞くと、耳が、ガンガンして目舞がして来るわ。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して不愉快ではなかつたが僕は、頭がガンガンしてしまつたので、ひとりで散歩に出かけた。",
              "citation": {
                "source": "センチメンタル・ドライヴ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜霧でびっしょり濡れた朝の街路の上を拡声器から出るラジオの音がガンガンと響いてゆく。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "警報班員は一人一人、石油缶を肩からつって、ガンガン叩いて駈けだす。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭脳がガンガン鳴って、心臓の鼓動も激しかった。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
