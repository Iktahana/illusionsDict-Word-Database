  {
    "uuid": "af6fa2df-4cda-59d8-969e-b34a04960a24",
    "entry": "学都",
    "reading": {
      "primary": "がくと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "university town",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "学都といわれているボストンなどでは、いわゆる上流社会の子弟がはいる私立の小学校で、授業料が一年五百ドル（十八万円）くらいというところがある。",
              "citation": {
                "source": "知られざるアメリカ",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木戸にまた高く札うち、蓮葉なる金切ごゑと老いたるが絶えず客よぶ、――と見る、ただ赤丹剥げたる閻魔王、青き牛頭馬頭、講釈のなかばいちどにがくがくと下顎鳴らす。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、泳ぎに慣れていない者がもがくときには、両腕をかならず上へ突き上げ、また頭をいつものように垂直の位置にしておこうとする。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「…………」　更に疑ひを深めたことには、その時わたしの膝がしらは、空しい不幸の悲しみから、がくがくとふるへ出してゐたのである。",
              "citation": {
                "source": "好日の記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "・暮れて雪あかりの、寝床をたづねてあるく・木の葉が雪をおとせばみそさゞい・雪でもふりだしさうな、唇の赤いこと・春の雪ふるヲンナはまことにうつくしい・春比佐良画がくところの娘さんたち・からたちにふりつもる雪もしづかな家　　　追加一句　みんな洋服で私一人が法衣で雪がふるふる　三月九日　愚郎居。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが　くらい底のない闇につきおとされて、くるしさにもがくとき、あなたのひかりがきらきらとかがやく。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、高名な浮世絵師えがくところの美女も、みなその粉本はこの狭斜のちまたから得ている。",
              "citation": {
                "source": "明治大正美女追憶",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "その真白く大きく開いた口の下顎が左右にがくがくと動き出した。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈料を吝んでいるのですから、姉妹二人とも薄暗い石油｜洋燈の光で、それも、少しでもながくともせば、こいつが大騒ぎなんです。",
              "citation": {
                "source": "聖アレキセイ寺院の惨劇",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、それと分るとぞっと寒気がし、顎ががくがくとなり、膝がくずれそうになった。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れて育った郷里のなつかしさががくがくと咽喉につかえた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこからしばらく、がくがくと動いている教師の顎を眺め、眺めているうちに彼のだらしない唇のすみからは涎が垂れ落ちた。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、どうしてこの階から上へ逃げだしたろう」　Ｘ号はがくがくとからだをふるわせて、興奮しきっていたのである。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "高声器が、がくがくと、ひどい雑音をたてた。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もがくとかえってひどい目を見る。",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもこれは乱暴だと振りもがくところを横に捩ったら、すとんと倒れた。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　だいがくとひげことさて、日の神の肖像としては、どういふものを立てるか。",
              "citation": {
                "source": "盆踊りと祭屋台と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "京の祇園の鉾を見たものは、形の類似から直ちに、其模倣だと信ずるかも知れぬが、だいがくと同型のものゝ分布してゐる地方の広い点から見ると、決して五十年百年以来の模倣とは思はれない。",
              "citation": {
                "source": "盆踊りと祭屋台と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "またでむがくといひて、あやしき様なるつゞみ、こしにゆひつけて、笛ふき、佐々良といふ物つき、さま／″＼の舞ひして、あやしの男ども歌うたひ、ゑひて心地よげにほこりて、十人ばかりあり云々。",
              "citation": {
                "source": "田遊び祭りの概念",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、日もおなじければ、曳く飾り山もおなじだいがくと言ふ大きな鉾であつた。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまで永い間私はあまり荒々しい人々のなかにのみ棲みすぎたように思っていましたが、あなたと逢って私は鳩のような、小鳥のような――それは私の心にながくとざされていたところのやさしい情緒をふるさとのおとずれでも聞くように思い出しました。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "がくと言ふ名に、社寺の奴隷の演ずる雑楽の感じがあつたのだ。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "もがくと、ますます痛い。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてスミス老人がぶるぶるふるえだしたわけを、それとさっして、これまた顔色が紙のように白くなり、ひざのあたりががくがくとふるえだして、とめようとしても、とまらなかった。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "俵のなかのからだが蓑虫のようにビクビクもがくところから蓑踊りと称したという。",
              "citation": {
                "source": "二合五勺に関する愛国的考察",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれが、だいがくと言ふ物なのである。",
              "citation": {
                "source": "だいがくの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其はともかく、住吉祭りといふ事が、だいがくと住吉踊りの傘鉾との関係を見せて居る様に思はれる。",
              "citation": {
                "source": "だいがくの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯をみがくと神経を刺戟して歯痛を起す。",
              "citation": {
                "source": "退歩主義者",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
