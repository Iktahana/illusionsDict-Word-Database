        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "舞台の端でがやとして登場するだけでも、役者にとっては貴重な経験となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映画のワンシーンで、背景に映るがやの一人になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "がやを募集する掲示を見て、友人と一緒に応募してみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
