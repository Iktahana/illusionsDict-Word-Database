        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "母は「早く起きなさい」とガミガミ言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "上司が部下をガミガミと叱責している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "勉強のことばかりガミガミ言われると、やる気がなくなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "妻のガミガミにうんざりしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "」夜中の二時頃、俺が集合場に馳せつけると、志願兵上りの少尉が見つけてガミガミ云う。",
              "citation": {
                "source": "防備隊",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の気持に思い遣りがなく、ただもう頭からガミガミ怒鳴り付ける。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "三好が、一番下手なんで、貴方が三好ばかりガミガミ云ったもんだから、あれっきり来なくなっちゃったんですが……」「ウム。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はどうせあとでわかることだからと思って取っといたのです」チーフメーツも、船長からガミガミやられると「何だこの野郎、おれだってあと一年で船長の免状がとれるんだぞっ」と思わざるを得ないのであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、突然彼女をガミガミと勢急に罵り出した。",
              "citation": {
                "source": "秋晴れの日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　照子が来ない前から焦ら立つてゐる私の神経は、ガミガミと震へるのだつた。",
              "citation": {
                "source": "妄想患者",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ読んでさえ七むずかしいのに弱らせられるんだから、あの気難かし屋に捉まったら災難だ、頭からガミガミと叱られるなら我慢し易いが、ネチネチとトロ火で油煎されるように痛めつけられたら精も根も竭きて節々までグタグタになってしまうと、恐れを成さずにはいられまい。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいじょうぶだ、へびはいねえよっていってやりましたら、おれさまともあろうものが、こまっけえやつの下風についてたまるけえと、こんなことをガミガミ言いのこしまして、どこかへずらかっちまいましたんですよ」　いっているところへ、どうもやることなすことが伝六流でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処にはかれのあとをつけねらっている刑事もなければ、かれに向ってガミガミ言う力の強い妻もいない。",
              "citation": {
                "source": "トコヨゴヨミ",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "善い悪いは、十分わかっておりながらも、頭からガミガミ叱らずに、だまって愛の涙で抱擁してくれる人もほしいのです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりガミガミ云っちゃ可哀そうですよ」　と、隅に腰を下ろしていた髭蓬々の男がいった。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旦那さんと奥さんがガミガミ馬鹿にしてんのはいいけんど、奥さんが叱られると、きっとこっちへ当って来るから、ほんとにやになっちゃう」　旦那さんが細君にやられても派出婦なんかに当りちらさないが、細君はきっと当って来るものだそうだ。",
              "citation": {
                "source": "想像力",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガミガミと途方もなく苛立って続けざまに発砲するのだが、癇癪を起せば起すほど腕が震えて埒があかず、終いには人畜を害ねなければ溜飲が下らなくなってしまうという始末の悪い迷信的潔癖性に富んでいた。",
              "citation": {
                "source": "ゼーロン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "由はまだ子供らしさが抜けきらないのでせうか、かへつて、ガミガミ叱られた方がいいなぞと思つたりしました。",
              "citation": {
                "source": "小さい花",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしあの時の二百両で諸方の借金を払ったのでどこからもガミガミ催促には来ない。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自棄が手伝っての昼の酒さ、まあそうガミガミいわねえものだ」　編笠を脱いで抛り出し、両刀を取って脇へ置くと、火鉢を中にお吉と向かい合い、「どうだ今日の商売は？",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "計画して行動しなきゃ駄目だと私はガミガミ云いました。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ウチの常務は、寝小便をたれた後と、神様の前へでた時だけは、平伏悄然モーローとしているけれども、その他の時はガミガミ口うるさいッたら。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんみたいに、神経質にガミガミ云ったって、この戦争じゃア、我々だっていつ手でケツをふかなきゃならないか分りゃしないね。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも性が合わないで、それが米友の弱味になって、頭からガミガミ言われても、得意の啖呵を切って、木下流の槍を七三に構えるというようなわけにはゆかないから不思議であります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "大雪の寒い日だから、コタツをだせ、コタツの上にのせる板はないか、ガミガミやられて、京家はちぢみあがったらしいな。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "道頓堀罷り通る",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、日本料理というと、そうはいかないのでありまして、私どもが料理人を使っていて、朝から晩までガミガミいっていましても、なかなかうまく出来ない。",
              "citation": {
                "source": "日本料理の基礎観念",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "いゝから、遠慮しないで、これまでどほり、ガミガミやつつけてくれ。",
              "citation": {
                "source": "女人渇仰",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうガミガミ、頭ごなしに夫婦になれつていつたつて、おいそれと簡単になれるもんぢやないだらう。",
              "citation": {
                "source": "道遠からん　四幕",
                "author": "――または　海女の女王はかうして選ばれた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あすの朝、おれを起す時に、「もう時間ですよ」なんてガミガミ呶鳴らずに、黙つて、枕もとで蓄音機をかけてくれ。",
              "citation": {
                "source": "明日は天気（二場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなにガミガミ云ふなよ、みつともない。",
              "citation": {
                "source": "ガンバハル氏の実験（ラヂオドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ぢや、もうガミガミ云はない。",
              "citation": {
                "source": "ガンバハル氏の実験（ラヂオドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ待ってくれお前達、そうガミガミ云うものではない。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうガミガミ云うものでない、食って行かれればいいじゃあないか。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあさ日本のお若い紳士、そうガミガミ云うものではない。",
              "citation": {
                "source": "赤げっと　支那あちこち",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
