        "examples": {
          "standard": [
            {
              "text": "統計によると、日本人の死因で最も多いのは癌死であり、早期発見の重要性が叫ばれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「叔父も癌死だったから、自分も定期的に人間ドックを受けなきゃって思ってるんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長年の不摂生がたたったのか、彼は若くして癌死という悲劇に見舞われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "医療の進歩により、かつては避けられなかった癌死を防げるケースが増えてきている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「和歌山県と奈良県の癌死亡者は人口百万人にたいして千人以上で、比率の大きなことでは世界的に有名なんですってね……先生、あたし和歌山なんです」　内科の主任は虚を衝かれたような気むずかしい顔になった。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お雑作でがんした」礼もちゃんと言った。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついお囃子に浮かれ出いて、お社の神様、さぞお見苦しい事でがんしょとな、はい、はい。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――爺さんにいひますとね、（氣の毒でがんしたなう。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「森々としたもんでがんしょうが。",
              "citation": {
                "source": "栃の実",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「引き懸けた処でがんしよ……鮒一尾入つた手応もねえで、水はざんざと引覆るだもの。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかゞあれだ、昨夜持つて行かしつた其の形代の像が、お天守の…何様か腑に落ちねえ処があるで、約束の通り奥様を返さねえもんでがんしよ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでも洋服とは楽でがんしょうがの」と、初やが焜炉を煽ぎながらいう。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸が、がんがんして来た。",
              "citation": {
                "source": "接吻を盗む女の話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとにまったく、がんがんしてくるじゃござんせんかい」「控えろッ」「え……？",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾の全身の血液は一度に頭へ上がって、頭ががんがんしてきた。",
              "citation": {
                "source": "オパール色の手紙",
                "author": "――ある女の日記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（思慮ある人々でも私のような軽率なことをしたとして）私はこれまでに読んだ小説や新聞種の中から、私の場合に似たような三角関係の例を思い出そうとしたが、頭ががんがんして何も思い出せなかった。",
              "citation": {
                "source": "秘密",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなことをいわないで、はやく海へはいってボートをおしあげてくれ」「あっしゃ、鱶という魚がきらいでがんしてね。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どぶろくをたくさんのんだので頭ががんがんし、私はすぐに寝てしまいました。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この父親といいますのは、近県六市は愚かなこと、アルサス、ルュクサンブウルのあたりまで鳴り響いた天下無双の荒牛でがんした。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "乱視の奈翁　――アルル牛角力の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "手近い家に声を懸けて唐松尾への道を聞くと、黒暗天女のような顔をした四十｜許の女が出て来て「わしは知らねえだよ、一ノ瀬へ行って聞いたらようがんしょう」といわれて、早々に逃げ出す。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お妙　まあ、それはご苦労でがんした。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道人さま」　その穴の前、まっくろな土の上に両手をついて、ひとりの少女が、さっきからたんがんしておりました。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お妙　まあ、それは御苦労でがんした。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲蔵　（筏の上から）お神さま、しばらくでがんした！",
              "citation": {
                "source": "破れわらじ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お化けか、そうでなければ天狗様のいたずらでがんしょう」「お前は、それを調べてみましたか」「いいえ、そういうことはしてみましねえ」「さまで遠くはないようだ」　　　　　　　　　九　けれども、響きがあって物のないという道理はありますまい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "二日酔で頭ががんがんしてるのを、無理やりたたき起されましてね。",
              "citation": {
                "source": "日めくり",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "何方が徳でがんしょう？",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何方が悧巧でがんしょう？",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺も東京へ行きましたが、静岡を見ているだあもの、些っとも怯じにゃあでがんしたよ」　とお父さんの車屋が気焔を吐き始めた。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
