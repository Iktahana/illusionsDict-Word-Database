[
  {
    "uuid": "2d4f1829-23e1-59b4-a67b-a2fecef75ddb",
    "entry": "外敵",
    "reading": {
      "primary": "がいてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
