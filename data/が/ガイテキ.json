    },
    "definitions": [
      {
        "index": 1,
        "gloss": "foreign enemy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして外敵を三度も退りぞけることが出来た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした外敵からは彼らは安全であったと言えるのである。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "国家の最も憂うる処は、貧乏でもない、外敵でもない、宏大な官庁が無い事でもない、狭軌鉄道が広軌鉄道にならぬ事でもない、実に国人意気の沈滞と民心の腐敗とである。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し建文帝にして走って域外に出で、崛強にして自大なる者に依るあらば、外敵は中国を覦うの便を得て、義兵は邦内に起る可く、重耳一たび逃れて却って勢を得るが如きの事あらんとす。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂公武一丸となつて神洲を守護し、外敵にあたる。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち、私の申上げたいのは、外敵に対する勇敢な戦士としての諸君の時代は既に終ったということです。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人智をみがくために、科学力をいやが上にもすぐれたものにするために、人類の中でも、特にすぐれた素質をもつわれわれ日本民族は、他の民族よりも進んで勉強し、地球全体の中から選ばれた第一線民族として、宇宙から来る外敵に対して、いさましく立上らねばならないのです。",
              "citation": {
                "source": "『火星兵団』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん軍部をはじめ諸官省や諸機関においては、最大の注意力を傾けて、この恐るべき外敵の攻撃を防ぐことを考えている。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "高松藩の上下は、外敵の侵入に混乱し、人心恟々として、毎日のように城中で評定が行われた。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし、多人数押しかけて御城下を騒がすことは、外敵を控えての今、慎まねばならぬ。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "栗や胡桃のやうに、その実を自分の手で外敵から固く護らうとする心用意の細かさも悪いことではないが、私はまた柿の実の張り切つた肉つきを朱色の素肌のまま、寒空にあかあかとかがやかせてゐる、あのあなたまかせの、間の抜けたところを一層好ましいものに思つてゐる。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじ車だけでも日本人が九人、独逸人の男女が各ひとり、あめりかのお婆さん、チェッコ・スロベキヤの青年、支那の紳士――これだけがモスコウへ着くまで一致団結して外敵｜露西亜人へ当ることに申し合わせる。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "航空路でもいけるんでしょう」「空中旅行は、外敵の攻撃を受ける危険がありますからね。",
              "citation": {
                "source": "三十年後の東京",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "フレデリツキが周圍の外敵に追迫されて、自分の國どころか、自分の身の存在に窮し、腰の劍を拔いて、わが身でわが身を刺さうとしたが、たゞこの危急な瞬間に堪へた時、既に大王たる資格は定つて居たのである。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那の富豪たちが外敵に対してどれほど深い用心をしているかが、これをみただけでもよくわかる気がする。",
              "citation": {
                "source": "余齢初旅",
                "author": "――中支遊記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「日本という国について外国の人人に知っていただきたい第一のことは、日本には地震が何より国家の外敵だということです。",
              "citation": {
                "source": "厨房日記",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外敵の侵入は歴史上に現れている限りでは二百七八十回ほどあります。",
              "citation": {
                "source": "厨房日記",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを筆にするも不祥ながら、億万一にも我日本国民が外敵に逢うて、時勢を見計らい手際好く自から解散するがごときあらば、これを何とか言わん。",
              "citation": {
                "source": "瘠我慢の説",
                "author": "瘠我慢の説",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは因習に拠る頑強な外敵を控えているのです。",
              "citation": {
                "source": "平塚・山川・山田三女史に答う",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "独逸という外敵に勝った各国の人道主義者は、これより更に、その各の国内における非人道思想や、専制思想と戦わねばなりませんが、日本人の国内におけるこの意味の戦いは、最も多くの苦闘を覚悟する必要があると私は考えます。",
              "citation": {
                "source": "激動の中を行く",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "外敵に對しては一意和親偸安を事とする、支那歴代の君主の間に在つて、彼は確に一異彩を放つて居る。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の小屋の伏床に寝ね、時としては困苦欠乏にも耐え、盗賊などの外敵を防ぎ、人間の散歩のお供もする。",
              "citation": {
                "source": "猫先生の弁",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "常々、お上より、天下大難の時、家中の争を禁じるようとの仰せを、蒙ってござりますが、家中に、両党あり、二君あっては、一致して、外敵に当り得ましょうか？",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "益満は、只今、家の中さえ修められずに、外敵に当りうるかと申した。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、わしは、家を修めて、わしの手で外敵に当ろうとは思わぬし、それは、出来ないことじゃ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラマ塔は昔、このお城がラマ仏教のお寺であつたとき、建つた、ずゐぶん古るいものですが、アイチャンキャラ侯の先祖が、これを取つてからのち、或時、外敵にせめられて、一時これを占領されたことがありました。",
              "citation": {
                "source": "ラマ塔の秘密",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　由来国軍は外敵に対して我が国土を防衛する任務を課せられて、国軍あるが為めに国民は自ら武器を捨て、安んじて国土の防衛を托したのである。",
              "citation": {
                "source": "二・二六事件に就て",
                "author": "河合栄治郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしないと、外敵の侵略を喰い止めるに充分な、科学的防備力を発揮することが出来ない。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "極楽生活は、飲食にも困らないし、着るものも充分だし、外敵の侵入の心配もなし、すべて充分だらけであるが、只一つ困ったことには、来る日来る日の退屈をどうして凌ぐか、これに悩まされる。",
              "citation": {
                "source": "今昔ばなし抱合兵団",
                "author": "――金博士シリーズ・４――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何がさて子供の時から目から鼻へぬける男、三国志の地へ出征して、つぶさに実力をみがいてきました。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
