        "examples": {
          "standard": [
            {
              "text": "父の学生時代、大学は学園紛争の真っ只中で、授業がほとんどなかったらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "授業料の大幅な値上げが、大規模な学園紛争の引き金となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "その大学の歴史資料館には、学園紛争当時の写真や立て看板が展示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "仲間たちとの闘いの日々は熱い宝石のような思い出として残ったが、学園紛争の火が消え、退屈な七〇年代に放り出されると羅針盤を失ったような日々が待っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
