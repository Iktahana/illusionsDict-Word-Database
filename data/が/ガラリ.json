    "definitions": [
      {
        "index": 1,
        "gloss": "(opening a door) with a clatter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
