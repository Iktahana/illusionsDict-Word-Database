  {
    "uuid": "2cb724be-7894-5145-8912-0158c4657a79",
    "entry": "外航",
    "reading": {
      "primary": "がいこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "foreign voyage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "明治になって最初に書物に現れたこの現象に関する記事は、筆者の知る限りでは、明治二十三年に出版された山辺曼遷外史の「外航見聞誌」で、その中に、船中で聞いた話として、一八六〇年ブラジルの大地震の時、空中にいちじるしい光が現れたと言うことが書いてある。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "席画の出来栄にすっかり上機嫌になった容堂は、「対山は酒の吟味がいこう厳しいと聞いたが、これは乃公の飲料じゃ。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "法　　そのためで経典を誦する事がいこう巧者になりまいてのう――まんざらそんばかりもまいらなんだがまだしもの事――　ま！",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼくがいこう」　と富士男がいった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "この中にいちゃ、目まいがしそうだ」「じゃおれは食物をとってくるからな」「いや、それはおれがいこう」「待て、おれもいく」　衛兵たちは、先をあらそって、廊下をかけだして行った。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの脚は、彼がいこうとするほうへ彼を運んでいこうとさえするのだった。",
              "citation": {
                "source": "変身",
                "author": "DIE VERWANDLUNG",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あてはありません」「私がいこうかしら」　玄関ホールでふたりは向き合って立った。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽に焼けた、ごま塩頭の甲板員が、ぼくがいこうとしている島はどれなのか教えてくれた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "おればかりじゃない、男とはたいがいこうしたものなのだ。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
