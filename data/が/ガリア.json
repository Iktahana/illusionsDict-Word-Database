        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ハンガリア語の山 hegy（ハヂ）が「飛騨」に似ているのが妙である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他「瘤」の仲間にはマレイの gmbal, ロシアの gorb, ズールーの kuhan, ハンガリアの 〔gomb, csomo'〕 等である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンガリアでは esz がそうである。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――しあわせなことに汽車がブルガリア領に入れば商人は伊太利人の武士気質に禍いされなくて思うままに我意を通すことができるのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私はリストのハンガリアンラプソデイ掛けようと思ってんのよ。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからハンガリアの改革があった。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内クムビラてふはヒンズ語でクムヒル、英語でガリアル、またガヴィアルとて現存※群中最も大きく、身長二十五フィートに達し、ガンジス、インダス河より北インドの諸大河に棲み、喙細長く尾の鼻端大いに膨れ起り、最も漢画の竜に似たり。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "真の肉※蓉は御肉と同じく列当科に属すれど別物で、学名をフェリベア・サルサと呼び、西シベリア、蒙古、ズンガリアの産、鎖陽は蛇菰科のシノモリウム・コクネシウムで蒙古沙漠に生ず（ブレットシュナイデル『支那植物学編』三）。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャムとフランスとイタリアとブルガリアとの酔っぱらい。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンガリア行　パリーの大罷業はパリー始って以来の最初の出来事である。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルザスからドイツのミュンヘンへ入り、チロルからウイン、ブダペストと延びて、ダニューブ河の河岸のホテルへ著いたときには、ハンガリアの曠野は、真紅の葵の花盛りだ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンガリアの都、ブダペストは、街も自然も人も美しい。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が暮れて夕月がダニューブの上にかかると、ジプシイの一団がハンガリアの歌を弾く。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "肋骨の飾りを胸につけ、袖とスカートが空色の、胴の緊った赤い服に、赤い長靴を履いた娘たちの、ハンガリアの踊りは、月の出のころからはじまり出す。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "後で人に訊ねると、そのタローガッタの吹奏者は、ハンガリア第一の名手との事であった。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "オーストリアからハンガリアの野へかけて、雛芥子が所嫌わず生えている。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンガリアの総人口八百万のうち、百六万人がこの都で生活している。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンガリアの曠野は真紅の葵の花がシンボルだ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "河岸でジプシイの一団が、ハンガリアの曠野の唄を弾く。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダニューブ河の漣は、あれはハンガリアをとったウインの喜びだ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンガリアの野はどこまでも連続した錦のつづれ帯だ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンガリアの曠野の終る所、徐々にアルプス連山が迫って来る。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルガリアは騎兵だ。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンガリアン・ラプソディーの波を背負って、自分でもそんな音楽にびっくりしているようなのぼせた頬のリーダの顔が現れた。",
              "citation": {
                "source": "モスクワの辻馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも東ローマの著述家たちが彼等の隣人に對して活溌な關心をもつてゐなかつたとしたならば、歴史家の云ふ如く、ロシア人、ハンガリア人、セルビア人、クロアチア人及びブルガリア人の早期に就いての我々の歴史的知識は「白紙」であつたであらう。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ハングリ、ハンガー、ハンガリアン、……ハンガリアンて言葉はないかな、待て待て、ハンガリアン・ラプソディと云ふではないか、飢ゑたるものの狂ひ歌と云ふところかな。",
              "citation": {
                "source": "大凶の籤",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
