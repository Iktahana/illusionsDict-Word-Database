[
  {
    "uuid": "2c39e249-e152-526b-ad71-68e97dd081e1",
    "entry": "頑強",
    "reading": {
      "primary": "がんきょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "stubborn",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "取引先の担当者はこちらの譲歩案に対しても、頑強に拒否の姿勢を崩そうとはしなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「彼は一度言い出したら聞かないからね。あの頑強な性格にはほとほと困らされるよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "周囲の猛反対を押し切り、彼は頑強に自分の夢を追い続ける道を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "山岸外史氏の、すぐれた著書も、やや、それに似てゐるが、これは、後日、きつと讀者に、ひろく頑強に支持されるにちがひない要素を持つてゐて、決して埋もれる本ではない。",
              "citation": {
                "source": "「人間キリスト記」その他",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼等を踏みにじつてゆく日々の歩みの下にぢつと我慢をして、まだ何かしらを待つて居なければならないかのやうに、頑強な甲蟲のやうに生き續けてゐるのです。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "方振武は頑強に、城内に踏み止まっていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも頑強に応じないと、あとから立つ人の演説の中で槍玉にあげられる。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い間人間の目の敵にされて虐待されながら頑強な抵抗力で生存を続けて来た猫草相撲取草などを急に温室内の沃土に移してあらゆる有効な肥料を施したらその結果はどうなるであろう。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし培養のしかたによって、頑強な抵抗力は保存し、しかも実の充実を遂げる事ができればなおさら都合がいい。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも多くの場合にこのような独創力と耐久力を併有しているような種類の人間は、同時にその性状が奇矯で頑強である場合が多いから、学者と言っても同じく人間であるところの同学や先輩の感情を害することが多いという事実も争われないのである。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし単にいろいろの優秀な楽器が寄り集まっただけでは音楽にはならないと同様に、単にいろいろな個性が他と没交渉に各自の個性を頑強に主張しているだけでは連句は決して成立しない。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "星野に対してはあの近づきがたいような頭の良さと、色の青白い華車な姿とに興味をそそられているらしいし、俺を見ると、遠慮っ気のない、開けっ放しな頑強さにつけ入ろうとしている。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなに頑強に見えたシカゴ軍があんまりもろく粉砕されたからです。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐十さんという頑強日光一の案内｜老爺。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此奴、狡猾い奴だ」と、兵站係の衣水子、眼玉を剥き出し、「八人前八銭ではないか、余分を返せ」と談判に及べば、船頭は一旦握った金を容易に放して堪るものかと、「この大水だで――」と頑強に抵抗したが、「馬鹿をいうな。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "大の男や頑強なるべき学生輩に至るまで、窓から太陽が射して来ようものなら、毒虫にでも襲われたように周章てて窓を閉ざして得意でいる。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "散弾が轟然として四辺に迸ると、頑強の敵も流石に胆を挫がれたらしい、踵を旋してばらばらと逃げ出した。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "次々と女をものにしたが、しかし豹一は頑強に体を濡らさなかった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は市治郎の無口な性質と、もと荷車挽きをしていた彼の頑強な身体を唯一の頼みにした。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "』ドリアンは頑強に拒んだ。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "オーイオーイオーイオーイ……」　といくら呼んでも頑強にベルを鳴らしていたが、やがてピタリと震動が止むと、「オホホホホホホホホ」　という笑い声が、真っ先きに聞えた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして反動から、より頑強な心を持った、神経の太々しい、大胆無法な勇気をもった、真の英雄的なものに憧憬している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お辻は宗右衛門に添つて三十年、宗右衛門の頑強と鋭才との下をくゞつて、よく忍従に生きて来た。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "覇気と頑強と、精力的なので多少主人を顰蹙させ、朋輩達に憎がられはしても、どんどん彼は他を抜いて行つた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それのみならず、争はれぬ血統からとでも言はうか、彼は無学頑強なうちにも、おのづからなる折目｜躾を持ち、武家への応待に一種の才能をさへ持つてゐた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のその精力と頑強と覇気とを余すところなく発揮した。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗右衛門は五十余歳の年齢にしては、若い肉体を持つてゐたが、それは彼の頑強と豪気との抑圧的な一種の反感を対者に加へるにとゞまつて、誰も彼から淫蕩の感じを受ける者はなかつた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、ある、と頑強に言ひ張つた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、若い頑強の肉体を、生れてはじめて、胸の焼け焦げる程うらやましく思った。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この叔母は、私の小さい時から、頑強に私を支持してくれていた。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は頑強にねばって、とうとう二人にそのお金を受け取らせた。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この乳母は、終始、私を頑強に支持した。",
              "citation": {
                "source": "新樹の言葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後に、元老の鶴屋北水の頑強な支持もあって、その特異な作風が、劇壇の人たちに敬遠にちかいほどの畏怖の情を以て見られていた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
