  {
    "uuid": "ccdfcbe1-62dc-50ba-9c2c-592356219e46",
    "entry": "外官",
    "reading": {
      "primary": "がいかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
