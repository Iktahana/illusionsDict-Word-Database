    "definitions": [
      {
        "index": 1,
        "gloss": "gas (as a fuel)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
