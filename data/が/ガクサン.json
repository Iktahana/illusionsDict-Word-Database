          "literary": [
            {
              "text": "学生の有志の見学団で毎週のようにいろいろの見学参加募集をする。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラガド大学参観記吊籠と月光と歌へる日まで（西部劇通信、アウエルバツハの歌）　以上は相通ずる意味を持つものであり、またその他単独のものを幾つか発表したが、特に好き嫌ひを区別することは困難である。",
              "citation": {
                "source": "今年発表した一ばん好きな自作について",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ラガド大学参観記」は、私の入学受験準備の仕事である。",
              "citation": {
                "source": "ラガド大学参観記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "（理論と実験説明は大学参観記で私が述べてゐるところだつた。",
              "citation": {
                "source": "ラガド大学参観記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガレノスは解剖学参考書の中で、ペルガモンのアスクラピオス寺院の後援者だった市民について、愛情をもって記載していることに気がついた。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの科学における全資産は８世紀の終には１冊の医学参考書と何冊かの錬金術の本の翻訳だけであった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボドレアン図書館にはイギリス由来の13世紀後期の顕著な解剖学参考書があり、そのうちの１つの挿絵によって著者が如何に無知であったかを充分に示すことができる。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "タシケントの手前の蒙古にあったというギリシア文化と支那の文化の混交した古都のことなんか何も知らず、あのバクー大学の考古学参考室なんか、今考えると惜しいの惜しくないの。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
