  },
  {
    "uuid": "232fb7cf-2145-5aa1-a2c4-265eac48cf73",
    "entry": "画趣",
    "reading": {
      "primary": "がしゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "picturesqueness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝霧に包まれた湖畔の風景は、どこをカメラで切り取っても素晴らしい画趣に溢れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この寂れた路地裏は独特の画趣があるね」と言って、彼は鞄からスケッチブックを取り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "旅先で見つけた廃屋でさえ、蔦が絡まるその荒れ果てた姿には不思議な画趣が感じられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "裁判所だか海軍省だかの煉瓦を背景にした、まだ短夜の眠りのさめ切らぬような柳の梢に強い画趣の誘惑を感じたので、よほど思い切って画架を立てようかと思っていると、もうそこらを歩いている人が意地悪く此方へ足を向け始めるような気がする。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○長命寺の下、牛の御前祠の地先あたりは水｜特に深くして、いはゆる○墨田の長堤もまた直に水を臨むをもて、陽春三月の頃は水の洋たると互に相映発して、絶好の画趣と詩興とを生ず。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その水門がくずれたままになっているのも画趣があった。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黎明印度画趣白き鷺、空に闘ひ、沛然と雨はしるなり。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "スイカダ、スイカダ、ランチ、ランチ　つい、着いたばかりに発信したが、あの高麗丸から海岸の西瓜の山を瞥見してそれこそ子供のように小躍りした鮮新さや、青や白や鼠色ランチの馳せちがう、やや煙で黒っぽい油絵風の画趣からも、今はもう午前十時の観想は離れてしまった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは明るいしずかな画趣である。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画女優のところへ女中に雇われるだけあって、彼女は非常に映画趣味があったから、ぶくぶくのオーバーを不恰好に身につけた豹一を見ると夜ふけのせいもあって、此の美少年は「男装の麗人」ではなかろうかと思ったほどである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも漫画趣味だよ。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣荵は風流に似て俗であるが、東京の夏の景物として詩趣と画趣と涼味とを多分に併せ持っているのは、かの虎耳草であることを記憶しなければならない。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕陽村落、楊の深いところに蟹を売っているのも、一種の詩料になりそうな画趣で、今も忘れない。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "芒の乱れているのもコスモスの繁っているのも、停車場というものを中心にして皆それぞれの画趣を作っている。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、そこには地方の小停車場に見るような詩趣も画趣も見いだせないのであるが、なんとなく一種の雄大な感が湧く。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "すすきは夏もよし、秋もよいが、冬の霜を帯びた枯れすすきも、十分の画趣と詩趣をそなえている。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "四人の陳述は割合に素直で、一見亜太郎の死となんの関係もないように思われたが、先にも述べたように、絵筆を握ったまま倒れた亜太郎の傍らに描き残された妙な一枚の写生画が、その場に居合せた洋画趣味の医師の注意を少からず惹きつけたのだ。",
              "citation": {
                "source": "闖入者",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここへ洋画趣味の医師が疑点を持ったのだ。",
              "citation": {
                "source": "闖入者",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すすきは夏も好し、秋もよいが、冬の霜を帯びた枯すすきも十分の画趣と詩趣をそなえている。",
              "citation": {
                "source": "我家の園芸",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、そこには地方の小停車場に見るような詩趣も画趣も見出せないのであるが、なんとなく一種の雄大な感が湧く。",
              "citation": {
                "source": "薬前薬後",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の母は非常に絵画趣味や、文学趣味に富んで居て、その血が私に遺伝したわけでございますが、何しろ菊安が家の近くだったものでございますから、母は屡私から母にせがんで、菊安へ買い求めに行って貰ったものでございます。",
              "citation": {
                "source": "幼き頃の想い出",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　画　東洋の詩歌は和漢を問はず、屡画趣を命にしてゐる。",
              "citation": {
                "source": "芭蕉雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この画趣を表はすのに自在の手腕を持つてゐたのもやはり芭蕉の俳諧に見のがされぬ特色の一つである。",
              "citation": {
                "source": "芭蕉雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この芭蕉の三様の画趣はいづれも気品の低いものではない。",
              "citation": {
                "source": "芭蕉雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "かう云ふ画趣を表現することは蕪村さへ数歩を遜らなければならぬ。",
              "citation": {
                "source": "芭蕉雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「くろぐろと円らに熟るる豆柿に小鳥はゆきぬつゆじもはふり」に素朴なる画趣を想はせてゐる。",
              "citation": {
                "source": "僻見",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには目を遮る何ものもなく、空池の低地には池のほとり、滑らかな芝生から裾野へかけ、数百の馬が放牧されて画趣を添え、同じく一面の芝生であるリンクスの遥の斜面には点々として豆の如く、ゴルファーや普賢から下って来る人達がうごめいている。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の記憶を信ずるとすれば、この一つ目の橋のあたりは大正時代にも幾分か広重らしい画趣を持つてゐたものである。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "喇嘛僧と言うもの、或は黄、或は赤、或は紫などの毛のつきたる三角帽を頂けるは多少の画趣あるに違いなけれど、どうも皆悪党に思われてならず。",
              "citation": {
                "source": "北京日記抄",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の記憶を信ずるとすれば、この一つ目の橋のあたりは大正時代にも幾分か広重らしい画趣を持っていたものである。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "白鷺は必ず小さな群を成して、水田に好個の日本的画趣を与へる。",
              "citation": {
                "source": "智恵子抄",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく彼は書記官としての自分の勤めも忘れて、大坂｜道頓堀と淀の間を往復する川舟、その屋根をおおう画趣の深い苫、雨にぬれながら櫓を押す船頭の蓑と笠なぞに見とれていた。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃は忙がしゅうてなあ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
