[
  {
    "uuid": "4a3737b7-a8e8-5b9a-adb7-e41d043e69cd",
    "entry": "画手",
    "reading": {
      "primary": "がしゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "painter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "若き画手たちがアトリエに集まり、これからの芸術のあり方について夜通し激論を交わした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その寺院の天井に描かれた龍の図は、江戸時代に活躍した無名の画手の手によるものだと伝えられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は単なる画手としての技術だけでなく、自然を深く観察する洞察力に長けていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "印象派の絵画手法がすでに光線と色彩との自覚的な研究の結果であるとしても、この事情に変りはない。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "画手と与次郎は笑ひ出した。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "画家さんは、愚助が画手本でも内証で見るのか知らと思ひました。",
              "citation": {
                "source": "愚助大和尚",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は娘の方を見て、「俊、お前の習った画を三吉叔父さんにお目に懸けないか」　こう言われて、お俊は奥座敷の方から画手本だの画草紙だのを持って来た。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が黙りこむと、武蔵は画手本を見ながら、描きかけの絵へ筆をとり始めた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃は忙がしゅうてなあ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "つきましてでござりますが、ええ、夫人、唯今はどうも、とんだお騒がしゅう、さぞまあ吃驚、お驚き遊ばしましてござりましょう。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「もし、お騒がしゅうござりましょう、お気の毒でござります。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "とかく、大晦日には、思わぬ事がしゅったい致す。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして真鍮の重い柄につけてあって、空気を切って揺れるときに全体がしゅっしゅっと音をたてた。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "「十日以前から戻りませんので……」「駈け落ちをしたのですか」「御承知の通り、十二、十三の両日は強い風雨で、十四日は境内の掃除がなかなか忙がしゅうござりました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おお、これで両眼もすがすがしゅうなった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "兼々仰せられ候には、六十七万石の家国を失いつる折は、悪夢より覚めたらんが如く、ただすがすがしゅうこそ思い候え。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると二つの目からは、例のように長い焔がしゅうしゅうとび出しました。",
              "citation": {
                "source": "ぶくぶく長々火の目小僧",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どたどたと騒がしゅう振舞って何者じゃ」　四十がらみの、ずんぐりとした好き者らしい脂肉を褥の上からねじ向けて、その主計頭がいとも横柄に構えながら、二万四千石ここにありと言いたげに脇息もろ共ふり返ったのを、ずいとさしつけたのはあの三日月形です。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それさえあるに、べろべろの神さんがしゅうねく祟って、呪文はいよいよ高く唱えられるのである。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにまじって、部屋の中央にはサモワールがしゅうしゅういいながらさかんに湯気を吹き出していた。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「せつの結婚式が明日なもので、急がしゅうて来れなんだが、何んでも、お前さんたち知らぬものに荷物を頼んだいうことだでのう。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、湯がしゅんしゅんとわく。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "随分忙がしゅうござりますよ。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに忙がしゅうござりましても。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに学校の方が忙がしゅうござりますから。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがここに、一｜椿事がしゅったいした。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちと今夜は騒がしゅうござるが、ご辛棒してくださるよう」「爺や」　と萩丸はうつろ声で云った。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「青山さん、表が騒がしゅうございますよ。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸も騒がしゅうございましたよ。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「今は京都も騒がしゅうございますよ。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、パーシウスがメヅサの首を落す時、いくら静かにやろうとしても、剣を打ちおろす音、蛇がしゅっしゅっという声、それからメヅサの首が海辺の砂の上にどさっと落ちる音などがしたので、他の二疋が目を覚ましたからです。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務所の方にはいつもサモヴァルがしゅんしゅんいっていて、お得意は輪形のパンでお茶の饗応にあずかった。",
              "citation": {
                "source": "可愛い女",
                "author": "DUSHECHKA",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがひどく騒がしいなあ」「ほんとに騒がしゅうございます」「町には騒がしくていられまい、こう思って私は名古屋へ来ると、この森を住居にしたんだが、どうもここにもいられそうもない。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
