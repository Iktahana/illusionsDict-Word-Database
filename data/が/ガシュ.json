  {
    "uuid": "e1d493e6-8319-557e-a2ad-cb5b31ea4663",
    "entry": "雅趣",
    "reading": {
      "primary": "がしゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "elegance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "庭園の隅に置かれた古びた石灯籠が、雪景色の中にえも言われぬ雅趣を添えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "派手さはないが、控えめな色使いの中に雅趣を感じさせる着物を選んで初釜の席に臨んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "都会の喧騒から離れ、雅趣に富んだ数寄屋造りの老舗旅館で静かな休日を過ごす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "前出した多くの句を見ても解る通り、蕪村の句には「さび」や「渋味」の雅趣がすくなく、かえって青春的の浪漫感に富んでいる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の茶道の基本趣味や、芭蕉俳句のいわゆる風流やが、すべて苔やさびやの風情を愛し、湿気によって生ずる特殊な雅趣を、生活の中にまで浸潤させて芸術しているのは、人のよく知る通りであるけれども、一般に日本人の文学や情操で、多少とも湿気の影響を受けてないものは殆んどない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその頃からみると、室内の調度や家具が古くなり、ハタオリ器械や、酒場の招牌や、腕の缺けた彫刻や、壞れた車輪や、投げ出された椅子などのガラクタ（と言つては失禮だが）に年代の錆がついて、大へん雅趣が深くなつた。",
              "citation": {
                "source": "歳末に近き或る冬の日の日記",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝原広く、梅樹雅趣を帯びて、春はさこそと思われる。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は心身共に健で、この新年の如く、多少の閑情雅趣を占め得たことは、かつて書生たり留学生たりし時代より以後には、ほとんど無い。",
              "citation": {
                "source": "鴎外漁史とは誰ぞ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ながらふるほどは憂けれど行きめぐり今日はその世に逢ふ心地して　巧みに書こうともしてない字が雅趣に富んだ気高いものに見えるのも源氏の思いなしであろう。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいそうにはしないで雅趣のある檜破子弁当が出て、勝ち方に出す賭物も多く持参したのである。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｍ、Ｈ氏のは昔しの彼の手紙とちがつて直截で素気がなかつたが、夫人のは筆蹟も文章も古への歌人のやうな雅趣を帯びてゐた。",
              "citation": {
                "source": "芭蕉と歯朶",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹皮にはウメノキゴケを生じ雅趣ある木が何本となく並んでゐる。",
              "citation": {
                "source": "伊那紀行",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よらで過ぎ行くところ、景を写し情を写し時を写し多少の雅趣を添う。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば甲は意匠の点において発達したるも言語これに副はず、乙は言語の点において発達したるも意匠これに副はず、丙は雅趣を解して繊巧を解せず、丁は繊巧を解して壮大を解せざるが如きこれなり。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "いはんや如何なる俗事物もこれを冷眼に視る時は、そのこれを冷眼に視る処において多少の雅趣を生ずるをや。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "余いふ、月並調といふは理窟めきたる言ひ廻しをのみいふに非ず、この句手料理も大きなる皿も共に俗なり、全体俗にして一点の雅趣なき者もまた月並調とはいふ、もし洗ひ鯉に代ふるに初松魚を以てせんか、いよいよ以て純粋の月並調となるべし。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も田舎に住んだ年よりは東京に住んだ年の方が多くなつたので大分東京じみて来て田舎の事を忘れたが、なるほど考へて見ると田舎には何でも一家の内でやるから雅趣のあることが多い。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓家があったり、家が潰れかかっているさまも却って雅趣がみえて嬉しかった。",
              "citation": {
                "source": "余齢初旅",
                "author": "――中支遊記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方になって参会者の次々に帰るころ、木の花は大部分終わりがたになって散り乱れた庭に霞もよどんで春の末の哀愁の深く身にしむ景色を、大臣は顔を上げて母宮のおいでになった昔の日を思いながら、雅趣のある姿でながめていた。",
              "citation": {
                "source": "源氏物語",
                "author": "藤のうら葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがまだまだ、新鋭的尖端が漸く旧き古色と雅味を追い出そうとする折から、新日本の新尖端的滋味雅趣を求める事は無理だろう。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は山東の泰山を知らないが、曽遊の人から伝へ聞く今の泰山は俗化してゐるらしいから、李白の登岳の詩に見るやうな縹渺たる仙界的雅趣は寧ろ此の千山に存するのであらう。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、その岩の配置に、背景の削ぎ立った懸崖に連峯に、人を威圧しながらも、猶お言い知れぬ風致と雅趣に微笑んでいたのだ。",
              "citation": {
                "source": "登山は冒険なり",
                "author": "河東碧梧桐",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「若し夫れ通人才子の情を寄せ興を託する、雅趣余りあらざるに非ざるも、而も必ず其の規矩に出入し、動きて輒ち合ふ能はざる、是を雅にして未だ正しからずと謂ふ。",
              "citation": {
                "source": "文芸鑑賞講座",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、私も昨年の夏、この村の青年の幹部の諸君と一、二時間この河原をぶらついて見たのでありますが、いかにも雅趣のありそうな自然石が目について驚いたことでありました。",
              "citation": {
                "source": "自力更生より自然力更生へ",
                "author": "三澤勝衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "よらで過ぎ行く処、景を写し情を写し時を写し多少の雅趣を添ふ。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "松浦川もまた養母田にて波多川の水と合し、夕日山の麓にそひ、幾多雅趣ある中洲をめぐり来り、満島の岸を洗ひ、舞鶴城の残趾を噛みて、つひに松浦潟に注ぐ。",
              "citation": {
                "source": "松浦あがた",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィリアム・エンド・メリー様式で、英国材の胡桃を用い、雅趣のある素地蝋磨に、おおよそがなって居りました。",
              "citation": {
                "source": "さまよう町のさまよう家のさまよう人々",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂近江八景は「比良の暮雪」のほかは、多く湖南に屬する地點を撰んで名附けてあるが、今日の如く西洋文明の利器に涜されない時代には、その邊の風景も落着いてゐて一層雅趣が豐であつたかも知れぬ。",
              "citation": {
                "source": "湖光島影",
                "author": "琵琶湖めぐり",
                "note": "青空文庫"
              }
            },
            {
              "text": "漆器美術の巧緻なことは、我々芸術を解せぬ者にも、当時の人の雅趣が思われたのだ。",
              "citation": {
                "source": "淡紫裳",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし春画を見るに際して、悠々として雅趣に富んだ顔付をしてみたって、救われるものではないだろうね。",
              "citation": {
                "source": "安吾巷談",
                "author": "ストリップ罵倒",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには風流とか、雅趣とかいうものが具わらねばならぬこと、もちろんである。",
              "citation": {
                "source": "現代能書批評",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "墨蹟の上に一番鮮明に表現されるものは、至純、横着、気宇の大なる者、小なる者、気取家、虚勢、虚飾、雅趣ある者、なき者、下等人物、上品なる者、熱ある者、なき者、学者、無学者、信力ある者、なき者、強き個性、弱き個性など、大体表われるものである。",
              "citation": {
                "source": "墨蹟より見たる明治大正の文士",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "一葉女史も座中優れたものではあるが、その雅趣に欠くるところと伝統的作意に囚われたる点において、漱石の風上に立つわけには行かぬ。",
              "citation": {
                "source": "墨蹟より見たる明治大正の文士",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
