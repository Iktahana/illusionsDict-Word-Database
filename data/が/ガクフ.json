[
  {
    "uuid": "7a5177b6-6dca-5439-8581-7a1e7aec49a6",
    "entry": "学府",
    "reading": {
      "primary": "がくふ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
