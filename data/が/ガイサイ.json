[
  {
    "uuid": "a85e643a-1c2f-5f06-a7f2-ebdc0d6ee08a",
    "entry": "外債",
    "reading": {
      "primary": "がいさい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
