        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "foreign loan",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "外債募集だの鉄道国有だのと一つの問題を五年も六年も担ぎ廻る先生の揃つてる経済界だもの。",
              "citation": {
                "source": "青年実業家",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりや外債位は返せるだらう。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "外債募集のためアメリカへやって来た何とかいう世界地図にものっていないような弱小国の麗わしい姫が、ニューヨークへついて間もなくオタフク風にとりつかれてしまったので、その身代りを瓜二つな容姿をもった一人の貧乏で悧※な失業女優がつとめて、終りには目出度大新聞の若い社主と結婚するという筋であった。",
              "citation": {
                "source": "花のたより",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年若し此數百萬圓を費さずして之を轉じて外債の一部を拂ふことあらば、我全國の人民は負擔の一部を卸して永遠獨立の一部を助け、全國肺病の一部を癒したるに非ずや。",
              "citation": {
                "source": "亞細亞諸國との和戰は我榮辱に關するなきの説",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "歐米諸國に對して、我學問の不熟、我商賣の拙劣、我兵備の不足等は姑く閣き、簡易明白、何人にも分り易き我國の損亡は今の外債なり。",
              "citation": {
                "source": "亞細亞諸國との和戰は我榮辱に關するなきの説",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "之を人に聞く、方今我國の外債凡そ千五百萬圓、元利共に償却して今後毎年二百萬圓づゝを拂ひ、凡そ二十年、共計四千萬圓の金を拂て皆濟たる可しと。",
              "citation": {
                "source": "亞細亞諸國との和戰は我榮辱に關するなきの説",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れにしても外債は我國の經濟にからみ付たる肺病と云ふ可し。",
              "citation": {
                "source": "亞細亞諸國との和戰は我榮辱に關するなきの説",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨萬の軍用金を費して歐米の物を仰ぎ、歐米の船艦を買ひ、歐米の銃砲を求め、錢を歐米の人に與へて物を朝鮮の國に費し、結局我外債の高を増して、毎年海に投ずるに等しく償金を拂ふに等しき利足を外國に輸出するに過ぎず。",
              "citation": {
                "source": "亞細亞諸國との和戰は我榮辱に關するなきの説",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何年やつても外債を起す必要はない。",
              "citation": {
                "source": "元時代の蒙古人",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃ外債位は返せるだろう。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三十七年八月）　　　　　尾崎行雄氏の半面　此頃外債問題討議の市會議場に於て、市長尾崎行雄氏は、久しぶりにて大氣焔を吐きたり。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏は某議院が、外債のコムミツシヨンを如何に處分するやと言へるを聞き咎めて、行雄は二十年來政海の激浪を經來れり、十萬二十萬の端金の爲に名節を汚すものに非ずと傲語し、以て頗る世間の耳目を驚かしたるものゝ如し。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や氏は千五百萬圓の外債募集に成功したり。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三十七年八月）　　　　　尾崎行雄氏の半面　此頃外債問題討議の市会議場に於て、市長尾崎行雄氏は、久しぶりにて大気焔を吐きたり。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏は某議院が、外債のコムミツシヨンを如何に処分するやと言へるを聞き咎めて、行雄は二十年来政海の激浪を経来れり、十万二十万の端金の為に名節を汚すものに非ずと傲語し、以て頗る世間の耳目を驚かしたるものゝ如し。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や氏は千五百万円の外債募集に成功したり。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "金は外債、兵器弾薬皆外国から持って来る。",
              "citation": {
                "source": "吾人の文明運動",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　借款全盛の現況　外債は今や支那十八省の間に至る処に行われている。",
              "citation": {
                "source": "三たび東方の平和を論ず",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "」かう云つて、己は目下の経済では、外債を募るのが一番好結果を得る方法だと云ふ説明を饒舌つた。",
              "citation": {
                "source": "鰐",
                "author": "ドストエウスキー　Fyodor Mikhailovich Dostoevski",
                "note": "青空文庫"
              }
            },
            {
              "text": "増税もしくは外債という如きものを繰返さぬでもいけるかも知れない。",
              "citation": {
                "source": "〔憲政本党〕総理退任の辞",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "三億五千万円の償金を取ったけれども、直ちに外債を起した。",
              "citation": {
                "source": "〔憲政本党〕総理退任の辞",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち増税を三度繰返して外債を三度繰返したというのである。",
              "citation": {
                "source": "〔憲政本党〕総理退任の辞",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち日清戦役の後、僅か七、八年の内に外債を三度、増税を三度繰返したのである。",
              "citation": {
                "source": "〔憲政本党〕総理退任の辞",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはや増税も外債も頗る困難である。",
              "citation": {
                "source": "〔憲政本党〕総理退任の辞",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "今わが政府の内外債、合して三千百二十万金余の借金くらいは、三年を出ずして人民よりこれをもって完済することは容易ではありますまいか。",
              "citation": {
                "source": "禾花媒助法之説",
                "author": "津田仙",
                "note": "青空文庫"
              }
            },
            {
              "text": "）……その疑がいさいなかったら、……今日までおめおめ生きてる私やあれしませんねんけど、……そうかて死んでしもた人恨んだとこで仕方あれしませんし、今でも光子さんのこと考えたら「憎い」「口惜しい」思うより恋しいて恋しいて、……ああ、どうぞ、どうぞ、こない泣いたりしまして堪忍して下さい。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
