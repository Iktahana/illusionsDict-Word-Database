        "examples": {
          "standard": [
            {
              "text": "新しい外交使節団が、歓迎式典のために首都に到着した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この外交使節は、平和構築の任を帯びて派遣された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「外交使節として、異文化理解を深めることが私の使命です」と彼女はスピーチした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "難民支援に関する国際会議に、多くの国の外交使節が出席した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "○　五十三歳、魯、斉と夾谷に会盟の際、外交使節として随行し、大功があった。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            }
          ]
        }
