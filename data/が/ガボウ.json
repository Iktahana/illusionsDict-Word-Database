      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "artist's studio",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "金目黐垣の抽き過ぎて出た芽を、二つ三つ摘み捨てゝ、松材の門の扉に手をかけ乍ら桂子が振り仰ぐと、「程君画房」といふ新しい標札がかゝつてゐる。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "またお医者でも代へて見て、さうむやみに命を諦めちまふものでもありません」といつて画房を出た。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この画房は椿岳の亡い後は寒月が禅を談じ俳諧に遊び泥画を描き人形を捻る工房となっていた。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "椿岳の伝統を破った飄逸な画を鑑賞するものは先ずこの旧棲を訪うて、画房や前栽に漾う一種異様な蕭散の気分に浸らなければその画を身読する事は出来ないが、今ではバラックの仮住居で、故人を偲ぶ旧観の片影をだも認められない。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十年前までは椿岳の旧廬たる梵雲庵の画房の戸棚の隅には椿岳の遺作が薦縄搦げとなっていた。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "・散つたり咲いたりやうやう逢へた　　（この句は雄和尚にあげたいと思ふ）四月八日　曇、春樹画房。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "印象の種類から云えば、まるで其等のものとは異いますが、先達て中、二科にあった「懶画房」？",
              "citation": {
                "source": "外来の音楽家に感謝したい",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後の十一月の末、私はまた河田博士と共に青楓氏の画房を訪うた。",
              "citation": {
                "source": "御萩と七種粥",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々は青楓氏の画房で絵を描いたり字を書いたりして一日遊び、昼食は青楓氏の宅の近所にあるという精進料理の桃山亭で済まし、その費用は河田博士が弁ぜられる。",
              "citation": {
                "source": "御萩と七種粥",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから呉青秀は大秘密で大工や左官を雇って、帝都の長安を距る数十里の山中に一ツの画房を建てた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五日も画房の中にジッとして、気分を取り直した呉青秀は、又も第二回の冒険をこころみるべく、コッソリと山を降って、前とは全然方角を違えた村里に下り、一｜挺の鍬を盗み、唯ある森蔭の墓所に忍び寄ると、意外にも一人の女性が新月の光りに照らされた一基の土饅頭の前に、花を手向けているのが見える。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏啼と藤代女史とが、この静かな画房の中で、蒐集の名画八枚をうっとりと眺めているとき、音もなく扉があいて、そこからひどい猫背の黒眼鏡をかけ、長いオーバーを着込んだ男がはいって来て、軽く咳払いをした。",
              "citation": {
                "source": "すり替え怪画",
                "author": "烏啼天駆シリーズ・５",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へえへえ、さようでござりますよ」「※叟無二、画学斎、いろいろの雅号を持っておられるが、画房は写山楼と名付けられた筈だ。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――五軒目ごとぐらいに、画房の窓ガラスが、日光にきらきら輝く。",
              "citation": {
                "source": "神の剣",
                "author": "GLADIUS DEI",
                "note": "青空文庫"
              }
            },
            {
              "text": "空はたいへん暗く重くなり、まわりがぼうっと霞んできました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "河原蓬の根がぼうぼうとひろがつてゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれはきみのわるい畸形の犬がぼうぼうと吠える月夜をぼんぼりのやうに病みつかれて歩いてゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がついて見るとそのうすくらい赤い瑪瑙の野原のはづれがぼうっと黄金いろになってその中を立派な大きな人がまっすぐにこっちへ歩いて来るのでした。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくたってからだ中から何とも云へないいゝ匂いがぼうっと立つのでした。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の峡間がぼうと照らされて、そこから大河のように流れ出ている所もあった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に暑くなった日に電車に乗って行くうちに頭がぼうっとして、今どこを通っているかという自覚もなくぼんやり窓外をながめていると、とあるビルディングの高い壁面に、たぶん夜の照明のためと思われる大きな片かなのサインが「ジンジンホー」と読まれた。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラシを板の上に置くや否や、そいつがぼうっとかすんで無くなって、風がどうっと室の中に入ってきました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそこらがぼうっとけむりのやうになってわたくしもそのけむりだか月のあかりだかわからなくなってしまひました。",
              "citation": {
                "source": "月夜のけだもの",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空はたいへん暗く重くなり、まはりがぼうっと霞んで来ました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "地面はごく麗わしい青い石で、空がぼうっと白く見え、雪もま近でございました。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空はたいへん暗く重くなり、まわりがぼうっとかすんで来ました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "草を焼くにおいがして、霧の中を煙がぼうっと流れています。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東のそらがぼうっと銀いろになってそこをまっ黒な雲が北の方へどんどん走っています。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしておしまいまで来たときは今夜もまた東がぼうと明るくなっていました。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関の六畳の間にランプが一つ釣るしてあって、火桶が三つ四つ出してある、その周囲は二人三人ずつ寄っていて笑うやらののしるやら、煙草の煙がぼうッと立ちこめていた。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
