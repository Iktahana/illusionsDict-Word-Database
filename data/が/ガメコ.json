        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あの子、また割り勘の端数を誤魔化そうとしてるよ。本当にがめ子なんだから。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「がめ子と言われようが何と言われようが、一円でも安く買うのが私のモットーなの。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「合コンにがめ子を連れて行くと、残り物を全部タッパーに詰めて持ち帰るから恥ずかしい。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "呼子湾を圧するながめこころよし。",
              "citation": {
                "source": "松浦あがた",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもは、ここで、閑居しての唯一の善事としての書道を試むるのですが、今日は、筆を選ぶことはあと廻しにして、まず、机に両肱をついて、腮を両掌で受けて、じっと庭前をながめこんだのであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯すにおいては重きとがめこれあると思いませい。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しづかにながめこむと、自分はいつしか松の林を歩いてゐる。",
              "citation": {
                "source": "長谷川等伯の「松林図屏風」",
                "author": "吉野秀雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯すにおいては重きとがめこれ有ると思いませい。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "カチ、カチ、と燧鎌を磨って、首をかがめこんでいた老人の耳の裏から、香りのある煙がゆるく這った。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "剣山の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
