        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「このいぶりがっこ、ご飯がすすむね！」と彼は言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "東北の旅館で出されたがっこが、素朴でとても美味しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夏バテで食欲がない時でも、冷たいがっこなら食べられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖母が漬けたがっこは、いつも食卓の中心だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "四歳のお児はがっこといい、三歳の奈々子はあっこという。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、下谷から焼け出された或四十がっこうの一婦人は、本郷の大学病院の後までにげて来ると、火の手はだんだんにそこへものびて来そうになりました。",
              "citation": {
                "source": "大震火災記",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず昭和五年長瀞に赴任し、文集“がっこ”をつくり、翌年は短期現役を終えてから文集一冊と詩集一冊をつくり、それ以来精力的にコツコツと原紙を切り、ルーラーを回転し、文集“もんぺ”“もんぺの弟”を出した。",
              "citation": {
                "source": "国分一太郎君の仕事",
                "author": "村山俊太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こまってしまって、　ホテルの　しはいにんに　そうだんしてみると、　ありがたいことに　じぶんの　むすこが　かよっている　がっこうの　せんせいの　おうちを　おしえてくれまして。",
              "citation": {
                "source": "ババールとサンタのおじさん",
                "author": "BABAR ET LE PERE NOEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽけっと小ぞうは、小がっこう四ねんせいですが、ようちえんのせいとみたいにからだが小さくて、ぽけっとにでもはいりそうだというので、こんなあだながついているのです。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとうさんはたけしくんと、いもうとのしょうがっこう一ねん生のきみ子ちゃんに、よくこんなふうにいってきかせるのでした。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
