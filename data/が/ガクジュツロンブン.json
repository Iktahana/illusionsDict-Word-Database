[
  {
    "uuid": "2fe2ff04-bb09-54af-bfe4-922b7fbc9524",
    "entry": "学術論文",
    "reading": {
      "primary": "がくじゅつろんぶん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
