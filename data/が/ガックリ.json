        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "徹夜明けで、午後の会議中、がっくりと首を垂れてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "一日中立ち仕事だったので、家に帰るとがっくりと座り込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "マラソン完走後、彼はゴールラインでがっくりと膝をついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "連日の残業で、体はがっくりと疲労困憊だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
