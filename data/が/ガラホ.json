        "index": 1,
        "gloss": "(Japanese) mobile phone with the form of a feature phone but running a smartphone operating system (esp. Android)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
