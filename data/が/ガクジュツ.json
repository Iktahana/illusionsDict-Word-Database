          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "現代社会は、日々進歩する学術によって支えられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は学術的な探求に生涯を捧げた偉大な科学者だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この分野では、学術的な成果を競い合う学会が頻繁に開催される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "学術的な視点から、この現象を分析してみよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それに猶、諸君も嫌ひではない冗舌は、此処に十分に按配されてをり、直き直きに抽象語を以てしなければ、かの「意味がない」と云つて嘯く、平盤な心情の人達のためには、十分哲学的学術的な言葉も此処には見出されるのである。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "学術の権威のためにも、マルキシズムにかわる新しい認識論を提示しなければなるまい。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（紅雪を標品として採集するには、雪と共に瓶の中へ入れ、フォルマリン薬を臭気強いまで滴下して置けば、雪は無論溶けるが、藻は保存が出来る、ただし紅色はやや久しいうちには、全く失われるが、学術標品としては差支えないのである。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもしこれが物理学の教科書か学術論文の中の文句であるとすれば当然改むべきはずであるが、随筆中の用語となると必ずしも間違いとは云われないかもしれない。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天地万有が活きて動いて変化している間はこの力学の応用はあらゆる学術技芸に一日も欠く事は出来ぬ。",
              "citation": {
                "source": "相撲と力学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも学術上の権威者の一つの役目は丁度旅行者に対する案内者の役目である。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし特殊の題目について重なる学術国の重なる研究者の研究の結果を up to date に調べ上げて、その題目に対する既得知識の終点を究める事は可能である。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とならば、学術を真剣に研究する研究者の数が増加すれば、そのうちで相当立派な成績をあげて学位授与に十分な資格を具備する人の数も増加するのは数理的に当然のことだからである。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう風に考えてみると、博士濫造の呼び声の高くなるのは畢竟学術研究者の総数の増加したことを意味し、従って我国における学術研究熱の盛んになったことを意味し、我学界の水準の高まったことを意味するのではないか。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "審査委員が如何に私情ないしは私利のためにもせよ、学位授与の価値の全然ないような低能な著者の、全然無価値かあるいは間違った論文に及第点をつけることが出来ると想像する人があれば、それは学術的論文というものの本質に関する知識の全く欠如している人に相違ないであろう。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "学術的論文というものは審査委員だけが内証でこっそり眼を通して、そっと金庫にしまうか焼き棄てるものではない。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度新聞で報ぜられた事件にしても事実は少しも知らないが、ただ問題となった学位論文が審査を及第通過している以上、その論文がともかくも学術上なんらかの価値あるものであり、少なくも全然無価値ではなく、全部が誤謬ではないであろうということはほとんど疑う余地のないことであろうと思われる。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この疑問の解答が一般に知られていないということが、学位をめぐるあらゆる不都合な事件の発生の胚芽となり、従っては一国の学術の健全な発達を妨害する一つの素因ともなり得るかと思われる。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "学位を狙う動機がたとえ私利や栄達のためであろうが、ともかくも我邦で一人でも多く学問の研究に志し従事する人が多ければそれだけ我邦の学術は発達を刺戟される。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果は研究者の増加を促し翻っては一国の学術研究熱を鼓吹することになるであろう。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の学術が進歩したとはいうもののまだまだ十分とは云われない。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "繰返して云うが、学位などは惜しまず授与すればそれだけでもいくらかは学術奨励のたしになるであろう。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "議会でも暴露の泥仕合にのみ忙しくして積極的に肝要な国政を怠れば真面目な国民は決して喜ばないであろうと同様に、学位授与の弊害のみを誇大視して徒らにジャーナリズムの好餌としていては、その結果は却って我邦学術の進運を阻害するようなことに多少でもなる恐れがありはしないか。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "執筆の動機はただ我邦学術の健全なる発達に対する熱望の外には何物もない。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "末広君の学術方面の業績は多数にあって到底ここで詳しく紹介することは出来ないし、またそれは工学方面の事に迂遠な筆者の任でもないが、手近な主だったものだけを若干列挙してみると次のようなものがある。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "云うまでもなく、家庭問題は、学術上の問題ではない事実の問題であるから、実験に基づかぬ話は、何程才学ある人の云うことでも、容易に価値を認めることの出来ないが普通である。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八七五年八月、ブリストルの大英学術協会に出席中に郷里から電報で呼びかえされた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八八二年サザンプトンにおける大英学術協会では Section A の座長をつとめた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八八四年カナダのモントリオルで大英学術協会が開かれたときにレーリーが会長に選ばれた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに増補された交流に関する章の一節は、十年ほど前に大英学術協会に提出したものであるが、その時どうした訳か出した論文原稿に著者の名が抜けていた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八九五年にはトリニティ・ハウス（海事協会）の学術顧問に聘せられた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは政党でも学術団体でも、芸術団体でも同様である。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし学者とこれに対する世間とから全く飛び離れた第三者の位置に立って見ると、これは世間というものが本当に学者を尊重し学術の進歩を期図する方法ではないような気がする。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "◎偏狭非学術的なるビヂテリアンを排せ。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
