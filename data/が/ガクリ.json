  {
    "uuid": "88557071-9c6a-54e0-929b-ca59c9cd857a",
    "entry": "がくり",
    "reading": {
      "primary": "がくり",
      "alternatives": [
        "ガクリ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "suddenly (e.g. falling, weakening, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "高熱で意識が朦朧とし、体ががくりと傾いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "試合中、相手のパンチを受けて膝ががくりと落ちた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長時間の労働の後、ソファに座った途端、がくりと肩の力が抜けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "『巧く行きましたか‥‥‥』と、云ひ返した時、私はがくりと重荷を下したやうな心の安らぎを感じた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　デボチンの色の黒い眼がくり／＼した一人の土匪は、両手をうしろへ廻されて、項に吊すように、ふん縛られ、足は大きな足枷で錠をかけられていながら、真中の洋車にふんぞりかえって、俥夫と、保安隊士を等分に呶鳴りつけていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際からだが妙にぐらぐらしたり、それをおさえようとすると肝心の手のほうががくりと動いたりするのである。",
              "citation": {
                "source": "笑い",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かぼちゃを食わぬ主義や、いがくり頭で通す主義や、無帽主義などというのは愛嬌もあるが、しかし他人の迷惑を考慮に入れない主義もあった。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙な処へ楫を極めて、曳据えるのが、がくりとなって、ぐるぐると磨骨の波を打つ。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛木の背後に迫って、のそっと前へ廻ると、両手を掉った不器用な、意気地の無い叩頭をして、がくりと腰を折って、「国手、お願い！",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……チャンチキ、チャンチキ、ヒューラと囃して、がったり、がくり、列も、もう乱れ勝で、昼の編笠をてこ舞に早がわりの芸妓だちも、微酔のいい機嫌。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "山里は冬ぞ寂しさまさりけり――まさかにそれほどでもないが、庭のかれ芒が木がらしを恐れるようになると、再びかの荒凉索莫がくり返されて、宵々ごとに一種の霜気が屋を圧して来る。",
              "citation": {
                "source": "郊外生活の一年",
                "author": "大久保にて",
                "note": "青空文庫"
              }
            },
            {
              "text": "じきに最後の呼吸ががくりと咽喉に鳴り、咽ぶように絶えてしまい、医師の駈けつけた時分には、死者の枕を北に直し、銀子も自分の寝床にかえっていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、これが最後の山の手の区域と訣れる一番高い坂へ来て、がくりと車体が前屈みになると、東京の中央部から下町へかけての一面の灯火の海が窓から見下ろせる。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと強く抱いて、と息をつめて哀願するところもよかったし、あたしは、だめだわと言って、がくりと項垂れるところなど、実に乙女の感じが出ていました。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とおつしやつて聞き耳を立て、それから、がくりと項垂れて何か口の中で烈しくぶつぶつ言つて居られたやうでしたが、ひよいと顔をお挙げになつて、「おそれながら申し上げまする。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞬間、グスタフソンの大きな顏もさつと青白み、肩先ががくりと戰いた。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "車體のがくりとしやくるやうな動搖にふと我に返つた私は、何處とない體の不快な痛みを感じて起き上つた。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳元に喚き立てるやうな聲を聞きつけて、私はがくりと眼をさました。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはその度びに頸ががくりとなって「あうん」と返事いたしました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸運に恵まれた男だというわけだが、しかし、例えば爪楊枝職人の家に生れたという偶然を、結局幸運な偶然にしてしまうまでには、絶えず偶然の襟首を掴んで、それに自分を賭けるというスリルがくりかえされて来たのだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "型があるのがいけないというわけではないが、紋切型がくりかえされると、またかと思ってうんざりすることはたしかである。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、父親が教えてくれた通り弾かねば、いつまでも稽古がくりかえされたり、小言をいわれたりするのが怖さに、出来るだけ間違えないようにと鼻の上に汗をかいているだけに過ぎなかった。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時、酒の香す、懐がくり徳利嘗め、けろり鐸ふる、太鼻の油汗見よ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちろめく谷地の燈火も、木の間がくりに線ひきぬ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "九耕作舟につむもの、犂、鍬、黒の雌の牛、朝靄がくり棹さす娘のあかい細帯。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばあさんがテイブルにかけて食事をしようとして、スープ入れの深皿のふたをとりますと、その皿の中から、ふいにピエロがとび出して、がくりと鼻先へかみつきました。",
              "citation": {
                "source": "小犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "木がくりに家居しせれば。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔦代はがくりと倒れた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして更に私たちは、血醒い行為がくり返えされないではいないことが分かっていたから。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、例の品物がパリのすぐ付近のどんな茂みのなかででも、ある日曜日から次の日曜日までより長いあいだ、発見されないでいるなどということは、まるで奇跡的と見なすべきだ、ということを僕がくりかえしても、それは冷静な観察家には誰にでもまったくわかりきったことを言っているにすぎんのだよ。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は闇夜にずんずんと運んだ足が急に窪みを踏んでがくりと調子が狂つたやうな容子であつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "一気に峠を駈け降りたが、流石に疲労し、折から午後の灼熱の太陽がまともに、かっと照って来て、メロスは幾度となく眩暈を感じ、これではならぬ、と気を取り直しては、よろよろ二、三歩あるいて、ついに、がくりと膝を折った。",
              "citation": {
                "source": "走れメロス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
