[
  {
    "uuid": "2d5359d3-0f1b-5667-854a-d25f45c76b78",
    "entry": "外交的",
    "reading": {
      "primary": "がいこうてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
      ],
