        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は柔道で鍛えただけあって、がっしりとした体格をしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この家の柱は太くて、見るからにがっしりとした造りだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "新しい棚は職人の手作りで、重い本を載せてもびくともしないほどがっしりしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "商談が成立し、相手の会社の社長とがっしりと握手を交わした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "網目はどのくらいの大きさであったか覚えないが、霞網などよりはよほどがっしりしたものであったらしい。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つり合うがっしりした顎。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "廂を長く突出した低いがっしりした二階家では窓から座敷に積まれているらしい繭の山の尖が白く覗かれた。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあね」　ふと鳴って通った庭樹の青嵐を振返ってから、柚木のがっしりした腕を把った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中背で、肥っていて、がっしりしている。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠には、盃の一つもさされると「いやどうも、僕は身体を壊していて、酒はすっかりとめられているのですが、折角ですから、じゃ、まあ、頂きましょうかな」といって、細いがっしりとしている手を、何度も振って、さも敬意を表するように鮮かに盃を受取り、気持ちよく飲んでまた盃を返す。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "がっしりした男の足音が、水泳場の方へ昇って来た。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「パパ」　十二歳の兄は、がっしりした、百姓上りらしい父親の頸を持って起き上らそうとした。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし刳物台に坐っているときの彼のなんとがっしりしていることよ。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの肩もどの肩もがっしり何かを背負っているようだ。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな井桁、堂々とした石の組み様、がっしりしていて立派であった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人は骨組ががっしりして大柄な樫の木造りの扉のような感じのする男で、橙色がかったチョコレート色の洋服が、日本人にしては珍らしく似合うという柄の人でした。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に大溝の幅広い溝板が渡っていて、粋でがっしりした檜の柾の格子戸の嵌った平家の入口と、それに並んでうすく照りのある土蔵とが並んでいた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "額も頬もがっしりしていて、熱情家らしい黒目勝ちの大きい眼が絶えず慄えているように見えた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と咳き、がっしりした、脊低の反身で、仰いで、指を輪にして目に当てたと見えたのは、柄つきの片目金、拡大鏡を当がったのである。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　しかし銀子の母親には、結核体質らしいところが少しもないばかりか、あの白皙人型の越後系のがっしりした、均齊のよく取れた骨格で、性格にも恪勤とか忍耐とか、どんな困難に遭遇しても撓まない強靱さがあり、家を外にして飛び歩きがちな放浪癖の父親と反対に辛抱づよく、世帯の切盛りに忠実であった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは大きなマントにくるまった、背の高い、がっしりした男で、青い眼と長い白い髪の毛を持っていました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して一方のもの、即ち意志的なる「権力感情」は、すべてに於て力のある、骨組みのがっしりとした、拍節の正しいリズミカルの美を求める。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラシズムの表現が欲するものは、何よりも骨骼のがっしりした、重量と安定のある、数学的｜頑固を持った、言わば「物に動ぜぬ直立不動の精神」である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし貴族的な精神は、本質的にクラシズムで、骨骼のがっしりした美を求めるからだ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "換言すれば彼等は本質的にがっしりとした、大地を堅く蹈みつけている、或る力の強い、現実感のある文学を要求した。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼等自身は、正に「大地を蹈んでしっかりと立つ」ところの、骨骼のがっしりしたレアリズムの文学を以て任じていた。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "表現派や立体派の求めるところは、鉄と機械によってがっしりと造られている、骨骼の逞ましいリズミカルのもの、即ちクラシックの形式詩体でなければならない。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの叙事詩的の精神は、彼の貴族的なる権力感情の発翔から、形式に於てどっしりしたもの、荘重典雅のもの、ストア的に厳格のもの、韻律の規則正しく、骨組のがっしりしたものを欲求することからして、必然にこの結婚が生れるのである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等のそこに求めるものは、ストア的律格の厳正さと、がっしりした韻律の骨組と、そしてあらゆる意志的な抑制とから、すべての生ぬるい主観を圧し、センチメンタルな情緒を殺し、それの痛烈から逆に飛躍しようとする意欲である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの哲学は、純粋に没情緒の概念で固めつけられ、がっしりとしており、組織的の方程式で成立している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして独逸人が悦ぶのは、実にこの男性的な、がっしりとした、真にクラシカルな哲学の美なのである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
