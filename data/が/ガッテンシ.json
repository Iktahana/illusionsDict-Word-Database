        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "月天子山のはを出でんとして、光を放ちたまふとき、疾翔大力、爾迦夷波羅夷の三尊が、東のそらに出現まします。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう月天子がお出ましなのぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "月天子山のはを出でんとして、光を放ちたまうとき、疾翔大力、爾迦夷波羅夷の三尊が、東のそらに出現まします。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう月天子がお出ましなのじゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕日天子、月天子、りりりと虫は鳴きまする。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "今宵まどけき月天子かぐや姫をか召したまふ。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一杯をつくして日天子を迎え、二杯を啣んで月天子を顧みる。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "『礼記』に春を東郊に迎うるに青馬七疋を用いるの、孟春の月天子蒼竜（青い馬）に乗るなどとあり。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "俊寛　（月をにらみつつ）いかに月天子、汝の照らすこの世界をわしは呪うぞよ。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "月天子よ、私は汝のやさしい面を仰いで夜をも明すであろう、姿は苦行の婆羅門のごとく、心は渇仰の信徒のごとく。",
              "citation": {
                "source": "島守",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが月天子である。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、風のふくままに、それが、がってんがってんしていました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            }
          ]
        }
