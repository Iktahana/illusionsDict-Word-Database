        "examples": {
          "standard": [
            {
              "text": "そのスーパーは、チーズやワインなど、特定の外国製品の品揃えが豊富だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "安全基準を満たしていないとして、一部の外国製品が輸入禁止になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は、珍しい外国製品を見つけてはコレクションするのを趣味にしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この店では、国内メーカーの部品と外国製品を組み合わせて、オリジナルのPCを組み立ててくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "フランス製の香水の表情の線を処女のうぶ毛とすれば、その他の外国製品は、極細の絹糸ぐらゐのものだ。",
              "citation": {
                "source": "「香水の表情」に就いて",
                "author": "――漫談的無駄話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は税関の役人が洒落た外国製品を身辺にそなえたり、珍らしい陶器やバチスト麻布を教母だの、叔母だの、妹などに送ってやったりするのを知っていた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガラスは外国製品だつたやうである。",
              "citation": {
                "source": "「いろは」の五色ガラスについて",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "５と反対に何から何まで外国製品を使用し、霧がまいて来ると酸っぱいドロップをしゃぶり、路に迷うとサラミを囓り、ドッグ・ビスケットを噛み、キャンプでは、味噌汁のかわりにビーフ茶を飲み、キャベツにマギ・ソースをぶっかけて食う。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
