        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "冷蔵庫から昨夜コンビニエンスストアで買ったサンドイッチを出してオーブンに入れ、ホットサンドが出来上がるまでの間シャワーを浴びた。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホットサンドが出来上がると下の方が少し焦げついていたのでナイフでそぎ落とし、ムシャムシャ立ち食いしながらテレビをつけてみる。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホットサンドを食べ終えるとテレビのスイッチを切り、急いで歯みがきを済ませてアパートを出た。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホットサンドが出来上がるまでの間何もすることがなく部屋の中をぶらぶら歩き回っていると、不意に玄関のドアをノックする音がする。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはいつでも好きなときに……」　隼人は小柄な男がふとノブから手を離した隙に素早くドアを閉めてロックし、オーブンのところへ行ってすっかり冷たくなったホットサンドを取り出した。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "小柄な男はなおも執拗にドアの向うから話しかけたり激しくノックしたりしたが、ホットサンドを食べ終わる頃にはどこかへ行ってしまっていた。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月二日（日）推定脳細胞総数　１４９億３８７０万個　小竹向原のが逆探知されたことを隼人が知ったのは、朝食のホットサンドを食べ終え何気なくテレビのスイッチをひねったときだった。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京駅地下室荘司でホットサンド食って座へ帰る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京駅地下室でホットサンドウィッチ食って、公会堂で一席やり、すぐ引返す。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
