  {
    "uuid": "907faa5d-9e8a-54fd-889a-85b353fec548",
    "entry": "法眼",
    "reading": {
      "primary": "ほうげん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the dharma eye",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "法眼｜正純の薬、名護屋にて宗叔の薬、又京の半井道三等の治療を受けたとある。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "保胤の兄保憲は十歳｜許の童児の時、法眼既に明らかにして鬼神を見て父に注意したと語り伝えられた其道の天才であり、又保胤の父の忠行は後の人の嘖々として称する陰陽道の大の験者の安倍晴明の師であったのである。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "法眼は学問があって律義の方、しかし其の律義さは余程、異っています。",
              "citation": {
                "source": "茶屋知らず物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで師匠の法眼が劇場の何たるかを知らないのに附け込んで、斯う言いました。",
              "citation": {
                "source": "茶屋知らず物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つお詣りしていらっしては如何です」　法眼は暫らく立佇って考えていましたが、手を振って言いました。",
              "citation": {
                "source": "茶屋知らず物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "法眼は不断、紀州に住み、円通は大阪に住んでいました。",
              "citation": {
                "source": "茶屋知らず物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「私は摂津国法福寺の円通と申す禅僧、これなるは紀州光明寺の法眼と申す連れの僧、御主人も在らばお目にかかり度い」　と堅苦しく申入れました。",
              "citation": {
                "source": "茶屋知らず物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の用事か知らないが、法眼、円通といえば当時噂に高い清僧たち、失礼があってはいけないと言うので、女中たちに云い含め、いとも丁寧に座敷へ通して正座に据え、自分は袴羽織で挨拶に出ました。",
              "citation": {
                "source": "茶屋知らず物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見て、感心した法眼は円通に向って言いました。",
              "citation": {
                "source": "茶屋知らず物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にも知らぬ二僧は、すっかり悦んで箸を取りながら主人や女中を相手に四方山の咄の末、法眼が言いました。",
              "citation": {
                "source": "茶屋知らず物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡りくらべて世の中見れば阿波の鳴門に波もなし――　ここの座敷では法眼の錆びて淡々たる声で唱え出されました。",
              "citation": {
                "source": "茶屋知らず物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿那律妙法を説き、寡婦聞き已りて塵を遠ざけ垢を離れて、法眼の浄なるを得たり〉。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれのほうじゃ」「いいえ、お鍼医の吉田｜法眼さまでござります」「当人か」「ご後室さまでござります」「なに、ご後室とのう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "住まいはいずれじゃ」「法眼さまがおなくなりになりましてから二年このかた、小石川の伝通院裏にご隠宅を構えて、若党ひとりを相手に、ご閑静なお暮らしをしていらっしゃるとかのことでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠宅というとふた間か三間の小さな家にきこえるが、法眼といえば位は最上、禄は百五十石、はぶりをきかした大奥仕えのお鍼医の未亡人がこの世を忍ぶ住まいです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "かりにも法眼の位をいただいたおかたさまのご隠宅なんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "詮議や手入れを拒むほど、位におごる法眼の隠宅に、なまめいた船宿のちょうちんなぞのあることからしてが、すでにふつりあいなのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "小石川伝通院裏吉田｜法眼様のご後室へ、たしかに三蓋松の紋つきちりめんをひとそろいお届けいたしましたと、呉服後藤の店の者がいってるんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「のう……」「おそれながら、御骨相におのずとそなわる天下の御威光、夜目にもさえざえと拝しました上、御近習衆のお槍筋が、揃いも揃ったお止め流の正法眼流！",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂言は「ひらがな盛衰記」の逆櫓、「鬼一法眼」の菊畑、「為朝」の八丈島、「梅川忠兵衛」の封印切から新口村などで、子供芝居流行の気運に乗じたためか、この興行もまた相当の成績を収めた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかでも最も好評を博したのは、中村芝子丸の鬼一法眼であった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔色あおく二重ひとみ、切り下げ髪を肩にかけ、法眼袴をはいたのは、館のあるじ由井正雪、もう一人は門下の鵜野九郎右衛門、足音を忍んでシトシトと歩く。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はっ」というと一人の天狗、髪は総髪、法眼袴、威風あたりを払うのが、スルスルと前へ進み出たが、懐中から巻物を取り出した。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天狗舞い　頼宣卿の虎の御印、連判状におされるや、法眼袴の総髪の天狗、ふたたび連判状を取り上げた。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はっ」というと立ちあがり、法眼袴の一天狗、由井の正雪踊りだした。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その師匠が当時江戸で一、二を争うところの仏師高橋｜法眼鳳雲という有名な人でありますが、この人のことは別に改めて話すことにする。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "高村東雲の生い立ち",
                "note": "青空文庫"
              }
            },
            {
              "text": "正法眼蔵随聞記拝読。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――朝は正法眼蔵拝読。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶碗の底を見ると狩野法眼元信流の馬が勢よく跳ねている。",
              "citation": {
                "source": "琴のそら音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
