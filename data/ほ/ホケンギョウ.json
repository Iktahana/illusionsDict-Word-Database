        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の会社は、保険業において長年の経験がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "保険業は、人々の生活を支える重要な産業だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "保険業法が改正され、より厳格な規制が導入された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その法則を知って初めて、生命保険業の経営が出来るわけである。",
              "citation": {
                "source": "茶碗の曲線",
                "author": "――茶道精進の或る友人に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "水先案内となり船長となり、所有主となり、保険業者となる。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご存知のボース地区に近く、保険業者と仲介業者が集まる一角である。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "保険業者と致しましては何でも対応します。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "グライドは時間を置かず保険業者のモレンス所長を訪ねた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "保険業者と掛け合ってうまくやってください。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "保険業界は当然、放火団に付け込まれない物件なら契約する。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
