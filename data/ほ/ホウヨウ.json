      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "tolerance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「春雨」はビルディング街に煙り「秋風」は飛行機の翼を払うだけの包容性を失わないのである。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその指揮者の頭がよほど幅員が大きく包容力が豊かでなければ、結局｜狭隘な独吟的になるか、さもなくばメンバーのほうでつまらなくておしまいまでやり切れないであろうと思われる。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "維摩の説は要するに、この現実に生きている以上、広い包容力と強い浄化の力をもって、あらゆる価値を活して行く積極的の態度でなくては人間として役に立たない。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "音樂上で言はれる韻律の觀念は、狹義の場合には勿論拍子を指すのであるが、廣義の語意では拍子と旋律との兩屬性を包容する。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "河には無限の乳房のような水源があり、末にはまた無限に包容する大海がある。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人は張る氣の中に包容されて居るのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "君子｜志を得れば小人を包容する、小人志を得れば君子に反発して容れず、剋殺して已まない。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる他を包容した自然を生命の潮流の中に浮ばせることである。",
              "citation": {
                "source": "心理の縦断",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗ても何でも……　長いものには巻かれろではあるが、また止むを得ず巻かれるのではあるが、しかし自己も完全な自然である以上、他を包容した小宇宙である以上、言ふべきことは言ひ、主張すべきことは主張すべきである。",
              "citation": {
                "source": "心理の縦断",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでわたしはよくヂーツゲン（ディーツゲン）の言葉を引用して、社会主義と無政府主義の差異をできるだけ少なくすることに努め、社会主義はどこまでも無政府主義を包容していくべきだと考えていた。",
              "citation": {
                "source": "赤旗事件の回顧",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由といふのは表現の手法や技術上の自由であり、どこの国でも作家の頭は概して理論的には粗雑であるところから生ずる、認識の不十分に対する寛容であつて、政治的に反対の見解をも包容することを意味しないのである。",
              "citation": {
                "source": "諸家の芸術価値理論の批判",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草券番の出現　浅草では同時に六百人を包容する券番が許可された。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく種々の直接経験があるならば、何に由りてその真偽を定むるかの疑も起るであろうが、そは二つの経験が第三の経験の中に包容せられた時、この経験に由りてこれを決することができる。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "説明とは一の体系の中に他を包容し得るの謂である。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してこの実在の統一作用は無限であるから、我々の自己は無限であって宇宙を包容するかのように感ぜられるのである。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人格とはかかる場合において心の奥底より現われ来って、徐に全心を包容する一種の内面的要求の声である。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どぎついものはなくて、柔らかな包容力ある感じであつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、一度本船を離れたが最後、何日も何十日も洋上に漂う覚悟がなくてはならないから、米塩、食糧品の類を人数に応じてボウトの包容し得る最大限度まで積み込まなければならない。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "その宋時の古文を包容してゐることは、丁香散を載するを以て知られる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし単に系図として看ても、全巻には三種の系図を包容してゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは特にその部落を作ったこともあるが、一般人民と混って住み、丁度アングル人、サクソン人その他ピクト人、ブリトン人らが今日英国と称する島に共に住して段々血も混り、今では彼らは、一種確定せる特別な民族たることを誇るに由なく、かえってよく他の長所を吸収する包容力あることを自慢せると同じである。",
              "citation": {
                "source": "民族優勢説の危険",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の小説を作るのは小説はあらゆる文芸の形式中、最も包容力に富んでゐる為に何でもぶちこんでしまはれるからである。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し谷崎氏の語彙に従ふとすれば、「包容力の大きい」と云ふ言葉と同意味にしても善いのである。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯この「包容力の大きい」と云ふことは古来の詩人を評価する上に余り重大視されてゐはしないであらうか？",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "右のような場合には、個人生活という中に他の二つの生活が自然に包容され、国民生活という中に個人生活も世界生活も摂取され、世界生活という中に同じく他の二つの生活が内含されていて、何の扞格も凝滞も発見されず、極めて平和であるのです。",
              "citation": {
                "source": "三面一体の生活へ",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは世界いずれの人種の帰化をも拒まず、現に朝鮮人の全部と支那人の一部とを包容した国民生活を営んでおります。",
              "citation": {
                "source": "三面一体の生活へ",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
