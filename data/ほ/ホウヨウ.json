[
  {
    "uuid": "8f11c0c0-401b-5f5b-9588-1a4e3ed9b690",
    "entry": "包容",
    "reading": {
      "primary": "ほうよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
