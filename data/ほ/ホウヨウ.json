  {
    "uuid": "2c058aec-52e0-5740-ba66-fe31e01e4222",
    "entry": "苞葉",
    "reading": {
      "primary": "ほうよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
