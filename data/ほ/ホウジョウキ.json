    "definitions": [
      {
        "index": 1,
        "gloss": "An Account of My Hut (1212 collection of essays in the Buddhist eremitic tradition, by Kamo no Chome)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
