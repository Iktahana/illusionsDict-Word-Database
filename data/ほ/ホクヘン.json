    "definitions": [
      {
        "index": 1,
        "gloss": "northern extremity",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "北辺の海中の魚皆赤しと云。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年秋風が立ちはじめると決って漢の北辺には、胡馬に鞭うった剽悍な侵略者の大部隊が現われる。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大将軍｜衛青・嫖騎将軍｜霍去病の武略によって一時｜漠南に王庭なしといわれた元狩以後｜元鼎へかけての数年を除いては、ここ三十年来欠かすことなくこうした北辺の災いがつづいていた。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の艦隊は、絶交した友人のように、西太平洋の海空戦を知らん顔をして見ているんだからねえ」九艦隊司令長官「北辺の護りは、本当いえば最も大切なんだ。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "糧秣その他作戦軍の給養を良好にするため北満の開発が大切であり、北辺工作はその目的が多分に加味されている事は勿論である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "南方ばかりでなく、此の北辺の地にまで、青年支那人の教育ある者が自主権の回復に目覚めてゐる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、北辺警備の本心を蝦夷地開拓の言葉につつんでうろうろしていた開拓使庁は、漠然とこの地域の一帯をもとの伊達藩にひき渡したのである。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "北辺の領国福井にも、軈て栄光の瑞兆がきざし染めて来た。",
              "citation": {
                "source": "橘曙覧",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "北の涯へ落ちのびても、日夜近隣の大人、子供に投石されるような惨めさで、義経、ベンケイも北辺へ落ちのびてからはダメであったが、ジコーサマもそれ以下である。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の現状はといえば、よその国では架空の怪談で人生の景品にすぎないような空とぶ円盤が、日本の北辺の海岸では実在する怪物らしい有様で、世間なみに怪談に打ち興じていられない身分のようである。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり今日に於てもウラジオストックからの漂流機雷が津軽海峡のレンラク船をおびやかす如くに、当時に於ても遠く北鮮からの小舟すらも少からぬ高句麗の人々をのせて越や出羽の北辺にまで彼らを運び随所に安住の部落を営ませていたであろうということを念頭にとどめておくべきであろう。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "高麗神社の祭の笛――武蔵野の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕府が北辺守備のために松前志摩守の領地を収めて奉行を置いたのは文化四年である。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "我｜邦識者の国防的観念に、一大刺激を与えたるもの、実に露国の北辺を侵擾したるに拠る。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通では耐えられない悲惨な生活だという噂もあるし、更生の意気に燃えて北辺開拓の鋤をふるっているという話もある。",
              "citation": {
                "source": "荒野の冬",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜀の陳寿の撰で、西紀三世紀ごろにつくられたこの本には、九州北辺と考えられる耶馬台国の人民の生活が、かなり詳しく述べられている。",
              "citation": {
                "source": "あすへの話題",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北辺防備の基礎は、雪、氷、低温などに基づく諸障害の克服にあるという私たちの昔からの持論は今でも変らない。",
              "citation": {
                "source": "二つの序文",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日いろいろな北辺防備に伴なう実際問題を解こうとしているわれわれの努力は、そういう意味で、過去十二年にわたる私たちの雪の研究にその基礎を置いている。",
              "citation": {
                "source": "二つの序文",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして北辺の急をつげる声が、私たちの雪の研究にもかなり影響を与えるようになった。",
              "citation": {
                "source": "二つの序文",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気温の年平均が零度である線は、ちょうど北満の奥地を通っているので、旧の東支鉄道の北辺には、この永久凍土地帯が存在するのである。",
              "citation": {
                "source": "永久凍土地帯",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この付近一帯の土地を、アメリカがデンマークから租借して、りっぱな飛行場をつくり、それを「北辺防備の第一線」としている。",
              "citation": {
                "source": "白い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この島の北端近くから、バッフィン湾を東北に横ぎると、グリーンランドの北辺チューレに着く。",
              "citation": {
                "source": "白い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化年間、露西亜がエトロフに入り、北辺を擾がした。",
              "citation": {
                "source": "『雪華図説』の研究後日譚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう仕事に著手しているところを見ると、泉石は北辺防備に早くから心を致していたものと思われる。",
              "citation": {
                "source": "『雪華図説』の研究後日譚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の一般の蘭学者は、多くは医家であって、医書を通じて外国の事情を知り、国を憂うるに至った人が多かったが、泉石は家老の家に生れ、若い時から北辺防備に思いを致して、その故もあって、蘭学を学んだものと思われる。",
              "citation": {
                "source": "『雪華図説』の研究後日譚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "泉石が外国地理や北辺防備に意をつくしたのも故あるのである。",
              "citation": {
                "source": "『雪華図説』の研究後日譚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "米国州立大学の学長を、当時人口三千に足りなかった日本北辺の小都市へ招いて、十代の生徒がわずか二十四名という、いわば寺子屋のような学校の教頭に迎えようというのであるから、ずいぶん無茶な話である。",
              "citation": {
                "source": "『ケプロン・黒田の構想』について",
                "author": "――英文誌 This is Japan のための草稿――",
                "note": "青空文庫"
              }
            },
            {
              "text": "次いで宋の時代になっても、北辺の蒙古民族｜契丹の国ははなはだ強大であって、西方からシナを呼ぶに Kitai→Cathay をもってせしめるほどであった。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昨夜｜新府を離れて、今朝は北辺の地に至る。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "胆大なること獅子の如く、足早きこと鹿の如く、血の熱することイタリア人の如く、1795堅忍不抜は北辺の民の如しと云う工合です。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も日本の国土は南北に長くなっていて、北辺と南陲とを比べたらばよほど寒暑の差があるのではありますが、それでも寒流や暖流の関係でその寒さも相殺されて、住みよい国になっている所もあります。",
              "citation": {
                "source": "俳句への道",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
