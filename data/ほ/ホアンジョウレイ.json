    "definitions": [
      {
        "index": 1,
        "gloss": "regulations for the preservation of law and order",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
