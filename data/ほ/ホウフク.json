      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "retaliation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこで父の歎、弟の恨、良正の妻は夫に対して報復の一合戦をすゝめたのも無理は無い。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "巫臣は直ちに晋から書を送って之を詛い、報復を誓った。",
              "citation": {
                "source": "妖氛録",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは架空の話だから御差し合いの方には真平御免下さいであるが、田中という人物が唾棄すべき悪党であったり、林という美人が自動車に轢き潰されたり、中村という先生が八ツ切りにされたりしたら日本中の田中氏、林氏、中村氏は、作者に対して報復しようのない怨恨を抱き、不浄を感じ、嫌悪の情を以て本を投出す虞がある。",
              "citation": {
                "source": "創作人物の名前について",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして又、梅田｜雲浜、吉田松陰、橋本左内、頼三樹三郎を始め多くの勤皇家が惨殺された安政の大獄＊や、その報復としての桜田門外の井伊大老襲殺の壮挙があつて、軈て薩長の聯合は終に倒幕の実現となつたのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつの性格に対する僕の読みが当たっているなら、これから全力で手ずから僕に報復を遂げようとするはずだ。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆が皆恩を忘れているのではないが、報復に手段を選ばない恐ろしい政府をはばかって、現在の源氏に好意を表示しに来る人はないのである。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "風流な家に住んで現代を誹謗して鹿を馬だと言おうとする人間に阿る者がある」　とお言いになって、報復の手の伸びて来ることを迷惑に思う人たちは警戒して、もう消息を近来しなくなった。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九の年に、免許皆伝を許されると、彼はただちに報復の旅に上ったのである。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも現実は容赦ないから、その生活的思意の無方向のまま矢張り我々は歴史の因子として厳然と存在しつづけ、そのような怠慢で自分が存在したことの報復は極めて複雑な社会全般の事情の推移そのものから蒙って生きて行かなければならない関係におかれているのであると思う。",
              "citation": {
                "source": "文学のディフォーメイションに就て",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この笑いを作者は、惨酷に甚兵衛を扱いつづけていた継母、異母弟への報復の哄笑として描き出している。",
              "citation": {
                "source": "鴎外・芥川・菊池の歴史小説",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "舟橋聖一氏が昨今提唱する文学におけるリベラリズムの根源は、そういう反動的憎悪とかつて進歩の旗のにないてであったものへの報復的アナーキーの危険の上にたっているのを見て、私はつよくそのことを考えるのである。",
              "citation": {
                "source": "冬を越す蕾",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、遼東半島還附の勅語の中の、「報復」という言葉の解釈についてであった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶん「臥薪甞胆して報復を謀れ」というような文句だったろうと想像する。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「報復」というのは、表むきは何とかの意味だが実は復讐のことだ、と言うんだった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで今言った教頭の「報復」の話が始まったのだった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これらの忠勇な軍人の霊魂を慰めるためにも、われわれは是非とも報復のいくさを起さなければならない。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、ロシアに対する報復ということを教えられた時にそれを思い出して、そしてその思い出がかえって後の事実のように記憶されて来たのかも知れない。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう考え直して、出来るだけレムを嫌疑者の表から除外しようとつとめたのだが、こう事態が逼迫していたところから見ると、あきらかに報復をふくんだレムのいたずらと判断するよりほか、仕方のないものがあった。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペトロパヴロフスクの要塞監獄監禁が、その行為に対する報復であった。",
              "citation": {
                "source": "逝けるマクシム・ゴーリキイ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで保はベンサムの憲法論について、普通選挙を可とする章句を鈔出し、「外山先生は盲目蛇におじざるものだ」という鸚鵡返の報復をした。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは槐庵をして蘭軒の報復を促さしめようとしたのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "就中正月に発した金子入の書は、茶山が必ず報復を得ることを期してゐたのに、蘭軒はこれにさへ答へずにゐた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶山と江戸にあつた井上四明との応酬に徴するに、茶山の東命は期せずして至つたらしいから、必ずや茶山は相見る日を待たずして屡報復を促し、蘭軒は遂に一たび断えたコレスポンダンスの緒を継いだことであらう。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩田氏は既に七代目団十郎の寿海老人が己に四代目団十郎の演じた勧進帳の正本を返す時、菓子折を添へて茶屋の二階に送り、同行の師榛軒がこれに報復する所以を問うたことを語つて、さてかう云つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし未だ報復を得ざるに、訃音が早く至つたさうである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｊ・Ｉ・Ｃの叛逆者に対する報復手段が如何に深刻執拗なものであるかを知っておられながら、小生等親子を、その呪いの中に放任しようとしておられるＭ男爵の意中を察して、骨の髄まで震え上らせられて退出しました。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に陰険、悪辣な報復手段だ。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つにはその記者の感情を害すると、どこかで手酷しい報復をされる事を、一同が恐れているせいでもあったろう。",
              "citation": {
                "source": "Ｓ岬西洋婦人絞殺事件",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛先生の側にも面倒があり、作者は　親兄の勘当ものとなり果てしわろき叔母見に来たまひしかな　といふ歌のやうに、父兄から勘当同様の身となり、剰へ新夫妻は恋仇の恐ろしい報復を受けて一時は文壇の地位をさへ危くしたほどであつた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
