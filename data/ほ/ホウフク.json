[
  {
    "uuid": "4fcb1582-cdef-583f-b96c-9929d3373f49",
    "entry": "報復",
    "reading": {
      "primary": "ほうふく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
