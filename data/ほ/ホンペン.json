    "definitions": [
      {
        "index": 1,
        "gloss": "original story (as opposed to a sequel, spin-off, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "本編の初めに述べたように俳句という特異な詩形の内容と形式の中に日本民族の過去の精神生活のほとんど全部がコンデンスされエキストラクトされている。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "本編を草するために参考にした書物は次のようなものである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以下、本編に於いて私は、この六つの町に就いて語る事は努めて避けたい気持である。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本編一　巡礼「ね、なぜ旅に出るの？",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本編には、女優高野幸代の女優としての生涯を記す。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ目は、本編と呼ばれる映画館にかける作品。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでまあ今回はいよいよ本編となるはずなのだが、話はなぜか十七年前に今日のバンド・ブームを予見させる愚行を高田馬場の空の下で演じた、谷川ユズル（現・大手電線メーカー勤務）からスタートしてしまう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その声をふと耳に入れたのが本編の主人公――すなわち『むっつり右門』です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩はこの標準によりて本編を起草せり、ゆえに当時に在りて自ら政論家をもって居らざる人といえども、その説の多少政論に影響を及ぼしたる者は、あえて収めてもって一政論派の代表者となす。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしドキュメンタリー映画の常で、記録された言葉のうち本編に収録できたものは、ごく一部に限られていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、ちっとばかり古い事を並べて見ると、本編最初からお馴染になっている大門通りは、廓の大門の通りなのだから大門とよんでください。",
              "citation": {
                "source": "テンコツさん一家",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを評論するは本編の旨に非ず。",
              "citation": {
                "source": "学者安心論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえに真の愚民に対しては、政府まずその愚を容れてこの水掛論の処置に任せざるべからずといえども、本編の主として論ずる学者にいたりては、すなわちこれを愚民と同一視すべからず。",
              "citation": {
                "source": "学者安心論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "右時事小言の所論も、其旨は本編の義に異ならず。",
              "citation": {
                "source": "帝室論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "此他蒔繪、塗物、陶器、銅器、植木、割烹等の諸藝術に付き、逐一説明を下だすは我輩の能はざる處、又本編の旨にも非ざれば之を省き、唯願ふ所は、之をして政治革命の如き小世變の爲に、斷絶せしむるなきの一點に在るのみ。",
              "citation": {
                "source": "帝室論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "此なども、巻九の原本編纂当時に、作者はわかつてゞもゐた様な書き方らしくもある。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮廷の呪詞・寿詞の中、とりわけ神秘に属するものは発表しなかつたらうと言ふ事は、本編に述べるが、「新室ほがひ」の呪言及び、其に関係深い家々の氏上たる人々の生命呪は、唯二つしか伝つてゐない。",
              "citation": {
                "source": "「とこよ」と「まれびと」と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こはあえて本書について言うにあらず、本著者が故意にこれを為したりとするにあらねど、その論ずるところ往々にして本編に触るるあり、他日余が発表せんとするところと符合するものまた少きにあらざるがゆえに、筆のついでに附記するのみ。",
              "citation": {
                "source": "武士を夷ということの考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしてその内容、本編と相関するところきわめて多きがゆえに、余輩が本編起稿当初の腹案にては、詳細これに論及して、もって武士を夷ということの具体的証明を完からしめんとするにありき。",
              "citation": {
                "source": "武士を夷ということの考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは本編の記事を以て訂補した事に御承知願いたい。",
              "citation": {
                "source": "くぐつ名義考",
                "author": "古代社会組織の研究",
                "note": "青空文庫"
              }
            },
            {
              "text": "また本編述べるところが、すでに本誌に掲げたところ、また将来掲げるところと、多少重複する点のあるのも、これまた御承知を願います。",
              "citation": {
                "source": "本州における蝦夷の末路",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "本編に於いていささかその沿革を研究してみたい。",
              "citation": {
                "source": "エタに対する圧迫の沿革",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分もやむをえず、不愉快ながら本編以下多くこれを使用しようと思うが、それにしても「穢多」という同情なき文字は、なるべく避けたい。",
              "citation": {
                "source": "エタ源流考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "本編の目的は、所謂「エタ」が我が日本民族上、いかなる地位にあるものなるかを明らかにせんとするのにある。",
              "citation": {
                "source": "エタ源流考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　本編は主として材料を、所謂「穢多の水上」なる京都地方に求めた。",
              "citation": {
                "source": "エタ源流考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "以下掲載の諸編は本編説くところを補い、その各部にわたって詳説を試みたものである。",
              "citation": {
                "source": "エタ源流考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "本編は便宜上主として特殊民の三大要素中、俗法師の方面から観察したのであるが、唱門師（声聞師）の研究をまっとうせんには、さらに他の二大要素たる、土師部・浮浪民の方面からの観察をも怠ってはならぬ。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
