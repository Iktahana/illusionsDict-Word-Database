[
  {
    "uuid": "e25577b1-4b3c-5253-ad03-83057177c7c0",
    "entry": "滅ぼす",
    "reading": {
      "primary": "ほろぼす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
