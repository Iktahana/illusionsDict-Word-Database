        "examples": {
          "standard": [
            {
              "text": "航海の安全を祈る漁師たちは、自分たちの村の保護の聖人を祀る小さな教会を大切に守っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は子供の頃から、音楽家たちの保護の聖人である聖セシリアに深い敬意を抱いてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "イタリアの多くの都市にはそれぞれ保護の聖人がおり、その聖名祝日には盛大な祭りが催される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼は私の保護の聖人である。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
