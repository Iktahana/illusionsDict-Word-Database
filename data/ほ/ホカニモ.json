[
  {
    "uuid": "48cd263f-ee64-5ddf-ad09-88362aa5695a",
    "entry": "他にも",
    "reading": {
      "primary": "ほかにも",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
