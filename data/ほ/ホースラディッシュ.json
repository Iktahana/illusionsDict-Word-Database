        "examples": {
          "standard": [
            {
              "text": "ローストビーフの薬味として、おろしたてのホースラディッシュを添えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ホースラディッシュのツンとした刺激が、肉の脂身の甘さを引き立てる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "西洋わさびとも呼ばれるホースラディッシュは、ソースの隠し味にも使われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "４日目に新生児の臍帯の上にモクサを載せるか、ホースラディッシュで焼灼する。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホースラディッシュは附いていたが、ヨークシャープディングは添えてない。",
              "citation": {
