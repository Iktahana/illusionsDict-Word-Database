          "literary": [
            {
              "text": "どの店に於いてもわたくしは旅人が感ずるホスピタルなやさしさを抱くことができた。",
              "citation": {
                "source": "八月の霧島",
                "author": "吉田絃二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中間の駅名に、前駅をペーン（苦痛）といい、後駅をホスピタル（病院）というものあるは、あに奇ならずや。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "孟買市のは英国系で、ジェネラル・ホスピタルと呼んだ。",
              "citation": {
                "source": "ブイヨン・ドンゾール",
                "author": "――十一時の肉の煮出し――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし1846年10月16日にあのモートンがマサチューセット・ジェネラル・ホスピタルの公開の手術室で患者をエーテルで感覚を失わせて外科麻酔が役立つことを示すまで知られなかった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
