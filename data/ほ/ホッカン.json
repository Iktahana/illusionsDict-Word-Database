        "examples": {
          "standard": [
            {
              "text": "ニュース番組では、北韓のミサイル発射に関する速報が繰り返し流れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "北韓と南韓の境界線付近では、常に緊張した空気が漂っているという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "専門家が、北韓の内情と今後の国際情勢への影響について詳しく解説した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "駕籠の上から、路傍を見ると落葉の間に白い北韓スミレや可愛らしい紫スミレが咲いていた。",
              "citation": {
                "source": "淡紫裳",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "他日比較言語學、考古學、土俗學等の研究の結果、我石器時代の遺跡と、北韓滿洲との間に十分なる連絡を得る迄は、疑を存して附記すべきものなるべし。",
              "citation": {
                "source": "蝦夷とコロボツクルとの異同を論ず之に潜みて",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
