        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はサミットのホストとして、各国首脳を空港で出迎えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "トークショーのホストが巧みな話術で、シャイな俳優から面白いエピソードを引き出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "次回のオリンピックでホストを務める都市では、急ピッチでスタジアムの建設が進んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "あれ、巨象の様な大機関車を先きにして、どの汽車よりも大きな地響を立てて、ウラジホストツクから倫敦までを十二日間で突破するノオル・エキスプレスの最大急行列車が入つて来た、怖しい威風を持つた機関車は今世界の凡ての機関車を圧倒する様にして駐つた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ、巨象のやうな大機関車を先きにして、どの汽車よりも大きな地響を立てて、ウラジホストツクからブリユツセルまでを、十二日間で突破する、ノオル・デキスプレスの最大急行列車が入つて来た。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男性の、大人のホストがひとりいて、新しいロックンロールのレコードをかける。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九五七年、このテレビ・ショウは、全米にネットされることになり、ホストは交代し、ＤＪをやっていたディック・クラークが選ばれた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
