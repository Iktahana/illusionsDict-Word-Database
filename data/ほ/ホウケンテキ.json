    "definitions": [
      {
        "index": 1,
        "gloss": "feudal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すこし馴染になった顔にたまたま小初は相手をしてやると、「へえ、へえ、済みません」　お客にするように封建的な揉み手をして礼をいう。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "独歩はブルジョア的であるが、蘆花は封建的色彩がより色濃い。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は同胞というセンティメンタルな封建的な感情に誘惑された。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、その戦争は、主として、封建的専制主義及び外国の支配拘束を取り除くことであった。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の封建的な親達が娘の配偶者の条件に、家柄、財産、学歴を考えるのとほとんど同じ自己保存の本能から、貴子は男の条件をパトロンとしての資格で考える女だった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝに一言すべきは、平民に特種の思想生じたりとはいへど、思想は時代の児にてある事勿論なれば、彼等の思想も自ら封建的武勇、別して忠孝の大道を武士の影より鞠養し得たりし事を思はざるべからず。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸幕府の中心思想は、封建的農業主義である。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕府中心、将軍絶対主義は、勤皇思想の勃興によつて動揺しようとしてゐるし、農業的鎖国の徹底によつて維持しようとした封建的大土地所有制度は、今や世界商業資本主義流入の急潮によつて、脅かされてゐるのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの村々の人達は、未だに封建的といふのか何うか、他の土地から入り込んでゐる者の上には何とはなしに白眼を向け勝ちで、また直接に会話を交へるのを好みません。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "小松均氏は、日本画につきまとつてゐる封建的な要素、つまり古い亡霊と闘ひながら新しい日本画を描かうとする悩みがある。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の『松』をみてもわかるやうに、彼は一本の直線を引くことに対しても、その直線の性質の中に、如何に封建的な要素が含まれてゐるかといふことをさへ吟味しその封建的要素の否定のために、物体を直線の上に描き添へて古い線に新しい要素を与へる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "その答は結論的で固定的ではあるが、その固定的なことが決して封建的な非道学的不理由にはならない、日本の洋画家からやうやく洋画材料で「竹」を描いた作家島崎鶏二氏がたつた一人出たばかりである、しかし竹は昔から日本にあつたし現在もある。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "東西ヲ通ジタル歴史的進歩ニ於テ各々其ノ戰國時代ニ亞ギテ對建國家ノ集合的統一ヲ見タル如ク、現時マデノ國際的戰國時代ニ亞ギテ來ルベキ可能ナル世界ノ平和ハ、必ス世界ノ大小國家ノ上ニ君臨スル最強ナル國家ノ出現ニヨリテ維持サルル封建的平和ナラザルベカラズ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこうした強い女も、封建的な家庭制度には敵わない。",
              "citation": {
                "source": "大力物語",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは偶然日本に天才的作家が現われなかつたことにもよるであろうが、いま一つは、日本のブルジョアジーが十分革命的階級としての鬪爭を經過しないで、封建的勢力と妥協して、その庇護のもとに發達して來たからである。",
              "citation": {
                "source": "政治的價値と藝術的價値　マルクス主義文學理論の再吟味",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは偶然日本に天才的作家が現はれなかつたことにもよるであらうが、いま一つは、日本のブルジヨアジーが十分革命的階級としての闘争を経過しないで、封建的勢力と妥協して、その庇護のもとに発達して来たからである。",
              "citation": {
                "source": "政治的価値と芸術的価値",
                "author": "マルクス主義文学理論の再吟味",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜人足――この運輸労働者達は「親方制度」とか「現場制度」とか、色々な小分立や封建的な苛酷な搾取をうけ、頭をはねられ、追いつめられた生活をしているので、何かのキッカケでよくストライキを起した。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "農民を過去の封建的農奴的生活より、光ある社会へ解放し得るものは、都市労働階級の力だ。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "│　│　　封建的搾取と闘うために！",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人のナンセンス文学にはどうも重苦しい、封建的｜詮めの伝統を脱しきらないところがあって、たとえば佐々木邦の滑稽小説にしても、新時代の精神に触れていない。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く老いこむ半封建的なまた個人主義的なこれまでの文士気質を一しゅうするものであります。",
              "citation": {
                "source": "心から送る拍手",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま作品の名をおもい出せませんが赤穂義士の仇討に対してそれを唯封建的な忠義の行為と見ず、浪士たちの経済的事情やその他の現実的いきさつを主眼として扱ったものもあったようです。",
              "citation": {
                "source": "心から送る拍手",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん封建的遺制の問題なんだ。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ歴史の勉強から始めるにしても、東京の學者達のやうに、何時までも半封建的がどうかうしたといふやうなことを論じてゐたんでは、假令言葉では同じやうなことを云ふにしても、今ほどの自覺には達し得なかつたらうと思ふ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "封建的なものから自由な一面はあるが、同時に遠い父祖の生活を思はせるしつとりとした雰囲気といふやうなものは町のどこにもないのである。",
              "citation": {
                "source": "忘れえぬ風景",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に自身の生活態度に於ては封建的なものの一つとして世俗な力に従う傾向のあった鴎外がほかならぬこの道を、歴史小説に於て辿ったことも肯けるのである。",
              "citation": {
                "source": "鴎外・芥川・菊池の歴史小説",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊池寛は、歴史的題材をあつかったあらゆるテーマ小説で、封建的な勇壮の観念、悲愴の伝統、絶対性への屈服、恩と云い讐というものの実体等に対して、真正面からの追究を試みている。",
              "citation": {
                "source": "鴎外・芥川・菊池の歴史小説",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "逍遙はこの論文の中で、馬琴風な封建的枠内での勧善懲悪文学を否定して、文学における写実・客観的観察を提唱したのであった。",
              "citation": {
                "source": "文学における今日の日本的なるもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代日本のブルジョア文学において、常に綯いまぜられて来た退嬰的な妥協的な封建的戯作者風の残りものとの関係においては、進歩的面のバトンの運び手であった自我の探求は今日、未開のまま外ならぬ生みの親のブルジョア文学者の手で※られるというめぐり合わせに置かれている如く見える。",
              "citation": {
                "source": "文学における今日の日本的なるもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
