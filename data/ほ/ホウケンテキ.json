[
  {
    "uuid": "9896f0ff-0612-51e8-9b6a-f11876a55df7",
    "entry": "封建的",
    "reading": {
      "primary": "ほうけんてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
