        "examples": {
          "standard": [
            {
              "text": "パン生地に干しぶどうを混ぜて焼くと、香ばしくて美味しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "小腹が空いたときに、手軽に食べられる干しぶどうは栄養満点だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、苦手だった干しぶどうが、今では大好物になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "水は不快なものであり、沈殿には明らかに屋外便所の土地の悪臭があり、そこには消化管を通ったが消化されなかったもの、たとえば干しぶどうの核や殻、他の果物や野菜の皮の部分が存在した。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖飯は砂糖入りで、米の中へ干しぶどうを十字形に押し込んであった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年のオート麦や干しぶどうや、ジャガイモの蓄えがかなりあります。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほしぶどうがちょっと顔をだしてるだろう。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "固パン、ビスケット、ほしぶどう、かんづめ、塩や砂糖、ほし肉、バタの類はそれぞれしばったり、つつんだり、袋にいれたり、早く潮がひけよとばかり待っていた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、その日のごちそうは、マーチ家では、はじめてのすばらしいクリスマスのごちそうで、七面鳥のむし焼き、ほしぶどういりのプディングゼリイなど、ハンナができるかぎり腕をふるいました。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
