[
  {
    "uuid": "f29e1eec-c7da-58de-85b6-245115e6d608",
    "entry": "法院",
    "reading": {
      "primary": "ほういん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "court",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "但し先頭の所化乗円は『妙法院』と記されたる提灯を持ちたり。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山西は伝法院の塀に添うて並んだ夜店の前を通って、池の方へ往った。",
              "citation": {
                "source": "水魔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝法院の塀をはなれて池の縁へ出たところで、左の方から来る人群の中に、友禅模様の羽織を着た小女を見出した。",
              "citation": {
                "source": "水魔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その伝法院の前を来るまでは見たのですのに、あれから、弁天山へ入るまでの間で、消えたも同じに思われました。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草の伝法院へ度々融通したのが縁となって、その頃の伝法院の住職唯我教信と懇ろにした。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "椿岳の住っていた伝法院の隣地は取上げられて代地を下附されたが、代地が気に入らなくて俺のいる所がなくなってしまったと苦情をいった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝法院の唯我教信が調戯半分に「淡島椿岳だから寧そ淡島堂に住ったらどうだ？",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "椿岳は何処にもいる処がないので、目鏡の工事の監督かたがた伝法院の許しを得て山門に住い、昔から山門に住ったものは石川五右衛門と俺の外にはあるまいと頗る得意になっていた。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "瘤寺は前に申したようなわけで、ヘルンの気に入らなくなったのですが、以前からの関係もあり、又その後浅草の伝法院の住職になった人と交際があった縁故から、その人を導師として瘤寺で式を営む事になりました。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙法院所藏の後白河院宸影は又隆信筆と傳へらるゝ中最も名迹と稱せらるゝ者なり。",
              "citation": {
                "source": "日本の肖像畫と鎌倉時代",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲店の中間、左側が伝法院で、これは浅草寺の本坊である。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "名高かった店などの印象",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝法院の庭を抜け、田圃の間の畔道を真直に行くと（右側の田圃が今の六区一帯に当る）、伝法院の西門に出る。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "名高かった店などの印象",
                "note": "青空文庫"
              }
            },
            {
              "text": "その部屋は合衆国高等法院のように出来ていて、ポウル・ボウの税関吏のような疑い深い、そしていつも突発事を待っている眼をした役員たちがとまり木の上に止まっていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "独り老男老女に取っては伝法院と一寸八分の観世音菩薩と淡島様とに彼の趣味を伴う。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅竜は妙法院｜堯恭法親王の侍読にせられた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "柏軒の備忘録に此女の法号が蓮法院と記してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥山見世物の開山は椿岳で、明治四、五年の頃、伝法院の庭で、土州山内容堂公の持っていられた眼鏡で、普仏戦争の五十枚続きの油画を覗かしたのでした。",
              "citation": {
                "source": "諸国の玩具",
                "author": "――浅草奥山の草分――",
                "note": "青空文庫"
              }
            },
            {
              "text": "経文を伝法院に学ばんと貞子の語り蟋蟀の鳴く　由来家常茶飯事を歌によんで立派な歌にしたてたこと作者のやうな人は先づなかつた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "その貞子さんが話の序に或は伝法院の表に観音経読誦会の立札か何か立つてゐた話をして私も出て見ませうかしら位のことをいつたのではないか。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、錦子が煩悶に煩悶した三、四年の間を、美妙と留女との歓楽はつづいて、前川――浅草花川戸の鰻屋――に行き、亀井戸の藤から本所四ツ目の植文の牡丹見物としゃれ、万梅――浅草公園｜伝法院わきの一流｜割烹店――で食事をし、歌舞伎座見物の帰りは、銀座で今広の鶏をたべるといったふうだった。",
              "citation": {
                "source": "田沢稲船",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "森の木を伐ったり、叢を刈ったりしたので、隠れ家を奪われたと見えて、幾匹かの狸が伝法院の院代をしている人の家の縁の下に隠れて、そろそろ持前の悪戯を始めました。",
              "citation": {
                "source": "寺内の奇人団",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "三一　評定所に遊女　評定所は徳川幕府の最高等法院で、老中および寺社奉行・町奉行・勘定奉行の三奉行らが、最も重大なる訴訟を評議裁判する所であった。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　この話にあるように、神聖なる最高法院の給仕に遊女を出したのは、現今の考えからは殆んど信じ得られない事であるが、当時の遊女に対する考えは現今とは全く異なっておった。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、法院長夫人の悲劇はあらゆる時代に存し、侯爵夫人も子爵も我々の身辺に又我々自身に実在し、可憐なセシル・ボランヂュは常にかくの如く我々の身辺に成熟しつつあるではないか。",
              "citation": {
                "source": "思想なき眼",
                "author": "――「危険な関係」に寄せて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "世のあらゆるセシル・ボランヂュも法院長夫人も、学窓の頃からその師と共にかかる一書をひもとかれるがよい。",
              "citation": {
                "source": "思想なき眼",
                "author": "――「危険な関係」に寄せて――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
