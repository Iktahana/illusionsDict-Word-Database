    "definitions": [
      {
        "index": 1,
        "gloss": "head temple (of a branch temple)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "左に新勝寺の本坊あり、右に三佛堂あり。",
              "citation": {
                "source": "宗吾靈堂",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　彼岸の十九日に、大阪天王寺の本坊で猫供養というものが行われました。",
              "citation": {
                "source": "初蛙",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲店の中間、左側が伝法院で、これは浅草寺の本坊である。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "名高かった店などの印象",
                "note": "青空文庫"
              }
            },
            {
              "text": "正明は法を弟｜槙本坊詮応に伝えて置いて瞑した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此より錦橋は槇本坊詮応に就いて痘科を学んだ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "『先生はまだ此處にか』と打ち伴れて、行けば行くほど、どうやら通つたことの無き路なりと氣が付き、行きつ戻りつ、漸く本坊の上に出で、『おうい／＼』と二聲三聲、かなたにも、『おうい』と答へて、待つ間程なく、うれしや闇を照らす車夫の提燈。",
              "citation": {
                "source": "夜の高尾山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "眞珠の小箱　東大寺の本坊の廣間に、私は執事長Ｋ師と對坐してゐた。",
              "citation": {
                "source": "奈良二題",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本坊の庭は、今の主人の祖父か曾祖父にあたる人が造園したものだと云はれてゐる。",
              "citation": {
                "source": "挿頭花",
                "author": "津村信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "本山修験、入間郡越生郷山本坊配下ナリ。",
              "citation": {
                "source": "二、三の山名について",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　田丸主水正は、必死につづけて、「御承知でもござろうが、日光｜什宝のうち、まずその筆頭にあげられるのは、本坊輪王寺に納めある開山上人御作の、薬師仏御木像一体……」　と主水正は、まるで、そのあらたかな仏像に面と向かっているかのように、うやうやしく一礼した。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "比叡山本坊貴賓室にて。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　本坊の前から炊谷へかけて森々たる老杉の中へ駕籠が進んで行く時分に、さきほどから小止みになっていた雨空の一角が破れて、そこから、かすかな月の光が洩れて出でました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "光悦は、さればにて候という態で、即座に、「――まず次はあなた様、その次は、八幡の滝本坊――あの昭乗でございましょうかな」　すこしのみ込めない顔つきをして、三藐院は、もういちど問い直した。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、洛外の滝の本坊にいるという隠操の雅人、松花堂昭乗の淡味な即興風のものにも心をひかれた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は妙義山に将て行かれて奴となり、或は讃岐の杉本坊の客となりしとも云ふ。",
              "citation": {
                "source": "山の人生",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "たれかと見れば、岡本坊の快実という豪の者だった。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "――岡本坊ノ律者快実、武家の大将一人打ち取ッたり」　と、み幕の内へすすみ、穂先の首を抜いて、実検に供えた。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとり岡本坊のみに、手柄を誇らせておくな。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめて、藤本坊の英憲やまた円宗院の法印｜定宗らが、五百余人の堂衆を後えにつれて、大床の下に来て伏し、「まずは三千の衆徒、臨幸を厭んじたてまつるなどの者は、一人もあるまじきにて候う。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あの翌朝、おれの縄目を解いて放してくれた……」「いや、縄を解いて放してやれと仰っしゃったのは、たれでもない、和殿がその前夜、男山八幡の石段で、殿ノ法印の身うち岡本坊と共に、暗殺しようと計って仕損じたわがおあるじ尊氏どのだ」「これは？",
              "citation": {
                "source": "私本太平記",
                "author": "筑紫帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、敵の術策を裏返しに、岡本坊の良円を、はるか東北へ密使に放った。",
              "citation": {
                "source": "私本太平記",
                "author": "黒白帖",
                "note": "青空文庫"
              }
            }
          ]
        }
