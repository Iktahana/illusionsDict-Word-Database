    "definitions": [
      {
        "index": 1,
        "gloss": "state (or period) of life",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "日本有数という形容は、そのまま世界有数という実相なのだから、自重しなければならぬ。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本有數といふ形容は、そのまま世界有數といふ實相なのだから、自重しなければならぬ。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "チエホフの　「熊」　　　　　　一幕シングの　　「鑄掛屋の結婚」　一幕山本有三の　「海彦山彦」　　　一幕「熊」の老僕にはあとで「青空」の同人になつた小林馨がなつた。",
              "citation": {
                "source": "『青空』のことなど",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本有數のフランス語學者であるその老教授は、三度目に、たまりかねたやうにして、大聲で言つた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "理学士ではなかったがしかし非常に篤学な人で、その専門の方ではとにかく日本有数の権威者だという評判であった。",
              "citation": {
                "source": "埋もれた漱石伝記資料",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの直感的理性は、その概念性の有無を除いて、本質には科学や哲学の認識と同じことで、常に事物と現象の背後に於て、或る普遍的に実在するもの――即ち自然人生の本有相――を、観照の面に映し出そうと意図している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "換言すれば問題は、山の景色が詩的であるか、海の景色が詩的であるかという、その対象の判別ではなく、こうした一般のものについて、吾人の心に感じられる「詩」の本質が、いかなる本有性のものであるかに存するのである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は物質の本有する形態感、重量感、触覚感等のものを、絵画によって三次元的の空間に描こうとした。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人は彼の描いた一つの椅子から、すべての物質に遍する本有の実在を直覚する。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "感情の南方地帯に属するもの、即ち所謂「情緒」は、それ自ら愛の本有感である故に、博愛や人道やの、すべての柔和なる道徳情操を基調している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪漫主義の本有感は、愛のメロディアスな情緒感で、柔軟可動の自由を愛し、内容を本位とするものであるのに、クラシズムは情緒を排し、感傷的気分を嫌い、そして均斉、対比、平衡、調和等の、数学的法則による形式を重要視する。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸例を挙げて言って見ると、前の長崎高等商業学校長をしていた隈本有尚、故人の日高真実、実業家の植村俊平、それから新渡戸博士諸氏などで、此の外にも未だあるだろう。",
              "citation": {
                "source": "私の経過した学生時代",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋台の裏にも山桜の大木三本有之、微風吹き来る度毎に、おびただしく花びらこぼれ飛び散り、落花｜繽紛として屋台の内部にまで吹き込み、意気さかんの弓術修行者は酔わじと欲するもかなわぬ風情、御賢察のほど願上候。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉田百三か、山本有三かね。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も勤先の窓の前に幹の繁いかなめもちが一本有る。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る時、内地人の集まりの場所で、偶※私が山本有三氏の名を口にしたところ、それはどういふ人ですと一齊に尋ねられた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る時、内地人の集まりの場所で、たまたま私が山本有三氏の名を口にしたところ、それはどういう人ですと一斉に尋ねられた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "山本有三、自由主義の門番あなたの良心に一応会釈をして通るだけだ。",
              "citation": {
                "source": "小熊秀雄全集-12",
                "author": "詩集（11）文壇諷刺詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、改造社からは、時々特別にお禮を貰ふこともあるが、これは山本有三なども貰つてゐるらしいから、佐藤君だつて同じだらう。",
              "citation": {
                "source": "よしなし事",
                "author": "〔源内の手紙、原稿料のことなど〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本ノ講和委員ハ何ガ故ニ英米ト日本トガ國民精神ノ根本、國家組織ノ信念ヨリ異ニスル所以ヲ指摘シテ、日本國民本有ノ國家有機體的信仰ヲ彼等ニ訓ユルコトナカリシカ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　山本有三、井汲清治、豊島與志雄の諸氏がいたが、誰も知らなかった。",
              "citation": {
                "source": "芥川の事ども",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "作家では山本有三氏、歴史家では羽仁五郎氏などが、文化に対する良心から、自身の著作に漢字の制限と仮名使いの単純化を実行して居られる。",
              "citation": {
                "source": "今日の文章",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、山本有三氏の労作「真実一路」と数年前に書かれた「女の一生」などとを比べると、この作者の進歩性が陥っている今日のスランプの客観的・主観的な性質が手にとるように感じられる。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山本有三氏は或る意味で大衆に愛読されている作家である。",
              "citation": {
                "source": "文学における今日の日本的なるもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山本有三氏の境地宮本百合子-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）些か｜：ルビの付く文字列の始まりを特定する記号（例）勉強する気｜頓になくなる。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "：入力者注　主に外字の説明や、傍点の位置の指定（例）いざこざに堪えて-------------------------------------------------------　今日、山本有三氏の読者というものは、随分ひろい社会の各層に存在していることであろうと思う。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大仏次郎氏などの作品も、吉屋信子氏が読まれるとは別のところに多くの読者をもっていることでは、山本有三氏と同様であろうが、作者と読者との間にある共感の種類は、必ずしもこの二人の作者に於て同じものであるとは思えない。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山本有三氏の読者たち、山本氏の作品から何かを期待している人々は、そういう気分を主とした気持より、もっとずっと謂わば野暮くさいものをもって作者に向っていると思う。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か人生的な、何か社会の指針的な、何か誠実な生きてゆく人間の姿の表現を、読者は山本有三氏に求めている。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山本有三氏と読者との結びつきは、どこか只面白い小説という以上のものに対する暗黙の契約の上に立っているように見えるのである。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
