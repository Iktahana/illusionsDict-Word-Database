  {
    "uuid": "5b8fe66d-7bc7-5cef-835d-89fd859d2b74",
    "entry": "本寺",
    "reading": {
      "primary": "ほんじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
