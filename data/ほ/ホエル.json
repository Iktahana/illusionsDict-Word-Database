    "definitions": [
      {
        "index": 1,
        "gloss": "to bark",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "犬が吠える、虫が鳴く、　　　畜生！",
              "citation": {
                "source": "暗い天候",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "吠えるなら吠えろ、　　　鳴くなら鳴け、目に涙を湛へて俺は仰臥さ。",
              "citation": {
                "source": "暗い天候",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇夜に吠える黒犬は、自分が吠えているのか、闇夜の宇宙が吠えているのか、主客の認識実体が解らない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度その時、僕は處女詩集「月に吠える」を出し、室生犀星君もまた第一詩集「愛の詩集」を發行した。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで水を飲もうとすると、犬が盛に吠える、「誰だあ、やい」戸の中から寝ぼけ声が聞える。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "月に吠える、それは正しく君の悲しい心である。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬になつて私のところの白い小犬もいよいよ吠える。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼のうちは空に一羽の雀が啼いても吠える。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "霜の下りる声まで嗅ぎ知つて吠える。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴようぴようと吠える、何かがぴようぴようと吠える。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "月に吠える犬は、自分の影に怪しみ恐れて吠えるのである。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば私の詩集『月に吠える』――それは感情詩社の記念事業である――は、正に今日の詩壇を予感した最初の黎明であつたにちがひない。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しののめちかく、さみしい道路の方で吠える犬だよ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、どこまでも、どこまでも、この見もしらぬ犬が私のあとをついてくる、きたならしい地べたを這ひまはつて、わたしの背後で後足をひきずつてゐる病気の犬だ、とほく、ながく、かなしげにおびえながら、さびしい空の月に向つて遠白く吠えるふしあはせの犬のかげだ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれはきみのわるい畸形の犬がぼうぼうと吠える月夜をぼんぼりのやうに病みつかれて歩いてゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "喧噪、武具の音、吠える犬。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそんなひろびろとした、銀色の、いかにも丁抹らしい夏の夜に、そんな死の吠えるのが聽えてくると、村の人々は嵐のときのやうに起き上り、著物をきて、一言もものを云はずに、それが過ぎ去るまで、ランプのまはりに坐つてゐるのだつた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の鼾声や、犬の吠えるのがきこえる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までえらそうにぶつ／＼云っていた奴が、ワン／＼吠えることだけしか出来ねえんだ。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青じろ番兵は　　　ふんにゃふにゃ　吠えるもさないば　泣ぐもさない　瘠せで長くて　　　ぶぢぶぢで　どごが口だが　　　あだまだが　ひでりあがりの　　なめぐじら。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてたうとうこらへ切れなくなって、吠えるやうにうなって荒々しく自分の谷地に帰って行ったのでした。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてとうとうこらえ切れなくなって、吠えるようにうなって荒々しく自分の谷地に帰って行ったのでした。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとその晩おそくワンワンワンとはげしく犬が吠える声と一緒に、「痛い痛い。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "）、口と犬とを合わせて吠えるというようにできあがっていると言い、また歌舞伎についても分解的演技の原理という言葉を使って、役者の頭や四肢の別々な演技がモンタージュ的に結合されるというふうに解釈した。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と直ぐに答へて、坂上は其のまゝ立留まつて、振向いた……ひやりと肩から窘みながら、矢庭に吠える犬に、（畜生、）とて擬勢を示す意氣組である。",
              "citation": {
                "source": "三人の盲の話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、奥山で餞した時、時ならぬ深夜の人影を吠える黒犬があった。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほツと息をすると、びよう／＼と、頻に犬の吠えるのが聞えた。",
              "citation": {
                "source": "星あかり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　ほえるような声で主人は叫んだ。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "尻尾を焼かれた馬が芝生のある傾斜面を、ほえるように嘶き、倒れている人間のあいだを縫って狂的に馳せまわった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一犬は虚をほえなくても残る万犬の中にはうそ八百をほえるようなのもたくさんに交じるのであるが、それがみんな実として伝えられるのである。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
