[
  {
    "uuid": "0209a57a-ed46-576d-8a44-3e7b065f250f",
    "entry": "火焚き",
    "reading": {
      "primary": "ほたき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
