        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一族はこれからイレエネ・ホルンと云ふ未亡人の邸へ食事に行くのである。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "イレエネは亡くなつたアントンの娘で、ホルンと云ふ夫を持つて、その夫に先立たれてゐるのである。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同はイレエネ・ホルンの家の戸口に着いた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "「をぢさん」と一声を発することを敢てしたのは、女主人イレエネ・ホルンであつた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホンブレンさまと、一人はホルンブレンドだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の伯爵のガス排出の音からふざけ半分のホルンの一声が呼び出され、このラッパが鹿狩りのラッパに転換して爽快な狩り場のシーンに推移するのである。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一行八人がアルプスのマッターホルンを初めて征服したので、それから段々とアルプスも開けたような訳です。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは皆様がマッターホルンの征服の紀行によって御承知の通りでありますから、今｜私が申さなくても夙に御合点のことですが、さてその時に、その前から他の一行｜即ち伊太利のカレルという人の一群がやはりそこを征服しようとして、両者は自然と競争の形になっていたのであります。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四日の一時四十分にとうとうさしもの恐しいマッターホルンの頂上、天にもとどくような頂上へ登り得て大に喜んで、それから下山にかかりました。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一行八人がアルプスのマッターホルンを初めて征服したので、それから段※とアルプスも開けたような訳です。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは皆様がマッターホルンの征服の紀行によって御承知の通りでありますから、今私が申さなくても夙に御合点のことですが、さてその時に、その前から他の一行即ち伊太利のカレルという人の一群がやはりそこを征服しようとして、両者は自然と競争の形になっていたのであります。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷の八つ当りは、もう大丈夫だろうかと検すように、森の中でかっこうがホルンを吹奏した。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでにホルンとサックスに、三味線と琴の音も出してみましょう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに聞きたいのは胸にずんと来る演奏その物で、ホルンに見える楽器がサックスの音を出していようが、ポチがミケの声で鳴こうがそんなことはどうだっていい。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺のホルンらしいな。",
              "citation": {
                "source": "馬車の歌",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年も僕が使ひ慣れた真鍮のラツパ・ホルンである。",
              "citation": {
                "source": "馬車の歌",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私の顔を見ると、明るい微笑を浮べて、此方が未だ何も云ひ出さないうちに、ホルンの、片端にＳ・Ｍといふローマ字が誌してある皮袋を指差して、「これですか？",
              "citation": {
                "source": "馬車の歌",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの大事なホルン（ラツパ）までもとられてしまつて！",
              "citation": {
                "source": "歌へる日まで",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "……さう／＼、あたしが幼い時分にフランクはホルンを吹いてゐたけれど今でも続けてゐて？",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "左端のタンホルンから、右端のドルデンホルンにいたるまで、ベルグリストックが、フィンステルアルが、アイガアが、モンクが、ユングフラウが、ブリュムリフオルブの群巒が、さらにブルュンヂンが、續々として屹立ち、こゝに人間界とは別の天地を形成してゐるのである。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "巌頭に立つて黄銅のホルンを吹く者へ。",
              "citation": {
                "source": "遺産分配書",
                "author": "富永太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、後日彼自身が白状したとおり、その際この舞踏会全体が、やかましい話声や騒々しい物音と一緒に、しばらくのあいだは何処かへ遠退いてしまい、ヴァイオリンやホルンも、何処か山の向うででも、やけに鳴らされているように思われたのである。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "花崗岩の巨峰は、日本のマッタホルンとも言はれると聞いた。",
              "citation": {
                "source": "屋久島紀行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワグネルはあの楽劇の中で、フレンチ・ホルンの弱音器記号に｜＋という符号を使っている。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男は左端に近い旗太郎の直下にいた、大田原末雄というホルン奏者であった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
