  {
    "uuid": "88aae987-9843-5fcf-900c-52bd4c5ceea4",
    "entry": "鳳梨",
    "reading": {
      "primary": "ほうり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
