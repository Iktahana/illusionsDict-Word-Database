    },
    "definitions": [
      {
        "index": 1,
        "gloss": "walking speed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「大変あったかい鼻の頭をしているよ」　暫く行くと、歩速の整った彼等の脚が、先へ行く三四人の学生の一団に追いついた。",
              "citation": {
                "source": "杉垣",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆村のすぐ後に、ぴったり寄り添ったように同じ歩速で歩いている大寺警部の前へつきだした顔が、見えない紐につながれて、帆村の右手で引張って行かれるようであった。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処はまだ別れる場所ではなかつたが、伊豆は斯う言はれたので咄嗟に歩速を緩めた。",
              "citation": {
                "source": "小さな部屋",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "興奮が短い脚の歩速をはやめる。",
              "citation": {
                "source": "麓",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、散歩をして参りましょう」　金博士は、石段づたいに芝地に下り、そして正確なる歩速でもって、向うの方へ歩いていった。",
              "citation": {
                "source": "大使館の始末機関",
                "author": "――金博士シリーズ・７――",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処はまだ別れる場所ではなかったが、伊豆はこう言われたので咄嗟に歩速を緩めた。",
              "citation": {
                "source": "小さな部屋",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "近づいて来る新島の歩速に合わせて、秀之進は松林の中をそっと道の近くへおりていった。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乱心者だ、狼藉者だ、と喚く声が前後から聞え、玄四郎は歩速を緩めずに走った。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うぬ、今夜こそは」　と、東儀与力もまた、歩速のあらんかぎりを出して、つんのめるように追い駆けた。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の歩速と、女の歩速――　またたくまにその距離は迫ったけれど、もう一歩という所で、女は、混み入った裏町の露路へまぎれこんでしまった。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "くたばった振りなどしやがって」　――状元橋を渡るやいな、彼の歩速はだんだん早くなっていた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車はかなりの歩速で躍ッていたが、馭者の鞭の数がまだ少ない気がした。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その歩速に合わせて、後からは十兵衛の駒と、槍の穂先が背を追って来る。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬も兵もこれまで来た歩速と変りなくうごいて行く。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まず、午過ぎまでには」　と、そこで甲府に着くまでの時間と歩速に、すっかり見込みがついたらしく、ひと休みして、甲斐盆地にも訪れている夏の日をながめていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀吉は、その踵を、反対のほうへ回らして、途中から次第に歩速を大股に運んでいた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに拠ってただちに根原の同一を推断することは大胆に過ぐとしても、少なくとも是だけ複雑なる外来の影響を受けながら、なお変化の傾向と順序とがほぼ一致し、ただその歩速のみが地域ごとに著しくちがっていたのだということが、比較によって追々と判ってこようとしているのは頼もしい。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、さすが馬の疲れに、五郎は目的の邑久郡今木（現・今城）までくると急に歩速をゆるめ、やがて向山の今木城のうちへ入った。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "――味方の陸上軍の歩速――特に山手隊のうごきと、全船列の船脚とを見合せて、「ちと迅いぞ。",
              "citation": {
                "source": "私本太平記",
                "author": "湊川帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶然などという奴は「尖鋭の精神」の権化みたようなもので、よっぽど精神をほそくとんがらかさないでは捉えにくい代物だ。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、わたしはどこへ行くのか知らない、わたしのゆく道路の方角では、長屋の家根がべらべらと風にふかれてゐる、道ばたの陰気な空地では、ひからびた草の葉つぱがしなしなとほそくうごいて居る。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "くぢら浪海岸にて孤独田舎の白つぽい道ばたで、つかれた馬のこころが、ひからびた日向の草をみつめてゐる、ななめに、しのしのとほそくもえる、ふるへるさびしい草をみつめる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄昏花さけるねむの林を、　　　　さうさうと身もかはたれつ、声ほそく唱歌うたひて、　　　屠殺士の加吉さまよふ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、十匹の蟻が、墨汁の海から這い上って、そうして白絹の上をかさかさと小さい音をたてて歩き廻り、何やらこまかく、ほそく、墨の足跡をえがき印し散らしたみたいな、そんな工合いの、幽かな、くすぐったい文字。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽつんとしたまっ赤なあかりや、硫黄のほのおのようにぼうとした紫いろのあかりやらで、眼をほそくしてみると、まるで大きなお城があるようにおもわれるのでした。",
              "citation": {
