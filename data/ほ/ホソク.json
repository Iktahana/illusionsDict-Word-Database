[
  {
    "uuid": "b4dd9b95-6396-51df-8c05-b48de7178421",
    "entry": "捕捉",
    "reading": {
      "primary": "ほそく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
