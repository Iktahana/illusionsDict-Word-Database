          "literary": [
            {
              "text": "だれかが、ハーフバウンドを捕球しそこなって、あざをつくっていたりするのだろうが、音だけなら、ノックもじつに無害にきこえる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕球する革具の、鈍い響き。",
              "citation": {
                "source": "昼の花火",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
