    "definitions": [
      {
        "index": 1,
        "gloss": "supply line",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "敵の補給線が絶たれ、部隊は撤退を余儀なくされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遠征軍は、長すぎる補給線によって食料不足に陥った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "災害で寸断された補給線を復旧するため、関係者が奔走した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "北海の濃霧の底に沈んでいたはずの英国の飛行場から、爆撃機の大軍が次ぎから次ぎと飛び出して来て、ドイツ攻撃軍の補給線を断ち切ったからである。",
              "citation": {
                "source": "霧を消す話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「連合軍のドイツ補給線に対する戦略爆撃がわが攻勢を挫折せしめた」とフォン・ルントシュテットは嘆じた。",
              "citation": {
                "source": "霧を消す話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
