    },
    "definitions": [
      {
        "index": 1,
        "gloss": "inclusion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "民族的、歴史的存在規定をもった現象を自由に変更して可能の領域においていわゆる「イデアチオン」を行っても、それは単にその現象を包含する抽象的の類概念を得るに過ぎない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "誠に宇宙は無限大でその中に包含する万象の数は無限である。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ文化の特徴がことごとくこの奇妙な物質の中に集中され包含されているような気がするのであるが、その理由は分らない。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在の日本はカラフト国境から台湾まで連なる島環の上にあって亜熱帯から亜寒帯に近いあらゆる気候風土を包含している。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしていわゆる温帯の中での最も寒い地方から最も暖かい地方までのあらゆる段階を細かく具備し包含している。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二つの短詩形の中に盛られたものは、多くの場合において、日本の自然と日本人との包含によって生じた全機的有機体日本が最も雄弁にそれ自身を物語る声のレコードとして見ることのできるものである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は近代物理学によって設立された物質やエネルギーの素量の存在がいわゆる経験によった科学の事実である事を疑わないと同時に、またかくのごとき素量の存在の仮定が物理学の根本仮定のどこかにそもそもの初めから暗黙のうちに包含されているのではないかということをしばしば疑ってみる事がある。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで一見いわゆるはなはだしく末梢的な知識の煩瑣な解説でも、その書き方とまたそれを読む人の読み方によっては、その末梢的問題を包含する科学の大部門の概観が読者の眼界の地平線上におぼろげにでもわき上がることは可能でありまたしばしば実現する事実である。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に一株の樹を植うる其事は甚だ微少瑣細であるけれども、其の事の中に包含されて居る將來は、甚だ久遠洪大なもので、其の久遠洪大の結果は、實に人の心念の機微に繋つて居るものであつて、一心一念の善良なる働は、何程の福を將來に生ずるかも知れぬのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し人事は、其の人に切なる上に於ては天數にも過ぎて居るが、畢竟天の數は人の事を包含して餘が有る。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖人偉人帝王豪傑は、星辰之に符し、雲氣之に應ずるものとして信ぜられて居たことは、歴史や雜書が吾人に語るところであるから、望氣の術が軍陣以外の事を包含して居たことも自ら明らかである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダカラ甘く天地を包含したようの事を示せるのサ。",
              "citation": {
                "source": "ねじくり博士",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "從つて社會主義と基督教との間には、或調和の保たれる餘地は充分にあるが、然しその調和は兩方の特質を十分包含し得る程の調和ではあり得ない。",
              "citation": {
                "source": "小説「墓場」に現れたる著者木下氏の思想と平民社一派の消息",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰もがいつの間にか行く常道、その平凡こそなまじ一個人の計いより何程かまさった真理を包含しているものなのだろうということを自分自身に感得した智子であった。",
              "citation": {
                "source": "明暗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "論理と解析ではその前提においてすでに包含されている以外の何物をも得られない事は明らかである。",
              "citation": {
                "source": "科学者と芸術家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの法則は、その本原において、未来に横たわりうるいっさいの偶発事項を包含するように作られたのである。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "より幅広い世界を包含する紙―ペン環境を使いこなしの基本としたとしても、必要とあらばそこにキーボードをくっつける一手だろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "人にとってより親しみのあるマシンを目指すのなら、我々は早く『タイプライター』で凝り固まった頭を切り変えて、『紙とペン』というより幅広い世界を包含するメタファーに移行すべきだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし人事はその人に切実な点では自然の作用にも収まらないが、結局は自然の作用は人事を包含して余りが有る。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖人・偉人・帝王・豪傑には、星辰これに付し、雲気これに応ずると信じられていたことは歴史や雑書が我々に語るところであるから、望気の術が軍陣以外の事を包含していたことも自然と明らかである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐藤熊蔵君『机に倚れる幼女』面白し、さてその珍奇さから眼を転じてその内容的に包含されたものを探し出して見る場合、実質に於ての物足らなさがある。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "地質発達史は、数万年、数十万年乃至数百万年の時間を包含することによりはじめて成立するのであつて、数百年、数千年位の短時日の間に、一定の自然条件が甚だしく変化することは殆んどないといつてよい。",
              "citation": {
                "source": "文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "後日に到って彫刻の世界のものは種々包含されて、木の部に竹彫が入って木竹部となりました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "発会当時およびその後のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般に探偵小説の愛読者は、他の軟文学の読者よりも遥かに広い範囲にわたっており、しかもその中にはより多くの教養ある階級の人々を包含している。",
              "citation": {
                "source": "探偵小説の世界的流行",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に新市域に編入されてからは、碑衾町をも包含することになったので、私のような出不精の者には容易に廻り切れない。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ラ・セイジヤス」の秀什、この想を述べて余あり、又、千八百六十四年の詩集に収めたる「瞻望」の歌と、千八百八十九年の詩集「アソランドオ」の絶筆とはこの詩人が宗教観の根本思想を包含す。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ラ、セイジヤス」の秀什、この想を述べて餘あり、又、千八百六十四年の詩集に收めたる「瞻望」の歌と、千八百八十九年の詩集「アソランドオ」の絶筆とは此詩人が宗教觀の根本思想を包含す。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
