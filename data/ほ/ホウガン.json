[
  {
    "uuid": "2dba45ba-3f0c-5609-aec8-31bf41615b6c",
    "entry": "包含",
    "reading": {
      "primary": "ほうがん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
