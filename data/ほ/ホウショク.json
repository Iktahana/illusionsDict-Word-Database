        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "being in the service of",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "換言すれば、蠅はわれわれの五体をワクチン製造所として奉職する技師技手の亜類であるかもしれないのである。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "換言すればはえはわれわれの五体をワクチン製造所として奉職する技師技手の亜類であるかもしれないのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "周防山口の地方裁判所に父が奉職して居た時分、馬場金之助という碁客が居て、父と非常に懇親を結び、常に兄弟の如く往来して居たそうです。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に地方の学校にでも奉職していて充分な研究設備をもたない人で、何かしらオリジナルな仕事がしてみたいというような人には、いつでもこの線香花火の問題を提供した。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校を出たときに、北海道と台湾とに奉職口があって、桐沢さんは北海道の方へ行ったら好かろうと勧めたのだそうですが、本人はどうしても台湾へ行くと言って出かけたので……。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその着実とはたんに今日の学生のすべてがその在学時代から奉職口の心配をしなければならなくなったということではないか。",
              "citation": {
                "source": "時代閉塞の現状",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の日本人の先祖にしてはチッと立派過ぎはせんかのうハッハッハッハッ」　日本に帰って千代町の役場に奉職している時は毎月五円の月給（巡査の月給二円五十銭、警部が三円時代）を貰っていたが、その殆んど全部が酒代になっていた事は云う迄もない。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "講和になつた時は一日も早く横須賀へ行つて吸付烟草の噺もして見たかつたが内地へ凱旋の間際にはそのどさくさ騷ぎに紛れて遂機會を失し其内に病院へ奉職はする、それから開業して一身は束縛される。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "四『病院へ奉職したのは二月である。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "其前にも外科室附が一人あつたが僕が奉職して間もなく、赤十字社の病院へ行く積りで試驗を受けたが落第したとかでそれで外聞が惡いとかいつて病院を出てしまつた。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の學校にもせめて三年も奉職して居ることが出來ましたならば幾らか義務を果すことが出來たでありませう。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　さて、一方足跡の番人を仰せつかった新米の蜂須賀巡査は、奉職してから初めての殺人事件に、もう一番手柄を立てたかと思うと、内心少からぬ満足で、こうなるとそろそろ商売は可愛らしく、後手を組んで盛んに合点しながら、足跡の線をあちらへブラリこちらへブラリと歩き廻っていた。",
              "citation": {
                "source": "石塀幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "後年美術学校教授を奉職し私とは同僚となりました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "竜池会の起ったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰化の事でも好まない奉職の事でも皆そうでございました。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以来私は、Ｒ漁場の魚見櫓に奉職して、毎日毎日何回となく長梯子を登り降りしてゐた。",
              "citation": {
                "source": "酒盗人",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父は鬼柳村の村役場に奉職してゐたが（それは勿論、極度の神経衰弱症に他ならぬのであらうが、誰もそんな病名を患者の上に冠せもしなかつた。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "理学士が此処に奉職したのは冬の終り頃であつた。",
              "citation": {
                "source": "風媒結婚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、倉部巡査はこの町に近いある村の駐在所に奉職していたが、ちょうど今夜のような細かい雨がしとしとと降る宵であった。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等学校時代の知合いで、法学士になっている連中は、幾人もいることはいたが、郵船会社にはいって洋行したり、政治科を出て農商務省へ奉職したり、三菱へはいっている連中などばかりが思い浮んで、自分の相談に乗ってくれそうな、法律専門の法学士はなかなか思い当らなかった。",
              "citation": {
                "source": "島原心中",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――唯一人の兄が県庁に奉職してゐたので。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――唯一人の兄が縣廳に奉職してゐたので。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "文三の某省へ奉職したは昨日今日のように思う間に既に二年近くになる。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "知己と云うは石田｜某と云って某学校の英語の教師で、文三とは師弟の間繋、曾て某省へ奉職したのも実はこの男の周旋で。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、私の職業の変遷を述べれば、官報局の翻訳係、陸軍大学の語学教師、海軍省の編輯書記、外国語学校の露語教師なぞという順序だが、今云った国際問題等に興味を有つに至って浦塩から満洲に入り、更に蒙古に入ろうとして、暫時警務学堂に奉職していた事なんぞがある。",
              "citation": {
                "source": "予が半生の懺悔",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは宮廷に出入し、往々『天の秘密の司官』という官名で奉職していた。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "原は金沢の学校の方に奉職していて、久し振で訪ねて来た。",
              "citation": {
                "source": "並木",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、ずっと後になって、私が美術学校へ奉職するようになり、憲法発布式の当日に家内が上野で竹内先生が不思議な風をして行列の中に交っていたという話しの訳が分りました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "学校へ奉職した前後のはなし",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
