[
  {
    "uuid": "71c77b69-44f4-5c32-8c3c-3b35a880b1a9",
    "entry": "奉職",
    "reading": {
      "primary": "ほうしょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
