    "definitions": [
      {
        "index": 1,
        "gloss": "splendid multistoried building",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "観音のとなりにも鳳閣寺という真言宗の寺があって、芝居の鳴り物はその寺の境内からきこえて来るのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳳閣寺の宮芝居は坂東小三という女役者の一座で、ここらではなかなかの人気者であることを半七は知っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　鳳閣寺の境内を出て、半七は更に久保町へむかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が鳳閣寺内の宮芝居をのぞいたのは、単に芝居好きであるが為ではない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "斬られた腕は二度とも唐人飴の筒袖を着ていたのですが……」「おめえは知るめえが、鳳閣寺の女芝居で国姓爺の狂言をしている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に照之助は虎狩に出るだけの役らしいので、ぐずくずしていると帰ってしまうかも知れないと、二人は鳳閣寺へ急いで行くと、桶屋の源次が門前に待っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳳閣寺の門前には庄太が待っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは国姓爺の芝居です」「鳳閣寺の芝居ですね」「さっきもお話し申した通り、ここの芝居は女役者の一座ですから、男と女と入りまじりの芝居は出来ない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、男と女と入りまじりの芝居をするのは不都合だというので、浅川の方から鳳閣寺の芝居小屋へ掛け合いを持ち込んだが、四の五の云って埓が明かない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
