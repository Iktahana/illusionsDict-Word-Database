        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "又いろいろ教育界方面の希望もあつて、國史の教授を盛んにする氣運も動き、また確か今年あたりから、これ迄高等文官の試驗にも今迄に無かつた日本の法制史といふ新科目をも加へることになつて居ります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが、支那の法制史上に於いて明律の注意すべき點であります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論、法理学のように法律に関する哲学的考察を目的とする講義も行われているし、また法制史のように法律事実学の部門に属するものと考えられる講義も行われている。",
              "citation": {
                "source": "新たに法学部に入学された諸君へ",
                "author": "末弘厳太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてかくのごとくに考えればこそ、大学の法学教育で現行法のほかに法制史や外国法を教える意味もわかるのであり、現行法の教育としても、もっと目的に適った教え方があるのではないかというようなことも、考え得るに至るのである。",
              "citation": {
                "source": "法学とは何か",
                "author": "――特に入門者のために",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝川（政）氏が博士になれたのは、多分同じ法制史でも日本の法制史の研究だったからではないかと思う。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきはあれから護国寺前の本やによりまして、やっと『文春』の十二月号を買い、三浦周行の『法制史下巻』をかい、外山卯三郎の切支丹文化史という本を買いました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "三浦周行の『法制史研究』は面白そうなのに下だけしか買えませんでした。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九〇三年二十歳七月、ローマ法、教会法、ドイツ法、オーストリア法制史に関する国家試験（前半二年間の修了試験に相当）を好成績ですます。",
              "citation": {
                "source": "「世界文学大系58　カフカ」年譜",
                "author": "原田義人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
