    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hay",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "昼過ぎに行って見ると、刈られた葉はすっかりかわき上がって、青白い干し草になって散らばっていた。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやゆび姫はベッドから下りて、大きくきれいに干し草の毛布をあみました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にやっと柵の上へ制服の胸をのしかけたまま、目の前へ歩み寄った白牛に干し草をやったことを覚えている。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "――或精神的風景画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛は彼の顔を見上げながら、静かに干し草へ鼻を出した。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "――或精神的風景画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふうん、干し草刈りにの？",
              "citation": {
                "source": "一塊の土",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると急に篤介の匂――篤介の体の発散する匂は干し草に似ているような気がし出した。",
              "citation": {
                "source": "春",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の経験に誤りがなければ、干し草の匂のする男性はたいてい浅ましい動物的の本能に富んでいるらしかった。",
              "citation": {
                "source": "春",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にやつと柵の上へ制服の胸をのしかけたまゝ、目の前へ歩み寄つた白牛に干し草をやつたことを覚えてゐる。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "―或精神的風景画―",
                "note": "青空文庫"
              }
            },
            {
              "text": "弥生ウサギ　もう残ってるのは干し草だけで。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤のキング　ならば干し草を。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤のキングは干し草を受け取り、もしゃもしゃと食べる。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤のキング　（アリスに）気が遠くなったときは干し草を食うに限るぞぉ！",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋の片隅に干し草を積んで、パトラッシュのベッドにしました。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A Dog of Flanders",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ壁面には鏡がかけてあって、時折私はそこに映る幼少期という謎の薄布を、ヒナギクの花輪を、暖雨の風が過ぎた果樹園一杯に散る花びらを、長い遊歩道の途中の追い剥ぎ洞窟を、干し草置き場にこっそり溜め込まれたリンゴを見ていたのだ。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるものは崩壊を農業政策の失敗で説明している（シムホヴィッチ：干し草と歴史）。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬は24時間に全部で8.5kgの干し草と燕麦を食べ、１日の窒素摂取量は139gであり、尿および糞に回収される窒素量は116gであった。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "牝牛は干し草とジャガイモを与えられ、１日の窒素摂取量は201gであったが、回収された窒素はミルク中の46gを含めて175gに過ぎなかった（表１）。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "閉塞性黄疸でこのビタミンの吸収に障害のある出血性の患者や、抗ビタミン物質を含むスウィートクローバー干し草を食べていた家畜に、このビタミンは治療効果があった（84）。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か誘導する標識が無かったら、このようなものを意図的に探すのは諺に言う干し草の山に針を探すように望みがない仕事であろう。",
              "citation": {
                "source": "アルカプトン尿の発現",
                "author": "THE INCIDENCE OF ALKAPTONURIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれのように、なかなか雑念も煩悩も捨てられない奴は、それがいちばん解脱の近道かも知れないぞ）　太夫房｜覚明は、牛小屋の外に積んである干し草のうえに坐りこんで寝足らない顔を陽なたに曝していた。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "干し草に火をつけて燃やせ。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "干し草の山から針一本探すようなものだ。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
