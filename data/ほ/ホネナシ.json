    "definitions": [
      {
        "index": 1,
        "gloss": "boneless (of a fillet, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ことこと、ひちゃひちゃ、骨なし子の血を吸う音が、舞台から響いた。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬神、蛇を飼う婦、蟇を抱いて寝る娘、鼈の首を集める坊主、狐憑、猿小僧、骨なし、……猫屋敷。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "Neon. Flourum. Magnesium.Natrium. Silicium. Oxygenium.Nitrogenium. Cadimium or, Stibium　　　　　　　　　　　etc., etc.……四十三年三月　　骨なし児と黒猫そは恐ろしきＸなり。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "淫らにして不倫なる母のごとく、汝が神経と知覚とは痛ましきほど慄けども、力なき骨なし児よ。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国でも女に制せらるる骨なし男をヘン・ベックト、牝鶏に啄かるるという。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮りにも旗本と言われたほどの幕臣が、讐同然な奴の米を貰うて喰って、骨なしにもほどがあると、みんなも憤慨していたぞ。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの骨なしみたいな、癩病みたいな顔の子が、私は初め恐くていやでね、それから、今度は好く見るともう可哀そうに思えましてね。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "弱い男ね、骨なしだわ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と口々に言いながら、めちゃめちゃにぶち据えたものですから、とうとうからだ中の骨が、くなくなになって、今のような目も鼻もない、のっぺらぼうな骨なしのくらげになってしまいました。",
              "citation": {
                "source": "くらげのお使い",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしたち女はただじっとしてればいいんだけど、男の方は家へ帰ると、もう骨なしみたいに、ぐったり疲れてらっしゃることよ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　竜宮に関する昔話はたくさんあるが、そのなかで面白いのは、「くらげ骨なし」だ。",
              "citation": {
                "source": "竜宮",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一応もっとも至極の説なれども、田舎の叔母より楷書の手紙到来したることなし、干鰯の仕切に楷書を見たることなし、世間日用の文書は、悪筆にても骨なしにても、草書ばかりを用うるをいかんせん。",
              "citation": {
                "source": "小学教育の事",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず、骨なしの草書を覚えて廃学すればそれきりとあきらめ、都合よければ後に楷書の骨法をも学び、文字も俗字を先きにして雅言を後にし、まず大根を知って後に蘿蔔に及ぶべきなり。",
              "citation": {
                "source": "小学教育の事",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが蒼※が出まして、全く骨なしの句をこしらえて、それが大そうはやった者でありますが、これは京の厭味な部分だけを取ったので、誠に下らぬ者です。",
              "citation": {
                "source": "俳句上の京と江戸",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしあなたがたがそれを見たらば、魂は消え、息は止まり、総身は海綿のように骨なしになって、からだの奥までぐずぐずに頽れてしまうことでしょう。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はこんにゃくの如く骨なしだ。",
              "citation": {
                "source": "みみず先生の歌",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "稗官小説に――南海に虫ありて骨なし、名づけて泥といふ。",
              "citation": {
                "source": "酒渇記",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "家のなかでは威張つてやがるけど、ほんとは、骨なしだ。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合は、箸で身をむしったり、首ごと背骨を抜いて（京、大阪の人が得意に頭から骨抜きをやる癖）骨なしの姿をパクパクやったりしないで、小口かぶりに頭から順次にかぶって食うのが、真に鮎食いの食い方である。",
              "citation": {
                "source": "鮎を食う",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本立ちすればぶるぶる震える骨なしだから、一人の田中という男に会うために何百人も徒党を組んで赤旗たてたりなんかしてデモをやったうえ、いざ会見となると何十人も手をつながなきゃ文部省の門をくぐれないんだ。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "……笑い男だってそうじゃアねえか、自分一人だけ面白そうに、バカのようにゲラゲラ笑っていずに、鬼火の姥の眷族どもをよ、一緒にゲラゲラ笑わせてよ、骨なしにしてしまえばいいじゃアねえか！",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "良人が又抓られると骨なしのようになって何でも言うことを聞くから、昨今はこれが有力な武器になっている。",
              "citation": {
                "source": "好人物",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "メイエルホリドは、前のシーズンから構成派風の奇抜な舞台装置で、蒼白くて骨なしめいたフレスタコフを登場させているのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "タコは骨を太くするんじゃげなと仰云るから、アラ、タコは自分が骨なしの癖に、と又大笑い。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お起きなさい」　竜之助は苦笑いしながら医者の手を取って起してやると、「失礼失礼」　骨なしのようにグデングデンで、面をかぶったままでお辞儀をするのが、いかにもおかしい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴鹿山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥酔している永田は、ナマコのように、骨なしになって、サクの膝のうえにうつぶし、ほとんど、意識がない。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨なしのような永田杢次を立たせ、頑是ない子供にしてやるように、襦袢、着物、羽織、そして、帯まで締めてやった。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "九州の盆の精霊送りで、最も青森のネブタと近いものは、肥後の山鹿の骨なし燈籠などであろう。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
