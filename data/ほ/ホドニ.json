    "definitions": [
      {
        "index": 1,
        "gloss": "the more ... the more ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
