    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Hokuto",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
