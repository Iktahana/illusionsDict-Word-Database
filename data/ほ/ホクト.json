  {
    "uuid": "2e4ad977-6afe-50a0-a519-574d1ff8baf7",
    "entry": "北斗",
    "reading": {
      "primary": "ほくと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
