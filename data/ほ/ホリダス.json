[
  {
    "uuid": "2ef6644c-4fbc-55cf-b9c5-4a47ff8d00a2",
    "entry": "掘り出す",
    "reading": {
      "primary": "ほりだす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
