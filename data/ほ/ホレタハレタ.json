          "literary": [
            {
              "text": "人に唆かされて惚れた腫れたもないではないか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにか、おのぶサンには惚れた腫れた以外に、折竹に言いたいことがあるらしい。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "避暑の客が大方帰ったので居残りの者は我儘放題、女中の手もすいたので或夕、大友は宿の娘のお正を占領して飲んでいたが、初めは戯談のほれたはれた問題が、次第に本物になって、大友は遂にその時から三年前の失恋談をはじめた。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
