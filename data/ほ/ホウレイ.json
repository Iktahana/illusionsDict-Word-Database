[
  {
    "uuid": "31bc1f6c-29a1-5259-a75b-bbfe0d1ce714",
    "entry": "法令",
    "reading": {
      "primary": "ほうれい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
