        "examples": {
          "standard": [
            {
              "text": "昨夜、銀行でホールドアップ事件が発生し、警察が緊急出動して捜査にあたっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "マスクを被った男がコンビニに押し入り、店員を脅してホールドアップを企てたが失敗に終わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "警察は、ホールドアップの容疑者を数時間後に現場近くで逮捕したと発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
