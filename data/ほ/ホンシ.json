  {
    "uuid": "ba69eddc-dcae-58af-9809-e6eee28f7a99",
    "entry": "本誌",
    "reading": {
      "primary": "ほんし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "main section (of a magazine or journal)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかしこれらの点についてはむしろ本誌の読者の側から示教を仰ぐべきであろう。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月一日の朝、最後の筆を加えた後に、これを状袋に入れて、本誌に送るつもりで服のかくしに入れて外出した。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでわざとそのままに本誌にのせる事にした。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あえて本誌の読者の一考を煩わしたいと思った次第である。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴィアレジオからの二番目の手紙、即ち、本誌所載の手紙は、それに對するリルケの返事である。",
              "citation": {
                "source": "リルケ書翰（ロダン宛）",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、これに関してはやはり『野鳥』の読者の中に知識を求めるのが一番の捷径であろうと思われるので厚顔しくも本誌の余白を汚した次第である。",
              "citation": {
                "source": "鴉と唱歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私が今本誌の貴重な紙面をかりてここにこれらの問題を提出することによって、万一にも、好学な読者のだれかがこの中の一つでもを取り上げて、たとえわずかな一歩をでも進めてくれるという機縁を作ることができたら、その結果は単に私の喜びだけにはとどまらないであろうと思うのである。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上未熟な考察の一部をしるして貴重なる本誌の紙面をけがし読者からのとがめを招くであろうことを恐れる。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うに本誌「理学界」の読者の中には、まさにそういう問題に理解と興味を持ち、また同時に必要の予備知識を持ち、しかして自分自身の研究に従事しうるだけの時間と便宜を有する人も多数にあるであろう。",
              "citation": {
                "source": "物理学圏外の物理的現象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は単なるスペキュレーションに過ぎないが近来ますます盛んになった分子物理学上の諸問題と連関して種々興味ある研究題目を暗示する点において多少の意味があろうと思うので本誌の余白を借りて思いついたままをしるした次第である。",
              "citation": {
                "source": "鐘に釁る",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも彼がかりにわが日本政府の官吏であったと仮定したら、はたしてどうであったかを考えてみることを、賢明なる本誌読者の銷閑パズルの題材としてここに提出したいと思う次第である。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一々これを細舒しおれば本誌全誌を挙げてもなお不足を覚ゆる位である。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "本誌お馴染の断水坊、暴風雨を冒して遊びに来り、夜遅くまで、二人で将棋をパチクリパチクリやっておったが、時刻は夜半の零時か零時半頃であったろう、吾輩はなんでも香車か桂馬をばパチリッと盤面に打下そうと手を伸ばした途端である。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "髯将軍と衣水子の快筆は、未醒子の漫画、木川子の写真と共に、必ず痛快に本誌の次号を飾るであろう。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこの書物が、詩という芸術の真本質を、内容と形式との二部にわたって、能う限り論理的に、合理論によって弁証したものであることだけを、本誌の読者のために告げておこう。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本誌連載中、同郷の友たる今官一君の「海鴎の章。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "末筆ながら、左の二氏より本誌の出版費中へ左の通り寄附ありたり。",
              "citation": {
                "source": "消息",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は近時本誌の文章の天然描寫の一段に於て多大の進境を認むると共に喜悦の念禁ぜざるものあり。",
              "citation": {
                "source": "寫生斷片",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "併せていふ、余は本誌過去一年間の製作品に就いて及び文章に就いて余が考ふる處を述べて次號に發表せんとす。",
              "citation": {
                "source": "寫生斷片",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした趣味の芸術は、あらゆる芸術の先鋒を承って行くべき――そうして将来益々その精鋭の度を加えつつ――あらゆる方面に人類の生活をエグリ付けつつ――新領土を次から次に開拓して行くべき、人類の生命の躍動の最新最鋭の、白熱的尖端――オヤオヤ――スッカリ本誌のお提灯になってしまった――イヤドウモ――。",
              "citation": {
                "source": "ナンセンス",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、このような私的な考えから出た投稿をするという事は、本誌の読者に対しては勿論のこと、乱歩氏に対しても済まない事になりはしないか……というような事も考えられます。",
              "citation": {
                "source": "江戸川乱歩氏に対する私の感想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは私が本誌上に於て「私は探偵小説なるものをこう考えている」という事を一度も発表さしてもらわなかったせいであると考えている事である。",
              "citation": {
                "source": "甲賀三郎氏に答う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて、出来るだけの予約者を得たいから、本誌の読者諸君に挙つて尽力していたゞきたいと思ふ。",
              "citation": {
                "source": "「小学生全集」について",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事件の担当はスコットランド・ヤードのレストレード、グレグソンの二大警部という朗報を聞き、本誌はまもなく両名によって、事件解決の糸口が見つかるのではなかろうかと期待するものである。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "本誌二巻五号、拙文「千疋狼」三〇九頁以下。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "志賀さんの流れに忠実なのは偉いが、いつか本誌で読んだ「擬態」などを見ると独自の翼も悠々たるものがあり、凝るといふよりも寧ろ自由に書きすゝんだ方が展かれさうなのではないか。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "本誌を先きに読むことを自ら約してゐるので守つてゐるのだが、犀星氏の「弄獅子」を別にすると、あれなど最も読み応えがあつた。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのころのことはいつも本誌と一処に、印象的にいろんなことが思ひ出される。",
              "citation": {
                "source": "〔無題〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄は金銀と異なり、わずかな分量では利得にならぬと聞いたが、頃日米国禁鉄となってから、一粒の鉄砂も麁末にならぬような話を承る、ふとした事から多大の国益が拡がった例多ければ、妓家の黒壁が邦家の慶事を啓かぬにも限らぬと存じ、本誌紙面を藉りてその筋の注意を惹き置く。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "予が本誌へ書き掛けた羊の話も例の生活問題など騒々しさに打ち紛れて当世流行の怠業中、未の歳も傾いて申の年が迫るにつき、猴の話を書けと博文館からも読者からも勧めらるるまま今度は怠業の起らぬよう手短く読切として差し上ぐる。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
