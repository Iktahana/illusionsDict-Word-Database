[
  {
    "uuid": "5d95c609-004e-57da-b107-950726061aa5",
    "entry": "本案",
    "reading": {
      "primary": "ほんあん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
