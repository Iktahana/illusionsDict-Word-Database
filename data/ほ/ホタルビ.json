    "definitions": [
      {
        "index": 1,
        "gloss": "glow of a firefly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
