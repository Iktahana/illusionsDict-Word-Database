        "examples": {
          "standard": [
            {
              "text": "災害時に備え、食料と水を安全な保管場所に確保しておく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "貴重な美術品の最適な保管場所を探すのに苦労した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "鍵のかかるロッカーが、個人的な物品の保管場所として利用できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "きわめて貴重な存在である書物は、修道院において、それにふさわしい保管場所を与えられました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日『本心器』がないことに気づいて、カーターを説得して保管場所を尋ねたところ、俺を信頼してか、何も言わずに場所を教えた。",
              "citation": {
                "source": "観点",
                "author": "THE POINT OF VIEW",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に何者かが、サーンス伯爵夫人の保管場所から盗みました」「本当か。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもなんとか尾行をまいて、変装道具の保管場所から出て、奴らの鼻をあかしてやりました。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "メルセデスの運転は分かるし、車の保管場所もだ。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
