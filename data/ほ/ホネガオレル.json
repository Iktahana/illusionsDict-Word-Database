    "definitions": [
      {
        "index": 1,
        "gloss": "to be hard (to do)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "象徴と譬喩と、どうちがうか、それにさえきょとんとしている人がたまにはあるのだから、言うのに、ほんとに骨が折れる。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで彼の仕事を正当に理解し、彼のえらさを如実に估価するには、一通りの数学的素養のある人でもちょっと骨が折れる。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、この込み入つた為事は随分骨が折れるので、をばさんは逆上して来て、折々息を入れるのである。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨が折れること、汚いこと、燐の毒を受けることはすべて彼等がやった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時代のアルプスを登るにはやはり骨が折れる。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "みずすましとちがってあひるの成長はなかなか骨が折れるのである。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手な片手落ちの若返り法などを試みて造化に反抗するとどこかに思わぬ無理ができて、ぽきりと生命の屋台骨が折れるようなことがありはしないか。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "刈り始めてみるとなかなか骨が折れる。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけでもいい加減骨が折れるのに、衣裳も新規のものだと大体の形を画いて著物の模様までつけてやる。",
              "citation": {
                "source": "久保田米斎君の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことをたびたびやられちゃ、使うのに骨が折れるから、何なら思うようにしてくれというの。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに積んであった薪を片づけて、分捕りスコップ（日露戦役戦利｜払下品）を取り上げると、氷のような満月の光を便りに、物音を忍ばせてセッセと掘り初めたが、鍬と違って骨が折れるばかりでなく、土が馬鹿に固くて、三尺ばかり掘り下げるうちに二の腕がシビレて来たので、文作はホッと一息して腰を伸ばした。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう所で、ランデヴウする人も、さぞ骨が折れるでしょうが、そのランデヴウを世話する人は、いよいよ並大抵じゃないわね」　私は揶揄いながら、横を向き、ハンカチを額へ持って行って、滲み出す汗を抑えた。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お客さまは骨が折れるんでしょう。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "短篇十二は、長篇一つよりも、はるかに骨が折れる。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「卓子の向う前でも、砂埃に掠れるようで、話がよく分らん、喋舌るのに骨が折れる。",
              "citation": {
                "source": "朱日記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「主人は頼むんだよ、自分もおまえの姉の思い出を捨てるから、おまえも自分というものを捨てゝ、すっかり姉の気持になり代って呉れ」　歿き人の思い出を捨てるのも骨が折れるだろうが、自分を捨てゝ姉の気持になり代ることは一層むずかしい骨折だとご新造は言います。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、何が骨が折れるといって、ルンペンから乞食に陥ちるこの一線を突破するくらい骨の折れることはない」　そう言って苦笑するだけでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし生は、これはまた何という骨が折れることだろう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、おまえの結婚というものはおまえがたいして望んでいないだけにこれはちょっと骨が折れる。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御承知でもありましょうが、いま独逸で私たちのような境遇の者の食って行く途は実に骨が折れるのです。",
              "citation": {
                "source": "褐色の求道",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「學校の先生が、生徒でない一人前の大人と話をする時には、リリパットから歸つて來たガリ※アのやうに、理解力の標準を換算するのに骨が折れる」と、ラムは言ふ。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中心は磨上らしいが、しかし鑑定には骨が折れるぞコイツは……」「ヘヘヘ、……そう仰言ればもう当ったようなもんで……」「黙ってろ……余計な文句を云うな。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっ黒な腕と足を露出したおかっぱのお嬢さんでない弾き手を連想するのは骨が折れるようである。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝉の声には慣らされるが、ラジオの※舌にはなかなか教育されるのに骨が折れる。",
              "citation": {
                "source": "軽井沢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来へまでついて来ないようにするのには、かなり骨が折れるくらいであった。",
              "citation": {
                "source": "黒猫",
                "author": "THE BLACK CAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓は骨が折れるからとばかり思って、とかく本気に百姓しようと思わなかったけれど、考えると兄のいうことがほんとうだ。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっとしていたんじゃ、だいいち体のためにもよくないから」「そんなつもりでやるにやっても、あんまり骨が折れるとばかばかしくてねィ。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "糟谷は次男芳輔三｜女礼の親子四人の家族であるが、その四人の生活が、いまの糟谷の働きでは、なかなかほねがおれるのであった。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、死体鑑別には少々ほねがおれるが、一部分でも発見されれば恐ろしいセンセイションをまき起こすので、警察は全力を尽くして捜査することになり、けっきょくは犯人が見つかってしまいます。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "海底には、コンブのような海草が、たくさんはえていますから、その中へ沈んだ金塊をさがすのは、ひどくほねがおれるのです。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
