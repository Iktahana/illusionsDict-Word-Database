        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（立ちながら休むときは、脊の担い梯子へ、息杖を当てがって、肩を緩めるので「一本立てる」というのである。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばタレースは始めて金字塔の高さを測るために、塔の影の終点の辺へ小さな棒を一本立てた。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "本箱の上に釘を二本立ててその間にわずかに三寸四角ぐらいの紙を張ったのがスクリーンである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と曖昧に塩入れ場の前に六尺の天秤棒や、丸太棒やを六七本立てかけてある方に顎をちょいと突き出して搾り場を通り抜けて行ってしまった。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが次の日のこと、畜産学の教師が又やって来て例の、水色の上着を着た、顔の赤い助手といつものするどい眼付して、じっと豚の頭から、耳から背中から尻尾まで、まるでまるで食い込むように眺めてから、尖った指を一本立てて、「毎日｜阿麻仁をやってあるかね。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三郎はいよいよおもしろそうに指を一本立てながら、「それから？",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "又三郎はいよいよ面白そうに指を一本立てながら「それから？",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼女の笑い――執念深い呪ひの女――深夜、髮を亂したあたまに蝋燭を三本立て、口に髮剃りを喰はへ、片手に藁人形、片手にかな槌を持つた丑滿參りを想像して、義雄はぞツとした。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにこの番組を見たＮＨＫのディレクターの話に乗って、ブラウン管のアーティスト、ナムジュン・パイクと祝田久の二本立てで、子供向けの番組も収録したとのこと。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "サーヴィスの内容は、三本立てを想定しました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "百物語とは多勢の人が集まって、蝋燭を百本立てて置いて、一人が一つずつ化物の話をして、一本ずつ蝋燭を消して行くのだそうだ。",
              "citation": {
                "source": "百物語",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あゝわかつた――」　成ほどそこに小さな筒が一本立てられてあつて、人が五六人黒くかたまつてゐるのがそれと見えた。",
              "citation": {
                "source": "浴室",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "四角な棒を四本立てて、その上を板で張ったものである。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれは、慶一や柾生と、スカラ座でビートルズの二本立てだ」　高志がヴェランダにもどりながらこたえた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "六六年の夏休みに、みんなで馬車道に、ビートルズの二本立てを見にいったの、憶えてる？",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪しい大道商人　以前東京では、縁日の出はずれ、浅草、神田、京橋｜辺の露店の切れ目、活動館の付近、人通りの多い近所の蔭暗い処に、蝋燭を一本立てて怪し気な絵を売買したものである。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "槍が一本立てかけてある。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめ白人看護婦を指して右の人さし指を一本たて、こんどは梨花を指して左の人さし指を一本立てた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジナイーダはいささかの心の乱れも見せず、すこぶる無造作にわたしを迎えたが、ただ指を一本立てて脅かす真似をして、どこか青あざはできなかったかと訊いた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本立てを一つ作らにやいかんな。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、本立てで思ひ出したけど、さつきの肥桶の話。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」本立てと肥桶の對照がおかしかつたので皆笑つた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "八畳の隅を一つの大きな本棚と一つの本立て、本箱とで区切った勉強部屋の卓子の前に坐って、小説をよみ、空想に耽って居るとき、ふと、コトコトと何処かで働き廻って居る彼の音をきくと寛大な、寂しい、何処かに不愉快な微笑が湧いた。",
              "citation": {
                "source": "一九二三年夏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くも揺らぎはじめた三本立てパソコン事業体制　ＩＢＭのＰＣが浜田を西のもとに走らせた直後、日本電気はおよそ二年で約一二万台を売り上げたＰＣ―８００１の上下に新しい二つのシリーズを加え、パーソナルコンピューターのファミリーを形成してラインナップの充実を目指す方針を明らかにした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＣ―８８０１互換の一六ビットのベーシックマシンとして仕立てたＰＣ―９８０１がどこまで市場に受け入れられるか、見極めのつかない段階で着手した後継機の仕様検討の作業を、浜田俊三は当初、二本立てで考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "同社のＰＣシリーズはこれにより、最上位のＸＴと中位のＰＣ、そして廉価版のＰＣジュニアによる三本立て体制となっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "神山は彼の方を見ずに、金格子で囲った本立てへ、大きな簿記帳を戻していた。",
              "citation": {
                "source": "お律と子等と",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "教科書が青銅のピイタア・パンの本立てで挾まれた背をこちらへ向けて机の上に並んでいる。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
