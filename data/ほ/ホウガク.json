[
  {
    "uuid": "82e14cc7-c475-5074-b781-46f1f85ffa9f",
    "entry": "方角",
    "reading": {
      "primary": "ほうがく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
