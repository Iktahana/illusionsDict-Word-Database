  {
    "uuid": "21b1409b-4ecb-5bbe-ab93-fcac2c38177c",
    "entry": "放学",
    "reading": {
      "primary": "ほうがく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "expulsion from school",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ここを以て講習は除夕を徹し、未だ嘗て放学せざるなり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "古藤はほほえんだらしい語気で、「そんな事はもうあなたのほうがくわしいはずじゃありませんか……心のいい活動家ですよ」「あなたは？",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野のほうがくで黒いけむりがたちのぼっています。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、学校がおわると、おなじほうがくへかえる子ども七人が、一かたまりになって歩いていました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、今度は、幕将たちのほうがくすくす笑った。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
