    },
    "definitions": [
      {
        "index": 1,
        "gloss": "true feelings",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれども、それは決して大隅君の本心からのものではなかった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつぱりあんな時に、つい本心といふものがあらはれるものらしいのね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、もう、あなたの本心といふものが、こんど、はつきりわかつたわ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とＮさんは、本心から同感を寄せて下さる。",
              "citation": {
                "source": "大恩は語らず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といふ言葉は、私の本心からのもので、それは、ちつとも變つてゐない。",
              "citation": {
                "source": "大恩は語らず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳の本心を見ぬいている。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "杜九如の方ではテッキリそれだと思ったから、贋物だったなぞというのは口実だと考えて、約束｜変改をしたいのが本心だと見た。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と書かれていて、訪問客は、みんな大笑いして、兄もにやにや笑っていましたが、それは、れいの兄のミステフィカシオンでは無く、本心からのものだったのでしょうけれど、いつも、みんなを、かつぐものだから、訪問客たちも、ただ笑って、兄のいのちを懸念しようとはしないのでした。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "恥ぢて死ね」　部屋に歸つてからしつかりと考へる積りでゐながら、急性な彼れの本心は瞬時も彼れに餘裕を與へて置かなかつた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前論者の、ビジテリアンは人間の感情を以て強て動物を律しようとするというのに対して、私は実に反対者たちは動物が人間と少しばかり形が違っているのに眼を欺かれてその本心から起って来る哀憐の感情をなくしているとご忠告申し上げたいのであります。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来私どもの感情はそう無茶苦茶に間違っているものではないのでありましてどうしても本心から起って来る心持は全く客観的に見てその通りなのであります。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "して見ると私はいよいよ本心に立ち帰らなければならない。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとあの離縁状は私の本心でないからつて、嬶が手紙をよこしたが、それはもう届を発送したあとだつたから、今頃は驚いてるでせう。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "之が俺の本心である、どこまでもやると覚悟をしてしまへば、手形の形式はどうでもいい。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが本心をつきとめて置いたからまあいいや。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして別れ別れになつてる事は、恐らく小夜子の本心ではないでせうよ。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は昂つた男の言出しを手ぐつて自分の本心を打明けようとも思つたが、それが果していいか悪いか一寸分らなくなつた。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は昂つた男の言出しを手ぐつて自分の本心を打明けようとも思つたが、それが果していいか惡いか一寸分らなくなつた。",
              "citation": {
                "source": "計畫",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊主を軽蔑する本心にも手段にも、いささかもかわりはない。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "また私は、眠りの中の夢に於いて、こがれる女人から、実は、というそのひとの本心を聞いた。",
              "citation": {
                "source": "フォスフォレッスセンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸福なる哉、なんて、筆者は、おそろしく神妙な事を弁じ立てましたけれども、筆者の本心は、必ずしも以上の陳述のとおりでもないのであります。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "井伏さんが本心から釣が好きということについては、私にもいささか疑念があるのだが、旅行に釣竿をかついで出掛けるということは、それは釣の名人というよりは、旅行の名人といった方が、適切なのではなかろうかと考えて居る。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さんは本心はええ人ぢや。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　夫人はこれも決定的な本心を含めた冗談で言った。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私は次兄の顏をよくないと本心から感じたことが一度もないのだ。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学へ、また行きたいというのは、君の本心ではありません。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの子の此の頃の様子を見たって、すぐにわかる事ですが、あの子の本心は決して、いまのあなたのお言葉どおりに曇りなく割り切れているようでないのです。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ほんしんでございますとも。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれどもこれはひでよし公の御ほんしんでござりましたかどうか。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
