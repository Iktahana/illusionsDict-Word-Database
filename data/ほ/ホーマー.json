        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ドストエフスキー、セルバンテス、ホーマー、ストリンドベルヒ、ゴットフリード・ケラー＊、こんな名前が好きな方の側に、ゾラやイブセンなどが好かない方の側に挙げられている。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして「ホーマーのおかげで詩は横道に迷い込んでしまった。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホーマー以前のオルフィズムこそ正しい詩の道だ」と言ったそうである。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際今の日本の文学者の前でホーマーとかミルトンとかいう名前を持ち出すのはだれでも気がひける事だろうと思う。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホーマーやダンテの多弁では到底描くことのできない真実を、つば元まできり込んで、西瓜を切るごとく、大木を倒すごとき意気込みをもって摘出し描写するのである。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "試験の時に、かつて先生の引用したホーマーの詩句の数節を暗唱していたのをそっくり答案に書いて、大いに得意になったこともあった。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋の詩の歴史は、ホーマーの叙事詩に始まっている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "古代希臘に於ける、この叙事詩と抒情詩との特殊の対立――それはホーマーとサッホオによって代表されている――は近世の文芸復興期に至っても、同じ精神の流れを汲んで伝承してきた。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "叙事詩はホーマーのイリアッドが代表し、抒情詩はサッホオの恋愛詩が代表している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこのホーマーとサッホオとの対立が、後に文芸復興期に移ってから、さらにダンテやミルトンの荘厳な神曲叙事詩と、一方にペトラルカやボッカチオ等の、民衆的な情痴抒情詩の対立になったことは、前に同じ章で述べた通りである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実にホーマーについて知られることは、彼がイリアッドを書いている時に、あの見すぼらしい放浪詩人が、実にトロイ戦争の勇士であり、アキレスであったと言う事である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが反対にもし、ホーマーが実の英雄であったならば、おそらく彼は、そうした詩など書こうともしなかったろう。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」請ふ見よ、羅馬死して羅馬の遺骨を幾千万載に伝へ、死して猶ほ死せざる詩祖ホーマーを。",
              "citation": {
                "source": "富嶽の詩神を思ふ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "茫々乎たる空際は歴史の醇の醇なるもの、ホーマーありし時、プレトーありし時、彼の北斗は今と同じき光芒を放てり。",
              "citation": {
                "source": "一夕観",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼処にホーマーあり、シヱークスピーアあり、彗星の天系を乱して行くはバイロン、ボルテーアの徒、流星の飛び且つ消ゆるは泛々たる文壇の小星、吁、悠々たる天地、限なく窮りなき天地、大なる歴史の一枚、是に対して暫らく茫然たり。",
              "citation": {
                "source": "一夕観",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホーマーの英語における最初の翻訳者として有名である。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホーマー物語とかライン河の伝説だとかは非常に少年を喜ばせました。",
              "citation": {
                "source": "首相の思出",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへばラシイヌの描いたイフジエニイとウリピイドの描いたイフゲニイ、ラシイヌの描いたアシイルとホーマーの描いたアキレスを比較して見れば、這般の事情ははつきりとわかるであらう。",
              "citation": {
                "source": "文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "――シツダル、歌つて呉れ、お前が歌へばロールツヒ先生の作歌であらうと、ホーマーの恋歌であらうと、何の見境へもなく、俺達一同は五月の朝風に撫でられる孔雀歯朶のやうにうつとりとしてしまふよ。",
              "citation": {
                "source": "山彦の街",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホーマーの詩「オヂツセー」の中には、ユリツシーズがアイラスに矢毒を要求することが書かれてあり、希臘神話の中にもパリスが毒箭を放つてアキリーズを射殺すことが述べてある。",
              "citation": {
                "source": "毒と迷信",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "この説の先駆者とも見るべきものはエジプト伝説の中にもまたホーマーの中にもあるのであるが、これによると事物（人間）は次第次第に改善されていくのである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホーマーはエジプトの医師を当代の最も熟達したものとして賞讃している。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホーマーがオディセイのカリュプソ（Kalypso）の島からコルフ（Korfu）への渡航を歌っているが、全くあの通りであった。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホーマーの詩の百千の句を知っていることのよろこびより、自身の世代の真の歌を、何かの形でうたいうる名のない一人の作家であることのよろこびは、何と謙遜でしかも激しいであろうか。",
              "citation": {
                "source": "作家と教養の諸相",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと昔に溯ってホーマーはどうです。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この枢密顧問官は、役人くさくない聰明な人がらで、ホーマーやシェクスピアを愛読していた。",
              "citation": {
                "source": "カール・マルクスとその夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界文学の最も古典のものとしていつも語られるギリシアの詩人ホーマーの「イリアード」のなかに、この描かれるものとしての第一の女性が現われている。",
              "citation": {
                "source": "女性の歴史",
                "author": "――文学にそって――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘレネは美しさにおいては、ヴィナスのようにも美しかったのであろうが、社会的な存在としてホーマーが彼女を描いているところをみれば、美しきヘレネは当時の支配者たちの、闘争における一人の「かけもの」のような立場におかれている。",
              "citation": {
                "source": "女性の歴史",
                "author": "――文学にそって――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう意味でコンムーナ員たちが素晴らしい作品だと決定した各国のいろんな作品の中に、ホーマーの「オデッセイ」が入っているのは非常に面白い。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
