    "definitions": [
      {
        "index": 1,
        "gloss": "holding (foul in basketball, soccer, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "バスケットボールの試合で、相手チームの選手がホールディングの反則を取られてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "サッカーのディフェンダーは、相手のフォワードにホールディングをしてイエローカードを受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "審判の笛が鳴り、ビデオ判定の結果、ホールディングがあったと判断された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "★『ハッカーズ』によれば、この誌名はジャニス・ジョップリンが一時期参加したビッグ・ブラザー＆ザ・ホールディング・カンパニーのもじりであるという。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにたどればビッグ・ブラザーはジョージ・オーウェルの『一九八四』から、ザ・ホールディング・カンパニーはマリファナを持っているという意味のスラングからきている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛇足とは知りながら一言付け加えれば、灰になっても忘れることのなさそうなジャニスの「サマータイム」は、ビッグ・ブラザー＆ザ・ホールディング・カンパニー時代の佳作である。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから彼女は、ホールディング・カンパニーとわかれてしまった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビッグ・ブラザー・アンド・ザ・ホールディング・カンパニーとしてスターになると、コンサートのたびに客からおなじ曲をリクエストされるし、また、いろんなことのために、おなじ曲をうたわなければいけないことになってしまう。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、かつて彼女が属していたホールディング・カンパニーのリード・ギタリスト、ポール・カントナーは、次のように言う。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "carrying (foul in volleyball)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "バレーボールで、セッターがボールを長く持ちすぎたためホールディングの反則を取られてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼のセットは少し長すぎたので、ホールディングと判定されて相手に得点が入った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ホールディングは、ボールを保持しすぎることで起こるバレーボールの基本的な反則の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "holding (pattern)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "悪天候のため、着陸機は管制官の指示に従い、上空でホールディングパターンに入った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "管制官は、滑走路が混雑しているため、着陸機にさらに20分ホールディングするように指示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "私たちは離陸許可を待つ間、空港周辺を旋回しながらホールディングしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
