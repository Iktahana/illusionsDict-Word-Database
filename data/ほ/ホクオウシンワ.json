        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "Yg'dra-sil（イグドラスィル）【固名】［北欧神話］その根は地獄に達しその枝は天国に達すという大木。",
              "citation": {
                "source": "熟語本位英和中辞典",
                "author": "Y",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度神話、希臘神話、北欧神話の基礎本源たる、思想の原形は、殆んど同一なるも、ホメロスの詩篇に見ゆる一個の神話と、『エダ』の神歌に見ゆる一個の神話とは、何人も之れを混同すること無かる可く、又この何れをも、『ブラーマーナー』中の一個の神話と混同すること無かる可し。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この北欧神話は、其起原を何処に求む可きや。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "北欧神話が、基督教より受けし影響の大なるは、最近の研究によりて、次第に明白となるに至れり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "北欧神話に於ても、洪水の原因はイミルの後裔の堕落して、神怒りてイミルを殺して、洪水を生ぜしなり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはある四人のオスカール（訳者注　北欧神話オシアン中の勇士）であった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
