        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "承元の法難には親鸞も連累した。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "金吾は日蓮龍の口法難のをりは、自分も腹を切らうとした無垢純粹の歸依者だ。",
              "citation": {
                "source": "尼たちへの消息",
                "author": "――よく生きよとの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "武宗時代の會昌の法難にも、摩尼教は第一番に受難して居る。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "淀殿と且元（桐一葉・孤城落月）・牧の方と義時（牧の方）・日蓮と嘉藤治（法難）などは、立派に対等の位置に据ゑられて居ます。",
              "citation": {
                "source": "芝居に出た名残星月夜",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それのみか、これが機縁となって、翌月二十八日夜に松葉ヶ谷草庵が焼打ちされるという法難となって報いられた。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　相つぐ法難　日蓮の闘志はひるまなかった。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが彼の第二の法難であった。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は法難によって殉教することを期する身の、しきりに故郷のことが思われて、清澄を追われて十三年ぶりに故郷の母をかえりみた。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにその翌月、十一月十一日には果してまたもや大法難にあって日蓮は危うく一命を失うところであった。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日蓮はこの法難によって、経に符合する意味で法華経の行者としての自信を得た。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がこの小松原の法難における吉隆と鏡忍との殉教を如何に尊び、感謝しているかは、彼の消息を見れば、輝くほどの霊文となって現われているのであるが、ここに引用する余裕がない。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この法難から文永五年蒙古来寇のころまで、三、四年間は日蓮の身辺は比較的静安であった。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、竜ノ口の法難のとき、四条金吾が頸の座で、師に事あらば、自らも腹切らんとしたことを、肝に銘じて、後年になって追憶して、「返す／＼も今に忘れぬ事は、頸切られんとせし時、殿は供して馬の口に付て、泣き悲しみ給ひしは、如何なる世にも忘れ難し。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "神サマの法難も自分の至らぬためという自責に苦しみ、碁をうつほかに何も知らない彼がトンチンカンな救出運動にキリキリ舞いをはじめたのである。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あれは法難でございました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "活き佛",
                "note": "青空文庫"
              }
            },
            {
              "text": "御仏に宏大無辺な神通力があるならば、放って置いてもこの法難は避けられるだろうし、若し又焼かれ砕かれるのも一つの約束事ならば、それは人間の力では救いようのない因果だ」「――――」「南都の七堂｜伽藍を焼き尽した平重衡の暴挙にも、大きい眼で見れば何んかの意味があるだろう。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "観音様の頬",
                "note": "青空文庫"
              }
            },
            {
              "text": "法難とは信仰の拙劣な自己弁解にすぎない。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「福田旅館は、ここでは、いいほうなんだろう？",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんて言いながら、危いのは、僕のほうなんだからなあ。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（あの弾丸で男のほうだけでも倒れてしまえば、女のほうなんかどうにだってなったのだから……）　彼のうちの復讐の炎は、失敗の口惜しさを加えて、かえって激しく燃え立った。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりア、そんなロンドンの中央東部郵便区なんて云う場所は、あなたの趣味には合わないでしょうけれど、しかしその商会はロンドンでも最も金持ちのほうなんです。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうことになると、これでおいらのおしゃべりあごもなかなかちょうほうなんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしがいいたいのは、そのときに考えたことのほうなんだから」　ほんとうは、おどろいて、ききかえすべきなのだろうが、慶一はふしぎに冷静な気持ちで令子の話を受けとめ、それがあのときのことと、どうつながるかのほうが気になった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺が一か、八かの抵当にしようというのは……ダイヤよりも土のほうなんだ。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかい、そりゃよかったな、ぼくのほうなんか、とても話にならない。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "小圓太のほうなんか振り向いてもくれなかった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの香世子にばかり夢中になって、ときたま食堂でなんかお逢いしても、あたしのほうなんか、見たことがなかったじゃ、ありませんか」「そうだったかね」「えゝ、そうだったのよ、あなたから眼を離したことがなかったから、あたし、よく知っている。",
              "citation": {
                "source": "雲の小径",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう見えても、わたしは信心のいいほうなんですが、いっこうに御利益がありません」　とど助も、弱った声で、「いかにも珍である。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "初春狸合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんは、これでも無口なほうなんです。",
              "citation": {
                "source": "キャラコさん",
                "author": "女の手",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が貰おうというのは、その六番目のほうなんですよ、今も申したようにまだ女學校へ通っている。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
