[
  {
    "uuid": "1cf3696a-26e4-5fd6-bb28-49a6ddded2c4",
    "entry": "翻訳",
    "reading": {
      "primary": "ほんやく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
