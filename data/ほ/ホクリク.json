    "definitions": [
      {
        "index": 1,
        "gloss": "Hokuriku region (of Honshu; incl. Niigata, Toyama, Ishikawa and Fukui prefectures)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "幼稚園は兼六公園の傍の北陸幼稚園であつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の調べたところでは、北陸道一帯にかけて昔も今も山くずれ地すべりの現象が特に著しい。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの恐ろしい函館の大火や近くは北陸地方の水害の記憶がまだなまなましいうちに、さらに九月二十一日の近畿地方大風水害が突発して、その損害は容易に評価のできないほど甚大なものであるように見える。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "安政元年十一月四日五日六日にわたる地震には東海、東山、北陸、山陽、山陰、南海、西海諸道ことごとく震動し、災害地帯はあるいは続きあるいは断えてはまた続いてこれらの諸道に分布し、至るところの沿岸には恐ろしい津波が押し寄せ、震水火による死者三千数百、家屋の損失数万をもって数えられた。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　神通は富山市の北端を流るる北陸七大川の随一なるものである。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、北陸線の通じなかつた時分、舊道は平家物語、太平記、太閤記に至るまで、名だたる荒地山、歸、虎杖坂、中河内、燧ヶ｜嶽。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "米原は北陸線の分岐道とて、喜多にはひとり思出が多い。",
              "citation": {
                "source": "大阪まで",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともすれば、誓を忘れて、狭き池の水をして北陸七道に漲らそうとする。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……これは、北陸道無双の霊山、白山、剣ヶ峰千蛇ヶ池の御公達より、当国、三国ヶ岳夜叉ヶ池の姫君へ、文づかいに参るものじゃ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい近頃、北陸の城下町から稼ぎに出て来た。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君、他日もし北陸に旅行して、ついでありて金沢を過りたまわん時、好事の方々心あらば、通りがかりの市人に就きて、化銀杏の旅店？",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "快く頷いて、北陸地方を行脚の節はいつでも杖を休める香取屋といふのがある、旧は一軒の旅店であつたが、一人女の評判なのがなくなつてからは看板を外した、けれども昔から懇意な者は断らず留て、老人夫婦が内端に世話をして呉れる、宜しくば其へ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてこれは小宮山良介という学生が、一夏北陸道を漫遊しました時、越中の国の小川という温泉から湯女の魂を託って、遥々東京まで持って参ったというお話。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　天皇はついで大毘古命を北陸道へ、その子の建沼河別命を東山道へ、そのほか強い人を方々へお遣しになって、ご命令に従わない、多くの悪者どもをご征伐になりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "大毘古命は天皇にそのしだいをすっかり申しあげて、改めて北陸道へ出発しました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛騨から東京へのぼるには、北陸線か、東海道線か、二つにひとつです。",
              "citation": {
                "source": "指輪一つ",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、ともかくも汽車に乗ったのですが、なにしろ関西方面から満員の客を乗せてくるのですから、その混雑は大変、とてもお話にもならない始末で、富山から北陸線を取らなかったことを今更悔んで追っ付かない。",
              "citation": {
                "source": "指輪一つ",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで知ったのですが、その出家は鎌倉でも五山の一つという名高い寺のお住持で、京登りをした帰り路に、山越えをして北陸道を下らるる途中であったのです。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "信長は、朝倉退治のため、元亀元年四月、北陸の雪溶くるを待って、徳川家康と共に敦賀表に進発した。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "正成｜夙に戦死し、続いて北畠｜顕家は和泉に、新田義貞は北陸に陣歿し、今や南朝は落漠として悲風吹き荒び、ひたすら、新人物の登場を待って居た。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本書紀に依れば、此の御代に四道将軍を派遣せられたとあるが、当時初めて東海、北陸、吉備、丹波地方への交通が開け、皇化がこの交通線に沿うて、辺鄙の地に及んだことが察せられる。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "後醍醐天皇は、その後も新田義貞に勅して、皇太子｜恒良親王、皇子｜尊良親王を奉ぜしめて、北陸経営に当らしめ、又｜陸奥の北畠｜顕家を西上せしめて、京都の恢復を計り給うたが、顕家は延元三年五月、摂津の石津で戦死し、新田義貞は、延元三年七月藤島の戦ひで戦死した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "五分間停車、北陸線乗換え、敦賀、直江津、新潟方面行の方は右の階段を登って、三番線の列車にお乗換え願います、乗換時間は十七分、十六時五十分発二三等急行東京行き！",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――白山は北陸道第一の高山にして、郡の東南隅に秀で、越前、美濃、飛騨に跨る。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "惟うに北陸の猩々は海狗を誤認したのだろう。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "五｜畿内、東海、東山、山陰、山陽、北陸、南海と、彼は漂泊の旅路に年を送り年を迎え、二十七の年まで空虚な遍歴の旅を続けた。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は犯人が、最近北陸線の列車で不慮の死をとげた安田であると仮定するのである。",
              "citation": {
                "source": "誰が何故彼を殺したか",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸へ引っ返すと、碓氷峠を越えて信濃を経て、北陸路に出て、金沢百万石の城下にも足を止めてみた。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "だん／＼樣子をきいて見ると、若狹の商人が北陸の海邊から山越しに京都まで運んで來る魚荷の中には、かならず笹の葉が入れてあつて、そのために魚の味の落ちないことが判つたといふ。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
