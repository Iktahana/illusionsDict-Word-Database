[
  {
    "uuid": "62dfc74b-e42d-547b-b194-25792948088b",
    "entry": "方寸",
    "reading": {
      "primary": "ほうすん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
