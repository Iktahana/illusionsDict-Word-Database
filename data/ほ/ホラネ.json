        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ほらね、足も膝皿を挫いて一週間も揉んでもらって、やっと歩けるようになったですよ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほらね、かあさん、この肩んところに花があるでしょう。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほらね、このとおりだ。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほらね、あの方は脚に赤いきれを結えつけておいでだろう。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            },
            {
              "text": "においぞ　　いずるいざや　　いざやみに　　　ゆかん少女「いいえ兄さん、よく聞いて御覧なさい……ほらね」少年「ああ、ほんとだ、誰だろう」少女「ね、兄さんもっと何か言って御覧なさい」さくら　　　さくらやよいの　　そらは少年歌いながら首を傾、舞台裏でも歌を真似る。",
              "citation": {
                "source": "春",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほらね、だからあらそわれない！",
              "citation": {
                "source": "高台寺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほらね、見えるでしょう？",
              "citation": {
                "source": "一条の繩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうかもしれない、　あ、ほらね此処が此那に折れてるでしょう。",
              "citation": {
                "source": "盗難",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だちょうの大食は少年にまさること数等である、かれのために少年たちは、毎日その食料たる木の根や、生草を、雪深くほらねばならなかった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほらね、お母ちゃん。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほらねとぱちッと音をさせて座敷を真暗にした上、またぱっと元通りに明るくするかと思うと、大きな声でばあと云った。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほらね、かういふ形のと、又別にかういふのがあるだらう」　と、房一は机の上に虫の卵の形を書いてみせた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほらね、知らぬ顔の半兵衛の白河半平、アッハッハ」　ひとりで、喜んで、笑っている。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　女狐はニッコリ笑って、「ほらね、あれは、あたしの眷属……」　頭に掛けていた手拭をとると急に真面目な言い方になって、「これをお敷きなさいまし。",
              "citation": {
                "source": "生霊",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ならんでお坐り、ほらね、こう。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "街の灯櫻間中庸見てたよ窓からじつと遠い街の灯ほらねお星樣の下の空ぼーつと明かつたよそしてねお星樣うすかつた死んでるのあつたよ知つてるあの遠い街にいゝこと　うんとあるんだ",
              "citation": {
                "source": "街の灯",
                "author": "櫻間中庸",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほらね、あそこに白い帆が見えるだらう。",
              "citation": {
                "source": "影絵師",
                "author": "櫻間中庸",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（両手を腰にあてて、コートを歩きまわる）ほらね、――ピヨピヨ雛っ子よ。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほらね、顫えがついてるわ。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほらね、ずいぶん古いロトーでしょう。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほらね、わたしもう泣いていないわ。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルピック夫人――ほらね、そういってあるだろう、子供はなんか頬ばったまま、ものを言うんじゃないって……。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほらね、やつぱり私の言つた通りでしよ？",
              "citation": {
                "source": "死児変相",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴はいかにもうれしくてたまらないという風に笑いだしながら、「……ほらね、知らなかったんでしょう。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あたしたちは、お互いの勇気を、もっと信用し合わなくてはいけないな」「だから、いい教訓だといったわ」「ほらね、ちゃんと知ってるじゃないか。",
              "citation": {
                "source": "キャラコさん",
                "author": "雪の山小屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほらね、早いでしょう」　泥だらけの四人の鉱夫は、ちょっと足をとめると、なんだ、というような顔つきで、いっせいにキャラコさんの顔を見すえた。",
              "citation": {
                "source": "キャラコさん",
                "author": "女の手",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほらね、ここからが田舎よ。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほらほらね、お母さま」とアーサが口を出した。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほらね」と親方がさけんだ。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
