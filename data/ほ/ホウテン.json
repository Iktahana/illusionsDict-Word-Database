[
  {
    "uuid": "d870cbd5-bbc1-526e-9617-3a7515822fca",
    "entry": "法典",
    "reading": {
      "primary": "ほうてん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
