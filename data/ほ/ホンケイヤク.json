        "examples": {
          "standard": [
            {
              "text": "祖父は今年で『ほんけがえり』を迎え、盛大な還暦祝いのパーティーを開いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "人生の折り返し地点とも言える『ほんけがえり』を機に、これまでの人生を振り返ってみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔は『ほんけがえり』のお祝いに、赤いちゃんちゃんこを着る習慣があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし「犠牲の血をささぐる者は罪を贖われる」というモーセ律の根本契約を、この場合連想から除外しなければならぬ理由は一つもない。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            }
          ]
        }
