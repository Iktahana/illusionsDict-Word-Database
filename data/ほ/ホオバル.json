[
  {
    "uuid": "5e48d264-54d1-526c-b882-aea5c16dd910",
    "entry": "頬張る",
    "reading": {
      "primary": "ほおばる",
      "alternatives": [
        "ほうばる"
      ],
      "is_heteronym": false
    },
    "grammar": {
