    "definitions": [
      {
        "index": 1,
        "gloss": "(a) Buddha",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
