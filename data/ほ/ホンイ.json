      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "changing one's mind",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "実はドレゴが急にこんな翻意をするようになったわけは、その前夜、アイスランドから一通の無線電信を受領したことに拠る。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "形ばかりではなく、強く慰留されたが、翻意する気にはなれなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ心境の変化、電撃的翻意くらいで、そう易々と片付けられるものではあるまい。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の翻意の原因は、風にある」「へえ。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだ、きっと英官辺からの圧迫があったのだろう――と、折竹翻意の理由をこう睨みたい気持が、誰の胸にも疼いていたのであるが……。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしても翻意させることができないと見てとると、今度は、博士は、真剣になって、地下旅行のいろいろな注意を与えはじめた。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、社長は極力その翻意を求め、もう一年踏み止まつて、危機にある会社の建て直しに協力してくれと懇願した。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし右二カ国を御承諾下さらず、あくまでも日本滞在を固執なさるならば、大使館当局としては、已むを得ず旅券の返上をお願いするという意味のことを今日まで御相談していたが、太子は頑として翻意なさらなかった。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "久良馬の翻意が動かないのと、久良馬が処罰でなく切腹だと聞いたからである。",
              "citation": {
                "source": "初夜",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "津田は、鉱毒事件の解決するまでは是非とも留っていてもらわねばならぬといって、しきりに翻意を促した。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "正造が議員を辞退したことを知ると、周囲の者はいっせいに翻意することを迫った。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そいじゃ、案内しましょう」　事務的に言って、朝倉は俺の翻意を別に喜ぶでもなかった。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう辞めるのかよ」　という島崎の反応はすぐに慰留の説得に変わり、昼食のあいだずっと、島崎は北原を慰留し、退職の意志を翻意するよう、説得した。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "専門的な知識や実際についての知識を必要とする場合は別であるが、ただ判断さえ用いればよい事柄に関しては、他人の理由はわたしを支持するには役立つけれども、わたしを翻意させることはほとんどない。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみのお父さんを説得して翻意させよう。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いにも、まだご世子、きっと、われわれもそれとなく、ご翻意をおすすめいたしまするが、殿よりも、何とぞ……）　いいかけると頼房は、こは意外なといわぬばかりな面持で、（ああ、これ、何をいう。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "合戦には強かろうが、世事には」「殿」「なんじゃ」「御翻意ねがわしゅう存じます。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の助けか、一路ご帰国と、俄に、ご翻意くださいましたので」「はははは。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
