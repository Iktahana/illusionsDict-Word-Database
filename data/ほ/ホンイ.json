  {
    "uuid": "3d8bf178-2e91-52a3-b72d-5e191498cd3b",
    "entry": "翻意",
    "reading": {
      "primary": "ほんい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
