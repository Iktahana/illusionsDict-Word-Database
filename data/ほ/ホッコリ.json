    "definitions": [
      {
        "index": 1,
        "gloss": "warm and fluffy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
