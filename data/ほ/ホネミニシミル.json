        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そんな時だから、どんな映画でも、骨身にしみる。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木々を吹きわたる夕風の音ばかり――逢魔が刻のしずけさは深夜よりも骨身にしみる。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "積もる苦労、重なる失望、ひしひしと骨身にしみる寂しさ……私の躯はだんだん衰弱してまいりました。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "郷里へ帰れば、知れる限りの人の指が、わたしの身体へ蜂の巣のように突き刺されて、そのあざ笑いの痛さ、冷たさが、想像してさえ骨身にしみるようです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "みちりやの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、ひとしお骨身にしみるようにね。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし見わたすかぎりの泥海を越えて攻めよせる法はなかった、たとえその法があったとしても、城兵のたたかいぶりを骨身にしみるほど味わったよせてには、おそらく突撃するだけの戦気はなかったに違いない。",
              "citation": {
                "source": "日本婦道記",
                "author": "笄堀",
                "note": "青空文庫"
              }
            },
            {
              "text": "山上の寒さは骨身にしみる。",
              "citation": {
                "source": "私本太平記",
                "author": "湊川帖",
                "note": "青空文庫"
              }
            }
          ]
        }
