        "接頭辞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "homo-",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "子兎のホモイは、悦んでぴんぴん踊りながら申しました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホモイはもううれしくて、息もつかずにぴょんぴょん草の上をかけ出しました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからホモイはちょっと立ちどまって、腕を組んでほくほくしながら、　「まるで僕は川の波の上で芸当をしているようだぞ」と言いました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当にホモイは、いつか小さな流れの岸まで来ておりました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホモイはちょっと頭を曲げて、　「この川を向こうへ跳び越えてやろうかな。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホモイは急いで岸にかけよって、じっと待ちかまえました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホモイはいきなり水の中に飛び込んで、前あしでしっかりそれをつかまえました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそのひばりの子供は、いよいよびっくりして、黄色なくちばしを大きくあけて、まるでホモイのお耳もつんぼになるくらい鳴くのです。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホモイはあわてて一生けん命、あとあしで水をけりました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、　「大丈夫さ、　大丈夫さ」と言いながら、その子の顔を見ますと、ホモイはぎょっとしてあぶなく手をはなしそうになりました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホモイは二度ほど波をかぶったので、水をよほどのみました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホモイはいきなりその枝に、青い皮の見えるくらい深くかみつきました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホモイも疲れでよろよろしましたが、無理にこらえて、楊の白い花をむしって来て、ひばりの子にかぶせてやりました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホモイはそれを見るとぞっとして、いきなり跳び退きました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホモイは立ちどまって、ふりかえって見ると、それは母親のひばりでした。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホモイはもう大丈夫と思ったので、いちもくさんにおとうさんのお家へ走って帰りました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎のお母さんは、ちょうど、お家で白い草の束をそろえておりましたが、ホモイを見てびっくりしました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おっかさん、僕ね、もじゃもじゃの鳥の子のおぼれるのを助けたんです」とホモイが言いました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎のお母さんは箱から万能散を一服出してホモイに渡して、　「もじゃもじゃの鳥の子って、ひばりかい」と尋ねました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホモイは薬を受けとって、　「たぶんひばりでしょう。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　ホモイが、おとうさんやおっかさんや、兎のお医者さんのおかげで、すっかりよくなったのは、鈴蘭にみんな青い実ができたころでした。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホモイは、ある雲のない静かな晩、はじめてうちからちょっと出てみました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホモイはうっとりそれを見とれました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたさまは私ども親子の大恩人でございます」　ホモイは、その赤いものの光で、よくその顔を見て言いました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは私どもの王からの贈物でございます」と言ながら、ひばりはさっきの赤い光るものをホモイの前に出して、薄いうすいけむりのようなはんけちを解きました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかお納めをねがいます」　ホモイは笑って言いました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホモイは玉を取りあげて見ました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホモイはそっと玉をささげて、おうちへはいりました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前はよく気をつけて光をなくさないようにするんだぞ」　ホモイが申しました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくいじわるなんかしないように気をつけないといけないぞ」　ホモイはつかれてねむくなりました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
