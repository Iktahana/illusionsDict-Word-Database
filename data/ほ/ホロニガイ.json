    "definitions": [
      {
        "index": 1,
        "gloss": "slightly bitter (taste)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "新鮮な色彩が眼に、芳醇な香が鼻に、ほろ苦い味が舌に孰れも魅力を恣にする。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮坂があのほろ苦い理智の匂う独逸の作家の名を挙げて「僕のはトーマス・マンのに一番似ているね」そういうときは如何にも嬉しそうだった。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほろ苦いものが暫くの間心の隅に殘つてゐる。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほろ苦いものがしばらくの間心の隅に残っている。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「妾の春雄が、ほんとうに……妾を心配すると……云ったでしょうか……」　私もほろ苦い気持になった。",
              "citation": {
                "source": "光の中に",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月のはじめに出る青い蕗のあまり太くない、土から摘立てのを歯にあてると、いいようのない爽やかな薫りと、ほろ苦い味を与える。",
              "citation": {
                "source": "樋口一葉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "文芸評に渡るようにはなるが、作物を通して見た一葉女史にも、ほろ苦い涙の味がある。",
              "citation": {
                "source": "樋口一葉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "うれしさに、背すじをゾクゾクさせて、戻って来て、「なアにね、おほめに預かれるほどのものじゃアありゃせんが、あッしも酒のみゆえ、酔いざめに、ほろ苦い茶がうめえものだから、だんだん今の年で茶好きになりやしたのさ」「結構だ、話せらあ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、彼の持味の、鋭さを含んだノンシャランスと、人をくつたシニスムとが、それぞれの人物に、複雑で、痛快で、ほろ苦い味をつけ、時には、不気味な悪の臭気や、執拗な欲望の焔の如きものを撒き散らすのである。",
              "citation": {
                "source": "ルイ・ジュウヴェの魅力",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「カヤもいる」「お前、もたないのか」「お前も、もたないだろう」　亮作の胸にほろ苦いものがこみあげる。",
              "citation": {
                "source": "水鳥亭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、強ひてそれを追及しようともせず、「それぢや、秋葉の」　自分の手柄に陶醉する小平に挨拶して、ほろ苦い心持で自分の家へ引揚げる平次でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "頬の疵",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝利の後のほろ苦い悲哀といつたやうなもの、――名匠が不本意な仕事を俗衆にヤンヤと言はれる時のやうな、――言ひやうもない腹立たしさと交つて、若く美しい娘の死を悼む氣持が、異樣に胸を騷がせるのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "和蘭カルタ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、妙にほろ苦い安倍川でございましたよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金の鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "涼みの相談などは、一向気が乗らなかったので、平次は何べんか帰ろうとしましたが、隠居の喜平は折入って智恵を借りたいことがあるから、皆んなの帰った後まで残るように――と再三頼み込むので逃げも隠れもならず、ほろ苦い杯を嘗めております。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二服の薬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「氣の毒なのはお福さ、心柄とは言ひ乍ら、あれぢや江戸中に貰ひ手もあるまい」「あつしは親分」　八五郎はニヤリニヤリとほろ苦い笑ひを見せます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "ガラツ八祝言",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前は力があるさうだな」「――」　ほろ苦い得意の色が、少年らしい顏を輝かせます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死の祕薬",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝利の後のほろ苦い悲哀といったようなもの、――名匠が不本意な仕事を俗衆にヤンヤと言われる時のような、――言いようもない腹立たしさと交って、若く美しい娘の死を悼む気持が、異様に胸を騒がせるのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "和蘭カルタ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「気の毒なのはお福さ、心柄とは言いながら、あれじゃ江戸中に貰い手もあるまい」「あっしは親分」　八五郎はニヤリニヤリとほろ苦い笑いを見せます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "ガラッ八祝言",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい気持になり、らくになり、その楽さは、日なたとともに、のんだ薬を工合よく体じゅうにしみわたらせ、苦みも、ほろ苦い暖かさとなります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "するといつか、妻がおふくろに思はれて來たりして、そゞろ、ほろ苦い淋しみと、また、新たなる妻へのいとしみを覺えることがある。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがこのリンゴは、あとで辛く酸っぱい刺激風味がするので、ほろ苦いという烙印を押されていた。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう、トリガーセン島のリンゴは今のところすべてほろ苦い。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "一口口に銜むと、ほろ苦い顔をして吐き出してしまった。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "平中も亦、国経ほどではなかったにしても、やゝそれに似た、或る後味のほろ苦いものを嘗めさせられたのであった。",
              "citation": {
                "source": "少将滋幹の母",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭が重く、口中がほろ苦い。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒もそうなるとほろ苦いし、唇だけがやたらに乾き、水を飲めば家が思い出されて来る。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠利は、ほろ苦い顔をした。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとなく、ほろ苦いのだ。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "加藤へ行ったのか」　筑阿弥は、なおさらほろ苦い顔をしたが、日吉の寺入りには、反対しなかった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "パリの町はすすけてきたなく土地の人間にはいったいになんとなく陰気でほろにがい気分がただよっているように感ぜられたのであった。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
