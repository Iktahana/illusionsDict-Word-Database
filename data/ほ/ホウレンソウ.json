    "definitions": [
      {
        "index": 1,
        "gloss": "spinach (Spinacia oleracea)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
