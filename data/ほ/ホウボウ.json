  {
    "uuid": "4cb13e14-223d-53d5-babb-7f4c6195ff1e",
    "entry": "謗法",
    "reading": {
      "primary": "ほうぼう",
      "alternatives": [
        "ぼうほう"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "slandering Buddhism",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "説法さえ廃して貰われれば、僕も謗法はしない。",
              "citation": {
                "source": "独身",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "佛教者に言はせると、佛法を謗つて書いたやうに申しまして、非常に憤慨して居るのでありますが、實は何も謗法の爲に書いたのではない。",
              "citation": {
