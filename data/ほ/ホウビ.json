[
  {
    "uuid": "d8cdf43e-e2cf-58d5-bad2-4427b171e221",
    "entry": "褒美",
    "reading": {
      "primary": "ほうび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "reward",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのため一歩踏み出したばかりで、御褒美の水引きを先へ頂戴してしまった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれはこの動物にとっては全く飼主の曲馬師から褒美の鮮魚一尾を貰うための労役に過ぎないであろうが、娯楽のために入場券を買ってはいった観客の眼には立派な一つの球技として観賞されるであろう。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隊長は犯人を検挙するために、褒美を十円やることを云い渡してあった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「勝つたら、御褒美に銀二｜枚。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はあの娘の事に就いて少々相尋ねたいために今日、良助に同道致させた次第じゃが……万一、その方の申立てによってあの胴切りの下手人が相わかれば、褒美を取らするぞ」「ヘエヘエ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "又良い児が悪くなっていたら、御褒美をやらない事にしよう」「うん、それがいい。",
              "citation": {
                "source": "犬のいたずら",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもかなり残忍な方法で……たとえば私はいろんな事の褒美や何かでおやじから金時計を四ツとプラチナの時計を二個貰っていたが、実物はまだ一度も手にしなかった。",
              "citation": {
                "source": "ざんげの塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その肉は御褒美に犬におやり」　女中は涙を流して喜びました。",
              "citation": {
                "source": "どろぼう猫",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そうだもう一ついうことを忘れていたが、死ぬ番にあたった奴は、その褒美としてともちゃんを奥さんにすることができるんだ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひそかにこの向上発展を人生行路の勇ましき実行者に褒美として与えるのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも体験的のもので、どんな形で褒美が与えられるか、人々によって違うのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もかも因果応報ずくめのこの芝居の中で、ハムレットだけには、骨折りばかりあって褒美の方が足りないようです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、さすがは作者の沙翁、実は褒美は幕の外からハムレットに与えるようになっています。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯父さんが、また褒美をやるわ。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――小児らの中に出づ）まあ、いいお児ね、媛神様のお庭の掃除をして、どんなにお喜びだか知れません――姉さん……（寂く微笑む）あの、小母さんがね、ほんの心ばかりの御褒美をあげましょう。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それではお礼としないで、あの、こうしましょうか、御褒美。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嬢様が御褒美をお賭けなすったのを、旦那様がお聞遊ばすと、もっての外だ、間違いに怪我でもさせたらどうする、外の内の者とは違うぞ、早く留めろと有仰るの。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして御約束の御褒美は。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を御褒美に上げようかしら、ああ良い品があったっけ、姉様とさあ一所に光来。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "名物と聞く切干大根の甘いにほひをなつかしんで、手製ののり卷、然も稚氣愛すべきことは、あの渦卷を頬張つたところは、飮友達は笑はば笑へ、なくなつた親どもには褒美に預からうといふ、しをらしさのおかげかして、鴻の臺を向うに見る、土手へ上ると、鳴く、鳴く、鳴くぞ、そこに、よしきり。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御褒美に遣わさるる石臼なれば可けれども＝＝この坊主を輪切りにして、スッポン煮を賞翫あれ、姫、お昼寝の御目覚ましに＝＝と記してあろうも計られぬ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方、私に御褒美を下さいまし。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨がふったら御褒美をやるぞ」「僕はいりませんから、雨降り坊主にやって下さい」　太郎はすぐに半紙を一枚持って来て、平仮名でこんなことを書きました。",
              "citation": {
                "source": "雨ふり坊主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして太郎さんの頭を撫でて、「えらいえらい、御褒美をやるぞ」　とお賞めになりました。",
              "citation": {
                "source": "雨ふり坊主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その御褒美で、アアは王様の国を半分と一番目のお姫様を、サアはまた残りの半分と二番目のお姫様を貰って、二人共王様になり、お父様とお母様を半月宛両方へ呼んで、大威張りをしているところまで見えました。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに一両の褒美をとらせる。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」としんみり言って、一両の褒美をつかわし、ひらりと馬に乗り、戞々と立ち去ったが、人足たちは後を見送り、馬鹿な人だと言った。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時はじめて氏郷は莞爾と笑って、好い奴だ、汝は此の乃公に能う勝ったぞ、と褒美して、其の翌日知行米加増を出したという。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごほうびをあげるから。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとでごほうびはやるからな。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
