    "definitions": [
      {
        "index": 1,
        "gloss": "top-quality dried bonito",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
