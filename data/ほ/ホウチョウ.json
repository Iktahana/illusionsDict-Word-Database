        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それがある時台所で出入りの魚屋と世間話をしながら、刺身包丁を取り上げて魚屋の盤台の鰹の片身から幅二分くらい長さ一尺近い細長い肉片を巧みにそぎ取った。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "将校は老人の手や顔に包丁で切ったような小さい傷をつけるのがいやになった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの時も俺出刃包丁がいきなり胸にさゝるべと思つて床の中で震へてゐたさ」　Ｉはおんつぁんの不思議な一面を知つたやうな顔をして聞いてゐたが、「けれどおんつぁんは親切だなあ」　と言葉を入れた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この包丁｜塩梅甚だ心許ない。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを近所の料理屋の寿美屋の料理番が七十五銭で買い取って、あくる朝すぐに包丁を入れると、その鯔の腹のなかから手紙の状袋が出た。",
              "citation": {
                "source": "有喜世新聞の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎は台所から包丁を持って来た。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たわけ者ッ、菜っ葉包丁みたいなものを、おもちゃにすんねえ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜っ切り包丁抜いてくるかッ」「ほざいたなッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、二十三、四のうらわけえ気違いがね、殺された子どものそばに、にやにや笑いながら血のついた出刃包丁をさか手に握って、しょんぼりと張り番をしているっていうんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな出刃包丁なんぞ振りまわしながらおもちを食べてはあぶないよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "血のついた出刃包丁を振りまわしていた以上は、おそらくその凶器で狂人が突き刺したのだろうと思われるのに、傷が二色あるのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐさりと胸もとをえぐっている三少年の三つの傷は、たしかに出刃包丁の突き傷に相違ないが、いま一カ所子どもたちの首筋に、そろいもそろって何か細ひものようなものででも強く絞めつけたらしい、赤く血のしんだみみず色の斑痕があるのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、犬の顔にも裏表があるかもしれねえがね、よしんばお駒が免許皆伝の剣術使いであったにしても、包丁はドス、そのドスが血によごれて、死骸のそばにころがっておったと、万兵衛のだんなが詳しくご披露なすったんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "やまがら美人影絵",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さんの包丁は、また格別だな、いつもお上のお残り頂戴で、本当に味わったのは今日が初めてだが、お前さんが自慢するだけあらあ！",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は源太夫の家に中間として長い間仕えていたために、見様見真似に包丁の使い方を覚えたのに過ぎないのである。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「道理で、包丁の味が違ってらあ！",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、彼が丸亀を退散して、京の四条の茶屋の板前を勤めていたとき、血気の朋輩と喧嘩をして、お手の物の包丁で斬りつけられた傷である。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "おきん　（大根を大切そうに包丁で、切りながら）おぬしには、この朔日にも一本貸してやったな。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "出刃包丁を持って、母屋と牛小屋の間から奥底へ行くと、炬火の薪と手頃の竹竿を持って出てくる。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "齢は今年五十二とやら、以前十里許り離れた某町に住つてゐたが、鉈、鎌、鉞などの荒道具が得意な代り、此人の鍛つた包丁は刃が脆いといふ評判、結局は其土地を喰詰めて、五年前にこの村に移つた。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "齡は今年五十二とやら、以前十里許り離れた某町に住つてゐたが、鉈、鎌、鉞などの荒道具が得意な代り、此人の鍛つた包丁は刄が脆いといふ評判、結局は其土地を喰詰めて、五年前にこの村に移つた。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子が、爼代りの板の上で、ブリキの破片の包丁で、草や木の葉を切り刻んでまま事遊びをしてゐる。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いそがしく物を煮て出さなければ成らないかうした湯宿なぞで、種々な好みも違へば、年齡も違ふ男女の客を相手に、誰をも滿足させるやうな包丁の使ひ分けや、鹽加減といふものはあり得ないかも知れないのだ。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は包丁を選ぶが、たいていは刀――つまり日本刀を用いるであろう。",
              "citation": {
                "source": "死生に関するいくつかの断想",
                "author": "BITS OF LIFE AND DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "二丁目は私の生れたところ、角の菊屋は有名だったが今は銀行の敷地となっている、堺包丁店は十年位の店であろう。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると夕方になって、野郎が台所へ水飲みに来たから、皆変だとは思ったが、その時鮪包丁が一本見えなくなった事は誰も気がつかなかったんだ。",
              "citation": {
                "source": "ある遊郭での出来事",
                "author": "公娼存廃論者への参考資料としての実例",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人は鍋も、包丁も敷蒲団も置いて行ってしまった。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつが出刃包丁を啣えた女の生首の刺青の上に、俺達の太股ぐらいある真黒な腕を組んで、俺の寝台にドッカリと腰を卸して出ッ歯をグッと剥き出したもんだ。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶の間と座敷――三人の寝て居た部屋――の境の襖は包丁で滅茶滅茶に切りきざまれていた。",
              "citation": {
                "source": "琥珀のパイプ",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、いま女中が大きなほうちょうで、このさかなのおなかを切ったところだったのです。",
              "citation": {
                "source": "すずの兵隊さん",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
