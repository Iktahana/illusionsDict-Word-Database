    },
    "definitions": [
      {
        "index": 1,
        "gloss": "remuneration",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自分の手で作るか、自分の労力の正当な報酬として得たもののあまりに少ないのに驚いた。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は、好きな道を役立てて歌舞伎の小道具方の相談相手になり、デパートの飾人形の衣裳を考証してやったり、それ等から得る多少の報酬で学費を補っていた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "序に報酬の歩合をきめた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その犠牲の報酬として年金千二百円ほどと一時金八千円くらいとを貰う事になったと伝えられる。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつ達のネタを一週間以内にもってくれば手附の十倍の報酬を進呈するわ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ところで日本へ帰って来ると、仕事をせよと奨励されずに、会合に出て宴会に出席して、雑誌を発刊して、演説をして、無報酬の講義をして、原稿を訂正して、仕事を妨げることに想像される有りとあらゆることをして、その時間を浪費せよと頼まれる。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽柴筑前守なぞも戦をして手柄を立てる、その勲功の報酬の一部として茶器を頂戴している。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも少しも報酬をあてにしていない奉仕でしょう。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六千円位の報酬では足りないと思っている位だ。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "げに見るに忍びざりき、されど彼女自ら招く報酬なるをいかにせん、わがこの言葉は二郎のよろこぶところにあらず。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二郎、君は報酬と言うや、何の報酬ぞ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ、人の愛を盗みし報酬なり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しからば愛を盗まれし者の報酬は何ぞと言いつつ飲み干せり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然こなたに向きて、しからば問いまいらせん、愛の盗人もし何の苦悩をも自ら覚えで浮世を歌い暮らさばいかに、これも何かの報酬あるべきか。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし君が言わるるごとくば世には報酬なくして人の愛を盗みおおせし男女はなはだ多しと、十蔵はいきまきぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらず、あらず、彼女は犬にかまれて亡せぬ、恐ろしき報酬を得たりと答えて十蔵は哄然と笑うその笑声は街多き陸のものにあらず。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれはわが杯を受けて心地よげに飲み干し、大空を仰ぎて、愛盗まれし者の受くべき報酬はげに幸いなりき、十蔵なんじもその一人ならずやと杯を十蔵が前に置きぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんじはまことに幸いなる報酬を得たりと思うや二郎、とわれは二郎の顔を仰ぎて問いぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二郎は目を細くして月を仰ぎつ、うれしき報酬とは思わず、されどかの少女をふびんなりと想えば限りなき哀れを覚え、われに負きし挙動など忘れはて、ただ懐かしさに堪えず、げにふびんなるはかの少女なり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供だなあ」　月末にはまだ三日もある今夜｜報酬をくれるというのもそれで読めた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで俺の方からいうと、報酬を貰った以上、今月はもう来ないというのは予定の行動だ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "牢獄も如何する事も出來ない孤獨と、其孤獨の報酬たるべき自由とが、暗く、冷たい、厚い牢獄の壁を劈いて勝手に流れ漂ふのを想像するのは、彼れの一番快い夢だつた。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は二人の童女の項に軽く手を置き添えて、口の中で小さな祝祷を捧げてやった報酬に、まず二人から寝前の接吻を受け取った。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまわの際に少年は、刻下無意識になった恋人に対して、為に生命を致すその報酬を求めたのではない。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その様を黙視するに忍びず、一身を賭して博士の生死を探らんその報酬として運よく探りあてたる方へは、嬢の一身を托せらるべしと嬢に申込みたる二人の青年紳士あり。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "労働の値は供給によつて定まるものだと云へば、その不十分の（生命を維ぐに）報酬に甘んじて居た被告は、甘んじて居たこと自体が間達つて居るのである。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "此間に松村は借方即ち工事経営者を呼び寄せて担保や報酬の交渉をした。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は此金を受けいれて、私に約束の報酬さへくれれば、その報酬で、私がなにをしようとも、一切自由なんだ、訴訟の解決に使はうが地所を買はうが、相場をしようが、私は貴方からかれこれ云はれる気遣はない積りなんですから……理窟を云へばまあかうだがね。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
