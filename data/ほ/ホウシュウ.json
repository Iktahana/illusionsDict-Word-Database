[
  {
    "uuid": "8defb604-b30b-5ea7-ae29-111e3e7458a0",
    "entry": "報酬",
    "reading": {
      "primary": "ほうしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
