        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "アップル※が発表され、数多くのホラ吹きどもが講演者となってパーソナルコンピューターの未来にかける夢を思うままに語り、十代も半ばの小僧が紙テープに記録したソフトウエアを売り、山と詰まれた広告ビラがバタバタとはけていく先駆者達の祭りで、古川は完全に熱に浮かされた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも南フランスの農民出らしい頑丈な、陽気な、そして幾らかホラ吹きな父ベルナールと、生粋のパリッ子で実際的な活動家で情がふかいと同時に小言も多い若い母との間に、三人の子があったが、その総領として「よく太った、下膨れの顔の、冬になると手足にいっぱい霜やけの出来る」オノレが生れたのである。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「君も、やつぱり、ひとり隅つこでの自分勝手なホラ吹きらしいな。",
              "citation": {
                "source": "二人の男",
                "author": "島田清次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は内々大喜び、よくぞお気がつかれた、というところであるが、それでは大人物らしくないものだから、イヤ、人間は、図太いということゝ、善良さとは無関係なものですよ、変に小心ヨクヨクたる奴が内々はフテクサレのミミッチイ嘘つきのホラ吹きなどゝは、よくある奴ですよ、などゝ言う。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏川君がせっかく帰る気持になってくれたそうだのに、バカ大竜の大阿呆の大トンマのホラ吹き野郎が悪いのだ。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホラ吹きの Cudra 女性をいじめて下さい。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "加納もホラ吹きで、「月五千円かせぎます」なんて言ふんでいかん。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜって、カラーはたいへんなほらふきだったんですからね。",
              "citation": {
                "source": "カラー",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほらふきの兵太郎君は着物だったので、まずかばんをはずして、しりまくりし、パンツをぬいだ。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう点が、ほらふきの兵太郎君のばかなところであると、久助君は思って見ていた。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵太郎君はほらふきで、ひょうきんで、人をよくわらわせるが、こういう種類のからかいはあまりこのまない。",
              "citation": {
                "source": "久助君の話",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほらふきだとさ、　　　　　　　　　　　　　　　　わかっているわよ。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなあなたのことを、ほらふきのインチキだと言ってますよ」「ほう、どうしてですか」と、メーソフはたずねました。",
              "citation": {
                "source": "金の目銀の目",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからというもの、がちょうが長ったらしい演説をぶちながらそばへよって来ても、カシタンカは二度としっぽをふらないで、人のねむりの邪魔をするうるさいほらふきめと言わんばかりに、鼻のさきであしらい、えんりょなく≪うううう≫と返答してやることにした。",
              "citation": {
                "source": "カシタンカ",
                "author": "КАШТАНКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男は、たいていのほらふきや詐欺師とは違つて、表面正直そうに見せかけようとしていなかつた。",
              "citation": {
                "source": "古書の呪い",
                "author": "THE BLAST OF THE BOOK",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほらふき、つまり広告屋に、高額費用を払い、広大なアメリカで実に斬新かつ衝撃的に訴えた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
