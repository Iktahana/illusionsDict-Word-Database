        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その山の北壁は、冬でも常に雪と氷に覆われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "登山家たちは、未踏の北壁ルートの攻略を目指した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "日当たりの悪い北壁には、珍しい植物が自生している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さらに目を転じて室の北壁に向かうと、そこにも唐招提寺などの木彫の観音が、あたかも整列せしめられたごとくに、並び立っている。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北壁にはオルニー・コートの家から運んできた古い彫刻のあるオーバーマントルが立っていた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "本が持ち去られて隙間があいた埃っぽい書棚を見、北壁の羽目板のあるオーバーマントルにむっつりとした微笑を向けた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
