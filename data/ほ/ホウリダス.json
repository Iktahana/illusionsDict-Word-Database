    "definitions": [
      {
        "index": 1,
        "gloss": "to throw out",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（又急速にＦ・Ｏ）Ｓ＝同じ神社の表　文六と団九郎、前の侍二人の足を曳きずって出て来て、　道へおっ放り出す。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、一文も渡さずに放り出すのは、あまりに悪辣である。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、売込の妨害をされないためだけにでも、五百やそこらは放り出すべきだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その蛇を餅のつもりで伝六掴んで口の所へ持って行って、ワーッと放り出す。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺もマチットで我慢しとった屁をば屁放り出すところじゃった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度その時、浪花節の若衆がかすれた声を止めて扇を放り出すやうに置いた。",
              "citation": {
                "source": "蛾",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『いやはや、』と言いながら僕は立ち上がる、『この楽しい会話につられて、よそで僕を待つ重要案件も放り出すところでした。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は万年筆を放り出すと、部屋中をきりきり舞いしながら、飛んで歩いた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このプレゼントは、物ではありません」　寮長は袋の口を開き、黄色いスポンジ・ブロックを出して、それをつぎつぎと放り出す。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "四、五十機は見えたがね、それが大体五百メートルぐらいにつっこんで来て、何かをぽいと放り出すんだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "命う放り出すのじゃけにのう。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ちながら紅茶を一杯｜啜つて、タヱルで一寸口髭を摩つて、それを、其所へ放り出すと、すぐ客間へ出て、「やあ兄さん」と挨拶をした。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて電車は僕の降りる駅に来て僕を放り出す。",
              "citation": {
                "source": "魔のひととき",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "前と同じように反古に巻いて放り出す。",
              "citation": {
                "source": "三人の師",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "放り出す……このようにして、五日ほどすると美事な雄渾な絵がそれぞれの構図で完成するという制作の方法であった。",
              "citation": {
                "source": "三人の師",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "宏子は、帽子を寝台の上に放り出すようにぬいで、先ず靴をはきかえた。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはしまったと、私は提灯も懐中電灯もそこに放り出すと、一目散に暗い小路を突切って、いよいよ暗い方へ逃げ出した。",
              "citation": {
                "source": "大脳手術",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ちながら紅茶を一杯｜啜って、タオルで一寸口髭を摩って、それを、其所へ放り出すと、すぐ客間へ出て、「やあ兄さん」と挨拶をした。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の樣な弱い男を放り出すには、もつと穩當な手段で澤山でありさうなものだと信じてゐたのである。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体何をぐずぐずしていたのだ」　甲野さんはただああと云ったばかりで、いきなり蝙蝠傘を放り出すと、その上へどさりと尻持を突いた。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査は、最後の手段として、車の上のクツシヨンを後ろへ放り出す。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩は、何時もびくびくもんで――そのうちに突つ返されやしまいかと思ひながら――それこそ、顔も見ないやうにして放り出すんだ……。",
              "citation": {
                "source": "沢氏の二人娘",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "こつちの懐をいためない程度で、さういふことをする慈善家たちと違つて、あたしは、有りつたけのものをみんな、洗ひざらひ放り出すんですの。",
              "citation": {
                "source": "沢氏の二人娘",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝大キナトタン板を屋根から放り出す音と云ったら！",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "タンスのヒキダシは一ツ一ツ放り出す。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、あまくない日本人たちは、そのためにバルザックを放り出すこともできるであらう。",
              "citation": {
                "source": "谷丹三の静かな小説",
                "author": "――あはせて・人生は甘美であるといふ話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は変に不気味になり出して、それかって彼女を放り出すわけにもゆかないで、とっとっと足を早めると、彼女は足が痛いと云ってるくせに、後れがちにもならないでついてくる。",
              "citation": {
                "source": "道連",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その棺桶だ」「なぜ放り出すのか。",
              "citation": {
                "source": "宇宙尖兵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが森君も幸吉もそうそうはいつも斬られてばかりいられぬ、たまに癇癪を起こして国定忠治を縁側からほうりだすことがある。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "出なけりゃ外へほうりだすぞ」　江川が機械人間の手から赤鉛筆をもぎとった。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
