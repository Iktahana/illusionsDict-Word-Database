        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "木魚の音のポン／＼たるを後に聞き朴歯の木履カラつかせて出で立つ。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "堅く尖った足駄の朴歯が、世界一堅固な伯林の道路面に当って端的な乾いた反動の音をたてた。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、トランクへ入れて呉れた朴歯の下駄を、取り出して穿いたのかも彼には判らなかった。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも袖の短い綿服にもめん袴をはいて、朴歯の下駄、握り太のステッキといったようないで立ちで、言わば明治初年のいわゆる「書生」のような格好をしておられた。",
              "citation": {
                "source": "田丸先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と腰衣の素足で立って、すっと、経堂を出て、朴歯の高足駄で、巻袖で、寒く細りと草を行く。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は鳥打に紺飛白、小倉袴、コール天の足袋、黒の釣鐘マントに朴歯の足駄といういでたちでお菓子らしい包みを平らに抱えながら高林家のカブキ門を出た。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "横笛だけは、お嬢さんを三人で包んで立った時、焦茶の中折帽を真俯向けに、爪皮の掛った朴歯の日和下駄を、かたかたと鳴らしざまに、その紋緞子の袴の長い裾を白足袋で緩く刎ねて、真中の位置をずれて、ツイと軒下を横に離れたが。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人共小倉袴に紺足袋で、朴歯の下駄をがらつかせて出る。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人は見上げるほどの大兵で、紫の打紐で大たぶさに結い、まち高の袴に立派な大小を差して、朴歯の下駄を踏み鳴らし、見るからに武芸者といった立派な風采。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "店初まっての大作をしたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "講武所ふうの髷に結って、黒｜木綿の紋付、小倉の馬乗り袴、朱鞘の大小の長いのをぶっ込んで、朴歯の高い下駄をがらつかせた若侍が、大手を振ってはいって来た。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは午前二時頃に起きて、ゆうべの残りの冷飯を食って、腰弁当をたずさえて、小倉の袴の股立ちを取って、朴歯の下駄をはいて、本郷までゆく途中、どうしても、かの三崎町の原を通り抜けなければならない事になる。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "白足袋に低い朴歯の下駄をはいて、やはり俯向き勝ちにとぼとぼと歩いていた。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる朝涼に乗じて、朴歯の下駄をからから踏み鳴らしながら行った。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "『定公、また東京で逢はうな』　持つて来た風呂敷包を背負つて、古びた蝙蝠傘を持つて、すり減した朴歯の下駄を穿いて、しよぼたれた風をして、隣の老人は暇を告て行つた。",
              "citation": {
                "source": "朝",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは小さい肩をすくめて、朴歯の下駄をかちかちと踏み鳴らしながら路を急いだ。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは午前二時頃に起きて、ゆうべの残りの冷飯を食って、腰弁当をたずさえて、小倉の袴の股立を取って、朴歯の下駄をはいて、本郷までゆく途中、どうしてもかの三崎町の原を通り抜けなければならない事になる。",
              "citation": {
                "source": "三崎町の原",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "講武所風の髷に結って、黒木綿の紋附、小倉の馬乗袴、朱鞘の大小の長いのをぶっ込んで、朴歯の高い下駄をがら付かせた若侍が、大手を振って這入って来た。",
              "citation": {
                "source": "二階から",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　佐和子の下駄は、朴歯だから平気であった。",
              "citation": {
                "source": "海浜一日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "調査に出かける場合にはどんな遠いところでも自転車に乗つて行き、脂じみた朴歯の下駄で鈍重に動作し、ぽつりぽつりともの云つて口数も少い。",
              "citation": {
                "source": "日本三文オペラ",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜でも急用があるといえば、巾の広い木綿じまの前掛けをかけて、提灯をさげて、朴歯をならして、謹しやかに通ってきた。",
              "citation": {
                "source": "テンコツさん一家",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "人と云っては只一人、宴会帰りの学生らしいのが、朴歯の下駄をカラコロ／＼と引摺って、刑事の跼んでいる暗闇を薄気味悪そうに透して見て通ったきりだった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵馬は朴歯の下駄かなにかを穿いている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "小額付に一文字の大髷、打割羽織に小倉の袴、白柄朱鞘の大小を閂のように差しそらせて、鉄扇片手に朴歯の下駄を踏み鳴らしてまわるいかつい豪傑が、まるで順番のようにばったばったと他愛なく死る。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜葉色になった、洗いざらしの単衣を裾短かに、心の出た小倉の角帯、几帳面な前かけ、鼠色になった白足袋に、朴歯の下駄をはいて、右の小脇に長い杖を抱えたまま、一心不乱にハーモニカを吹いて居るのは、十八九とも見える、唯の按摩さんだったのです。",
              "citation": {
                "source": "焔の中に歌う",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "霜が下りるようになってから、まだ暗い午前六時頃、寒く凍った道路を、工場へ出かける人々の朴歯の音が、伸子の寝ている枕に響いて来た。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "傘をおおげさにふり、朴歯の日和下駄を踏石にかたかた鳴らして風を切るように駆けだすクニ子の後姿を見送り、実枝はふう、と声に出して息をついた。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はふだん大抵中学時代の制服を着て、朴歯の下駄を履いています。",
              "citation": {
                "source": "わが師への書",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は眼を惹く限りのものに眼を止めては、調和ある心を得ようと努めるのですが、僕の朴歯の歩みは依然としてぎごちないのです。",
              "citation": {
                "source": "わが師への書",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "また「朴歯の下駄」は井伏鱒二氏が「落穂拾ひ」は亀井勝一郎氏が、それぞれ題名をつけて下さつた。",
              "citation": {
                "source": "私の処女出版",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時縁側には、二足の下駄があって、彼の穿いたのはその内の朴歯の日和下駄であったが、若しそうでなく、もう一つの桐の地下穿きの方を穿いていたなら、或はあんなことにならなくて済んだのかも知れないのだ。",
              "citation": {
                "source": "夢遊病者の死",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
