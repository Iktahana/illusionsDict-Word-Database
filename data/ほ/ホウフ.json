[
  {
    "uuid": "eed5e24c-f9e9-5d92-a910-4bdb5d650088",
    "entry": "抱負",
    "reading": {
      "primary": "ほうふ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "aspiration",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "痩せた小柄な船長が船人らしい雄大な抱負を正面の卓子から吹聴していた。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "知るべし、今の世に徒に指環の多きを欲すると、聊か其の抱負を異にするものあることを。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また活きてゐる間｜溌溂たる意氣に日毎酒を被ツて喧嘩を賣いて多大の希望と抱負とを持ツて空しく路傍に悲慘なる人間の末路を見せた青年もあツたであらう。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "自體周三が、此の繪を描き始めた時の意氣込と謂ツたら、それはすばらしい勢で、何でもすツかり在來の藝術を放擲ツて、新しい藝術に入るのだと誇稱して、其の計畫も抱負も期待も大したものであツた。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで世界経綸の抱負と無産階級の意義と露西亜への好意と、マクドナルドの打倒――等々がアクセント許りに煮詰められた用語で拍手の唸りを長閑に反応させてゐる。",
              "citation": {
                "source": "英国メーデーの記",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの作家が、身のほど知らずの抱負を、無邪気に語っているのを聞いていると、私はその人たちを、うらやましく思い、生きていることが、矢鱈に、つらく思われて来るのです。",
              "citation": {
                "source": "正直ノオト",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "理想の抱負のと威張ってみたところで、所詮己は牛にふみつぶされる道傍の虫けらのごときものにすぎなかったのだ。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "多年の抱負の実現に生々と忙しげな孔子の顔を見るのも、さすがに嬉しい。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もし我をして絶大の果断、絶大の力量、絶大の抱負あらしめば、我は進んで支那民族分割の運命を挽回せんのみ。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも同君は、この抱負を自覚しているようです。",
              "citation": {
                "source": "挿絵と闘った話",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時は支那かぶれの荻生徂徠が、日本を東夷と称してゐた時代だが、春満の「ふみ分けよ、大和にはあらぬから鳥の、跡を見るのみ人の道かは」の一首は、実に彼の一生の抱負であるばかりでなく、門下から門下へと伝承して行くべき建学の根本精神であつた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが吾家の抱負では情けない、が質問に接した時それを思ひ出したので、答へとしては厭味で且つ見当はづれらしいが、誌して見た。",
              "citation": {
                "source": "大正十五年の文壇及び劇団に就て語る",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "来年は何をするか――一九三〇年に対する私の希望・抱負・計画――牧野信一　ある先輩が経営することに決つた其鰤敷魚場は今月（十一月）から来年の六月迄房州の何某村（村名を今ちよいと失念した）で行はれる。",
              "citation": {
                "source": "来年は何をするか",
                "author": "――一九三〇年に対する私の希望・抱負・計画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「や、えらい抱負じゃぞ」と、友達は笑って去ったが、腹の中ではやや気味悪くも思った。",
              "citation": {
                "source": "安井夫人",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は子の教育に関しては深甚なる抱負を持つ者なり。",
              "citation": {
                "source": "サフランの花",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は社会主義運動を始めるのだとその抱負を語つても、彼女はてんで対手にしてくれない。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "六代將軍に用ゐられて、其抱負を政治上に實行したり。",
              "citation": {
                "source": "近藤重藏の富士山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "然かと思ふと、其青年は高等商業の生徒らしく、実業界に羽を伸さうと云ふ前途の抱負なども微見かしてある。",
              "citation": {
                "source": "背負揚",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "研究報告書は経費の都合上十分抱負が実現されなかったが、とにかく鴎外時代となって博物館から報告書が発行されるようになったのは日本の博物館の一進歩である。",
              "citation": {
                "source": "鴎外博士の追憶",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴎外は各国博物館の業績に深く潜思して、就任後一、二回落合った偶然の咄のついでにも抱負の一端を洩らしていた。",
              "citation": {
                "source": "鴎外博士の追憶",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論、劇についての特別の抱負があったわけでなく、いわば夷子講の茶番のようなものであったが、左に右く文士劇の先駈をしたので、何事にも新らしい試みに率先した当時の硯友社の意気を窺う事が出来る。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄鶴楼劇は前にもいった通り格別抱負があったわけではなかった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二葉亭の東方問題の抱負は西郷の征韓論あたりから胚胎したらしい。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "二葉亭の露西亜語は日露の衝突を予想しての国家存亡の場合に活躍するための準備として修められたのだから、「君は支那公使となれ、我は露国公使とならん」というが二人の青年の燃ゆる如き抱負で、殆んど天下の英雄は使君と操とのみの意気込であった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学に対する態度もまた随って以前とは全く違って、一生の使命とするというような意気込も理想や抱負も全で失くなっていた。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴木は極めて粗放な軍人肌であって、二葉亭の人物や抱負を理解もしなければ理解しようとも思わず、ただ二葉亭が浪人しているのを気の毒がって斡旋してくれたので、「丁度君には適当の位置だ。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三　第二期の失意煩悶朝日社内における葛藤不平・国際的危機・『平凡』前後・実際的抱負　が、それにもかかわらず、世間は盛んに嘖々して歓迎し、『東朝』編輯局は主筆から給仕に到るまでが挙って感歎した。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も文学を嫌って実際界に志ざしたは強ちこの一癖からばかりでなく、実際方面における抱負も或る人々の思うように万更詩人的空想から産出したユートピヤ的あるいは志士気質の自大放言ではなかった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、露国へ行って何をするツモリであった乎は友人中の誰にも精しく話さなかったが、左に右く出発に先だって露国と交渉する名士を歴訪し、更にその途上わざわざ迂回して後藤や小村やマレウイチと会見した事実から推しても二葉亭の抱負や目的をほぼ想像する事が出来る。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その左にほうふつとして立つ紫の幻塔が見える、それが金の鱗のお城だというのである。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
