    "definitions": [
      {
        "index": 1,
        "gloss": "truth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かの女の本真は芸術の坪をはみ出して生活に情熱を漲らす女である。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "国の本真は気にあり。",
              "citation": {
                "source": "想断々（２）",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "剃刀屋で三月ほど辛抱したが、やがて、主人と喧嘩して癪やからとて店を休み休みし出したが、蝶子はその口実を本真だと思い、朝おこしたりしなくなり、ずるずるべったり店をやめてしまった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "本真の気持で言うのやないねんぜ。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなところを同情しての言葉だったかも知らぬが、蝶子は本真のことと思いたかった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "サイエンが本真チウのか……馬鹿あ。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "清水氏は　『日本真体制論』に次の如く述べている。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の有する天才の一人である清水芳太郎氏は『日本真体制論』の中に、その文明の発展について種々面白い空想を述べている。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたら、新聞に、巖本真理が半年ほどアメリカ、カナダの演奏旅行に出発するという記事がのっていた。",
              "citation": {
                "source": "手づくりながら",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "巖本真理のおばあさんは明治初期の婦人英学者若松賤子である。",
              "citation": {
                "source": "手づくりながら",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわりに本当に音楽家であるヴァイオリニスト巖本真理のような若々しい才能者を教師として迎えた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、当時国民全般の要望であった普選の要求の波と切りはなせない関係であり、ガントレット恒子を、日本代表として万国婦人参政権大会に出席させたような世上一般の気運が坂本真琴の「婦人参政権同盟」その他いくつかの同種の団体を生んだ。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔は丸顔で……もしもし……顔は丸顔で髪は真黒く、鏝か何かで縮らした束髪に結って、大きな本真珠らしい金足のピンで止めてあったと云います。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月二十七日（木曜）　三宅やす子、金子茂、坂本真琴、平塚明子、赤江米子、西川文子、その他で、災害救済婦人団の仕事を始る。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "書でもよいということには、少しも根本真理には変りはないのでありますが、多くの書家は柄に偏する傾向がありまして、書家風に申せば、やはり、唐人風の書がよい。",
              "citation": {
                "source": "書道と茶道",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤いのや、黒いのや、種々の色が交る中に一本真白なのがある。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "林町の父は、この頃ちょくちょく旅行に出かけ用事なのですが、正月には御木本真珠を見に山田へ行った話、まだ申しませんでしたね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三五年（昭和十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でか云うたら、こいさんと一緒やったら、あれ僕の叔母さんや云うたかて本真にせえへん、………」「成る程なあ」「第一ボーイが、あなた方お二人さんですか云うて、けったいな顔して、うちがビール持って来てほしい云うたかて、『えっ』と云うて、不思議そうにジロジロ見てるねん。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "アア、日本真珠の誇り「志摩の女王」は、遂に怪物の手中に帰した。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "川喜多長政・原節子・藤本真澄といふ三人の席が、すぐ近いので出張。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち、よせばいゝのに藤本真澄に、「東宝へも使ってくれよ」と売り込みを始めたものだ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "男鹿では足利時代の終わりに近くなって、本真二山の社僧が相前後して、真言山伏の宗派に転属したことがあった。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「粋な心についたらされて、嘘と知りてもほんまに受けて」という言葉はその消息を簡明に語っている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんまに家まで去んでみにゃ、どんなになるか分りゃせん。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あしこの茂公は、ほんまに油断がならなんだせにんの。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら、ほんまに、ぬれマラのようやないか。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんまの鶴はどんなん？",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「防空壕やったら、あんた、誰に気兼遠慮もいらんし、夜空襲がはいっても、身体｜動かす世話はいらんし、燈火管制もいらんし、ほんま気楽で宜しあっせ」　そして、わては最後までこの大阪に踏み止って頑張りまんねんと、他アやんは言い、「メリ助が怖うてシャツは着られまっかいな。",
              "citation": {
                "source": "起ち上る大阪",
                "author": "――戦災余話",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京のけつねうどんは不味うてたべられへん、大阪のほんまのけつねうどんをたべさしたるねんと、坂田は言い、照枝も両親が猪飼野でうどん屋をしていたから、随分乗気になった。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんまに暫らくどしたなア――お達者どすか」「うん。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
