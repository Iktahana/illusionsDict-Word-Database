        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "当日となって行って見ると、そのわれわれの座席の前に補助椅子の観客がいっぱい並んで、その中には平気で帽子をかぶって見物している四十格好の無分別男がいたりしたので、自分の席からは舞台の右半がたいてい見えず、肝心の水谷八重子の月の顔ばせもしばしばその前方の心なき帽子の雲に掩蔽されるのであった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "劇場建築の設計者が補助椅子というものの存在を忘れていたらしい。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは補助椅子といったようなものをあてがわれて、隅の方に小さく控えていると、第二の一幕物がもう終るところでした。",
              "citation": {
                "source": "米国の松王劇",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、帝劇の舞台に間近な補助椅子にかけていて、目をこらして、この貧寒なクライマックスを観た。",
              "citation": {
                "source": "復活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、前夜の惨劇が好奇心を唆ったものか、その夜は補助椅子までも、出し切った程の大入りだった。",
              "citation": {
                "source": "オフェリヤ殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「前の補助椅子にもう一人の刑事を乗せるから、杉山さんは人垣に囲まれるわけだ、これなら安全でしょう？",
              "citation": {
                "source": "鳩つかひ",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけてもブルメスターは、ドイツ大使館の肝煎りで、大使館に音楽関係者を招待して紹介した上、帝劇を半分買い切るような騒ぎで演奏会を開いたが、予期に反した恐ろしい不入りで、クライスラーが連夜の満員で、帝劇の補助椅子まで不足になった騒ぎに比べると、全くお話にならないみじめな有様であった。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "大入満員、補助椅子も、出切ってゐる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月六日（土曜）　今日もマチネー、意外にも昼の部は補助椅子が出てゐない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "補助椅子の出る大満員。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の部、補助椅子が欠伸してゐる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐもう夜の部、補助椅子が大分出た、が、まだ活気が充分ではない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚くべし補助椅子を売り切る大満員。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時半、中泉眼科へ寄り、東宝グリルでロールキャベツを食って座へ出ると、今日亦補助椅子を売切る大満員。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "座へ帰る、昼も大満員だったが、夜も補助椅子出し切り、「弥次喜多」は、此の四五日ずっと受けるやうになった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "座へ出ると、夜一回だが、凡そ大満員で、補助椅子も出て、ギッシリ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "声はがさ／″＼でくさりであるが、今晩こそ本当の客、補助椅子の出る満員で、ぎっしり、気持よく受ける。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "社長が今晩見物するとの前ぶれあり、夜の部も補助椅子出て満員。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の部、補助椅子が出る有様。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "満員、今日はいくらか涼しいからもあらうが、補助椅子が出る／＼。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "座は今日も補助椅子満員。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "座へ出る、今夜も補助椅子が出た。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "初日、補助椅子ジャン／″＼出て、有楽座の初日としては未曽有なり。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつは又々大当りだ、既に補助椅子がワンサと出てゐる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も補助椅子の出る満員。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "座へ出る、今日も補助椅子ベッタリ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "座は満員である、づーっと補助椅子の出ない日なしといふ景気になるらしいので安心する。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "入りは今日も補助椅子沢山の大満員。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルニューグリルで、オニグラとミニツステーキをやり、座へ出ると今日も補助椅子がワンサと出てゐる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶりで補助椅子の出ない芝居だ、考えてみるに、先づ、ロッパ七役を売ってない宣伝のまづさ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
