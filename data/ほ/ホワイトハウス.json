        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ウンター・デン・リンデンを歩いている女と、タウエンチーン街を歩いている男と、ホワイトハウスの玄関をはぎ合わせたりするような事はそもそも宵の口のことであって、もっともっと美しい深い内容的のモンタージュはいかなる連句のいかなる所にも見いだされるであろう。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時差と醒めきらぬアルコールがすっかり気分をハイにしてしまい、チェック・インもそこそこにホワイトハウスあたりを見物。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "月――日露の講和会議が米のポーツマスに開催されると決定された数ヶ月前に、一人の日本学生が、急にホワイトハウスの何課かに雇入れられました。",
              "citation": {
                "source": "私の万年筆",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "英介はレシービングシツプの使ひで、絶えずホワイトハウスへ往復してゐた折からで、その画がたまたま先のルーズベルト大統領の鼻眼鏡に触れて、新吉は大統領から名誉に富んだメツセーヂと銀鎖のついた万年筆を贈られた。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "つごう二〇〇〇台近く製造されたアルトは、パロアルト研究所で広く使われるようになっただけでなく、いくつかの大学や外部の研究機関、ホワイトハウスなどで運用されて一部から高い評価を受けていた★。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "六、ホワイトハウスの緑蔭。",
              "citation": {
                "source": "函館八景",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学生達は、愛称としてホワイトハウスと呼んでゐたのである。",
              "citation": {
                "source": "函館八景",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は、何か神秘なものでも望見するやうに、おそるおそるホワイトハウスを眺めたものである。",
              "citation": {
                "source": "函館八景",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学生達は、にやにや笑ひながら、意味ありげにホワイトハウスと云つた。",
              "citation": {
                "source": "函館八景",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきに述べた大森浜に沿うて、砂山に至り、砂山を越えて牧場に至り、緑蔭のホワイトハウスをみながら、更に大草原を横断して湯の川の温泉へ行くコース、これは一里半ほどの快適なハイキングコースである。",
              "citation": {
                "source": "函館八景",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばワシントンのホワイトハウスやパリ郊外のＮＡＴＯ司令部だ。",
              "citation": {
                "source": "いえ、いえ、ラゴーフにはもう！",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
