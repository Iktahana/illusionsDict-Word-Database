        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "市場の軒先には、アジやカマスなどの干し魚がずらりと並んで売られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "干し魚を細かく刻んでお茶漬けに入れると、魚の旨味が溶け出して絶品だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "保存食としての干し魚は、山間部の人々にとって貴重なタンパク源だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "玉ねぎや馬鈴薯に交じって椰子の実やじゃぼん、それから獣肉も干し魚もある。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中がそれを持って来た時、私は干し魚が送られたと思ったほど部屋の中が生臭くなった。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――というても、芋の煮たのや、木の芽｜味噌の筍や、せいぜい干し魚ぐらいな、この辺の農家の馳走ぐらいな質素ではあったが。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
