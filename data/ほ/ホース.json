    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hose",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は、ミキサーに引いてあるゴムホースの水で、一と先ず顔や手を洗った。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいや、西風ゴスケでない　そんならホースケ、蜂だか？",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うんにゃ、ホースケ、蜂でない　そんなら、トースケ、ひばりだか？",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雪のないとき、ねていると、　西風ゴスケがゆすぶるぞ　ホースケ蜂が巣を食うぞ　トースケひばりが糞ひるぞ。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "英人はホースナッツ・ツリーといっている。",
              "citation": {
                "source": "マロニエの花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年画家の下宿している部屋の窓にもこのホースナッツ・ツリーが白いロウソクを差出していた。",
              "citation": {
                "source": "マロニエの花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "パリのマロニエはそちらのホースナッツのことですとさ。",
              "citation": {
                "source": "マロニエの花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして野暮なホースナッツの咲く窓の内のごつごつしたイギリス娘のもとへ落ついた。",
              "citation": {
                "source": "マロニエの花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "舳の斜の行手に浪から立ち騰って、ホースの雨のように、飛魚の群が虹のような色彩に閃めいて、繰り返し繰り返し海へ注ぎ落ちる。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴せ下ろす星降り、地上の火から空への火の伝騎のように、また、火勢を管で伸して注ぎかけるホースのように、数条の登り竜は、くきくきと天上に昇っては花影の余抹を劈んで満口の火粉を吹き、衰えては降り、また登って行きます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "喞筒押しでなくても、ホース持ちなら出来るやろ」　ホース持ちは、空気の過不足の合図を受ける大切な役目で、昔は潜水夫の妻がこれをしていたのである。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "君枝がホースを持っているのだと思えば、次郎はもうどんな危険もいとわぬ気がして、そして、マニラで死んだという君枝の父親の気持が、ふっと波のように潜水服に当って来るのだった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのポンプはかなり上等のものだったらしく、長いゴムのホースの尖端の筒先から迸る水が、数間先の土塀を越えて、通行人を驚かした。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホースの尖端からは、沸騰点に近い熱湯がほとばしり出たが、それがデッキを五尺流れるうちには凍るのであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉服橋で電車を降りて店の近くへ来ると、ポンプの水が幾筋も流れてる中に、ホースが蛇のように蜒くっていた。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ダッシン・スルー・ザ・スノウ、イナ・ワン-ホース・オープン・スレイ」　ワラが歌いだした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルーのホースが、事務室の外にある蛇口につながれたまま、とぐろを巻いている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと口に栗と云っても、ここらの国々に多い栗の木は、普通にホース・チェストナットと呼ばれて、その実を食うことは出来ないと云います。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速に支度をして、ベーカーストリートの停車場から運ばれてゆくと、ガーデンの門前にゆき着いて、先ずわたしの眼をひいたのは、かのホース・チェストナットの並木でした。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、ここでアーヴィングが「スケッチ・ブック」の一節を書いたとか伝えられているレッド・ホース・ホテルという宿屋に泊まりました。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一口に栗と云っても、ここらの国々に多い栗の木は、普通にホース・チェストナットと呼ばれてその実を食うことは出来ないと云います。",
              "citation": {
                "source": "栗の花",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速に支度をして、ベーカーストリートの停車場から運ばれてゆくと、ガーデンの門前にゆき着いて、先ずわたしの眼をひいたのは、彼のホース・チェストナットの並木でした。",
              "citation": {
                "source": "栗の花",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、ここでアーヴィングがスケッチブックの一節を書いたとか伝えられているレッド・ホース・ホテルと云う宿屋に泊まりました。",
              "citation": {
                "source": "栗の花",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「別に気附きませんでしたが、ただ、瓦斯のホースが乱雑に投げ出されてあり、バルーンは非常に浮力が減って、フニャフニャになりながら、今にも墜ちそうに低い処で漂っていました。",
              "citation": {
                "source": "デパートの絞刑吏",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから瓦斯のホースをあてがい、水素｜瓦斯の補充を始めます。",
              "citation": {
                "source": "デパートの絞刑吏",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、浮力の増したバルーンは、瓦斯のホースを投げ離し、弁を開けっぱなしたまま容赦なく上昇を始めます。",
              "citation": {
                "source": "デパートの絞刑吏",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫓の上からホースが二すぢ釣りさがつてゐるのが灰色に見えその少し向は桜並木が黒々と渦巻いてゐた。",
              "citation": {
                "source": "潮干狩",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "オイお前は、ホースを引っぱれ。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
