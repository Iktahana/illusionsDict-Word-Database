      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "look!",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ほら、じっとして見ていなさい。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ね、ほら、カチ、カチつて音が聞える。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、これくらゐの強い藥でなければ、おれの色黒はなほらないやうな氣もする。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら、襦袢の襟なんか、油光りしてゐるぢやありませんか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こなひだから、さう、こなひだ、ほら、あの、若い娘のお客さんが來た頃から、あなたはまるで違ふ人になつてしまひました。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "み空の方より、風の吹くみちこみちこそなたの胸は海のやうおほらかにこそうちあぐる。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の下からは蒼黯い偃松が、杉菜ほどに小さく見えて、黄花石楠花は、白花石楠花に交って、その間にちらほらしている、一団の霧が槍へ吹っ懸けて、白い烟をパッと立てるので、一時は姿を没したが、又穂先だけ鋭く突き出す。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから尾根を伝わって、下り気味になる、ちょいちょい小さく尖った山稜は、大波の間に、さざ波をだぶだぶ打ち寄せたようで、爪先が上ったり下ったりする、石の皺には、黄花の石楠花が、ちらほら咲いている、この花の弁で承けた霧の雫を吸ったときは、甘酸っぱい香気で、胸が透いた。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "大和大峰いりのほら貝は聞えないが、町から野、野から山へと、秋草をわたり、落葉松の枯木をからんで、涼しくなる鈴の音は、往さ来さの白衣の菅笠や金剛杖に伴って、いかに富士登山を、絵巻物に仕立てることであろうか。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら」　少年は通路に立っている乗客の方を、顎でしゃくって見せた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらバスケットを取ってくんなよ」「ほら。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、私が訊くと、「ほら、そこにあるよ」　と、上の子が出て来た。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前担いでおいでよ」「うん」「ほら、こんなに釣れたよ」　魚籠を解いて腰から外し、子等に持たせた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　外では、グラン・パレイの春のサロンから出て来た人がちらほら晩餐までの時間を持てあましている。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯林にちらほら街路樹の菩提樹の葉が散り初めたのは十日程前だった。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな畑だけれど、十月の半過ぎでは、茄子もちらほらしかなって居ない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「吉日を選びてなしたるわざの、すゑとほらぬを数へてみんもひとしかるべし」というのは、現代の科学者が統計学の理論を持出してしかめつらしく論じることを、すらすらと大和言葉で云っているのである。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろな善良な、しほらしい考が私の心の底にはげしくこみあげた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほら、教はると、すぐそれね、」と少女はからかふやうに言ふのだつた。",
              "citation": {
                "source": "夢",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほら、鮨だよ、おすしだよ。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほら、あのでつぷり肥つたロシヤ人と組みながら、今、こつちを向つて笑つてる女があるだらう。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほらキルビイさんのお宅にあるやうな。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら、建物の端が見えるでせう。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その柳の下を、駈けて通る腕車も見えず、人通りはちらほらと、都で言えば朧夜を浮れ出したような状だけれども、この土地ではこれでも賑な町の分。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雁もどきッて、ほら、種々なものが入った油揚があらあ、銀杏だの、椎茸だの、あれだ、あの中へ、え、肴を入れて交ぜッこにするてえことあ不可ねえのかなあ。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来傍には又岸に臨んで、果しなく組違えた材木が並べてあるが、二十三十ずつ、四ツ目｜形に、井筒形に、規律正しく、一定した距離を置いて、何処までも続いて居る、四ツ目の間を、井筒の彼方を、見え隠れに、ちらほら人が通るが、皆黙って歩行いて居るので。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "花も百合の美しさは無けれど、しほらしさはあり。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "山桜桃　にはうめは、いと小さき花の簇れて咲くさま、花の数には入るべくもあらず見ゆるものながら、庭の四つ目籬の外などに、我は顔もせず打潜みたる、譬へば田舎より出でたる小女の都慣れぬによろづ鼻白み勝にて人の背後にのみ隠れたるが、猶其の姿しほらしきところ人の眼を惹くが如し。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "花の形しほらしく、色ゆかし。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "断腸花　秋海棠は丈の矮きに似ず葉のおほやうにて花のしほらしきものなり。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
