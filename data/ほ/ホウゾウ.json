  {
    "uuid": "1dbd3b41-01dc-5091-b6d8-a87c193734b3",
    "entry": "法蔵",
    "reading": {
      "primary": "ほうぞう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
