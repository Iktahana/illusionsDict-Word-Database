    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Buddhist teachings",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
