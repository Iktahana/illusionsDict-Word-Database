        "examples": {
          "standard": [
            {
              "text": "自衛隊の方面隊は、地域の防衛と災害派遣の中心となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今回の大規模な災害では、複数の方面隊が出動した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "方面隊の演習は、有事の際の連携を強化するために重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その代わり地質学的なアドヴァイスが欲しいというレイクの懇願にも拘らず北西方面隊には同行しないことに決めた。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
