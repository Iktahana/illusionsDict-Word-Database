          "standard": [],
          "literary": [
            {
              "text": "」男女の奉納物４・24（夕）　香取秀真氏が法隆寺の峰の薬師で取調べたところに拠ると、お薬師様に奉納物の鏡には、随分｜傑れた価値のものも鮮くなかつたが、同じ献上物の刀剣は皆なまくらで鏡と比べたらてんで談話にもならなかつたさうだ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜も大勢来て居った友人（碧梧桐、鼠骨、左千夫、秀真、節）は帰ってしもうて余らの眠りに就たのは一時頃であったが、今朝起きて見ると、足の動かぬ事は前日と同しであるが、昨夜に限って殆ど間断なく熟睡を得たためであるか、精神は非常に安穏であった。",
              "citation": {
                "source": "九月十四日の朝",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼餉を食うて出よとすると偶然｜秀真が来たから、これをもそそのかして、車を並べて出た。",
              "citation": {
                "source": "車上の春光",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀真格堂の二人は歩行いて往た。",
              "citation": {
                "source": "車上の春光",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "土産に張子細工を一つほしいというたので秀真は四、五本抜いて持って来てくれた。",
              "citation": {
                "source": "車上の春光",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "その箱の前に秀真の鋳たる青銅の花瓶の足三つ附きたるありて小き黄菊の蕾を活けあり。",
              "citation": {
                "source": "明治卅三年十月十五日記事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の首を焼いてくれずやとかつて秀真に頼みしに、がらんどにしてなければ焼けずといふ。",
              "citation": {
                "source": "明治卅三年十月十五日記事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "終に秀真の鋳物日記に到る。",
              "citation": {
                "source": "明治卅三年十月十五日記事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "左千夫来り秀真来り麓来る。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "釜の蓋は近頃秀真の鋳たる者にしてつまみの車形は左千夫の意匠なり。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜も大勢來て居つた友人（碧梧桐、鼠骨、左千夫、秀真、節）は歸つてしまうて余等の眠りに就たのは一時頃であつたが、今朝起きて見ると、足の動かぬ事は前日と同じであるが、昨夜に限つて殆ど間斷なく熟睡を得た爲であるか、精神は非常に安穩であつた。",
              "citation": {
                "source": "九月十四日の朝",
                "author": "病牀に於て",
                "note": "青空文庫"
              }
            },
            {
              "text": "花活は秀真が鋳たのである。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "香取秀真　香取先生は通称「お隣の先生」なり。",
              "citation": {
                "source": "田端人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "（十一月四日）　　　　　茶釜の蓋置き　今日香取秀真氏の所にゐたら、茶釜の蓋置きを三つ見せてくれた。",
              "citation": {
                "source": "雑筆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一月二日）御降りや竹ふかぶかと町の空　　　　　夏雄の事　香取秀真氏の話によると、加納夏雄は生きてゐた時に、百円の月給を取つてゐた由。",
              "citation": {
                "source": "点心",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭木に烏瓜の下つたのは鋳物師香取秀真の家。",
              "citation": {
                "source": "続野人生計事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは日本へ帰った後、香取秀真氏にひやかされた事だが、骨董を買うには支那へ行くより、東京日本橋仲通りを徘徊した方が好さそうである。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その主なる者では、伊藤左千夫氏、森田義郎氏、香取秀真氏、蕨真一郎氏、長塚節氏、岡｜麓氏等である。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから重症となってからは、碧虚二氏は勿論、鼠骨、義郎、秀真の諸氏なども、昼夜輪番に身辺に詰めて、母氏妹氏と共に心を尽して看護した。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤマト或いは日本の外に、古く大八洲国、豊葦原瑞穂国、葦原中国、玉墻内国、細戈千足国、磯輸上秀真国、或いは虚見倭国、秋津洲倭国などの称号が、古く呼ばれた事があった。",
              "citation": {
                "source": "国号の由来",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀真君の鋳物を批評するのにもこの写生ということを極言して従来の型にはまろうとする上に警告を与えるのを常としていた。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは秀真君の鋳物の批評である。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜も大勢来て居った友人（碧梧桐、鼠骨、左千夫、秀真、節）は帰ってしもうて余らの眠りに就いたのは一時頃であったが、今朝起きて見ると足の動かぬ事は前日と同じであるが、昨夜に限って殆ど間断なく熟睡を得たためであるか精神は非常に安穏であった。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四冊目が香取秀真君の『日本鋳工史稿』であった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩は吾々が座に落付くと間もなく芥川の所謂お隣の先生たる香取秀真氏が来られた。",
              "citation": {
                "source": "芥川龍之介を憶ふ",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "香取秀真氏の古い歌に「おしいれの猫の産屋に雨もりて夜たゞ親鳴く子を守りがてに」というのがあった。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "香取秀真氏が大学病院で詠まれた歌に「風の音あめのしづくの音聞かむ板葺やねを恋ひおもふかな」というのがあった。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "「山車引くと花笠つけし玉垂の細し少女の丹の頬忘らえね」という香取秀真氏の歌は、山車を引く花笠であり、くわし少女の丹の頬であるから、更に美しいけれども、朱拙の句も祭の句だけに、尋常の編笠とは同一に見がたい。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "香取秀真氏の歌に「魂祭すぎにけるかも里川に瓜の馬流る蓮の葉流る」というのがあったかと記憶する。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女　　ほんとのことはなほつまんないわ。",
              "citation": {
                "source": "女人渇仰",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
