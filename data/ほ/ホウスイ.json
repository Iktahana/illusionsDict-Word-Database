      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "discharge of water (from a river, dam, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "円タクに乗ったり、歩いたりして、一行は荒川放水路の水に近い初夏の景色を見て廻った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒川放水路の水量を調節する近代科学的｜閘門の上を通って土手を数町川下へさがると右にクラブハウスがあり左にリンクが展開している。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙地でそれを認めたらすぐ返答にその松明を上げて同時に土器の底の栓を抜いて放水を始める。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒川放水路が北方から東南へ向けまず二筋になり、葛西川橋の下から一本の大幅の動きとなって、河口を海へ融かしている。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は同じ東京となった放水路の川向うの江戸川区には移り住むのを極度に恐れた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついに父は荒川放水を逃路の限りとして背水の陣を敷き、青海流水泳の最後の道場を死守するつもりである。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しぐらい待ってよ」　だが、息づまるような今までの気持からいくらか余裕をつけようとして、小初はもう一度放水路の方を見やった。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一めん波が菱立って来た放水路の水面を川上へ目を遡らせて行くと、中川筋と荒川筋の堺の堤の両端を扼している塔橋型の大水門の辺に競走のような張りを見せて舟々は帆を上げている。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "川上はだいぶ降ったと見えて、放水路の川面は赭土色を増してふくれ上った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中川放水路の堤の塔門型の水門はきりっと閉った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから放水路の水へ滑り込んで、舟に護られながら海へ下って行くのだ。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京近郊の川では、荒川放水路が一ばん似てゐる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京駅に着き、半日掛って漸く荒川放水路近くの木下の住いを探し当てた。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に水の轟く音は、鋭い叫び声のような――ちょうど幾千という蒸気釜がその放水管から一時に蒸気を出したと思われるような――物音にまったく消されてしまいました。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった今、玉石が抜けて、下にいた仲間を放水路ん中に叩っこんじまったんです。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから石も、抱き合った二人も、瞬く間に、あの放水路ん中にまくれ込んじまって、騒ぎになったんでさあ」「二人とも流れちまったんかい。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰を打たれた方はすぐ死んだらしいんです、だから、放水路を出外れた吊橋のところから、渦になっているでしょう。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "警官ともあろうものがこの放水路に気がつかんなんていい気なもんですよ。",
              "citation": {
                "source": "動物園の一夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし荒川放水路を隔てた向ふの河岸には、一つの小さな寺院があつて、そこにこの刑務所附属の墓地があつた。",
              "citation": {
                "source": "随筆「断片」",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒川放水路のそばの、煤煙がふきこむ檻の内で自分は、母からの達筆な手紙を読まされた。",
              "citation": {
                "source": "鈍・根・録",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その放水が、約十秒ほどの間継続することも判明した。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君は、荒川放水路をくだって行った海沿いの一角に、以前から、「洲蘆の居留地」と呼ばれる、出島があるのを御存知であろう。",
              "citation": {
                "source": "地虫",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼく達、ボオトの場景が最後を飾り、観ていれば、撮影された覚えもある荒川放水路、蘆の茂みも、川面の漣も、すべて強烈な斜陽の逆光線に、輝いているなかを、エイト・オアス・シェルの影画が、キラキラする水を鋭く切り、凄まじい速さで、進んでゆくのでした。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "平和記念館を建て、爆心地付近や城趾の荒野に大公園を設け、橋梁を修理し、河川を清掃し、放水路を作り、広い街路を通じ、河岸の緑地遊歩場を拵え……おう、限りなく仕事がある。",
              "citation": {
                "source": "ヒロシマの声",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……ジャン、チェーコン、リウコン……コンリウ、コンジャン、チェーコンチェー……チェーリウコンコンジャンコンチェー……じゃんすいじゃんすい、ほうすいほう……すいすいじゃんすい、ほうすいほう……」　子供は又も黒い顔を見合わせた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
