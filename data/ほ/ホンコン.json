        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "海から近づいて行く函館の山腹の街の灯は、神戸よりもむしろ香港の夜を想わせる。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき食卓の日本料理の美味のうちに急に鳴物の入った三味線を土人街の坊主頭の幇間が弾き出すと、香港あたりでよく歌われる鴨緑江節を女達が噛むようにうたいだした。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "海峡から飛んできた伝書鳩が香港政庁の上空で旋回した。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "広東香港間の電信が切断されてその後の消息は不明なのですが、恐らく明日は外国人は南方に於ける商業上の前途を楽観して、交易所では支那へ夥しい投資が行われるでしょう。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "シイ・ファン・ユウが早朝天津から香港に向けて出発する知らせであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一通は上海の同士から、一通はシイ・ファン・ユウから香港行を中止した電文であった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "米良は香港デーリ・プレスの朝刊をひらいた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府にあったリー・シー・ツワンは今暁香港に飛行機で来り、直にホテル・マンションに入ったことが記事になっていた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "西部のパノフォラム・ロードに虹が浮いて、香港は動乱の巷を他所に見て、植民地兵の配列のなかで、幾重にも市街を取巻いた軍用道路の設置と、無線電信台に集中される軍国主義の機密と、今日の支那に関する利権が活動を始めた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は昨夜からの涙の滲んだ絹のハンカチを香港の朝の風景に飜えして、　――妾達は陳独秀の健康を祈るのです。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは今暁飛行機で香港にくると陳独秀の革命的遺産をうけついだのだ！",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "香港の階段の街が涙に濡れて濶葉樹の葉がビクトリア女皇の銅像前の花園で金色に光った。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "水自転車、香港、そこで彼女は仲居をしていた。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｙ、僕は粋な香港に未練があるんだ。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "マレー半島に奇襲上陸、香港攻撃、宣戦の大詔、園子を抱きながら、涙が出て困った。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは興行のためにと香港へ赴かんとて、此船に乘組んで居つた伊太利の曲馬師の虎が檻を破つて飛び出した事で、船中鼎の沸くが如く、怒る水夫、叫ぶ支那人、目を暈す婦人もあるといふ騷ぎで、弦月丸出港のみぎりに檣燈の微塵に碎けたのを見て『南無阿彌陀佛、此船には魔が魅つて居るぜ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は娘にはああは約束したが、たかだか台湾の基隆か、せめて香港程度までであろうと予想していた。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここまで来る航行の途中で、上海と香港の船繋りの間に、西洋らしい都会の景色も、支那らしい町の様子もすでに見て来た。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一回の移民船香港丸が百二十五名の労働者を乗せて、マニラに入港したのは明治三十六年十月十六日であった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　全長二十一マイル三十五のベンゲット道路が開通したのは、香港丸がマニラへ入港してから一年四ヵ月目の明治三十八年一月二十九日であった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもシンガポールを立去って、ホンコンの方へ行ったとかいうことでした。",
              "citation": {
                "source": "マレー俳優の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正九年六月、渋柿）　　　　　二　ホンコンと九竜　夜の八時過ぎに呉淞を出帆した。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホンコンと九竜の間の海峡へはいるのだという。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　夕飯後に甲板へ出て見るとまっ黒なホンコンの山にはふもとから頂上へかけていろいろの灯がともって、宝石をちりばめた王冠のようにキラキラ光っている。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホンコンから乗った若いハイカラのシナ人の細君が、巻煙草をふかしていた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲板でハース氏に会うと、いきなり、芝の増上寺が焼けたが知っているか、きのうのホンコン新聞に出ていたという。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホンコンやカルカッタ辺の支邦人街と同じ空気が此処にも溢れていた。",
              "citation": {
                "source": "淫賣婦",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、船長などというのもいかがわしいのが多く、これらの船員と結託しては密航婦を、シンガポーアだとか、ホンコンだとか、またはアントワープだとかの遠方までも、大仕掛けで輸送したものだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、ホンコン入港の時に、密航婦を、フォーアピークへ移しかえることを忘れなかったボースンは、何と考え違いしたものか、大切のシンガポーアで、有頂天になり過ぎていて、密航婦を、チエンロッカーから出すことを忘れてしまった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑いのはホンコン、シンガポール間であるそうな。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
