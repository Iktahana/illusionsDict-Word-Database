    "definitions": [
      {
        "index": 1,
        "gloss": "Northern Wei dynasty (of China; 386-535)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "漢高祖や文帝や北魏の宣武など、母が竜に感じて帝王を生んだ話も少なからず。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那にも北魏孝荘帝の時｜冀州の沙門法慶、新仏出世と称し乱を作した（『仏祖統記』三八）。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "」関野博士と木乃伊７・27（夕）　工学博士関野貞氏は、古代建築専攻の学者で、近頃は支那に派遣せられて大同府の千仏山や、洛陽の龍門や、または支那五獄の随一と言はれる嵩山あたりまで出掛けて往つて、古物といふ古物は何一つ残さず捜し廻つて、「どうしても北魏隋唐となると、芸の冴え方が違つてるから偉い。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "北魏の世宗（宣武帝）時代に、母親を殺害した罪人があつた。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち第一に北魏の太武帝は道士寇謙之を信用して佛教に迫害を加へた。",
              "citation": {
                "source": "老子化胡經",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "様式だけは北魏に則って造られているが、この破天荒とも言うべき表現の直接性は決して様式伝習の間から生れているのではなく、却て様式｜破綻から溢れ出る技術と精神｜気魄との作ったものである。",
              "citation": {
                "source": "美の日本的源泉",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに後世北魏の※道元の水經注は東南の諸水に就いてその記載が確實でないと云はれて居る位であるが、假に禹貢を禹の時代とせずして、それより千年若くは千五百年も以後のものとしても、その水脈の記載が悉く後世の地理に合せんことを求むるは無理なる注文である。",
              "citation": {
                "source": "禹貢製作の時代",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし魏・後趙・成漢・東晋・北魏等にある太和、これまた一も干支の符合するのがない。",
              "citation": {
                "source": "石上神宮の神宝七枝刀",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "北魏の石の仏頭は、スフィンクスみたいな表情をしてゐた。",
              "citation": {
                "source": "夜の鳥",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその中に、支那から帰った友達に貰った北魏の二十品という石摺のうちにある一つを択り出して入れた。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "五胡十六国と言われているようにその交代は頻繁であったが、蒙古民族たる鮮卑の建てた北魏のごときはかなり強大であった。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "グプタ朝の最盛期は北魏の時代に当たっているが、その時代には西域人の来朝が少なくない。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし北魏式美術にはギリシア風の感じはない。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて外来美術の美しさに目ざめたシナ人は、振りかえって北魏の美術をも見なおした。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北魏の時代に子供らしい無垢な心の驚異をもってなされた人体の美の闡明が、今や成熟した人の複雑な意識をもってなされるに至った。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲崗石窟の遺品によって見れば、我々が推古彫刻の先蹤として考えている北魏式彫像は、実は北魏美術の一半に過ぎぬ。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "釈迦像にしても薬師像にしても、形式から云えば北魏の磨崖の像に起源していることは今日の定説と云っていい。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御悲願を正しく心にとめて、北魏伝来の形式にそれを刻まんとしたのである。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このほか、隅壁その他に、天人、異獣、草花、種々の文様など一面に描かれているが、わが飛鳥期の遺品とよく似通い、支那北魏の系統といわれる。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも北魏風な厳しさはかえって強い。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの新感覚の造型は、飛鳥の主流をなした北魏様に先駆したのでもなく、また並存したのでもなく、北魏的なものが飽和した時に現われたもので、そこにはやはり時代の下るものが考えられるのである。",
              "citation": {
                "source": "百済観音と夢殿観音と中宮寺弥勒",
                "author": "野間清六",
                "note": "青空文庫"
              }
            },
            {
              "text": "今をおいて、北魏を討つときはないのです。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわんや晩年数次にわたる北魏進撃と祁山滞陣中の労苦とは、外敵の強大なばかりでなく、絶えず蜀自体の内にさまざまな憂うべきものが蔵されておったような危機に於てをやである。",
              "citation": {
                "source": "三国志",
                "author": "篇外余録",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
