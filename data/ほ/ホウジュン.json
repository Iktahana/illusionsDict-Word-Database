[
  {
    "uuid": "c5df12c3-e8eb-5bde-b125-dabfc25728cb",
    "entry": "豊潤",
    "reading": {
      "primary": "ほうじゅん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
