        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "木綿の幌蚊帳の方を数えたらこれは四百くらいであったが、これでも細か過ぎると思う。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の前には幌蚊帳の中に俊坊が顔をまっかにして枕をはずしてうつむきに寝ている。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人力車にも初めは幌なし況んやゴム輪透幌蚊帳幌アセチリンの灯に於てをや。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほろがやのなかに、くびれて丸々した手をのばして大の字になって立派な顔つきして眠っているのや、おばあちゃんや私にあやされて、キキと笑う顔つきや。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
