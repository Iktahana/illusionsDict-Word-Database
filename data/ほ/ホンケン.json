    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pure silk",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "新劇の方では、生憎、お客さんが、柄いきだけで、品物に飛びついて来ると思ひ、正札は、人絹を本絹並みにつけてあるのです。",
              "citation": {
                "source": "新劇の観客諸君へ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "お梅は本絹の帯を一本買ったというし、お民はまたこれも本絹の御召を一反買ったといってはしゃいだ。",
              "citation": {
                "source": "錦紗",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "本絹も本絹「材木から取った本絹よ」でお通の「毒気」を抜き、それから自分たちがいくら丹精して蚕を飼っても、その蚕から取った本絹の着物など夢にも着れない現状を、げらげらと明けぱなしでけなすのであった。",
              "citation": {
                "source": "錦紗",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、人絹と本絹との区分で、自然のものにも人絹みたいなつまらんものもある。",
              "citation": {
                "source": "味覚馬鹿",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
