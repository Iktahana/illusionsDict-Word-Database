[
  {
    "uuid": "7c99a422-5f26-52a2-ba71-baa9b1e5402c",
    "entry": "報告書",
    "reading": {
      "primary": "ほうこくしょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
