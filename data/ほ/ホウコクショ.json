    "definitions": [
      {
        "index": 1,
        "gloss": "(written) report",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "飛行機や潜航艇の所在を探知する方法について絶えず軍務当局から相談を受け、また一方では国民科学研究所と航空研究顧問委員会の軍事的活動の舞台でも主役を勤めていたので、その頃の彼の書斎は机の上も床の上もタイプライターでたたいた報告書類などで埋まっていた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "有閑者がこの街を自分の調査機関のようにたえまなく往来して、記憶をタイプライターで刷りあげると、不生産的な、非社会的な報告書しかつくれないような愚な街であった。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "気にかかるのは、師団長にどういう報告書を出すか、その事の方が大事であった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "教授が今ここの図書室で見たいと言った本は、同教授の関係した北光観測のエキスペジションの報告書であったが、あいにくそれが当時のＰ教室になかったので、あてにして来たらしい教授はひどく失望したようであった。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "取敢ず其屍体を町へ運ばせて、己は其報告書を作る準備に取かかった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "※に対する調査の報告書である。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ銀行上本町支店から児子権右衛門預金元利決算報告書が来て、権右衛門の預金が百万円に達したことが分ったからである。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その報告書は内務省に現存して、浅野｜正恭翁も一読したと云って、筆者は浅野翁からそれを聞かされた。",
              "citation": {
                "source": "レンズに現われた女の姿",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく報告書で御覽の通り殺害の手口は鬼畜に類してゐます。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "拓殖会社の大事務室には卓が一見縦横乱雑に並び、帳面立ての上にまで帰航した各船舶から寄せられた多数の複雑な報告書が堆く載っている。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと月ふた月と過すほどに、おおやけの打ち合せもすみて、取調べも次第に捗り行けば、急ぐことをば報告書に作りて送り、さらぬをば写し留めて、ついには幾巻をかなしけん。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "報告書は麾下の陳歩楽という者が身に帯びて、単身都へ馳せるのである。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "長官はその属僚の調べ上げてこしらえた報告書を自分のものにして報告しなければならない。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時に、しかし、コリンス方面監察の報告書によると――それは現在記者の卓上に置かれてあるのだが――解明の可能性は決して思ったほど乏しいものではないようだ。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "報告書にはこう書いてあった――『両駅間の軌道沿線には、炭坑の散在するあり。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私はその報告書を綴織の掛っている食堂に居る、ホームズのところに持って行った。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "「署に報告書は出したけどな。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝、私は警視庁へ行って、いままでに挙げられたすべての証拠の完全な報告書を手に入れ、また、いろいろ新聞社をまわって、初めから終りまで、この痛ましい事件に関するなんらかの決定的な報道を載せているあらゆる新聞紙を一部ずつ手に入れた。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、多くの証言の報告書にはみんな、僕が君との話のなかに用いてきたように、この相対的な言い表わし方がはっきりと、またいつも用いられているのに、いままでのところ、どの新聞紙も、あるいはどの警察の役人も、このひどい矛盾にちっとも注意していないのだ。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時まとめた報告書を、彼はアラン・ケイに読んでもらおうと考えます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "報告書や提案書の類も、嫌というほど見つかりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで言う、「比較的短期間で結論が出ることが見込まれるもの」として、事務局は「権利制限の見直し」と「私的録音録画補償金の見直し」問題を設定し、二〇〇五年の一一月までに、この二つの問題に対する報告書をまとめる審議予定案を示した。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "著作権、著作隣接権をめぐる法的枠組みの見直し事項に関して、二〇〇四年七月一九日付けでまとめられた欧州委員会の報告書は、保護期間のさらなる延長に歯止めをかけた点で、注目に値する。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＣＴＥＡによって、アメリカでは商業用レコードが発売後九五年間保護されるようになったことを受けて、同様の延長を図らなければ、ヨーロッパの音楽制作者と音楽産業が、不利益を被るとの主張がなされたと、報告書は指摘している。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "この延長論に対しては、報告書によれば、現状維持を主張する強固な反対があった。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに、保護期間の短縮を求める声も存在することなどをあげた上で、報告書は、著作隣接権保護期間の延長の機は、熟していないと結論付けた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学論文や報告書などをバサバサ拾い読んだり飛ばし読んだりする程度ならいいが、それによって小説やエッセイや哲学や歴史の本を読もうなどという気分にはとてもなれない。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと月ふた月と過す程に、おほやけの打合せも濟みて、取調も次第に捗り行けば、急ぐことをば報告書に作りて送り、さらぬをば寫し留めて、つひには幾卷をかなしけむ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "何心なく係官の机の上の紙きれをみた、彼を連れて来た若い巡査の書いた報告書がのつてゐた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
