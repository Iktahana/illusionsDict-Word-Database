    "definitions": [
      {
        "index": 1,
        "gloss": "to air",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして、テエブルの上にあつたグラスの、琥珀色の酒をぐいと呑み干すと、いきなりまた男の首筋に白い手を卷きつけて、じやれつくやうに短い接吻をその唇に與へた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは青空よい天気まえの家でも隣でも水｜汲む洗う掛ける干す。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気候は、と言うと、ほかほかが通り越した、これで赫と日が当ると、日中は早じりじりと来そうな頃が、近山曇りに薄りと雲が懸って、真綿を日光に干すような、ふっくりと軽い暖かさ。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れた日には庭一面におしめやシャツのような物を干す、軒下には缶詰の殻やら横緒の切れた泥塗れの女下駄などがころがっている。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまでは、とうけて恐る恐る干すと、ややあって、客僧、御身は苦悶し、煩乱し、七転八倒して黒き血のかたまりを吐くじゃ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この茶碗を、一息に仰ぎ干すと、按摩が手を掛けたのと一緒であった。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる用意あってはじめて、自分は無制限と豪快の気持で、その一本を飲み干すことができる。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水天髣髴の間に毛筋ほどの長堤を横たえ、その上に、家五六軒だけしか対岸に見せない利根川の佐原の宿、干瓢を干すその晒した色と、その晒した匂いとが、寂しい眠りを誘う宇都宮の田川の宿――その他川の名は忘れても川の性格ばかりは、意識に織り込まれているものが次々と思い泛べられて来た。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コップを探してましたもんでね、どうも遅くなりました」と、言って盆に水を運んで来た茶店の老婆は、逸作が水を飲み干す間、二人の姿をと見こう見しながら、「そうですとも、娘さんとお婿さんとでたんと泣いてお上げなさいましよ。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "物干へ蒲団を干す時である。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "干すと窄まる木場辺の渋蛇の目、死んだ頭の火事見舞は、ついおもだか屋にあった事。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの布を干す二三人の群を目の粗いカン※スに取つたら嘸愉快の事だらう。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「私は濡れても天日で干すわさ。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小田島はすこしてれた様子で手を止めず、ぐいぐいグラスを呑み干すので、女はいくらか気を呑まれて呆然と見て居た。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "春も半ばとなつて菜の花もちりかかるころには街道のところどころに木蝋を平準して干す畑が蒼白く光り、さうして狐憑の女が他愛もなく狂ひ出し、野の隅には粗末な蓆張りの円天井が作られる。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "早や干す、白き子の衣。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "煤がふります、つんとして妻が物干す鼻のうへ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "（舊作）三黍の穗は、足で揉むで、筵に干す。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡麻のからは、藁につかねて、竿に干す。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つのを開いて見ると、それはからだの下半が干すばって舎利になっていた。",
              "citation": {
                "source": "簔虫と蜘蛛",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "實は梅干すらその時は出し惜しまれたのであつた。",
              "citation": {
                "source": "梅雨紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "可惜、鼓のしらべの緒にでも干す事か、縄をもって一方から引窓の紐にかけ渡したのは無慙であるが、親仁が心は優しかった。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「満蔵、今日は朝のうちに籾を干すんだからな、すぐ庭を掃いてくれろ」　姉はもう仕事を言いつけている。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに籾を干すのである。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は白い衣物を葉鶏頭の側に干すのが好きであつた。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は衣物を櫻の木へ掛けて干す。",
              "citation": {
                "source": "松蟲草",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣物を干すために延ばした其手が非常に白い。",
              "citation": {
                "source": "松蟲草",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "書生が可厭さに商売を遣らうと云ふのなら、未だ外に幾多も好い商売は有りますさ、何を苦んでこんな極悪非道な、白日盗を為すと謂はうか、病人の喉口を干すと謂はうか、命よりは大事な人の名誉を殺して、その金銭を奪取る高利貸などを択むものですか」　聴居る満枝は益す酔を冷されぬ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お婆さんはお掃除が好きで、大好きで、時偶女中がお掃除をしようものなら直ぐまた自分がやりなほすといふふうでした。",
              "citation": {
                "source": "家族",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「春の梅、秋の尾花のもつれ酒、それを小意気に呑みなほす」という場合の「いき」と「息」との関係は単なる音韻上の偶然的関係だけではないであろう。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
