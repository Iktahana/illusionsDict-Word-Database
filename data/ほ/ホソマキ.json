          "literary": [
            {
              "text": "幾度もわたしを不快にした、あの一本の細巻きの洋傘！",
              "citation": {
                "source": "わが散文詩",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "細巻きの大江戸といふ煙草が好きだつた。",
              "citation": {
                "source": "両国橋の欄干",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし犬屋で売ってくれましたら、二人で同じものを手に入れて品評会へ出して、ソレルの夫人を吃驚させてやりましょうって……」と妻はショコラの茶碗を措いて、細巻きの煙草に火を点けた。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペルペチュー修道女と並べると、細巻きの蝋燭に対する大蝋燭のように輝いていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
