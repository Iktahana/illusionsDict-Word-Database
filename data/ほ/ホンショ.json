    },
    "definitions": [
      {
        "index": 1,
        "gloss": "main text",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『あなた学問ある時、私この本書けません。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "此所にそれを再録したのは、詩のスタイルを同一にし、且つ内容に於ても、本書の詩篇と一脈の通ずる精神があるからである。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「佛蘭西文學の旺盛時代たる路易第十四世の朝に於て、突如として一世の耳目を聳動し來れる一書あり、其の簡淨痛快にして靈犀奇警なる人世批評は、天下驚畏の中心となれり、本書是れ也。",
              "citation": {
                "source": "ラロシフコー",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしまひのはうに、「我國人の間にも豈之が紹介の要無しと言はんや、本書の譯ある徒爾ならざるを信ず。",
              "citation": {
                "source": "ラロシフコー",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本武尊東征の途中の遭難とか、義経の大物浦の物語とかは果して颱風であったかどうか分らないから別として、日本書紀時代における遣唐使がしばしば颱風のために苦しめられたのは事実であるらしい。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『日本書紀』や『万葉集』においては大体書き分けてはあるが、しかし幾分か厳重でない所がある。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈良朝の文献は幾つかありますが、その中『古事記』は無論太安万侶一人が書いたものであるが、しかし『日本書紀』のようなものになりますと、数人の編輯者があって、巻ごとに違っているとは言えませぬけれども、巻によって誰かが主になって書いたという違いがあると思います。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな『日本書紀』を見ましても、やはり仮名の二類の区別は同じように守られているのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすれば、これらの語は、上二段活用でなかったかとも考えられるのでありますが、『日本書紀』巻七景行天皇十二年の条を見ると、「乾此云賦」とあって「乾」を「フ」と読ませてあります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十六年二月校訂の時しるす）本書は昭和十二年五月内務省主催第二回神職講習会における講義を速記したものであって、昨年三月｜神祇院で印刷に附して関係者に頒布せられたが、今回｜書肆の請により同院の許しを得て新たに刊行したものである。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は先日、僕の住んで居る鳴滝村のホン屋連中が数名協同してシナリオを一本書き上げた時の事です。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この正月の休暇に八人会で旅をしますが、旅の間に一本書こうかとの話があります。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本書紀第十六巻に記録された、太子が鮪という男に与えた歌にも「ない」が現われており、またその二十九巻には天武天皇のみ代における土佐国大地震とそれに伴なう土地陥没の記録がある。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはいいがその隣にガラスの蔽蓋をして西洋向きの日本書を並べたのがある。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "階下の日本書や文房具の部は、たいていもうくたびれてしまって、見ないですます事が多い。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八雲氏令孫の筆を染めたという書名題字もきわめて有効に本書の異彩を添えるものである。",
              "citation": {
                "source": "小泉八雲秘稿画本「妖魔詩話」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "他日機会があったらもう少し補充してまとめたいと思っているが、本書所載の他の論文にしばしば引き合いに出ている関係上参照の便宜のためにこのままここに採録した次第である。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天長節の佳日に際し　　子爵　　伊東海軍大將　　　　　　肝付海軍少將　　伯爵　　吉井海軍少佐　　子爵　　小笠原海軍少佐　　　　　　上村海軍少佐各位の清福を賀※、つたなき本書のために、題字及び序文を賜はりし高意にむかつて、誠實なる感謝の意を表す。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪木に比すれば私の狭い自由もまだ大きな範囲で、燕木は手紙一本書くすら容易に許されない身でした。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪木に比すれば私の狹い自由もまだ大きな範圍で、蕪木は手紙一本書くすら容易に許されない身でした。",
              "citation": {
                "source": "計畫",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "本書の標題「青猫」の意味について、しばしば人から質問を受けるので、ついでに此所で解説しておかう。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）本書に納めた私の散文詩も、勿論さうした種類の文學である。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "健脳な読者の中には、ずっと昔、自分と室生犀星等が結束した詩の雑誌「感情」の予告に於て、本書の近刊広告が出ていたことを知ってるだろう。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら本書の出版が、一切を完全に果すことを信じたからだ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（実に或る意味からみて、本書は一種の小説論でさえある。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本書はこの曖昧をはっきりさせ、詩の詩たる正体を判然明白に解説した。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人が本書で説こうとするのは、こうした個人的の詩論でなくして、一般について何人にも承諾され得る、普遍共通の詩の原理である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで本書は、この普遍的な解答をするために、内容と形式との、二つの方面から考察を進めて行こうと思っている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで本書の前半を内容論とし、後半を形式論とし、前のものの肖像が、後のものの鏡面に映り出してくるように、論述を組織したいと思っている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
