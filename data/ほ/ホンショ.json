  {
    "uuid": "8d9e7fb9-8913-560f-ac78-77b79b0ddf0f",
    "entry": "本所",
    "reading": {
      "primary": "ほんしょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "main office",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "長男が中学校の始業日で本所の果てまで行っていたのだが地震のときはもう帰宅していた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうでもない　矢張男等が云う通りにちがいないようであった明治34年２月『ほとゝぎす』署名　　本所　さちを",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治33年10月『ほとゝぎす』署名　　本所　幸男",
              "citation": {
                "source": "草花日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも本所深川あたりの遠方からはじめ、おひおひ市中いつたいにおよぼしてくる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく煙草專賣局の本所工場觀覽招待に同行を約した内田誠君から、久保田夫人告別式の歸途自動車事故で足に負傷したのでお伴出來ぬと斷りの電話が掛かる。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで馬場孤蝶先生と二人だけで行く事になつた譯だが、お宅へお迎ひになどと思つてゐる矢先ちよつとした客來があつたので、お約束のまま午後一時に京橋の明治製菓賣店の前で先生と落ち合ひ、すぐ本所工場へ向つた。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからそれと探し歩いて、ようよう今朝になって本所の安泊りに一人いるのを見付けたんですが、どうしましょう」「幾つぐらいの奴だ」「さあ、二十七八でしょうかね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで本所へ渡る船を待っていると、一と足おくれてこの渡へ来たのは菅笠をかぶった四十恰好の色の黒い男で、手甲脚絆の草鞋がけ、頸に小さい箱をかけていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "船が本所の河岸へ着くと、半七はまずひらりと飛び上がった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛇を種に遣ったところは巧く考えましたね」「その蛇は御符売りのを盗んだんですか」「本所の安宿に転がっていると、丁度そこへ池鯉鮒の御符売りが泊り合わせたもんだから、それからふと思い付いて、その蛇を一匹盗んだんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "横川は業平橋報恩寺橋長崎橋の下を経、総武鉄道汽車の発著所たる本所停車場の傍を過ぎ、北辻橋南にてかの隅田川と中川との連絡するところの竪川に会し、南辻橋菊川橋猿江橋の下を過ぎて小名木川に会し、扇橋その他の下を過ぎて十間川に会し、なほ南して木場に至る。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "本所側にありては電燈会社対岸の下に当りて東に入るの小渠あり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて隅田川いよ／＼下りて、浅草瓦町、本所横網町まさに尽きんとするのところに至れば、○富士見の渡といふ渡あり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "○百本杭は渡船場の下にて、本所側の岸の川中に張り出でたるところの懐をいふ。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "竪川は一之橋二之橋竪川橋三之橋新辻橋四之橋等の下を経て、大島村小名木村亀戸村深川出村本所出村等の間を千葉街道に沿ひ、終に中川逆井橋下流に出づる一水路にして、甚だ重要なる一渠なり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは活動写真の挿曲から行はれたので、原意は必ずしも此度の惨事を予言したのでも何でも無いが、大震大火が起つて、本所や小梅、到るところ河原の枯芒となつた人の多いに及んで、唱ふ者はパッタリと無くなつたが、回顧すると厭な感じがする。",
              "citation": {
                "source": "震は亨る",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば東京市の近年の火災について少しばかり調べてみた結果でも、市民一人あての失火の比率とか、また失火を発見して即座に消し止める比率とか、そういう人間的因子が、たとえば京橋区日本橋区のごとき区域と浅草本所のごとき区域とで顕著な区別のあることが発見されている。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "本所地先の隅田川百本杭は抜き去られて、きれいな石垣になった。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "安政の頃本所南割下水に住んで、祿高千｜石を領した大御番役、服部式部の邸へ、同じ本所林町家主惣兵衞店、傳平の請人で、中間に住込んだ、上州瓜井戸うまれの千助と云ふ、年二十二三の兄で、色の生白いのがあつた。",
              "citation": {
                "source": "片しぐれ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よこしぶき　さても、其の後、江戸で元二が身を置いた處は、本所南割下水に住んで祿千石を領した大御番役服部式部邸で、傳手を求めて同じ本所林町、家主惣兵衞店、傳平と云ふもの請人で齊く仲間に住込んで居たのであつた。",
              "citation": {
                "source": "二た面",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、嘘か眞か、本所の、あの被服廠では、つむじ風の火の裡に、荷車を曳いた馬が、車ながら炎となつて、空をきり／＼と※つたと聞けば、あゝ、その馬の幽靈が、車の亡魂とともに、フト迷つて顯はれたかと、見るにもの凄いまで、この騷ぎに持ち出した、軒々の提灯の影に映つたのであつた。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの利根川圖志の中に、……えゝと――安政二年乙卯十月、江戸には地震の騷ぎありて心靜かならず、訪來る人も稀なれば、なか／＼に暇ある心地して云々と……吾が本所の崩れたる家を後に見て、深川高橋の東、海邊大工町なるサイカチといふ處より小名木川に舟うけて……」「また、地震かい。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか四谷の堂の扉をのぞいて、眞暗な中に閻王の眼の輝くとともに、本所の足洗屋敷を思はせる、天井から奪衣の大婆の組違へた脚と、眞俯向けに睨んだ逆白髮に恐怖をなした、陰慘たる修羅の孤屋に比べると、こゝは却つて、唐土桃園の風が吹く。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なほ同一川筋を、扇橋から本所の場末には、天井の裏、壁の中に、今も口寄せの巫女の影が殘ると聞く。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本所の一ツ目を見ねえな……盲目が見つけたのからして、もうすぐに辨天だ。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本所から辛うじて火を免れて避難をして居る人だつた。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……本所、麻布に續いては、この邊が場所だつたと言ふのに、あゝ、その狸の影もない。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、銀座、日本橋をはじめ、深川、本所、淺草などの、一時に八ヶ｜所、九ヶ｜所、十幾ヶ｜所から火の手の上つたのに較べれば、山の手は扨て何でもないもののやうである、が、それは後に言ふ事で、……地震とともに燒出した中六番町の火が……いま言つた、三日の眞夜中に及んで、約二十六時間。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
