        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼が球を高く高く放り上げる姿をみた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそれを、巧みに放り上げると、そこから、私の上へ飛び降りようとした。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを手早く拵えて、持っていって、あてもなくやんまのかがいの中に放り上げる。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはひじょうに神秘な力をもっていて、ほんのちょっとした力でもってすごい爆発をおこし、御本人を運命の舞台へ、ドーンとほうりあげるのだ。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒紋付白小倉のはかま、キリッとしたようすで、竹矢来のなかにすすむと、たもとのなかから一条のひもをとりだし、空中たかく、それをほうりあげると、ひもは北のやぐらのてっぺんにかかって、そのままクモの糸にもにた銀色の、ほそいほそいハシゴになるのです。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "珊瑚質のかたい地面を、ごつん、ごつん、とほりさげ、シャベルで砂をすくって、ほうりあげるのだが、大男は、はだかの全身、水をあびたような汗。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手をつないだままボトムへ降りていき、おたがいに相手をスロープの上にほうりあげるようにターンをきめ、波の頂上へ向けてのぼった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑顔のナミは、楽しそうな大声で、高くほうりあげるように、みじかくうたった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
