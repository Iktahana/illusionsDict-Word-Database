    "definitions": [
      {
        "index": 1,
        "gloss": "horn (speaker, klaxon, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かの青空高くひびきわたるかたつむりのメガホーンの声でした。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたつむりの吹くメガホーンの声はいともほがらかにひびきわたりました。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが丁度その時、又もや青ぞら高く、かたつむりのメガホーンの声がひびきわたりました。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベンダーさんが最初にお出かけして、それからインディアンのピート、次はマグレガーの奥さん、次はジョニー・ホーンズ、次は、嬢ちゃん、君のママだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィリヤム・ホーンの書を見ると、下等な店では蛇を代用するもあるらしい。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "半途で駐って右手に持った鎗を下げ左手で旗を三度振って宮廷を礼し、また走り登って鐘塔に入り徒歩で出で最高の絶頂に上り、金の天使像に坐って旗を振る事数回、鐘塔に還って騎馬し復び綱を走り降った（ホーンの『机上書』五四〇頁）。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホーンの『ゼ・イヤー・ブック』一八六四年版一二六頁に、豕能く風を見るてふ俚言を載す。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一つ豕に因んだ例を挙げんに、ホーンの『テーブル・ブック』一八六四年版一九〇頁にいわく、数年前エールス人ダヴッド・ロイドが、ヒャーフォードで、六脚ある牝豕をその一膳飯店に飼ったからたまらない。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "――コルネツトとかホーンとか云ふ楽隊用の奴さ。",
              "citation": {
                "source": "蝉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ホーンといふのは何んな形なの？",
              "citation": {
                "source": "蝉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本で開かれた「パーソナルコンピュータの未来像」におけるケイの講演によれば、このシステムはのちにリサとマッキントッシュのファインダーを開発したブルース・ホーンが、一五歳のときにパロアルト研究所で書いたものであるという。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆっくり厚紙の表紙をめくりながら、「チホーン・アルフィモヴィッチ・グリーゼル」　ソラ来た！",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本事件はエレーナ・アレークサンドロヴナ・パタキンによって、チホーン・アルフィモヴィッチ・グリーゼルに対して提起された養育費請求に関する訴訟です」　爺め！",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「私工場へ働きに出たことはないし、どうしようと思ってたら、チホーン・アルフィモヴィッチが、ソヴェトに知っている者がいるから、野菜の許可露天商人に世話してやるって云ったんです」「それが今の職業ですね」「ええ」「どうして真直職業紹介所へ行かなかったんですか？",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "メガホーンで何か叫んでいるぼやけた人間の声。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Samuel Butler――Erewhon.（エレホーン）nowhere を逆に綴ったのであって、彼の皮肉的理想郷を提示しているのである）Erewhon Revisited.（エレホーン再訪問記）　最後の種類に属するもの。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "三角｜暗礁にて――クロクロ島の紛失　望遠鏡に、ケープ・ホーンの、鬼気迫る山影がうつったかと思う間もなく、南米大陸は、ぐんぐんと後に小さくなって、やがて視界に没した。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳が遠いといえば尾崎行雄氏が与謝野さんの歌会へお出になって、いつも聴音器（イヤホーン）を卓に置いていられたお姿を思出すので、私も使って見ましたが、工合よくまいりません。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "俊爾　　おい、好子、そこにあるイヤホーンをお父さんにとつてあげなさい。",
              "citation": {
                "source": "雪だるまの幻想（ラジオ・ドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（イヤホーンをかけたことがわかるやうに、声をやや普通の調子に落し）きのふから、度々、申しあげたやうに、お父さんは、不自由はかまはんとおつしやるけれど、われわれ子供の立場からは、それを黙つて、ほうつとくわけにいかんのですよ。",
              "citation": {
                "source": "雪だるまの幻想（ラジオ・ドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人　　もうイヤホーンは外してもいいか？",
              "citation": {
                "source": "雪だるまの幻想（ラジオ・ドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、かの有名なるウィンパアが、マッターホーン登攀に成功した話、下山の途中起った悲劇、それ等に関してロープが如何に重大な役目をつとめているかを思えば、これこそ登山具中の王者とも云う可きである。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその時すでにアレッチホーンを百回ばかり登っており、ネストホーンに至っては何度登ったか覚えていられない程であった。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　カリフォルニア黄金狂時代　ニューヨークを出た船はケープホーンを廻って太平洋へ首を出すまでには、立派に喜望峯をめぐってインド洋へ出ていられる。",
              "citation": {
                "source": "汽船が太平洋を横断するまで",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "無人の広野はかくて四九年の末までに約十万の人間を呼集め、うち陸の幌馬車組が五万二千、のこりはことごとくケープホーンに帆を光らせる海のゴールドラッシュである。",
              "citation": {
                "source": "汽船が太平洋を横断するまで",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三百三十年の間、太平洋に向うヨーロッパの全商業は、感心すべき気永さであるいは喜望峯を、あるいはケープホーンを迂回して行われてきた。",
              "citation": {
                "source": "汽船が太平洋を横断するまで",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケープホーン迂回航路は古くなった。",
              "citation": {
                "source": "汽船が太平洋を横断するまで",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆船によるシナ貿易はケープホーンを迂回するとき、長期の航海日数を要するため非常な不便を嘗めている。",
              "citation": {
                "source": "汽船が太平洋を横断するまで",
                "author": "服部之総",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
