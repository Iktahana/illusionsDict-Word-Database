    "definitions": [
      {
        "index": 1,
        "gloss": "principle of laissez-faire",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
