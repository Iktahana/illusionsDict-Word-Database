    "definitions": [
      {
        "index": 1,
        "gloss": "Hōreki era (1751.10.27-1764.6.2)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "風の強さの程度は不明であるが海嘯を伴った暴風として記録に残っているものでは、貞観よりも古い天武天皇時代から宝暦四年までに十余例が挙げられている。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物の縞柄としては宝暦ごろまでは横縞よりなかった。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「熨斗目」の腰に織り出してある横縞や、「取染」の横筋はいずれも宝暦前の趣味である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、宝暦、明和ごろから縦縞が流行し出して、文化文政には縦縞のみが専ら用いられるようになった。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都方言では享保・宝暦頃には大体ｈ音になっていたようであるが、元禄またはそれ以前に既にｈ音であったのではないかと思われるふしもある。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "六世弥忠太は番方を勤め、宝暦六年に致仕した。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このあいだも話した通り、僕の家の六代前の主人は享保から宝暦のころに生きていたのだそうで、雅号を杏雨といって俳句などもやったらしい。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "九代家重公の宝暦の初めっ方。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "青山銀之丞は、宝暦元年の冬、御書院の宝物お検めの日が近付く前に、今までの罪の露見を恐れ、当座の小遣のために又も目星しい宝物を二三品引っ抱えて、行衛を晦ましてしまったのであった。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その宝暦二年の三月初旬。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "明くれば宝暦二年の三月十五日。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面に名娼満月之墓と金字を彫り、裏に宝暦二年仲秋行年二十一歳と刻んである。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い人は筑前の出生、博多の孫一と云ふ水主でね、十九の年、……七年前、福岡藩の米を積んだ、千六百｜石の大船に、乗組の人数、船頭とも二十人、宝暦午の年十月六日に、伊勢丸と云ふ其の新造の乗初です。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（博異記）　　　蒋武　唐の宝暦年中、循州河源に蒋武という男があった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "白猿伝・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "その三　宝暦三年、正月五日の夜のことである。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸田とよ女の敵討は、丸亀藩孝女の仇討として、宝暦年間の江戸市中に轟き渡った。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "とよ女の孝節が、藩主の上聞に達して、召し還された上、藩の家老の次子を婿養子として、幸田の跡目を立てられて、旧知の倍の百石を下しおかれたのは、同じ宝暦五年の九月のことである。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "出雲の法名は「文明院岑松立顕居士」で、同寺保存の旧過去帳を見ると、宝暦六年十一月四日歿といふ事になつてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし宝暦の頃、江戸に菅大助といふ書肆が居た。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句の句法は貞享、元禄に定まりて享保、宝暦を経て少しも動かず。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝暦のころなりけん、京に帰りて俳諧ようやく神に入る。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は宝暦×年の今月今日に生れましたから、今日で丁度、満百五十歳になるので御座います。",
              "citation": {
                "source": "血友病",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "文台の裏面には短文と発句とありて宝暦五年蕪村と署名あり。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝暦五年は蕪村四十一の年なれば蕪村の書方もいまだ定まりをらざりしにや。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
