    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese scallop (Patinopecten yessoensis)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
