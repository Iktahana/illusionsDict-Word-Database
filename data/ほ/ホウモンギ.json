    "definitions": [
      {
        "index": 1,
        "gloss": "semi-formal kimono for women",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "指定された通りに裏門の潜り戸から這入ると、そこいらのベンチに待っていたらしい訪問着姿の未亡人が出迎えた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅かの間に櫛巻髪を束髪に直して、素晴らしい金紗の訪問着の孔雀の裾模様を引ずりながら、丸々と縛られた維倉青年の前に突っ立った。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お気の毒でしたわね」「…………」　維倉青年はギリギリと歯を噛んで、眼の前の訪問着を見上げた。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめ、まだ一度も袖をとおさぬ訪問着が、すっと無くなっているのに気附いた時には、さすがに節子も顔色を変えた。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その訪問着は、とうとうかえって来なかった。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その訪問着だけでなく、その後も着物が二枚三枚、箪笥から消えて行くのだ。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奥さんも、顔は少々二の町だけれど、派手な訪問着なんか着て、この人はただ人柄がいいというだけのものなの。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日では帯が極度に発達致しましたし、きものも訪問着など出来まして真に立派な服飾時代に入りましたが、現在の帯は余りに広巾すぎて、私達は今後何とか改良されるべきものであるという事を考えさされています。",
              "citation": {
                "source": "帯の巾が広すぎる",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、四年前に拵えたまま、まだ一度も手をとおさなかった訪問着が夜具の上にそっと置かれていた。",
              "citation": {
                "source": "死のなかの風景",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という生地かわからぬ金線入、刺繍裾模様の訪問着に金紗の黒紋付、水々しい大丸髷だ。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はーイ」　と返事がして、派手な訪問着を着たウェイトレスがパタパタと駈けてきた。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "コートの下には小紋らしい紫がかった訪問着がしなやかに婦人の脚を包み、白足袋にはフェルト草履のこれも鶯色の合わせ鼻緒がギュッと噛みついていた――それほど鮮かな佐用媛なのに、そのひとの顔の特徴を記憶している者が殆んど無いという全くおかしな話だった。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人さま」　ママは大いそぎで身じまいをすると、訪問着に半礼装のシャールをかけて招待のお礼に行った。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛一郎が操縦席におさまると、暁子はすっきりした地色の訪問着の袖を庇いながら、「あたくし、助手」　と愛一郎のとなりのシートに辷りこんだ。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "真名古はその顔に眼を注ぎながら、「まだじかに一度も逢ったことはないのだね、残念だな」「でも、訪問着のお仕立をホテルへお届けすることになってますから、近々お目にかかれますわ」　と答えると、顎を襟に埋めて急に考え込んでしまった。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "御注文の御訪問着を持参いたしましてございます。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今朝、鶴子がやられたと聞いたとき、わちきは、てっきり花の仕業だと睨んだんだ……わけってえのは、ちょっとゾッとするような話なんだけど……」　踏絵はジロリと上目使いをして、「去年の十二月初めごろ、わちきは訪問着の仕立をせかせに行くと、花はどこかへ行っていない。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "私、気味が悪いんですもの、変な事ばかり仰しゃるから」　礼子は帽子と手袋をかなぐり捨てて、意気な訪問着のまま私の身体へ全身的に凭れて来るのでした。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第四夜　恋の不在証明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミセス・レイマンはその老年にかかわらず、レースの訪問着はややつかれているにかかわらず、いくらか頬の艷があせているだけで、イギリス婦人らしいしっかりとした骨格と血色を失っていなかった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おはしょりがゆるんで派手な訪問着の前褄がカーペットの上にずりおちた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間にお嫁さんは立って黒の裾模様を訪問着にかえ、すこし坐っていて又立って、こんどは友禅のものにかえ、又すこし立って別の着物にかえ、そしてこちらの親族の一人一人に「不束な者でございますが何卒よろしく」と挨拶してはお盃を出します。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "八日に十時から、こんどはあたり前の髪と訪問着とでお里へ夫婦、母上とで出かけ、十二時何分かで戸田まで立った由です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よく勤めた娘だから、別れにわしも線香の一本も手向けねばなるまい」　朝顔の浴衣を着せられ、錦紗の訪問着を逆さにかけられた奈世の、世間の娘とは変わって電髪をかけたことのない黒髪が、布団の上に豊かに這って居た。",
              "citation": {
                "source": "面",
                "author": "富田常雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "褪紅色の上品な訪問着を着けて綺麗な優しそうな眼は幾分疲れを帯びた風情に恍惚と見開いていたが、こないだホテルで逢ったとおり、まず感じは一口に言って豪奢というのが一番当て嵌っているように思われた。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "浄吉ハタキシード、颯子ハ訪問着。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "猪首の夫人が、肥った体を裾模様のある訪問着につつんで、気どりながら門のなかへ入ってきた時、牧の奥さんは丁度女中たちを指図して、土塀の内側に大根を乾しているところであった。",
              "citation": {
                "source": "南方郵信",
                "author": "中村地平",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の訪問着姿に感心して、一揃えお拵えになったくらいの日本贔負でいらっしゃいます。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなり訪問着を着たりすると、おみやげのこけしさんのようになるわね。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
