    "definitions": [
      {
        "index": 1,
        "gloss": "religious ecstasy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
