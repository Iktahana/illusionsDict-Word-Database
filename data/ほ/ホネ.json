[
  {
    "uuid": "d49efa01-d1a9-5d39-b0e6-a39299f28659",
    "entry": "骨",
    "reading": {
      "primary": "ほね",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
