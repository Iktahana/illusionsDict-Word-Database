    },
    "definitions": [
      {
        "index": 1,
        "gloss": "form",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは如何なる点に存するか明白に自覚し得ないが、やはり子音母音の反復律動に一種の独自の方式があるためと思われる。",
              "citation": {
                "source": "宇都野さんの歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台の奥に奏楽者の席のあるのは能楽の場合も同様であるが、正面に立てた屏風は、あれが方式かもしれないが私の眼にはあまり渾然とした感じを与えない。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "事がらが、見方によってはある有限数の型式的要素の空間的排列の方式に関するものであると見る事ができるからである。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくもこれらの名前を一定の方式に従って統計的に取り扱い、その結果がよければ前提が是認され、悪ければ否定されるのである。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、少なくともそれに近づくようにわれわれの言語、というかあるいはむしろ思考の方式を発育させる事はできるかもしれない。",
              "citation": {
                "source": "数学と語学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たくさんな弦線の少しずつ調子の狂ったのを、一定の方式に従って順々に調節して行く。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かるが故に象徴的表現しか自己を表現し得ない場合に於て、換言すれば或る刹那に於ける自己表現の方式として唯一の象徴的表現が存在する場合に於て象徴的表現は最大の効果を発輝するのである。",
              "citation": {
                "source": "俳句に於ける象徴的表現",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして文芸に於ては詩、殊に俳句は性質上又形式上かくの如き境地をかくの如き方式によって表現せざるを得ないのである。",
              "citation": {
                "source": "俳句に於ける象徴的表現",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　短歌に於ける有機的な内部律（調べ）とは、言語の構成される母音と子音とから、或る不規則な押韻を踏む方式であり、日本の歌の音律美は、全くこの点にかかっている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが論理の原則であり、我々の推理の方式は、いつでもこの前提の上に組みたてられる。",
              "citation": {
                "source": "非論理的性格の悲哀",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眺めたままの人生の事実だけでは何の奇もないことも、それに或る物を加工し、それを一定の方式に従って取扱う時、たちまち、意味のある面白いものとなることがあるんだ。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの方式を知らなければちょっと解けそうもない方程式が、あれ一つですぐに出来てしまう。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした芸術進化の二方式の優劣論は暫くお預りとして、事実「能」は斯様な進化の方法を非常な努力と自信の下に執って来た、世界に稀な芸術である。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "意気筋では、よくは存じませぬが、江戸前の「ツンケン型」、上方式の「京人形型」、「オキャーセ型」、「アキマヘン型」、「バッテン型」なぞいうのが、その地方地方のこうした社会の気前を代表しているのだそうであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "請負師や大工に責めを帰していいのか、在来の建築方式そのものに欠陥があるのかどうかわからない。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、よい記憶で、「方式」どおりにやるということが、うまく勝負をする秘訣だと一般に考えられている点である。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "原盤からプレスする方式で数百枚まとめれば、一枚三百円前後でケースに収めたＣＤ―ＲＯＭが出来上がります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "活版印刷の方式から説き起こし、写植機の誕生からコンピューター化に至る流れを跡付け、その延長上にＤＴＰの登場の意義が位置づけられていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パイオニアのレーザーディスクは、いくつかあったヴィデオディスク方式の最有力候補でした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロヴァイダーに電話をかけて繋ぐ、いわゆるダイヤルアップの方式では、スピードが遅すぎる。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "辞書をネットワーク越しに開くようになると、百科事典の類もこの方式に限るとあらためて確信しました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぞるべき原本を何分冊かにわけ、並行して書き写しの作業を進める方式が確立されます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦組み、ページめくり方式に加えて、青空文庫で使っているルビ記号を振り仮名として表示するビュワーが幾つも開発され、利用されている。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "パソコン上で読む際の負担を軽減する手法として、多くのビュワーが縦組み、ページめくり方式を取り入れている。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、複数の変換候補からそのつど選んでいく方式で、パソコンにおける日本語入力が広く普及したように、修正しながら作業することを前提に、新しいタイプの点訳ソフトの活用も広がって行くだろう。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦組み、ページめくり方式のテキストビュワーのほとんどは、自由に文字サイズを変更できる。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし時間を切り分けることからタイム・シェアリング・システムと呼ばれるこの方式を取れば、仕事のペースの遅い人間がコンピューターと向き合いながら作業することが可能になる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし今、ソフトウエアの側からノートブック・マシンに向けて押し出されてきた第二の情報家電の試みは、ＭＳ―ＤＯＳという標準技術を背景にしている分、メーカー固有の方式の縛りを逃れた、より普遍性を持った美しい解答を提供してくれる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方大地は、ＤＴＰの標準候補に背を向けて独自方式を取った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一通の指示書が、この方式に対応した全ての出力機でそのまま変更なしに通用する。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
