        "examples": {
          "standard": [
            {
              "text": "このラーメンの味は、まさに『ほんけほんもと』の伝統的な製法を守っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "先祖代々受け継がれてきた、『ほんけほんもと』とも言えるこの屋敷に住んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この芸術様式は、『ほんけほんもと』とも言える〇〇（人名や場所）から始まったと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "まだ御当人は死ぬなどとは思わず、本卦還りの歳になったら南の演舞場を借りて花々しい会を催すのだと云っていたことなど。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            }
          ]
        }
