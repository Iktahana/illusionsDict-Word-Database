        "examples": {
          "standard": [
            {
              "text": "スマートフォンには、内蔵メモリの他にSDカードなどの補助記憶が利用できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "パソコンの容量が足りなくなったので、外付けハードディスクを補助記憶として追加した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "重要なデータは、クラウドサービスなどの補助記憶に定期的にバックアップを取るべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "第三に、これまで補助記憶装置として使われてきたカセットテープレコーダーも、接続できるようにする。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＨＣ―20の本体には、液晶のディスプレイに加えて、補助記憶として使うマイクロカセットレコーダーと小さなプリンターまで組み込まれており、西はこのマシンにもマイクロソフトのベーシックを売り込んでいた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "今後のハードウエア技術の進歩を見込めば、一九八〇年代の半ばには高解像度のディスプレイ、一Ｍバイトのメモリー、一〇〇Ｍバイトの補助記憶を備え、一ＭＩＰＳの処理能力を備えたマシンが一万ドル程度になると予測できると提案は主張した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
