    "definitions": [
      {
        "index": 1,
        "gloss": "book",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やがてケシの花だつたかを買つて円タクに帰つて来ると、その男は花を一本づつ我々に配つた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本づつ持つて牧野さんを訪ねるといふのである。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がこの本を初めて知つたのは大正十四年の暮であつたかその翌年の初めであつたか、とまれ寒い頃であつた。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮沢賢治全集刊行に際して中原中也　宮沢賢治全集の、第一回配本が出ました。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨、魂はにがい深淵だぞといふやうなことを我々日本人が云ふと、一寸そぐはない感じがしよう。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊本へ出張して一と晩久しぶりで旅人の気分で歩いたが、熊本といふ所はいい所です　火山地方特有の落付がありますとも書いてゐた。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝろ宮沢賢治曇りてとざし風にゆるそれみづからぞ樹のこゝろ光にぬるみ気に析くるそのこと巌のこゝろなり樹の一本は一つの木規矩なき巌はたゞ巌",
              "citation": {
                "source": "こゝろ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論其処にもその原因の説明に役立つ材料はあるかも知れぬが、根本原因はそんな所にはない。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり他力本願が必要だと思ふのだ。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは何も人々が短歌に不熱心であつたといふやうなことではなく、短歌様式そのものが本来さうしたものであるやうに思はれる。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の出した本にどんな本があるかも知らないが、リヴィエールのランボオ論とモオリヤックのイエス伝――結局彼の死の前年に出した此の二つの翻訳書だけが私の頭に残つてゐる。",
              "citation": {
                "source": "逝ける辻野君",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩原朔太郎評論集　無からの抗争中原中也　萩原氏の本はよく売れるさうである。",
              "citation": {
                "source": "萩原朔太郎評論集　無からの抗争",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから氏の本がよく売れることは、私としても喜びである。",
              "citation": {
                "source": "萩原朔太郎評論集　無からの抗争",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一種の率直な果敢性をもつ、本能的なその芸術は、その暫く後にいたつて、人々が意志と探究との結果、漸く得た新風を、サツサとやりおほせてゐるのであつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "木一本ない野原とて、却々街よりは変化に富んでゐます。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際文壇に出ることが容易になつた此の頃は、さういつた文学青年も少くないことで、一知半解の故に却て元気がいいといつた風の元気が、本当の元気と間違へられる風景は、毎日のやうに見受けられることである）。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本文学にしろ外国文学にしろ、その作品の「流れ」の諦視、「持続ぶり」「終始ぶり」の諦視、さてはフォルムに就いての理念、その涵養が今日我々の緊急事である。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今仮りに芸術不振の根本理由を規定してみるならば次の如きものである。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "響くといふこともないけれども、何かしら本当に仕事してゐるものを却て一時的とはいへ吃驚させたりするのだ。",
              "citation": {
                "source": "文学に関係のない文学者",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も此の外観は真の詩からなつてをり、彼はそれを、全ての本物の芸術家の如く、天才の一撃で以てその暗い色と蒼白い色とを強調することに依つて獲得してゐる。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一韻文音楽家たるには余りに芸術家であつた彼は、その形式の中に、根本的に絵画の或る物を持つてゐた。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕と節野とは、教室で可なり口をきき合つたのであり、一緒に酒場なぞにも行つた男であるが、それでも彼の昼間通つてゐる日本大学の同級生が其の場に来合せたりすると、その方が主になるのである。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚れ易く、破れ易く、着くづれし易く、こんな服装を讃へなければならない我々日本男児は、なんとなく不幸であるやうに思へる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には、それはおまへの今ゐるのが何の変哲もない峠道のことで、闇夜のことだし草一本満足には見えぬ有様だからだらうなぞ思ふ人もあるかも知れぬ。",
              "citation": {
                "source": "深夜の峠にて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程草一本満足には見えぬ。",
              "citation": {
                "source": "深夜の峠にて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は前夜の飲過ごしでぐつたりして、少し卓子の割合には高過ぎる椅子に腰掛けて、煙草を喫つたり本を読みかけてみたり、と、急に思ひ出して此の日頃方々で受取つた名刺の整理をしたり、――要するに何の野心もなく、その日第一回の食事を済ましたばかりのところであつた。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、俺のこの宿酔の頭では、一杯ひつかけてから行かなければ、とても相談にはのられやしないぞ」といふやうなわけで私はまたも其処に入り、どうせこんな所の日本酒はまづいからと思つたのでビールを註文。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本飲み終つた頃、また後から一人来た、今度は先のよりは少し綺麗、デツプリ太つて自信がおありだ。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに良いお天気の日に　　お別れしてゆくのかと思ふとほんとに辛い　　こんなに良いお天気の日にさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕さむしい Hotel の臺所で、のすたるぢやのメリイが泣いて居る、ほんのり光る玉菜のかげから、ぜんまい仕かけで、鼠がひよつくり顏を出した。",
              "citation": {
                "source": "玩具箱",
                "author": "―人形及び動物のいろいろとその生活―",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
