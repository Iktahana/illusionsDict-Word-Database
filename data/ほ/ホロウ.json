[
  {
    "uuid": "bc84d388-4dbf-5373-b6c6-85a4c419581b",
    "entry": "歩廊",
    "reading": {
      "primary": "ほろう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
