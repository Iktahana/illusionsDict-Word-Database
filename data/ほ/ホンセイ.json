    "definitions": [
      {
        "index": 1,
        "gloss": "real or original name",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "曰く、清葉、曰く令夫人で可いものを、誰が詮索に及んだか、その住居なる檜物町に、磨込んだ格子戸に、門札打った本姓が（滝口。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は止むなく本姓に復歸することにだけは成りましたが然し私は落魄の故に貞淑な妻を捨てることは出來ません。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "一　淡島氏の祖――馬喰町の軽焼屋　椿岳及び寒月が淡島と名乗るは維新の新政に方って町人もまた苗字を戸籍に登録した時、屋号の淡島屋が世間に通りがイイというので淡島と改称したので、本姓は服部であった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故、維新後は本姓の服部よりは世間に通りの好い淡島と改称して、世間からも淡島と呼ばれていたが、戸籍面の本姓が小林であるばかりでなく、事実上淡島屋を別戸していた。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "沼南は本姓鈴木で、島田家の養子であった。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人は元萩原国吉といいましたが、後に実家の山本姓に復し号を瑞雲と改めました）。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "皇居御造営の事、鏡縁、欄間を彫ったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "森垣さんはそれ以来、本姓の内田をすてゝ養家の苗字を名乗ることになったのです。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は本姓を梅沢君といって、年はもう四十を五つ六つも越えているが、非常に気の若い、元気のいい男である。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "小奴の本姓は坂本といふのであつた。",
              "citation": {
                "source": "石川啄木と小奴",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし市兵衛の本姓は劉であるので、安永四年に名を梅卿と改めてからは、劉梅卿とも称してゐた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その本姓に復したのは維新後の事である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞白は本姓磯野、名は元亮、俗称勝五郎である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」石川貞白、名は元亮、本姓は磯野氏である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "昌盈は其本姓を知らない。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "関藤氏の家乗に拠れば、藤陰は戊辰十二月三日に本姓に復し、中岡才助に石川氏を譲つたのだと云ふ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に聞けば、直は幾ならずして吉田氏を去り、一たび甲斐氏を冒し、遂に本姓｜前原に復して終つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "老爺さんは、湯川というのも自分の本姓ではない。",
              "citation": {
                "source": "木魚の顔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに依ると、淡路の假屋から植村文樂軒（本姓は柾木）と云ふ人が現れて、高津橋（今の高津四番地）南詰西の濱側で人形淨瑠璃を興行した、これが文樂座創始で、時代は明和とも天明とも云ふが確かでないとある。",
              "citation": {
                "source": "淡路人形座訪問",
                "author": "竹内勝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れは何故本姓ではいけないのか、あれは法律で名前だけにしろと定めてある譯でなく各自が勝手に假の名を用ひるので、夫れも是非とも用ひなければならないといふ規定がある譯ぢやなし、であるから余は姓迄も改めて居るのだと言へば夫れまでだが、男子が筆を取つて天下に見へるのならば須らく堂々とやるべしだ。",
              "citation": {
                "source": "貝殼追放",
                "author": "愚者の鼻息",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが慣習とか或はさうするに至る歴史とか故事とかがあるといふならば名前だけ雅號を用ひて、姓は本姓にして置けばよいではないか、何うだらう此事は？",
              "citation": {
                "source": "貝殼追放",
                "author": "愚者の鼻息",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚古堂は本姓を本居信久、当時一流の好事家で、海舟の屋敷へ出入りをしていた。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その浪人は平戸九十郎――本姓臼杵九十郎であった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人は貝をとる潜水夫のうちでも、名人とよばれた太海｜三之助の一人息子でありましたが、海亀を助けてやつて、海亀に助けられたところから浦島といふあだ名がついて、後には浦島今太郎といふ通名になつて、誰も本姓太海を呼ばなくなりました。",
              "citation": {
                "source": "動く海底",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも、その女の本姓をいって電話をかけたので、電話口へ出た婢衆らしい女に、こちらの名をいわず、それとなく、「もしもし、あなたは松井さんですか。",
              "citation": {
                "source": "狂乱",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "能登守の語るところによれば、南条の本姓は亘理といって、北陸の浪士であるとのこと。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この系図は徳川時代になって、秋田実季が自身調査を重ねて編纂したもので、その安倍という本姓は、先祖の安日という名を取ったというのでありますが、しかしその説の由来はすこぶる古いもので、すでに津軽浪岡家の永禄日記十年の条に、同地岩木神社の祠官阿部氏が、やはり同様の系図を持っていた趣きに見えております。",
              "citation": {
                "source": "本州における蝦夷の末路",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に永正二年に没した日澄の著だという「日蓮注画讃」（享保二十一年版）には、その貫名氏の先祖調べを行って、日蓮本姓三国氏だと云い、父は遠州刺史、すなわち遠江守貫名重実の次子重忠までは前者と同一だが、さらにその先は聖武天皇の裔で、母は清原氏だと余程古いところまで及んでいる。",
              "citation": {
                "source": "旃陀羅考",
                "author": "日蓮聖人はエタの子なりという事",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに貞享二年の「蓮公年譜」に至っては、遠く藤原鎌足からその系図を引いて、彦根藩主井伊氏の一族となし、「伝に曰く本姓三国、後藤原に転ず」と云っているのである。",
              "citation": {
                "source": "旃陀羅考",
                "author": "日蓮聖人はエタの子なりという事",
                "note": "青空文庫"
              }
            },
            {
              "text": "本姓は益田氏、甲斐国大藤村の人。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
