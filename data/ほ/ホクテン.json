    "definitions": [
      {
        "index": 1,
        "gloss": "northern sky",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一群の星は前述のリーラ星座より発して四方に展開しつつあるがごとく、他の一群は北天カメロパルダリス星座の辺より馳せ出るようである。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く『民衆は皆肩を聳かし、眉をあげて、北天を望めり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "『馬鳴菩薩伝』にいわく、昔北天竺の小月氏国王、中天竺を伐ちて三億金を求む。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて説法所の前に七つの馬を繋ぎ、馬は浮流草を嗜めばとて浮流草を与えしも、馬ただ涙を垂れて法を聴くのみ、少しも草を食う意なき様子、天下すなわちその不世出の比丘たるを知り、馬がその恩を解したから馬鳴菩薩と号づけ、北天竺に仏法を弘めたと。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて食卓から立って妻児が下りて来た頃は、北天の一隅に埋伏し居た彼濃い紺※色の雲が、倏忽の中にむら／＼と湧き起った。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――北天竺｜乾陀羅国の見生王は生身の観世音を拝みたくて発願入定三七日に及んだ。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して九州天狗と東北天狗との間になんらの相違はない。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨過五湖春色研、近山如笑遠山眠、不知造化有何意、画幅懸来瑞北天。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "呂宋海上向南東、吹送炎氛赤道風、午下知吾皇国遠、太陽已在北天中。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽はすでに北天の中央にある。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜に入りて天ようやくはれ、一輪の秋月北天に懸かる。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨過秋宵露気寒、家書不到思漫漫、知吾独有故山月、飽見北天光一団。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜に入れば天涯一片の雲なく、ただ半輪の孤月の高く北天に懸かるを望むのみ。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "六旬不見夏山青、回首客程雲緯経、暮雨一過四涯霽、北天秋月照南溟。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "没後北天紅を吐き、毫も白昼と異ならず。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときに天涯遠く晴れて片雲なく、清朗の北天に旭日を懸け、その光気の海水に映射する光景は、言亡慮絶の妙趣を実現せり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "当夜は十二時に至るも太陽地下に入らず、まさしく北天にかかり、徐々として東方に移る。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときに夕日高く北天に懸かり、多少の雲煙を帯ぶ。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜半は北天に微雲ありたれども、なお太陽の光影に接するを得たり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜半仰ぎて明月を望むに、少しく頭上よりも北天に懸かるを見る。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして月を北天に望み、半輪を下辺に生ずるは、やや奇異の感なきあたわず。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜に入りて天気ことに清朗、一輪の明月北天に懸かり、清輝客庭に満つ。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "船衝碧浪向南端、雲宿亜然州角巒、日左北天光不遍、春風料峭昼猶寒。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして月なお北天にあり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "一葉舟浮赤道辺、太平洋上水雲連、回頭判得家郷遠、日在南天月北天。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "北天竺迦畢試國人也。",
              "citation": {
                "source": "弘法大師と景教との關係",
                "author": "イー、エー、ゴルドン",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
