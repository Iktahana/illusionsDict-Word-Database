    "definitions": [
      {
        "index": 1,
        "gloss": "Le petit prince (by Antoine de Saint-Exupéry)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
