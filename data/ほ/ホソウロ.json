          "literary": [
            {
              "text": "舗装路の上に、靴はかたっかたっと音を立てた。",
              "citation": {
                "source": "変る",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "トラックは通り過ぎ、やがて舗装路の穴ぼこをさけようとして、ハンドルを切りそこねたらしい。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて救急車がサイレンを鳴らしながら、舗装路をまっしぐらに近づいて来た。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び列をつくって、今度は舗装路を歩み出した。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
