    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese scallop (Patinopecten yessoensis)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いまはさうでもないやうだけれど、私の幼少の頃には、津軽に於いては、肉を煮るのに、帆立貝の大きい貝殻を用ゐてゐた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆立岩の側を過ぎて、七合目半にいたれば、巉巖高く五六十度の勾配をなす。",
              "citation": {
                "source": "妙義山の五日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "（気分をかえて）えー斧足類は蛤に蜆に牡蠣、あさり、あげまき、帆立貝、赤貝、ばか貝。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "臓腑を抜いた家鴨、豚の腎臓、蜂蜜の中に浸った鼠の子、林檎の揚げ物に竜顔の吸物、青蟹や帆立貝――参木は翡翠のような家鴨の卵に象牙の箸を突き刺して、小声で日本の歌を歌ってみた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一口に云えば巨きな帆立貝であって、凹状の楕円と云ったら当るかもしれない。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪と瀧空氣に色をつけよ僕は谿の空中をへだてて雪の山嶽の裂け目からぼうぼうと落下する瀧の花火を見つめるこんなにも雪白な、生きた寫眞を鮮かな感覺をもつて切斷しきよらかなる、きよらかなる情感を盡して僕は尖れる帆立貝のやうに眞晝の扇をうちひらく大氣よ、色を點ぜよあまりにかがやき、あまりに雪白すぎる。",
              "citation": {
                "source": "季節の馬車",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "○本文記載のビーフ・スカラップは料理したる牛肉の残りを細かに切り別にバターにてメリケン粉をいため牛乳にて溶し塩胡椒を入れて白ソースを作り前の肉を和え、小さき帆立貝か菊形へ入れてテンパンに並べ上へパン粉を振掛けテンピの中へ入れて十分間焼くなり。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "秘密警備隊員の笹枝弦吾は、定められた時刻が来たので、同志の帆立介次と肩を並べてＳ公園の脇をブラリブラリと歩き始めていた。",
              "citation": {
                "source": "間諜座事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "弦吾は肘でチョイと同志帆立の脇腹を突いた。",
              "citation": {
                "source": "間諜座事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぬからず帆立が、「ピ、ピーイ、ピッ……」　とヴァレンシアのメロディーを口笛で吹き始める。",
              "citation": {
                "source": "間諜座事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "弦吾と同志帆立とは、酔漢の頭を飛び越えると足早に猿江の交叉点の方へ逃げた。",
              "citation": {
                "source": "間諜座事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」入口の扉にガチャリと鍵をかけると、帆立が云った。",
              "citation": {
                "source": "間諜座事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "別れの盃と行こう」　同志帆立は、押入の隅から壜詰を取出した。",
              "citation": {
                "source": "間諜座事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は俺に払わせろ」「いいんだよオ」「いけないよォ」　頗る手際よく、だらしなくグニャグニャと縺れ合いながら弦吾と同志帆立はプログラム片手にひッつかんだ儘、嬉しそうに入っていった――だが一皮下は、棒を呑んでいるような気持だった。",
              "citation": {
                "source": "間諜座事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "弦吾は同志帆立に脇腹を突つかれて、慌てて舞台へ拍手を送った。",
              "citation": {
                "source": "間諜座事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "副司令の芸名は、柳ちどり※　弦吾は素早く「柳ちどり」と名前をプログラムから千切りとって、隣りにピタリと寄り添っているＱＺ19同志｜帆立介次の掌のうちに、ねじこんだ。",
              "citation": {
                "source": "間諜座事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆立はフラリと席を立った。",
              "citation": {
                "source": "間諜座事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の瞬間に、屋根裏の機関銃手も公衆電話室甲乙の黄外套も、それから又、同志帆立も、飛鳥の如く現場から逃げ去った。",
              "citation": {
                "source": "間諜座事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸を歩けば、帆立貝の殻が山の如く積んである。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅虫で食ったものゝ中で、帆立貝の柱の天麩羅はうまいものであった。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "首を縮め帆立尻をし、ジリジリと後へ退りながら、息を呑み眼を見張り、素破と云わば飛んで逃げようと、用心をして構えていた。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒磯の辺り、夏の日に照り晒らされて帆立貝帆を失なひぬ、砂の上に歯をくひあてゝ滅ばゞやとおもひにしも怨疾の膿に悩める昨夜なりし、帆を失なひし貝ならば今日より思ひ安からむ、荒磯の上や寂光土――ねたみくづれし花ならば今日よりなげきあらためむ、法の雨降れあゝさらば、乱れて飛びし花片を濡れ朽たしめよ土着せよ。",
              "citation": {
                "source": "友に",
                "author": "末吉安持",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、お前、帆立貝の猿股を穿いた象の脚、剃刀入れ、元禄袖、模範｜煙突、羽根箒、これは棕櫚の木、失敬。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆立の貝鍋は手に入らぬので、まだやっていないが、充分出るでしょうといっていた。",
              "citation": {
                "source": "貝鍋の歌",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして、ここは海岸の事だから、帆立貝のなかから生れたような子供だの、鯨の背中に乗って流れ着いて来たような、うっとりするほどロマンチックな子供も居るに違いないのだ。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "八人の小悪魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "柄にない狭い単衣、尻をまくるには便利ですが、真面目に坐り直すと、帆立て尻にならなければ、どう工面をしても膝っ小僧がハミ出します。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "小唄お政",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガラッ八はその後ろから、帆立て尻になって煽ります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "結納の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸を歩けば、帆立貝の殼が山の如く積んである。",
              "citation": {
                "source": "熊の足跡",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "淺蟲で食つたものの中で、帆立貝の柱の天麩羅はうまいものであつた。",
              "citation": {
                "source": "熊の足跡",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆立貝の中に俺達を閉じ込めて、宇宙の真底を見せてくれない奴さ。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
