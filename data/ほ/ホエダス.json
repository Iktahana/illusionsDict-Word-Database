        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "此方で奇妙な不幸な境遇に置かれた犬が、冬の青空に向って遠吠えると、きっと暫くして、あの小窓の奥の女の人も吠え出す。",
              "citation": {
                "source": "吠える",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "気味悪い狐の事は、下女はじめ一家中の空想から消去って、夜晩く行く人の足音に、消魂しく吠え出す飼犬の声もなく、木枯の風が庭の大樹をゆする響に、伝通院の鐘の音はかすれて遠く聞える。",
              "citation": {
                "source": "狐",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "声を懸けたが返事がないので、横へ廻ってひっそりした中庭へつかつか入って行くと、急に犬が吠え出す。",
              "citation": {
                "source": "初旅の大菩薩連嶺",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "足元で狆が驚ろいて急に吠え出す。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまにまたきっと吠え出すことよ。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
