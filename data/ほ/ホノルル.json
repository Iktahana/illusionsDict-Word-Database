        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「君、いま、ホノルル・カフェにはいないのかい？",
              "citation": {
                "source": "兵士と女優",
                "author": "オン・ワタナベ（渡辺温）",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、ホノルルは夙の昔に辞職しちゃった。",
              "citation": {
                "source": "兵士と女優",
                "author": "オン・ワタナベ（渡辺温）",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ホノルル・桑港・ニウメキシコ・市伽古・ナイヤガラ・紐育・巴里・倫敦・エデンバラ・ストラットフォウドオンアヴォン。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ホノルルはとてもきれいな港よ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はホノルルでカトリックの教会に行っていた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホノルルはローマ正教の僧正が駐在しているのであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは彼女に瀬戸内海の景色がホノルルのよりも美しいことを知らして、彼女の郷愁を解消させようと思って私が誘ったのであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんたは健脚だね」　と私が言うと、安子は息切れしてる私を見て笑いながら、「ホノルルは高い火山脈があって、登りなれてるもの」　と言って、疲れを見せなかった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌の輸出　日本からホノルル、ソルト・レークなどにいる在米邦人を対象として十九点約五千冊の輸出が正式許可された。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚、その程度によっては、ホノルルなり、サンフランシスコなりに、船が着いたら、下船させてしまうぞ。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホノルル・ブロオドウェイの十仙店で、ぼくは、紅のセエム革表紙のノオトを買いました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホノルルの日本領事館で、官民合同の歓迎会が催されたのち、邦人の方の御好意で、選手一同ハワイの名勝ダイヤモンド・ヘッドからハナウマイヘかけて、見物させて貰いました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "だぼはぜ嬢は、相不変の心臓もので、ぼく達よりも一船前にホノルルを去った野球部のＤさんやＨさんに、生のパインアップルをやけに沢山託づけました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "※二三日前、新聞でオリムピック選手達が、明日ホノルルに寄航するという記事を読み、坂本さんにも会えると思ったら、その晩｜夢をみました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホノルルの日本領事館で、官民合同の歓迎会が催されたのち、邦人の方の御好意で、選手一同ハワイの名勝ダイヤモンド・ヘッドからハナウマイへかけて、見物させて貰いました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "≪二三日前、新聞でオリムピック選手達が、明日ホノルルに寄航するという記事を読み、坂本さんにも会えると思ったら、その晩｜夢をみました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "※二三日前、新聞でオリムピック選手達が、明日ホノルルに寄航するという記事を読み、坂本さんにも会えると思ったら、その晩夢をみました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "卓にかざられし緋と桃色のホノルルの花を束にして私等｜女三人に取らせ給ひ候。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新婚し給ひて一月とか云ひ給ひし郵船会社支店長某氏の夫人に、　ホノルルは何を祝ひて咲くやらん此若き日の妹と背のため　と書きて贈りしその花に候。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年の秋、私はホノルルでオペラをやる契約がありました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが三浦始め周囲の者が私のホノルル行きを猛烈に反対するのでした。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "終いには親族会議まで開いて私の外国行きに反対した上、私が九州へ演奏旅行に行った留守に、ホノルルから送って来た二千ドルの小切手を、三浦が独断で、三浦環は病気でホノルルへ行けない、と電報で断って小切手を送り帰してしまったのです。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
