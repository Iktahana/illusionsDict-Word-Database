    "definitions": [
      {
        "index": 1,
        "gloss": "to surge",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "燧の鉄と石の触れあう音、迸る火花、ホクチの燃えるかすかな囁き、附け木の燃えつくときの蒼白な焔の色と亜硫酸の臭気、こうした感覚のコムプレッキスには祖先幾百年の夢と詩が結び付いていたような気がする。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほとんど腐朽に瀕した肉体を抱えてあれだけの戦闘と事業を遂行した巨人のヴァイタルフォースの竈から迸る火花の一片二片として、こういう些細な事柄もいくらかの意味があるのではないかと思われるのである。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽ち、ざつとなつて、ポンプで噴くが如く、泥水が輪の両方へ迸ると、ばしやんと衣裳鞄に刎ねかゝつた。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰がした事かいなあッ……」　その声は、さながらに腸を絞る悲痛な声に変って、涙と一緒に迸るのであったが、しかし蔵元屋の主人は、やはり眼も口も開かなかった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "余りの不意に思わず気息を引くと、迸る様に鋭く動悸が心臓を衝くのを感じた。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の甲板にグリゴリー・ペトニコフが足をかけようとした刹那、誰が投げたのか、長方形のクヅ鉄が飛んで行って、其の頭蓋骨を破ったので、迸る血烟と共に、彼は階子を逆落しにもんどりを打って小蒸汽の錨の下に落ちて、横腹に大負傷をしたのである。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いて法師が、笠に手を掛け、振返ると、亀甲形に空を劃った都会を装う、鎧のごとき屋根を貫いて、檜物町の空に※と立つ、偉大なる彗星のごとき火の柱が上って、倒に迸る。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲は暗からう……水はもの凄く白からう……空の所々に颯と藥研のやうなひゞが入つて、霰は其の中から、銀河の珠を碎くが如く迸る。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は又それを押へようとはしないで、むしろ其｜迸るが儘に任せて、ぢつと結局を見つめてやらうと思つた。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、名所だ、と云う、浦の、あの、子産石をこぼれる石は、以来手毬の糸が染まって、五彩｜燦爛として迸る。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "散弾が轟然として四辺に迸ると、頑強の敵も流石に胆を挫がれたらしい、踵を旋してばらばらと逃げ出した。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "媚薬の痺れにも似た中欧の青深い、初夏の晴れた空に、夢のしたたりのように、あちこちに咲き迸るマロニエの花。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母さん、とうとう巴里に来ましたね」　今後何年でもむす子のいるかぎり、毎年毎年、マロニエが巴里の街路に咲き迸るであろう。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋七月｜布政使張貴の軍の殺気の迸るところ、箭をば放って府内に達するものすら有りたり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾の時一道の金光が漫々と涯無き浪路の盡頭から、閃くが如く、迸るが如く、火箭の天を射るが如くに發する。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘆の軸に、黒斑の皮を小袋に巻いたのを、握って離すと、スポイト仕掛けで、衝と水が迸る。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "という言葉も終らぬ中に、良夫の頸はがっくり前に落ち、黒地に金で猛虎を刺繍した大緞帳に鮮血がさっと迸る。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふ言葉も終らぬ中に、良夫の頸はがつくり前に落ち、黒地に金で猛虎を刺繍した大緞帳に鮮血がさつと迸る。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのポンプはかなり上等のものだったらしく、長いゴムのホースの尖端の筒先から迸る水が、数間先の土塀を越えて、通行人を驚かした。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "水に迸る勢に、水槽を装上って、そこから百条の簾を乱して、溝を走って、路傍の草を、さらさらと鳴して行く。",
              "citation": {
                "source": "瓜の涙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "清水は、人の知らぬ、こんな時、一層高く潔く、且つ湧き、且つ迸るのであろう。",
              "citation": {
                "source": "瓜の涙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲は暗かろう……水はもの凄く白かろう……空の所々に颯と薬研のようなひびが入って、霰はその中から、銀河の珠を砕くが如く迸る。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "地獄の裡に堕ちながら、慣るるにつれて、身の苦艱の薄らぐままに、ひたすら想い出でらるるは、故郷の父母さては東京、大阪の有志が上なり、一念ここに及ぶごとに熱涙の迸るを覚ゆるなりき。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒ることを俗に腹立つと云い、こみ上げる事であるが、憤は胸の中の突っ張りがはじけて、噴水が地を破って噴き出すように、噴火が岩を巻き上げて噴き迸るように、止めても止まらない勢い以って盛り上がることをいう。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "憤は心の盛り上がる状で字を成し、慍は心が煩悩｜瘟熱で、盛り上がり溢れ迸るというほどでは無いが、心中が穏やかで無いことをいうのである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯有る小路の湯屋は仕舞を急ぎて、廂間の下水口より噴出づる湯気は一団の白き雲を舞立てて、心地悪き微温の四方に溢るるとともに、垢臭き悪気の盛に迸るに遭へる綱引の車あり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の事はかまつてはおくれでないのだから……」　我にもあらで迸る泣声を、つと袖に抑へても、宮は急来る涙を止めかねたり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその一方では、辛い悲しい感情が迸るやうにＢの全身を揺がした。",
              "citation": {
                "source": "島からの帰途",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　夫人は、心の中に抑えに抑えていた女性としての平生の鬱憤を、一時に晴してしまうように、烈しく迸る火花のように喋べり続けた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "槍鍛冶の名手、備後貞包の鍛えた七寸に近い鋒先から迸る殺気が、一座の人々の心を冷たく圧した。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
