        "examples": {
          "standard": [
            {
              "text": "過労で、彼の顔は頬の削げた状態だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長患いの後、彼女の頬はすっかり削げてしまっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "写真の彼は、昔に比べて頬の削げた印象だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ただ一｜穂の燈し灯と、それに照らさるる武蔵の青白く頬の削げた影とがあるだけであった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "六畳間には、顔の長い、頬の削げた、そして窪んだ穴の中に鋭い眼のある老人が、漆黒の腮髯をしごいて、いつも書見か、墨池に親しんでいる。",
              "citation": {
                "source": "田崎草雲とその子",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
