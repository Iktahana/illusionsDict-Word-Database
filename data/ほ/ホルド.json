        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あのロイトホルド君が今に来るのですがね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それではロイトホルド君には逢わないで帰るのですね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロイトホルド君かも知れない。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "医学士ロイトホルド。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロイトホルド君にその紙巻の箱を上げて下さい。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "クスタリヌイ博物館と、夜はメイエルホルド座――「証明書」の今年のシイズンにおける何回目かの上演だ。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、カアルトンやウホルドルフ・アストリアの最高級ホテルに泊って、誰が安心のために、火事の場合の非常設備などを一応調べてみたりする者があろう。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "メイエルホルドが演出したゴーゴリの〈検察官〉の幕切れにそっくりだ。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
