        "examples": {
          "standard": [
            {
              "text": "クリスマスの飾り付けに、ホーリーの葉と赤い実を使った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "庭に植えたホーリーが、青々と茂ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ホーリーの枝は、魔除けとしても使われることがあるらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "サンフランシスコの英語学校に半年通ってから、現地の高校に入った孫は、いったんホーリーネームズ大学に入学したあと、目標としていたカリフォルニア大学バークレー校の経済学部への編入を果たした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二八、ダブリンからウェールズ・バンガー村へ　四月三日、午前ダブリンを発し、春雨蕭々のなか海峡を渡り、ウェールズ（Wales）州ホーリーヘッド（Holyhead）港に着す。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホーリーヘッドより車行一時間にして、ウェールズ州北部の都会なるバンガー（Bangor）町に着す。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
