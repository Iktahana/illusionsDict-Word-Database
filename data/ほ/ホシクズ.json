    "definitions": [
      {
        "index": 1,
        "gloss": "(countless) stars in the night sky",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "問題はつまり銀河に対して天球を数千の区劃に分ち各区中の星屑の数を数えるというのである。",
              "citation": {
                "source": "天河と星の数",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは夜天の空に輝やいてる、無數の星屑が照らすところの、宇宙の常夜燈の明りであつた。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空から星屑を振り撒かれたように芽を吹く雑木林。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日暮頃から空は戛々に晴れて、氷結したやうな夥しい星屑が象眼張りのやうに光つた。",
              "citation": {
                "source": "白明",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "孤独は求むべきものではない、求めてはならない、太陽は孤独だといつて威張る人がある、負け惜しみは止したがよい、人間は星屑のやうに在るべきものである。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "光った藁のような金星銀星その他無数の星屑が緑や青に閃きあっている中程に、山の峰や深い谿の有様を唐草模様のように彫り出した月が、鈍く光りを吸う鏡のように浮んでいます。",
              "citation": {
                "source": "ようか月の晩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間も窓によって空にきらめく星屑と満潮した川面のふくらみと岸べの静かな森とを眺めた時、私は調和と愛との深い感動を抑えることができず、ああ愛したい、許したい、と涙をこぼして神に祈りました。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は飢と疲れでがっくりと仰臥になったまま、暗い蒼穹にきらめく星屑をうち眺めた。",
              "citation": {
                "source": "乞食",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "半夜めざめて星屑の散乱する高い大空を眺めながら、哥薩克｜男子の骨の髄まで爽々しく浸みとほる冷たい夜気にブルッと身震ひを覚えるのが彼等には何より快いのだ、伸びをして、夢見心地で何か呟やきながら、彼等は一服喫ひつけてから、温かい皮裘にひしと身をくるむのである。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "きらめくばかりの星屑の光。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "星屑が空いちめんに拡がり、霜冷えする寒い道であつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "星屑がまるで船の燈火のやうにまたゝいてゐる。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　Ａ老人が振向いた方を眺めると、辰野工学博士の傑作の一つとされてる工科大学の建物が、中世紀風のシャトーの姿を、星屑の淡い夜空に、くっきり聳やかしている。",
              "citation": {
                "source": "地水火風空",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにこの歌では満天の星屑尽く君だといふのであるから一寸様子が違つて分らなくなるのである。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は濃いい瑠璃色に星屑の金を鏤め、五月の末にもう天の河がべつとりと乳を流してゐる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "猶この石炭には琥珀を含んでゐると聞いて、試みに同行の男達が附近にある炭塊を石に打ち附けると、しばしば小粒の星屑が光つてゐるのを見受けた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にその煙の末が、所斑な天の川と一つでいるのを眺めますと、どうやら数え切れない星屑が、洛中の天を傾けて、一尺ずつ一寸ずつ、辷る音まではっきりと聞きとれそうに思われました。",
              "citation": {
                "source": "邪宗門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "古往今来、数十万・数百万とも数へきれぬ高天の星屑ほどな、文芸人はあつても、真の芸術者として光り残つたのは幾人か。",
              "citation": {
                "source": "鵠が音",
                "author": "追ひ書き",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして深い闇の底に愼ましく瞬いて居る星屑を數へては、我等に屬して新しくこの惱ましの世に生れ來るであらう小さな者のために、占ひ祈るのであつた。",
              "citation": {
                "source": "雪をんな",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "天上の星屑の外に、人工の星が閃光を放って散乱し爆発する。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "星屑ひとつ見えない暗い夜で、どこも深い闇だけであった。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりそのむれを離れた諏訪栄三郎、腰の武蔵太郎安国に大反りを打たせて、星屑をうかべた池のほとりにたった。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　が、里好はそれには答えず、星屑のこぼれるような空を仰いで、ただ坂を上る足を早めた。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとにはただ、寄せては返す潮騒が黒ぐろと鳴り渡って、遠くに松平肥後守様のお陣屋の灯が、漁火と星屑とのさかいに明滅しているばかり。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "海へ帰る女",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　四　夜に入って冴え渡った寒空、濃い闇黒が街を一彩に刷き潰して、晴夜とともに一入の寒気、降るようにとまでは往かなくとも、星屑が銀砂子を撒き散らしたよう、蒼白い光が漂ってはいるが地上へは届かないから、中天に霞んで下は烏羽玉。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怨霊首人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "点々と散在する遠火の群は、夜白々と明けるにつれて晴れた空の星屑とも見え、古歌にいう、河辺の蛍もこのことかと思われた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第九巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "星屑ひとつない暗い夜で、どこを見ても深い闇だった。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし宵もまたこの上なくこころよかった――遊園の草木が芳香をはき、空の星屑がいつもの輪舞をおどり、そしてやみに包まれた海のつぶやきが、かすかに押しのぼりながら、たましいに語りかける時には。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
