    "definitions": [
      {
        "index": 1,
        "gloss": "main hall (of a Buddhist temple)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今日は彼岸にや本堂に人｜数多集りて和尚の称名の声いつもよりは高らかなるなど寺の内も今日は何となく賑やかなり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまきの葬式は丁度それと入れ違いに本堂に繰り込むと、前に来ていた見送り人はやはり芝辺の人達が多かったので、あとから来たおまきの見送り人と顔馴染みも少なくなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりは欅と桜の間をくぐって本堂の前に立った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "１７＝本堂　伝六本堂へ忍び込む。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "和尚が本堂の中央に黙然と坐して居る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "３６＝本堂　集まった男女。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "３８＝本堂　和尚の読経、木魚の音。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "４１＝本堂　読経を終った和尚が一同に、Ｔ「では御婦人方は室へ退って御待ち下さい」　と言って、Ｔ「貴女がたの心に想う殿方がやがて」Ｔ「貴女がたの眼の前に現れておいでになります」　と小坊主に案内を命ず。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "４６＝本堂　和尚が今度は男達に、Ｔ「拙僧が今、御教え致しました室に」　と云って、Ｔ「貴女の想う御婦人が、貴下の来るのを待って居られます」Ｔ「御仏が御許しなされたのです」Ｔ「勇敢に御進みなさい」４７＝門前　伝六の率いる捕方の一隊ひしひしと詰めかけた。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "17＝本堂　伝六本堂へ忍び込む。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "36＝本堂　集まった男女。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "38＝本堂　和尚の読経、木魚の音。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "41＝本堂　読経を終った和尚が一同に、Ｔ「では御婦人方は室へ退って御待ち下さい」　と言って、Ｔ「貴女がたの心に想う殿方がやがて」Ｔ「貴女がたの眼の前に現れておいでになります」　と小坊主に案内を命ず。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "46＝本堂　和尚が今度は男達に、Ｔ「拙僧が今、御教え致しました室に」　と云って、Ｔ「貴女の想う御婦人が、貴下の来るのを待って居られます」Ｔ「御仏が御許しなされたのです」Ｔ「勇敢に御進みなさい」47＝門前　伝六の率いる捕方の一隊ひしひしと詰めかけた。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどこの上口の辺に美濃の蓮大寺の本堂の床下まで吹抜けの風穴があるということを年経ってから聞きましたが、なかなかそこどころの沙汰ではない、一生懸命、景色も奇跡もあるものかい、お天気さえ晴れたか曇ったか訳が解らず、目じろぎもしないですたすたと捏ねて上る。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "本堂｜青光して、はたたがみ堂の空をまろびゆくに、たまぎりつつ、今は姉上を頼までやは、あなやと膝にはいあがりて、ひしとその胸を抱きたれば、かかるものをふりすてむとはしたまわで、あたたかき腕はわが背にて組合わされたり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけの寺だから屋の棟の高い本堂が見えそうなものだが、それは回禄したのかどうか知らぬが眼に入らなくて、小高い処に庫裡様の建物があった。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを目ざして進むと、丁度本堂仏殿のありそうな位置のところに礎石が幾箇ともなく見えて、親切な雨が降る度に訪問するのであろう今もその訪問に接して感謝の嬉し涙を溢らせているように、柱の根入りの竅に水を湛えているのが能く見えた。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "御本堂の改築から何から、いつでも一番の施主で御座いましてなあ」「ウン。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお島どんがなあ……御存じかも知れんが、当寺の本堂の……ホラ……あすこの裏手に住んでおりまする非人の処へイツモ立寄って行きましたそうで……これは寺男の話で御座いまするが……」「ハハア。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝早よう……ふうむ……」　本堂に近い柴垣の処で立止まった良助は、又もや腕を組んで、今出て来た墓所の奥の暗がりを振返った。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "筑紫野を見晴らす大根畠と墓原の間の小径の行止まりに、万延寺の本堂と背中合わせにして一軒の非人｜小舎がある。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした門構えを入ると、本堂の阿弥陀様と背中合わせの板敷土間に破れ畳の二畳敷、竹瓦葺の板廂、ガタガタ雨戸に破れ障子の三方仕切は、さながらに村芝居の道具立をそのまま。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "博多の町の南の出外れ、万延寺の本堂と背中合わせの竹瓦に板庇、板敷土間に破れ畳二枚、ガタガタ雨戸の嵌め外しがやはり二枚という、乞食小舎の豪華版から、墓原越しに見晴らす筑紫野は、これも晩春の豪華版であろう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "脱ぎ棄てた、浴衣、襯衣、上衣など、ちらちらと渚に似て、黒く深く、背後の山まで凹になったのは本堂であろう。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の夏頃開帳があって、これを何だ、本堂の真中へ持出して大変な騒ぎを遣るんだ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨戸の中は、相州西鎌倉亂橋の妙長寺といふ、法華宗の寺の、本堂に隣つた八｜疊の、横に長い置床の附いた座敷で、向つて左手に、葛籠、革鞄などを置いた際に、山科といふ醫學生が、四六の借蚊帳を釣つて寢て居るのである。",
              "citation": {
                "source": "星あかり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると　一休さんは、なにを　おもったか、ちょこちょこと　じくさいさんに　さきまわりして、ほんどうから　たいこの　ぱちを　もって　くると、いきなり　じくさいさんの　はげあたまを　ぽかぽかと　たたきました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしょうさまが、一休さんを　よんで、「しゅうけん、ほんどうの　おとうみょうを　けして　きなさい。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　一休さんは　すたすたと、ほんどうに　いって、ふっ　ふと、おとうみょうを　ふきけしました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
