[
  {
    "uuid": "d95303f8-9e89-51f1-a256-050259353e0b",
    "entry": "誉むべき",
    "reading": {
      "primary": "ほむべき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
