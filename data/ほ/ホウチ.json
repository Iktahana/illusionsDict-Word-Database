[
  {
    "uuid": "79ff3fbb-66e8-592d-a107-28e360dd732e",
    "entry": "報知",
    "reading": {
      "primary": "ほうち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "information",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "来診を報知らせる電鈴がその時鳴つた、「夜遅く………」と唸きながら父は立つて行つた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "アフリカでキンバーレー、ヴィクトリア滝を見てプレトリアへの途上赤痢に罹り、その報知はロンドンを驚かせた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして多くの新聞（中央新聞、報知新聞、二六新聞等）雑誌（太陽、国民之友、文芸倶楽部等）に戦争小説、軍事小説なるものが現れた。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今手あたり次第に饗庭篁村の「従軍人夫」（太陽、明治二十八年一月）、江見水蔭の「夏服士官」「雪戦」「病死兵」（中央新聞二十七年十二月─一月）、村井弦斎の「旭日桜」（報知新聞二十八年一月─三月）等を取って見るのに、恐ろしくそらぞらしい空想によってこしらえあげられて、読むに堪えない。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず初めは、浴槽の水を掻き廻さないで、水面二、三寸のところへ寒暖計の球をさしこんで、所定の温度に達した頃に報知して来るのだから、かき廻さないで飛び込めば上の方は適温だが、底の方はまだ水である。",
              "citation": {
                "source": "家庭の人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが家の先祖の誰かがどこかでどうかしていたと同じ時刻に、遠い遠い宇宙の片隅に突発した事変の報知が、やっと今の世にこの世界に届くという事である。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事かと思って出てみると、国際電報によって昨年度と今年度のノーベル賞金の受賞者の名前の報知が届いた、その一人はアインシュタインで、もう一人はコーペンハーゲンのニールス・ボーアという人だそうだが、このボーアという人はいったいどんな人でどういう仕事をした人かというのである。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　俊の報知は、母には恐怖をもたらした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この報知に虚栄心を燃やされるのは「長」がつく人間だった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眠られぬままにいろいろな事を考えた中にも、Ｎ先生が病気重態という報知を受けて見舞いに行った時の事を思い出した。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが友だちと二人で悪漢の銀行破りの現場に虜になって後ろ手に縛られていながら、巧みにナイフを使って火災報知器の導線を短絡させて消防隊を呼び寄せるが、火の手が見えないのでせっかく来た消防が引き上げてしまう。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "亮の死の報知が伝わった時に、Ｆ町の知友たちは並み並みならぬ好意を故人の記念の上に注いでくれた。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞の記事はその日その日の出来事をできるだけ迅速に報知する事をおもな目的としている。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうものがあらゆる階級の人に興味があるという事は望まるべき事でもあり、またそれが事実であるとしたところで、これらの報知を一日でも早く知る必要をほんとうに痛切に感ずる人が国民の中で何人あるかという事を考えてみなければならない。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれとても必ずしも新聞によらなくても他に報知する方法はいくらでもある。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月三日に井伊大老の殺された報知が電信も汽車もない昔に、五日目にはもう土佐の高知に届いたという事実がある。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（完）（『報知新聞』大正十一年五月）",
              "citation": {
                "source": "子供の世界",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "船中八｜時三十｜分の銅鑼は通常朝食の報知である。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "『他でもない、櫻木海軍大佐に此急難を報知して救助を求めるのだ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程、此處から大佐等の住へる海岸の家までは三十｜里以上、飛ぶ鳥でもなければ通はれぬ此難山を、如何にして目下の急難を報知するかと審るのであらう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて報知新聞の記者、いまは代議士である、田中萬逸君その人である。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "親父も許して呉れるし、學資の方の心配もなく、漸く安心して間もなく、恰度其手紙が來てから二週間も經つと、突然親父が病氣だと云ふ報知が來て、驚いて取るものも取り敢へず歸國して見ると親父は死んで居る。",
              "citation": {
                "source": "自傳",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は固より僕に示す丈の積りだらうが僕以外の人の説も參考に聞く方が將來の作の上に利益があると思ふから一寸報知する。",
              "citation": {
                "source": "鈴木三重吉宛書簡―明治三十九年",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "余がかつて「土」を「朝日」に載せ出した時、ある文士が、我々は「土」などを読む義務はないと云ったと、わざわざ余に報知して来たものがあった。",
              "citation": {
                "source": "『土』に就て",
                "author": "――長塚節著『土』序――",
                "note": "青空文庫"
              }
            },
            {
              "text": "主税が、小児衆は、と尋ねると、二人とも乳母が連れて、土産ものなんぞ持って、東京から帰った報知旁々、朝早くから出向いたとある。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうするとその学校では郵便報知新聞を取つて居た。",
              "citation": {
                "source": "いろ扱ひ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うも、伏目に俯向いたと思うと、リンリンと貴下、高く響いたのは電話の報知じゃ。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それこそ、清く明るくほがらかに、帰宅の報知をするつもりが、むざんや、いつも声がしゃがれる。",
              "citation": {
                "source": "家庭の幸福",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "近く見える西洋館から遠くの船舶の檣、港の起重機、棧橋上の鐵道荷車、各種の煙突、正午報知臺等が皆それである。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、いま女中が大きなほうちょうで、このさかなのおなかを切ったところだったのです。",
              "citation": {
                "source": "すずの兵隊さん",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
