    "definitions": [
      {
        "index": 1,
        "gloss": "hotel",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この橋のあるあたりの小高い崖の上に、湯元ホテルとかいふ木造のホテル兼レストランがある。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に何の奇もない平凡な木造建築であつて、ホテルと言つてもごく簡便な物であるが、それがどことなく西洋の野菜料理店といつた感じがする。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝夕の散歩のかへり道に、このホテルの静かな食堂へ入つて、大層冥想的な紅茶を飲むのは、温泉場の物侘しい生活にふさはしいことである。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルのポルチエーが自分を小蔭へ引っぱって行って何かしら談判を始める。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の夕方、ホテルの食堂で食事のあとに出した菓物鉢の数々の果物の中にただ一つ柿の実がのっかっていた。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またいふ、東郷大將とふたり外遊の折、乃木、かならずその國一のホテルに宿り、手袋、煙草、すべて一流のものをのみ用ゐた。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の宵　　　　　　青いソフトに降る雪は　　　　　　過ぎしその手か囁きか　　白秋ホテルの屋根に降る雪は過ぎしその手か、囁きか　　　　ふかふか煙突｜煙吐いて、　　赤い火の粉も刎ね上る。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しづかにしづかに酒のんでいとしおもひにそそらるる……　　ホテルの屋根に降る雪は　　過ぎしその手か、囁きかふかふか煙突煙吐いて赤い火の粉も刎ね上る。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく富士山麓の宿屋としては、北の精進ホテル以外において、もっとも景勝の地を占めたものであろう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "生憎時計を見ると、かれこれ午後二時に近い、空気も稀薄になり始めて、絶頂まで、遅々たる足取りでは、今夜中にホテルまで、戻り得られるか否かも、覚束ないので、ここから下山することにした。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し池畔からホテルへのドライヴウェーは、亭々たる喬木の林を切開いて近頃出来上つたばかりださうであるが、樹々も路面もしつとり雨を含んで見るからに冷涼の気が肌に迫る。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑞西あたりの山のホテルを想はせるやうな帝国ホテルは外側から観賞しただけで梓川の小橋を渡り対岸の温泉ホテルといふ宿屋に泊つた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼ではあつたが自分達の盆の餅をすゝめて、さうして此人達から新築のホテルに関する噂を聞いた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ道を引返して帝国ホテルで昼飯を食つてから、今度は田代池といふのを見に行つた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし池畔からホテルへのドライヴウェーは、亭々たる喬木の林を切開いて近頃出来上がったばかりだそうであるが、樹々も路面もしっとり雨を含んで見るからに冷涼の気が肌に迫る。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "スイスあたりの山のホテルを想わせるような帝国ホテルは外側から観賞しただけで梓川の小橋を渡り対岸の温泉ホテルという宿屋に泊った。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼ではあったが自分たちの盆の餅をすすめて、そうしてこの人たちから新築のホテルに関する噂を聞いた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ道を引返して帝国ホテルで昼飯を食ってから、今度は田代池というのを見に行った。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてそんなことで、主人も私も東海道のことはすっかり忘れ果て、二人ともめいめいの用向きに没頭して、名古屋での仕事もほぼ片付いた晩に私たちはホテルの部屋で番茶を取り寄せながら雑談していた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、ホテルを出発しようとすると、主人に訪問客があった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "紳士は丁寧に礼をして、自分がこの土地の鉄道関係の会社に勤めて技師をしているということから、昨晩、倶楽部へ行ってふと、亡父が死前に始終その名を口にしていたその人が先頃からこの地へ来てＮホテルに泊っていることを聴いたので、早速訪ねて来た顛末を簡潔に述べた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイデルベルクでもベデッカーの案内記にはグランド・ホテルとなっている旅館もハイデルベルゲル・ホーフと改名していた。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルの食堂へはいって見ると、すぐ向うの席に有名な某音楽家の家族連れがいる。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして熱海ホテルでお茶を飲んで七時にはもう宅へ帰って夕食を食っていた。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱海ホテルの海に面した芝生は美しい。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
