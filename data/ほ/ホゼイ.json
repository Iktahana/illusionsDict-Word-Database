        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "また、おほぜいの召使ひもゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべだつて、婦長室へ看護婦をおほぜいあつめて、歌留多なんかして大さわぎだつたくせに。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同宿の若い坑夫さんと山の観音様へ詣でた、一年一度のおせつたいがあるといふので、近村のおぢいさんおばあさんが孫を連れておほぜい詰めかけてゐた、山村風景のおもしろい一枚である。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし鳥右ヱ門は、もつとおほぜいの人のためになることがのぞましかつたのでした。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲華寺では、もうすぐ報恩講があつて、毎日おほぜい参詣人があるので、そのしたくに、仏様の前におくいろいろな道具を、ぴかぴか光るやうに磨いたのであります。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何せ、おほぜいの人ですから。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいじな息子をなくしたおほぜいの母親たちは、毎日泣いてくらしました。",
              "citation": {
                "source": "湖水の鐘",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にはのこ／＼人のところへ話しにいつたり、おほぜいで踊ををどつたり、さうかと思ふと、けんかをし合つたりして、おほさわぎをしはじめました。",
              "citation": {
                "source": "一本足の兵隊",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "目白はおほぜいでやつてくる、貴族的だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "はらみこうろぎは腹がおもくてとべないので、よち／＼あるいてゐる、子蜘蛛がおほぜいで網を張るおけいこをしてゐた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "おほぜいの人が門を叩いてゐますの、それに確か、この家の教父の声もするやうなんですの……。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はおほぜいの人だかりといつしよに、往来で彼女を待ち受けてゐたのであつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿屋にはおほぜい客がありましたし、彼は少年でしたから、二階の隅の物置みたいな室に入れられました。",
              "citation": {
                "source": "エミリアンの旅",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "人がおほぜいくるので、めつたに外へも出られません。",
              "citation": {
                "source": "エミリアンの旅",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "まはりには、おほぜいの人があつまつてゐます。",
              "citation": {
                "source": "シロ・クロ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おほぜい人をつれて、冒険の旅にでかけるので、用心のためにもつていきたいのだとか、あいまいな話です。",
              "citation": {
                "source": "シロ・クロ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おほぜいお客がつめかけてゐます。",
              "citation": {
                "source": "シロ・クロ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポン公もおほぜいのお客にまぎれて、店のなかの様子をうかゞつてゐます。",
              "citation": {
                "source": "シロ・クロ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人といつしよに死んだ人が、おほぜいあるさうです。",
              "citation": {
                "source": "シロ・クロ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おひるすぎになつて、ターマンがおほぜいの男をつれてかへつてきました。",
              "citation": {
                "source": "シロ・クロ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はおほぜいの生徒たちからはなれて、毎日小い紙の旗をもつて、学校のうら庭の、桜の木の下で、ひそひそと、さうだんごとを、してゐました。",
              "citation": {
                "source": "にらめつくらの鬼瓦",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、門のところへ、走つて行つてみますと、おほぜいの生徒が、そこに立つてゐて、「東山の鬼瓦……　西山の鬼瓦……」と、言つて、さわいでゐました。",
              "citation": {
                "source": "にらめつくらの鬼瓦",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四応接間には、加来の臨終を待つ人々、おほぜい、或は腕組みをし、或は、長椅子に倚りかかり、或は、額をよせてひそひそ話をし、など、緊張と退屈との入り混つた空気が漲つてゐる。",
              "citation": {
                "source": "カライ博士の臨終",
                "author": "人生の最も厳粛であるべき瞬間に、わたくしがもし笑ひの衝動をおさへることができぬとしたら、いつたいどんな罪に問はれるであらう？",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の外から、女生徒がおほぜい中をのぞいてゐる。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "文楽見物は多分、改造社の講演か何かでおほぜい大阪へ乗り込んだ時であつたらう。",
              "citation": {
                "source": "個人的な余りに個人的な饒舌",
                "author": "＝龍之介対潤一郎の小説論争＝",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
