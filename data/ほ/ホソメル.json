        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "モーツァルトのフリュウト・コンチェルトに眼を細める。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その竹の耳かきの一端には、ふさふさした兎の白い毛が附いていて、男は、その毛で自分の耳の中をくすぐり、目を細める。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は画家が真に色彩を眺め取る時に必ず細める眼つきを、そちらへ向けながら沁々云った。",
              "citation": {
                "source": "高原の太陽",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "円いはじきれそうな赭ら顔のすこしく釣った眼尻を仔細らしく細めると、両腕をテエブルに、そして肩を怒らした。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "かん子は彼の横まで來ると、身體を捻ぢらせ、前へ出てから裾を細めるやうに手で壓へて歩いていつた。",
              "citation": {
                "source": "悲しみの代價",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩きながら眼を細める。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼を細めるとサン・ミツシヱル橋も樹も建物も生々と美しかつた。",
              "citation": {
                "source": "瑪瑙盤",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼を細めると佛樣のやうな顏になる。",
              "citation": {
                "source": "秋果",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は目を細めるようにし、突然僕も忘れていた万葉集の歌をうたい出した。",
              "citation": {
                "source": "彼　第二",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを、よう考えたら、そなたも、日頃の心がけを、今夜だけは忘れても、損はないように思われるが――」　雪之丞は、三郎兵衛が、例の悪狡い眼を細めるようにして、こんな事を、くどくどと述べたてるのを聞いているうちに、だんだん気持が変って来た。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「妙なものが好物なんだなあ」　素子は、新しくたばこに火をつけ煙に目を細めるようにしていたが、「ああ、おつまはんから手紙が来ているよ」　その室の角に置いてある洋風の大テーブルから、しゃれた手すきの封筒をもって来た。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "目を細める代りに、厚紙に穴をあけて、のぞいて見るっていう工夫です。",
              "citation": {
                "source": "智恵の一太郎",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "細めると、まつ毛の陰に針のようなものが光る。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの有名な宋公明さまじゃったのか」　老主人は眼をほそめる。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
