    "definitions": [
      {
        "index": 1,
        "gloss": "pleasantly (warm)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何処も彼処もぴかぴかと黒く光るなかへこればかりは新らしく容れられた縁の部厚な椹の風呂桶の生々しい肌の色が、白くほっかりと浮んで見えた。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶店の女は、目の前にほっかりと黒毛の駒が汗ばんで立ってるのを憚って、密と洋盃を齎らした。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふっくりとも、ほっかりとも、細い毛へ一つずつ日光を吸込んで、おお、お前さんは飴で出来ているのではないかい、と言いたいほど、とろんとして、目を眠っている。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "行灯の光がほっかりと膝の上にありました。",
              "citation": {
                "source": "薬指の曲り",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処には切灯台の微紅い灯がほっかりと青い畳の上を照らしていたが、その灯の光に十五六に見える細長い顔をした女の童の銚子を持った姿をうつしだしていた。",
              "citation": {
                "source": "庭の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにはほっかりした燈のある室があった。",
              "citation": {
                "source": "赤い土の壺",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤味を帯びたほっかりしたその光は、燈の光より他の光ではないと思った。",
              "citation": {
                "source": "陳宝祠",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "王は窓から窓を覗いて往ってみると、中から灯のほっかりと見えている小さな窓があった。",
              "citation": {
                "source": "蘇生",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩に限って奥底のはかられないような気のする暗い気もちの悪い林の奥に、小さな蛍のような燈が一つほっかりと光っていた。",
              "citation": {
                "source": "雀が森の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気は冷たかったが静な煙ったように見える日で、輝のない夕陽がそのまわりをほっかりと照らしていた。",
              "citation": {
                "source": "港の妖婦",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ宵の口だけれども、何となく人足｜稀に、一葉二葉ともすれば早や散りそうな、柳屋の軒の一本柳に、ほっかりと懸っている、一尺角くらいな看板の賽ころは、斜に店の灯に照されて、こっちへは一が出て、裏の六がまともに見られる。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "醤油で、ほっかりと煮て喰わっせえ、頬ぺたが落こちる。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだ網膜にも灯の光がほっかりと感ずるらしい。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "春らしい日の光が稀にはほっかり射すようになって麦がみずみずしい青さを催して来た頃犬は見違える程大きくなった。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "手に持っている毛糸が急にほっかり暖かく、つめたい雨空もビロウドみたいに柔かく感ぜられる。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しこれから気をつけてな、堅く柔らかくほっかりと、蒸しかげんもほどのいい人間になりなせえよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいかげんにだんなもほっかりと蒸しかげんのいい人間にならねえと、七橙かなにかで祈られますぜ」　――知らぬ知らぬというように、名人の足の下でちゃらりちゃらりと雪駄の音が鳴りました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の水草の白い花が夕もやの下りた池のうす紫の中にほっかり夢の様に見える様子や、泳ぎながらその花で体中を巻く時の美くしさや快さなんかも思った。",
              "citation": {
                "source": "グースベリーの熟れる頃",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな仕事だったけれど、生まれたての本は僕のてのひらの上でほっかりとあたたかかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の上の右手には花電燈がほっかりと点いていて、周囲には大勢の客が笑いさざめいている。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほっかりと、身をあたためる『巣』のようなものである。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "春暁やあとさきもなき夢の橋　　妙子　ぼうっとしてそれこそ、ばら色の靄でもかかっている様な、春暁のねむりの中に、ほっかりと七彩の夢の浮橋があとさきもなくかかっている。",
              "citation": {
                "source": "女流俳句を味読す",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "照らされた部分は明るい灰色の断片となって暗い中にほっかり落ちた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　つつみを　といて、一休さんが　ちょっと　さわってみると、おもちは　まだ　ほっかりと　あたたかくて、まるで　ごむまりの　ように　ぷかぷか　していました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほっかりと明るく、花やかでありながら渋みがあって、じっと見ていると胸が安まるようになる。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
