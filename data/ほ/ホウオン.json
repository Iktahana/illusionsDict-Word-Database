  {
    "uuid": "12939d0b-0b46-5776-93dc-3966bbb0549d",
    "entry": "方音",
    "reading": {
      "primary": "ほうおん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dialectal pronunciation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その『みち』の国の名を、古い地方音によつて『むつ』と発音し、『むつ』の国となつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此ほど悪声や、地方音や、音勢の標準を求めることに無関心だつた劇も、稀だらうと思ふ。",
              "citation": {
                "source": "市村羽左衛門論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此頃から一方音韻分化したうたゝの形が、うたゝありともなり、悲感を表すと共に、積極感をも示すことになつたが、此は訓読専門の語となつて行つたらしく、専らうたゝと言ふ形の死語として、今日までも残つた。",
              "citation": {
                "source": "言語の用語例の推移",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方音を立てて雨が降って来た。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベートーヴェンに対する尊崇は、日本だけの現象ではないが、ベートーヴェンなくんば西洋音楽なしの感あるは、多少の行き過ぎにしても、一方音楽の普及力、並びに文化に対する浸透力の方面から言えば、まことに結構なことであったと思う。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方音楽院長のデュボアは、「ペレアス」を聴くことを学生に禁じた。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾張の知多半島などでこの遊びをネギゴトといい、それに使う木の棒をネギというのも、同じ念木という語の地方音だったかも知れぬが、別にこれを願いごとまたは禰宜事と解してもよいような感覚がなお残っていて、二つの心持が融合したものとみられる。",
              "citation": {
                "source": "こども風土記",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
