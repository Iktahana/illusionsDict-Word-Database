        "examples": {
          "standard": [
            {
              "text": "「干し草の山から一本の針を探すようなものだ」と、彼はその作業の困難さを嘆いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夕暮れ時、子供たちが牧場に高く積まれた干し草の山に登って遊んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "モネの描いた連作「干し草の山」は、光の当たり方による色彩の変化を見事に捉えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "何か誘導する標識が無かったら、このようなものを意図的に探すのは諺に言う干し草の山に針を探すように望みがない仕事であろう。",
              "citation": {
                "source": "アルカプトン尿の発現",
                "author": "THE INCIDENCE OF ALKAPTONURIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "干し草の山から針一本探すようなものだ。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
