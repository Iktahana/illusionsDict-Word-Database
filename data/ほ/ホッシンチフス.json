    "definitions": [
      {
        "index": 1,
        "gloss": "epidemic typhus",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "先ごろ浅草の本願寺だかで浮浪者の救護に挺身し、浮浪者の敬慕を一身にあつめて救護所の所長におされていた学生が発疹チフスのために殉職したという話をきいた。",
              "citation": {
                "source": "特攻隊に捧ぐ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして患者が結核または発疹チフスに罹っていた２−３例を除いて、実際の罹病の日時は不快が始まったときと決められた。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "……発疹チフスというやつでね。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "１）　Id. vol. iii. p. 178.　世界中で最も美しい地方の一つであるシレでは、最悪性の発疹チフスがほとんど絶えることがない１）。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "（３）発疹チフス　これが西洋で如何に絶え間ないものであり恐ろしい呪いであったかは信ずるのが困難であるが発疹チフスの歴史はヨーロッパの歴史であるとある研究者は言っている。",
              "citation": {
                "source": "簡約医学史",
                "author": "A Concise History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "感染率はイギリスで百万人あたり1,228人（当時は区別されていなかったので発疹チフスと腸チフスの合計）から1838年に腸チフス137人と発疹チフス３人に減少した。",
              "citation": {
                "source": "簡約医学史",
                "author": "A Concise History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしゴミに依存するところは発疹チフスに非常によく似ているが、衛生を完全にすることによって熱帯地帯でホームになっていたハヴァナや以前に流行していた南部諸都市から実際上に消し去ることができた。",
              "citation": {
                "source": "簡約医学史",
                "author": "A Concise History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふつうの多くの病気、たとえばマラリアや発疹チフスは特定の日に突然に終了することはこの信念を支持した。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルイと彼の弟子ガーハードその他は発疹チフスと腸チフスの違いを明らかにして病理学においてもっとも不明瞭な問題の１つを解明した。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在生きている人の記憶の範囲では我々の大都市で発疹チフスが大きな天罰であり恐ろしい流行病になっていて、とくに死亡率が高かったのは医師であったことを実感するのは困難である。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "19世紀の40年代のアイルランドにおける厳しい流行ではアイルランドの全医師の５分の１が発疹チフスで死亡した。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄熱病、マラリア、赤痢、発疹チフス、が９年間にほとんど２万人の従業員を持ち去った。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは強い敵にたいする長期にわたる戦いであって、いくら低く見積もっても結核が少なくともハンセン病や発疹チフスと同じように消滅した病気になるには数世代かかるであろう。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "シラミによる発疹チフス、水からの伝染病、その他。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがペストであるか天然痘であるか発疹チフスであるか知られていない。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "このようにして彼は現在発疹チフスとして知られている病気を発見した。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲルンスバッハで発疹チフスの流行が始まった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "天然痘、ジフテリア、結核、麻疹、産褥熱、チフス（腸チフスと発疹チフスは未だ区別されていなかった）、マラリアによって多数の犠牲者が出ていた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "シラミが繁殖し発疹チフスがひろがった。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚れた衣服でシラミは増殖し、シラミは発疹チフスや回帰熱などの媒介体である。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "インドにおける流行の１つで人口100万人あたりの死亡数は次の通りであった(21):※章表５　多くの他の伝染病たとえばコレラ、黄熱病、発疹チフス、は同じように経済が発展した国から追い出されたが我々は決して免れたのではない。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今日、1941-1942の冬に発疹チフスは始まり東部戦線において燃え上がっている。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "発疹チフス　ハンス・ジンサーは非常に機知に富んだ本「ネズミ、シラミと歴史」(5)に「政治および軍事の歴史に及ぼす疫病の影響、および将軍たちの比較的な非重要性」という章を設けた。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルネッサンス以降に発疹チフスは優れた軍隊を破り多くの国の一般市民を苦しめる最も危険な敵の１つであった。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "発疹チフスはまた経済が不況のときや過去の混み合い非衛生な刑務所では大きな問題であった。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "発疹チフスはもともと東洋から来たものでこの病気それ自身は独立のものと認められていなかったが(6)ヨーロッパで中世に病人が発生したに相違ない。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "発疹チフスはまたドイツ皇帝カルル５世とフランス王フランソワ※１世の間における２回目の戦争で決定的な役割を果たした。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇帝軍は飢餓に苦しみ大義名分が失われたように見えたときに包囲軍に発疹チフスが突然に発生してフランス軍は殆ど一掃されてしまった。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
