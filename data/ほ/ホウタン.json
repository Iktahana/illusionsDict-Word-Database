[
  {
    "uuid": "6ec1b058-ef0f-544f-95d8-cb79b76adbaf",
    "entry": "放胆",
    "reading": {
      "primary": "ほうたん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "boldness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何で一人前の男をこんな放胆な飼い方をするのだろう。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "格別の新しがらなくとも新らしい智識の洗礼を受けたのちの彼女｜等の素直さと女らしい愛らしさと皓潔な放胆がぎすぎすした理窟や気障な特別な新らしがりより新らしいのでしょう。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの子　宜い調和と賢い素直さと皓潔な放胆で適宜に生きるというほどいつの時代にだって新鮮な生き方はなかろうと思いますわ。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　柿本は、高取の放胆な話しッ振りに似ず、しみ／″＼とした心持になった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "放胆な大槻は、妻を持ち子を持とうとしている、行一の気持に察しがなかった。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は似ようが似まいがどうでもいいというくらいの心持ちで放胆にやり始めてただ二日で顔だけはものにしてしまった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は何処までも快活な男で、放胆で、而も眼中人なきの様子がある。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその弁護人が摯悍矯直にして裁判官を面責することを恐れざる放胆を予め示して置いたときである。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "一代を震骸すべき重大犯罪事件の調書として、其数頁を繰つたものは、誰でも被告の自白なるものが、絶倫なる記憶力と放胆なる蛮性からでなければ、決して供述することの出来ない事実の供述から出来上つて居ることを看出し得たであらう。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術は懸命な努力と奇特な志がなければどんな境遇に居ても決して行はれるものではありませんね、私の芸術が明快であり放胆華美であり肩肘昂げて人生の厳粛呼ばりをことさらにしないと云つて、あそびなど云ふ人こそ却つて厳粛ごつこのあそびをして居る気障な本当の苦労をしない人の云ふことでせう。",
              "citation": {
                "source": "一平氏に",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父君の時政公でさへ、この相州さまに較べると、まだしもお無邪気な放胆の明るさがあつたやうでございます。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭山翁は終生をこの無造作と放胆振りでもって押通している。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは放胆な露骨な話であつた。",
              "citation": {
                "source": "青い紐",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は慰めようもなく、ただおおいに放胆なことをいうて主人を励ました。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然華やいだ放胆な歌声が耳に入った。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時は葉子は慎み深い深窓の婦人らしく上品に、ある時は素養の深い若いディレッタントのように高尚に、またある時は習俗から解放された adventuress とも思われる放胆を示した。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」特別な事情がある為に、それで余計に飲むのだ、と察しられたりしてはつらかつたので、彼は殊更に放胆らしく「馬鹿に今晩は寒いな。",
              "citation": {
                "source": "熱海へ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二葉亭も一つの文章論としては随分思切った放胆な議論をしていたが、率ざ自分が筆を執る段となると仮名遣いから手爾於波、漢字の正訛、熟語の撰択、若い文人が好い加減に創作した出鱈目の造語の詮索から句読の末までを一々精究して際限なく気にしていた。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒月の放胆｜無礙な画風は先人椿岳の衣鉢を承けたので、寒月の画を鑑賞するものは更に椿岳に遡るべきである。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術即生活は椿岳に由て真に実現されたので、椿岳の全生活は放胆自由な椿岳の画そのままの全芸術であった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも椿岳の大作に数うべきものの一つであるが、就中大浪は柱の外、框の外までも奔浪畳波が滔れて椿岳流の放胆な筆力が十分に現われておる。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今なら文部省に睨まれ教育界から顰蹙される頗る放胆な自由恋愛説が官学の中から鼓吹され、当の文部大臣の家庭に三角恋愛の破綻を生じた如き、当時の欧化熱は今どころじゃなかった。",
              "citation": {
                "source": "四十年前",
                "author": "――新文学の曙光――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は運転手の放胆な操縦が、此の惨禍の主なる原因であることを、信じたからであった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時は既に大官を得て出世しているとはいえ、万事が粗野放胆で婚儀のことなど礼節にかかわらず、妻を娶るは品物のやり取り位に思っていたであろうから、お品の好い御殿風な三枝未亡人を驚かしたも無理ならぬことと思われます。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大隈綾子刀自の思い出",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは相手を憐愍するから起る忍耐ではなく、ああ実に、聴く人があらば聴いて貰いたい、実に、それは、自分から自分を侮辱し軽蔑する自棄と放胆とから生じた忍耐であった。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは放胆な露骨な話であった。",
              "citation": {
                "source": "青い紐",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は運転手の放胆な操縦が、此の惨禍の主なる原因であることを、信じたからであつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫蘇の紫にそれ程の趣好と用意とはなささうで、ことによつたら造化の絵具皿に紫の色しか残つてゐなかつた時の創造かも知れませんが、それにしても、色も香も紫づくめに塗りくつた放胆な意匠は季が季だけに充分の効果が見えます。",
              "citation": {
                "source": "雨の日に香を燻く",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くものすれば放胆の方に養ふ所あり、苦しみてものすれば小心の方に得る所あり。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月のごいわいに松の葉を手に取り持ちて、祝うなるものかなこれは誰がほうたんだえもとさえもがほうたんだ一本植えればせんぼになるかいとの早稲の種かな、ほい／＼と唱えてそのエンブリを摺った。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
