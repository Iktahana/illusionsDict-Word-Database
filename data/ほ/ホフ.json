    "definitions": [
      {
        "index": 1,
        "gloss": "male carer (at a nursery school, children's home, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ああ、いづこぞ夢の序樂のぽろねえず、會社は河岸に涙をひたし、花店の飾窓つゆにぬれたり、しばしまたつりがね鳴らむ、あさまだきにほふ葉影に、しろじろとかざし泳がせ、この列をなす少女らあゆむ。",
              "citation": {
                "source": "若き尼たちの歩む路",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゑゝ言ふ事を聞かぬ我まゝ者め、何うともお爲と捨てぜりふ言ひて心ともなく庭を見るに、ぬば玉の闇たちおほふて、物の黒白も見え分かぬに、山茶花の咲く垣根をもれて、書生部屋の戸の隙より僅かに光りのほのめくは、おゝまだ千葉は寢ぬさうな。",
              "citation": {
                "source": "われから",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二荒の山の裾野にあかねさす紫匂ふ花あやめかも櫻草の花によく似る紫の花めでつゝも名を知らずけり花あやめしみ咲きにほふ紫の花野を來れば物思もなし紫の雲ゐる野べに朝遊び夕遊びます二荒の神湯の滝を見、湯本に遊びて帰る。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲメンゲラーゲさながらを、　　焦げ木はかつとにほふなり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はかなきかなや夕さりを、　　なほふかぶかと物おもひ、街をうづめて行きまどふ、　　みのらぬ村の家長たち。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "深呼吸新美南吉クリームのやうににほふから、――朝の空気はにほふから、通風筒は深呼吸。",
              "citation": {
                "source": "深呼吸",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "合歓の木、ねもとはにほふよ、花だか、土だかにほふよ。",
              "citation": {
                "source": "ごろぜみ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一方原始的の食人種が敵人をほふってその屍の前に勇躍するグロテスクな光景とのある関係も示唆される。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青丹よし寧楽の都は咲く花の　　にほふがごとくいま盛りなり奈良七重七堂伽藍八重ざくら　前の和歌は当時を詠んだ古歌であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "トンネルの暗闇に彗星でも出て見ろと、クツシヨンに胡坐で、湯呑につぐと、ぷンとにほふ、と、かなで書けばおなじだが、其のぷンが、腥いやうな、すえたやうな、どろりと腐つた、青い、黄色い、何とも言へない惡臭さよ。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、たふさぎといふよしは、手にて前を塞ぎ秘すべきを、手のかはりに布にておほふゆゑにいふなりとぞ。",
              "citation": {
                "source": "当世女装一斑",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "このまより　　すすしくにほふ。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫柳つめたく青ざめた顏のうへにけ高くにほふ優美の月をうかべてゐます月のはづかしい面影やさしい言葉であなたの死骸に話しかける。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "をとめは戀戀の羞をふくんであけぼののやうに爽快な　別製の皿を運んでくる仕組私はゆつたりとふほふくを取つておむれつ　ふらいの類を喰べた。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みよあめつちにみづがねながれしめやかに皿はすべりてみ手にやさしく腕輪はづされしが眞珠ちりこぼれともしび風にぬれてこのにほふ鋪石はしろがねのうれひにめざめむ。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠く市街を離れたところでだれも訪づれてくるひとさへなく林間の　かくされた　追憶の　夢の中の珈琲店であるをとめは戀戀の羞をふくんであけぼののやうに爽快な　別製の皿を運んでくる仕組私はゆつたりとふほふくを取つておむれつ　ふらいの類を喰べた。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫柳つめたく青ざめた顏のうへにけ高くにほふ優美の月をうかべてゐます。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅順の要塞が陥落すると、日本の国内は、もったいないたとえだが、天の岩戸がひらいたように一段とまぶしいくらい明くなり、そのお正月の歌御会始の御製は、　　富士の根ににほふ朝日も霞むまで　　　　　としたつ空ののどかなるかな　まさに日本は、この時、確実に露西亜を打破ったのだといってよい。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」坐つたままで袴を脱いでそれを老母にほふつてやつて、「ああ、お母さん。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その片隅の薄あかり、背にうけて天鵝絨の赤きふくらみうちかつぎ、にほふともなく在るとなく、蹲み居れば。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あな、見よ、青き大月は西よりのぼり、あなや、また瘧病む終の顫して東へ落つる日の光、大ぞらに星はなげかひ、青く盲ひし水面にほ薬香にほふ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはらかきほの熱る女の足音あはれそのほめき如し、燃えも生れゆくゆめにほふ心音のうつつなきかな。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてしもゆるけくにほふ夢路、したたりしたたる櫂のしづく、薄らに沁みゆく月のでしほほのかにわれらが小舟ぞゆく。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｅ　不調子われは見る汝が不調、――萎びたる瞳の光沢に、衰の頬ににほふおしろひの厚き化粧に、あはれまた褪せはてし髪の髷強きくゆりに、肉の戦慄を、いや甘き欲の疲労を。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "はやにほふ樅のふたもと。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十一年八月　　入日の壁黄に潤る港の入日、切支丹邪宗の寺の入口の暗めるほとり、色古りし煉瓦の壁に射かへせば、静かに起る日の祈祷、『ハレルヤ』と、奥にはにほふ讃頌の幽けき夢路。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "見よ、女が髪のたわめき濡れこそかかれ、このときつと寄り、男、みだらの接吻――にほふ舗石。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "つつましき枯草の湿るにほひよ……円形に、あるは楕円に、劃られし園の配置の黄にほめき、靄に三つ四つ色｜淡き紫の弧燈したしげに光うるほふ。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
