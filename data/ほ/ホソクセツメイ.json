        "examples": {
          "standard": [
            {
              "text": "先生は、難しい箇所について補足説明をしてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プレゼンテーションだけでは不十分だったので、後日補足説明の機会が設けられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "Q&Aセッションで、彼は質問に対してさらに補足説明を加えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "つまり、分配されない理由があって、それをヒダ側の伝説が補足説明していると見ることができますまいか。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛騨・高山の抹殺――中部の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その次にフシギな女について詳説したのは、なぜ男が山口であるかということを、補足説明するためのことである。",
              "citation": {
                "source": "フシギな女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
