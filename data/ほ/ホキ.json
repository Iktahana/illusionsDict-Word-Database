  {
    "uuid": "12e39743-46f1-5df0-82d5-b2545fa0739d",
    "entry": "ホキ",
    "reading": {
      "primary": "ホキ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hoki (Macruronus novaezelandiae)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "サテ、コノ　タケノコハ　オホキク　カタク　ナツタ　トキ、リツパナ　ヨコブヱト　ナリマシタ。",
              "citation": {
                "source": "タケノコ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヤア、チヒサイネ」「コドモデスカラネ」「コレデハ、オトナニ　ナツテモ　アマリ　オホキク　ナリマスマイ」「イヤイヤ　オトナニ　ナツタラ、コヤクラヰノ　オホキサニ　ナル」「ダマサウタツテ　ダメダヨ」「ホントウデスヨ。",
              "citation": {
                "source": "ウサギ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "コレガ　オホキク　ナル　シヨウコデス」　ミルト　ナルホド、ナガイ　ミミガ　フタツ、ニヨツキリ　ハエテ　ヰマス。",
              "citation": {
                "source": "ウサギ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナニシロ、イマニ、コヤミタイニ　オホキナ　ロバニ　ナルト　イフノデスカラ、チヒサナ　クルマデハ　マニアヒマセン。",
              "citation": {
                "source": "ウサギ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "トコロガ　ウサギノ　ハウハ　イクラ　ダイジニ　シテ　ヤツテモ、チツトモ　オホキク　ナリマセン。",
              "citation": {
                "source": "ウサギ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナニカト　マウシマスト、ホカデモ　アリマセン、オホキナ　ハゲシイ　オナラヲ　スル　コトデ　アリマス。",
              "citation": {
                "source": "ガチヨウノ　タンジヨウビ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「グツグツグツ、カアチヤン」　コドモダヌキハ　タマラズ　トウトウ　オホキナ　コヱヲ　ダシテ　ナキダシマシタ。",
              "citation": {
                "source": "ゲタニ　バケル",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月十四日大王はホホキルヒで敵に撃破せられたけれども大体に於て能く敵を圧し、遂にほとんど完全に敵を我が占領地区より駆逐して冬営に移る事が出来た。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "オバアサンガ一字ヨムカヨマナイウチニ――オバアサンハ、ムツカシイ字ヲヨムトキハ一字ヨムノニトテモ時間ガカカルノデス――マドノソトデ、ハリサケルヤウナオホキナオトガ、キコエマシタ。",
              "citation": {
                "source": "ネコ　ノ　オバアサン",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ト、ミミガヤブケルヤウナオホキナコエヲシテ、ミケ子トトラ三ガ、マドノソトヲトホツテユキマシタラ、オバアサンハヤツトメヲサマシマシタ。",
              "citation": {
                "source": "ネコ　ノ　オバアサン",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジロウハ　カケマワリナガラ　オホキナコエデ　ウタヒマシタ。",
              "citation": {
                "source": "スナマンヂウ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ジロウハ　トビアガツテ　オホキナコエデ　ウタツテ　ワラヒダシマシタ。",
              "citation": {
                "source": "スナマンヂウ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「キミモ　イマニハ　オホキクナルサ。",
              "citation": {
                "source": "こいぬ　の　ちびすけ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ウウ、ウウ、ボクハ　キミヨリ　オホキインダ。",
              "citation": {
                "source": "こいぬ　の　ちびすけ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボクハココイラキンジヨデ　イチバン　オホキインダ。",
              "citation": {
                "source": "こいぬ　の　ちびすけ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケサハヤク　ノハラデ　アソンデヰテ、ヒヨイト　ミタラ、ボクノカゲハ　キミヨリ　ズツト　オホキカツタンダゼ。",
              "citation": {
                "source": "こいぬ　の　ちびすけ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "イクラ　オホキク　フンバツテモ、チイサナ　カゲハ　オホキク　ナリマセンデシタ。",
              "citation": {
                "source": "こいぬ　の　ちびすけ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アサ　ミタトキヨリモ、モツト　モツト　カゲハ　オホキク　ナツテヰタノデス。",
              "citation": {
                "source": "こいぬ　の　ちびすけ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "キミノ　カゲハ　オホキイガ、ボクノカゲハ　モツト　ズツト　オホキイヨ。",
              "citation": {
                "source": "こいぬ　の　ちびすけ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "カゲガドンナニ　オホキクナツテモ　キミハ　ヤツパリ　コイヌ　ナンダヨ。",
              "citation": {
                "source": "こいぬ　の　ちびすけ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ボクハ　オホキナ　カゲヲモツタ　コイヌダ。",
              "citation": {
                "source": "こいぬ　の　ちびすけ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "イマニ　モツト　オホキナ　カゲヲモツタ　オホイヌニ　ナルンダ。",
              "citation": {
                "source": "こいぬ　の　ちびすけ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アタマノウエデ　オホキナ　フトンガ　マドノトコロデ、パタパタト　アバレテヰマシタ。",
              "citation": {
                "source": "オホサウヂ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　カメコオバサンハ　オホキナ　アクビヲ　カミコロシナガラ、イヒマシタ。",
              "citation": {
                "source": "オマツリ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "カメコオバサンハ　オホキナ　アクビヲ　カミコロシナガラ、「デモネエ、ワタクシ　スコシ　ハデスギヤシナイカト　オモフノデスケレド。",
              "citation": {
                "source": "カメサン　ノ　サウダン",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギンザヲトホルト、クマノ　トムクント　メリーサンハココハ　ボクシッテヰルアタシモ　シッテルワトオホキナコヱヲ　　　　　ダシマシタ。",
              "citation": {
                "source": "ユメノリヨカウ",
                "author": "岡本歸一",
                "note": "青空文庫"
              }
            },
            {
              "text": "トウ　トウトムガ　オホキナカラダデ、アンマリアバレタ　　　ノデ、フネガヒックリ　カヘッテ、シマイ　　マシタ。",
              "citation": {
                "source": "ユメノリヨカウ",
                "author": "岡本歸一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
