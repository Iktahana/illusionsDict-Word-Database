        "examples": {
          "standard": [
            {
              "text": "海外旅行には、ポケット翻訳機を持っていくと便利だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最新の翻訳機は、リアルタイムで会話を翻訳してくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は英語が苦手だが、翻訳機のおかげで海外出張も安心だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして内地語で書くことを慊らずとする者、又は実際に書けぬ者の芸術のためには、理解ある内地の文化人の支持と後援のもとに、どしどしいい翻訳機関でも拵えて紹介するように努めるがいい。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイクロコンピューターを使った「音声装置付き多国語翻訳機」は、ここから生まれたアイディアだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
