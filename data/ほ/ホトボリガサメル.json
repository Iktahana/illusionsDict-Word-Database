        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だからお前、そのほとぼりが冷めるまでは、おたがいに窮屈でも、じっとこうして隠れていなくちゃならねえ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間体とは関係がないと云ひながら、事件のほとぼりがさめるのを待つ気でゐるとしたら、やつぱり、おんなじではないか。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてやがてほとぼりがさめると、また相変らず、おじさんの御出勤がはじまった。",
              "citation": {
                "source": "おじさんの話",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほとぼりがさめるとまた、王婆の奥に入り浸って、金蓮相手に、したい三昧な痴戯に耽った。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
