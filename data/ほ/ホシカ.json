    "definitions": [
      {
        "index": 1,
        "gloss": "fertilizer made from dried sardines",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これだけならば不思議はないのであるが、次の巻のいちばん初めのその人の句が「卵産む鶏」であって、その次が「干鰯俵のなまぐさき」である。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大小いづれも串を用ゐず、乾したるは干鰯といふ。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲公英の咲く川堤に並んで腰を打ちかけ、お宮の背後から揚る雲雀の声を聞きながら、銀之丞が腰の瓢と盃を取出せば、千六は恥かしながら背負うて来た風呂敷包みの割籠を開いて、焼いた干鰯を抓み出す。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに福岡にも鎮台が設けられて、町人百姓に洋服を着せた兵隊が雲集し、チャルメラじみた喇叭を鳴らして干鰯の行列じみた調練が始まった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫に干鰯でツイ卑しい根性出いたのが悪かった」「この外道等……訳のわからん文句を云うな。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰯のヌタに蒲鉾が肴だったというが、二人とも長酒で、そんな場合はいつも徹宵飲み明かすのが習慣だったので、娘さんは肴に心配をして近所の乾物屋から干鰯を買って準備していたというね。",
              "citation": {
                "source": "無系統虎列剌",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "西木、斎藤の両家は勿論のこと、前の日に斎藤さんの診察を受けた患者の家も勿論のこと、ヌタの材料を売った魚屋から、斎藤さんが喰いもしない干鰯を売った乾物屋まで、疾風迅雷式に猛烈な消毒、出入禁止だ。",
              "citation": {
                "source": "無系統虎列剌",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の様に一尾一円もする時代では鰯の干物の値打ちも昔日の比でなく、この歌の対照の面白味も少しく減るわけだが、この歌の出来た頃の干鰯の値段は一尾一銭もしなかつただらう。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "一応もっとも至極の説なれども、田舎の叔母より楷書の手紙到来したることなし、干鰯の仕切に楷書を見たることなし、世間日用の文書は、悪筆にても骨なしにても、草書ばかりを用うるをいかんせん。",
              "citation": {
                "source": "小学教育の事",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処の津より運び来にけん、俵にしたる米の他に、塩鮭干鰯なんど数多積めるに。",
              "citation": {
                "source": "こがね丸",
                "author": "巌谷小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十二回　聴水黒衣の二匹の獣は、彼の塩鮭干鰯なんどを、総て一包みにして、金眸が洞へ扛きもて往き。",
              "citation": {
                "source": "こがね丸",
                "author": "巌谷小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日しも主家の廝に曳かれて、この辺なる市場へ、塩鮭｜干鰯米なんどを、車に積て運び来りしが。",
              "citation": {
                "source": "こがね丸",
                "author": "巌谷小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸には大八車にべか車、荷駄の馬、負子などが身動きもならぬ程に押合いへし合い、川の岸には山と積上げられた灘の酒、堺の酢、岸和田の新綿、米、糖、藍玉、灘目素麺、阿波蝋燭、干鰯。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "長崎ものがたり",
                "note": "青空文庫"
              }
            },
            {
              "text": "王子川、赤羽川、深川｜干鰯場などにて釣る。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤羽川は川口で、深川干鰯場などというなつかしいところの名まえが出てくる。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると隣の干鰯船から、仲間の八が、苫を剥くって、「――権十、飯の支度か」と顔を出した。",
              "citation": {
                "source": "旗岡巡査",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の干鰯船へは、まだ八の帰って来た様子もない。",
              "citation": {
                "source": "旗岡巡査",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "烈しい秋の日が照りつけて、むっとするような干鰯の匂もあたりに漲っているに相違ない。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、風雨の中を夢中で逃げ、身寄の漁師の家の床下、干鰯倉の闇、釣舟の中の幾日と、覚えきれない程な惨苦をなめて、やっと、奥州船へ乗り澄ましたのであった。",
              "citation": {
                "source": "篝火の女",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬一疋、一日の供食には、白米三合、味噌五十目、干鰯一升ずつ――日によって物はちがうがこの程度である。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　室の津の港に、五六人のごまの蠅が、干鰯のように砂地で転がっていた。",
              "citation": {
                "source": "梅※の杖",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "有り合せの干鰯を肴に、家のうちで酒を酌み交していた一学と木村丈八は、そとの声に、杯を措いて聞き耳を※てていたが、『よせばいいに、馬鹿な詮議立て』　呟いて、一学は干鰯を噛んだ。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の命よりもいとほしかつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡的だってあの大きな図体じゃ、飯もうんと食うだろうし、女もほしかろう。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「河原町で……」　と、言いかけて、君勇はいきなり、「――ほしかったら、あんたにあげる」「おおーけに……」　鈴子は無邪気にその扇子を受け取った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほしかったら、もっとあるぜ」　と、針助はまたパンを出した。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、自分たちがニューギニアでまるで乾いた雑巾から血を絞りとるほどほしかった航空機を作りに大阪の工場へ行くんだといって、じゃ、仲間の共同生活や小隊長を見捨てて行くのかという稗田の言葉には、大晦日に帰って来ると答えたまま出掛けてしまった。",
              "citation": {
                "source": "電報",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だかいい儲け口があるから、北海道へ行くとか言ってたけれど、その旅費がほしかったのかも知れないわ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうは、おかあさんも、ウナギの頭がほしかったのです。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼酎を買うお金がほしかったのです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
