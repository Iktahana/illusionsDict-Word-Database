    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese (language)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
