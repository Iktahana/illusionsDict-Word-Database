    "definitions": [
      {
        "index": 1,
        "gloss": "twig used in grafting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "月におほぎみのみやまひおもし、おほぎみのみやまひおもし。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　夜はこのときようやく初更に近く、宮戸あたり墨田の川は、牽牛織女お二柱の恋星が、一年一度のむつごとをことほぎまつるもののごとく、波面に散りはえる銀河の影を宿して、まさに涼味万金――。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀と黄金が考え深い様にまたたくと私の霊は戦く様に共にまたたき無声の声にほぎ歌を誦せばその余韻をうけて私も心の奥深くへと歌の譜を織り込んだ。",
              "citation": {
                "source": "旅へ出て",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、よくよく軽部も腹が立ったと見えてあるとき軽部の使っていた穴ほぎ用のペルスを私が使おうとすると急に見えなくなったので君がいまさきまで使っていたではないかというと、使っていたってなくなるものはなくなるのだ、なければ見附かるまで自分で捜せば良いではないかと軽部はいう。",
              "citation": {
                "source": "機械",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕べの寒さ計りに新年の年ほぎ縄を掛けてほぐかも（一月十六日）　一月七日の会に麓のもて来しつとこそいとやさしく興あるものなれ。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "おほぎみの御楯となるを待ち申す命は早くたてまつりつつ失題。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一郎はことほぎ詞も深くはいわず。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "男男こそ慰めはあれ、おほぎみの側にも在りぬ、みいくさに出でても行きぬ、酒ほがひ、夜通し遊び、腹｜立ちて罵りかはす。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "来り攻めよ、わがおほぎみ、わが親、わが夫、わがはらから、あはれ最後の戦ひにわれは瘋癲病院の冷き城に立て籠る。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其以外、古く這入つた千秋万歳のことほぎ系統に属するものが、極めて多く残つてゐるが、それらは皆、やまとの万歳に見られぬ程の早さながら、日本の舞ひぶりが基調になつてゐることは、その服装以上に明らかである。",
              "citation": {
                "source": "沖縄舞踊に見る三要素",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "元々此行事は、土地の精霊を意味する、夜叉神・羅刹神・麻陀羅神などゝ一つのものが群行して、まづ伊東家を訪れ、此を祝福した後、伊豆権現、或は其別当寺なる二善寺をことほぎする形だつたと思はれます。",
              "citation": {
                "source": "信州新野の雪祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三番叟の所作発言はことほぎと称せられるものであるが、同時にあの詞章だけをとつて来ると、鎮護詞と言ふものゝ古代の用語例に這入るものなのである。",
              "citation": {
                "source": "日本文学における一つの象徴",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎮護詞には全体として、其所作ことほぎが残つたのである。",
              "citation": {
                "source": "日本文学における一つの象徴",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことほぎの芸能化したのは、古いことであつて、我々には何時と定めることは出来ないが、其古い頃から既に採桑老でない仮面をつけて斎ひの場に現れたのである。",
              "citation": {
                "source": "日本文学における一つの象徴",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　山のことほぎ――山人・山姥かうして漂泊を続ける形の神人も昔からあつたのですが、其よりも、神人としては、常には奥山家にあつて、時折り里に下りて来るのが古い形なのです。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした山人と言ふのは、常には里との交渉を絶つて居ますが、歳暮・初春には、檀那の家や村をことほぎに下りて来ます。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お目出とうござります」「お目出とう、御苦労だったの」　とてお互いに、初日をことほぎ合ったあとで、雪之丞、手を突いて、「さて、わたくしはこれから、お客衆にまねかれまして、柳ばし、川長とやらへまで、顔出しをいたしてまいるつもりでございます。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌は、萬葉集にも似たものがあつて、おほぎみの御笠の山の帶にせる、細谷川の音のさやけさ　となつてゐます。",
              "citation": {
                "source": "歌の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなれば、『おほぎみの御笠の山』といふところに、人の頭が、もつれを感じます。",
              "citation": {
                "source": "歌の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "劉公は擯けて受けじといふに、たまたま劉氏の幼女六七歳ばかりなるが誕生の祝ひなどするをりなりければ、道士言へらく、こは大人の清玩には供へがたし、いささか女公子の福寿をほぎ奉らむのみとあるに、受け納めつ。",
              "citation": {
                "source": "『聊斎志異』より",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "其以外、古く這入つた千秋万歳のことほぎ系統に属するものが、極めて多く残つてゐる。",
              "citation": {
                "source": "組踊り以前",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "短歌の宿命何物も、生れ落ちると同時に、「ことほぎ」を浴びると共に、「のろい」を負って来ないものはない。",
              "citation": {
                "source": "歌の円寂する時",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「国栄えむと月は照るらし」も、転じて、殿ほぎに月を出したので、此夜は、主上・高級巫女同床せられるのだ。",
              "citation": {
                "source": "小栗判官論の計画",
                "author": "「餓鬼阿弥蘇生譚」終篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "念仏踊りの中にも、田楽能から移したらしい能狂言――物まね狂言――や、村｜群行や、家ぼめのことほぎが行はれて居る。",
              "citation": {
                "source": "古代研究　追ひ書き",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏歌のことほぎを説かねば、千秋万歳の芸能の一因の解決がつかぬ。",
              "citation": {
                "source": "古代研究　追ひ書き",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほぎ歌の一種、建て物に関したものが、後には、替へ歌などが出来て、読み歌の特徴を失ひ、唯、調子だけの名となつたが、尚「言ひ立て」風の文句を謡うたものと思はれる。",
              "citation": {
                "source": "叙景詩の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほぎの詞には、歌になつたものと、やゝ語りに近いものとがあつた。",
              "citation": {
                "source": "叙景詩の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者がほぎ歌であつて、後者は寿詞と称せられた。",
              "citation": {
                "source": "叙景詩の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "寿詞は、常に譬喩風に家のあるじの健康をほぐが、同時に建て物のほぎ言ともなるのである。",
              "citation": {
                "source": "叙景詩の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
