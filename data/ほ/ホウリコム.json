    "definitions": [
      {
        "index": 1,
        "gloss": "to throw into",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私とても、言葉の上の皮肉や、自分の行李を放り込む腹癒せ位で、此事件の結末に満足や諦めを得ようとは思っていなかった。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "さていよいよ放り込むや否や直ちにその穴を土で埋め、かくて声も香も他に知れざりしを確かめ、やっと安心して帰ったとあって、この書世に出た頃大いに疑われたが、ニエビュールがその真実たるを証言した。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までのように何を言ってもいけない、何を書いてもいけない、お前たちは黙って死んで行け、さもなければ牢屋へ放り込むというのでは自分たちの声を発揮することはできません。",
              "citation": {
                "source": "婦人の創造力",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水夫でもウッカリ反抗したら最後、足を捉まえて海に放り込むという評判を、まだ陸に居るうちに海員仲間から聞いた。",
              "citation": {
                "source": "幽霊と推進機",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とっつぁん、睡いだろうが、一本つけてくれ」　爺さんは、頷いて、銅壺に、燗瓶を放り込む。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "御堂ができるや否や待ち構えていた我々は意識を攫んでは抛げ、攫んでは抛げ、あたかも粟餅屋が餅をちぎって黄ナ粉の中へ放り込むような勢で抛げつけます。",
              "citation": {
                "source": "文芸の哲学的基礎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから何をするかと思って見ていると、例の栗をね、俵をほどいて、どんどん樽の中へ放り込むんですよ。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "呑み掛けの煙草を、青葡萄の灰皿に放り込む。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、東洋人を人間扱いにしていないのだ」「どうして、海ン中へ放り込むのさ」「この船の船員は、みんなピコル船長の乾児だろう。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふん、見兼ねて助ける風かえ、足を掬って放り込むほうだろう」とお神さん、さながらいま志ん生の得意とする裏長屋の神さんらしい調子で応酬してくる、てっきりまたどこかで丁半を争ってしまったものとひたすら泣いて口惜しがってはいるのである。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず地面に大きい穴を掘って、その中に石塊をたくさん放り込む。",
              "citation": {
                "source": "西洋の浜焼",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おきはそのままにして、燃え残りの丸太だけを取りのけて、この、いわば炉になっている穴の中にいろいろな材料を放り込むのである。",
              "citation": {
                "source": "西洋の浜焼",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "羊でも子牛でも、文字通り丸ごとであって、頭も皮もそのまま、毛までついたままで放り込む。",
              "citation": {
                "source": "西洋の浜焼",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には人から勧められる事もあり、たまには自ら進む事もあって、ふと十七字を並べて見たりまたは起承転結の四句ぐらい組み合せないとも限らないけれどもいつもどこかに間隙があるような心持がして、隈も残さず心を引き包んで、詩と句の中に放り込む事ができない。",
              "citation": {
                "source": "思い出す事など",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "堤軍次は非常な悪党で、お金の身代金の半分を着服した上、お坊っちゃんの左馬之助の目を盗んで、お金を物にしようと思いましたが、これは見事に失敗した上、北見之守に横合からさらわれてしまったので、例の悪魔的な智慧を働かせて、北見之守の涼船へ蛇を放り込む事を計画したのでした。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第八夜　蛇使いの娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「茶ん袋」というものに入れて、茶壺の耳についた金の輪に紐でしばりつけ、釜の湯がくらくらたぎると、そのしばりつけた茶袋を、そのまま放り込む。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃は、諸大名の門番や、見付の番人は言ふに及ばず、渡り中間、輕輩な士分の者まで、一種の武器として、棒を使つたもので、駕籠屋の股へ棒を放り込むくらゐの事は、ちよつと心得のある者なら、誰にだつて出來ます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "七人の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃は、諸大名の門番や、見附の番人は言うに及ばず、渡り仲間、軽輩な士分の者まで、一種の武器として、棒を使ったもので、駕籠屋の股へ棒を放り込むくらいの事は、ちょっと心得のある者なら、誰にだって出来ます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "七人の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミカンの皮をわざわざむしって放り込むと、すぐ吐き出してしまうが、一度はガバーッと食う。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "粉を口に放り込む瞬間、どうせぶっこわれた体だと――」　加納は言いかけて、あと口をつぐんだ。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして老婆はあなたをつまみ上げ、口を大きく開けて放り込む。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "水で割ると、かえってにおいが鼻につく」　つまみの塩辛を掌に受けて、丹尾は焼酎とともに口に放り込む。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その飲み方も、ウィスキー用の小さなコップに一杯注いで、ぐいと一と息に、飲むと云うよりは口の中へ放り込む。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどいのになると、残飯をあけているところへ、わざわざやって来て、タバコの吸い殻を放り込む佳人さえあるのだ。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十九日以上は拘留ができない規則から、このタライ回しが考案されたのだが、そのうち、サツの玄関の外に形式的に出して、すぐそのまま同じ豚箱に放り込むようになった。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の世に、十九世紀の昔語りにでもあり相な、貰い子殺しの部落が現存するかと思うと、真実の弟を叩き殺して、つい門前の土中に埋め、その御手伝いをさせたもう一人の弟を狂人に仕立てて、気違い病院に放り込むなど、まるで涙香｜小史飜案する所の、フランス探偵小説みた様な、奇怪｜千万な犯罪すら行われているのだ。",
              "citation": {
                "source": "魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "衛兵たちは、出発前夜の酒と御馳走に夢中になっていたので、三浦をほうりこむと、そのくさい部屋から、あたふたと出ていった。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんしろ荷物を台所へほうりこむ。",
              "citation": {
                "source": "正午の殺人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その勇ましい態度に、ザラもちからを得て、父である領主にたてついたので、彼は二人を城の牢屋にほうりこむことを命じますと、家来がだまってひきたてていきました。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひとを寝台からひきずりおろして、川のなかへほうりこむような人間は、どんなめにあわせたらよかろう。",
              "citation": {
                "source": "森のなかの三人の小人",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
