[
  {
    "uuid": "85d52e77-820d-5f22-9839-4b0c56c7220d",
    "entry": "奉加",
    "reading": {
      "primary": "ほうが",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "donation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "駿介は奉加帳を作つてそれらの人々の名を記した。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、奉加帳を開いて見せた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云つて奉加帳を擴げた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "でその費用は一般の寄進からとあつて、大きな奉加帳が順繰りに富豪連の手に廻される事になつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と富豪は使者の前へ大きな奉加帳を押戻した。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "何うともしてくれってんだ」　庄吉は、南玉の方へ、肩を聳やかして「おいらあ、これで、男の一分が立ったから、おさらばってことにして――一つ、仲間の奴へ、奉加帳を廻してさ、二三十集まったら、何か、こう小商売でもやらかそうかと思うんだが。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴木はそのクシャクシャになった手紙を読みづらそうに眺めていたが、「ああ、赤木の兄弟も奉加帳になってしまったのか」と悲しそうにつぶやいたが、「お前は松田というのか」とその男に訊ねた。",
              "citation": {
                "source": "恨なき殺人",
                "author": "宮嶋資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは武州高尾山の半ぺん坊主が、やけに大きな奉加帳を腰にブラ下げて、この寺に乗込んで来たことで、「こういうわけで、今度お許しが出ましたから、またまた山を崩し、木を伐って、車を仕掛けることになりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、役人の方はうまくまるめちまいましたが、工事をうまくまるめるには、別にそれ、丸いものが余分にかかりますでな……」といって、頤を撫でながら奉加帳をくりひろげたものです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "奉加帳をひろげて、べらべらと能書を並べた末、「さて高い声ではいえませんが……そうして登りが楽になりますてえと、山の上へ金持がバクチを打ちに参ります、商売人を連れて、おんかでバクチを打ちに参ります、これがそのテラといっては出しませんが、この連中の納める杉苗が大したものなんで。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これとても全く勧進奉加をしないで諸人の供養物をなげうってこう云うことをしたのである。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "堂塔の新築改造には、勧進、奉化、奉加とて、浄財の寄進を俗界に求むれども、実は強請に異ならず。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを「東大寺造立供養記」には、　東は毛人の域に勧進して夷類等随分の奉加あり。",
              "citation": {
                "source": "奥州における御館藤原氏",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも顎十郎の奉加につく一人で、このほうは叔父ほど手数がかからない。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "稲荷の使",
                "note": "青空文庫"
              }
            },
            {
              "text": "朧夜にそそのかされて、鉦も撞木も、奉加帳も打ちすてて、誘い合せるや否やこの山寺へ踊りに来たのだろう。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "御奉加賜れと奏上したが、折しも管絃の催しの時だったので、誰もこれを法皇に伝えなかった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第五巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "布施、奉加、献納金等のこと、みなわが国の風習に異なることなし。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲間の妹や姪たちもみな熱心な同情者で、それに、われわれがいいくらいに嗾しかけるものだから、四谷見附や仲町あたりで待伏せするようなのも三人や五人ではなく、貧乏な安部のために進んで奉加につきたいのも大勢いたが、酒田忠敬の二女の知世子が最後までねばりとおして、とうとう婚約してしまった。",
              "citation": {
                "source": "予言",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "一文｜商ひでも始めるなら、お妙へ入れ揚げた講中へ、奉加帳を廻して少しくらゐの資本は集めてやるぜ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "毒矢",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざま見やがれ」　と、笑って、兄弟分のために、奉加帳を廻した。",
              "citation": {
                "source": "醤油仏",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも會社の弔慰金はじつに雀の涙ほどなもので、見舞金あつめの奉加帳といふのがいつも仲間に廻つてゐた。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一紙半銭のご奉加も、今の文覚には、かたじけない。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君もはなやかな空想でせいぜい胸をふくらませて置いたほうがよい。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこのところを先生から大隅君に、よく注意してやったほうがいいと思います。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえってむしろ悪く頭のかたまったわれわれ専門学者のほうが始末が悪いかもしれない。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに東京と国とどっちがいいかと聞いてみたら、おくにのほうがいいと言った。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はむしろ意味のわからないほうがいいような気がしていた。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く外へ出たほうがよい、おれはも少し見て行くからと言ったら、ちょっとためらったが、おとなしく出て行った。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "川を戻るよりはここからさっきの道へのぼったほうがいい、傾斜もゆるく丁度のぼれそうだ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〕手を振ったほうがわかるな。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
