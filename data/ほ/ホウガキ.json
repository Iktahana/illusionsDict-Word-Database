          "literary": [
            {
              "text": "「わたしたちのなかにいるほうがきらくだよ。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみだっていつまで女給をしているわけでもなかろうから、そのほうがきみのためじゃあないかね」　と冗談らしく後ろから波瑠子の肩を抱えた。",
              "citation": {
                "source": "宝石の序曲",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めのうちこそ、いつもなかなか面白くできるんですけど、おしまいのほうがきっと出鱈目になっちまうんですわ。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へえ……そのほうがきみに、ゆ、有利なのかね？",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、きみが世間に対してすまないというよりも、むしろ世間のほうがきみに対して申しわけないんだろう。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ながいあいださんざん苦労してきたのだ、寝酒くらい飲むのはあたりまえだし、そのほうがきっと躯にもいいにちがいない、と云った。",
              "citation": {
                "source": "枡落し",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ、剃髪して、浄海入道となり、身にも法衣を着ているけれど、それも彼にとれば矛盾でも何でもなく、「白髪を蓄えておるよりも剃り下ろしたほうがきれいである。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより拙者のほうがきくが、いましがた、大津の町の上をとんでいた鷲が、ここらあたりでおりた形跡はないか、どうじゃ」「白ばッくれちゃいけない。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "理窟で説くよりは、感動に訴えるほうがききめのあることを知っていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
