        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "吉良はまだ寝起きの眼を腫れぼったくして、その暇のなかった朝飯の代りに、ホットケーキを食べていました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局「スター」の喫茶店で十五銭のホットケーキを食べれば、珈琲がついているから、一挙両得だと思ったのであるが、それには一銭足りない、誰か知った奴に会わないかと歩きまわったのである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「スター」の前を六度通ったが、そのたびに、陳列窓のなかにあるホットケーキの見本が眼にちらついてならなかった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三条の「リプトン」で十銭の珈琲を飲むか、うどんをたべるかどっちかにしようと自分に言い聴かせたが、どうにもホットケーキに未練が残った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふわっと温いホットケーキの一切が口にはいる時のあの感触が唾気を催すほど、想い出されるのだ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――会いたいときはなかなか知った顔に会わんもんやなと、その時のことを想い出していると、急にホットケーキが食べたくなった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「スター」へはいってホットケーキを食べた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍の鉛張りの実験台の上で、問題の伊那少年が銀のナイフでホットケーキを切っていた。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホットケーキを切りかけた白い指が、ワナワナと震えた。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビスケット、ホットケーキ、紅茶皿、干柿、鰺の乾物、塩ゆでの車鰕、こまかく裂いた※、南京豆、ビール瓶、コップ、茄子と瓜の味噌漬、林檎と蜜柑、小皿類……。",
              "citation": {
                "source": "塩花",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて彼が馥郁とかおる麦畑に通りかかり、蜂蜜の香を吸いこみながら見わたすと、うっとりするような期待が彼の心に忍びこんで、うまいホットケーキにバタをたっぷりつけ、蜂蜜か糖蜜をたらしたのを食べるときのことを考えた。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈うた：ソロとコーラス〉　ふけよラッパ　ならせベルを　カレーあじの　ホットケーキ　グラスかかげて　うたいながら　ようこそ　アリスとクイン　ようこそ　アリスとクイン　ようこそ　アリスとクイン　ようこそ　アリスとクイン　ようこそ　アリスとクイン　アリスとクイーンたちが席に着く。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホットケーキに、コーヒー、ココア、紅茶、皆歓迎だ。",
              "citation": {
                "source": "富士屋ホテル",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊水で銀のライター（十五円）一つ買ひ、不二家でホットケーキ食べる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーヒー以外、ホットケーキやみつ豆もうまくて、大衆的でゐ乍ら味がよく、丸の内へ来て一ばん恋しいのは、ハトヤである。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一回終るとデリケッセンのカツと、コーヒーに、トースト、ハム、ホットケーキと豪遊し、ねころびて揉ませる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハムエグストースト、ハンバークステーキにホットケーキ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、教文館のフジアイスへホットケーキのべーコン附が食ひたくなって、行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "天六下りたところで伊志井寛に逢ひ、不二家でホットケーキなど食ひ、中座の花柳を訪問する。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡辺・藤原とハイヤで町へ出た、コンキといふカフェかレストランか分らないとこでホットケーキを食べ、出てスマートボールといふのをやって二十銭ばかり遣ひ、宿へ帰ると、又読書。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房同道十一時に出て、教文館の富士アイスで食事、チキンクリーム煮入りのホットケーキといふのは大ゲテ物。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
