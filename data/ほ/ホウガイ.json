    "definitions": [
      {
        "index": 1,
        "gloss": "exorbitant",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "古本屋は法外の高価でそれを皆に売りつけて居た。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、何にしろ足利時代には一般にそういう魔法外法邪道の存することが認められていたに疑ない。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "勃凸の買つて来た赤皮の靴が法外に大き過ぎると冗談めいた口小言をいひながらも、おんつぁんはさすがに何処か緊張してゐた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文字は、うまいとも拙いとも批評に上せられぬような法外な字であった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "法外な賃金を強請って頑として動かぬ。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "良人が家に居てくれてすら生計が付かなかつた手許であつたのに、村中から法外人あつかひにせられ、日傭取に出ようたつて一寸頼み手もなくなつた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "○二月、大阪梅田の劇場に団十郎乗込み、二興行の給料五万円は余りに法外なりという物議を醸す。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、その倶楽部は恐しいと云っても決して見境もなく無闇矢鱈と恐ろしい事を企てるのではなくて、ただ倶楽部で決められた則をやぶった者に対してだけ少しの容赦もなくその法外にきびしい制裁を下すと云うのであって、彼等倶楽部員は皆、極端なる、「不正を悪くむ紳士方」であるのです。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様が法外な白痴だから己に妹があると謂ふことは人に秘して居る位、山田の知らないのも道理だが、これ／＼で意見をするとは恥かしくつて言はれもしない。",
              "citation": {
                "source": "妖怪年代記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめから人の妻を掴み取つてものを云ふ、悪魔の所業ぢや、無理も無躰も法外の沙汰と思へ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその為めに突き上げて来た笑いが、甲野氏への法外な愛嬌になった。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "梶井の父は銀行員で、これもその地面と家とを法外に安く買って来たらしかった。",
              "citation": {
                "source": "月の夜がたり",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、全く、今の私達の眼から見て、時代錯誤に近い世界――髭の生えた官員様がえらかったり、色々な肩書が法外にものをいったりする世界――なのであるが、そういう時代錯誤的な観念さえもが（更に、氏の作品の構想の幼稚な不自然ささえも）ここでは「鏡花的な美」の不可欠の要素となっているのは不思議なことである。",
              "citation": {
                "source": "鏡花氏の文章",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣服の法外な贅澤さに引換へて、住宅となると、之は亦、ミクロネシヤの中で最も貧弱だ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣服の法外な贅沢さに引換えて、住宅となると、これはまた、ミクロネシヤの中で最も貧弱だ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そうでなくとも法外な額の賭金を、二倍にしようと申込んだのだ。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで懸賞金は〆て三万フランを下らないことになったが、娘の低い身分や、大都会ではこういった惨事が実にたびたび起ることなどを考えると、これは法外な金額と考えていいのだった。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "結果的に生じたのは、ＤＯＳマシンの最先端から比べればかなり貧弱な機械に法外な値札がついた、お寒い日本市場の現実だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘次は工事がどんなことかも能く知らなかつたが一｜日の手間が五十｜錢以上にもなるといふので、それが其季節としては法外な値段なのに惚れ込んで畢つたのである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "疎匆とあれば致し方もないが、大切のお宝をわざと打割ったとは余りに法外の仕方で、たとい殿様が御勘弁なさるといっても、自分が不承知である。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のようなぜいたくは実は俺しにとっては法外なことだがな。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫れ台所に於ける鼠の勢力の法外なる飯焚男が升落しの計略も更に討滅しがたきを思へば、社会問題に耳傾くる人いかで此｜一町内百「ダース」の文学者を等閑にするを得べき。",
              "citation": {
                "source": "為文学者経",
                "author": "三文字屋金平",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは決して法外に安い給料とは思わなかったが最近、彼女の功績を大いに認めなければならぬ状態を認めて、姉や妻と寄々相談をしていた次第であったが、折も折、ちょうどそのさ中に、実に奇妙とも不思議とも、たとえようのない事件が彼女を中心にして渦巻き起って、遂に今度のような物凄い破局に陥ったのであった。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなったら仕方がないから、金でも遣って大小を出して貰うか、それとも相手の云うことを肯いて遊んでゆくか、二つに一つより外はないのですが、可哀そうに大次郎はあまり沢山の金を持っていない上に、こゝで祝儀を遣ったり、法外に高い勘定を取られたりしたので、紙入れにはもう幾らも残っていないのです。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "粗相とあれば致方もござりませぬが、大切のお品をわざと打割つたとは、あまりに法外の致し方。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "団十郎はその傲慢が増長して法外の暴利をむさぼると言うものもあった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私があなたに法外もない、天国の夢をお見せしました。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そりゃあお困りでしょう」「勿論、手前方でも相当のとむらい料を遣わすつもりで居りますが、どうもその、相手方の申し条が法外でございまして、どうしても三百両よこせ、さもなければ、お此さんを下手人に訴えると申すのでございます。",
              "citation": {
                "source": "半七捕物帳",
                "author": "弁天娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほど評判のいい徳蔵が根もないことを云いがかりにして、弟の主人の店へねじ込んで行こうとは思われなかったが、それにしても三百両という大金をねだるのは少し法外であると半七は思った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "弁天娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄の望み通りに、五百両でも千両でも出してやります」　さりとて千両は法外であると云うので、仲裁人らは再び交渉をすすめて、六百両までに相場をせり上げると、次右衛門もここらが見切り時と思ったらしく、渋々ながら承諾した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "かむろ蛇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
