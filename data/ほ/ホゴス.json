    "definitions": [
      {
        "index": 1,
        "gloss": "to unfasten",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "悲しいことにはわれわれはまだ、その聖文字を読みほごす知能が恵まれていない。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　手にほごす葉を散つて、小さな白いものが飛んだ。",
              "citation": {
                "source": "玉川の草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩の凝りをほごすために」　傍で新聞を読んでいた兄の陸郎はこれを聞いて「おばあさんのようなことをいう」と言って笑った。",
              "citation": {
                "source": "快走",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、濡れたところをしきりに手でもみほごす。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをほごすとまた油紙で包んであった。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ペネロペが昼間自分の織った織物を夜の間に解きほごすと同様に、自然もまた時々自分の制作したものを破壊する。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "又わしはどんなにもつれた糸でも手際良くほごす力を授かって居るでの。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はちょっと肩にかけて見ていたが、一度でも小夜子の手を通したものだと思うと、矜りが傷つけられるとでも思ったらしく、いきなり揉みくしゃに揉みほごすと、ヒステリックな表情でつかつか庭へおり立って下駄で踏みつけた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "油だらけの新聞紙をほごすと、焼きたてのロースビーフが、碁盤のように転がり出た。",
              "citation": {
                "source": "放浪の宿",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺さんが綱の玉を段々にほごすと、綱はするするするするとだんだん空の方へ、手ぐられでもするように、上がって行くのです。",
              "citation": {
                "source": "梨の実",
                "author": "小山内薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもなら何んとか矢代に突っかかって来る彼だったが、今日は何も云わず、黙って額を揉みほごすと軽く横に振ってみていた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ生れて以来使ってみたことのない翅と見え、蟻はそのままねばりついたような翅のよじれを解きほごす準備にかかっているらしかった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやら彼自身のこんがらがつた幼時の思ひ出をほごすのにあんまり夢中になり過ぎてゐたＴ君は、いつの間にやら、私たちの目指してゐる外人墓地への方向を間違へてしまつてゐるらしかつた。",
              "citation": {
                "source": "旅の繪",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、わたくしには、この年よりのいったんかけたのろいを、のこらずときほごすまでの力はございません。",
              "citation": {
                "source": "眠る森のお姫さま",
                "author": "ペロー　Perrault",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやら彼自身のこんがらがった幼時の思い出をほごすのにあんまり夢中になり過ぎていたＴ君は、いつの間にやら、私たちの目指している外人墓地への方角を間違えてしまっているらしかった。",
              "citation": {
                "source": "旅の絵",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人としては、なおくわしく、伊達家所蔵の王羲之の孝経――しかも唐太宗親筆入りという絶代ものの出所来歴を話して聞かせたかったらしいが、話がそこで折れた上に、その後は忙がしく、白雲もまた、いかに伊達家のことなりとも、羲之の真筆は少々割引物として、問いをほごすことをしてみませんでした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の髪を解きほごす素早い私の指先から、長いお前の髪毛は旅籠屋の井戸の中へと流れ込んだ。",
              "citation": {
                "source": "珊瑚集",
                "author": "仏蘭西近代抒情詩選",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも私の力では、それくらいにしなければ、あの『仙書参同契』をもみほごすことは出来なかったのである。",
              "citation": {
                "source": "身辺雑記",
                "author": "――『日本のこころ』を囲って――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで云わば二つの力が衝突することによって起こったこの旋回運動を簡潔に解きほごす為めには、この運動を二つの相対的な分に分解し、そうすることによって、夫々の分をして相反するこの二つの理論を代理せしめる必要があるのである。",
              "citation": {
                "source": "イデオロギーの論理学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "して見ると我と汝はいつまでも単に我と汝とであって、それが社会という存在の姿を示す型にも、夫をほごす鍵にもなるものではない。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々はこのこんがらがりを多少でもほごす義務があるのではないか。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくして竹村が、「むずかしいもんさね」　緊張した空気をほごすように、座蒲団の上で胸をひろげて、のびをするようにしながらいった。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔二四〕凝乎と、絶えず深く、鋭く見究めろ一から二、二から三――と繭をほごすようにじりじりと繰って行け。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍬を使う人があって、それがカチリカチリと小石に当って土をほごす音が、一層その場の情景を陰惨なものにしましたけれど、情景そのものよりもお銀様は、鍬の音と、その音をさせる主との何者であるかに眼を放ちました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "重くるしくだまっていると、それをほごすように、ミサ子は気がるに話しだした。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙っているスフィンクスの舌を誰もほごすことができないからである。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいま軽くうっちゃりを喫して、危くべそをかくところだったのだが、そんな出鱈目を喋っている中に、どうやら表情の緊張だけは揉みほごすことが出来た。",
              "citation": {
                "source": "メフィスト",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれどもきょうはとくべつにお肩がこっていらしって、おんえりくびのりょうがわに手毬ほどのまるいしこりがおできになっておりまして、もみほごすのがなか／＼なのでござります。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "イヤ、大きにありがとう」　眼八はていねいにこういってから、自分の振分を解いて、「うるさいことをきいてすみませんが、ついでに、もうひとつお伺いしたいと存じますが……」荷物の中から取り出した渋紙の端をほごすと、コロコロと一本の鑿がころがりだした。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "剣山の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
