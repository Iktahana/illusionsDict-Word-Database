    "definitions": [
      {
        "index": 1,
        "gloss": "this land",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "説明書によるとこの曲はもと天竺の楽で、舞は本朝で作ったとのことである。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二場、餅施行の事蹟は阿難と裸形外道との間の出来事であり、有手無手の問答は本朝禅宗の大燈国師の逸話中の事蹟よりヒントを得た。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今時本朝には斯樣のもあるまいが、淺葱の襟に緋縮緬。",
              "citation": {
                "source": "麥搗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃孫に代を譲って、雪叟とて隠居した、小鼓取って、本朝無双の名人である。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "○四月、市村座にて「本朝廿四孝」を上演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」（本朝桜陰比事、巻一の四、太鼓の中は知らぬが因果）　　　粋人「ものには堪忍という事がある。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此様な不祥のある度に威を張るのは僧侶｜巫覡で、扶桑略記だの、日本紀略だの、本朝世紀などを見れば、厭はしいほど現世利益を祈る祈祷が繰返されて、何程｜厭はしい宗教状態であるかと思はせられる。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "よししげの保胤などと読む者の生じたのも自然の勢ではあるが、後に保胤の弟の文章博士保章の子の為政が善滋と姓の字を改めたのも同じことであって、為政は文章博士で、続本朝文粋の作者の一人である。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の文人の源｜英明にせよ、源為憲にせよ、今｜猶其文は本朝文粋にのこり、其才は後人に艶称さるる人々も、皆文時に請いて其文章詞賦の斧正を受けたということである。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此往生極楽記は其序に見える通り、唐の弘法寺の僧の釈迦才の浄土論中に、安楽往生者二十人を記したのに傚ったものであるが、保胤往生の後、大江匡房は又保胤の往生伝の先蹤を追うて、続本朝往生伝を撰している。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三段抑々蒙古ときこゆるは草莽にして胡沙を馳駆し、万里北に蔓つて勢漢土に臨むや、金を滅し、宋を傾け、余威高麗に及んではしばしば本朝をもうかがふ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "文淵堂所蔵の「狂歌本朝二十四孝」「狂歌調子笛」等は早く嘉永六年に印刷せられたものである。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀本朝鮮征伐記　　　　　其他　　　日本戦史朝鮮役　　　近世日本国民史朝鮮役等",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "『長興記』をして、「本朝五百年来此の才学なし」とまで評さしめた当時の碩学一条｜兼良は『樵談治要』の中で浩歎して述べて居る。",
              "citation": {
                "source": "応仁の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "抑本朝の朝廷は、神代の初めより、殊なる御子細まします御事にて、異国の王の比類にあらず。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "此老人字は書けども、本朝の言語多く忘却しぬ。",
              "citation": {
                "source": "秘魯國に漂著せる日本人",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "果してしからば、我が可懐しき明神の山の木菟のごとく、その耳を光らし、その眼を丸くして、本朝の鬼のために、形を蔽う影の霧を払って鳴かざるべからず。",
              "citation": {
                "source": "遠野の奇聞",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その替りの外題は「優曇華浮木亀山」の通しで、切に「本朝廿四孝」の十種香から狐火をつけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "本朝虞初新誌を読む。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ興味のふかいことは、小杉放庵の呼吸ぬきは、「本朝道釈」のやうな作品を生み、この呼吸ぬき作品がなかなか風味が良いのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は小休止するときも、筆を停めない、そして「本朝道釈」のやうな、呼吸ぬきの、肩の凝らない、それでゐて内容的には非常に凝つた作品を見せてもらふことができる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本朝道釈」の中の一人物に芋銭を加へてゐるのなどは、如何にも放庵の理解の面白さがでゝゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が日本画家であつたら、「新本朝道釈」を描いて、芋銭の次に放庵を描くであらう。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにその後、『異制庭訓往来』和漢の名馬を列ねた中に、本朝｜厩戸王子甲斐黒駒、太宰大弐弘継土竜とあるを見出した。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが本拠ある事なら、広嗣の土竜がまず本朝で産地や毛色に由らぬ馬の名の最も早く見えたものであろう。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "何と仰天だろうとあるを読んで、そんな事をもしや邦書に載せあるかと蚤取眼で数年捜すと、近頃やっと『古今要覧稿』五〇九に、『本朝食鑑』を引いて、この事を記しあるを発見した。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "本朝にも住吉は軍神たり、世に事あればそこに飼う神馬見えず。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "このついでにいう、『日本霊異記』や『本朝文粋』に景戒や嚢鈔』十三に羊僧とは口に法を説かざるをいう。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに『続紀』に見えた柿本朝臣｜佐留、歌集の猿丸太夫、降って上杉謙信の幼名猿松、前田｜利常の幼名お猿などあるは上世これを族霊とする家族が多かった遺風であろう。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して比丘尼の詛いに由らぬはもちろんながら、この辺、昔の熊野街道で色々土人が旅客を困らせた事あったらしく、西鶴の『本朝二十不孝』巻二「旅行の暮の僧にて候、熊野に娘優しき草の屋」の一章など、小説ながら当時しばしば聞き及んだ事実に拠ったのだろう。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
