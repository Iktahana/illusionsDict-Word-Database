    "definitions": [
      {
        "index": 1,
        "gloss": "kindergarten hunting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
