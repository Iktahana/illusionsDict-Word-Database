        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かさこそと雑木の葉が、ばさりと朴の木の広葉が、……朴の木の葉は雪のように白く曝らされていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の砂は金銀の、雪は凍った、草履で可、……瑠璃の扉、と戸をあけて、のゆきげた瑪瑙の橋と、悠然と出掛けるのに、飛んで来たお使者は朴の木歯の高下駄、ちょっと化けた山伏が供をするようだわ。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "朴と月朴の木の濃き影見れば、弦月の黄に明るなり。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜露朱に円き朴の木の月、墓の上に湿る夜露や。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "天王寺の朝涼朴の木に白き花群れ、塔はあり、ひむがしの方。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "朴の木に白き花群れ、鐘が鳴る。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "取敢へず火鉢の側の鉢植の朴の木の枝にとまらせた。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "膝から上が桐の木で、膝から下が朴の木で作られて足の形を取る時に、かんなで削つたことを考へたのである。",
              "citation": {
                "source": "三十三の死",
                "author": "素木しづ子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處もほそ長い窪地になつてゐて、いろ／＼な雜木のなかに二三本の朴の木が立ち混り、夏の初めなどあの大きな白い花が葉がくれに匂つてゐたものである。",
              "citation": {
                "source": "樹木とその葉",
                "author": "東京の郊外を想ふ",
                "note": "青空文庫"
              }
            },
            {
              "text": "面小手で竹刀を引担いでお前、稽古着に、小倉の襠高か何かで、朴の木歯を引摺って、ここの内へ通っちゃ、引けると仲之町を縦横十文字に鳴して歩いた。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に深くなつた溪流の向うの岸の汀から朴の木が存分に葉を廣げて立つて居るのがある。",
              "citation": {
                "source": "旅の日記",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は小石をとつて朴の木へ投げて見た。",
              "citation": {
                "source": "旅の日記",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ近くだと思つた朴の木は余が腕の力では容易に小石が屆かぬのに驚いた。",
              "citation": {
                "source": "旅の日記",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "朴の木のもとを洗つて作並の浴槽の側を過ぎ行く水はこゝから見える密樹の根からしぼれ出る雫の聚りである。",
              "citation": {
                "source": "旅の日記",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "向ふの岸の岩間には山吹の花がしなやかな枝ごと風に吹きゆすられてゐる、自分の立つてゐる巖の近い處には大木の朴の木が雄大な花を咲かせてその高いかほりが時折に身に迫つてくる……。",
              "citation": {
                "source": "雪解水",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この沈默を破つた一番鎗は古山｜朴の木である。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分から云はせると、校長と謂ひ此男と謂ひ、栄養不足で天然に立枯になつた朴の木の様なもので、松なら枯れても枝振といふ事もあるが、何の風情もない。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "この沈黙を破つた一番槍は古山朴の木である。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母さんが朴の木の葉で包んで下さる※い握飯の香でも嗅いだ方が、お錢を出して買つたお菓子より餘程おいしく思ひました。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母さんはよく※い鹽のおむすびを庭の朴の木の葉につゝみまして、父さんに呉れました。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "お牧は朴葉飯といふものを造へて、庭にあつた廣い朴の木の葉に鹽握飯を包んで、それを私に呉れたものです。",
              "citation": {
                "source": "幼き日",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋間の窓並びに唐戸の枠は蝦夷松、額ぶちはヌカセン、その天井板二十五種、腰羽目板二十二種は、以上に擧げた種類の外に、シナ、ナラ、シウリ、ヱンジユ、櫻、槲、朴の木、ドロ、山モミヂ、オヒヨウ楡、ハンの木、アサダ、サンチン、カタ杉、檜の木などだ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔役の裔　久しい以前のこと、山の手から下町、下町から山の手と、殆んど処隈なく古ぼけた車に朴の木樫の木撫の木を載せて、いずれの太夫が用いすてたのやら、糸も切れ切れの古鼓を鳴らして、下駄の歯入れをなりわいに呼び歩く四十なにがしという爺さんがあった。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚朴の木を榛と云ふことは本草別録に見え、又｜急就篇顔師古の註にもある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの朴の木の下の二つ目の石、光を半分｜斜に受けて上を向いて、渋面をして泣いて居ます。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の松、葉銀杏、吉野檜、遠くでは向う屋敷の欅、朴の木、柳、庭の隅の秋草まで、見る限りの葉が皆動く。",
              "citation": {
                "source": "茗荷畠",
                "author": "眞山青果",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　主屋と離れ、崖の中腹に、懸け作りになっている別館が一棟、桜や椿や朴の木に囲まれ、寂然として立っていた。",
              "citation": {
                "source": "猿ヶ京片耳伝説",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朴の木、橿の木の一種にもおなじ名がある。",
              "citation": {
                "source": "花の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い地面に、廣い葉の青いまゝでちらばつて居るのは、朴の木だ。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は、あの谷川のほとりのほおのきを知っているだろう。",
              "citation": {
                "source": "風雨の晩の小僧さん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
