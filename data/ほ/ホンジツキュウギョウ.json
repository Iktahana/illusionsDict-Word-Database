          "literary": [
            {
              "text": "店の入口には本日休業と書いた紙が貼つてあつたが、中には頻に話聲がしてゐる。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋のまえに立ってみると、あの景気のよい呼びこみの声もなく、にぎやかすぎるほどの楽隊の楽士たちも、どこへ行ったかすがたがなく、表の札売場はぴったりと閉じられ、「都合により本日休業」のはり紙が四、五枚はりつけられ、そよかぜにひらひらしていた。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "本日休業の札がかかげられて、カーテンがおりている。",
              "citation": {
                "source": "町内の二天才",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかしくも、なんともねえや」「本日休業か。",
              "citation": {
                "source": "町内の二天才",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして慌てて店を閉ぢ、本日休業の札をかかげた。",
              "citation": {
                "source": "のんしやらん記録",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            }
          ]
        }
