  {
    "uuid": "3f9cce75-6b90-5bd6-ab2b-986b69fc3c2a",
    "entry": "褒章",
    "reading": {
      "primary": "ほうしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "medal of honour",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "功により、緑授褒章を賜はる。",
              "citation": {
                "source": "十和田湖",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "藍綬褒章とか、緑綬褒章とかいふものは、勲章の部類にはひらないと聞いてゐるが、文功章とやらはどつちの部類か。",
              "citation": {
                "source": "文功章",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "納富　　因循にして気概なき此の地方の青年は、悲しい哉、わが剣道の精神を解せず、私の素志は空しく今日に至つたのでありますが、一方、模範農場の経営と、農作指導の事業は、著々とその歩を進め、その翌々年には、仏蘭西政府より、名誉ある橄欖褒章の贈与を受けました。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "無形文化財とか、紫綬褒章とかいうものの偉力を身をもって体験させられた。",
              "citation": {
                "source": "おば金成マツのこと",
                "author": "知里真志保",
                "note": "青空文庫"
              }
            },
            {
              "text": "その功績によって昭和31年無形文化財保持者に指定され、紫綬褒章を授けられた。",
              "citation": {
                "source": "おば金成マツのこと",
                "author": "知里真志保",
                "note": "青空文庫"
              }
            },
            {
              "text": "頸飾もなければ、勲章もなく、褒章も着けてない。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
