    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bonus",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "報奨欲しくないということでは、ゆめゆめないが、それなら長らく懸想した女、どこにもおりませんでしたと、嘘ついて手ぶらで帰ってゆこうか。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "出頭して自白した犯罪者にも恩赦が与えられたが効果無く、莫大な報奨金も無駄だった。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
