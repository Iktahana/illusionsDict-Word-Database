    "definitions": [
      {
        "index": 1,
        "gloss": "to be strongly attracted (by)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
