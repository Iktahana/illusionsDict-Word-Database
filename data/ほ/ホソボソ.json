    "definitions": [
      {
        "index": 1,
        "gloss": "poor (living)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "といふのは、それでなくても厳しい父と細々し過ぎる母とが、殊に遊ぶこと以外には何にも考へようとはしない耕二に、執拗にも間がな隙がな小言を言ひつめるので、今もやつと許されて出掛けるらしい耕二に沢山の言葉は掛けないで出してやりたかつた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥の間でお通夜してくれる人たちの話し声が細々と漏れる。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "長さ一マイルの手紙　米国のある水兵が電信用の紐紙に細々と書いた手紙をその友に送った。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説といふものはだらだらして、くだらないことを細々と書き立てるので、讀むからに退屈であり、僕のやうな結論を急ぐ性急者には、てんでのつけから讀む氣がしない文學である。",
              "citation": {
                "source": "芥川龍之介の追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に就中、身邊記事のくだらない出來事を、茶呑み婆さんの繰言みたいに、絮々細々と――文壇の術語で言へば克明に――書き立てた日本の文壇小説に至つては、義務にも讀めた次第でない。",
              "citation": {
                "source": "芥川龍之介の追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "廣庭に向た釜の口から青い煙が細々と立騰つて軒先を掠め、ボツ／＼雨が其中を透して落ちて居る。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "金のない細々と商売している奴ばかりが、やかましい規則の制裁を受けた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　硬派でも軟派でも、細々と、小心に、ちょっとずつ扱っている人間は、発覚すると、自分自身の血税で、そのつぐないをつけさせられている。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、彼とは最もちかしい、市街の方々に散らばって、細々と暮しを立てゝいる人々や、血縁のつながっている人間を、直接、保護することも、行って見ることも出来なかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五｜日以上……滋養灌腸なぞは、絶対に嫌ひますから、湯水も通らないくらゐですのに、意識は明瞭で、今朝午前三｜時に息を引取りました一寸前にも、種々、細々と、私の膝に顔をのせて話をしまして。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してその背後には凡てのよいものも惡いものも、はかない存在の縁から切り放されて、忘却のあなたに消え去つて行く、その淋しい運命に對しての暖かい冷やかさが細々と動いてゐる。",
              "citation": {
                "source": "水野仙子氏の作品について",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝生代りに校庭に植えられた牧草は、三番刈りの前でかなりの丈けにはなっているが、一番刈りのとはちがって、茎が細々と痩せて、おりからのささやかな風にも揉まれるように靡いていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぬいさんは、畳についた両手をしゃんと延ばして寄せ合わせて、肩さえいつもより細々と見えるのに、襟足がのぞかれるまで顔を重く伏せていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長々と力なげに手を伸ばして、かじかんだ膝を抱えていたのが、フト思出した途端に、居合わせた娘の姿を、男とも女とも弁別える隙なく、馴れてぐんなりと手の伸びるままに、細々と煙の立つ、その線香を押着けたものであろう。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "可哀氣に、苦勞で氣やみに煩つて、帶をしめてもゆるむほど、細々と成つて居るものを、鐵槌で打つやうに、がん／＼と、あたまへ響くまで申しましたわ。",
              "citation": {
                "source": "三人の盲の話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "真俯向になって面を上げず、ものとも知らぬ濁みたる声で、「猿の年の、猿の月の、猿の日に、猿の年の、猿の月の、猿の日に、猿の年の、猿の月の、猿の日に、」と支干を数えて呟きながら、八九寸伸びた蒼黒い十本の指の爪で、件の細々とした、突けば折れるばかりの巌の裾をごしごしごしごしと掻※る。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は斯く云いつつ、瓶を差し上げて太陽の光線に透かしてみたが、「オオ、あるある果してみょうな物があるある」と叫んで、好奇心は満面にあふれ、口栓を抜くのももどかしと、かたわらの巖石をめがけて投げつけると、瓶は微塵に砕け、なかから黄色い紙に何か細々と記した物が出て来た。",
              "citation": {
                "source": "南極の怪事",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "中に一条、つるくさ交りの茅萱高く、生命を搦むと芭蕉の句の桟橋というものめきて、奈落へ落るかと谷底へ、すぐに前面の峠の松へ、蔦蔓で釣ったように攀ずる故道の、細々と通じているのが、函嶺の裏関所の旧跡である。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月ばかり経って、細かに、いろいろと手毬唄、子守唄、童唄なんぞ、百幾つというもの、綺麗に美しく、細々とかいた、文が来ました。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "父には去年死に別れて、母は二人の子供をかかえて細々に暮らしているのであるが、姉娘のおせんは唖という片輪者であるから、奉公に出すことも出来ないで困っているのを、重兵衛がどう掛け合ったのか、養女に貰うことにして自分の家へ連れて来たのである。",
              "citation": {
                "source": "深川の老漁夫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　銀子も何か歯痒くなり、打ち明けて相談してみたらとも思うのだったが、それがやはり細々と話のできない性分なのだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年も、もう、いまでは鬚の剃り跡の青い大人になって、デカダン小説と人に曲解されている、けれども彼自身は、決してそうではないと信じている悲しい小説を書いて、細々と世を渡って居ります。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（なぜなら女性というものは、すべて事件の細々とした描写を好むもので、真の抒情詩的表現を持たないから。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金の出る山ひとつ持っている、とまるで、子供みたいな、とんでもない嘘を言い出しましてな、男は、つらいものですね、ながねん連れ添うて来た婆にまで、何かと苦しく見栄張らなければいけないのですからね、わたくしたちに、それはくわしく細々とその金の山のこと真顔になって教えるのです。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう十年くらい、細々ながら生活するくらいのお金はある。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "資性｜穎慧温和、孝心深くましまして、父君の病みたまえる間、三歳に亘りて昼夜｜膝下を離れたまわず、薨れさせたもうに及びては、思慕の情、悲哀の涙、絶ゆる間もなくて、身も細々と瘠せ細りたまいぬ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と低い声で細々と教えてくれた。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "コオトは着ないで、手に、紺蛇目傘の細々と艶のあるを軽く持つ。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一たいが、小づくりで、薄皮膚の色の白いやはらかに素直な毛をそつとわけて声もほそぼそと、歴史といふ遠い昔の夢をロマンチツクにおどおどと語る――ただ、すこしほんのすこしではあるけれども、見栄坊に気どつて年頃の女生徒への多少の対感意識はあつたやうでした。",
              "citation": {
                "source": "ある男の死",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひかりうづまく黒の雲、　　ほそぼそめぐる風のみち、苔蒸す塔のかなたにて、　　大野青々みぞれしぬ。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
