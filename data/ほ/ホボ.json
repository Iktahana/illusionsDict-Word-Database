[
  {
    "uuid": "c6042106-d0ca-5a82-8077-7fd9933409da",
    "entry": "略",
    "reading": {
      "primary": "ほぼ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
