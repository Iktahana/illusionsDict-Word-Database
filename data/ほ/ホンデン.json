  {
    "uuid": "164ac230-6804-5b40-b8fa-235848f5b6d6",
    "entry": "本伝",
    "reading": {
      "primary": "ほんでん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
