        "examples": {
          "standard": [
            {
              "text": "実験室では、教授の指示のもと、学生たちが補助員として働いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女はイベント運営の補助員として、多くの雑務をこなした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "医療現場では、看護師の業務を支える補助員の存在が重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "○この頃「古池旧蹟芭蕉神社創立十年祭記念物奉納並大日本俳家人名録発行緒言」と題する刷物の内に賛成員補助員などの名目ありて我名もその補助員の中に記されたり。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "カントが「商人あるいは手工業者の雇人、僕婢、日傭労働者、小作人及び総ての女子等、約言すれば他人より「食物及び保護」を受くる総ての人々を国民とは認めず、単に国家補助員と見做していた」というのは、その人格論に由来する正当な結論であろうと思います。",
              "citation": {
                "source": "平塚・山川・山田三女史に答う",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            }
          ]
