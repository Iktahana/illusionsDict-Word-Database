    "definitions": [
      {
        "index": 1,
        "gloss": "carrier (of a disease-causing agent)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
