        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夢じゃないかと疑い、自分の頬をつねってみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「痛い！」と叫んで、子供が友達の頬をつねった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔、先生が注意するときの癖で、生徒の頬をつねることがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "長閑な小春日和の野山である――酸つぱい蜜柑――戯れ――娘の頬をつねるといふ（決して、つねつたりするものか――その時は、その代りにその頬に接吻をしてもかまはぬであらう）目的で、勇敢なる青年が駿馬に打ちまたがつて、可憐な娘を追ひかけて行く――。",
              "citation": {
                "source": "ダイアナの馬",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to pinch one's cheek (to make sure one isn't dreaming, esp. upon hearing good news, experiencing something fortunate, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
