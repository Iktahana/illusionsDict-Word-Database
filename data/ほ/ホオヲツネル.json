    "definitions": [
      {
        "index": 1,
        "gloss": "to pinch someone's cheek",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
