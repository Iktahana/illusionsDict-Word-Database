    "definitions": [
      {
        "index": 1,
        "gloss": "whaling ship",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "荷役に忙しい樺太や釧路通ひの汽船や、白いペンキの醜く剥げ落ちた帆船の中には、舷の低い捕鯨船の疲れたやうな姿が横はつてゐる。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなる捕鯨船もいまだかつてこの時期にあって、かかる緯度の処にとどまったことはなかった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕鯨船のうちで、イングランド教会の祈祷書が常に用いられるのはおかしなことである。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕鯨船｜北海丸の砲手で、小森安吉と云うのが、その夫の名前だった。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "砲手は、捕鯨船では高級な船員だった。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海丸と云うのは、二百｜噸足らずのノルウェー式捕鯨船で、小さな合名組織の岩倉捕鯨会社に属していた。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ日本の捕鯨船にノルウェー人の砲手達が雇われていた頃から、その人達によって云い伝えられた伝説だった。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「仔鯨を撃つ捕鯨船には、必らず祟りがある」　宗教に凝った異邦人達は、そう云って仔鯨撃ちを恐れ拒んだ。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "親鯨でさえもその濫獲を防ぐためには、政府は捕鯨船の建造を、全国で三十艘以内に制限しているのだった。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、捕鯨能率を高めるために、監視船の眼のとどかぬ沖合で、秘かに仔鯨撃ちも犯す捕鯨船は、時折りあるらしかった。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "安吉の告げ残した「釧路丸」と云えば、同じ岩倉会社の姉妹船で、北海丸が去年の秋に沈没した折、いち早く救助に駈けつけた捕鯨船ではないか。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "電文は――捕鯨船ニ告グ、東経１５２、北緯45ノ附近ヲ、北北東ニ向ウ大鯨群アリ――それほどの大鯨群でもないんだが」と東屋氏は笑いながら、「そうそう、序に発信者を――貨物船えとろふ丸――とでもしといて下さい」「えとろふ丸、はよかったですね」　船長が苦笑した。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初右舷の遥か前方に、黒い小さな船影がポツンと現れたかと思うと、見る見る大きく、捕鯨船となって、その鯨群を発見けてか、素晴らしい速力で潮の林へ船首を向けて行った。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕鯨船は、見る見る鯨群に近付いて、早くも船首にパッと白煙を上げると、海の中から大きな抹香鯨の尻穂が、瞬間跳ね曲って、激しい飛沫を叩きあげた。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "間違いないようですよ」　やがて捕鯨船は、両の舷側に大きな獲物を浮袋のようにいくつも縛りつけて、悠々と引きあげて行った。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、しかし、一時間しても、第二の捕鯨船は現れない。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "左舷の斜め前方に、とうとう岩倉会社特有の、灰色の捕鯨船が現れたのだ。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――捕鯨船は、戦わずして敗れた。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕鯨船の法定制限数は、三十｜隻でしたね。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕われた捕鯨船の船首砲には、その大きな鯨共を撃つための第二の銛が、用意されたままになっていた。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿父は、それらの友達と捕鯨船へ乗り込んで遠洋航海へ赴いたり、ボルネオ地方へ鰐狩りへ行つたりしたが、「これ位ひの道楽は、余興のようなものさ。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは滝の親父が、昔アメリカの学校にゐた頃暑中休暇を利用して捕鯨船に乗り込んだ時そこの水夫から聞き覚えたのだと云つた。",
              "citation": {
                "source": "雪景色",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕鯨船が病みつきで、一時は何も彼も放擲してそれの水夫になつて働いたことがあるといふ父親は、海の話となると得意のあまり夢中になつて「船歌」を相の手にして身振り勇ましく追憶談を繰り返すのが好きだつた。",
              "citation": {
                "source": "雪景色",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕はアメリカに居た時分何かのことで破れかぶれになつて市を飛び出すと、学校友達の親父が持つてゐた捕鯨船に乗り込んだものだ、獲るんなら鯨でなくては面白くないといふ考へ……」云ひかけて父は、何か思案した。",
              "citation": {
                "source": "円卓子での話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんでもね、二っちも三っちもいかなくなった捕鯨船の後始末とかで、こいつを売ったやつの名は、クルト・ミュンツァ、です。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、体質上潜行に適しないので、捕鯨船の古物である一｜帆船にのって『ネモ号』というその潜船に蹤いていったのです。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、そこへ運よく一隻の捕鯨船が通りかかって、僕は無電の修理材料をもらいました。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほうは、ずうっと版も古く、書名を『｜捕鯨船ブリッグ号難破録』というのである。",
              "citation": {
                "source": "紅毛傾城",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本船は横浜｜解纜の際、以前捕鯨船の砲手であったヴィデを招き、同時に四｜吋の砲を二門積み込んだのであった。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜宮へ連れて往ってくれないかわりに、こうして漂流しているうちに、やがて、捕鯨船に発見されるだろう。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
