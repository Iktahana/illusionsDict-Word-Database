[
  {
    "uuid": "b82f8e2f-b4e1-5c8e-9717-f975512f92b2",
    "entry": "捕鯨船",
    "reading": {
      "primary": "ほげいせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
