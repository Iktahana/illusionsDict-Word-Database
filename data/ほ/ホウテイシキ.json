  {
    "uuid": "b2ed4622-c065-5fcc-ad14-f3560e9a88b9",
    "entry": "方程式",
    "reading": {
      "primary": "ほうていしき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
