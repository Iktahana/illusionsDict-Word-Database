    "definitions": [
      {
        "index": 1,
        "gloss": "originating (something)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "其処で三百円という類稀なる慰労金まで支出したのは、升屋の老人などの発起に成ったのである。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "未醒君の発起で陰気な二階の一夜を怪談に更かす。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「考えものです――発起人方、幹事連と、一応打合せて、いまの別亭の事は誰にも言わずに、人の出入りをしないようにした方が可いかとも思います。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、ちょうど発起人を代表して、当夜の人気だった一俳優が開会の辞を陳べ終った処であった。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それ、いま発起人の言ったとおり、御銘々話を頼むぜ。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆者は……実は、この時の会の発起人の一人であった。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "塔婆は幹事、発起人のうちで、槙君から、所をきいて、良圓寺と云うので心ばかりの供養をした。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "発起者及び会員は朝野知名の政治家、実業家、学者を網羅し、その宣言は堂々たりしが、実績の見るべきものなくして終れり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて新富座もみずから発起して、十、十一の二日間、慈善興行を催せり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "華族紳士連の発起にて、高等演芸場の目的にて建築されたるものなるが、のちには劇場同様となれり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "また翌日の一組は、れいの発起人の顔役とその十八の娘。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "発起人がこの様子で。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "記念碑発起押っぽだての、帽子、靴、洋服、袴、髯の生えた、ご連中さ、そのつもりであったれど、寺の和尚様、承知さっしゃりましねえだ。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の列は全くの大人で、その中にはこの催しの発起者である手前として学務委員も参加しています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、前に書くはずなのを、うっかりしていたが、ちょうど、この日の昼餐が済むと、直ぐから、二等船客発起の仮装行列なるものが、それこそジャランジャラン騒ぎでケビンの甲板を一周し二周したものだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「読売」の高田半峰氏発起して歴史脚本を募れるは、「早稲田」の史劇論に続て、劇詩界の高潮を報ずる者なれ。",
              "citation": {
                "source": "劇詩の前途如何",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治三十七年十月八日九日両日、門弟中からの発起で翁の八十八歳の祝賀があった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてまだ発起人連中の予算の相談も纏まらぬ中に、前掲の如き見事な銅像と土台石が津上氏から古賀得四郎氏の許へ到着したので、筆者等は少なからず狼狽させられながらも津上氏の感激振りに心から感激した。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "因に同銅像は昨秋十月旧門弟一同発起となり一月着工、胸像は福岡県糸島郡出身彫塑家津上昌平氏の献身的努力により作製されたものである。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま発起に附きて（中略）無理に切利支丹に勧められ罷り成り候は、聞召し届けられ、御助けなさる可く候事、上意の由に御座候（中略）勿論切利支丹宗の儀｜相背き難く存じ候者は、籠舎仕り相果て候とも、その段は銘々次第と存じ候。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "プレンダーガストはその発起人であった。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "実弟のハリー・ピナーが発起人で、分担額に従い社長として取締役会に参加しており、自分がこちらへ渡っているのを知ってましたから、いい人間を手頃に見つけてくれと。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここらで発起をするこッた、また三晩ばかしあけたというじゃあないか。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸妓の罪障は、女郎の堅気も、女はおなじものと見えまして、一念発起、で、廻国の巡礼に出る。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日を経て、ふるえの留まらぬままに、一念発起して世を捨てた。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてある時、一念発起して、彼が書いたものを一から読み直してみようと思い立ったのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "明くれば郷里の有志者および新聞記者諸氏の発起にかかる慰労会あり、魚久という料理店に招かれて、朝鮮鶴の料理あり、妾らの関係せしかの事件に因めるなりとかや。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　川上音二郎　これより先、大阪滞在中和歌山市有志の招待を得て、重井と同行する事に決し、畝下熊野（現代議士山口熊野）、小池平一郎、前川虎造の諸氏と共に同地に至り同所有志の発起に係る懇親会に臨みて、重井その他の演説あり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらしが音楽をかなでて、ほっきょくぐまがあと足で立ちあがって、気どっておどるダンスの会もみられません。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほきョきョ、ほっきョきョ。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
