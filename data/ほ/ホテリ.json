    "definitions": [
      {
        "index": 1,
        "gloss": "a glow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夜中になって来ると病気の私の身体は火照り出し、そして眼が冴える。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頬の火照りをじっと怺えていて、何かを一心に祈っている眼であった。",
              "citation": {
                "source": "忘れがたみ",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夏がほぼ終ろうとする頃、残暑の火照りが漸く降りはじめた雨でかき消されてゆく、とある夜明け、私は茫とした状態で蚊帳のなかで目が覚めた。",
              "citation": {
                "source": "翳",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちら側まで火照りが反射して来るので、満潮の川水に座蒲団を浸しては頭にかむる。",
              "citation": {
                "source": "夏の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨はあたりの火照りを稍々鎮めてくれたが、暫くすると、またからりと晴れた天気にもどつた。",
              "citation": {
                "source": "夏の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨はあたりの火照りを稍々鎮めてくれたが、暫くすると、またからりと晴れた天気にもどった。",
              "citation": {
                "source": "夏の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "その話振りは、何かもどかしく僕には通じないところもあつたが、烈しい火照りは疼くやうに僕の方にも伝はつて来た、二人は街を歩きながら、まるで遠い世界のはてを視てゐるやうだつた。",
              "citation": {
                "source": "火の子供",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん僕の頭の芯は火照り、無我夢中の時間が過ぎて行つた。",
              "citation": {
                "source": "心願の国",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめの一章二章は丹念に讀めた圭一郎の眼瞼は火照り、終りのはうは便箋をめくつて駈け足で卒讀した。",
              "citation": {
                "source": "業苦",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹藪の側を駈け抜けると、夕焼けのした日金山の空も、もう火照りが消えかかっていた。",
              "citation": {
                "source": "トロッコ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は「しまった」と思うが早いか、たちまち耳の火照り出すのを感じた。",
              "citation": {
                "source": "お時儀",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後はトタン屋根に日が当るものですから、その烈しい火照りだけでもとうてい本などは読めません。",
              "citation": {
                "source": "手紙",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹藪の側を駈け抜けると、夕焼けのした日金山の空も、もう火照りが消えかかつてゐた。",
              "citation": {
                "source": "トロツコ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内に朝焼の火照りが消えると、ぽつぽつ雨が落ちはじめた。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなければ忘れたように、ふっつり来なくなってしまったのは、――お蓮は白粉を刷いた片頬に、炭火の火照りを感じながら、いつか火箸を弄んでいる彼女自身を見出した。",
              "citation": {
                "source": "奇怪な再会",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔も手伝ってからだが無性に火照り出した。",
              "citation": {
                "source": "蕎麦の花の頃",
                "author": "李孝石",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は案外に健康さうな双頬に純真な火照りを漂はせて明子を眩しさうに見上げてゐた。",
              "citation": {
                "source": "青いポアン",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああやって、毎日顔と顔とを見合わせている裏で、あんな企らみがあったかと思えば――おばあさんも憎いが、判るところを判らせない検事にも、私は愛素をつかしてしまった」　熱して話し、姉妹を見較べたおくめの瞼には、強い火照りと一緒に涙が滲み上って来た。",
              "citation": {
                "source": "黄昏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱の火照りで珍らしく冴えた頬をして、髪を引きつめのまま仰向きに寝ているお咲の顔は、急に子供に戻ったように見える。",
              "citation": {
                "source": "日は輝けり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とたんに身内が熱く火照りはじめ、女は空になった武士の杯を満たしてやるのも忘れて、全身がわななくようにふるえた。",
              "citation": {
                "source": "菊",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると顔がカッとして火照り出しかなりの痛みを感じたが、心はかえって落ち著いて来た。",
              "citation": {
                "source": "阿Ｑ正伝",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "……女の死を、私がはじめて強烈な衝撃として胸に感じ、頬が急に熱く火照りはじめたのは、いったん熟睡したあとの土曜日の下宿でだった。",
              "citation": {
                "source": "愛のごとく",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪子は先刻の白葡萄酒が今になって循って来たらしくて、両｜頬にぽうッと火照りを感じながら、もう阪神国道を走っている車の窓から、微醺を帯びたチラチラする眼で、濡れた鋪装道路に映る無数のヘッドライトの交錯をうっとりと見ていた。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポインタア系の雑種の犬が一匹、鼻で扉を押し開けて這入って来て、ストーブの火照りが一番よく当る場所を選んで、人間達の脚と脚の隙間へ割り込み、前肢の上に首を伸ばしてぬくぬくと蹲踞まった。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんで、今日は、考えてることを遠慮なしに云うよってに、こいさんもあたしには何も隠さんと、ほんとうのことを云うて欲しい」「………」妙子は脂の乗った光沢のよい頬に煖炉の火照りを受けながら、じっと息を詰めるようにして燃えさかる薪を見守っていた。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると正造は体を前へ傾けて覗きこむようにしながら、「はじめてか君、初めてではなかろう」　永島は言葉をかけられて、漸くさめかけていた頬がまた火照りだした。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔が火照り始め、身体が温もって来ると、横になったが、疲れが出て来て、沢田が自動車の掃除をすまして出て行きながら、小森さん、ガソリンも切れてますよ、と喚いて行ったのに、返事をしたようでもあり、せんようでもあり、土間に転がったまま、眠ってしまった。",
              "citation": {
                "source": "糞尿譚",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔が熱く火照り、動悸がはげしく打つ。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔が熱く火照り、目まで真ッ赤になっている。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "新火山のことだから、土の締まりは、しッくりしていない、むしろ危ッかしいほど、柔脆の肉つきではあるが、楽焼の陶器のような、粗朴な釉薬を、うッすり刷いた赤る味と、火力の衰えた痕のほてりを残して、内へ内へと熱を含むほど、外へ外へと迫って来る力が、十方無障碍に放射することを感ずる。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
