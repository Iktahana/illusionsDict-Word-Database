        "examples": {
          "standard": [
            {
              "text": "北海道の市場で、新鮮なホッキ貝を刺身にしてもらったが、甘みが強くて最高だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今日のカレーにはホッキ貝が入ってるよ」と、食堂のおばちゃんが笑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ホッキ貝の殻は非常に丈夫で、昔は道具として使われることもあったらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "標準和名はウバ貝であるが、今はホッキ貝というのが通り名になってしまった。",
              "citation": {
                "source": "ホッキ巻",
                "author": "知里真志保",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホッキ貝は東北から北海道樺太にかけて寒海に分布し外洋に面した砂泥の浅海に棲息する。",
              "citation": {
                "source": "ホッキ巻",
                "author": "知里真志保",
                "note": "青空文庫"
              }
            }
          ]
        }
