        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "雨の音だって、犬の吠え声だって前後とちっとも変らない明瞭さで聞こえていたのだし、それに彼奴の恨めし相な凄い顔！",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "「犬の吠え声が聞こえます」今度は袴広太郎。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬のいななき、犬の吠え声、鶏の羽ばたき、子供の叫び声、みんなみんな活気がある。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一遍ごとに遠くの女の吠え声は高まって来、遂には、はっきりウォーイ、ウォーイというのがわかる。",
              "citation": {
                "source": "吠える",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを堪え、いつか気を奪われて、人間らしい獣と、獣に近い人間の吠え声にききとれていると、妙なものではないか、私の理性迄がちっと変になる。",
              "citation": {
                "source": "吠える",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの二つの、切な吠え声だけに人生が圧縮されてしまったように感じ、私も一緒に吠えだしたくなる。",
              "citation": {
                "source": "吠える",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠く家畜小屋の附近では、活溌な猟犬の吠え声が聞えた。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と思わず云った矢代の声も、もう真下に追った犬の吠え声に聞えなかった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの夥しい犬の吠え声を……。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そっちの空で犬の吠え声がおこった。",
              "citation": {
                "source": "朝の風",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで訳がわからんね」「泥棒かしら……」「まさか」　納屋の二階を見上げて、ひそひそ話し合っていると、突然ゲンのけたたましい吠え声――、続いて誰かが床板に叩きつけられる様な音にまじって、鋭い怒声罵声ががんがん響き、えらい騒ぎになって来た。",
              "citation": {
                "source": "睡魔",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬の吠え声、女の笑い声。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ウオーッ」と狼群も吠え声を上げた。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウオーッという豹の吠え声がした。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は竹筒を木箱の中へ納め、また地袋の中へ押し入れて、犬の吠え声に耳をかしげましたが、「あらかた話は済んだらしいな。",
              "citation": {
                "source": "怪しの者",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤児の泣き声が聞こえてきたり、犬の吠え声が聞こえてきたりしたが、それさえ貧しげな町の通りを、寂しくするに役立つだけであった。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　朧月の深夜で、往来の人はなく、犬の吠え声がずっと遠くの、露路の方から聞こえて来た。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥の啼く音や猿の叫び声や豹の吠え声や山犬の声などが、林の四方で騒がしくひっきりなしに聞こえていたが、それはどうやら遠征隊の傍若無人の振る舞いを怒っているようにも聞きなされた。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬の吠え声、凧の唸り、馬の嘶、座頭の高声、弥次郎兵衛も来れば喜太八も来る。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞えて来るのは食物に倦いた猛獣の恐ろしい吠え声と太陽を掠めて舞っている巨大な沙漠鷲の啼き声だけです。",
              "citation": {
                "source": "沙漠の歌",
                "author": "スタンレー探検日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "家中みんな寝静まったと見えて四辺は森然と静まり返えり時々遠い沙漠の方から豹の吠え声が聞えるだけです。",
              "citation": {
                "source": "沙漠の歌",
                "author": "スタンレー探検日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四　犬の吠え声はやがて止んだ。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　叫ぶ声々が一つに集まり、ウオーッというような吠え声となった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウオーッという群衆の吠え声が、その瞬間ひときわ高くなり、ムラムラと三人の犠牲者を、おっとり囲んだと見る間もなく、その一団は真ん丸となり、中へ三人の犠牲者を囲み、真ん丸のままで雑草の原を、一軒の廃屋の背後の方へ、一直線に縦断し出した。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂気したような群衆の叫びが、例のウオーッという吠え声となり、廃屋の蔭から上がったが、忽ち例の一団が、盆地へ姿を現わした。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその姿を追っかけて、胸の中で、声には出さないで、犬の吠え声をまねた。",
              "citation": {
                "source": "変る",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふらふらした足取りが、その吠え声に調子を合せた。",
              "citation": {
                "source": "変る",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "車が門をすぎると犬の猛烈な吠え声が諸方からわき起った。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "動物の言葉　人間は言葉で話を交わしているから、犬も吠え声がかれらの言葉のように思われ易いが、必ずしも、そうではないようだ。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "吠え声も無論意味をもっている。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
