        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ミリ」や「キロ」といった補助単位を使い分けることで、数値を分かりやすく表現する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "単位の換算ミスを防ぐため、補助単位の定義を再確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "科学論文では、SI基本単位と補助単位を正しく組み合わせる必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 2,
        "gloss": "supplementary SI unit (radian and steradian)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
