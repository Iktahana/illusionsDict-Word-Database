      {
        "index": 1,
        "gloss": "prefixed unit of measurement (i.e. millimeter, kilogram, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
