        "examples": {
          "standard": [
            {
              "text": "古いコートの縫い目が「綻ばす」てしまい、修理が必要になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、うっかり袖の縫い目を「綻ばす」てしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あー、このバッグ、端っこが「綻ばす」てきたよ。もうダメかな。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "」ホームズは顔をほころばす。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中でただ一人木曾礼二郎だけが、呆然とした顔つきで、拍手をするでもなく、頬をほころばすでもなく、気抜けのように突立っていた。",
              "citation": {
                "source": "宇宙爆撃",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            }
          ]
        }
