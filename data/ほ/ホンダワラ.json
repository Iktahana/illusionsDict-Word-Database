        "examples": {
          "standard": [
            {
              "text": "海岸には、打ち上げられたたくさんの馬尾藻があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "馬尾藻は、食用にもなる海藻の一種です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "潮干狩りに行った時、水中に揺れる馬尾藻を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "すじめ、ざらめ、うがのもく等の馬尾藻科の海草が、覗き眼鏡の底に鬱蒼として林のごとく繁茂して、大きな波のうねりのごとにゆらゆらとゆらめいてうつるのであった。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、あるといえば藻海くらいだろうが、それも過去における魔境に過ぎず……いまはその怪｜馬尾藻も汽船の推進器が切ってしまう。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆船のころは、無風と環流のためそこを出られなくなり、舵器には馬尾藻がぬるぬると絡みついてしまう。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
