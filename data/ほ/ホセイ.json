[
  {
    "uuid": "5f14eb86-5185-5ae5-b247-f61f210684f1",
    "entry": "補正",
    "reading": {
      "primary": "ほせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
