        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それよりかまだ歩いてゐた方がマシである。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私ゃあのガキをウチへ泊めるぐらいなら、ホンモノのメメズと一しょにドブへねる方がマシだよ」　そこで金サンは隣の床屋へでかけた。",
              "citation": {
                "source": "町内の二天才",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな苦しみをするぐらいなら、財産半分なくした方がマシです。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "すくなくとも、軍人指導下の日本よりも、ソビエトの方がマシなのは明かだろう。",
              "citation": {
                "source": "安吾巷談",
                "author": "野坂中尉と中西伍長",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸のない裸体を舞台で見るよりは、共同ブロへはいった方がマシであろう。",
              "citation": {
                "source": "安吾巷談",
                "author": "ストリップ罵倒",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだしも代用教員を使う方がマシだと言いましてね」「そんなことを云って、大事な子供をまかせておく我々はどうなるのかね」「今になんとかしますが、本人にも言いきかせますから、辛抱して下さい」　そのたびに彼は校長室によびつけられ、学務委員や有力者の家を謝罪して廻らねばならなかった。",
              "citation": {
                "source": "水鳥亭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハシタ金で、ボートクを加えるほどなら、火をかけて燃した方がマシですとも」「ボートクじゃないのです。",
              "citation": {
                "source": "水鳥亭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "野口はなんとなく哀れに思い、三千円だと引越しのツケトドケにしかならないが、どうせ戦禍に消え失せるもの、捨てるよりは三千円で売った方がマシだろうと思った。",
              "citation": {
                "source": "水鳥亭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざわざこの犯人を探すぐらいなら、武田信玄が自然死であるか、他殺であるか、自殺であるか、その犯人でもさがした方がマシなぐらいですよ」　と新十郎は苦りきって答えた。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十　冷笑鬼",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリス　セイウチの方がマシね。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "だったら大工の方がマシね――セイウチほど食べてはいないし。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が長生きすると息子がこまるばかりだから、死んだ方がマシのようだ。",
              "citation": {
                "source": "安吾史譚",
                "author": "勝夢酔",
                "note": "青空文庫"
              }
            },
            {
              "text": "階上のヴェランダにいるだれかに、知らないあいだに目撃されるよりは、だれに見られたかを確認できるほうがマシだろう、と結論をだし、廊下を歩きはじめた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、手を放すよりは、帰るほうがマシだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "私などがいくら歩いても、たいしたことが起きないことは知っているが、しかし私でさえも歩かないよりも歩くほうがマシなことを私は知っている。",
              "citation": {
                "source": "歩くこと",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
