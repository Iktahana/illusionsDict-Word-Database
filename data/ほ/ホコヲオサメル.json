        "examples": {
          "standard": [
            {
              "text": "激しい議論の後、双方が「矛を収め」、和解の握手を交わした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もう戦うのはやめよう。今こそ「矛を収める」時だ。」と、長老は皆に訴えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ふぅ、やっと「矛を収め」られたよ。君との議論はいつも疲れるね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "今さら、骨肉の血みどろと、領土の荒し合いが厭になっても、将門の方で、このまま矛を収めるはずはない。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな合戦も、一｜枚の、熊野権現の誓紙で、矛を収めることができた。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
