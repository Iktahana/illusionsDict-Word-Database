        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「北極点に到達したぞ。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ自分は、ノールウェー国王並に王妃から探検隊に賜はつたノールウェー国旗を、窓から北極点に投下した。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "沈黙のうちに、ノルゲ号は静かに北極点の上を三回まはつた。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "北極点にある三ヶ国の国旗をぢつと眺めた。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞記者のラム君は、北極点での吾々の儀式や刻々の印象について、世界各国のおもな新聞社に通信した。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "北極点を基点にとれば、太陽も地球も動くことになる。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは、グリーンランドでも、ずっと北の端近いところで、北極点までは、あと八百マイルくらいしかない。",
              "citation": {
                "source": "エスキモーの国から",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "全飛行時間は、十二時間足らずであって、朝アメリカの物質文明の中心地を立つと、夕方には北極点から八百マイルのところに着くわけである。",
              "citation": {
                "source": "エスキモーの国から",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なのにロンドン市内は極寒の凍結中心となり、外部と接触不能な北極点のようだった。",
              "citation": {
                "source": "四日白魔",
                "author": "THE FOUR WHITE DAYS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
