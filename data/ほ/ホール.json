    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hall (dance, concert, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "〔霜枯れのトマトの気根〕宮沢賢治霜枯れのトマトの気根その熟れぬ青き実をとり手に裂かばさびしきにほひほのぼのとそらにのぼりて翔け行くは二価アルコホール落ちくるは黒雲のひら",
              "citation": {
                "source": "〔霜枯れのトマトの気根〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてダンシングホールにでも少し出這入りなさると好いわ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（間）ダンシングホールへ行くことも禁じられるし、まるで女中代りよね、此の頃のあたしつたら。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の端のミルクホールで物質とエネルギーと神とを論じた。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホールス・キャムプという平地に出で馬を下り、野営の仕度をする、海抜九千尺、水も少しはある。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの、桃の肉が溶けているイタリーのヴェルモットはありませんかしら」　と誂えて置いて、トオクを冠った女客がホールの鏡壁の七面へ映る七人の自分に対して好き嫌いをつけている。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺達は茲で疲れやすめだ（クリスマス前夜の賑かな労働者街のダンスホールで踊り明したのでしょう。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の日のミルクホールで弁護士から今日の判廷の様子を聞かされ、この二十四時間に捜しあてなければ愚鈍なる陪審官達はいよいよ有罪の判断を下すであろうという心細い宣告を下されるのである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがそこは芝居であるからこのミルクホールの店先を肝心の夕刊嬢が丁度そのときまるで打合せておいたように通りかかる。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西鶴の人間に関する観察帰納演繹の手法を例示するものとしてはまた『織留』中の「諸国の人を見しるは伊勢」に、取付虫の寿林、ふる狸の清春という二人の歌比丘尼が、通りがかりの旅客を一見しただけですぐにその郷国や職業を見抜く、シャーロック・ホールムス的の「穿ち」をも挙げておきたい。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年五月二十日『東京朝日新聞』）　　　　　　　　　八十二　　　　　　学者の犠牲　英国のホールエドワードという学者はＸ線のために左の手全体と右の手の指とを失った。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "★　前夜のこと、………更けるとすこしばかし溝をつたうクレオソートの臭いが鼻に滲みたが、築地河岸附近にあるダンシング・ホールで僕はその夜、踊っていた。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "waltz　ダンス・ホールの溶暗のなかで、僕たちは縫目のない肉体のように結びついた……………。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、赤い蝶のようにホールを旋回しながら、僕は粟鼠の毛皮をつけた甘美な女の顔の花園を眺めながら云うのだ。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　不可思議な女の声にあらわれるメロデイを感じて、「――そんなら、僕と、ホールからお出掛けになりますか？",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、僕は酔ったときの癖で、鍵穴に秘めた最期の手管をもって、ダンス・ホールからの女友達を眺めた。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "タキシード姿の役人が、奥のホールの奏楽場に妾達を案内しました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "数日前「Ｍａｔｓｕ・ホテル」のダンス・ホールでもと吉原の遊女であった中年の女将が殺害された事件。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が明けると、天界ホテルの海辺に面したダンス・ホールで、マリを先頭にして十三人の娼婦が一列に並んで健康のための体操をはじめたが、何故かお六ひとりその列に見えなかった。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は現代が、夜光虫と欧羅巴スタイルのグランド・ホテル・ド・横浜のダンシング・ホールと空中の軽業だと断定する。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダンシングホールでは華やかな腰を振って踊子がシンミイダンスを踊っていた。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は多少キじるしだとの評がホールの仲間にあるけれども、おそらくホールの御連中にキ的傾向を持っていないかたはあるまいと思われる。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに言うホールとは、銀座何丁目の狭い、窮屈な路地にある正宗ホールの事である。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "正宗ホールでなければ飲めません。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "混成酒ばかり飲みます、この不愉快な東京にいなければならぬ不幸な運命のおたがいに取りては、ホールほどうれしい所はないのである。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一時間ばかり、さらに談じかつ飲み、中倉翁は一足お先に、「加と男」閣下はグウグウ卓にもたれて寝てしまったので、自分はホールを出た。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも講義の時の口調で「これではブラックホールの苦しみに優るとも劣ることはない」といって生徒を笑わせた。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時マコーレーのクライヴ伝を講じていて、ブラックホールの惨劇が一同の記憶に新鮮であったのである。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
