          "literary": [
            {
              "text": "あの男が褒めちぎるもので。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人が皆その女を褒めちぎる。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こんな風に二人は鼬ごつこをして褒めちぎる。",
              "citation": {
                "source": "クサンチス",
                "author": "XANTHIS",
                "note": "青空文庫"
              }
            },
            {
              "text": "花園　　世間の男どもは屹とさう云ふ女に同情して、わい／＼褒めちぎるに相違あるまい。",
              "citation": {
                "source": "能因法師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "良因　　感心して褒めちぎる奴の顏が見たうございますよ。",
              "citation": {
                "source": "能因法師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハリソン嬢がナオミを頻りに褒めちぎるのはそのせいなので、もう頭から「賢い児だ」ときめてしまっているのでした。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカーキイ・アカーキエウィッチはいささかてれはしたものの、根が正直な人間だけに、みんなが自分の外套をほめちぎるのを眺めては、どうしても喜ばずにはいられなかった。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、反訳のものでも、日本のものでも、過激な小説や露骨に人間の姿をえがいたものは、渋い顔で、くだらないと云い、自分の世界に近いものは、ほめちぎるのでした。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "カラハミがほめちぎるのをうすうす感づいていた。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
