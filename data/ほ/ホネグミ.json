[
  {
    "uuid": "059ed3cf-8862-58db-9bb0-f4b4a557e938",
    "entry": "骨組み",
    "reading": {
      "primary": "ほねぐみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
