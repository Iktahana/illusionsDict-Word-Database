    "definitions": [
      {
        "index": 1,
        "gloss": "Northern Expedition (China; 1926-1928)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「あんな奴を放って置いちゃ、北伐軍でもやって来た日にゃ、手がつけられなくなっちまうんだ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　蒋介石の第二次の北伐と、窮乏した山東兵の乱暴と狼藉が、毎日、巷の空気をかき乱した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「北伐軍にゃ、まだ／＼政治部を出た共産党が、だいぶまじっとるんだよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それよりゃ、僕は、北伐軍がここまで漕ぎつけて来るだけの力があるかどうか、それが見ものだと思ってるんだがな。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　巷の騒々しさと、蒋介石の北伐遂行の噂は、彼女が内地へ着いた頃から、日々、頻ぱんになって来た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "在留邦人達の北伐に対する関心は、幾年かを費して、拵え上げた財産や、飾りつけた家や、あさり集めた珍らしい支那器具や、生命を、五・三十事件当時の南京、漢口の在留者達のように、無惨に、血まみれに、乱暴な南兵のため踏みにじられやしないか、という一事にかかっていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）」　工場では、内川が、北伐にともなう、共産系の宣伝と組織運動、動乱にまぎれての工人の逃亡に対する対策に腐心していた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "せいぜい徐州か臨城まで押しかけて来れば大出来だ、と高をくゝっていた北伐軍が、もう袞州を陥れ、泰安へ迫っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山東兵は、南は、北伐軍に圧迫された。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "北伐軍の威勢が案外にあがるのは、金があるからだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら日本軍がやって来たって、今度の北伐軍の前には、牛車に向かうとうろうだよ、と笑った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は、独逸人の軍事顧問ばかりで、日本人には、見学さえ許していないそうだが、本当か、アメリカは、北伐軍には、もっと金を出す腹じゃないか、二千万円は、貧乏たれの日本人ならともかく、アメリカにしちゃケチくさいじゃないか、など話しはじめた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "工人が、北伐兵の過激派と策応しないとも限らない。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝黄子澄の言を用い、長興侯耿炳文を大将軍とし、李堅、寧忠を副えて北伐せしめ、又｜安陸侯呉傑、江陰侯呉高、都督都指揮盛庸、潘忠、楊松、顧成、徐凱、李文、陳暉、平安等に命じ、諸道並び進みて、直に北平を擣かしむ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "今大兵を率いて北伐す、時に年六十五。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて蜀が南征北伐と軍を出す時には、孔明が必ず軍を統率したから、陸軍大臣に司令長官の職を兼ねた譯である。",
              "citation": {
                "source": "支那史上の偉人（孔子と孔明）",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し北伐を中止したならば、蜀の存在が無意義となる。",
              "citation": {
                "source": "支那史上の偉人（孔子と孔明）",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔明としては道理からいうても、私情からいうても、一日も北伐を忘るべきでない。",
              "citation": {
                "source": "支那史上の偉人（孔子と孔明）",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔明の生涯の中で、私の尤も感激に堪へぬのは、その草廬三顧の時でなく、呉に使して孫權を説服した時でなく、又南蠻を征伐して、孟獲を七擒七縱した時でなく、實に成敗を度外に北伐を實行して、義務に殉じた時に在る。",
              "citation": {
                "source": "支那史上の偉人（孔子と孔明）",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し眼前の小利小康からいへば、蜀の險阻を守つて、北伐などを企てぬ方が得策かも知れぬ。",
              "citation": {
                "source": "支那史上の偉人（孔子と孔明）",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔明の北伐はこの正統論の基礎を置いたもので、かかる重大なる影響を、千歳の後に及ぼしたことを、記憶せなければならぬ。",
              "citation": {
                "source": "支那史上の偉人（孔子と孔明）",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は第一囘の北伐の時に、大將の馬謖が彼の指揮に違背して敗軍した罪を正すべく、之を誅戮した。",
              "citation": {
                "source": "支那史上の偉人（孔子と孔明）",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "北伐の成功を目前に控へた南方政府の所在地の見聞記を云ひつけられたのだ。",
              "citation": {
                "source": "南京六月祭",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "北伐軍が南京で日本の陸戦隊と衝突し、漢口でも同じようなことがおこった。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、支那南方に起った蒋介石が、孫逸仙とともに北伐を開始し、奉天派はこれに対して、その先端は、浙江方面上海にまで進み、張学良と楊宇霆を首将としてあたらしめていた。",
              "citation": {
                "source": "私が張作霖を殺した",
                "author": "河本大作",
                "note": "青空文庫"
              }
            },
            {
              "text": "張作霖は勢いに乗じて、上海までも手を伸ばしているが、やがて蒋介石らの北伐が開始されれば、たちまちにして奉天軍はまたまた奥の手の関内へ逃げ込みの一手を用うるに相違ない。",
              "citation": {
                "source": "私が張作霖を殺した",
                "author": "河本大作",
                "note": "青空文庫"
              }
            },
            {
              "text": "北伐も北支では阻止しなければならない。",
              "citation": {
                "source": "私が張作霖を殺した",
                "author": "河本大作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、蒋介石の北伐は開始された。",
              "citation": {
                "source": "私が張作霖を殺した",
                "author": "河本大作",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀吉の北伐軍は、湖北を越えて、越前に入った。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は今や北伐の断行を固く決意したもののようである。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
