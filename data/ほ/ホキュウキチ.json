        "examples": {
          "standard": [
            {
              "text": "宇宙探査計画のために、月面に補給基地を建設する構想がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遠隔地の調査隊は、定期的に補給基地から食料や機材を受け取る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "紛争地域に設置された補給基地が、人道支援の拠点となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "留守番をおいて田畑をつくらせ、鶏を飼い、戦争中の栄養補給基地に用いるという一石二鳥の作戦でもあった。",
              "citation": {
                "source": "水鳥亭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
