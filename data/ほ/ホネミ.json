    "definitions": [
      {
        "index": 1,
        "gloss": "flesh and bones",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そんな時だから、どんな映画でも、骨身にしみる。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "満目｜粛殺の気に充ちて旅のうら寂しさが骨身に徹る。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "正常の教程課目として教わったことで後年直接そのままに役に立ったことは比較的わずかで教程以外に直接先生方から受けた実例教育の外には自分の勝手で自修したことだけが骨身に沁みて生涯の指導原理になっているような気がする。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風邪を引いた代りにレーリーがずいぶん骨身にしみて後日の役に立った。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "實際、私は整頓とか、整理とか、掃除とか、片附け事とか云ふ事には殆ど興奮さへ覺へて骨身を惜しまない人間で、普通の詞で云へば、綺麗好きとか、潔癖とか云ふのらしいが、どうも聊か病的で、下らぬ暇潰しになつて仕方がない。",
              "citation": {
                "source": "自分の變態心理的經驗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、どこにまでも息子のために骨身を惜まなかった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "清吉の前では快活に骨身を惜まずに働いた。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "数千年来このような純日本的気候感覚の骨身にしみ込んだ日本人が、これらのものをふり捨てようとしてもなかなか容易にはふりすてられないのである。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "両眼を閉じて唇をワナワナと震わしたが、一言も物を言い得ないまま「ハアア――ッ……」と骨身に泌みるようなタメ息を一つして、涙をハラハラと流した。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸外は月冴えて風はないが、骨身に徹える寒さに磯は大急ぎで新開の通へ出て、七八丁もゆくと金次という仲間が居る、其家を訪ねて、十時過まで金次と将棋を指して遊んだが帰掛に一寸一円貸せと頼んだ。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして骨身を惜しむ事を知らないし、油を売る事をしらなかったせいであろう。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし先生は、「むだ」や「余白」だらけのだらしのない弟子たちに対して、真の慈父のような寛容をもって臨み、そうしてどこまでも懇切にめんどうを見てやるのに少しも骨身を惜しまれなかったように見える。",
              "citation": {
                "source": "田丸先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺も若い時に、なまじっかな楽な暮しをしたばかりに、この年になっての貧乏が、骨身にこたえるのだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と懐紙にて押拭う、優しさと深切が骨身に浸みこむ、鉄はぶるぶる。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀州沖はどこかと海の彼方をじっと見つめては歯をくいしばり、黙々として骨身惜しまず働いている姿を変ってると思ったか、主人が訊ねて、もとは魚問屋の坊ぼんであると分ると、可哀想だと、帳場に使ってくれた。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る山寺で例のおむすびを味つた、親友の心持がしみ／″＼と骨身にしみた、その山寺の老房守さんもしんせつだつた、わざ／＼本堂の障子をあけはなつて、私を涼しく昼寝させて下さつた。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "黎々火君と共に星城子居に泊る、星城子君の友情が骨身にしみとほる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒の味が、もうすツかり骨身に沁渡ツて了ツたんですね。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年連中の草川巡査に対する尊敬ぶりは、ちょうど小学校の生徒が、受持の教師に対する通りで、骨身を惜まず、夢中になって活躍するのであった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間の寒さは私の骨身にこたえた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　無心の声でしたが、これがまた、じんと骨身にこたえるほどに痛かったのです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてかの女は突立ったままで「ははあ、規矩男も奇抜なことをするものだ」と単にこう思っただけだったが、直ぐそのあとから、しんしんと骨身に痛みを覚え出した。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "定基に取っては力寿のかわゆさが骨身に徹していたのである。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "イヤ、骨身に徹するどころではない、魂魄なども疾くに飛出して終って、力寿の懐中の奥深くに潜り込んで居たのである。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年ぶりに見る、ふるさとの山川が、骨身に徹する思いであった。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年ぶりに見る、ふるさとの山川が、骨身に徹する思ひであつた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また石太郎は、なんどむちでこづかれたとて、いっこう骨身にこたえない。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌晩になるとまた昨夜のように、同じ女が来て手を取って引出して、かの孤家へ連れてまいり、釘だ、縄だ、抜髪だ、蜥蜴の尾だわ、肋骨だわ、同じ事を繰返して、骨身に応えよと打擲する。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたが気付かずして、ゆくりなく洩らす一口の言葉や、半端な呟きによって、それが現れ、自分のような性質のものに取ってはそれが却ってぴり／＼と骨身に応えて、電気のように感ずるのがいよ／＼判って来たのだ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
