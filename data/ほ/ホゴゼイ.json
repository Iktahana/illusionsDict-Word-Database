        "examples": {
          "standard": [
            {
              "text": "海外製の安い鉄鋼が大量に流入したため、国内産業への打撃を懸念して暫定的な保護税が導入された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "保護税の引き上げにより輸入品の価格が高騰し、消費者の間では家計への負担を嘆く声が上がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自由貿易協定の交渉において、特定の農産物に対する保護税を撤廃するかどうかが最大の争点となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "明治の初めのころ、政府は米にも棉にも高い保護税をかけて、国産を奨励して輸入を防いでいたが、日清戦争のころになると、だんだんそれができなくなり、保護税をやめて、輸入を緩やかにした。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
