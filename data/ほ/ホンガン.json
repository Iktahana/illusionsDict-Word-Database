    "definitions": [
      {
        "index": 1,
        "gloss": "Amida Buddha's original vow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
