        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――煩うてな……」　もの言もやや打解けて、おくれ毛を撫でながら、「ほっといてお通りなさいますと、ひとりでに離れます。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほっといてちょうだい」と、おかあさんアヒルは、言いました。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけどお母さん、あたしの事はもう、ほっといて。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、比良夫君のことなんかほっといて、みんな鐘めがけて走った。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "京橋のアパートで罹災なさって、それから今の御住所にお移りになった事を直治から聞きまして、よっぽど東京の郊外のそのお宅にお伺いしようかと思ったのですが、お母さまがこないだからまた少しお加減が悪く、お母さまをほっといて上京する事は、どうしても出来ませぬので、それで、お手紙で申し上げる事に致しました。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしようと思ってんだから、ほっといてくれよ」「なに？",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この頃は少しなまけているから、あなたは梯子段を拭いてね、私は洗濯をするから……」「ええ私するから、ここほっといていいよ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "静子はいつもぐずぐずしているからほっといて行きます。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「私するから、こゝほっといていゝよ。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえさんなどとは考えが少し違うのだから、いいから、ほっといてください、とこうなのでしょう。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほっといてくれよ、うるさいね」　信二郎はおこったような顔をし、私の方へ背中をむけました。",
              "citation": {
                "source": "落ちてゆく世界",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほっといても人々は山野に出る。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "トロフィーモフ　ほっといてくれったら。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま呼びますからね……（ドアの口へ）ワーリャ、そこはほっといて、こっちへおいで。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしらは、キーシュが熊の皮を剥いでいるのをほっといて、この話をしようと思って駈けもどって来たんだよ」　　六　その日の午後、女どもが肉を運んで来る間に、男たちは寄合って相談していました。",
              "citation": {
                "source": "負けない少年",
                "author": "吉田甲子太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　しごとにんげんは、ほっといてはもらえないんだと、あきらめた。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "君たちみんなも、どうぞ僕をほっといてくれたまえ！",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ほっといてください、エレーナさん！",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワーニャ　ほっといてくれ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワーニャ　ほっといてくれったら。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんだ、お前の番さ、ね、僕の背中へおあがりよ」「僕あ、自分で練習してるんだから、ほっといておくれよ」　にんじんは、こういうのである。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほっといてくださいよ」　お駒ちゃんは、ぞんざいなことばでなら、かなり雄弁家なのだ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "よけいな世話ぁ焼かないで、ほっといてくれたらどうだえ？",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明　ほっといてくれよ！",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほっといてよ」　女は答え、笑った。",
              "citation": {
                "source": "他人の夏",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この哀れなおんぼろ老牧師をほっといて、半時間そっとしておいて下さい。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、わたしの家の前はほっといてもらいます。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それだけの話だったら、ほっといてくれたまへ。",
              "citation": {
                "source": "死刑囚最後の日",
                "author": "LE DERNIER JOUR D'UN CONDAMNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「藤左衛門さんとこへ風呂をもらいにいったよ、何度も呼びにきてくれたもんでな、ほっといてもわるいと思って」「まア、いいやな、そのあいだにひとやすみするかな」　立ちあがって奥の間へ入ろうとするのを、おのぶは慌てて障子の前へ立ちふさがった。",
              "citation": {
                "source": "本所松坂町",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
