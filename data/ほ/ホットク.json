[
  {
    "uuid": "001e8687-69ff-52a0-9265-cc0b08b2fbd6",
    "entry": "放っとく",
    "reading": {
      "primary": "ほっとく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-カ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to leave alone",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "真紀　お裁縫ひとつさせてもね、あたしが気をつけないで放っとくと、袖口迄縫いつめてしまうの。",
              "citation": {
                "source": "みごとな女",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「放っとくがいいよ、お母さんも今井さんも、揃いも揃って狂人ばかりだ。",
              "citation": {
                "source": "変な男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを今迄放っとくなんて、余りひどいじゃありませんか。",
              "citation": {
                "source": "古井戸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房をつれて居候もできず、さりとて五郎を一人放っとくのも不安だ。",
              "citation": {
                "source": "曾我の暴れん坊",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、いかにも歎息するらしく言い、そして、最後にはきまって、「ああ何時も何時も、あちらにばかり入浸っているのを、私という老人もいながら、放っとくわけにもいくまいではないか。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "父さんまでが、もし知らん顔をして、このまま何時までも僕を放っとくとすると、――）　次郎は、そう考えて、胸のしんに冷たいものを感じた。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「このまま放っとくと、上級生の権威にかかわるぞ！",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると大沢は恭一を見ながら、「しかし、本田、このまま放っとくと危いぜ。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「すると、流されるままに放っとくほうがいいとおっしゃるんですか。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何でいうて、こんなとこいあんな時間に呼び出しといて、着物借ったりお金借ったりして、放っとくいう法あるかいな。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたほどの女を、誰が放っとくものか。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その病気の出ているときには放っとくよりしようがねえんだ。",
              "citation": {
                "source": "夜の蝶",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうですかねえ」「俺がお前さんを抱きこもうと思って、うそをついてるとでも思ってるのか」「うそとは思いませんがね」「お前さんを抱きこもうと思ったら、上海へ来たお前さんを、今まで黙って放っとくわけはない。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊藤松雄に電話して舞台稽古に来ないかと言ったら、何か怒ってるらしく、来ないやうな返事、又うるさいな、放っとく。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし婆さんが本物だと知っていたら、放っとくと思うか。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてここの家を放っとくはずはありません。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなになるまでほっとくとは呆れましたな。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのおてがらに免じて、逃げたものならほっとくさ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "このままにほっとく方がいいです」「麻酔剤には何を用いたでしょう？",
              "citation": {
                "source": "祭の夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、ほっとくつろいだ吐息にはきだしますと、眼の前のことだけがまざまざと、恰も鏡に映ったようにはっきりと見えました。",
              "citation": {
                "source": "沼のほとり",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほっとくと気違いになりそうだから、まだ夏休みが半分ぐらい残っていたが、突然思い立って東京へ戻った。",
              "citation": {
                "source": "二十一",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんしろ、じぶんのきているぼろ着物がもえたって、そのままほっとくんだからなあ。",
              "citation": {
                "source": "こわいことを知りたくて旅にでかけた男の話",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで起きなけれぼ、ほっとくほうがいいんです。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほっとくと殖える一方だよ。",
              "citation": {
                "source": "日日の麺麭",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほっとくべきだった。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
