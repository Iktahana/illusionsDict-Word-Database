[
  {
    "uuid": "5b173478-d8e9-51b0-88ac-c234826b55cc",
    "entry": "法主",
    "reading": {
      "primary": "ほっす",
      "alternatives": [
        "ほっしゅ",
        "ほうしゅ"
      ],
      "is_heteronym": false
    },
    "grammar": {
