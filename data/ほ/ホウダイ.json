    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese title (given to foreign work)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
