[
  {
    "uuid": "cfe932dc-0ce1-5c2f-a4ea-a962b079bce1",
    "entry": "放題",
    "reading": {
      "primary": "ほうだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "接尾辞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(doing) as one pleases",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今はもうぐつすり眠つてゐて、脚を伸ばしたい放題に伸ばしてゐる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "散々あぶく銭を男たちから絞って、好き放題なことをした商売女が、年老いて良心への償いのため、誰でもこんなことはしたいのだろう。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、ウルスガァルでふんぞりかへつて、したい放題のことをしてゐるその死の中に……　よし誰が侍從ブリッゲに對して、そんな死ではなしに、もつと他の死を死なんことを希望したにせよ、どうして彼はそんなことに構つただらうか？",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし元子の結合のしかたにある定則があって、勝手放題なものはできない。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央アジアではまだ自然が人間などの存在を無視して勝手放題にあばれ回っている。",
              "citation": {
                "source": "ロプ・ノールその他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾はサンザしたい放題のことをして来た虚無主義のブルジョア……惜しい浮世じゃ御座んせんからね。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "出放題の和歌を詠んでは人を笑わせ、縁を取持っては人間の種をアチコチに蒔いてまわるのが何よりの道楽で……棄てた水仙、粋ゆえ身故、水に濡れ濡れ花が咲く……とか申しますなあ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃｜痳疹が流行りよるけに何かよい禁厭はないかちゅう話から、わしが気休めに書いて遣った、意味も何もない出放題じゃ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "避暑の客が大方帰ったので居残りの者は我儘放題、女中の手もすいたので或夕、大友は宿の娘のお正を占領して飲んでいたが、初めは戯談のほれたはれた問題が、次第に本物になって、大友は遂にその時から三年前の失恋談をはじめた。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「早く……早く行って助けて下さい……あすこだ、あすこだ」　私は、涙を流し放題に流して、地だんだをふまないばかりにせき立てて、震える手をのばして妹の頭がちょっぴり水の上に浮んでいる方を指しました。",
              "citation": {
                "source": "溺れかけた兄妹",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もっとも西山君のことだから、言いたい放題をいっているかもしれないが……」　清逸の心の裏をかくとでもいうような言葉がしばらくしてからまた園の唇を漏れた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京に行ってひとつ俺は暴れ放題に暴れるだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人は抵抗力がないといふだけの理由で、勝手放題な仕向けを子供の世界に對して投げつける。",
              "citation": {
                "source": "子供の世界",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも、あるがままがよいとして、食べたい放題、遊び放題、無理の言いたい放題、不義理のし放題――それを、また世間でも、磊落だとか無邪気だとか言って買い被り、苦笑しながらも黙って見ているようなことがあります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第九課　人生の広い道　私たちの持っている人間性、これを刈り取ってはいけず、さればと言って、伸び放題うっちゃって置いてもいけない、なかなか難しいことになりました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか私には逞ましい力が漲り、野のどこへでも好き放題に流れて行けそうです。",
              "citation": {
                "source": "愛",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝手に台所を掻廻した挙句が、やれ、刺身が無いわ、飯が食われぬ、醤油が切れたわ、味噌が無いわで、皿小鉢を病人へ投打ち三昧、摺鉢の当り放題。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "俎板とんとん庖丁チョキチョキ、出放題な、生欠伸をして大歎息を発する。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "放すが疾いか、猿は方々を駈ずり廻って勝手放題な道楽をする。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……洲崎の土手へ突き當つたつて、一つ船を押せば上總澪で、長崎、函館へ渡り放題。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家のまわりや山野渓谷を歩き廻って、見つかりしだい手あたり放題に雑草を摘んで来て、机上の壺に投げ入れて、それをしみじみ観賞するのである。",
              "citation": {
                "source": "白い花",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸子は庭に降りて、誰も構うものがないので、延び放題に延びてたおれかけたコスモスの群れをいくつにもまとめて紐で縛りつけていた。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔の生白いこの写真屋は土地の言葉でいう兄さんで、来たてからの客であり、倉持とは比べものにもならないが、銀子のためには玉稼ぎに打ってつけの若い衆で、お神や仕込みの歓心を買うために、来るたびに土産物を持ち込み、銀子の言いなり放題に、そこらの料亭を遊び歩いていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんしい、食べ辛棒の土地で気儘放題に育てられたもんやて！",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけれど兄であるのを嵩に着て傍若無人の振舞をし続けたり、弟だからとて甘えて放蕩の仕ほうだいをする。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その影響で、ぼくは別荘の坊ちゃんとしての我儘なしたいほうだいを止めて、執偏奇的な宗教家、神秘家になりました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　そこらあたりからは、いよいよ深く樹が茂り合っていて、太い幹に、山葡萄やあけびの蔓が、様々な怪奇な姿態でからみつき、路傍の熊笹や雑草も延びほうだいに延びている。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、路のうえまで茂りほうだいしげって、そのながくのびたじくや葉を、あたりの木の枝に、所かまわずからみつけましたから、そこらはどこも、おぐらくなっていました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "また絵所に幾人も画家がいますが、席上の絵の描き手に選ばれておおぜいで出ます時は、どれがよいのか悪いのかちょっとわかりませんが、非写実的な蓬莱山とか、荒海の大魚とか、唐にしかいない恐ろしい獣の形とかを描く人は、勝手ほうだいに誇張したもので人を驚かせて、それは実際に遠くてもそれで通ります。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "機会を作って明石へ源氏の君をお迎えするから」　と勝手ほうだいなことを言うのにも、風変わりな性格がうかがわれた。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
