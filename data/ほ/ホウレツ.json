    "definitions": [
      {
        "index": 1,
        "gloss": "aromatic",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "飲んでみると名状の出来ぬ芳烈な香気が鼻と咽喉を通じて全身に漲るのであった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は昨年｜塩山の停車場で、白ペンキ塗の広告板に、一の宮郷銘酒「白嶺」と読んで、これは「雪の白酒」ではあるまいか、さぞ芳烈な味がすることであろうと思った、また他で製糸所の看板に、白嶺社とあるのを見て、この社の糸の光には、天雪の輝きがあろう、衣に織ったらばさぞ、と考えたことがある。",
              "citation": {
                "source": "雪の白峰",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦痛を通して内臓機関に浸み込んで行く芳烈な匂いは、彼の眼に青とも桃色ともつかぬ二重の蝶を幻覚させた。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "死にして生、そこに芳烈な匂いさえも感ぜられる。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "實に「思ひ出」の驚くべきはその至る所の頁をあけても芳烈無比な詩的靈魂が高調されてゐる事である。",
              "citation": {
                "source": "名詩集「思ひ出」の眞價",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとしきりすると闇のなかからは芳烈な柚の匂いが立ち騰って来た。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "フーッと長い息を吐くと、芳烈な緑色の香気が私の顔を打った。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「醉」と「香氣」と、ただそれだけの芳烈な幸福を詩歌の「最後のもの」として決定する。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "換言すれば、さういふ工合にして書かれた文章の中の幾篇が、讀者にまで、果して芳烈な詩的魅惑をあたへ得るか。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう、妹も伺いますから、もうすこしいらしてくださいまし」　讓の肉体は芳烈にして暖かな呼吸のつまるような圧迫を感じて動くことができなかった。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう妹も伺ひますから、もうすこしゐらしてくださいまし、」　譲の肉体は芳烈にして暖かな呼吸のつまるやうな厭迫を感じて動くことが出来なかつた。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この青春の悩みを煎じ詰めると、芳烈純真なる生命の火となって永劫に燃えさかえる。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロ文化の末路　しかしこうした江戸草創時代の元気横溢した平民の気象――逃げ水を追つつまきつつ家を建てた時代の芳烈な彼等の意気組は、太平が続くに連れて、次第に頽廃的傾向即ちブル気分を帯びて来た。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのたおやかな古文の妙、たとえば真名盤の香を瑰の芳烈なる薫か、ヘリオトロウプの艶に仇めいた移香かと想像してみると、昔読んだままのあの物語の記憶から、処々の忘れ難い句が、念頭に浮ぶ。",
              "citation": {
                "source": "『新訳源氏物語』初版の序",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした無感覚さと、ものぐささと、愚しさとの澱み滞つてゐる水のほとりにゐて、芹のみは早くも春の足音を気づいてみづみづしい新鮮な茎をそなたざまへとさし伸べてゐるのみか、芳烈な春の香を魚の腹のやうに冷えきつた葉つぱのひとつびとつに沁み徹らせてゐる。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜は山中の旅行に餓えていた美味、川魚のフライ、刺身、鯉こく、新鮮な野菜、美しい林檎、芳烈な酒、殆んど尽くる所を知らず四人して貪った。",
              "citation": {
                "source": "木曾御嶽の両面",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "放牧　其夜は山中の旅行に餓ゑてゐた美味、川魚のフライ、刺身、鯉こく、新鮮な野菜、美しい林檎、芳烈な酒、殆んど盡くる所を知らず四人して貪つた。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、急にふら／＼と眼の眩むのを覚えたが、私はその芳烈な香味を忘れることが出来なかつた。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "重たい風が飄々と吹く度に、興奮した私の鼻穴に、すがすがしい秋の果実店からあんなに芳烈な匂いがしてくる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "芳烈な油の匂いがする。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "重たい風が漂々と吹く度に、昂奮した私の鼻穴に、すがすがしい秋の果実店からあんなに芳烈な匂いがする。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして噎せかえるほど芳烈な、火のように舌を刺す液体をドクドクと口の中へ注ぎ込んでくれた……ように思うが、何が何であったかハッキリとは記憶しない。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な選手などは、二つも三つも掛けて貰っていましたが、ぼくが洋装をした田舎の小母さん然たる奥さんに、にこにこ笑いながら掛けて貰ったレイの花は、ひとつでも堪えられないくらい芳烈な香りを放っていました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカシアの芳烈な花々に満ち溢れた六月の植民地よ。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲壮だの芳烈だのと云う考えは出て来ない、ただ妙な圧迫を受ける。",
              "citation": {
                "source": "文芸の哲学的基礎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は芳烈な一樽の清酒を貰っても、それを味わい尽くす資格を持たない下戸として、今日まで世間から教育されて来たのである。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の学問に、若し万が一、新鮮と芳烈とを具へてゐる処があるとしたら、其は、先生の口うつしに過ぎないのである。",
              "citation": {
                "source": "古代研究　追ひ書き",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩の世界に這入つた事のないものは、いつでも其から、芳烈な他界の花の香を※ぐ。",
              "citation": {
                "source": "詩と散文との間を行く發想法",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
