    "definitions": [
      {
        "index": 1,
        "gloss": "seriousness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "或る種の作家は、本気に書くつもりの小説を前もって広告する事を避けたがるものである。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の人が、私の器量の悪口を言ふと、叔母は、本気に怒りました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の人が、私の器量の悪口を言うと、叔母は、本気に怒りました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本気な従兄の怒りを恐れる気持をゴマカすやうに、Ｓ子は雪駄の音をペツタペツタさせて、オドケてみた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一人の女性にこうまで深く染み通らせた白痴少年の一本気をも想ってみた。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うるさいのね、さあ、これでいいの」彼女は柚木が本気に自分を見入っているのに満足しながら、薬玉の簪の垂れをピラピラさせて云った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだ着物のことなどか　きさまらは男だらう　それに本気で着もののことを云ふのか、などとおれはそっと考へて見たがどうも気持が悪かった。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一かけるにしても足のふみやうがもっと経済もとれ本気にもなれさうでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとしゅっこは、さっきからよっぽど怒っていたとみえて、「ようし、見てろ」と云いながら、本気になって、ざぶんと水に飛び込んで、一生けん命、そっちの方へ泳いでいった。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れ商売上手の手合の仕事とすれば、害のない位をモッケの幸とせねばならぬが、真面目に家庭談を為すものや、本気に家庭作物を読む人々は、先ず此の家庭の意義を、十分に解して居って貰い度いものである。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "レーリーはたいそう感心し、また乗客のあるものがそれを本気に受取っているのを見て嬉しがっていた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時には吾々はもう少し謙遜な心持で自然と人間を熟視し、そうして本気で真面目に落着いて自然と人間から物を教わる気になるであろう。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "本気で云ってるんじゃないわ」　「儂も、本気じゃないとは思うが……」　源兵衛、不安になって奥の石松の部屋へ去る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか本気で云ってンじゃないわね」　石松、無言。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「先生はそれでよいかも　しれませんが　此の五郎蔵の腹の虫　が収まらぬ」　と本気になって怒り出した。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな男達と本気で喧嘩をするなんて問題にも何にもならないよといって誰かが鼻で嗤うような気もした。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "貝原は悪びれず、「相当な年配の男のいうことですから、あなたも本気で聴いて下さい。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "道理はあるが、あの徳の言い草が本気でない。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくと同じように本気に仕事にかかった人でなかったらこんなもの実に厭な面白くもないものにちがいない。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一かけるにしても足のふみようがもっと経済もとれ本気にもなれそうでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田は母親がそれをおずおずでもない一種変な口調で言い出したとき、いったいそれが本気なのかどうなのか、何度も母親の顔を見返すほど妙な気持になった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまだ本気にはなっていなかった。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いつの間にか本気になっていた。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし不幸にして科学が進歩するとともに科学というものの真価が誤解され、買いかぶられた結果として、化け物に対する世人の興味が不正当に希薄になった、今どき本気になって化け物の研究でも始めようという人はかなり気が引けるであろうと思う時代の形勢である。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれらの象が本気であばれだしたら大概の人間の知恵では到底どうにもならなくなるのではないか。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」という書物を買って来て本気に研究したこともあった。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、私は、怒る時には、本気に怒ってしまいます。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そう口を尖らせて不服を言うと、佐吉さんはにこにこ笑い、「誰も本気に聞いちゃ居ません。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、水夫たちから、ことに、彼女を見るも気の毒なくらいに恥ずかしめる、ボースンや大工らは、彼女が、「インド猿」によく似てると、むきつけて、そうであることが、不都合きわまることのようにほんきに、彼女を罵倒し、そして恥ずかしい目にからかった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそんな中から、可なりほんきな正しい態度の批評を、近頃聴くことが出来て、久しぶりの喜びを感じた位である。",
              "citation": {
                "source": "歌の円寂する時",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
