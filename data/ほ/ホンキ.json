  {
    "uuid": "b0ff66af-0884-5a0a-b2fd-e0295b1e795c",
    "entry": "本機",
    "reading": {
      "primary": "ほんき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
