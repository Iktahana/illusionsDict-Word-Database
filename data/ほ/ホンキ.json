    },
    "definitions": [
      {
        "index": 1,
        "gloss": "this device",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "紙の本作りの工程になぞらえれば印刷機や製本機の機能を代行し、植字工や編集者の作業の多くを自動化して受け持つこの製品は、Expanded Book Toolkit と名付けられている。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＢＢＡが想定していた画面上の拡大訳は、今や、これらのソフトの基本機能として実現されている。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "二千メートル以上の上空をとんでいる日本機の翼に、照空灯が二重三重四重に釘づけになっている。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "味方の砲撃の間を縫って、日本機を追いかけるのは、自殺行為と選ぶところがないではないか。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本機は、癪にさわるほど悠々と二千メートルの高空をぐるぐるまわっていた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "高射砲弾はぱっぱっと花傘をひらいたように、日本機の前後左右に炸裂する。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "がしばらくすると煙の横から、日本機は悠々と白い腹をくっきりと現すのであった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜか日本機は、光弾を落したきりで、ほかに一発の爆弾も落さなかったのだ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "監視中の日本機はどこへ行ったか、急に姿を隠してしまったのである。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪しき記号　日本機の姿が見えなくなってしまうと、飛行島の人々は、ほっと息をついて、おたがいの顔を見合わせた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「国籍不明ノ快速飛行機ガ本機ヨリ一キロ後方ニ尾行シテ来ル」　本機を尾行している国籍不明の飛行機とは一体何者が操るものであるか。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――『本機ニ二三〇三地点ニ達セルモ敵機ヲ発見スルニ至ラズ』……とあります」「あッ。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――『本機ニ三〇三地点ニ達セルモ敵機ヲ発見スルニ至ラズ』……とあります」　防空飛行隊が暗夜に必死の活動をつづけている間、帝都では、非常管制をはじめ、あらゆる防護の手段が着々として用意されていった。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには「銀翼号に関する事実の一部」とあって、「本機「銀のつばさ」は、アラン・カブハム卿が倫敦ケイプ・タウン間、ならびに英濠往復飛行に使用して大成功をおさめたるアウムストロング・シドレイ式三八五・四二五馬力冷空ジャガア・エンジン三個により推進さる。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "本機は特に長時間飛行のため建造られ、キャビンの通風｜煖※照明等すべて最も近代的デザインになる。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "本機の最大速力は一時間百｜哩以上。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本機は銀色、Ａ国機は水色である。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、あれは、日本の飛行機じゃないか」「日の丸のマークはついているが、まさか、この南極に、日本の飛行機がやってくるはずはない」「でも、日の丸がついていれば日本機と思うほかないではないか」　将校の間には、はやくも、いいあらそいがおこった。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、いったん、通りすぎた日本機は、すぐまた、引きかえしてきた。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本機は、大たんな低空飛行をつづけてあっという間にとび去った。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本機が、機銃一つ、うたないのに……。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことで、アメリカ兵の弾丸が、日本機にとどくはずはなかった。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本機め、うまくにげやがった」「もう一度、とんでこい。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはどうやらさっき基地の上を低空飛行でとびさった日本機らしかった。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、全機は、隼のように、日本機の編隊のうえにとびかかっていった。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっ、前に、日本機がいるじゃないか。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本機は、どういうものか、一発もうってこないで、ひらりひらりと逃げまわってばかりいるのだ。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "察するところ日本機は全部、うちおとされたのかもしれないぞ」　パイ軍曹は、景気のいいことをいった。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、水夫たちから、ことに、彼女を見るも気の毒なくらいに恥ずかしめる、ボースンや大工らは、彼女が、「インド猿」によく似てると、むきつけて、そうであることが、不都合きわまることのようにほんきに、彼女を罵倒し、そして恥ずかしい目にからかった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそんな中から、可なりほんきな正しい態度の批評を、近頃聴くことが出来て、久しぶりの喜びを感じた位である。",
              "citation": {
                "source": "歌の円寂する時",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
