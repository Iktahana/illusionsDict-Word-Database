[
  {
    "uuid": "183d4a4a-8bd5-5664-9f7c-efdb36103a6d",
    "entry": "ほどの事はない",
    "reading": {
      "primary": "ほどのことはない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
