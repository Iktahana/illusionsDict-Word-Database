[
  {
    "uuid": "b19554bf-98dd-5907-9027-9a0e08b84da1",
    "entry": "方策",
    "reading": {
      "primary": "ほうさく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "plan",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これを仮に第二次の作戦とすると、そのもう一つ上の第三次の方策は第一次とほぼ同じようなことになるのである。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く予測し難い地震台風に鞭打たれつづけている日本人はそれら現象の原因を探究するよりも、それらの災害を軽減し回避する具体的方策の研究にその知恵を傾けたもののように思われる。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "神々が鏡や玉を作ったりしてあらゆる方策を講じるという顛末を叙した記事は、ともかくも、相当な長い時間の経過を暗示するからである。",
              "citation": {
                "source": "神話と地球物理学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしていっそう難儀なことはその根本的な無知を自覚しないでほんとうはわからないことをわかったつもりになったりあるいは第二次以下の末梢的因子を第一次の因子と誤認したりして途方もない間違った施設方策をもって世の中に横車を押そうとするもののあることである。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一方下級の技術官たちの間では実に明白に有効重要と思われる積極的あるいは消極的方策があっても、その見やすい事が、取捨の全権を握っている上長官に透徹するまでにはしばしば容易ならぬ抵抗に打ち勝つことが必要である。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことにその間に庶務とか会計とかいう「純粋な役人」の系列が介在している場合はなおさら科学的方策の上下疎通が困難になる道理である。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼にはこの危地から自分を救いだす方策はすぐにでき上っていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどの借主どもに対する方策としてもだ、さうせかれちや実際困らあね。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "中庸の方は上智英略あらざるものの方策なるを言ふ也。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこれ等の手紙が安全にあなたのお手に入る方策をとります。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから家康が立てた政治の根本方策は、「神君が定め置かれた通り」に自動的に適用されて、代を経るに従つて、どこまでも巧緻精妙化されて行く力を内蔵してゐたのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一の道がもし交通を遮断すれば、第二の道へ、第二の道でもまた何かの偶発事から交通を遮断するようなことがあればさらに第三の道へと、彼らは臨機応変に処置して入場時刻に遅れない方策を用意していた。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわんや、実際地方には必ず多少の姦徒あり、種々方策してこの基本金を濫用し去らんとする輩多きをや。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の間に就いては百方策が盡きた。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧語学校の支那語科出身で、若い東方策士のグループの一人として二葉亭とは学校時代からの親交であった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはどうしたって、会わないというその事がらに対して疑いを深めるより道はないのだけれども、相手は小身ながらともかくもお直参のかさを着たお旗本なんでしたから、右門は三倍に疑惑を強めながらも、第一段の方策は放棄するのほかはありませんでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇から闇へ片付けて、事の黒白を永遠に秘密の中に葬ろうとしたこの計らいが、豊後自身の方策から出ているか、それとも腰本治右が手を廻した策であるか、もしも治右が陰に動いて、破邪顕正の大役承わる大目付までをもおのが薬籠中のものにしているとしたら、ゆめ油断はならぬ。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "職工たちがせゝッこましい工場の中のことで、頭をつッこんでグズ／＼しているまに、彼等は「世界」と歩調を合せて、その方策を進めていた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、我々は、皆んなにお集りを願ひ、その方策をきめることにしたいのだ、と結んで壇を下りた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処で彼は数多の紹介状を贋造して、多くの富豪の知己となり、それから彼は徐々に詐欺の方策を進めて行った。",
              "citation": {
                "source": "錬金詐欺",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "して見ると、ポオがこの物語の一八五〇年版に附加した脚註（この文の最初に掲げた）はデフォーがしばしば用いた手段と同じように、読者の感興を深からしめるための方策に過ぎないといっても差支ないと思われる。",
              "citation": {
                "source": "「マリー・ロオジェ事件」の研究",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "願はしいのはお上が何等かの方策を樹ててくれることだ。",
              "citation": {
                "source": "東旭川村にて",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学教育の徹底、技術水準の向上、生産力の大拡充が、われらの奮闘の目標であるが、特に発明の奨励には国家が最大の関心を払い、卓抜果敢な方策を強行せねばならぬ。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "國内におけるニユー・デイール、國際的にはマーシヤル・プラン、更に最近に到つては全世界にわたる未開發地域援助方策等は、それ自身が大なる統制主義の發現に他ならぬ。",
              "citation": {
                "source": "新日本の進路",
                "author": "石原莞爾將軍の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツは天才ヒットラーにより戦争の中に於て着々欧州連盟の結成に努力し、恩威併行の適切なる方策により輝かしき成果を挙げている。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本映画の進出に関する方策については今までにおびただしい議論がくり返されたが、私の見るところではだいたいにおいてそれを二つの傾向にわかつことができる。",
              "citation": {
                "source": "映画と民族性",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大衆の文化を圧する方策が、大衆の現実という名において大衆の頭上にふりかかって来ている。",
              "citation": {
                "source": "全体主義への吟味",
                "author": "――今日の民衆、知識人への課題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、もう百方策尽きているところへ、神近から金を送ろうかと言って来た。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
