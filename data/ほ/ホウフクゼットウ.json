[
  {
    "uuid": "862b8793-1154-58d1-bd83-e0d58f93d0b5",
    "entry": "抱腹絶倒",
    "reading": {
      "primary": "ほうふくぜっとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
