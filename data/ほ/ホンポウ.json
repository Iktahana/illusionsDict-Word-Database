    "definitions": [
      {
        "index": 1,
        "gloss": "regular salary",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "吾輩の本俸手当を全部タタキ込んでも建物の家賃と、タッタ一人の事務員の月給と、小使の給料に足りないのだから屁古垂れたよ……実際……。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "月収百四十円（本俸の由）　譲治氏青森へ行った由、二十二日に。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○その外に九月から翌年一月までの五ヶ月分の本俸が、どこか留守を担任する部隊から直接とゞくかと思ひます。",
              "citation": {
                "source": "島の便り",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
