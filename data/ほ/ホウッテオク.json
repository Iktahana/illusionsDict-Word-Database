    "definitions": [
      {
        "index": 1,
        "gloss": "to leave alone",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "怪我をしている者だけは、そのまま床の上に放っておくわけにはゆきませんからな」「あなたはいつ頃ここに来られました？",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "誓いました、どんなものであろうと、もう放っておくことはできない、と。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は謎のパズルを解きほぐそうとしたが、絶望し、あきらめ、夜になって全貌が明らかになるまでこの事は放っておくことにした。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏中は窓を開け放していても、この病気特有の一種の動物的悪臭が房内にこもり、それは外から来るものには堪えがたく思われるほどのもので、担当の老看守すら扉をあけることを嫌って運動にも出さずに放っておくことが多かった。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "放っておくと体の躍り出しそうな若者なら、原宿の歩行者天国にでも出かけるのだろう。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも立たん奴は暫く氷った土の中へ放っておくことです。",
              "citation": {
                "source": "戦場",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在ソヴェト同盟にある食糧困難が、五ヵ年計画さえやっちまえばひとりでに消えるもんだろうぐらいに考えて放っておくのは、まるで非階級的な日和見主義だということが、よく分ったと思うんだ。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このままで、しばらく放っておくと、海綿は水を吸ってふくらみまして図のようになります。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、いくら天狗だからといって、そのまま放っておくわけにはゆきません。",
              "citation": {
                "source": "天狗の鼻",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "御返しよ、放っておくれよ、よう、と精一杯にせっついたが与吉は毬を持ったまま、上を見て威張って突立っている。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕はお前を自由に放っておくことが、お前の精神力を引立たせる仕方だと思っていた。",
              "citation": {
                "source": "食慾",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――放っておくがいいんだ。",
              "citation": {
                "source": "霧の中",
                "author": "――「正夫の世界」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ていると、滑稽で気の毒にもなるが、たかが女のことだ、放っておくに限る。",
              "citation": {
                "source": "好人物",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、二人だけ放っておくわけにもゆかないだろうね。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃ私には、あなたの出来ないとわかっている事を知らん顔をして放っておくことは出来なかったし、自分なら出来るとわかっている仕事を出来ないような顔をしてすましていることもしませんでした。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯火事になりそうなものを早く消し、道路上のものは放っておくがよい。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことになるよりは、自然のまま放っておく方がましです。",
              "citation": {
                "source": "変な男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉岡をあのまま放っておくのは気に掛ることだったけれど、もう最後の手段として何事にも触れないで、時の経過を待つの外はないと腹をきめた。",
              "citation": {
                "source": "好意",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかって、このまま放っておくわけにもゆきませんしね。",
              "citation": {
                "source": "叔父",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはこの比野町の西端に、新築の二階家があって、それを抵当流れで実は建築主から受取ったものの、自分はこの町に住むつもりはないので、空き家にして放っておくより法がない有様である。",
              "citation": {
                "source": "雷",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "女難により居候失脚のこと　勘当の五郎を放っておくわけにいかないから、十郎は弟につきそって、親類を転々と居候して歩いた。",
              "citation": {
                "source": "曾我の暴れん坊",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時は占領後まだ日は浅い時で、第三国人の勢力が強い時でもあるが、ジコーサマの乱暴ローゼキが何と云ってもたしかに訴えの通りに相違ないのであるから、警察も放っておくわけにはゆかない。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "放っておくと、二人でどこかへ行ってしまいそうで、あぶなくてしょうがないから、離すわけにはいかない。",
              "citation": {
                "source": "猪鹿蝶",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "このまま放っておくと、いずれ姉とおなじようなことをやりだすにちがいない。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく人間の利用するために用意されてあるものを、利用しないで放っておくのは、人間の怠慢だよ。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ、立ち去る記代子を立ち去るままに放っておくことができないのは、可憐な記代子に断ちがたいミレンのあるせいだ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば、彼女は、さっそく意趣返しができたつもりになり、彼を放っておくに違いないからだ。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらはつぎつぎと仕事に追われているので、こういう御礼状などは貰っても、それを印象に留めることは出来ないのであるから、少し無駄だという気もするが、先方にしたら、見学や出張の締めくくりをするという意味でも、全然放っておくことも出来ないのであろう。",
              "citation": {
                "source": "低温室だより",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人が余りやきもきしないで放っておくというのも一法であるが、それでは少し乱暴である。",
              "citation": {
                "source": "簪を挿した蛇",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にはそれを拭わずにほうっておくことは出来ません」「どうもまだはっきりしないんですが、マンローさん」　と、ホームズは少しイライラして云った。",
              "citation": {
                "source": "黄色な顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
