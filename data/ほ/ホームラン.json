        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蛾をはたき落す猫を羨み讃歎する心がベースボールのホームランヒットに喝采を送る。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "サーブからして見送りのストライクばかりで、タマタマ当ったと思うと鉄網越しのホームラン……それでも本人は勝ったのか敗けたのか解らないまま、いつまでもコートの上でキョロキョロしている。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛾をはたき落とす猫をうらやみ賛嘆する心がベースボールのホームランヒットに喝采を送る。",
              "citation": {
                "source": "からすうりの花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一には、ホームラン性の打球を追って、フェンスによじのぼった外野手が見える。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホームランか、スリーアウト、チェンジかの分かれ目だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホームランをキャッチしてしまった外野手が、高だかとグラヴをさしあげる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おやじのシャッポ（ポコペンとか駄目とかいう意味）がホームラン（流連のこと）」だの、「彼女のラジオ（色眼）がミシン（意味深長）」なぞ云って、わかる気づかいは毛頭ない。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このバットには先生がぼくらを愛する慈愛の魂がこもってる、ぼくはかならずこれでホームランを打ってみせるよ、ぼくが打つんじゃない先生が打つんだ」　　　　　　　　　九　浦和中学と黙々塾が野球の試合をやるといううわさが町内に伝わったとき人々は冷笑した。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうじゃない、もしひとりでも傑出した打手があってホームランを三本打てば三点とられるからね、勝負はそのときの拍子だ、強いからってゆだんがならない」「だからぼくは練習をしようというんだ、青木千三は小学校時代には実にうまかったからね、身体が小さいがおそろしいのはかれだよ」　と光一はいった。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホームランか三塁か、いずれにしても一点は取るだろうと人々は思った、投手五大洲はじっと腕をくんで捕手のサインを見やった。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "原さんワセダで、ホームランに大熱狂。",
              "citation": {
                "source": "日記",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケイオーどんどんのり出しあわやというとき呉のホームラン。",
              "citation": {
                "source": "日記",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "また向いのイタズラ小僧がホームランを出しやがったな。",
              "citation": {
                "source": "空気男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "打つ、投げる、はまだいゝのですが、走る方がもうダメですと、千谷先生は嘆いていたが、まさに同感、僕らの年齢になると、ホームランを打っても、せいぜい二塁で息がつづかず、休息ということになり、その疲労で一度にグッタリしてしまう。",
              "citation": {
                "source": "神経衰弱的野球美学論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの縦横の廊下に、パチンコ屋だのボットル落しだのホームランゲームだのと、その店の数だって人口三万の東海道の温泉都市と覇を争うほどの盛大なものだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて、「ホームラン、ホームラン。",
              "citation": {
                "source": "はつゆめ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴木静一が「僕のホームラン」の曲が出来たからと、ひいて呉れた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕のホームラン」の吹込みをやる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕のホームラン」のテスト盤をきいて、あんまり声楽家じみた声で本格に歌ひすぎてるのでくさった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時からビクター「僕のホームラン」の吹込直しである。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者へ寄り、ビクターへ、「僕のホームラン」の吹込直しのつもりで行ったが、誰にも通ってゐないらしい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕のホームラン」すら／＼行って無事に吹込が済んだ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「東京オリムピック」と「僕のホームラン」のテスト盤をきく、まあ両方ともきかれる程度には入ってゐる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベーブ・ルースといふ男はホームラン王だが、それでも三振することがある、他の人間なら三振すれば引込め、バカヤローを食ふところ、ベーブの場合は客が喜んで拍手し声援する。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
