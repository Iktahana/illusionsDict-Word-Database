    "definitions": [
      {
        "index": 1,
        "gloss": "head house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "で、長男の私が学校を打つちやつて詩人になるとか脚本家になるとか勝手な熱を吹いてゐることは父に取つては自分の命を喰ひ取られることとしか思へなかつたのだ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "設計者が日本に地震という現象のあることをつい忘れていたか、それとも設計を註文した資本家が経済上の都合で、強い地震の来るまでは安全という設計で満足したのかもしれない。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、そのうちに本家の老舗の日本人がこのアメリカ語に翻訳された「俳諧」の逆輸入をいかなる形式においてしおおせるであろうかを観望するのは、さらにより多く興味の深いことである。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる颱風なるものが三十年五十年、すなわち日本家屋の保存期限と同じ程度の年数をへだてて襲来するのだったら結果は同様であろう。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "差当ってこの両都市で本家争を起すべきである。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "コトレツ・ミラネーズとウィンナー・シュニッツレルの異るところは前者は伊太利風のマカロニかスパゲチを付け合せとして居り、後者が馬鈴薯を主な付け合せとしていることで、そこに両本家の特色を表わしている。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また構造物の模型実験が従来はいわゆる力学的相似にかまわず行われているのに飽き足らず、この点について合理的な模型を作る方法を考案し、その一例としてパラフィンの混合物で二階建日本家屋の模型を作りその振動を験測したりした。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お松が家の本家のあるじだという事であった。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでにペストの本家本元たるインドでは宗教上の迷信から殺生を絶対的に忌むので、鼠狩りの実行が甚だ困難なようである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文章倶樂部のものはさうした資本家惡の犧牲になる一人の中番頭のなんともならない境遇が實に丹念にかけてゐた。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸なことに北海から税関をかすめて密輸入される鮭類と黒狐の肉は腹を満たすためには四十｜法が必要なので、アンナ・ニコロはスラビナに食欲さえ感じて黙ってしまうのだが、それにも拘らず私は現代のロシアの気狂い染みた歴史家の記録が純粋な女性の愛情まで資本家に身売りしていることが分るのであった。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "人道主義の砲弾でさえ影を潜めて民族に対する愛着をなくした支那の現在が資本家とプロレタリアに分岐されず、国内に小協商、小同盟を作ってプチ・ブルジョワの戦が始められるのです。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "売笑婦の持つ感覚の楼上から底辺に達する戦場には、資本家の軍隊の残した指紋の遺跡がある。",
              "citation": {
                "source": "戦争のファンタジイ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "袋地の奧にある自分の家、出入りの度毎に厭やでも眼に著くのだが、古い日本家を洋風まがひに造りなほした、さう言へば如何にもそれらしい變に陰氣臭い感じの小住宅で、殺された女中の可憐な一田舍娘らしい容姿もぼんやり自分の頭に殘つてゐる。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは全く、内地で懐手をしている資本家や地元の手先として使われているのだ。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時には地主も資本家やその他の、現在に於ける社会的地位が、がらりと変って来る。",
              "citation": {
                "source": "小豆島",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本家のためであり、地主のためである。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士たちは、自分が労働者の出身であり、農民の出身でありながら、軍隊に這入ると、武器を使うことを習って、自分たちの敵である資本家や地主のために奉仕しなければならない。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "満洲や台湾の苦力や蕃人を動物を使うように酷使して、しこたま儲けてきた金で、資本家は、ダラ幹や、社会民主主義者どもにおこぼれをやるだろう。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年田之浦の本家へ歸つて亡なつたとの事である。",
              "citation": {
                "source": "都の友へ、Ｂ生より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "原始的にはあるいは南洋に系統を引いていないとも限らないであろうが、しかしたとえそうであっても現時の日本家屋は日本の気候に適合するように進化し、また日本の各地方でそれぞれの気候的特徴に応じて多少ずつは分化した発達をも遂げて来ている。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人間の「本家」がまき歩くビラの「ホンケ」は、鼻紙を八つ切りにしたのに粗末な木版で赤く印刷したものであったが、その木版の絵がやはり蝙蝠傘をさして尻端折った薬売りの「ホンケ」の姿を写したものであった。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合において馬方は資本家であり、馬は労働者である。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本家は、紡績にも、機械にも、製粉にも、搾油にも、製糖にもこの方法を用いていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "米国資本家の如きは、早くも黄河の氾濫地帯が棉花栽培に適することに着目し、調査の歩を進めている。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君ハ、日本国内ニ於テハ、農村ヤ工場ニ於テ、資本家ヤ地主カラ搾取セラレ、支那ニキテハ帝国主義ブルジョアジーノタメニ命ガケノ血ナマグサイ戦争ヲサセラレヨウトシテイル。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "満洲ハタダ大資本家大地主ヲ太ラセルダケダ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "太ッタ大資本家共ハ、鈴文ヤ松駒ノ如キ階級的裏切者ヲ買収シ、諸君カラノ搾取ヲマスマスヤサシクシ、諸君ノ妻ヤ子ヲ、飢ニヒンセシメ、諸君ヲモ絞殺スル反動ノ城塞ヲ固クスルモノデアル。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴隷が奴隷主に対しての闘争、領主に対する農奴の闘争、資本家に対する労働者の闘争は必要である。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
