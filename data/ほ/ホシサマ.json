        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「北の青いお星さま、あなたの所へどうか私を連れてって下さい。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「東の白いお星さま、どうか私をあなたの所へ連れてって下さい。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれきっと双子のお星さまのお宮だよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「双子のお星さまのお宮って何だい。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "双子のお星さまが何したっての。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "双〔〕子のお星さまが野原へ遊びにでてからすと喧嘩したんだらう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはきっと黄金色のお星さまになるんだよ。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お星さまは野原の露がキラキラ固まったようです。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "双子のお星さまが野原へ遊びにでてからすと喧嘩したんだろう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれはチュンセ童子とポウセ童子という双子のお星さまの住んでいる小さな水精のお宮です。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして双子のお星さまだちは海蛇の王さまの前に導かれました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "双子のお星さまはめいめいのお宮に昇りました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれきっと双子のお星さまのお宮だよ」男の子がいきなり窓の外をさして叫びました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「双子のお星さまのお宮ってなんだい」「あたし前になんべんもお母さんから聞いたわ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "双子のお星さまが何をしたっての」「ぼくも知ってらい。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "双子のお星さまが野原へ遊びにでて、からすと喧嘩したんだろう」「そうじゃないわよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はきっと黄金色のお星さまになるんだよ。",
              "citation": {
                "source": "いてふの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お星さまをちりばめたやうな立派な瓔珞をかけてゐました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして見ると空にはずゐぶん沢山のお日さまが、あら、お星さまが、あらやっぱり変だわ、お日さまがあるんですね。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お星さまにはどうしてあゝ赤いのや黄のや緑のやあるんでせうね。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お星さまのいろのことですわ。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれきつと雙子のお星さまのお宮だよ。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雙子のお星さまのお宮つて何だい。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
