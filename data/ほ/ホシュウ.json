[
  {
    "uuid": "eac0711c-130f-5283-a7c4-4c19eb22b10c",
    "entry": "補修",
    "reading": {
      "primary": "ほしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
