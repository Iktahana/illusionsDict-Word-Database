[
  {
    "uuid": "816ea38e-7e69-5fb6-ac68-cbeba8eb6002",
    "entry": "惚れる",
    "reading": {
      "primary": "ほれる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
