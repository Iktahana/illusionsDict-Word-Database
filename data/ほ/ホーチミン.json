          "standard": [
            {
              "text": "胡志明はベトナムの独立運動を指導し、建国の父として今も尊敬されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歴史の教科書で、胡志明が歩んだ波乱に満ちた生涯を辿った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "胡志明廟には、彼の遺体が安置されており、多くの参拝者が訪れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
