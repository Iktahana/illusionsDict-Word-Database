        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「曽田屋の気違いめ、又あの保険屋とふざけ散らしているな。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜もあの通り保険屋の若い男と狂い廻っている始末……。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "保険屋８・22（夕）　今の世に廃兵と生命保険の勧誘員ほど蒼蠅い者は、たんと有るまい。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "保険屋は一文でも掛金を多くしたいのと、一寸｜物識らしい顔がしてみたかつたのだ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "保険屋の野崎君も好い感じを持っていない。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "保険屋のように唯殖しさえすれば宜いって次第のものじゃない。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸出ていたものだから」「保険屋になると居留守は食いつけているから一向驚かない」「本当だよ。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは僕達保険屋の常食だ。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は今朝あたりの積りで当てにしていたら、悉皆忘れていた保険屋がやって来やがった。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから保険屋が来るから潰れてしまう。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは前の女中に無断で逃げられた当座、おきぬが来るまでの間を、その保険屋の細君に手伝ってもらっていたからである。",
              "citation": {
                "source": "早春",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "保険屋の細君はひまを見ては、よくおかみさんの部屋にきて話し込んで行った。",
              "citation": {
                "source": "早春",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と保険屋の細君は云った。",
              "citation": {
                "source": "早春",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "保険屋さんの団体、これのつまらんこと、全く受けるところが変り、すっかりクサる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "変更々々で、主人公の商売が保険屋になったり小使になったり、結局野球場の掃除夫の如きものとなったらしい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
