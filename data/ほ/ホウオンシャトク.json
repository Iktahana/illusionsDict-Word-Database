          "literary": [
            {
              "text": "報恩謝徳の厚志があらば、神明の加護もあろう。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "その唱うる念仏は報恩謝徳の念仏であって、極楽往生を願う為の念仏ではない。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば自分が公の行状を書き記すのも、一つには追善供養のため、一つには報恩謝徳のためで、別に他意ある次第ではない。",
              "citation": {
                "source": "武州公秘話",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
