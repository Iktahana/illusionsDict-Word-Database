        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "父は維新前いわゆる御鯨方の支配の下に行われた捕鯨の壮観と、大漁後のバッカスの饗宴とを度々目撃し体験していたので、出発前にその話を飽きるほど聞かされていた。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今になって考えてみるとそのおかげでかえって自分の頭の中には父の言葉で描かれた封建時代の捕鯨の光景がかなり鮮明な影像となって四十年後の今日もまだ保存されているのである。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷役に忙しい樺太や釧路通ひの汽船や、白いペンキの醜く剥げ落ちた帆船の中には、舷の低い捕鯨船の疲れたやうな姿が横はつてゐる。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大分沖へ出た頃、サヴァイイから帰る数隻の捕鯨ボートに追越される。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白人の――恐らくは昔の捕鯨者等の――血の交つてゐることは明らかである。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "白人の――恐らくは昔の捕鯨者らの――血の交っていることは明らかである。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕鯨者は鰯やひらめにどう値するか。",
              "citation": {
                "source": "風は草木にささやいた",
                "author": "風は草木にささやいた",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなる捕鯨船もいまだかつてこの時期にあって、かかる緯度の処にとどまったことはなかった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "（捕鯨者仲間では鯨を体の長さで計らず、その鬚の長さで計るのである）　さて、ドクトル。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミルン氏はまたこう考えている――船長という職は彼がみずから選み得るなかで最も危険な職業であるという理由によって、単に捕鯨に身をゆだねて来たのであって、彼はあらゆる方法で死を求めているのであると。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "大北極の氷群、すなわち捕鯨者のいわゆる「関所」のはしに位してはいるが、どんな風でも北さえ吹けば、われわれの周囲の氷を粉砕して、われわれを助けてくれることになる。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕鯨船のうちで、イングランド教会の祈祷書が常に用いられるのはおかしなことである。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕鯨船｜北海丸の砲手で、小森安吉と云うのが、その夫の名前だった。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "砲手は、捕鯨船では高級な船員だった。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海丸と云うのは、二百｜噸足らずのノルウェー式捕鯨船で、小さな合名組織の岩倉捕鯨会社に属していた。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初に救難信号を受信つけたのは、北海丸から二十｜浬と離れない地点で、同じように捕鯨に従事していた同じ岩倉会社の、北海丸とは姉妹船の釧路丸だった。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ日本の捕鯨船にノルウェー人の砲手達が雇われていた頃から、その人達によって云い伝えられた伝説だった。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「仔鯨を撃つ捕鯨船には、必らず祟りがある」　宗教に凝った異邦人達は、そう云って仔鯨撃ちを恐れ拒んだ。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "親鯨でさえもその濫獲を防ぐためには、政府は捕鯨船の建造を、全国で三十艘以内に制限しているのだった。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、捕鯨能率を高めるために、監視船の眼のとどかぬ沖合で、秘かに仔鯨撃ちも犯す捕鯨船は、時折りあるらしかった。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "安吉の告げ残した「釧路丸」と云えば、同じ岩倉会社の姉妹船で、北海丸が去年の秋に沈没した折、いち早く救助に駈けつけた捕鯨船ではないか。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの海でどんな風にして捕鯨をしとったか、果してあそこらの海でうろうろ鯨を追っていたのかどうか、さアそいつは誰も見ていた人はないんだから、流石の岩倉社長も証明することは出来ないよ」「いよいよ怪しいな」「うン、怪しいのはそれだけじゃアない。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "電文は――捕鯨船ニ告グ、東経１５２、北緯45ノ附近ヲ、北北東ニ向ウ大鯨群アリ――それほどの大鯨群でもないんだが」と東屋氏は笑いながら、「そうそう、序に発信者を――貨物船えとろふ丸――とでもしといて下さい」「えとろふ丸、はよかったですね」　船長が苦笑した。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初右舷の遥か前方に、黒い小さな船影がポツンと現れたかと思うと、見る見る大きく、捕鯨船となって、その鯨群を発見けてか、素晴らしい速力で潮の林へ船首を向けて行った。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕鯨船は、見る見る鯨群に近付いて、早くも船首にパッと白煙を上げると、海の中から大きな抹香鯨の尻穂が、瞬間跳ね曲って、激しい飛沫を叩きあげた。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "間違いないようですよ」　やがて捕鯨船は、両の舷側に大きな獲物を浮袋のようにいくつも縛りつけて、悠々と引きあげて行った。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、しかし、一時間しても、第二の捕鯨船は現れない。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "左舷の斜め前方に、とうとう岩倉会社特有の、灰色の捕鯨船が現れたのだ。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
