        "examples": {
          "standard": [
            {
              "text": "大学受験の本試験まで、あと一ヶ月を切った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "本試験では、これまでの学習成果が問われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は本試験に合格するため、毎日遅くまで勉強している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "七月十日から一学期の本試験がはじまっている。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今年あるよ、君はそれに優等で及第するよ」　間もなく郷試があったので、朱もそれに応じてみると第一等の成績を得、秋の本試験には経元に及第した。",
              "citation": {
                "source": "陸判",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして学期の途中には中間試験、学期末には、本試験がある。",
              "citation": {
                "source": "六三制を活かす道",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本試験のときは、夜明けの四時五時まで、あるいは徹夜である。",
              "citation": {
                "source": "六三制を活かす道",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
