[
  {
    "uuid": "c850901d-c76b-5eee-8ee2-10f413a328a1",
    "entry": "本題",
    "reading": {
      "primary": "ほんだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
