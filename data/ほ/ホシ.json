[
  {
    "uuid": "6151e3e1-2399-5e09-b0de-b150bddd1e60",
    "entry": "干し",
    "reading": {
      "primary": "ほし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-接頭辞"
      ],
