      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "drying",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "色々の手拭やタオルの洗濯したのがその上に干し並べてある。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風が強くて干し物がいくつか砂利の上に落ちている。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高阪橋を越す時東を見ると、女学生が大勢立っていると思ったが、それは海老茶色の葦を干してあるのであった。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "辨天樣の池畔などで、ぐつたり寢そべつて甲羅を干してゐるのは、あれは、いしがめとでもいふのであらうか、繪本には時々、浦島さんが、あの石龜の脊に乘つて小手をかざし、はるか龍宮を眺めてゐる繪があるやうだが、あんな龜は、海へ這入つたとたんに鹹水にむせて頓死するだらう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "郊外住宅者は干し物を東南方の側には出して乾せない日である。",
              "citation": {
                "source": "風と裾",
                "author": "――何人か良案はないか？――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「沈丁花の花の干したのをお風呂へ入れてあげるから入りなさい。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お城の下の麥を干したらしい空くひの列に沿って小さな犬が馳けて來る。",
              "citation": {
                "source": "うろこ雲",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですからわざと真面目な顔をして、「ここの水少し干したほういいな、鉄梃を貸しませんか。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が十二月二十五日の午前に帰って見ると、庭一面に籾を干してあって、母は前の縁側に蒲団を敷いて日向ぼっこをしていた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふぐのひれの干したの（大丈夫ですかな？",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "風景にしても壞れかかつた街だとか、その街にしても他所他所しい表通よりもどこか親しみのある、汚い洗濯物が干してあつたりがらくたが轉してあつたりむさくるしい部屋が覗いてゐたりする裏通が好きであつた。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る窓には白い布が干してあつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、窓臺の上には氷嚢や白い布が三つ四つ干し並べてあるのに氣が附いた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、きつと、どうにかするよ」「だけど、あなたのそのどうにかするつていふことほど、いつも當てにならないのはないぢやありませんか」「然し、お互に日干しにもならない所を見ると、たしかにどうにかなつて行きつつあるぢやないか」「あア、あなたにはとても叶はない」　妻はふつと笑ひ出した。",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はふと思ひ出して、半分殘つてゐたグラスのウイスキイをぐつと呑み干した。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一面に干した烏賊の匂ひがひどく鼻をついた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは干した牧草を小山のやうに積んでゐた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっとしていわゆる甲良を干しているという様子であった。",
              "citation": {
                "source": "蜂が団子をこしらえる話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに干してある蒲団からはぽかぽかと暖かい陽炎が立っているようであった。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらにおむつが干したりしてあるが、それでもどこかオルガンの音が聞えていた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その剥げた薄い膳には干した川魚を煮た椀と幾片かの酸えた塩漬けの胡瓜を載せていた。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄に枯れた朝鮮芝に赤い蒲団が干してある。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある朝、彼は日当のいい彼の部屋で座布団を干していた。",
              "citation": {
                "source": "過古",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私の立っているのは、半ば朽ちかけた、家の物干し場だ。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所は、港に舫った無数の廻船のように、ただぎっしりと建て詰んだ家の、同じように朽ちかけた物干しばかりである。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その連想から、私は自分の今出ている物干しがなんとなくそうしたゲッセマネのような気がしないでもない。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の物干しの暗い隅でガサガサという音が聞こえる。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして隣りの物干しの隅には煤で黒くなった数匹のセキセイが生き残っているのである。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中おそく物干しへ出ている姿などを私は見られたくなかった。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ舟にのりて行かば、くるほしきなみの亂れもここちよく、ちのみごの夜びえする、あやしきこゑもきかであるべきに、ふるとせひとにかくれて、わがはぐくみしいろぐさのはや涸れぬとぞ、けふきけば薄葉に涙しをるる、よしゑやし、悲しきものはあだがたき、君ならなくに、はやも我が世をのがれいでばや。",
              "citation": {
                "source": "浮名",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
