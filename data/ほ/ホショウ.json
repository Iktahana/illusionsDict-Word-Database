  {
    "uuid": "22018703-7246-503f-8c3b-baeed1583c3f",
    "entry": "堡礁",
    "reading": {
      "primary": "ほしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "barrier reef",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "外海の濃藍色とは全然違つて、堡礁内の水は、乳に溶かした翡翠だ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "堡礁内の淺い緑色の水、眞白い砂と丈高い椰子樹の遠望、汽船目懸けて素速く漕寄せて來る數隻のカヌー、其のカヌーから船に上つて來ては船員の差出す煙草や鰯の罐詰などと自分等の持ち來たつた※や卵などとを交換しようとする島民共、さては、濱に立つて珍しげに船を眺める島人等。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その帆掛｜獨木舟は、今丁度外海から堡礁の裂目にさしかかつた所だつた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭上の葉のそよぎと、ピチヤリ／＼と舐めるやうな渚の水音の外は、時たま堡礁の外の濤の音が微かに響くばかり。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "海も――少くとも堡礁の内側の水だけは――トロリと翡翠色にまどろんでゐるやうだ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "外海の濃藍色とは全然違って、堡礁内の水は、乳に溶かした翡翠だ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "堡礁内の浅い緑色の水、真白い砂と丈高い椰子樹の遠望、汽船目懸けて素速く漕寄せて来る数隻のカヌー、そのカヌーから船に上って来ては船員の差出す煙草や鰯の缶詰などと自分らの持ち来たった鶏や卵などとを交換しようとする島民ども、さては、浜に立って珍しげに船を眺める島人ら。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その帆掛｜独木舟は、今ちょうど外海から堡礁の裂目にさしかかったところだった。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭上の葉のそよぎと、ピチャリピチャリと舐めるような渚の水音の外は、時たま堡礁の外の濤の音が微かに響くばかり。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "海も――少くとも堡礁の内側の水だけは――トロリと翡翠色にまどろんでいるようだ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
