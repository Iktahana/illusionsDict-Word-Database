[
  {
    "uuid": "b489cced-70c8-59ef-92c4-0001d06cdc7a",
    "entry": "本領を発揮",
    "reading": {
      "primary": "ほんりょうをはっき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to display one's real ability",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そろそろ駄犬の本領を発揮してきた。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも、髑髏と、竹如意と、横笛とが、あるいは燃え、あるいは光り、あるいは照らして、各々自家識見の象徴を示せるごとくに、　そういえば――影は尖って一番長い、豆府屋の唐人笠も、この時その本領を発揮した。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼い時から、お伽話と実際の差別がつかなかったり、人前に立ってワイワイもてはやされると、いよいよ有頂天になる性質は、たちまちその本領を発揮して、人に対する奉仕というようなものでなく、彼女自身がその空気の中に溶け込んで、浮れ出してしまうのであった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、電子本に本領を発揮させる欠かせない要素と考えた、ネットワークによる流通の道を付けていこうと心が決まります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが両帝国の間に介在するの悲しさ、沖縄人は充分にその本領を発揮する事が出来ないで、漸く機械として取扱われるようになったのである。",
              "citation": {
                "source": "琉球史の趨勢",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方早く一洵君徃訪、同道して村瀬氏方へ推参、相客二人（支配人Ｆ氏、校長Ｓ氏）、酒は白鹿、寄せ鍋はぽつぽと湯気を立てる、主人夫妻は温情をばらまく、私も今夜はとりわけ野人の本領を発揮して、飲んだ々々食べた々々！",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、彼は一向そんなことに驚かなかったばかりか、そういう弾圧に逢って初めて本領を発揮する、あのいかにも露助らしい目端をはたらかして、忽ちそれを、逆に自分に有利な武器に変えてしまったのである。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら熊城君、すでに僕は危険を悟って、心理学の著述などは、ロッジの『レイモンド』ボルマンの『蘇格蘭人ホーム』の改訂版以後は読まないのだし、また、『妖異評論』の全冊を焼き捨ててしまったほどだからね」　最後に至って、法水は鉄のような唯物主義者の本領を発揮した。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうやって三人で遊び合うようになってからだっても、お竜ちゃんはますますその本領を発揮した。",
              "citation": {
                "source": "幼年時代",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それぞれ、その本領を発揮すればよいのであつて、その一つを失ふも、日本の劇壇に取つては惜むべきことである。",
              "citation": {
                "source": "新劇運動の二つの道",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂言の元なる能楽の「脇狂言」なども、今日では誠に無意味な、見物を低能者扱ひにした、古風と言ふより外に、せむもない物になつたが、以前は語りを主にするものではなく、今の狂言が岐れ出るだけの、滑稽な、寧、能楽の昔の本質「猿楽」の本領を発揮したものであつた筈である。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "露西亜人のピトエフ夫人は、仏蘭西語で芝居をするのだが、発音やアクセントには、幾分怪しげなところがあるに拘はらず、言葉の心理的ニュアンスを捉へる点になると、正に名優の本領を発揮したものである。",
              "citation": {
                "source": "「抽斗にない言葉」",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等が彼自体の本領を発揮し独自の光彩を放つのはその最悪の事態に処した時であり、そのとき自我の発見が奇蹟の如くに行はれる。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "チンピラどもに捩じふせられて一向に本領を発揮できなかった不快さが喉元につまっているが、敵の本営だから今日のところは仕方がない。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の結論に至って、諷刺の本領を発揮し、巧みに視覚的な幻像を与えている。",
              "citation": {
                "source": "安吾巷談",
                "author": "教祖展覧会",
                "note": "青空文庫"
              }
            },
            {
              "text": "族長の物語に違わず、翌日の夜中ごろからこの不吉な小屋はおいおいとその本領を発揮することになった。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "タラノ音頭　――コルシカ島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち、科学的智識を濾過し、これを背景として、ロマンチシズムの本領を発揮したのであります。",
              "citation": {
                "source": "時代・児童・作品",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れ故、毒婦が遺憾なく其の本領を発揮する場合には観客は道義的批判を離れて、全く芸術的快感に酔ひ、毒婦の迫害に遭遇する良民の暗愚遅鈍を嘲笑する。",
              "citation": {
                "source": "虫干",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の侍女が寄って来て、「お仕度出来ましてござります」　と、こう陸奥守へ囁いたのは、館の中の好色陣が、いよいよ本領を発揮して、武将が武将の体面を忘れ、白拍子や遊君と各自の部屋へ、こっそり隠れる頃であった。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、君らは元々大鹿の行方に最も執着をもっているのだから、隠れ家が分ると、記者の本領を発揮して、さっそく乗りこんで、ロマンスの一件など根掘り葉掘り訊問するだろうからね。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ則ち質実、義勇、斃れて已むの真骨頭を以て、尊王攘夷の大本領を発揮したるものといわざるべからず。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と櫛巻の姐御、姐御の本領を発揮して、いきなり、縫い取りの美しいうちかけをぬぎすてるが早いか、パッと地面へ投げすてた。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち立派な作物を出して、大に本領を発揮する時に天下は我々のものとなるんだよ」「いつの事やら」「そう急いたって、いけない。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "素子は今日までこの男を曲者だと思つてはゐたけれども、それはたゞ漠然とした世間の通念がさう思はせるだけで、実際はこれと云つて、曲者の本領を発揮したこともなく、寧ろ、彼女に接する面だけでは、小心翼々、ひたすら不徳漢の名を懼れる一個の立志伝中の人物に過ぎなかつた。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁清の出世によって日本の陶磁も、国土的芸術としておのずからその本領を発揮することが出来たのである。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し鉢のひらいたような聰明で敏捷なガーリンの丸いおでこは、『検察官』のフレスタコフとはちがった役柄が彼の本領を発揮させそうに思えた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今こそ俺はテロリストの本領を発揮できるのだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄金仮面の怪物は、魔法使の本領を発揮して、地面を突破り、彼の住家の地獄へと、姿を消してしまったのであろうか。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは馬上にあるときは比較的に無力で、両脚でぬかるみのなかに突っ立ち、銃を構えているときが本領を発揮するときだった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
