          "literary": [
            {
              "text": "考えようによってはランニングや砲丸投げなどのレコードよりもより多く文化的の意義があるかもしれない。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝生の中では砲丸投げが始まった。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "砲丸投げほど力のいるものはなかろう。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行くと、砲丸投げが出来るので。",
              "citation": {
                "source": "麦藁帽子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、すぐその木蔭で、砲丸投げをやり出した。",
              "citation": {
                "source": "麦藁帽子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行くと、砲丸投げが出來るので。",
              "citation": {
                "source": "麥藁帽子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
