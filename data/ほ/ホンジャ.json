        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それもそうだな、ほんじゃ、おら、今日は、休ませてもらうべかな。",
              "citation": {
                "source": "山茶花",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ほんじゃ、ゆっくり休ませえ。",
              "citation": {
                "source": "山茶花",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ほんじゃ、爺つあまに、おれ、直接に、訊いで見んべかなあ？",
              "citation": {
                "source": "山茶花",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんじゃ、長作せえいいごったら、取り換えでくんつえ。",
              "citation": {
                "source": "山茶花",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんじゃ、水持って来て呑ませろ。",
              "citation": {
                "source": "蜜柑",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんじゃ汝あ、片岡さ寄れよ。",
              "citation": {
                "source": "駈落",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんじゃ、明日の二時の汽車にしんべかな？",
              "citation": {
                "source": "駈落",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんじゃ、二時半までにゃ、停車場さ来んのだぞ。",
              "citation": {
                "source": "駈落",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんじゃ、この浪岡をおまえが曳っ張っていけ。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんじゃ、その浪岡をおれさ寄越せや」　そして、正勝は浪岡の首についている細引を平吾から受け取った。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新平の野郎が、俺さ交通妨害をしやがって……兎に角、ほんじゃ間違えだで、俺が一升買うがら、一緒に茶屋さ行くべ。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいほんじゃないの……私高橋おでんの小説読んだわ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓二　ほんじゃ、見てみにゃなんねえなあ。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房が、「猿ウは山へ逃がいとう」と答えると、与次郎は、「ほんじゃア直きに行って俺ンめっけて来る」と言って、直ぐ山へ駈け登り、方々を探したが、なんぼめっけても手白がいはしんので、仕方なく家に帰り、「まず、おしゅんのおトブラいでもしず」と言って、見ると、そこに寝かして置いたはずのおしゅんの死骸がない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
