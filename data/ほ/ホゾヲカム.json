    "definitions": [
      {
        "index": 1,
        "gloss": "to regret bitterly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
