[
  {
    "uuid": "86abcee0-0645-5d48-8fab-1f51b21cd94a",
    "entry": "法人",
    "reading": {
      "primary": "ほうじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "corporation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この権威の財団法人といったようなものの権威の程度はどのようであろう。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな調法人をどこで歓迎しないところがあろうか。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし一九九二年十月に、米ボイジャー社と日本のソフト制作者グループとのジョイントベンチャーによって、日本法人のボイジャージャパン（正式名称、株式会社ボイジャー）が設立されており、一九九三年三月のリリースをめどに日本語化の作業が進められている。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロジェクトを非営利の法人化し、月に二千ドルを見積もっているという資金の提供者を広く求めていくことで、ハートはプロジェクトの生き残りを図ろうと考えています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アスキーが同社の製品の販売にあたっていた時期を経て、日本法人としてマイクロソフト株式会社が設立されたのが一九八六年。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一九八六年三月、アスキーとマイクロソフトが独占代理店契約を打ち切り、新たにマイクロソフトの日本法人が設立される中で、アスキーの開発本部担当取締役を務めていた古川は、新会社の社長へと一大転身をはかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後も一貫して情報処理部門を歩み常務取締役まで上り詰めてから、広範な人脈を持つ御大はアメリカ生まれのベンチャーの日本法人のトップへと転じた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学技術庁の認可法人である日本科学技術振興財団はこの春、開発と指導実験を進めてきた幼児のためのパソコン教育システムを公表した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "とすればマックでいいんじゃないかとなって、今やアップルコンピュータの日本法人は笑いが止まらない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの農場を小作人の共有にするといふことが許されないなら残つた方法は二つで財団法人にするか組合組織にするかであります。",
              "citation": {
                "source": "農場開放顛末",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御身はよろず、お慎み深く、近侍の者を憫み、領民を愛撫したもう有様、六十七万石の家国を失いたる無法人とも見えずと人々｜不審しく思うこと今に止まず候」と、あった。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に文部省が五十万円の補助金を出して、文部・外務・民間思想文化連合の統一体として財団法人「中央文化連盟」が結成された。",
              "citation": {
                "source": "矛盾の一形態としての諸文化組織",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉敷にあった研究所は大原氏の手を離れて東京へ来て、日本労働科学研究所となり、やがて財団法人になるとこの所長は云っている。",
              "citation": {
                "source": "日本の頭脳調べ",
                "author": "――特に自然科学者に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでこの機関は一応民間のものであり、財団法人なのである。",
              "citation": {
                "source": "思想動員論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の放送事業は財団法人日本放送協会の独占的事業である。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "財団法人として、新設の大学部を併せ六・三・三・四の新学制で出発した。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗教団体法が廃止され、宗教法人令によって宗教団体の設立はやさしくなった。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "財団法人日本ペニシリン学術協議会（一九四六年九月設立）。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "財団法人遺伝研究所（一九四七年四月設立）　栄養食料学会（一九四七年五月設立）　国立栄養研究所（一九四七年五月）は厚生省公衆衛生院の国民栄養部を分離拡張したもので、これに試験所、相談所が附属している。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾家遺法人知否　　　　我が家の遺法、人知るや否や、不爲兒孫買美田　　　　児孫の為めに美田を買はず。",
              "citation": {
                "source": "閑人詩話",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七七年一月にアップルが正式に法人となって間もなく、ラスキンはマニュアルの制作会社ごと同社に移った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『帝王の誕生』の著者たちは、マイクロソフトの日本法人であるマイクロソフト株式会社にアスキーから移った、古川享のコメントをもとに、このエピソードに関して記述している。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＣの日本語化は、世界市場でＰＣ互換のラップトップを成功させた東芝の逆輸入版Ｊ―３１００や、マイクロソフトの日本法人がリーダーシップをとったＡＸと名付けられたプロジェクトによって側面から進められることになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "同年二月十七日、マイクロソフトは日本法人のマイクロソフト株式会社を設立した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイクロソフト日本法人の社長には、古川享が就任することになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本電気にパーソナルコンピューターの種をまいた渡辺和也は、一九九〇（平成二）年六月二十七日付けで同社を退社し、七月二日、ネットワーク用ソフトウエアの雄、ノベルの日本法人の社長に就任した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまざまなメーカーのさまざまなマシンをつなぐネットワーク分野で急成長を遂げたノベルの日本法人の社長にと誘いを受けたとき、渡辺はてのひらからこぼれ落ちたオープンの夢が、小さな炎となって胸によみがえるのを覚えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「無法人」についても、「紋章」についても、同様のことが云える。",
              "citation": {
                "source": "長篇小説私見",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
