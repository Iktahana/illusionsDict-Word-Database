        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "芒の蓬々たるあれば萩の道に溢れんとする、さては芙蓉の白き紅なる、紫苑、女郎花、藤袴、釣鐘花、虎の尾、鶏頭、鳳仙花、水引の花さま／″＼に咲き乱れて、径その間に通じ、道傍に何々塚の立つなどあり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事を考えたのが動機となって、ふと大根が作ってみたくなったので、花壇の鳳仙花を引っこぬいてしまってそのあとへ大根の種を蒔いてみた。",
              "citation": {
                "source": "鸚鵡のイズム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳳仙花の実が一定時間の後に独りではじける。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳳仙花　前栽の透籬の外などに植ゑたるは、まことによし。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "インパチェンスは鳳仙花の類の一般的な名前らしいが、ともかくも「かんしゃく」である。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その門口に並んだ鳳仙花が風もないのに乱れ落ちて、はかない紅白の花びらがあとからあとから土の中に消え込んでゆく。",
              "citation": {
                "source": "塵",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳳仙花はもう実となつたし、曲りくねつた野生の小菊はまだ石蕾である。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな宿にも盆栽の数鉢はある、鳳仙花、唐辛、蘭、万年草など、おしやべりの、きかぬ気の小娘の丹青だ、日本人はうれしいなと思ふ。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "恥かしさと飛びかゝり度い気持と捻じ合うあの切ない胸の中のときめきは、紙に染めたらおまえの好きな鳳仙花の花の汁の色にもうつりそうである。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とほせんぼ赤い赤い鳳仙花。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園からだらだらの阪を西谷の方へ、日かげを選み選み小急ぎになると、桑畑の中へ折れたところで、しおらしい赤い鳳仙花が目についた。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳳仙花や百日草が咲き、村の子が遊び、鶏がけけっこっこっこっである。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そりゃあね、庭の鳳仙花の中か、裏の玉蜀黍畠にでも連れてきゃよかったんだよ」と私は三高生に笑って見せたが、「それでも下剤薬を飲ましたので通じましたよ」とその甥がまた笑い出した。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私この花がすきですから」と言って、おまけに添えてくれたのが、珍しくもない鳳仙花の種であった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、かの売り子がおまけにくれた鳳仙花だけは、実にみごとに生長して、そうして鳳仙花とは思われないほどに大きく美しく花を着けた。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳳仙花の実が一定時間の後にひとりではじける。",
              "citation": {
                "source": "からすうりの花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま花の眼についたは、罌粟、菖蒲、孔雀草、百日草、鳳仙花、其他、梅から柿梨｜茱萸のたぐひまで植ゑ込んである。",
              "citation": {
                "source": "梅雨紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五　鳳仙花の、草に雑って二並ばかり紅白の咲きこぼるる土塀際を斜に切って、小さな築山の裾を繞ると池がある。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳳仙花の咲いた処でぬっと出て来たのは玄関番、洗晒した筒袖の浴衣に、白地棒縞の袴を穿いた、見知越の書生で、（やあ、貴女でありますか、勝手に居た女中が女の明巣覗が入ったっていうですからな。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸端にぼつさりと茂りながら日中の暑さにぐつたりと葉が萎れて居る鳳仙花の、やつと縋つて居る花が手拭の端に觸れてぼろつと落ちた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉が更にぐつたりと萎れた鳳仙花の枝がすかりと裂て先が地についた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "卯平は暫くして鳳仙花の折れたのを見つけて井戸端へ立つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "垂れた鳳仙花の枝は竹の杖に縛りつけようとして手を觸れたらぽろりと莖から離れて畢つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹の棒はぎつと突き透した儘いつまでも空しく鳳仙花の傍に立つて居た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "狹い庭には糠交りの麥が筵へ二枚干してあつて其先には鳳仙花がもさ／＼と簇つて居る。",
              "citation": {
                "source": "鉛筆日抄",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "余はすゞろに興を催しながら鳳仙花の傍に立つて此の意外な庖丁を持つて木か竹でも削るやうにして皮をむいた。",
              "citation": {
                "source": "鉛筆日抄",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳳仙花の種子を採集するには、蟋蟀を捉えるのと同じ程度の細心さがなくてはならない。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "白鳳仙花のはなさける夏の日なかにただひとり。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
