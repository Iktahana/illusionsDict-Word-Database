[
  {
    "uuid": "46215e00-3648-52ff-81ce-98cfc1a67967",
    "entry": "奉書",
    "reading": {
      "primary": "ほうしょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
