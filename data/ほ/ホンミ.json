    "definitions": [
      {
        "index": 1,
        "gloss": "real sword (as opposed to a wooden practice sword)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし四ツ身から本身に変る時には、拵えてやっても、拵えてやってもなお子供は要求する。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本身の脇指をぶっ込んで出かけるんだから、そう思ってくれ。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "してみると、槍突きは本身の槍で無しに、竹槍を持ち出して来るんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "槍突き",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者はこの神を本尊と斎く祠に限り、後者は羅摩またはその本身｜韋紐を本尊として脇立とす（第六図は余が写実し置いた脇立像なり）。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂言の方ではえてして、あの類の勇み肌が勝つことに筋が仕組まれておりまするが、啖呵では勝ちましても、本身の刄先が飛び出したとなりますると、筋書通りに参りますまいかと思いまする」「いや、そうでない。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "）おまえさんの持って来た刀は本身かえ。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんで本身なんぞを持って来るものですか。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが若旦那に渡したのは確かに舞台で使う金貝張りに相違ないのですが、それがいつの間にか本身に変っていたので、こんな騒ぎが出来してしまったのです。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "与兵衛　いつの間にか本身に変っていた……。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七　この本身はおめえが持って来たのかえ。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三津平　わたしも皆さんの顔をこしらえに来て、舞台の上のことも何やかやとお世話をしているので、衣裳や持物はみな一と通り調べましたが、五助さんの持って来た大小は金貝張りで、決して本身ではなかったのでございます。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七　それがいつの間にか本身に変っていたのか。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときに和泉屋の若旦那が六段目の勘平で切腹すると、刀がいつの間にか本身に変っていたので、ほんとうに腹を切ってしまいました。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）どうか親分さんのお力で、一体どうして角太郎の大小が本身の品と取り変ったのか、それをよく詮議して頂きたいと存じまして、こうしてお願いに出たのでございます。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七　舞台で使う銀紙の刀がどうして本身に変ったのか、わたくしもその晩すぐに楽屋へ踏み込んで調べてみたが、さっぱり見当が付かないので困ってしまいました。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お冬　舞台で使う勘平の刀がいつの間にか本身に取りかわっていて……。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘平の刀は舞台で用いる金貝張りと思いのほか、鞘には本身の刀がはいっていたので、角太郎の切腹は芝居ではなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "勘平の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうして本身の刀と掏り替っていたか、内々それを調べて貰いたいと存じまして……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "勘平の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この度｜諏訪の戦ひに、松本身内の吉江様、大砲固めにおはします。",
              "citation": {
                "source": "庭",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "此物忌みの衣と、村の男となる前――恐らくは、第一次の元服なる袴着の際――に行うた母の手わざの印象とが相俟つて、衣服と皮膚との間に、蛇子の本身・化身の関係を絡めて居るのではないか。",
              "citation": {
                "source": "小栗外伝（餓鬼阿弥蘇生譚の二）",
                "author": "魂と姿との関係",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて餓鬼阿弥の場合、第一章では、肉身を欲する魂魄を以て説いたが、其上にたましひの放散した後、本身の魂への魂ふりに、頗長い期間を要した蘇生者に対する経験が加はり、又謂はうなら、かげの身が本身と合体する径路も、根柢に含まれて居ると見られよう。",
              "citation": {
                "source": "小栗外伝（餓鬼阿弥蘇生譚の二）",
                "author": "魂と姿との関係",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぬいて御覧あそばせ」　僕もラキ子さんもこわごわ手にするとその重いこと、「それは本身の鉄です。",
              "citation": {
                "source": "花模様女剣戟",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その木の身の奴は軽くってあつかいよいのですが、やはり本身のものはずっしりと、腕にこたえて調子がようございます。",
              "citation": {
                "source": "花模様女剣戟",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが武兵衛の本身でござる。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「加賀の白山十二峰の一つ瑠璃ヶ｜岳の谷深く一本立てる大楠の木こそ彼の本身でござります」　こう云って冠者は打ち案じ、遠い昔の出来事を思い出すような表情をしたが、「おおよそ今より十年前。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妖精の踊り　人丸左陣、天丸左陣――二人の武士の立ち去った後は、白山山中瑠璃ヶ岳の森々と深い谷底は再び無人の境となり、鬼王丸の本身たる数千歳を経た楠の木は谷の諸木の王のようにいかにも厳かに立っている。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「諸※の化身を本身に返し、総ての変化を退治致すそうで」「ふうん」　と云った鬼王丸、これにはどうやら困ったらしい。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
