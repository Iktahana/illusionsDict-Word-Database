[
  {
    "uuid": "c79fb490-de6f-544b-a25d-c61ed150686a",
    "entry": "時鳥",
    "reading": {
      "primary": "ホトトギス",
      "alternatives": [
        "ほととぎす"
      ],
      "is_heteronym": false
    },
    "grammar": {
