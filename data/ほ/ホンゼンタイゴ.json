        "examples": {
          "standard": [
            {
              "text": "長年の疑問が、師の一言で翻然大悟した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "迷いに満ちていた心が、突然の啓示を受けて翻然大悟した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、その哲学書を読み終えた時、世界の見方が変わるような翻然大悟を経験した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "何とかいう芝居で鋳掛屋の松という男が、両国橋の上から河上を流れる絃歌の声を聞いて翻然大悟しその場から盗賊に転業したという話があるくらいだから、昔から似よった考えはあったに相違ない。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」五　のろまで愚図の悟浄のことゆえ、翻然大悟とか、大活現前とかいった鮮やかな芸当を見せることはできなかったが、徐々に、目に見えぬ変化が渠の上に働いてきたようである。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
