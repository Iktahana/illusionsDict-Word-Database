    "definitions": [
      {
        "index": 1,
        "gloss": "meadow bunting (species of passerine, Emberiza cioides)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "頬白は散髮屋の鋏のやうにせはしく、四十雀はけたたましいアイアムビツク。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』なんて遠くから呼びますのに、それが頬白で自分よりもひはのことをよく思ってゐると考へて、憤ってぷいっと横へ外れたりするのでした。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さうするとどうしてあんなにめじろも頬白も、きちんと両方おんなじ形で、おんなじ場所に白いかたが残ってゐるだらうね。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅黄の襟に頬白う、………また雨催の五位鷺が啼くのに、内へも入らず、お孝は彳む。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頬白、山雀、雲雀などが、ばらばらになって唄っているから、綺麗な着物を着た間屋の女だの、金満家の隠居だの、瓢を腰へ提げたり、花の枝をかついだりして千鳥足で通るのがある。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "余所のおじさんの鳥さしが来て、私ン処の橋の詰で、榎の下で立留まって、六本めの枝のさきに可愛い頬白が居たのを、棹でもってねらったから、あらあらッてそういったら、叱ッ、黙って、黙って。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐い顔をして私を睨めたから、あとじさりをして、そッと見ていると、呼吸もしないで、じっとして、石のように黙ってしまって、こう据身になって、中空を貫くように、じりっと棹をのばして、覗ってるのに、頬白は何にも知らないで、チ、チ、チッチッてッて、おもしろそうに、何かいってしゃべっていました。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　頬白は智慧のある鳥さしにとられたけれど、囀ってましたもの。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは皆お前がそう思うからで、あの、雀だって餌を与って、拾ってるのを見て、嬉しそうだと思えば嬉しそうだし、頬白がおじさんにさされた時悲しい声と思って見れば、ひいひいいって鳴いたように聞えたじゃないか。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大方今の紅雀のその姉さんだの、頬白のその兄さんだのであったろうと思われる。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……お嬢さん、奥方たち、婦人の風采によつては、鶯、かなりや、……せめて頬白、※子鳥ともあるべき処を、よこすものが、木兎か。",
              "citation": {
                "source": "玉川の草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "袋から、血だらけな頬白を、（受取ってくれたまえ。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、眼張魚は、蟇だと諺に言うから、血の頬白は、※になろうよ。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、何処の巣にいて覚えたろう、鵯、駒鳥、あの辺にはよくいる頬白、何でも囀る……ほうほけきょ、ほけきょ、ほけきょ、明かに鶯の声を鳴いた。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "山坂を踏越えて、少々｜平な盆地になった、その温泉場へ入りますと、火沙汰はまた格別、……酷いもので、村はずれには、落葉、枯葉、焼灰に交って、※子鳥、頬白、山雀、鶸、小雀などと言う、紅だ、青だ、黄色だわ、紫の毛も交って、あの綺麗な小鳥どもが、路傍にはらはらと落ちている。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……小雀頬白も手にとまる、仏づくった、祖母でなくては拾われぬ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頬白、山雀、雲雀などが、ばら／＼になつて唄つて居るから、綺麗な着物を着た問屋の女だの、金満家の隠居だの、瓢を腰へ提げたり、花の枝をかついだりして千鳥足で通るのがある、それは春のことで。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四頬白は智恵のある鳥さしにとられたけれど、囀つてましたもの。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其は皆お前がさう思ふからで、あの、雀だつて餌を与つて、拾つてるのを見て、嬉しさうだと思へば嬉しさうだし、頬白がおぢさんにさゝれた時悲しい声だと思つて見れば、ひい／＼いつて鳴いたやうに聞こえたぢやないか。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "細らなる若樹のはやし、頬白の鳴く音もきかず。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "小野の鈴の音、夕づつのほのめき、ゆめの頬白のみやびやすらに、風ぬるみ、髪にはさくら、くさに地の歔欷ふけつつ、仄に灯は君が館に、妻琴の調べ澄む夜ぞ、花やかに朧ろに耳はそのかみの日をしも薫ゆれ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "頬白のふりまねびをる。",
              "citation": {
                "source": "風隠集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "頬白鳥　ものぐさ百姓がある朝、めづらしく早起きして、畑で種蒔きをしてゐました。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを頬白鳥がみつけて「おぢさん、今日は」といひました。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "頬白が淋し相に桑の枝を飛びめぐる。",
              "citation": {
                "source": "寫生斷片",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "桑畑へ鎌もて行く、草取りと野に行けば、桑の木の枝移り鳴く、頬白に吠えながら先へ／＼駈けめぐると、人ならば草臥れむ。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな身體でありながら少し鋭い嘴を持つたばかりに、果敢ない雀や頬白の前にのみ威力を逞しくする鵙が小さな勝利者の聲を放つてきい／＼と際どく何處かの木の天邊で鳴いて居た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした研究の結果いかんによっては、ほととぎすの声を「テッペンカケタカ」と聞いたり、ほおじろのさえずりを「一筆啓上仕候」と聞いたりすることが、うっかりは非科学的だと言って笑われないことになるかもしれない。",
              "citation": {
                "source": "疑問と空想",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏は唐の金鶏鳥、四国土佐のおながどり、あるはまためじろ、ほおじろ、うぐいすならば鳴き音が千両、つるに、ひばりに、恋慕鳥、別して大奥のお女中がたは、この恋慕鳥が大の好物でござりやす。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間というものは、こういう茫漠たる大自然の中へとりこめられてしまうと、むやみに心細くなるものだとみえ、雪ほおじろが人も恐れずに沼のほとりでピョンピョンはねているのを見ても O my friend と呼びかけたいような気がしたりする。",
              "citation": {
                "source": "南部の鼻曲り",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
