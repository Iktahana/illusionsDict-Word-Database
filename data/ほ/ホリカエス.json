    "definitions": [
      {
        "index": 1,
        "gloss": "to dig up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「梨畑を掘り返すにはまだ早い。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸の側の濕つた地に轉がつてゐた石を掘り返すと、大きな蚯蚓が出て來たので、私は鷄共をそこに呼び集めながら、棒片を持つて猶もやたらにそこらを掘り返した。",
              "citation": {
                "source": "白い雌鷄の行方",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こうやっておいて、又じきに掘り返すんだからなあ。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにその辺の土を掘り返すと、数千両の銀が発見されました。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "稽神録",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかで土を掘り返す鋤の音がした。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "知れば知るほど自分の下劣さを掘り返すにすぎなかった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「百姓どもははあ、一寸でもよけい畑作ろうと思ってからに、桐の根まで掘り返すごんだうわ、それでいて芽を一本かいてくれない。",
              "citation": {
                "source": "祖母のために",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲る角々の木を伐り倒し、崖をけずって新しい土を掘り返すのが精一ぱいであった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍬を取って掘り返すべき、一隅の地面もない。",
              "citation": {
                "source": "悪夢",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "……大体この、一度埋めたのをまた掘り返すというのは、法にないことだそうですが、初め埋めたのが悪いというので、却って法に戻すんだと云いましてな……。",
              "citation": {
                "source": "古井戸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、三日もすれば、豚どもは食物を探して、隅から隅まで掘り返すし、それに、豚の糞が肥料になるので、あとはもう種を蒔けばいゝばかりです。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "海景銀の戦車や銅の戦車、鋼の船首や銀の船首、泡を打ち、茨の根株を掘り返す。",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦野今市君は、庭の小さな花壇を野菜畑に掘り返すことを思ひたち、長女の二年生に二十日大根の種を袋のまゝ持たせ、「まだ袋を開けちやいかんよ。",
              "citation": {
                "source": "美談附近",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅に水が滲み出てゐると、彼はステツキの先で土を掘り返す。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェハンじいさんは、牛が畑のあぜを掘り返すように国土を踏みにじった戦争のことを覚えていました。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A Dog of Flanders",
                "note": "青空文庫"
              }
            },
            {
              "text": "新墓を掘り返す權力などは、寺も、遺族も、町方も持つては居ません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "濡れた千兩箱",
                "note": "青空文庫"
              }
            },
            {
              "text": "新墓を掘り返す権力などは、寺も、遺族も、町方も持ってはいません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "濡れた千両箱",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒッソリとしたうちに、サクッサクッと土を掘り返す音、微かに泥の崩れる音、鍬の調子に連れて出る息の音等が、動くに従って彼の体の囲りに小さく響くばかりである。",
              "citation": {
                "source": "風に乗って来るコロポックル",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲惨の荒々しい息吹きを、かせぎ出すパンや掘り返す土地の匂いを、自分の顔に感じてるものか。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで多言語を話す労務者にあったことは無かったが、この男は鮮やかに忌まわしい形容詞を使って、ぐだぐだ言いながら、帝国を掘り返す。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘の奈美は老人が掘り返す側から、雑草を引抜いて捨てている、強くなった残暑の陽ざしに、二人ともびっしょり汗に浸っていた。",
              "citation": {
                "source": "内蔵允留守",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして新しい住居にはいってきた日、きわめて愉快そうで、版画や植物標本をかける釘を自分で打ち、残りの時間は庭を掘り返すことに使い、晩になって、プリュタルク婆さんが陰気な様子をして考え込んでるのを見ると、その肩をたたいてほほえみながら言った、「おい、藍ができるよ。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその厭悪すべき蠢動のうちに、啻に現在の社会制度を掘り返すのみでなく、なお哲学をも、科学をも、法律をも、人類の思想をも、文明をも、革命をも、進歩をも、すべてを掘り返す。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "新墓のこととて、掘り返すのに造作はありませんが、その下に隠れているものを想像すると、数日来多少｜場数を踏み、貪慾に気の狂った彼とても、云い難き恐れの為に、戦慄を感じないではいられませんでした。",
              "citation": {
                "source": "パノラマ島綺譚",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の墓を掘り返すことは、土が固っていたので、少々骨が折れましたが、汗まみれになって、せっせと働く内には、どうやら骨らしいものに掘り当てることが出来ました。",
              "citation": {
                "source": "パノラマ島綺譚",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ははは」「ともかく、この通りを、越前守様に、御復命はしておくが、御得心なき時は、掘り返すやも知れませんぞ」「おおいつでも。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨でしめって土がやわらかくなると僕達は自由に土をほりかえす事が出来るので、大急ぎで、新らしい所へ引っ越して行くのだ。",
              "citation": {
                "source": "みみず先生の歌",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほってるそばから　わすれるから、　あとで　ほりかえすと　じぶんのでない　きのみが　でてきたりして。",
              "citation": {
                "source": "つまさきチミーのはなし",
                "author": "THE TALE OF TIMMY TIPTOES",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャイコフスキイのトリオ竹内浩三アアちゃん白い雪のふる木の葉のちる寒い風のふくアアちゃんぼくはたたずみうづくまり寒い風のふく湯気のちぎれとぶアアちゃんぼくは地べたに爪あとをつけケシの種子をほりかえすアアちゃん",
              "citation": {
                "source": "チャイコフスキイのトリオ",
                "author": "竹内浩三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
