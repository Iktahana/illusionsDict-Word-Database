        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ほの暗い葡萄酒と、千の薔薇から、時はきらめきながら夜の夢のなかへと流れてゆく。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな、人通りのすくないほの暗い橋のうえで、花を売ろうなどというのは、よくないことなのに、――なぜ？",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほの暗い勝手口に芹川さんの兄さんが、にこにこ笑いながら立っていました。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "店の主人にまで、いやしい遠慮をして、片隅のほの暗い場所に坐って酒を飲んでいたのである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "テントのすきまから、ほの暗い内部を覗いたのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕暮の空ほの暗い時に、柱に靠れて居た僕が突然、眼を張り呼吸を凝して天の一方を睨む様を見た者は母でなくとも逃げ出すでしょう。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてがほの暗いそうして底光りのする雰囲気の中から浮き出した宝玉のようなものであった。",
              "citation": {
                "source": "青衣童女像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "別荘の袖垣から、斜に坂の方を透かして見ると、連の浴衣は、その、ほの暗い小店に艶なり。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "永遠に、永遠に、自分を忘れて、思惟のほの暗い海に浮ぶ、一つの侘しい幻象を眺めて居たいのです。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄關のほの暗い軒燈の下でうちの人たちがうようよ出迎へてゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一人、文藝春秋社のほの暗い応接室で、Ｍ・Ｓさん。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "京子の頭上の電燈は、先刻加奈子が部屋を出る時かぶせて行った暗紫色の覆いを透して、ほの暗い光をにじみ出している。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "白いランニングシャツを着た男が、グラウンドのほの暗い電燈の光を浴びて、自転車の稽古をしている。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐伯が帰って来る頃には、改札口のほの暗い電燈をぽつんと一つ残して、あたりはすっかり明りを消してしまっている。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口は思い切り大きい両開きの木の扉が左右に裏板を見せて、ほの暗い内部を透かした向うにかっきりした長方形の雨空と緑との画面がうち明っていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだほの暗い、藍鼠の背皮、その背皮は懸崖だ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るとこの始末で、黒ん坊はほの暗い夕闇のうちに火のような目をひからせながら、無理無体に娘を引っかかえて行こうとする。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "白いランニングシャツを着た男が、グランドのほの暗い電灯の光を浴びて、自転車の稽古をしている。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "グランドではランニングシャツを着た男がほの暗い電燈の光を浴びて、影絵のように走っていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "崩れ掛ったお寺の壁に凭れてほの暗い電灯の光に浮かぬ顔を照らして客待ちしている車夫がいたり、酔っぱらいが反吐を吐きながら電柱により掛っていたりする京極裏の小路を突き当って、「正宗ホール」へはいった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほの暗い谷（３）を歩みながら、私は世の人々の同情を――むしろ憐れみをと言いたいのであるが――切望している。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の小児が、母の腕から滑って、その高く聳えた建物の上方の窓から深いほの暗い運河へと落ちたのだ。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてかつて聖の聖なることは、ドドーナ７の周囲のうち震えるほの暗い樹の葉によって開かれたのだ。",
              "citation": {
                "source": "沈黙",
                "author": "――神話",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、局は、もの優しく微笑んで、また先の如く手を取つて、今度は横斜違に、ほの暗い板敷を少時渡ると、※ともみぢの緋の映る、脇廊下の端へ出た。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほの暗い長屋門をくぐって、見知らぬ男がふたりいそいそとはいってくる。",
              "citation": {
                "source": "告げ人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまでもよそよそしくしていらっしゃるのが苦しくてならない」　まだ空はほの暗いのであるが、積もった雪の光で常よりも源氏の顔は若々しく美しく見えた。",
              "citation": {
                "source": "源氏物語",
                "author": "末摘花",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾里あるいたか、もとより判らないが、行く行くうちに日は暮れかかって、三人はほの暗い野路をたどってゆくと、うしろの方から俄かにおびただしい人馬の音がきこえた。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "『村に出た時はもう日が暮れて夕闇ほのぐらいころであった。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "八寸ばかりのほのぐらい、が活けるが如き木彫である。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほのぐらい電燈の下の青扇の顔は、おやと思ったほど老けて見えた。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
