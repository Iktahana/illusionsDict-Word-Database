    "definitions": [
      {
        "index": 1,
        "gloss": "reprinting (of a book)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
