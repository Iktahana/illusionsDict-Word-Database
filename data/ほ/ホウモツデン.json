        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "芝生や、緩るきなだり、宝物殿、白きは隠る夏の花のえご、香の一本。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "（五月十八日）＊　この広隆寺の塑像は、広隆寺に宝物殿ができてからはそこへ帰っている。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "百済観音もまた近年は法隆寺へ帰って、宝物殿の王様になっている。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　法隆寺の宝物は今は新築の宝物殿に秩序立って陳列されている。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして住職が「お火を、お茶を」としきりに話しこむ腰を折って、ともかく先に宝物殿の御案内をと、お願いする。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
