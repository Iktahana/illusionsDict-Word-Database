    "definitions": [
      {
        "index": 1,
        "gloss": "regular course (of study)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "見よそこには無惨にも日本科学の粋を集めた篠山博士の飛行船月宮号は、微塵となって散らばっている。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "予備門は五年で、其中に予科が三年本科が二年となって居た。",
              "citation": {
                "source": "落第",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局総体の年数から云えば前と聊か変りはないが、予備門｜丈けでいうと、一年年数が殖えたことになり、その予備門五年をも亦二つに分ち、予科三年、本科二年という順序でした。",
              "citation": {
                "source": "私の経過した学生時代",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから中学卒業生は、英語専修科というに一年入ると、直ぐ予備門本科に入学することが出来たのである。",
              "citation": {
                "source": "私の経過した学生時代",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼休みの時間に、僕は教室にひとり残って、小山内薫の「芝居入門」を読んでいたら、本科の鬚もじゃの学生が、のっそり教室へはいって来て、「芹川は居らんか！",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜並木の下で、本科の学生が五、六人、立ったりしゃがんだり、けれども一様に真面目な顔をして、僕を待っていた。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」傍から、別の本科生も言葉を添えて、「中学時代に、あんなに鳴らしていたのにさ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本科一年の時から、キャプテンになったらしい。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けさ、大学の正門前でバスから降りた、とたんに、こないだの蹴球部の本科生と逢った。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの蹴球部の本科生と言い、けさの教室の、あさましい馬鹿騒ぎと言い、となりのクラスの学生たちと言い、実に見事なものだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは禾本科に屬する。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしか禾本科と教はつた。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或日或処でふと窓の外を窺ふと、秋の暮に近い弱い日が羽目板の裾に当り、禾本科の草の蔭をシルヱツトのやうに写してゐた。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学技術庁の認可法人である日本科学技術振興財団はこの春、開発と指導実験を進めてきた幼児のためのパソコン教育システムを公表した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君どうかしているようじゃないか」「僕は本科に這入ることは廃めた」「どうして」「実は君には逢わずに国へ立ってしまおうと思ったのだ。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は本科生でぼくは選科生だからだろう」と説明した。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒川俊子嬢は広島県豊田郡本郷町の出身で、尾道高等女学校を卒業して、東京共立女子専門学校本科二年在学中、昭和十三年十月二十五日倉敷病院で腹膜のため亡くなつたのである。",
              "citation": {
                "source": "追悼記",
                "author": "原杞憂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学の本科生となる。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央は本科で地方は予科だ。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、僕は語学校を出ればすぐ大学の選科にはいれ、その選科からはさらに普通学の試験を受けて本科に移れることをよく承知していたのだった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも一カ月ばかりしてから、仏人教師のジャクレエの心配で、卒業の時には本科卒業として出すという約束で全科目選集の選科生として、二年へ進級したが、その二年ももとより大したことではなかった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年になると、本科生は書庫の中に入って書物を検索することができたが、選科生には無論そんなことは許されなかった。",
              "citation": {
                "source": "明治二十四、五年頃の東京文科大学選科",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十年ごろ、美術学校や早大慶大が女子本科生入学許可の方針をきめたが、それは却下された。",
              "citation": {
                "source": "女性の歴史の七十四年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ｂ）丸山学・小泉八雲新考（講談社学術文庫一二二五、一九九六）七一頁は「本科三年、予科二年で、生徒は三〇〇人、教師は二八人」としている。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "その百一　保は東京に著いた翌日、十一月四日に慶応義塾に往って、本科第三等に編入せられた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "同行者の山田は、保と同じく本科に、中西は別科に入った。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "右百三十石被下置、表御医師本科被召出候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "数え十五歳の時に、私は郷里の岩国学校（それは高等中学校の予備門となっていたもの）を卒業して、山口高等中学校の予科（高等中学校は当時本科三年、予科二年であった）に入学した。",
              "citation": {
                "source": "御萩と七種粥",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本音楽学院本科声楽部卒業。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "国男さん、いよいよ美術学校建築科本科に入ったよし何よりよろこばしい。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
