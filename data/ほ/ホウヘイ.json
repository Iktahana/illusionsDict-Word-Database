[
  {
    "uuid": "43ef936b-3429-51c0-b85f-2e3bea174c61",
    "entry": "砲兵",
    "reading": {
      "primary": "ほうへい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
