    },
    "definitions": [
      {
        "index": 1,
        "gloss": "praise and censure",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
