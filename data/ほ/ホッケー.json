        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ゼネラルインスツルメンツ社がこの年の春からアメリカで売り出していた、ビデオゲームＬＳＩには、テニス、ホッケー、スカッシュ、ライフル射撃、クレイ射撃の六種類のゲームが組み込まれていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "九柱戯　ホッケーまたはクロッケットに類する運動競技の一種。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "楡の木のかげの公園で、町の若者たちが、学生は休暇で一人も居ない晴々しさで、ホッケーをして遊んでいるのを見物した。",
              "citation": {
                "source": "中條精一郎の「家信抄」まえがきおよび註",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "市の西南のはじのヴェルサイユ門からパリで一番長い街すじであるヴォージラールがはじまってモンパルナスやラスパイユをつっきり、ホッケーの打棒のようにカーヴした先が、サン・ミシェル通りでソルボンヌ大学につきあたる。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一七五センチの身長で、大学ではアイスホッケーをやってたのだけど、いまはもう完全に会社の人で、休みの日にジャンパーなんか着て町を歩いていると、いつもは会社の奥深くでデスクに張り付いてる人が、一日だけ現場要員になってるみたいで、恰好悪いの。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
