        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "崖の崩れた生ま生ましい痕が現はになり渓流の中にも危岩が聳え立つて奔流を苛立たせてゐる処もある。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖の崩れた生ま生ましい痕が現わになり渓流の中にも危岩が聳え立って奔流を苛立たせている処もある。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は残虐な血を見て、喜びがスペインの奔流のような歓呼の中で亢奮していました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "奔流、ごろつきのような波の音が僕に英国少女メリーの靴の踵と、乳房に鬘をかむったような女主人を思い出させた。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "行くこと数里、深山幽谷深かく分け入ると、谿川の流れ巌に激しく、奔流矢を射るごとき淵に出た。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "木川子の腰に細引を結び付けて、将軍が巌角に足を踏ん張り、大冒険を企てて、早速奔流落下の状を写し取った。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "片品の水せばまりて峡をなしている処、奔流｜碧潭、両岸の絶壁いずれも凡ならず。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "塲内の光景は實に慘憺たるもので、濁浪怒濤は一方の岩壁を突破つて、奔流の如く其處から浸入したものと見へ、其直ぐ側の、兼て發動藥液の貯藏せられて居つた小倉庫の鐵の扉は微塵に碎かれて、十二の樽は何處へ押流されたものか、影も形も無かつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "速力計の針が六十五｜哩と七十哩の間をちらちらすると、車全体が唸る生きものになって、広いアスファルトの道は面前に逆立ち、今まで眼にとまっていた榕樹の中の草葺きの家も、椰子林の中の足高の小屋も、樹を切り倒している馬来人の一群も、総て緑の奔流に取り込められ、その飛沫のように風が皮膚に痛い。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "波、波、波、波、波、　波、波、波、波、波、波、波、波、波、波、波、　波、波、波、波、波、波、波、波、波、波、「爽快爽快」「富士ヶ瀬です」　すばらしい飛沫、飛沫、飛沫、奔流しつつ、飛躍しつつ、擾乱しつつだ。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅と緑の光弾、円蓋、火箭、ああ、その銀光の投網、傘下し、爆裂し、奔流し、分枝し、交錯し、粉乱し、重畳し、傘下し、傘下し、傘下し、八方に爛々として一瞬にしてまた闇々たる、清秀とも、鮮麗とも、絢爛とも、崇美とも、驕奢とも、譬うるに言葉も絶えた。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "奔流怒りて岩を噛む利根の上流を過ぐれば、靉靆たる雲天にあり、峭峻たる山を指呼の間に相顧すべし。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "貨物自動車や自転車の間に挟まれて、雑踏に押し揉まれながらよちよちと重い荷車を曳いていく自分を、吾助爺は奔流の中に渦巻かれながら浮き沈みして流れていく木切れか何かのように感ずるのだった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪解けで増水した奔流が巨大な滝壺へと流れ込み、そこから飛沫が燃えさかる火事の煙のごとく噴き上がっている。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐ろしい考えがこのとき急に念頭に浮び、血は奔流のように心臓へ集まった。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "満潮時には潮流は猛烈なる速度をもってロフォーデンとモスケーとのあいだを陸に向って奔流す。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "二頭の乳牛を両腕の下に引据え、奔流を蹴破って目的地に進んだ。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄橋の下は意外に深く、ほとんど胸につく深さで、奔流しぶきを飛ばし、少しの間流れに遡って進めば、牛はあわて狂うて先に出ようとする。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二頭の乳牛を兩腕の下に引据ゑ、奔流を蹴破つて目的地に進んだ。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐵橋の下は意外に深く、殆ど胸につく深さで、奔流しぶきを飛ばし、少の間流に溯つて進めば、牛はあはて狂ふて先に出やうとする、自分は胸きりの水中容易に進めないから、しぶきを全身に浴びつゝ水に咽せて顏を正面に向けて進むことは出來ない。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして三友の彼を正解せざるに会して、この懐疑は奔流の如く心の表に現われて、彼の口より大哀哭を発せしめたのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀑としては勾配緩に、急湍としては勾配急なる奔流也。",
              "citation": {
                "source": "上州沼田より日光へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒雲を劈いて天の一角から一角に流れて行く電光の姿はまた私に本能の奔流の力強さと鋭さを考えさせる。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一里あまりの急坂を下りて来た我等は其処で釣橋を渡って大野川を越え、直ぐ左手に梓川の思いの外の大きな奔流が岩を越え岸を噛んでいるのに相対したのである。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて激しい奔流となっているのであろう、飛沫をあげて流れている雪の様な白さである。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "奔流しつつ、飛躍しつつ、擾乱しつつだ。",
              "citation": {
                "source": "日本ライン",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "叨りに東洋の思想に執着するも愚なり、叨りに西洋思想に心酔するも癡なり、奔流｜急湍に舟を行るは難し、然れども舟師は能く富士川を下りて、船客の心を安うす、富士川を下るは難し、然れどもその尤も難きは、東西の二大潮が狂湧猛瀉して相｜撞突するの際にあり。",
              "citation": {
                "source": "国民と思想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの奔流に流され、便所の脇で水中に没しました。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この僧の風采は、短躯矮小みるかげもないものであり、身には襤褸をまとい腰には縄の帯をしめ、醜穢をきわめていたものの、手に十字架を握り驢馬にまたがり、一度口をひらくや熱弁奔流の如くにほとばしり聞く者をして涙を流させ切歯扼腕させた。",
              "citation": {
                "source": "ローマ法王と外交",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
