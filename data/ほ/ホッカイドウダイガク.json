        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もう一つ、これは未発表のものであるが、北海道大学理学部の米田勝彦氏が現に研究を続けている「粉の波」の現象がある。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道大学の伊藤直君の研究にかかる低度真空中の放電による放射形縞についても同様の事が言われる。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでもう私は引退ればいゝのでしたが、その後をいゝ結果のでるやうに組織運営されそこを共同的精神が支配出来るやうにといふ願ひから私はこの農場の組織と施設とを北海道大学農業経済の教室で作製して貰つたのであります。",
              "citation": {
                "source": "農場開放顛末",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『Ｉ／Ｏ』と名付けた新雑誌の編集長には、北海道大学出身で編集の経験のある星正明があたることになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道大学の学生がざっと訳したという原稿を引き継ぎ、ＣＰ／Ｍを動かしながら内容を確認して、下訳を意味の通る文章に直していった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋田露子は北海道大学の理学博士の奥さんにもらわれて、子供が六人――男が四人、女が二人――あって、総領は三十くらいになるだろう。",
              "citation": {
                "source": "宝塚生い立ちの記",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "話は蘆溝橋事件の前、昭和十一年の昔にかえるが、その年に北海道大学に初めて低温室が出来た。",
              "citation": {
                "source": "ジストマ退治の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、北海道大学へ勤めることになったので、大阪へは滅多に行かなかった。",
              "citation": {
                "source": "鳥井さんのことなど",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学を出て、三年間｜理研で、寺田寅彦先生の助手をつとめていたが、北海道大学に理学部が出来ることになって、急に文部省の留学生として、ロンドンへ留学することになった。",
              "citation": {
                "source": "サラダの謎",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈『北海道大学新聞』332号　昭和24年７月12日〉",
              "citation": {
                "source": "学問ある蛙の話",
                "author": "知里真志保",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが今日の北海道大学の前身である。",
              "citation": {
                "source": "『ケプロン・黒田の構想』について",
                "author": "――英文誌 This is Japan のための草稿――",
                "note": "青空文庫"
              }
            },
            {
              "text": "若人よ大志を抱け　ケプロンのまいた種が、もっとも実を結んだのは、現在の北海道大学である。",
              "citation": {
                "source": "『ケプロン・黒田の構想』について",
                "author": "――英文誌 This is Japan のための草稿――",
                "note": "青空文庫"
              }
            },
            {
              "text": "長兄のお嫁さんが一度代議士に出た人の娘で、次兄が北海道大学教授の姪を貰っていることにまで及んだ。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
