    "definitions": [
      {
        "index": 1,
        "gloss": "long-cherished desire",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "民子は死ぬのが本望だと云ったか、そういったか……家の母があんなに身を責めて泣かれるのも、その筈であった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「役者が、舞台で死ねたら　本望……」　勇ましや、恋人の言葉！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎の姓に返ってから死にたいと願っていましたが……、骨は本当は太宰さんのお隣りにでも入れて頂ければ本望なのですけれど、それは余りにも虫のよい願いだと知っております。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾ゃおまえに怨まれるのが本望だ。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽しみが出来ていいわ」「……殺してくれる……」「どうぞ……貴方みたいな可愛いお人形さんに殺されるのは本望よ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そなたと永劫離れぬ双生像に鋳られるなら、娘も嘸かし本望でござろう。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶつぶつ切って刻んでも棄てたいように思うんですもの、ちっとも残り惜いことはないのですが、慾には、この上の願いには、これが、何か、義理とか意気とか申すので死ぬんなら、本望でございますのに、活きながら畜生道とはどうした因果なんでございましょうねえ。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、さて各自には、すでに御本望をお遂げなされたのでありまするか。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "和蘭陀の公子は本望でせう……實は其が望みだつたらしいから――　鸚鵡は多年馴らしてあつて、土地の言語は固よりだし、瓜哇、勃泥亞の訛から、馬尼剌、錫蘭、澤山は未だなかつた、英吉利の語も使つて、其は……怜悧な娘をはじめ、誰にも、よく解るのに、一ツ人の聞馴れない、不思議な言語があつたんです。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで死ぬなら全く本望というものだ。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬのは本望でござりましたろうが、もし、それや、これやで、釜ヶ淵へ押ぱまったでござりますよ。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ嬉しや、私は本望が協った。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "画工　可、この世間を、酔って踊りゃ本望だ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お位牌を抱けば本望です。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い月日の事でござりますから、里の人達は私等が事を、人に子だねを進ぜるで、二人が実を持たぬのじゃ、と云いますがの、今ではそれさえ本望で、せめてもの心ゆかしでござりますよ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒が上って、醒めずにいたりゃ本望だんべい、俺ら手が利かねえだに、もうちっとだ辛抱せろ、とぐらぐらと揺り出しますと、死ぬる、死ぬる、助け船引と火を吹きそうに喚いた、とのう。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　　十八「――（この上誰か、この手毬の持主に逢えるとなれば、爺さん、私は本望だ、野山に起臥して旅をするのもそのためだ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "厭わぬけれど……明さんがそうすると、私たちと同一ような身の上になりますもの……　それはもう、この頃のお心では、明さんは本望らしい――本望らしい、」　とさも懸想したらしく胸を抱いたが、鼻筋白く打背いて、「あれあれ御覧なさいまし。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "手足は凍って貝になっても、（こいし）と泣くのが本望な。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ジュリアンになれたら本望だ」　つねにサイコロによって自分の行動を左右しながら、運命の刃の上を渡るような激しいスリルを求めてやまない鶴雄は、倦怠した生活から脱け出す血路を、下鴨の小郷の家に求めてやって来たのである。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒と心中したら本望だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由詩人としての我々の立場が、之れによつて幾分でも一般の理解を得ば本望である。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "使者の口上は、明日路ははや敵の領分にて候、当地のそれがしが柴の庵、何の風情も無く侘しうは候が、何彼と万端御意を得度く候間、明朝御馬を寄せられ候わば本望たる可く、粗茶進上｜仕度候、という慇懃なものであった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋で死ぬ、本望です。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば、どんなにか嬉しかろう、本望じゃ、と思われたそうな。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴女に生命を取らるれば、もうこの上のない本望、彼等に討たるるのは口惜い。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人　いいえ、私も本望でございます、貴方のお手にかかるのが。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "公子　馬に騎った女は、殺されても恋が叶い、思いが届いて、さぞ本望であろうがね。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "気絶しようが、のめろうが、鼻かけ、歯かけ、大な賽の目の出次第が、本望でしゅ。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを何ゆえかと申しますのに、おくがたのおことにあわせて三味線のひじゅつをつくし、または御しょもうの唄をおきゝに入れて御しんちゅうのうれいをやわらげ、いつも／＼おほめのおことばをいたゞいていたのでござりますから、たいこうでんかのぎょかんにあずかりましたよりもずっとほんもうでござります。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
