    "definitions": [
      {
        "index": 1,
        "gloss": "the smoke of guns and a rain of bullets or shells",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
