[
  {
    "uuid": "776f236b-8d7c-5ffc-8362-5f9c07afb9f1",
    "entry": "程",
    "reading": {
      "primary": "ほど",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "副詞"
      ],
