    },
    "definitions": [
      {
        "index": 1,
        "gloss": "retainer's stipend",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夫れから第三次の侠客は、諸大名の中に何か一つ事が起ると人夫が必要になる、二本指の人間は使つて居ても之を雑役には使へぬし、又た俸禄の関係から云つても、平時用の無い時に万一を慮つて沢山の雇人を使つて置くといふことが出来ぬ。",
              "citation": {
                "source": "侠客の種類",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪冬の陣の媾和には、初め家康から、一、浪人赦免、二、秀頼｜転封の二条件を提議し、大阪方からは、一、淀君質として東下、二、諸浪人に俸禄を給するために、増封の二条件を回答した。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで阿部家の俸禄分割の策を献じた。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "俸禄も厚く、信任も重く、細大の事務｜尽く掌裡に帰して裁断を待ち、監督川島不在の時は処務を代理し、隠然副監督として仰がれていた。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶山が当時の身分は、前に江戸に客たりし時より俸禄が倍加せられてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "其後天明八年戊申と寛政十一年己未とに列次を進め俸禄を加へられた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "菅氏では此年文政六年に、茶山が大目附にせられ、俸禄も亦二十人扶持より三十人扶持に進められた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "俸禄は「現米十八斗」であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "目ざめて見れば六十五石の俸禄になっていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "俸禄は召しあげられ、武士は捨てさせられていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "現物の俸禄米を持てあました役人は、これを二束三文に売りはらって、痛飲馬食して持てはやされた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「先ず――俸禄が多すぎるんでしょう、結構なこってすよ」「左様か――そこの手拭いを貰おう」　店番の男はそこから動かなかった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "捨て売りするほどの俸禄を食む官吏と、それの直接の庇護のもとにある移民であった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたえられた俸禄を食んで、無為に暮した日を追想することであった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏そだちの彼らには、与えられた権力と、賄われる俸禄がふいに気持を奢らしていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "換言すれば俸禄をもって他人の身体を抑える者は、心そのものをも制し得る考えをもってする者が多くありはせぬか。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "俸禄を受ける者は知らず知らずのうちに心まで自分の主人のために奪われることはありはせぬか。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ところで先刻の話のつづきだが、彼奴ら、すなわち金貸しどもは、武士から俸禄米を質に取って、金を貸して高利をむさぼり、自身は蓄財し武士たち一統を……」「殿」　と貝十郎はそれには答えず、梅の木の下に佇んだまま、空を見上げ片手を差し出し、掌を上にして呻くようにいった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "太閤時代からの家柄でね、先祖代々、異国と御直商売というのをやっていたからなかなか金持よ、俸禄はたった七十俵五人｜扶持しきゃ貰っていねえけれど、五十万石の大名と同じぐらいの金があったそうだよ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼ら旗本方はほとんどその俸禄にも離れてしまった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしわたくしは遂にその役柄並に俸禄を知ることができない。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "○英国王、特権ヲ恣ニシテ官爵ヲ与奪シ俸禄ヲ増減セリ。",
              "citation": {
                "source": "アメリカ独立宣言",
                "author": "福沢諭吉訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に藩許を得るも未だ旅券を得ず、彼｜毫も遅疑せず、曰く、「一諾山よりも重し、俸禄捨つべし、士籍｜擲つべし、国に報ゆるの業、何ぞ必らずしも区々常規の中に齷齪するのみならんや」。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝暦十一年に俸禄を辞してからはどこにも仕えなかったので、なかには彼を招こうとする諸侯もいろいろあったのでしたが、特別な仕事のほかはそれに応じなかったと云うことです。",
              "citation": {
                "source": "平賀源内",
                "author": "石原純",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻君が自分の傍を遠退くのは漂泊のためであろうか、俸禄を棄てるためであろうか。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはその地位と官職とに応じて国家より俸禄を受くるのである。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "是において議するものあり曰く国家の俸禄を食む史家は誤謬の索捜を勉めて国史の美観を損ずと。",
              "citation": {
                "source": "史論の流行",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "エド時代の武士には生命は（俸禄との交換条件として）主君からの預りものであるということが教えられもしたが、上代にはそういう思想はなかった。",
              "citation": {
                "source": "日本歴史の研究に於ける科学的態度",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "で自分の学資として仰ぐところは、信者より「ゲ」として上げられた月々に一円から二円の金、それから俸禄として一円ぐらい。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "古寺やほうろく捨てる芹の中　荒廃した寺の裏庭に、芥捨場のような空地がある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
