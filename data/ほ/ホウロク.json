[
  {
    "uuid": "c16e748a-d94a-52dc-be1d-8a9cbe8fbabe",
    "entry": "俸禄",
    "reading": {
      "primary": "ほうろく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
