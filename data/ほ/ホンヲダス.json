    "definitions": [
      {
        "index": 1,
        "gloss": "to publish a book",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――　　　　　　　九　そこへ、祖母が帰って来たが、何んにも言わず、平吉に挨拶もせぬ先に、「さあ」と言って、本を出す。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は口語體で讀み易い譯本を出すことに贊成しますね。",
              "citation": {
                "source": "ロビンソン・クルソオ",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在のこの世の中で、本を出す主体となっているのは、企業である出版社です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めての本を出すにあたって、私は抜きがたい影響を自分に与えた体験とじっくり向き合いたいと考えました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "義理の母と云ふのが、さう云ふ商売にあり勝ちの女で、資本を出す男から男へ移るうち、結局は世間の恨みを買って、没落した。",
              "citation": {
                "source": "透明な輪",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "興行物としての損益はわかりませんが、もし損失があっては資本を出す考えでいる野見さんに迷惑が掛ることになります。",
              "citation": {
                "source": "佐竹の原へ大仏をこしらえたはなし",
                "author": "高村光雲",
                "note": "青空文庫"
              }
            },
            {
              "text": "一體、私は木曾のやうな田舍に生れて、少年時代に自分の着る物でも食べるものでも多くは家で手造りにしたやうなものであつたから、そんな幼少の頃からのならはしが自然と私の内に浸み込んで居て、自分で自分の本を出すといふ場合にも物を手造りにするやうな悦びを覺えた。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だか自分の作った唄の本を出すんだとさ。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "興業物としての損益は分りませんが、もし損失があっては資本を出す考えでいる野見さんに迷惑が掛かることになります。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "佐竹の原へ大仏を拵えたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "女性の書く本と、それを読む心理にこういう今日の生活の現実に立つ動機があるものだから、ごく最近では男のひとで、婦人の職業や結婚の問題を扱った本を出すひともあらわれて来た。",
              "citation": {
                "source": "女性の書く本",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人の作家たちはイタリーで本を出す時、夫或いは父親、その他の法律上の親権者に許可を求めてやっと本を出すということを説明し、「かの女らは美しいイタリーの空の下で、そういう生活をしている」といった。",
              "citation": {
                "source": "私の会ったゴーリキイ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "志賀直哉が自著入りでやはり千円の本を出す、ときく心持は「まんじ」の場合よりも、もっと文学の圏内におこったことの感じであった。",
              "citation": {
                "source": "豪華版",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕を信じて資本を出すものがあるとしても、それが社長の左右するところとなつてしまふ樣ではつまらんから、なア。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし神のお恵みで新年まで生きながらへて、もう一冊の本を出すやうなことにでもなれば、その時こそ、あの世から迷つて出てくる亡者だの、むかしむかし、この正教の国にあつたくさぐさの不可思議な出来ごとだのの物語で、少しばかりぞうつとさせて進ぜてもよろしい。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "休日などには図書館に小使位しか居ないのも宜しくない、（その為めに今度のやうな火災にもどういふ本が貴重かがわからず、従って貴重な本を出すことも出来なかつたらしい。",
              "citation": {
                "source": "大正十二年九月一日の大震に際して",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "行李から本を出すと、昔の私の本箱にはだいぶ恋の字がならんでいる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五日すると、実際サワ子が沖本によばれて、戸籍謄本を出すようにと云われた。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此が、この本を出すやうに奨めてやつた理由の二つである。",
              "citation": {
                "source": "鵠が音",
                "author": "追ひ書き",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の本を出すについて、前の「我等の劇場」と連絡をつけるために、その中から、基本となる若干の項目を抜萃した。",
              "citation": {
                "source": "「現代演劇論」はしがき",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "良い本を出すと店がつぶれるという通念が、もし万一、国民に流れたら、それは、小さいことのようだが、それは、文化の上において民族の「死の十字」の症状のあらわれである。",
              "citation": {
                "source": "「焚書時代」を脱却",
                "author": "――図書館法成立にあたって",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろききたければ、わたしが、近々本を出すから、それを読んでくれるといい。",
              "citation": {
                "source": "尋常一様",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治卅七年の夏藤村抄本を出すにつきて　二十五六といふ青年時代が二度と自分の生涯には來ないやうに、最初の詩集も自分には二册とは無いものだ。",
              "citation": {
                "source": "藤村詩抄",
                "author": "島崎藤村自選",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央公論社が雑誌の外に単行本を出すやうになつたのは震災時分からのやうに記憶してゐます。",
              "citation": {
                "source": "出版屋惣まくり",
                "author": "永井壮吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央公論社が雑誌の外に単行本を出すようになったのは震災時分からのように記憶しています。",
              "citation": {
                "source": "出版屋惣まくり",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃はまだ気が小さかったので、小宮さんにすすめられ、かつ適当におだてられて、やっと思い切って「本を出す」気になったわけである。",
              "citation": {
                "source": "ジストマ退治の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
