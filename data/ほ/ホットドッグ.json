        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "入って右側に売店とビュフェがあり、文具、日用雑貨、菓子、飲料などを買ったり、ホットドッグ、スパゲティ、ラーメンといった軽食をとることもできる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はい、お待ちどう」と、高志のまえにホットドッグがふたつ、薄緑色の皿にのって出てきた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「犬じゃあるまいし、骨なんか愛してたまるかよ」　高志はターンテーブルのカヴァーをあけ、アダプターをおき、ホットドッグを口にくわえ、溝にふれぬように、両手でレコードをのせた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "サブマリンサンドというのは、大魔神のホットドッグのようなものだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえのぶん」　高志がテーブルにおかれたホットドッグを、慶一のほうに押しやる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "リク　……（にぎらされたホットドッグをマジマジと見つめていたが、なんと思ったか、ポイと放り出してしまう）貴島　（それを見て）どうしました？",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の右側には、おなじく青い枠で囲んで、ホットドッグやバーガーのメニューが書いてあった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一ドルのオール・アメリカン・ホットドッグは道ばたでの軽食の基本であり、パイプライン・バーガーは御馳走と言っていい出来ばえだった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りに千成へ寄りすしをつまみ、屋台のホットドッグを食って帰る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
