    "definitions": [
      {
        "index": 1,
        "gloss": "hot (e.g. from the oven)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こせこせしたものは一切｜抛げ捨ててしまえ、生れたてのほやほやの人間になってしまえ。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯気さえほやほやと立っているよ。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "曇っていた日であったが、割にあたたかで、雪道からほやほや湯気が立ち昇っている。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ百韻中で調べてみると前のほうにある「とろとろ」はだいぶ離れているが、ずっとあとに来る「ほやほや」と「うそうそ」とは五句目に当たる。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂からあがりたてらしく、やせこけた両肩から湯気がほやほやたっていた。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき家々のかまどから立ちのぼる煙は、ほやほやとにぎわっていたとな。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日はすでに高く上って、島のここかしこから白い靄がほやほやと立っていた。",
              "citation": {
                "source": "猿ヶ島",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とに角まだ一月ばかり前のほやほやな話なんだ。",
              "citation": {
                "source": "Ｓ中尉の話",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「見たわ、あれでしょう」「見たの、山の、あの字のついた家よ」「そうよ、前夜、見たてのほやほやだわ」「ほんとう、料理番と婢さん」「そうよ」　彼女は得意になって話した。",
              "citation": {
                "source": "料理番と婢の姿",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほやほやの新聞記者。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校の三年まで行つて職工になつたが、なりたてのほやほやは自分の名位書けた。",
              "citation": {
                "source": "工場の窓より",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "新婚のほやほやのところをおどかしちゃ少しお気の毒かしら。",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "野郎が裏口の日あたりへ出やがって、にたにたと青白い顔にうすっ気味のわりい笑いをうかべながら、いま切りたてのほやほやといったような子どもの足を二本、日にかわかしているんでがすよ」「なに？",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本では最近にヨーロッパへ行ったことのある誰とも話はしなかったが、支那ではほやほやのフランス帰りの幾人かの人達と会った。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の皿には、焼豚がさも美味そうにほやほや煙を立てているが、モッフは、それを頒けるべくフォークを構え、ナイフをその肉にずぶりと突き刺したのを機会に、肝腎の話を切りだした。",
              "citation": {
                "source": "ラ・ベル・フィユ号の奇妙な航海",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "うん、よかつぺえ、それぢやあ、ほやほやの花聟どん、お祝ひに一杯やらかすことにすべいか！",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄米パンのほやほや売りだ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸見て、いかにも頭髪がうすくほやほやになり老年らしく御なりになった。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "フレンチ医師が医学校を出てまもない、二十代のほやほやだったということも、彼にとっては好｜都合だったに相違ない。",
              "citation": {
                "source": "浴槽の花嫁",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "凪ぎの晩より少しほやほやと南風の吹く晩がよいので、それにはコンクリートの海の城壁の上で、月を迎へ乍ら魚を待つ方が静的である。",
              "citation": {
                "source": "夏と魚",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "経済戦、外交戦、思想戦、宣伝戦、謀略戦、などはすぐに耳にも眼にも慣れて来たが、「生産戦」はほやほやの感があり、「生活戦」となると、まだ大分説明がいりさうだ。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、これまで申したことは、ついこないだ、それこそ湯気の立つほやほやの口からきいたお話ですよ。",
              "citation": {
                "source": "ブレーメンの町楽隊",
                "author": "DIE BREMER STADTMUSIKANTEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がほやほやのホットケイキの一つを取って、こわすかこわさないうちに、ひどく困ったことには、一瞬間前まで真白な小麦粉で出来ていたものが、玉蜀黍の粉でつくったように黄色がかって来ました。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて医師のスタールツェフ、その名はドミートリイ・イオーヌィチが、郡会医になりたてのほやほやで、Ｓ市から二里あまりのヂャリージへ移って来ると、やはり御多分に漏れず、いやしくも有識の士たる以上はぜひともトゥールキン一家と交際を結ばなくてはいかん、と人から聞かされた。",
              "citation": {
                "source": "イオーヌィチ",
                "author": "JONYCH",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治三、四年といえば、五十銭で米一斗買えた、ほやほやの明治政府は、内外山積の難問題で、のるかそるかというときである。",
              "citation": {
                "source": "明治の五十銭銀貨",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、おたがいもう、ほやほやの御夫婦じゃあるまいし、久しぶりで会ったからって、まさか無分別にのぼせあがりも出来なかろうじゃありませんか。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何しにです」「停車場へ迎えにさ」「道は知ってるんだから」――フィリップは言う――「一人で来れますって、子供じゃなし」「だって、そのほうが、帰りたてのほやほやのところをキスしてやれるわけだ」「そりゃまあ」「そうだろう。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "貰い立てのほやほやなんだ」「じゃなおどうも……」「なおどうもじゃない。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
