          "literary": [
            {
              "text": "十五六本貰つて栽ゑたのが唯一二本枯れたゞけである。",
              "citation": {
                "source": "中秋の頃",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "近きころ一本枯たりしが、根より芽生へ出で、元の如く並び立てり。",
              "citation": {
                "source": "柳橋考",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　一年に一本くらい枯れて行ったから、十五年間には十五本枯れたことに、なっていた。",
              "citation": {
                "source": "生涯の垣根",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう云えば、きのう、うちの門を入ったところの樫が一本枯れていたら新しいのと植え代えました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「松が一本枯れかゝっているね？",
              "citation": {
                "source": "負けない男",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
