    "definitions": [
      {
        "index": 1,
        "gloss": "every person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "用意の車五輌口々に何やら云えどよくは耳に入らず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "口々に La mer est calme, la mer est calme.（好い凪だ）と云っている。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして人民は皆「王が石垣島を占領した功に誇り、慢心を起し遂にこんなになつてしまつたのだ」と口々に言つて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "改札口でなしに、小荷物口の方に向って、三四十人の人の群が、口々に喚き、罵り、殴り、髪の毛を引っ掴みながら、揺ぎ出した岩のようにノロノロと動いて行った。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「頑張れよ」「御大事に」「しっかり頼むよ」口々にこうした激励の言葉を投げた。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでなければ、人々は口々に饒舌っていても世界は癲狂院かバベルの塔のようなものである。",
              "citation": {
                "source": "言語と道具",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「喧嘩だ」　と口々に叫び乍ら走って行く人々。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガヤガヤ、ワイワイ口々に、Ｔ「横暴だ！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて又数人、口々に「喧嘩だ」　と言っているらしい。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝表　馳け出す人々、口々に、Ｔ「お絹さんが　逃げたッ！",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と口々に、Ｔ「天狗様の　お怒りが　怖しいぞ！",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務室から出ることを許されて、兵舎へ行くと、同年兵達は、口々にぶつ／＼こぼしていた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ホンケが来たホンケが来た」と言って駆け出して行っては、この「ホンケ」を取り巻いて、そうして口々に「ホンケ、オーセ、オーセ」と言ってねだった。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの乗合の客も口々になだめたので、御符売りはよんどころなしに手をゆるめた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "」近所の人々は口々に、憎さげに云った。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　兵士たちは、口々に、憤って罵った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼等は、記者が一枚の写真をとって部屋を出て行くと、口々にほざいた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大王の問をみんなが口々に相伝えて云っているのをきいて「わたくしは自分の肉を売って生きているいやしい女である。",
              "citation": {
                "source": "手紙　二",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "１０＝茶店　仕出しが二人三人口々に「喧嘩だ」と叫んで走って行く。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "10＝茶店　仕出しが二人三人口々に「喧嘩だ」と叫んで走って行く。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "近く寄れ、喰さきなむと思うのみ、歯がみして睨まえたる、眼の色こそ怪しくなりたれ、逆つりたる眦は憑きもののわざよとて、寄りたかりて口々にののしるぞ無念なりける。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と口々にまたひしめきつ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな四ッ手網を枝川の口々へかけているものも可なり有る。",
              "citation": {
                "source": "夜の隅田川",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅れて来る人々もあちこちの横町からプロージット・ノイヤールと口々に叫ぶ。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五人、五六人という群れになって北山おろしの木枯らしに吹かれながら軒並みをたずねて玄関をおとずれ、口々にわざと妙な作り声をして「カイツットーセ」という言葉を繰り返す。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、その一団の青年、少女、口々に、駒が岳の偉容を賞讃した。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だいあれあ、と口々にお祭を意味なく軽蔑しながら、三島の町から逃れ出て沼津をさしてどんどん歩き、日の暮れる頃、狩野川のほとり、江島さんの別荘に到着することが出来ました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ととさまえのう、と口々に泣いて父を呼ぶ。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎっしり互いに身動きの出来ぬほどに乗り込んだ登山者あるいは遊覧の男女の客は、口々に、わあ、ひどい、これあ困ったと豪雨に対して不平を並べた。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」山ねこが、すこし心配そうに、それでもむりに威張って言いますと、どんぐりどもは口々に叫びました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
