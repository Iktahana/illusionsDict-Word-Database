[
  {
    "uuid": "07dd3bd6-5494-58fc-b1a9-236c022b80ea",
    "entry": "焼べる",
    "reading": {
      "primary": "くべる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
