      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to put (wood, coal, paper, etc.) into the fire",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "渡瀬さんは薪をくべると手をはたき合せながら机の向うに帰った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（老女は銅刀で乳房を裂き、白蓮華の一枚々々に乳房の血を塗り、炉の火中にくべる。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてせつせと柴を折りくべる方に気を取られた振りをしたなり、「儀平どんのかゝさあ。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "重兵衛は更に枯枝をくべる。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "炉に火をくべるから着物をあぶつて、今夜はわしのところで泊つてゆかつしやい。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "数枝、何も言わず、笑いをやめて、てれかくしみたいに、ストーヴの傍の木箱から薪を取り出し、二、三本ストーヴにくべる。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "大切におし、旅で病んでは心細い、私も今度は頼りなかつたと、私も紅葉をまた火にくべる。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとにね、それでも早うお癒りになつてよかつたと、妻もまた紅葉をくべる。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、旅僧は其の鍋の中へ米と水を入れて、地炉の自在鉤にかけた後で左右の足を踏み延ばして、それを炉縁に当て何時の間にか傍に来ていた鉈で、膝節から薪を割るようにびしゃびしゃと叩き切って、其の切れを地炉の中にくべると、火が盛んに燃えだして鍋の飯が煮立って来た。",
              "citation": {
                "source": "怪しき旅僧",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "食堂らしい部屋を通りぬけて行って、準之助氏の居ると思われる部屋をソッとのぞくと、そこは、サロンらしく壁に薪をくべるらしい大きい炉が切ってあり、中は山小屋らしく作られており、腰の低い窓が、いくつか開いている。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とホームズは紙巻き煙草を暖炉にくべる。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいよは炉に粗朶をくべる。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（正吉は無言でおいよに会釈し、枯枝を炉にくべる。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "盲目の親父は青い顏をして小さくなつて爐端に坐つてゐる……酒さへ飮まなけりやあ意氣地がね程、まあ確に意氣地がなかつたんだが、大きな聲も立てれぬ程おとなしかつたもんです……おふくろは茶を入れようつて、生の木をやたらにくべるもんだから、喘息持のをばさはよくむせたもんた。",
              "citation": {
                "source": "醉ひたる商人",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "爐の口へたき物をくべる者、爐の上は大釜がかかっている。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間始終叔母にいぶされる辛らさ苦しさ、初は叔母も自分ながらけぶそうな貌をして、やわやわ吹付けていたからまず宜ッたが、次第にいぶし方に念が入ッて来て、果は生松葉に蕃椒をくべるように成ッたから、そのけぶいことこの上なし。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわてて松葉と薪をくべると、ひどい煙の中から炎がまいたって、土間の自転車の金具が炎で赤く光った。",
              "citation": {
                "source": "河沙魚",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏みにじられてよ泥まみれになってよ」「火にくべるがいいだあ、火にくべるがいいだあ」　信輔筆の六歌仙は間もなく火の中へくべられた。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の毒にもこの難破船はもうストーブにくべる石炭や薪もなくなったと見えて、室内に氷が張っていたり天井から氷柱が下っていたりする。",
              "citation": {
                "source": "大空魔艦",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから自分で煖炉に焚木をくべる。",
              "citation": {
                "source": "風立ちぬ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが高尾が浪人者に与えた反魂丹があって、これを一粒火にくべると高尾の幽霊が現れて語り合うことができる。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第二回　富山の薬と越後の毒消し≪富山県・新潟県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一粒の反魂丹を火にくべると、煙の中から高尾が姿を現す。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第二回　富山の薬と越後の毒消し≪富山県・新潟県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、最初のうちこそ、縄を外してくれと要求しながら、その要求通りに縄を投げ出されてみると、それですべてが許されたものと心得て、それからは火をくべることだの、お茶をいれることだの、たらし餅をすすめることだのにとりまぎれてしまって、首の縄を全く忘れ去ってしまったものらしい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし榾とは言っても囲炉裏にくべるのではなくて、白樺など脂の多い木の榾を暖炉の上に立てて蝋燭代りにともすのがロシヤの貧しい農家のならいであった。",
              "citation": {
                "source": "イオーヌィチ",
                "author": "JONYCH",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストーブにくべる少しばかりの薪や、なべに煮るわずかのスープを買うのが精一杯でした。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A Dog of Flanders",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、暖炉にくべる薪も十分にはなく、食べるパンがないこともたびたびでした。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A Dog of Flanders",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはそれをじゃまする勇気がなかった、わたしはかれのわきにつっ立って、ただときどき火の中にえだをくべるだけであった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "女　うん、もうチョット……（しきりとヤカンの下に小枝をくべる）青年　やあ、水でもいいのに。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "くべればくべる程咳が出て仕様がない。",
              "citation": {
                "source": "いたずら小僧日記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
