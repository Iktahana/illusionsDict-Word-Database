        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こういう風に、聯想の火薬に点火するための口火のようなものを巧みに選び出す伎倆は、おそらく俳諧における彼の習練から来たものではないかと思われる。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬱積から爆發へ、もはや口火を點ずるばかりだ。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この老先生がかねて孟子を攻撃して四書の中でもこれだけは決してわが家に入れないと高言していることを僕は知っていたゆえ、意地わるくここへ論難の口火をつけたのである。",
              "citation": {
                "source": "初恋",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私の短文がわずかにその口火をなしたのにすぎない。",
              "citation": {
                "source": "想片",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国でいくつか渡る橋を想像したとき執着の口火がふたたびつけられたのかも知れない。",
              "citation": {
                "source": "橋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "も一人の子は、もう手に口火を持って待っていました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳氏はそれに口火をあてて、急いでのろし筒に投げ込みました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人口火を切ったから堪らない。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の飛躍も、一群の蘭医に依って口火を切られたのだと言っていた。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "維新は、水戸義公の大日本史｜編纂をはじめ、契沖、春満、真淵、宣長、篤胤、または日本外史の山陽など、一群の著述家の精神的な啓蒙によって口火を切られたのです。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "興世王の言を聞くと、もとより焔硝は沢山に籠つて居た大筒だから、口火がついては容赦は無い。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな全く無政府的な世相に口火を切って、応仁の乱を捲き起したのが、実に細川山名二氏の勢力争いである。",
              "citation": {
                "source": "応仁の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くとも、池田屋事変は、禁門戦争の導火線に、口火を切つたと云ふべきであらう。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "満洲の一角に上つた現状打破の波紋は、旧勢力に依る国際聯盟を無力化し、伊太利、独逸等の活躍となり、世界新秩序形成の口火となつたとさへ思はれるのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人｜口火を切つたから堪らない。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "東芝のダイナブックが口火を切った軽くて小さくて安いマシンの台頭と歩を合わせ、ソフト業界は一万円を切る低価格ビジネス・アプリケーションの波に洗われた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそもマイクロソフトとはなんの会社であるのかから、ワークスの紹介の口火を切った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが口火になって彼の殊勝らしい性根はだんだんに溶けてしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角自分から口火を切つた。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな事で口火を切つてどんな鹽梅に進行させたかといつたつてそれも言へぬ。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "四つ又はこんなことでそろ／＼戲談から口火を切る。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、これでも、事によるとほんとうのストライクの、口火にはなるかもしれないけれどね。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "お光の金の一条で栄之丞が偶然訪ねて来たのが口火になって、そのほとぼりはまた煽られた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも自分がその直接の責任者となるのを避けて、わが子の師冬をそそかして彼からその口火を切らせようとしたのであるが、師冬はあたかもこちらのふところを見透しているかのように、かえって塩冶の肩を持って父に反抗するような態度を示したので、師直はまた失望した。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや火というよりも、爆弾にしかけた口火のような女だった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在その手で口火をつけて、現在その手で夫の遺骸を燒くその焔の音が、煉瓦に圍まれた不思議な世界の中に、耳を欹てるまでもなくはつきりと聞えてゐました。",
              "citation": {
                "source": "響",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、彼と云うのは煙火の口火に過ぎないのだが、実はもっと濡れて湿気の多い所のある男である。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は朝から一発も放さないでじりじりしている時であったから、讐にでも出会ったようにいきなり銃の口火へ火縄をさした。",
              "citation": {
                "source": "猫の踊",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、いくらそんな工合でも、彼等は誰かゞ口火を切ってくれる迄は待っているものだ、ということだった。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "かへつて、自分の思ひ切つたことが、闇にゐる牛のやうにのろい百姓にキツト何か、グアンとやるだらう、そしたら、それが、口火のやうになつて、皆が案外かへつて手ツ取早く、一緒になつて、ヤレツ、ヤレツ※　と鍬と鎌をもつて立ち上る！",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
