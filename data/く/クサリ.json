  {
    "uuid": "5f91db3e-aeda-596c-b8e1-e771d5fc24e2",
    "entry": "腐り",
    "reading": {
      "primary": "くさり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rottenness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "きょうこの部屋で海賊の打ち合せをしようと思ってね」　私は馬場の興奮に釣られてうろうろしはじめ、蒲団を蹴って起きあがり、馬場とふたりで腐りかけた雨戸をがたぴしこじあけた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みな寝しずまったころ、三十歳くらいのヘロインは、ランタアンさげて腐りかけた廊下の板をぱたぱた歩きまわるのであるが、私は、いまに、また、どこか思わざる重い扉が、ばたあん、と一つ、とてつもない大きい音をたてて閉じるのではなかろうかと、ひやひやしながら、読んでいった。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（矛盾は巴里それ自身の性格でもあるように）何か内へ腐り込まれた毒素があって、たといそれが肉体的のものにしろ精神的のものにしろそれに抗素する女のいのちのうめきが彼女の唄になるのであろう。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその腐りかかった、間に合わせの時と空間を取って捨てて、新しい健全なものをその代りに植え込んだ。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "身の行ひは清くもあれ、心の腐りのすてがたくば、同じ不貞の身なりけるを、いざさらば心試しに拝し参らせん。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉永は、胸が腐りそうな気がした。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "溝の水は澱んで腐り、泥の中からは棒振りが尾を出していた。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小山は、下顎骨が燐の毒で腐り、その上、胸を侵され、胴で咳をしていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "湿気とかびの臭いは、肺が腐りそうにひどかった。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日に十里を楽々と走破しうる健脚を有し、獅子をも斃す白光鋭利の牙を持ちながら、懶惰無頼の腐りはてたいやしい根性をはばからず発揮し、一片の矜持なく、てもなく人間界に屈服し、隷属し、同族互いに敵視して、顔つきあわせると吠えあい、噛みあい、もって人間の御機嫌をとり結ぼうと努めている。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "あしさきが腐り出したんだ。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽二重や博多織は墓の中でも一番しまいまで腐り残るけになあ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷川の水、流れとともに大海に注がないで、横にそれて別に一小沢を造り、ここに淀み、ここに腐り、炎天にはその泥沸き、寒天にはその水｜氷り、そしてついには涸れゆくをまつがごときである。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざとらしい咳払いを先立てて襖を開き、畳が腐りはしないかと思われるほど常住坐りっきりなその座になおると、顔じゅうをやたら無性に両手で擦り廻わして、「いやどうも」といった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "根も葉もない幻想の翫弄物になつて腐り果てる自分ではないか。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしから人間の中にある大きな慾望のいくつかが、常識の厚い層の堆積に堪えられず、遂に腐り果ててしまったことだろう。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼を剥き、足を踏張り齒を露出してゐたが、もう毛も皮もべと／＼になツて、半ば腐りかけてゐた。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその核心には、まだ腐り切っていない或るものが残っていることを君は信じて下さるでしょう。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "月　　　日勇作妻加代　　　母上様　それでは後家さんはどこへ行ったのだろうと、家中を探しまわると、物置の梁から、半腐りの縊死体となってブラ下っているのが発見された。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の足もとの板は、腐りかけているようだ。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しづかにわたしは夢の記憶をたどらうとする夢はあはれにさびしい秋の夕べの物語水のほとりにしづみゆく落日としぜんに腐りゆく古き空家にかんするかなしい物語。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みよ　おくつきに銀のてぶくろかがやき指はひらかれ石英の腐りたるわれが烈しき感傷にけちえんの、らうまちずむの手は光る。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しづかにわたしは夢の記憶をたどらうとする夢はあはれにさびしい秋の夕べの物語水のほとりにしづみゆく落日としぜんに腐りゆく古き空家にかんする悲しい物語。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんまりこんな所に引込んでいると、なお気が腐りますからね。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（矛盾は巴里それ自身の性格でもあるやうに）何か内へ腐り込まれた毒素があつて、たとひそれが肉体的のものにしろ精神的のものにしろそれに抗素する女のいのちのうめきが彼女の唄になるのであらう。",
              "citation": {
                "source": "ダミア",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私も馬場の興奮に釣られてうろうろしはじめ、蒲團を蹴つて起きあがり、馬場とふたりで腐りかけた雨戸をがたぴしこじあけた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「また油をしぼられるんじゃねえかな、」ことし大学を卒業してすぐに海軍へ志願する筈になっている松野君も、さすがに腐り切っているようであった。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みな寝しづまつたころ、三十歳くらゐのヘロインは、ランタアンさげて腐りかけた廊下の板をぱたぱた歩きまはるのであるが、私は、いまに、また、どこか思はざる重い扉が、ばたあん、と一つ、とてつもない大きい音をたてて閉ぢるのではなからうかと、ひやひやしながら、読んでいつた。",
              "citation": {
                "source": "音について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "国技館の角力を見物して、まじめくさり、「何事も、芸の極致は同じであります。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一回の講義の始めに、人間本位の立場から物理学を解放すべきことや物理的世界像の単一性などに関する先生の哲学の一とくさりを聞かせた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
