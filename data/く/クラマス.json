[
  {
    "uuid": "1c9f618f-f321-587e-952e-5b3261631b4e",
    "entry": "晦ます",
    "reading": {
      "primary": "くらます",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
