    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to conceal (oneself)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「顔の皮を剥いだのは、犯跡を晦ます為でしょうか。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度｜葉裏に隠れる虫が、鳥の眼を晦ますために青くなると一般で、虫自身はたとい青くなろうとも赤くなろうとも、そんな事に頓着すべき所以がない。",
              "citation": {
                "source": "マードック先生の『日本歴史』",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺は行衛を晦ます。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "例せば兎｜能く猟犬がその跡を尋ぬる法を知り極めて巧みに走って蹟を晦ます。",
              "citation": {
                "source": "十二支考",
                "author": "兎に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "――兎に角、若しも犯人が、夫人やこの証人の方の遠目を晦ます為にそんな奇矯な真似をしたのだとしても、今更そんな事を名乗って出る犯人などないんだから、まあ、直接の証拠をもっと探し出す事だよ」　大月は再び熱心に靴跡を辿り始めた。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、それで、そればかりのことで、死ぬとか、踪跡を晦ますといふことはない筈である。",
              "citation": {
                "source": "田舎からの手紙",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分の犯した恐ろしい罪に戸惑いながらも、犯跡を晦ますために暴れ石のからくりを弄する……そうだ、これはまた、前から組み立てていた灯台破壊の計画と見てもいい……」「じゃあ、いったい、あの恐ろしい化け物はどうなるんです」　わたしは思わず口を入れた。",
              "citation": {
                "source": "灯台鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺してすぐに逃げなかったのも、やはり秘密を見つけることができなかったのと、も一つは令息に嫌疑をかけて、無事に身を晦ます心算だったということです。",
              "citation": {
                "source": "髭の謎",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "召集されて戦線に立つた画家連は、恰ど舞台の背景画家がするやうに、敵の目を晦ますために、戦場に色々な背景を拵へ上げることを考へついた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十三　人を二人まで締め殺して、死骸を床下に埋めておいたというその兇徒は、犯罪の迹を晦ますためにじきにその家を引き払った。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい三木という姓は私の地方には多く、播州三木城の別所氏が豊臣秀吉に滅ぼされた時、家臣たちが亡命して身を晦ますために元の姓を秘してその土地の名をとり三木と称したのに始まると伝えられている。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですが、畢竟こんなことをして、一時人の眼を晦ますことは出来ましても、ほんとうに画に眼のあいている人は胡魔化しきれるものでないと思います。",
              "citation": {
                "source": "迷彩",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし尊王家の智者は其智慧の光を晦ますことを努めた。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "晦ますのが、多数を制するには有利であつたからである。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂本等が梅田を打ち倒してから、四辻に出るまで、大ぶ時が立つたので、この上下十四人は首尾好く迹を晦ますことが出来た。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸崎の興行先からでは、此方へ廻っては道が損かも知れませんが、行方を晦ますのに都合が好いものですから」　この小虎の物語で、すべての疑問が解けたので有った。",
              "citation": {
                "source": "死剣と生縄",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "※賣屋の主婦の眼を晦ますことを覺えてから、それをいろ／＼の人に試みたが、うまく行くことの多いのに、嬉しくてたまらなかつた。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　たゞ足音を忍んで、人の眼を晦ますだけでは詰まらないといふことを、文吾の小ひさな胸は考へ始めた。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と齒噛みをしたが、家の母や寺の和尚さんの眼を晦ますことは、もう何んでもなくなつた。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の眼を晦ますことが何んでもなくなるに連れて、それをたゞぼんやりとやつてゐることが、文吾には詰まらなくなつたのである。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一和尚さんの眼を晦ます種を、何も見付けることが出來ない。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして無言のままハルスカイン家の奥庭の方へ引返して来まして、池の前に在る芝生の上に相並んで腰を下しましたが、そこで久方振りに口を利き合ってみますと、弟も私と同様に「一切を譲り渡す」という手紙を投函して行衛を晦ますつもりであったというのです……。",
              "citation": {
                "source": "霊感！",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼奴は吾輩が遅かれ早かれこの危険千万な放れ業式の解放治療の実験を切り上げて、その内容を学界に発表すると同時に、行衛を晦ますであろう事を、ずっと前から察していたんだね。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方に呉一郎とモヨ子の縁組は、九十九パーセントまで外れる気遣いがないのだから、この実験を試みるにも、又は、その跡を晦ますにも、この姪の浜以上に適当な処はない訳である」「……………」「……だから第二回の姪の浜事件というのも、決して神秘的な出来事ではない。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼾声雷の如く　　　　　酔臥して後行衛を晦ます正木博士は総長室を出ると無責任にも死傷せる患者を医員連の看護に一任したまま帰途に就いた模様であるが、その途中どこかで飲酒泥酔したらしく、その夕方、福岡市｜湊町の下宿に帰って二三時間のあいだ雷の如き鼾声を放って熟睡していた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢張り私にまで行先を晦ます為であったのであろうか。",
              "citation": {
                "source": "日蔭の街",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "重病人の親を捨てて姿を晦ますような不埒な奴にはこの家の相続はさせられない、と、いうことになりますもの。",
              "citation": {
                "source": "恐怖の幻兵団員",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなではないと言ったところで、このごろは世間が物騒でございますから、男が女の風をしたり、女が男の風をしたりしてお関所を晦ますようなことがあると、なかなか面倒には面倒になるんでございますね」　こんなことを言っている間に、いつか関所の裏道を抜けてしまって、本道へ出て笹子峠を上りにかかっていました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "慢心和尚の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫でも漁るのか、と思えば……不意に、キャ、キャ、キャ……と叫んで、羽音も荒々しく、どこへか姿を晦ます。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "税関の眼を晦ますためだと、誤解されても仕方がありませんぞ！",
              "citation": {
                "source": "グリュックスブルグ王室異聞",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
