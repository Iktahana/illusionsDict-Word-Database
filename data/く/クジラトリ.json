          "literary": [
            {
              "text": "鯨取りもとうにもうノルウェー式か何かになってしまったはずだから、自分が父から聞いたような美しい勇ましい夢物語はやはり永久の夢物語になってしまったに相違ない。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "オニイルの鯨取りの戯曲を読んで淋しくなった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は鯨取りの元締だから、何とか鯨をおいしく食わせる法を講じられないものか、と友人のある捕鯨会社の幹部に問うてみた。",
              "citation": {
                "source": "海豚と河豚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            }
          ]
        }
