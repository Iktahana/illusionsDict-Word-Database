          "literary": [
            {
              "text": "グライドがじっと見ていると、奇妙な小型機械が組み上がるさまは子供のパズル遊びのよう。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "もえしきる家の戸口からは、まるで、コンロから火を吐くやうに、炎をはき、そのすさまじい火勢に思はず、すくみあがる思ひがしました。",
              "citation": {
                "source": "思ひ出",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "チューブが走りきって消滅すると、夜の海の広がりが、見ているだけですくみあがるような量感をたたえて、目の前に横たわる。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
