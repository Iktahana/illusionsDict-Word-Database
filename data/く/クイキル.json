          "literary": [
            {
              "text": "また吸い出しては食い切る。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居でする金閣寺の雪姫、あの芝居の真似事をいたしまして、わたくしがお姫様の姿で桜の木にくくり付けられて、足の爪先で鼠をかきますと、たくさんの鼠がぞろぞろと出て来て、わたくしの縄を食い切るのでございます。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてめりめりと腕を食い切る、深い口をあけて耳の根まで胴にかぶりつく。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あしたもしカピが芝居の最中に、口輪を食い切るようなことがあるといけませんから、まえからそれをはめておいて慣らしてやらないでもいいでしょうか。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生」と、ガスパールおじさんだけはわたしを食べようとは思えなかったが、パージュとカロリーと、ベルグヌーは、とりわけベルグヌーは長ぐつの皮を食い切るあの大きな白い歯で、ずいぶんそんなことをしかねないと思った。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            }
          ]
        }
