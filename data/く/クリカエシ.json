        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "出鱈目な調子をつけて繰り返し繰り返し歌っていたのだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄が湯から上つて来ると、耕二がボールをグラムに投げ込んではまたボールを手に取つて投げ込む――それを殆んど無意識に繰り返してゐるらしい音が、三畳の間でしてゐた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "煤の埃の中にして捨松ここに思ふ樣老店の主人三代の暖簾をくぐる町人は幾度同じ夢を見て繰り返したる榮落に街の繁華は見たるなり。",
              "citation": {
                "source": "煤掃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日床の中に寝たきりで、同じような単調な日を繰り返しているうちに、ふと思い出してこの本を読んでみた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ習い始めたメンデルスゾーンの「春の歌」の、左手でひく低音のほうを繰り返し繰り返しさらっていた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "読み終わった本を枕もとへ置いて、蒲団をかぶって聞いていると、音楽の波に誘われて物語の幻は幾度となく繰り返し繰り返し現われた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして同じ低音部だけを繰り返し繰り返しさらっていた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある豪家の老人が死んだ葬式の晩に、ある男は十二分の酒を飲んで帰る途中の田んぼ道で、連れの男の首玉にかじりついて、今夜ぐらい愉快に飲んだ事は近来にないという事をなんべんもなんべんも繰り返しながらよろけ歩いていた。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）それから店頭に出て、一ヶ月間、朝顏を植ゑました、朝顏を植ゑました、と朝から晩まで、雜誌の隅で繰り返し繰り返し言ひつづけてゐるのは、とても、たまらないのである。",
              "citation": {
                "source": "義務",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "／＼：二倍の踊り字（「く」を縦に長くしたような形の繰り返し記号）（例）おそる／＼-------------------------------------------------------　　　　上　あくまでも蒼く晴れ上つた空であり、渓谷には微風さへもない。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事を繰り返しているうちに眠りの神様は御出でになる。",
              "citation": {
                "source": "赤",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人が上がってきて、また一しきり、親子姉妹がいってかいないはかな言を繰り返した。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の端に立っては、亡き人の今朝からの俤を繰り返し繰り返し思い浮かべて泣いた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "何べんも何べんもそれを繰り返しては涙を絞った。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの珍しい言葉を覚えるために何遍も口の中で、シッタシズム、シッタシズムと繰り返した。",
              "citation": {
                "source": "鸚鵡のイズム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度この時前の同じ發言者が、その同じ言葉を繰り返した。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処へ行って見ても、同じような人間ばかり住んでおり、同じような村や町やで、同じような単調な生活を繰り返している。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時スタニスラウスは家族が皆見てゐる前で、さつきの肩の運動を繰り返してゐる。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタニスラウスは先づ心配げな顔に、堪忍の表情を蓄へられる丈蓄へて、矢張さつきの肩の運動を繰り返して、溜息を衝いて云つた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "女教師は、自分が尼寺に這入らうと思つた事があると云ふ話を、もう十一度繰り返してゐる。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタニスラウスは少しせき込んで同じ事を繰り返したが、今度も老僕には聞き取れなかつた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年はその音を遠くに聞くやうな心持で、又さつきの「真の恋愛をしてゐる以上は」と云ふ詞を口の内で繰り返した。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち、それらの雲が急速なリズムで何やら言葉をつぶやいてゐるのが聞えて來るやうな氣がしだして、私は無意識的な夢のなかでのやうに小聲で、それがどうなつて往くかは少しも知らずに、その言葉を繰り返して見てゐました。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "湊の対応ぶりに有頂天になった相手客が、なお繰り返して湊に盃をさし、湊も釣り込まれて少し笑声さえたて乍らその盃の遣り取りを始め出したと見るときは、ともよはつかつかと寄って行って「お酒、あんまり呑んじゃ体にいけないって云ってるくせに、もう、よしなさい」　と湊の手から盃をひったくる。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "くりかえして言うが、実現は困難でない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日露戦争の出征軍歌を、くりかえしくりかえし歌っては、庭を巡回して居ました、その一回の起点が丁度私達の立って見て居る廊下の堅牢な硝子扉の前なのです。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「困ったなア困ったなア」　お松はくりかえしくりかえし云って溜息をついた。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その態度は、掌を引っくりかえしたように、今、全然見られなかった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間ばかり椅子でボンヤリしているうちに、伍長と、も一人の上等兵とは、兵舎で私の私物箱から背嚢、寝台、藁布団などを悉く引っくりかえして、くまなく調べていた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつは押し入ると、獲物を求める、夜鷹のように、屋内を、隅から隅へ突きあたり、ひっくりかえした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
