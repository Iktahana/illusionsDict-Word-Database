[
  {
    "uuid": "eec513a5-968b-514b-a0c3-100e3e24d7a6",
    "entry": "口ずさむ",
    "reading": {
      "primary": "くちずさむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
