[
  {
    "uuid": "094ca212-3c33-5bff-8e19-01d9d7082e52",
    "entry": "黒紋付",
    "reading": {
      "primary": "くろもんつき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
