[
  {
    "uuid": "85db0b3d-e060-5da6-90d5-a597817208d5",
    "entry": "苦土",
    "reading": {
      "primary": "くど",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "magnesia",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ああすべて惱ましき光の中に桃の笑みてふくらむ情慾の一時にやぶれてどくどくと流れ出でたり。",
              "citation": {
                "source": "春晝",
                "author": "――敍情小曲――",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬や小鳥やの動物は、単に鼻を嗅ぎ合うとか、尾を振り合うとか、目をちょっと見合すとかいうだけで、相互の意志が完全に疎通するのに、人間は廻りくどく長たらしい会話をして、しかもなお容易に意志を通じ得ない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいにくどうも、お相手を申上げる者がいないので。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこのリリシズムは、解説的にくどくどと説明するよりは、こうした句の嘆息している言葉の音楽（声調の呼吸する抑揚感）によく現われている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はめいめい先年の絶大な恩を受けたこと、及びこの度の戦勝の祝をくどくどしく申し述べた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "冗談にしたつて、あくどすぎる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、私はここにくどいくらゐに念を押して置きたいのだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは言ふまでも無い事だが、それゆゑ、私は日本一の桃太郎を描寫する事は避け、また、他の諸人物の決して日本一ではない所以をもくどくどと述べて來たのだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "焚火焚火、人々は手足の関節から、血の循環が一秒一秒止まったように、意識された、今凍えて行くのだということも解る、早くどうかしろと神経が知らせてくれる、誰の顔を見ても、蝋のように白い、マッチ箱は燐寸一本さえ、烟を立てることなしに、空になったほど、何もかも、ビショ濡れになった。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "新築の市役所の前に青年団と見える一隊が整列して、誰かが訓示でもしているらしかったが、やがて一同わあっと歓声を揚げてトラックに乗込み風のごとくどこかへ行ってしまった。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの情熱を生のままでは、たとえこのまま二人は結ばれたにしろ、のちのあくどさが思い遺られる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもだんだん気をつけて見ると、そのきれいな水は、ガラスよりも水素よりもすきとほって、ときどき眼の加減か、ちらちら紫いろのこまかな波をたてたり、虹のやうにぎらっと光ったりしながら、声もなくどんどん流れて行き、野原にはあっちにもこっちにも、燐光の三角標が、うつくしく立ってゐたのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくどこへ行っても、行く先々に勇敢な彼等のための天地が開けて行きそうな気がする。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそこで始めて、多数の公開観覧所が卑猥なものやあくどい際物で堕落し切っているのに対して、道徳的なものをもって対抗させる機会を得るだろう。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこにもあくどいところやうるさいところがなくて上へ上へと盛り上がって行くような全篇の構成を観賞しつつ享楽することが出来るようである。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくどい蒼蠅さがわりに少なくて軽快な俳諧といったようなものが塩梅されているようである。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「此奴ッ、あんまりくどいと兄さん怒るぞ」　「怒って御覧」　「なにッ」　「これでしょう、嫌やァよ」　お静、かくして居た手紙を出す。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年の六月妻が乳癌の手術を受けて退院して來たあと、自分は二人の子供達のために今後の自重養生を聊かくどいほどに説き頼んだ。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「けれども君は、かの後の事はよく知るまい、まもなく君は木村と二人で転宿してしまったから……なんでも君と木村が去ってしまって一週間もたたないうちだよ、ばあさんたまらなくなって、とうとう樋口をくどいて国郷に帰してしまったのは。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上私は俳句の形式の必然性についてかなりくどくどしく述べて来たようであるが、そうしたわけは私の考えでは俳句の精神といったようなものは俳句のこの形式を離れては存立し難いものと考えるからである。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずいぶん俗悪な木版刷りではあったが、しかし現代の子供の絵本のあくどい色刷りなどに比較して考えるとむしろ一種稚拙にひなびた風趣のあるものであったようにも思われる。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "病室までの道は予想に反して長くどこをどう通っているのかじきに分らなくなってしまった。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そこで、くどいことは云わねえ、手短かに話を片付けるが、おまえさんは死んだ若い師匠とどうかしていたんだろうね」　弥三郎の顔色は変った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "くどくも申す通り、おっかさんがひどく心配しているんですから」と、お登久はすがるように頼んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどももしこれがしんとした蒼黝い空間でならば全くどんなにいいだらう。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹はゆさゆさとゆすれ大へんにむしあつくどうやら雨が降って来そうなのでした。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
