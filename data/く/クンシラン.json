        "examples": {
          "standard": [
            {
              "text": "玄関先に飾られた君子蘭が、鮮やかなオレンジ色の花を咲かせている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "母は趣味で君子蘭を育てており、毎年見事な花を咲かせるのが自慢だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "君子蘭は、その気品ある葉の姿から「君子」の名が付けられたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "代助の買つた大きな鉢植の君子蘭はとう／＼縁側で散つて仕舞つた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "代助の買った大きな鉢植の君子蘭はとうとう縁側で散ってしまった。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁側に垂れた君子蘭の緑の滴がどろどろになって、干上り掛っていた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
