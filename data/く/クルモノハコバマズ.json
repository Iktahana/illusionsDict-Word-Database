          "literary": [
            {
              "text": "・来る者は拒まず、去るものは追はず、求めず、斥けず。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "香具師、博徒、遊芸の輩、そういう下級の人達とも、厭うところなく交際ったが、去る者は追わず来る者は拒まずの、この人一流の処世法が、そういう者どもにも懐かしがられ、それで集まって来たのであろう。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "来る者は拒まず、去る者は追わず、と。",
              "citation": {
                "source": "少年の食物",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "去る者は追わず、来る者は拒まず――これが姿見井戸の金科玉条であった。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
