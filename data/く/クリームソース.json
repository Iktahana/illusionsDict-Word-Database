        "examples": {
          "standard": [
            {
              "text": "魚料理には、レモン風味のクリームソースがよく合う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "パスタに絡む濃厚なクリームソースが食欲をそそる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "シェフ特製のクリームソースは、様々な料理に使われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "クリームソースにすればフレッシクリーム一合を沸かして砂糖を加えてコルンスタチ小匙一杯余でドロドロにしたもの、スポンジソースにすれば玉子と砂糖を等分に混ぜて湯煎にしながら泡立ててカステラの原料のようにしたものです。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "メロンが出て、ポタアジュ、お代りをして、次スッポンのクリームソース、こいつを三つも食ったので、こたへた、鴨のジェリー、トルネードはお代りの元気なし。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビーフ串焼、チキンのクリームソース。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピラフは（芝海老とチキン、マッシュルーム）クリームソース掛け。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
