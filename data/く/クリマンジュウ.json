        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お土産に買ってきた栗まんじゅうは、甘さ控えめでとても美味しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖母が作る栗まんじゅうは、秋の訪れを感じさせる優しい味だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "温かいお茶と一緒に栗まんじゅうをいただくのが、私の至福の時間だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "學校の先生の所にある栗まんじゅう飛んで來いと、むつは心で云いました。",
              "citation": {
                "source": "クララ",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むつはそれを兩手ですくって口の中へ押しこんでうまいうまいと云いましたが、生唾が出るばかりで、栗まんじゅうの姿が口のそばで消えてしまうのです。",
              "citation": {
                "source": "クララ",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二日目には、客からお届けものの栗まんじゅうの入っていたボールの箱を、臨時金庫にしたが、たちまちこの箱も、札で一ぱいになって、箱はとうとうこわれてしまうというさわぎであった。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "パラダイスは、給仕が女の子だからと、頑固党は寄りつかず、梅月の栗まんじゅうは三十幾つがレコードだった。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
