    "definitions": [
      {
        "index": 1,
        "gloss": "instruction",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "新築の市役所の前に青年団と見える一隊が整列して、誰かが訓示でもしているらしかったが、やがて一同わあっと歓声を揚げてトラックに乗込み風のごとくどこかへ行ってしまった。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく、みんなは向う側の草の生えた河原に下り、六｜列ばかりに横にならんで馬から下り、将校の訓示を聞いていました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき川を越えて見に行った人たちも、浅瀬に立って将校の訓示を聞いていましたが、それもどうも面白くて聞いているようにも見え、またつまらなそうにも見えるのでした。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく、みんなは向ふ側の草の生えた河原に下り、六列ばかりに横にならんで馬から下り、将校の訓示を聞いてゐました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき川を越えて見に行った人たちも、浅瀬に立って将校の訓示を聞いてゐましたが、それもどうも面白くて聞いてゐるやうにも見え、またつまらなさうにも見えるのでした。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "風やや強し、聯隊長の訓示の後、合唱の聲大いに騰る。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "風やや強し、聯隊長の訓示の後、合唱の声大いに騰る。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれ両人がこの事情を報告すると、船長は全員をあつめて、後甲板の上から一場の訓示を試みた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "（この四月の地方官会議に多少の訓示ありしは、白井氏、前日井上神社局長より得たる秘密書類の写しで明らかなり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年に對する一片の訓示で特に奇拔なものではなかつたが其沈痛な低い聲が自分の胸を刺戟した。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵卒たちは荒くれ男、だが中隊長の体に手をかけるやうな、勇敢な男は一人もゐない、ズラリと兵士たちをならべてをいて中隊長は兵士の額にむかつて訓示をしそれが終ると、くるりと廻れ右させて、今度は兵士の後頭部に命令した、すると彼等は、しやにむに走つた。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "額を訓示で撫でられて後頭部を命令で殴られたやうに――。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "場主がまだ何か訓示めいた事をいうらしかったが、やがてざわざわと人の立つ気配がした。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――庭先の、少し高い所に立って、小作に向って簡単な「訓示」を与えた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校で訓示演説でもする事があつたら、ブライアン氏並に駄法螺と豪傑笑ひの効能でも述べ立てて、「どちらでも身体の薬になるから。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "着くとすぐ、みんな一列にならべさせられて、受持の看守部長の訓示を受けた。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この訓示が済んで、一行八人（電車事件の方は一足先きに来た）が別々に隣り合った室へ入れられた時、こんどは受持の看守が、「つまらんことで大ぶ食ったもんだな。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、出発に際して隊員に一場の訓示を与えた。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "が或る時県知事が巡回して来て講堂で一場の訓示演説のようなものがあった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが校長は演壇の下に進み出て不動の姿勢をとって、「県知事閣下」　と冒頭してその訓示への感謝の辞を述べた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（以上、烏三平）　これらの作品は、非常に複雑で熱い意欲をたくみに圧縮しつつ心を打つ力をもっていると思われますし、別な例では、ようやく終った所長の訓示ヒヤカシ半分に拍手浴びせワッと喊声あげて職場へ引き上げる。",
              "citation": {
                "source": "歌集『集団行進』に寄せて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "養生法の引札すら既に変てこなるに、その上に引札の末半分は三十一文字に並べられたる養生法の訓示を以て埋められたるを見ていよいよ山師流のやり方なる事を看破せり。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "県庁動員課の男の式辞や、校長の訓示はいい加減に聞流していたが、やがて、立派な国民服姿の順一が登壇すると、正三は興味をもって、演説の一言一句をききとった。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "五時からやって来たのであるが、訓示や整列の繰返しばかりで、なかなか出発にはならなかった。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ある日、東警察署の二階では、市内の工場主を集めて何か訓示が行われていた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "県庁動員課の男の式辞や、校長の訓示はいい加減に聞流してゐたが、やがて、立派な国民服姿の順一が登壇すると、正三は興味をもつて、演説の一言一句をききとつた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "五時からやつて来たのであるが、訓示や整列の繰返しばかりで、なかなか出発にはならなかつた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ある日、東警察署の二階では、市内の工場主を集めて何か訓示が行はれてゐた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡野等三人は中屋敷に帰つて、一同に鷹見の処置を話して、偵察の結果を待つてゐると、鷹見が出向いて来て、大切の役目だから、手落のないやうにせいと云ふ訓示をした。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おお、いい子、いい子、泣くんじゃねえ。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
