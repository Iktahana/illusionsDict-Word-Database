        "examples": {
          "standard": [
            {
              "text": "彼は授与された勲章と一緒に、立派な額に入れた勲記を居間に飾っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "勲記には受章者の氏名とともに、その功績の内容が詳しく記されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "厳かな式典の場で、勲章とそれを証する勲記が本人に手渡された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "陛下のお椅子は、中央の衝立を後ろにすえられ、左へ寄って、総理大臣が勲記と黒塗の箱とを各受章者へ手渡す一卓をおいて佇立するわけ。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『はせがわくんきらいや』という絵本に魂の奧をつかまれ、この作家の本を出したいと願った。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
