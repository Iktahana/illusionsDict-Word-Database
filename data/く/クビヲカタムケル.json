    "definitions": [
      {
        "index": 1,
        "gloss": "to incline one's head",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "主人がそんなら何を御馳走しようかと云って、首を傾ける。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "と首を傾けるのが癖だつたが、この時は震えて涙を滾した。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と俺は首を傾けるのであつた。",
              "citation": {
                "source": "木枯の吹くころ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてな」　と首を傾けるより早く横手を拍ッて、「あ、ああわかッた。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし物を飛びこえねばならぬとなるといつでも首を傾ける。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "のんびりとした表情は忽ちその顔から消え去り、いったい何を忘れたのだろうと彼は切りに首を傾ける。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "首を傾ける度に、骨が可なり大きな音を立てゝ鳴るのが、老僧の昔しからの特徴で、右に左に、首振り人形のやうにすると、骨がコトン／＼と鳴つた。",
              "citation": {
                "source": "ごりがん",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども三年前の屍体だと云うと、いずれも云い合わしたように、「さあ」　と小首を傾けるのだった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも、うは／＼してゐる、と師匠の首を傾けることが度々になつた。",
              "citation": {
                "source": "身毒丸",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚写真である、盲人は首を傾けるやうにして成瀬の様子を伺ひ、写真を覆つたパラフィン紙の音を聞くと、えッへへへへと笑ひながら、惚気る訳ぢやあないがとことはつた後、結婚当時の生活が如何に幸福に溢れてゐたかをくどくどと納得させるのであつた。",
              "citation": {
                "source": "癩を病む青年達",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これでは鯨群の発見は困難だ」と丹下船長は首を傾ける。",
              "citation": {
                "source": "鯨を釣る",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "理解のある第三者は決してその娘を憎まず、必ず同情の涙をもってこれを迎えるには相違ありませんが、しかしその原因がどうあろうとも、事実その娘の性質がひがんでいる以上は、これをただちに善良なる家庭に入れることには、ちょっと首を傾けるに相違ありません。",
              "citation": {
                "source": "融和促進",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　こけ猿の茶壺にきけ――対馬守が、口のなかでつぶやいて、小首を傾けるのを、じっと見つめていた一風宗匠は、やがて筆をとって懐紙に、左の意味のことをサラサラと書き流したのです。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へさ、さう言へば、若いお孃さんにしては、少し重いやうに思ひましたが」　後棒の老巧なのが小首を傾けるのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死骸の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へエ、そう言えば、若いお嬢さんにしては、少し重いように思いましたが」　後棒の老巧なのが小首を傾けるのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死骸の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だが、伜は兎も角、本人の糸が何んと申すか」　津志田谷右衞門はむづかしく首を傾けるのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美しき人質",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、極りが悪くて、とても書けそうもないんですもの」　女はそういって、本当に極り悪そうに小首を傾けるのでした。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "代作恋文",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛嬌のある夫人が、心持首を傾けるようにして、「いかが、お茶を差上げましょうか」と云った時、正隆は、半分は上の空で、半分は、普通の茶だと思い込んで、「有難う、戴きます」と返事をした。",
              "citation": {
                "source": "渋谷家の始祖",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人殺しと聞えた」　介添に来た片柳伴次郎が小首を傾ける。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴鹿山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議でたまらぬように、小首を傾ける。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間にこんなものを書きやがったんだろう」　運転手も小首を傾けるばかりだ。",
              "citation": {
                "source": "魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
