        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "われは既に一たび畫工に隨ひて、「クリア、ホスチリア」にゆき、昔游戲の日まで猛獸を押し込めおきて、つねに無辜の俘囚を獅子、「イヱナ」獸なんどの餌としたりと聞く、かの暗き洞の深き處まで入りしことあり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八四六年カンニングハム大尉の『印度ラダック通過記』に今日アルモラー城ある地で往古クリアン・チャンド王が狩すると兎一疋林中に逃げ入って虎と化けた。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "インドにもクリアン・チャンド王狩りすると兎一疋林に入りて虎と化けた、「兎ほど侮りゃ虎ほど強い」という吉瑞と判じてその地にアルモウー城を建てたという。",
              "citation": {
                "source": "十二支考",
                "author": "兎に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "今に連なる本のサイズはこのベネチア人のアイデアに従っているわけで、この本の大きさまで行き付ければ、そのマシンはどこででも使えるという提供すべきサービスの条件を一つ、クリアーできるだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "画面を縦長に使えないこと、器が重すぎること、カラーやクリアーな写真の表示ができないこと、検索のエンジンがパワー不足であること、等々。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、すぐ近くの山にＮＨＫの中継局があって、おそろしくクリアに受信できるのは、なんの因果なのだろう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリアブコという人は、死後二十時間を経た人間の死体から、心臓を切り出して、これを動かして見たところが約一時間、たしかに動き続けたということだ。",
              "citation": {
                "source": "恋愛曲線",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに、電源の問題をクリアーしたとしても不満の種はいくらでもある。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕の高校生活は二年で終わったのだ」と腹をくくり、かろうじて出席日数の下限をクリアーできるだけ、授業に顔を出した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察官という職は、その最低条件は明らかにクリアーしている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "テレビ画面に出ている文字をクリアする。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで新しくキーバッファーの中身をクリアするための機能を付け加えると、それが思わぬところでじゃまをして今度は別のプログラムに問題が生じた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルバのクリアティウス（Curiazi）家の兄弟三人とローマのホラティウス家の兄弟三人と相爭ひしが、ローマ方遂に勝ちてアルバの主權を奪ひたり傳説に曰。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ソコトラ島とクリアムリア群島との、丁度中間のところへ浮き上るつもりです」　と、金博士が、地図の上を指でおさえながらいった。",
              "citation": {
                "source": "のろのろ砲弾の驚異",
                "author": "――金博士シリーズ・１――",
                "note": "青空文庫"
              }
            },
            {
              "text": "訳のわるい故か、アンドレーエフの作として、あの独特の簡明さ、クリアー・カットを感じられず。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "また何に感じたか、ある時女史はスクリアビンのゾナーテ（多分第四番）を弾こうかと言った事もあった。",
              "citation": {
                "source": "久野女史をいたむ",
                "author": "兼常清佐",
                "note": "青空文庫"
              }
            },
            {
              "text": "エピクリアンの哲学者が彼の相手になる。",
              "citation": {
                "source": "『偶像再興』序言",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐ろしい物足りなさと、妙な誇らしさを持って、――宿帳に本名を記入した二人の神聖を、恐らく誰も信じてはくれまいということなどは夢にも思わずに、汽車の中までアンダーセンとスクリアビンと夏目漱石の話を持ち込み乍ら、――何という途方もない恋人達でしょう。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "第四次元の恋",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の言葉で言えば、それはスクリアビンの「法悦の詩」にも比ぶべきものだったでしょう。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "枕の妖異",
                "note": "青空文庫"
              }
            },
            {
              "text": "スクリアビンが、音楽に色彩と光線と、香料さえも採り容れて、聴衆のあらゆる官能を動員したように、「奇談クラブ」の舞台装置と、その責道具もまた、一つの立派な綜合芸術でした。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "第四の場合",
                "note": "青空文庫"
              }
            },
            {
              "text": "汎魔殿そのものであり、水晶のようにクリアで厳格な客観性をもっていた。",
              "citation": {
                "source": "ピックマンのモデル",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論のこと、この新事実は当時、今ここで感じる程にはクリアーカットな意味合いを持ってはいなかった。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "スクリアビン（Alexander Skryabin 1872―1915）　今世紀の初頭から第一次欧州大戦前まで、最も大胆にして革命的な音楽家として喧伝された。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時シャリアピンというものが日本に知られていず、輸入商も見当が付かなかったので、スクリアビンと間違えて、店頭に「ロシア当代大作曲家の歌ったレコード」と大きく貼り出して売ったという一口噺が伝わっている。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "スクリアビンの『法悦の詩曲』と『プロメテウス』（七五一五―八、名曲集一五二）は、他にレコードがないので重要性を持つだろう。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はスミルナに行って医師ペロスおよびプラトン主義者アルビヌスの弟子になり、コリントスではヌメシアヌスのもとで、アレクサンドリアではヘラクリアヌスの講義を聞き、キリキア、フェニキア、パレスチナ、クレタ島、キプルス島、へ行った。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "獣性と虚栄と悪習慣とを超越して「全き人格」に憧るる時はクリアハートとクリンヘッドとをもって「人格」を形づくる刹那である。",
              "citation": {
                "source": "霊的本能主義",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その死角を充分にクリアした位置から、道に対して浅い角度で、敷地の上に向けてコンクリートのスロープとなっていた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の書いたものが、すくなくとも一定の基準をクリアしているということが、それによってわかるから」「明日、きみが言っていた日本人の写真家に会えそうだよ」「彼はぼくにも電話してきたよ。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行艇の胴体に叩き割られて舞いあがる海の水は、四つのプロペラをきれいにクリアしていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
