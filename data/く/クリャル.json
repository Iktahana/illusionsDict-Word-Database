        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おのが心痛ばかりでも心臟が痛うなるのに、足下までが泣いてくりゃると、一｜段と胸が迫る。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「のう、甚太郎、どうしてくりゃるつもりじゃ？",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "※そなたまでがそのように　主をおもうてくりゃるもの　わしが心を推量しや　なんの因果に　このように　愛しいものか　さりとては……　新内の「明烏」だった。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついで、くりゃるな八幡鐘をと、こうやったら、どうするかね」「どうするも、こうするもないさ。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しんでおくりゃるよりは、ずんとうれしいぞ」「左様にお心も確とおすわり遊ばしているわが殿のこと。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "……されば足利殿にも、ずいぶん、よろこんでおくりゃるに相違ない」「わが足利家は都の戦後を。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
