    "definitions": [
      {
        "index": 1,
        "gloss": "worldly-wise man",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところで萩原氏は文学的苦労人である。",
              "citation": {
                "source": "萩原朔太郎評論集　無からの抗争",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いき」の所有者は、「垢のぬけたる苦労人」でなければならない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "身を捨ててこそ浮ぶ瀬あるものでして、と苦労人の忠告、その忠告は、まちがっています。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、したり顔して教える苦労人が多いけれども、私は、そうでないと思う。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人は苦労人で、ちゃんとできた人であるから、醜くとり乱すこともなく、三七、二十一日病院に通い、注射を受けて、いまは元気に立ち働いているが、もしこれが私だったら、その犬、生かしておかないだろう。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "お露が可愛がるのは無理が無えだ」「ハハハハ何故や、何故や」「何故チュウて問われると困まるが、一口に言うと先生は苦労人だ。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲人はちょっとあきれたが、怒った顔も見せず、姉はんをさし置いて妹御をかたづける法もなかったと筋を通して、御縁は切れたわけでもないと苦労人だった。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はいわゆる苦労人で、職業遍路（信心遍路に対して斯く呼ばれる）としては身心共に卑しくなかった。",
              "citation": {
                "source": "物を大切にする心",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　苦労人らしい口調で言った。",
              "citation": {
                "source": "酒の追憶",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり苦労人だよ、斎藤氏は。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「置候」の相馬小次郎は我武者に強いばかりの男では無い、幼少から浮世の塩はたんと嘗めて居る苦労人だ。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、「嘘吐き」と呼ばれ、君は、「苦労人。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　矢藤老人――ああ、年を取った伊作翁は、小浜屋が流転の前後――もともと世功を積んだ苦労人で、万事じょさいのない処で、将棊は素人の二段の腕を持ち、碁は実際初段うてた。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "関東名代の、強弓の達者で、しかも苦労人だと聞いたが違いない。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあまりの飽気なさにわたくしは却って世の苦労人というものに憎みさえ持つのでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の邸宅が現わす感じのように典型的の英国人であるガルスワーシーは一見｜気難しやのようで実は如才ない苦労人だということがつき合って行くうちに判って来る。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲人は驚いたが、怒った顔も見せず、なるほど、姉さんをさし置いて妹御をかたづける法もなかったと筋を通して、御縁は切れたわけでもないと、苦労人だった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "わての考えでは、あんたがこっちへ帰ったはる限り、意地からでも潜りはれへんと思うな」　蝶子は苦労人らしく、しみじみした口調で言った。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "花嫁にあるまじい振舞いだったが、仲人はさすがに苦労人で、宇治の螢までが伏見の酒にあくがれて三十石で上ってきよった。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしはそんな苦労人じゃアございませんよ」と、僕の妻は顔を赤くして笑った。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そりゃア、これまでにも今度のようなことがあったし、またいろんな芸者をつれ込んで来られたこともあったから、その方では随分｜苦労人になった、わ」「ほんとです、ねえ、私も若い時は随分そんな苦労をさせられましたよ。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人は苦労人だなとすぐに子路は感じた。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明け暮れ黄河の水ばかり見て過した十年余りの中に、気まぐれで我が儘だった白面の貴公子が、何時か、刻薄で、ひねくれた中年の苦労人に成上っていた。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔から偉人とか傑士とか、又は苦労人と呼ばれる人々は、多少に拘らず無意識の裡にこの間の消息を飲み込んでおったもののようであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "話を聴くと、おきんは「蝶子はん、あんた維康さんに欺されたはる」と、さすがに苦労人だった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ね、小児だって、本場の苦労人が裸で出張ってる処へ、膝までも出さないんだ、馬鹿にするないで、もって、一本参ったもんです。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
