          "literary": [
            {
              "text": "暫くさうしてゐたが、牡丹の根方のくろぼくの上へ止つて蜘をおろした。",
              "citation": {
                "source": "べつ甲蜂",
                "author": "横瀬夜雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜂はくろぼくの日あたりのいい陰へ下りて口で土を掘ぢくり出した。",
              "citation": {
                "source": "べつ甲蜂",
                "author": "横瀬夜雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "穴が出來ると、蜂はくろぼくの上へ置いた蜘をかかへて、またはひつて行つた。",
              "citation": {
                "source": "べつ甲蜂",
                "author": "横瀬夜雨",
                "note": "青空文庫"
              }
            }
          ]
