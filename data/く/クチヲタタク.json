    "definitions": [
      {
        "index": 1,
        "gloss": "to speak brazenly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "女給達は、今来たばかりの常連らしいひどく冗談口を叩く男のまはりにみんな行つてしまつた。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生大きい口を叩く癖に。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀のようにむっつりとしていた男が見ちがえるほど陽気になって、さかんにむだな冗談口を叩く。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の夜遅くなってとんとんと門口を叩く音に、総領女が眼を覚した。",
              "citation": {
                "source": "白い花赤い茎",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚兵衛は、日頃大口を叩くが、戦場では殊のほか手に合わぬ男じゃ」という噂が陣中に伝わったらどうしようかと考えた。",
              "citation": {
                "source": "恩を返す話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "樽野の家は遊園地へ差しかゝらうとする丘の中腹にある一軒家で村とは半里近くも離れてゐるから同村の者とは称び憎くかつたが、その素晴しい村の大景気は恰も光の翼を延して此処の戸口を叩くかのやうであつた。",
              "citation": {
                "source": "村のストア派",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういえばなァ」　というので、半之丞説が俄かに有名となると共に、死んだ権四郎にひどい悪口を叩くものが日に日に多くなった。",
              "citation": {
                "source": "くろがね天狗",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒を喰つた時などは氣が大きくなつて、思切つて竹山の蔭口を叩く事もある位で、殊にも此男が馴々しく話をする時は、昔の事――強ひて自分で忘れて居る昔の事を云ひ出されるかと、それはそれは人知れぬ苦勞をして居た。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "怖れて居ない許りか、好んで敗けず劣らず無駄口を叩く。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒を喰つた時などは気が大きくなつて、思切つて竹山の蔭口を叩く事もある位で、殊に此男が馴々しく話をする時は、昔の事――強ひて自分で忘れて居る昔の事を云ひ出されるかと、それは／＼人知れぬ苦労をして居た。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟子達が大掾について浄瑠璃の稽古をする時は、婆さんはいつもちよこなんと側に坐つて、横合からさんざ憎まれ口を叩く。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで悪口を叩くのをやめて、再び教父の方へ向きなほつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "元は佃島の者で、ここへ引っ越して来てからまだ二年ばかりにもならぬのであるが、近ごろメッキリ得意も附いて、近辺の大店向きやお屋敷方へも手広く出入りをするので、町内の同業者からはとんだ商売｜敵にされて、何のあいつが吉新なものか、煮ても焼いても食えねえ悪新だなぞと蔭口を叩く者もある。",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "千代が門口を叩くを聞き、女房が物言はんとするを、右手にて後より抱き、左の袖を女房の口に当て、無理に引つ立てて二重に上り、若君を出して奥に伴はせ「はい、只今、誰ぞいぬか、無用心千万な、只今」といひ、刀を左に提げ、右手にて拝み、涙をふき、戸を開く。",
              "citation": {
                "source": "両座の「山門」評",
                "author": "三木竹二",
                "note": "青空文庫"
              }
            },
            {
              "text": "合図の数だけ入口を叩くと、重い木製の扉が静かに内に開いた。",
              "citation": {
                "source": "見えざる敵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "平然として取らせながら、「玉菊のお吉でござんすなどと、大口を叩くお前だが、やっぱり女十八番の、喚いて泣いて胸倉を取って、こづき廻して引っ掻いて……という醜態をさらすそうな。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……で、そのもう一つの理由というやつは……」　ヤケかそれとも策略あってか、三十郎は大地へ寝たまま、ペラペラとへらず口を叩くのであった。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり、軽口を叩く後見がこの辺へ入らなければ、太夫さんもやりにくかろうし、合の手が間が抜けるだろうという心配は無用の心配で、米友は米友らしい一人芸で、客を唸らすことができるものと認められます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "青梨の子供が、着物を脱ぎはじめると、おいおい君、おいおい君、抱き石をやろうかと、また悪まれ口を叩く。",
              "citation": {
                "source": "食べもの",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今その唐松尾に登ろうとして、汽車が塩山に着くまで一人旅のつれづれなる儘に余計な無駄口を叩くのである。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私はこうして無駄口を叩くのが好きでしてね」とソーボリは橇に坐りながら、「閣下、マッチを貸して下さい。",
              "citation": {
                "source": "妻",
                "author": "ЖЕНА",
                "note": "青空文庫"
              }
            },
            {
              "text": "首縊りの力学と云う脱俗超凡な演題なのだから傾聴する価値があるさ」「君は首を縊り損くなった男だから傾聴するが好いが僕なんざあ……」「歌舞伎座で悪寒がするくらいの人間だから聞かれないと云う結論は出そうもないぜ」と例のごとく軽口を叩く。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな無駄口を叩くとまた負けるぜ」と主人は迷亭に注意する。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "無駄口を叩く学者や、蓄音機の代理をする教師が露命をつなぐ月々｜幾片の紙幣は、どこから湧いてくる。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は、こういう非常のときにも、学者らしい執着を忘れずに蒼｜褪めた顔をしながらいかにもそのひとらしく、こんな減らず口を叩く。",
              "citation": {
                "source": "犂氏の友情",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "利いた風な口を叩くのは止しな。",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あにを、憎まれ口を叩くでい！",
              "citation": {
                "source": "妻恋行",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜助　へっ、ドン百姓のくせに、きいた口を叩くからよ！",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "植木屋の戸口を叩くと、戸は中から開いて、バアと出たのは主人の松五郎です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死の矢文",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
