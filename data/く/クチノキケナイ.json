        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ものをいう目をした、口のきけないすて子の、かわいいおまえをね」　こう言って、王子はお姫さまの赤い唇にキスをしました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だけど、海はこわくないだろうね、口のきけないすて子さん」　おとなりの国へ出かける、りっぱな船の上に立ったとき、王子はお姫さまに、こう言いました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "口のきけない子供は、死んでから苦痛を訴え始めた。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウツカリ口のきけない世の中だとおもひました。",
              "citation": {
                "source": "編輯室より（一九一五年三月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時とちつとも変りのない、きよろんとした大きな落ちつきのない眼、気短かさうな筋の立つた前額、うまく口のきけない、話すたびに何かにひつかゝつたやうな動きをする口もと、――それらは何もかも昔のまゝだつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "口のきけない動物が屠殺の為めに肥らせられるやうに、彼女はその為めに用意される。",
              "citation": {
                "source": "結婚と恋愛",
                "author": "エンマ・ゴルドマン",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、人間さえ食えないのだから、口のきけない動物は、みじめなもんです。",
              "citation": {
                "source": "道の上で見た話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "口のきけない者だから、秘密のもれる恐れは断じてなかろう……というので、選ばれてこの母娘の世話をすることになったのだが。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こけ猿の茶壺に封じこめあるもの也」　口のきけない一風宗匠、筆談で答えた。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「畜生に対しては、かわいそうな、口のきけないものだと思ってがまんするけれど、おまえではまったく気ちがいにさせられる」と、こうかれは言って、芝居のように両手を空に上げて、急にまた下に下ろして、はげしくももを打った。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子さん、許してくれるでしょう」　たやすく口のきけないのは、伸子も自分がわるかったと考えているからであった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "字は一寸も見えません、口も思わぬ処でひっかかって妙な事になります、こう云う障害は人間の体の植物性神経と云うもの（自分の意志のままにならない神経なのだそうです）の疲労で口のきけないのも言葉の記憶が無いのではなく、発音の筋肉をつかさどる神経の故障だそうです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "口のきけない者ですが　どうかお願いもうします。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
