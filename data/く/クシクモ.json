        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人の世の果敢無さ、久遠の涅槃、その架け橋に、わたしは奇しくも憩い度い……さあ、もう何も言わないでね。",
              "citation": {
                "source": "或る秋の紫式部",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「既報“人生紙芝居”の相手役秋山八郎君の居所が奇しくも本紙記事が機縁となって判明した。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに恋愛なる一物のみは能く彼の厭世家の呻吟する胸奥に忍び入る秘訣を有し、奇しくも彼をして多少の希望を起さしむる者なり。",
              "citation": {
                "source": "厭世詩家と女性",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は二作を読み了りける後、奇しくも実想相分るゝ二大家の作に同致の跡瞭然見る可き者あるを認めぬ。",
              "citation": {
                "source": "「伽羅枕」及び「新葉末集」",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇しくもあざなはれたるわが運命かな。",
              "citation": {
                "source": "清見寺の鐘聲",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上この文を草している今日は又奇しくも母が愈々掘り返しをはじめましたと云って来た。",
              "citation": {
                "source": "故郷を想う",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "音そのものが既におのれの反響のなかに悲哀と寂莫の声を聴きながら、奇しくもそれに耳傾けてゐる。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど天空は息づいてをり、万象が奇しくも、荘厳である。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "暖かい夏の夜、人も獣も鳥も、万象ことごとく眠りに落ちて、ひとり神のみ厳かに天と地とを見守り、その袍の袖を荘重にはためかす時、ドニェープルは奇しくも美はしい。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "その本尊の顔は奇しくも暢びやかなうちに鋭い近代女性を示している。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "異性すべて異性の手より受取るは、温かく、やさしく、匂はしく、派手に、胸の血の奇しくもときめくよ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして、こゝ、灯は暗し、某々劇場の花ランプさへ、幻に、奇しくも美しい。",
              "citation": {
                "source": "偶感一束",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "湘南の一漁邑、こゝ、燈は暗し、某々劇場の花ランプさへ、幻に、奇しくも美しい。",
              "citation": {
                "source": "偶感一束",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇しくもあるかな、蝋石の壁に這ひゆく導線は越歴幾の脈の幾螺旋、新なる代に新なる生命傳ふる原動の、その力こそ淨妙華、法音開く光明の香ぞ人に逼り來る。",
              "citation": {
                "source": "有明集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜作の最後に就いては、当時猟友として行を共にして奇しくも生命を助かった上高地の庄吉が詳しく物語ってくれる。",
              "citation": {
                "source": "案内人風景",
                "author": "百瀬慎太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇しくも宗久と通太郎とが、名も金もいらないという同じ鑑定を得ていたのである。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十四　ロッテナム美人術",
                "note": "青空文庫"
              }
            },
            {
              "text": "法外流のつかい手、下谷の小鬼と名を取った伴大次郎は、奇しくもこの田万里の出生だという。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四歳で府立三中に入学、この学校からは芥川龍之介が学び、奇しくも堀辰雄もここを卒業していた。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "けわしくにらんでいるその奥で見る者の心をぎゅっと捕え、底知れぬ闇の世へ引っさらって行くような奇しくも甘い目つき。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇しくもまたひにくなことである。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてゴーガンは奇しくも仏陀の教をひそかに憧れているのである。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とこしえのよろこび、ありとある人のこころをうるおす、奇しくもわきたつ力、いのちの杯をもやす。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆがんだ燭台に立っているろうそくの燃えさしは、奇しくもこの貧しい部屋の中に落ち合って、永遠な書物をともに読んだ殺人者と淫売婦を、ぼんやりと照らし出しながら、もうだいぶ前から消えそうになっていた。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇しくも、私の銭形平次と同じである。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおこの章に述べられている人間観は、奇しくも老驕にして係ぐべからざるものは、其れ唯だ人の心か」とある（以後『荘子』からの引用は、すべて福永光司『荘子』新訂中国古典選７、８、９巻、昭四一、朝日新聞社、による）。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の目のまえに登場するのが、奇しくも姉の死後になってしまった事実が、ストーリーの本質に即していなくてはいけない。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その一つ一つの構造も決してあり来たりのものではなく、園主治良右衛門の不思議な天才で、悪夢の中の風景の様に、或は西洋お伽噺の奇怪な挿絵の様に、或はクリスマスのお菓子製の宮殿の様に、奇しくも作り上げたものなのだ。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、奇しくも。",
              "citation": {
                "source": "私本太平記",
                "author": "筑紫帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ以上うつくしくもなければ、これ以下に卑劣でもない。",
              "citation": {
                "source": "碧眼托鉢",
                "author": "――馬をさへ眺むる雪の朝かな――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　同時に、伊豆守のせきたてるような命令があったものでしたから、ここにいよいよわれらがむっつり右門の捕物第五番てがらが、はからざるときに計らざることから、くしくも開始されることにあいなりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
