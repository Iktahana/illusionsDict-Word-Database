    "definitions": [
      {
        "index": 1,
        "gloss": "(living) from hand to mouth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
