        "index": 1,
        "gloss": "block of multiple characters arranged in a space equivalent to that of a single character",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
