        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうして、王女が窓からすべりこむ、魔法つかいが引っかえそうとするとたん、ぎゅッと魔法つかいのながい黒ひげをつかむがはやいか、剱をひきぬいて、そのにくらしい顔をした首を、肩のつけ根からずばりと切りおとしました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "たのむからあけねえでくだせえ」　黒ひげの男が、「外で戸をたたいているのが、透明人間だというのか。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "警棒をもってくればよかった」　黒ひげの男も警官のあとにつづき、「ねえ、かまわないから、かんぬきをぬいてドアをおあけなさい。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　黒ひげの男は身がまえ、さっとピストルを背にかくした。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒ひげの男は、ぐっとピストルをにぎりなおして、調理場のほうをにらんだ。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒ひげの男のピストルがなった。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　黒ひげの男が、ふいに、きょろきょろとあたりを見まわしてさけんだ。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ようし、おれがひきうけた」　黒ひげの男は、ひと声たかくさけんで、警官の肩ごしにピストルをつきだし、つづけざまに五発、透明人間のいるらしい方向にむけてぶっぱなした。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "五〇ポンドでどうだい」「高すぎる」　黒ひげ船長が意味深に片目をつぶった。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかり黒ひげ船長に身をゆだね、船長も契約した手前、世話をするだろう。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで甲板に上がって、黒ひげ海賊に文句を言おう。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
