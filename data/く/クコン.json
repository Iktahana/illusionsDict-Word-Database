[
  {
    "uuid": "ffebd783-52e3-5316-93b7-035766873abf",
    "entry": "九献",
    "reading": {
      "primary": "くこん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
