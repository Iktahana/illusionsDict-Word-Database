[
  {
    "uuid": "33f464b0-2616-5c30-aa1d-138fab3c3c37",
    "entry": "苦になる",
    "reading": {
      "primary": "くになる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ラ行"
