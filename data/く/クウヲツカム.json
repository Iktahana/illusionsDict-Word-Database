    "definitions": [
      {
        "index": 1,
        "gloss": "to grasp at the air",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
