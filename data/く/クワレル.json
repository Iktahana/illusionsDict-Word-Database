        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それだのに、それと比べて我家の原始的な雑煮が少しも負けずにうまく食われるから全く不思議なものである。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでわれわれは身を投げるか、弁慶の薙刀の※となるか、夜鷹に食われるか、それともまた鍋焼うどんに腹をこしらえて行手の旅を急ぐかである。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　米吉は、とうとうカンシャク玉を破裂さした、生活の糧まで食われるという法はなかった。",
              "citation": {
                "source": "名勝地帯",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は白木屋の階上で蕎麦が食われる。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四　食うか食われるか　亀と亀とが角力をとって負けたほうが仰向けに引っくり返される。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで食うか食われるかの二つのうちの一つしか道がない。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよおれも食われるだけだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "酋長のむすこがライオンに食われる場面がある。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「食われる小魚も可哀そうになれば、食うわしも可哀そうだ。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は実は宣伝書にも云って置いた通り充分詳しく論じようと思ったがさっきからのくしゃくしゃしたつまらない議論で頭が痛くなったからほんの一言申し上げる、魚などは諸君が喰べないたって死ぬ、鰯なら人間に食われるか鯨に呑まれるかどっちかだ。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "負けると食われるぞ。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう一足でおまえたちみんな頭をばりばり食われるとこだった。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "武田麟太郎が鰐を食ったのなら判るが、鰐に食われるようなそんな武麟さんかねと笑った。",
              "citation": {
                "source": "武田麟太郎追悼",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――でも人に食われる方の……なぞと言いながら、でも可恐いわね、ぞっとする。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、餅に混ぜて食えば食われる土が岩層の間から採れたともいう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そろそろ蚊屋を吊らなくちゃあ、かかあは好いが、子供が食われるだろう」こんな事を思っては、又家の事を考えて見る。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はいらないと蚊に食われるよ」　言いながら、彼はなくなった妻が何の遠慮もない恋仲だったことをふと想いだしていた。",
              "citation": {
                "source": "蚊帳",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "また面白きは鬼までも虎に食われる事が『風俗通』に見える。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐずぐずしていると、狼に食われるぞ。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "又五郎は中村紫琴の遺子で、大阪では子役中の麒麟児と呼ばれ、鴈治郎ですらも彼に食われるとかいう噂であったが、初上りのせいか、曾我の対面の鬼王と鞘当の留女の二役だけで、格別の注意をひかなかった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな死人を問題にしていちゃ、マルキシズムに食われるだけさ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日食われるか明後日食われるかあるいはまた十年の後に食われるか鬼よりほかに知るものはない。",
              "citation": {
                "source": "倫敦塔",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "水葬の時に肴につつかれるのはそれ程でもないが、ガシガシと狼に食われるのはいかにも痛たそうで厭やである。",
              "citation": {
                "source": "死後",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ死ぬ命だし、一切の望みは失せる、塚蟻にでも野の狼にでも食われるがいい。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "メモリー間で情報を動かそうとする際、ＣＰＵを介して行うとマイクロコンピューターの処理能力がその作業のために食われることになる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＣＰ／Ｍ―86なりＭＳ―ＤＯＳなりを使おうとすれば、まずＯＳそのものにメモリーをかなり食われることを覚悟せざるをえない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の引出しから私だけの「つやぶきん」を出して本棚や机をふいて、食堂から花を持って来たり、鼠に食われる恐ろしさに仕舞って置く人形や「とんだりはねたり」を並べたりする。",
              "citation": {
                "source": "秋風",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一｜日食べ物の無い穴の中に引っ込んだまま、おなかをへらして死ぬか、外に出て猫に食われるか、ほかにどうしようもございません。",
              "citation": {
                "source": "猫の草紙",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんたが、すくわれるんなら、わたしたちだって、すくわれてもいい。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "このヘンデルが、伝染病のばいきんを見つけてくれたので、村の人たちは、病気からすくわれるようになりました。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
