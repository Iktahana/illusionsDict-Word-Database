        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "落葉松の林中には蝉時雨が降り、道端には草藤、ほたるぶくろ、ぎぼし、がんぴなどが咲き乱れ、草苺やぐみに似た赤いものが実っている、沢へ下りると細流にウォータークレスのようなものが密生し、柵囲いの中には山葵が作ってある。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "△犬ころ草がやたらにはびこる、その穂花が犬ころのやうな感じで好きな草だ、其中庵の三雑草として、冬から春はぺん／＼草、春から夏は犬ころ草、秋はお彼岸花をあげなければなるまい、そのほかに、草苺、青萱、車前草、蒲公英。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "草苺のうつくしさよ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴかりを見たのは、緑の中に草苺の光るのを見つけて一つ二つ頬ばったところだった。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "人によっては草苺と呼んでいれど、これも別にクサイチゴがあるから名が重複して困る。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今迄に私は野生の草苺を三種類見た。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "地びたに出ていた、くさいちごの実を、ほんのふたつ三つ口にしただけでしたものね。",
              "citation": {
                "source": "ヘンゼルとグレーテル",
                "author": "HANSEL UND GRETEL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
