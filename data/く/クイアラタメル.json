    "definitions": [
      {
        "index": 1,
        "gloss": "to repent",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「そうすると、わたしは罪を悔い改めることができなくなりますからね。",
              "citation": {
                "source": "赤いくつ",
                "author": "DE RODE SKO",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその罪を悔い改める事によって等しく選ばれた神の僕となりうるのです。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来は一つの宗教運動で、公衆の前で自分の罪を告白し悔い改めることを眼目としたが、告白の内容は性的なものが多く、オックスフォード大学からの抗議でオックスフォード運動という名前を使うことをやめさせられた。",
              "citation": {
                "source": "再武装するのはなにか",
                "author": "――ＭＲＡについて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "悔い改める望のない男であるから、必ず冥々の裏に神罰を蒙るであろうというのである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　岡野は、返辞も出来ないで、罪人のように、悔い改めるように、卓子の上に顔を伏せていた。",
              "citation": {
                "source": "操守",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「神の国は近づけり、汝ら悔い改めて福音を信ぜよ」ということがイエスの説教の基本でありましたが、しからば人はいかにして悔い改めることを得るかという、その実行方法を示されたのがこの奇蹟であります。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは理屈っぽい霊とか、あるいは世の中の快楽の霊とか、これを追い払わなければ我々は悔い改めることもできない。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "誠実な心でなくては悔い改めることができない。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分の罪を責めたヨハネの教えをも聴くといういわゆる政治家的な腹の大きいところを見せたにとどまり、神の御前に己がたましいを砕いて自分の罪を悔い改めることをなさなかったのです。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "教えを説くだけで人々が悔い改めるなら、神の国の建設はこんなに困難ではないはずだ。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけでは悔い改めることのできないほど、人々は神に背いている。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は自分の死を見て、これはイエス自身の罪のために死んだのではない、我々の罪をイエスが身に受けて死なれたのだ、ということがわかって始めて悔い改めることができるであろう。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにその悔い改めることすら、人にはできないのです。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾なんぞ始めから魂が腐つてゐて悔い改める心なんぞ爪の垢程だつて持つてやしない。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し慢心してゐた當時の私は、徹へれば徹へるだけ、反省して悔い改めることの代りに、何か先生に反抗しようとしでもするやうに、いろんなものにいろんなことを書き散らした。",
              "citation": {
                "source": "知られざる漱石",
                "author": "小宮豐隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "トリタイアがトリガーセンに悔い改めるよう説得しましたが、決してそうしないでしょう。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシヤだって神を信ずる国だから、屹度悔い改める」　と安部君は真剣だった。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
