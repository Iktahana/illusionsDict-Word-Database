        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「首なし死体を投り込んだんだよ。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして海岸のけむつた柳のかげで首なし船のちらほらと往き通ふ帆でもながめてゐようあるいは波止場の垣にもたれて乞食共のする砂利場の賭博でもながめてゐよう。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでも今年は、去年のように、金色夜叉やロクタン池の首なし事件の覗きからくりや、ろくろ首、人魚、海女の水中冒険などの見世物小屋が掛っているはずだ。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから笠井氏の報告で名高くなった阿波の首なし馬の伝説があって、盗人に首を刎ねられた馬の幽霊だ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏に首なし、杓に底なし、とにかく異風景。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲団で栖方の顔が隠れているので、首なしのようにみえる若い胴の上からその臍が、「僕、死ぬのが何んだか恐くなりました。",
              "citation": {
                "source": "微笑",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう下層の労役に服している婦人は姑く措くとするも、明治の教育を受けたという中流婦人の多数がやはり首なし女である。",
              "citation": {
                "source": "婦人と思想",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君、どこかに首なしが、上がったと云うじゃないか」　ところが、その警部補は不思議なことにも、男の横顔に、凝っと視線を据えたまま動かない。",
              "citation": {
                "source": "地虫",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが頽勢の方の男が一向騒がず「どうぢやは大蛇の首なしぢや」と呟いてゐるのをきいて噴きだしたことがあつた。",
              "citation": {
                "source": "市井閑談",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草寺の観音堂もない、仁王門もない、粂の平内殿は首なし、胸から上なし、片手なしである。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり、首なしの生き物なのだ。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが火星人は、まさしく首なしで生きているのだった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "バラバラ事件、首なし屍体、そんなのがあると、みんな小岩とちごうか？",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "この亡霊はどの家の炉ばたでも、「スリーピー・ホローの首なし騎士」という名で知られている。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、幽霊の話、鬼の話、化け物の出る野原、小川、橋、屋敷、それから特に「首なし騎士」、彼女たちがときとして呼ぶところによれば、「スリーピー・ホローの早駈けヘッセ人」の話だった。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、さまざまな物語のうちでいちばん主だったものは、スリーピー・ホローの立役者幽霊、首なし騎士だった。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここが、首なし騎士の好んであらわれたところで、ひとびとが彼に出くわすのもここであった。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これがあんたのなら、べつのにしよう」べつの樽のところへ行ってかがむと、首なしが言った。",
              "citation": {
                "source": "首なし",
                "author": "TRUNK-WITHOUT-HEAD",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その樽はわしのものだ」「ぜんぶあんたのものってわけじゃないだろう、べつのにするよ」またべつの樽のところへ行き、注ぎはじめたところへ首なしが言った。",
              "citation": {
                "source": "首なし",
                "author": "TRUNK-WITHOUT-HEAD",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それはわしのだ」「かまうものか、おれはクルーシュキーンをいっぱいにする」そのとおりにして、貧しい男のところに戻ったが、首なしを見たことは言わなかった。",
              "citation": {
                "source": "首なし",
                "author": "TRUNK-WITHOUT-HEAD",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その樽はわしのものだ」顔を上げると首なしがいたので、水差しとろうそくを取り落とし、ドーナルのところへ飛んで帰った。",
              "citation": {
                "source": "首なし",
                "author": "TRUNK-WITHOUT-HEAD",
                "note": "青空文庫"
              }
            },
            {
              "text": "「首なしを見たかね？",
              "citation": {
                "source": "首なし",
                "author": "TRUNK-WITHOUT-HEAD",
                "note": "青空文庫"
              }
            },
            {
              "text": "証人がひつようなら、裁判でおまえの後ろに首なしの姿で立って、みんなに見えるようにしてやる。",
              "citation": {
                "source": "首なし",
                "author": "TRUNK-WITHOUT-HEAD",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もっと証拠がないと、この男が有罪かどうかはわからない」「わしがいるぞ」ドーナルの後ろに首なしがあらわれて声をあげた。",
              "citation": {
                "source": "首なし",
                "author": "TRUNK-WITHOUT-HEAD",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの方を殺しました、首はあの方の部屋の暖炉の床下に埋めてあります」それで裁判官は執事をしばり首にするよう命令し、首なしはいなくなった。",
              "citation": {
                "source": "首なし",
                "author": "TRUNK-WITHOUT-HEAD",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えていたような恐ろしい顔も、みにくい顔もあらわれてはこずに、男の顔はかき消え、首なしの怪人がそこにつっ立っていた。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "首なしの化けものは、そのまま、玄関にかけだしていった。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしにはいってきやがった」　首なしの化物の、首のあたりと思われるあたりから、怒った声がきこえてきた。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "首のない男「こうさんするよ」　なにを思ったのか、巡査をおさえつけていた手をはなして、首なし男は立ちあがった。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
