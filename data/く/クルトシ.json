    "definitions": [
      {
        "index": 1,
        "gloss": "the coming year",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "女に逃げられた時、来る年の受験日は四ヶ月のむかふにあつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の夜路に深山路かけて、知らない他国にうことはまた、来る年の首途にしよう。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "来る年も来る年も木之助は彼女を味噌屋の家で見た。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうふうにかれらが続けて来る年は、その後も続けて来るものだ。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "力不滅論のようなものも、我々が知り得る天体関係（甚だ狭い）の中の太陽系（甚だ小な）の中の地球（甚だ小な）の中で我々が知ることの出来る年代範囲（甚だ短い）の中の現時（いよいよ短小な）に於いて我々が理解する現象関係の中で真実と見えるのであって。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "来る年の幸福を祈り喜びごと万づ祝ひのばさん。",
              "citation": {
                "source": "秋・二日の話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "来る年も来る年も、来る月も来る月も、毎日毎日、他人の下駄をいじるという、単調な生活を繰り返していったならば、どんな人間でもあの二人の爺のように、意地悪に無口に利己的になるのは当然なことだと思った。",
              "citation": {
                "source": "出世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度来る年の正月には同人の新しい雑誌も出来ようというところであった。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "来る年を祝福して、よかれあしかれ是好年として積極的に迎える心持になりました。",
              "citation": {
                "source": "歳々是好年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この画家の顔を見ていると、きまりで岸本の胸に浮んで来る年若な留学生があった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地がせまくなったところへ、海外から大ぜいの同胞がもどって来たので、たいへん暮しにくくなり、来る年も来る年も苦しんだことを思い出した。",
              "citation": {
                "source": "三十年後の東京",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "来る年の草の芽はどこにもとめよう。",
              "citation": {
                "source": "私の果樹園",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年はもう三回忌の来る年だから、今からお前の傍に置くよ」といった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――や、除夜の鐘や、そやそや、……うちの商売もんで、来る年の運勢を占うたげまひよ、それを途々考へて来たんや」　彼は立ち上つて、はい、はい、お狐さまと云ひながら、狐の檻を部屋に運び入れた。",
              "citation": {
                "source": "大凶の籤",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時も変らない、来る年も来る年も。",
              "citation": {
                "source": "現代小説展望",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "来る年々の夏は、なるほど暑いものではあったが、しかし紺碧の大穹と、純白な雲の峰と、身軽な生活とから、私の好きな気候であった筈なのだが――。",
              "citation": {
                "source": "腐った蜉蝣",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　冬祭りの古義――たまふり祭り此山人が里へ下りて来る年の暮は、古くは霜月でした。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "小作に入れてる土地から上って来る収入を学費にして、来る年からは都に出かけようかと思っていた。",
              "citation": {
                "source": "秋の幻",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "不良少女と言つても、大それたことの出来る年頃ではない。",
              "citation": {
                "source": "孤独閑談",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつとはなしに釣銭の上前をはねる事も覚え、故意と主人に聞える様な所で厭味を云う事も平気になって来ると、丁度すべてに変化の来る年頃にあったお関は種々の生理上の動揺と共に段々川を流されて行く砂の様に気付かない内に性質を変えられて来て居た。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今年は悲しみをおいかけるように、よろこびがやって来る年らしいですが、その変化がはじまったようです。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "客は、時々来る年少技術家にて、白襟の下着に、市楽三枚重ね、黒｜魚子五つ紋の羽織に、古代紫の太紐ゆたかに結び、袴の為めに隠れて、帯の見えざりしは遺憾なりしも、カーキー色のキヤラコ足袋を穿ちしは明なりし。",
              "citation": {
                "source": "元日の釣",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "来る日も、来る月も、来る年も、空閨の連続である。",
              "citation": {
                "source": "猿ヶ京",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくるとしの元旦には、もっとめでたいことが起った。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあくるとしに父の黄村が死んだ。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "露草色のくるくるとした瞳であった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "子どものうちからてまえの兄弟のようにして育ったのがおりましたんですが、店が傾いてくるとしようのないものでござんす。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、ごみ箱へすてられるためにばかり運ばれてくるとして、それでいいものだろうか。",
              "citation": {
                "source": "水菓子屋の要吉",
                "author": "木内高音",
                "note": "青空文庫"
              }
            },
            {
              "text": "バラックの諸君は、もし永久に衣食の配給を受くるとしたならば、稼ぐ必要がないからよいと云ってそれに甘んじ得られるであろうか。",
              "citation": {
                "source": "バラック居住者への言葉",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕らはまたくるとしようと口惜しがりながら、顔だけは平気を装って、すたすたと大股に引返した。",
              "citation": {
                "source": "春の上河内へ",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
