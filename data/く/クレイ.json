          "standard": [],
          "literary": [
            {
              "text": "最後に再び根岸の訊問となって急所々々を突込まれ、揚句例の如く諄々として、一時も早く自白して、署長の慈悲に縋るが好いと説かれた時に、彼は非常に感激したらしく、両手をついてうな垂れた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "１）趣向や句法に独創性のあるもの（子規の言う「破天荒」）：　以下に挙げる句例の先頭三句は、子規が「藤野潔の傳」で「趣向も句法も新しく且つ趣味の深きこと当時に在りては破天荒ともいふべく」と例示されたものである。",
              "citation": {
                "source": "藤野古白句集",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "「別役の精様がこないだから連れて行てくれい云いよりましたがのうし。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、この埃を見てくれい。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなら、掃いてくれい。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "その積で見立ててくれい。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに少し果物を取ってきてくれい。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく真赤に熟したのを買ってきてくれい。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その反古を予に讀んでくれい。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつが一人娘のお熊の綺倆を見て、俺にくれいとか何とか言うて一睨み睨んだという筋になるかナ」「うむ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも明けい、とおっしゃりますについて、あの、入口の、たいてい原ほどはござります、板の間が、あなた様、道者衆で充満で、足踏も出来ません処から、框へかけさせ申して、帳場の火鉢を差上げましたような次第で、それから貴女様がお泊りの筈、立花が来たと伝えくれい、という事でござりまして。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐに後金の二円を持って来るから受取っておいてくれい。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うむ、勇美子さんが来てくれいと言うものじゃでの。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そち自ら蓋を開いて一応改めくれい。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち音をたてないで、じいつとやすんでゐてくれい。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが打ち揃つて来て、俺にも弁護人になつてくれいと云ふのであつた。",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "大……大……大変、これ、一大事じゃ、来てくれい。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く其の人參を中へ入れて、お主、天川屋と云ふ處で、のつしと腰を掛けて番をして居てくれい。",
              "citation": {
                "source": "人參",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "画工　（疲果てたる状、※と仰様に倒る）水だ、水をくれい。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　との、まだお稲が死なぬ前に、ちゃッと祝言した花嫁御寮に向うての、――お主は後妻じゃ、二度目ぢゃと思うておくれい、――との。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はア、何にも……」　お雪はそう言ったが、急に想い出して、「――あ、そうそう、あのお客様にこれを渡してくれいうて、ことづかりました」「お見せ？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（現在その女の本当の名を忘れているのだが、想い出す都度簡単に花子だとしている）あの時、一緒に連れてくれいうたのに、のし、どない思て連れてくれなかっちゃんならと、彼女は並んで歩き出すと、言った。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "小使が来て、低頭して命を聞くと、教頭は頤で教えて、「何を、茶をくれい。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹の順礼　我等は他国のものやほどに教へてくれいのう。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　　十二「立って歩行く、雑談は始まる、茶をくれい、と呼ぶもあれば、鰻飯を誂えたにこの弁当は違う、と喚く。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっと引返して、また手を支くと、婦の膝をはらばいに乗出して、（何じゃな、向うから金子くれい、と使が来て店で待つじゃな。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "声の有る色の有る影法師ぢや……其のものから、御身に逢ふて話してくれい、と私が托言をされたよ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長谷川辰之助君はいつもより氣分が好いから、どうぞデツクの上に連れて行つて海を見せてくれいと云はれる。",
              "citation": {
                "source": "長谷川辰之助",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何でも私に寄りかかっていさえすればいいと思って、だだッ子のように来てくれい、来てくれいと言ってよこすんです」「だッて、来てくれなきゃア仕方がないじゃアないか？",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えて見ても分るだろうじゃアないか、奥さんになってくれいッて、もしなって国府津にいたら、あッちからもこッちからもあたいを闇打ちにする人が出て来るかも知れやアしない、わ」「お前はそう方々に罪をつくっているのか」と、僕はつッ込んだことがある。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
