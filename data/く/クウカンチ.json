    "definitions": [
      {
        "index": 1,
        "gloss": "vacant lot or land",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
