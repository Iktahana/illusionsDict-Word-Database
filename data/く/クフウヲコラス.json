    "definitions": [
      {
        "index": 1,
        "gloss": "to exercise one's ingenuity",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかしさうするために、もはや工夫を凝らす余地もないなら……心よ、謙抑にして神恵を待てよ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでこいつをうまく使いこなせるようにと、各社はそれぞれ工夫を凝らす。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまざまなパターンを使って、図形の表示に工夫を凝らすことも可能になった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤沢桓夫氏など詰将棋に工夫を凝らすぐらいなら、大いに推理小説に工夫を凝らして貰いたいと私は思う。",
              "citation": {
                "source": "探偵小説とは",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、こんな人の常態として、紙入の底が大抵の場合には、軽挙を戒める程度内に膨らんでいるので、億劫な工夫を凝らすよりも、懐手をして、ぶらりと家へ帰る方が、つい楽になる。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この種の事情は、家庭によって皆ちがうので、それぞれの事情によって、工夫を凝らすより仕方がない。",
              "citation": {
                "source": "パーティ物語",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
