    "definitions": [
      {
        "index": 1,
        "gloss": "sitting in a circle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
