          "literary": [
            {
              "text": "こんな奴は終には亡国の種を播く糞虫となるのだ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎりぎりといつのまにか二進も三進もいかぬまでに自分を締めつけてしまった、逢えば愛想のいい、金にかけてはしかし糞虫のようにきたない大山の親爺のことであった。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の毒だが、おまえ方はまず糞虫だ。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
