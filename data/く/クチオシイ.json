[
  {
    "uuid": "b98204bb-ec12-50c3-b209-d983e1caaae1",
    "entry": "口惜しい",
    "reading": {
      "primary": "くちおしい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
