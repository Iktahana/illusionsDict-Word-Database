    "definitions": [
      {
        "index": 1,
        "gloss": "to be shrouded by darkness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
