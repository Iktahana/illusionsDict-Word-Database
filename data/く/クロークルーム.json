          "standard": [
            {
              "text": "コンサートホールでは、来場者のためにクロークルームが用意されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スーツケースが大きかったので、空港のクロークルームに一時的に預けることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "結婚披露宴の会場には、ゲストが上着を預けられるクロークルームがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "と、階段わきのクロークルームの前でぱったり、ピエロの仮装をした少年紳士の郁さんに出遇ったのでした――郁少年の事はたしかまだお話し致しませんでしたね。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            }
          ]
        }
