        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "中門の車寄せの所が曲がってよろよろになっていた。",
              "citation": {
                "source": "源氏物語",
                "author": "末摘花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の館もやはり堀川のうちにあって、むかしは然るべき殿上人の住居であったのを無体に横領して、車寄せを駒寄せに作り変えたのであった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関への青い芝生の中の道が、曲線をしている為に車寄せの様子などは、見えなかったが、ゴシック風の白煉瓦の建物は瀟洒に而も荘重な感じを見る者に与えた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い大理石の柱の並んでいる車寄せで、彼は一寸躊躇した。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "遉に、大理石の柱が、並んでいる車寄せに立ったとき、胸があやしく動揺するのを感じた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう再びは、足を踏むまいと思った車寄せの石段を、彼は再び昇った。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関への青い芝生の中の道が、曲線をしてゐる為に車寄せの様子などは、見えなかつたが、ゴシック風の白煉瓦の建物は瀟洒に而も荘重な感じを見る者に与へた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い大理石の柱の並んでゐる車寄せで、彼は一寸躊躇した。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "遉に、大理石の柱が、並んでゐる車寄せに立つたとき、胸があやしく動揺するのを感じた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう再びは、足を踏むまいと思つた車寄せの石段を、彼は再び昇つた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙ってドンドン、ステーションを出ると、今度は車寄せのところで、我々が馬車を傭おうとする、そこへたかって来て、また口を出す。",
              "citation": {
                "source": "ワルシャワのメーデー",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつはそのまま改札口を出ると、やはりほかの連中と一しょに、夫の同僚が車寄せから、自動車に乗るのを送りに行った。",
              "citation": {
                "source": "妙な話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "百斤を用ひた他の例に　百斤の桜の花の溜りたる伊豆のホテルの車寄せかな　といふのがある。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "「母の名代を仰せ付かっちゃったの」　車寄せへ出ると、「あなた、真直ぐおかえり？",
              "citation": {
                "source": "一本の花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "古びて、少し傾いた屋根がのっかっている村ソヴェトの車寄せの前で、青年共産主義同盟員ニキータが、ルバーシカをしめた帯革へ片手さしこんで、片手でやけに人蔘色の頭をかいている。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　清は鏡子を車寄せの方へ導いて行つた。",
              "citation": {
                "source": "帰つてから",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "総二階に車寄せなんかついて堂々たるもんですよ。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "タラノ音頭　――コルシカ島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "小松はそんなことは知らないから、夢中になって決闘しているうちに、われともなく幕に凭れかかったので、そのまま窓からころげだしたというわけなのですが、運悪く窓の下は御影石の車寄せだったので敷石で頭をうち割ってしまったのです。",
              "citation": {
                "source": "ハムレット",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "阪井の邸は赤坂表町の坂下にあって、ポーチの薄暗い外灯がぼんやり車寄せを照らしているほか、どこからも灯ひとつ洩れないひどく閉めこんだ陰気くさい構えでした。",
              "citation": {
                "source": "ハムレット",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "数えてみますとあれからちょうど二十八年たっているわけでしたが、家の正面がすこし汚れ、車寄せのそばに防空壕が掘ってあるほかなにもかもむかしどおりになっていました。",
              "citation": {
                "source": "ハムレット",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝には還幸の節、いろいろな御心づかいに疲れて、紫宸殿の御車寄せのところで水を召し上がったという話までが、景蔵からの便りにはこまごまと認めてある。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関車寄せに群がっていた人々は？",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関前車寄せにはおびただしい死傷者だ。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思った次の瞬間、彼女の姿はもう馬車の中にはなくて、煌々と灯のともったクラブの車寄せ近くに立っていた巡警が、不愉快きわまる声でパンテレイモンをどなりつけた。",
              "citation": {
                "source": "イオーヌィチ",
                "author": "JONYCH",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして金ぴかの門衛連が厳めしく車寄せに控えている貴族会館に着いた。",
              "citation": {
                "source": "頸の上のアンナ",
                "author": "АННА　НА　ШЕЕ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その車が馬車廻しをぐるり一まはりして、また風のやうに出て行つてしまつたのを見送つて（その尻尾の標識にはＪ国公使館と、白地の文字が鮮かだつた――）、十吉は車寄せの小幡氏と落合つた。",
              "citation": {
                "source": "灰色の眼の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はまた車寄せを中心に見事なシンメトリイをなしてゐるあの前庭の設計に見とれた。",
              "citation": {
                "source": "母たち",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "車寄せからすぐの白いポーチは、すらりとした優雅な円柱でささえられ、趣味のいい鉄金具の釣電灯がつやつやした嵌石の床を照している。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "御所造りの表玄関につづく、砂利道をうねり上って行くと、軍所属の家具を引き取りにきた米軍の大トラックが三台、車寄せの前にとまって、空色の労働服を着たアメリカ人が五人ばかり、芝生に寝ころがって煙草を喫っていた。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "お揃いのようにショルダー・バッグをかけた、十八九から二十四五ぐらいまでの女のひとが二十人ばかり、車寄せの芝生に足を投げだし、ピクニックにでも来たような気楽なようすで、笑ったりしゃべったりしている。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
