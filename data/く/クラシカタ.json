[
  {
    "uuid": "81de6837-2d68-52a8-807f-2ae2fa498922",
    "entry": "暮らし方",
    "reading": {
      "primary": "くらしかた",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
