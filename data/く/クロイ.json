[
  {
    "uuid": "3c8bffbf-a2ab-5cfd-9a1a-82ef629ebe30",
    "entry": "黒い",
    "reading": {
      "primary": "くろい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
