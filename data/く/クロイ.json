    },
    "definitions": [
      {
        "index": 1,
        "gloss": "black",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのマストは黒い、それも煤煙のやうに黒い、――黒い、黒い、黒い……それこそはあの有名な旅順閉塞隊が、沈めた船のマストなのである。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には、晴れた空の一部分に黒い濃い雲形定規のやうな雲があつて、一寸欠け初めたばかりの月が、みえたり隠くれたり、可なり威勢よく渡れ亙つてゆくのが見られた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと私は友の背後に立つ二つの黒い投影を見て驚いた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩いてゐる人たちも、一樣に皆黒いトンビを着て、田舍者の煤ぼけた樣子をして居る。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼黒い両頬が桃の実のようにむっつりふくれた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場の蒼黒い顔には弱い西日がぽっと明るくさしていて、夕靄がもやもや烟ってふたりのからだのまわりを包み、なんだかおかしな、狐狸のにおいのする風景であった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "太宰は瞬間まったくの小児のような泣きべそを掻いたが、すぐ、どす黒い唇を引きしめて、傲然と頭をもたげた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道路に落ちる家々の軒の日影が、くつきり黒い。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私はわけのわからぬ言葉を発して、携帯の風呂敷包を下駄箱の上に置き、素早くほどいて紋附羽織を取出し、着て来た黒い羽織と着換えたところまでは、まずまず大過なかったのであるが、それからが、いけなかった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "極く田舎の、孝行息によくある、不整で毛の長い眉を持ち、学校に少しでも関係のある者を見る時はその下の黒い瞳がキロリと動いた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤黒い顔に鉄縁の眼鏡を掛け、紋付羽織が好きで何時もその広い胸ははたけられてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの、君が幼な時汽車で通りかゝつた小山の裾の、春雨に打たれてゐたどす黒い草の葉などを、また窓の下で打返してゐた海の波などを……　　　　　　　※　実生活は論理的にやるべきだ！",
              "citation": {
                "source": "Me Voila",
                "author": "―― a Cobayashi",
                "note": "青空文庫"
              }
            },
            {
              "text": "以来、すべての物に喪の印の如く、私の目に停る所には何処にでも、その黒い汚点があるのを私はみる。",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯枝に止った一羽の烏は、彼の心の影像であり、ふと止り木に足を留めた、漂泊者の黒い凍りついたイメージだった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『なにをする』流石の男も、少し正氣になつて、激した口調で『失敬な、貴樣は』『何だと』芳は體を突き出した、苦み走つた、黒い眉毛がヒリリと動く。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "片側の大名邸の高い土堤の上に茂り重なる萩青芒の上から、芭蕉の広葉が大わらわに道へ差し出て、街燈の下まで垂れ下がり、風の夜は大きな黒い影が道一杯にゆれる。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸袋のすぐ横に、便所の窓の磨硝子から朧な光のさすのに眼をうつすと、痩せたやもりが一疋、雨に迷う蚊を吸うとてか、窓の片側に黒いくの字を画いていた。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍛冶屋の煙突から吹き出る真赤な焔が黒い樹に映えて遠い森の上に青い月が出ている絵も欲しかったが、何となく静かなこの「森の絵」にきめた。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも背広の片腕に黒い喪章を巻いていたような気がする。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い冠木門の両開き戸をあけるとすぐ玄関で案内を乞うと右脇にある台所で何かしていた老母らしきが出て来た。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後についているのは十五、六の色の黒い白手拭を冠った女の子であった。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒いものが立つと思うと網にかかった。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこから射して來るのか樹蔭のやうな緑色の光線を受けて、模糊と霞んでゐるその萬疊敷とでも言ふべき廣場には、やはり霰のやうな小粒の珠が敷きつめられ、ところどころに黒い岩が秩序無くころがつてゐて、さうしてそれつきりである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは生れて三十何年間、色が黒いばつかりに、女にいちども、もてやしなかつたんだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どろりとした黒い藥でね、こいつあ、強い藥なんだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜間倦んじ疲れて、懈怠の心が起らうとする時、頭をもたげて燈光の中に先生の黒い痩せたお顏を瞥見すると、いまにも抑揚頓挫のある言葉で話しかけようとしてゐられるかの如く思はれる。",
              "citation": {
                "source": "「惜別」の意圖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "清らかな斎の衣は、鶴の羽づくろいしながら泉を渡るに似て爽かにも厳かである。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は一足先なる方に悠々と羽づくろいす。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒き盥のうちに乗りて羽づくろいして静まりぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小型の、まっくろい表紙。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
