    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bear (any mammal of family Ursidae)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "熊本へ出張して一と晩久しぶりで旅人の気分で歩いたが、熊本といふ所はいい所です　火山地方特有の落付がありますとも書いてゐた。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は高森のことを想ふと、いつも一匹の美しい仔熊を聯想する。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も彼は紺の背広を着て熊のやうにしづ／＼と南国の夏の町を歩いてゐるのであらう。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "三造は毎日家の中で熊のやうに暮してゐる。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京｜帝国大学の招聘に応じて、松江や熊本の地を去ったことも、同じくヘルンの身にとっては、愛する妻への献身的な犠牲だった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭はわるし、文章は下手、学問は無し、すべてに無器用、熊の手さながら、おまけに醜貌、たった一つの取り柄は、からだの丈夫なところだけであった。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "訪ふものは扉を叩つくしわれの懶惰を見て憐れみ去れども石炭もなく煖爐もなく白堊の荒漠たる洋室の中我れひとり寢臺に醒めて白晝もなほ熊の如くに眠れるなり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の遠い先祖は、冬の来る前に穴を掘り、熊や狐やの獣と共に、小さくかじかまつて生きたへて居た。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "王は将軍のビオルン（熊）に「鋼鉄のかみつけないこの犬（フンド）はお前が仕止めてくれ」と言った。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊本高等学校に入学した年の冬の休みに長崎から佐世保へかけての見学をした。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊本から百貫まで歩いて夜船で長崎へ渡りそこで島原の方から来る友人四、五名と落ち合ったのである。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日はここから汽車にのって一と息に熊本へ帰るというので、一同元気づいてだいぶ賑やかに騒いだりした。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊本の近況から漱石師の噂になって昔話も出た。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "並んで行く船に苅谷氏も乗り居てこれも今日の船にて熊本へ行くなりとかにてその母堂も船窓より首さしのべて挨拶する様ちと可笑しくなりたれど、じっとこらゆるうちさし込む朝日暑ければにや障子ぴたりとしめたり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "富米野と云う男熊本にて見知りたるも来れり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "詳しいことは忘れたが、何でも庄屋になる人と猟師（加八という名になっている）になる人の外に、狸や猪や熊や色々の動物になる人を籤引きできめる。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊本の高等学校を出て東京へ出て来るについて色々の期待をもっていたうちでも、一つの重要なことは正岡子規を訪問することであった。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の土佐と熊本とでは、心理的には今の日本とカリフォルニアくらいのへだたりがあったのである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、夏目先生が英国へ留学を命ぜられたために熊本を引上げて上京し、奥さんのおさとの中根氏の寓居にひと先ず落着かれたときのことであるらしい。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の五歳の頃から五年ほどの間熊本｜鎮台に赴任したきり一度も帰らなかった父の留守の淋しさ、おそらくその当時は自覚しなかった淋しさが、不思議にもこの燈下の寒竹の記憶と共に、はっきりした意識となって甦って来るのである。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お酉樣の熊手の裝飾、まねき猫、あんな幼い、悲しくやりきれないものを感じました。",
              "citation": {
                "source": "國技館",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は怖くなつて、とてもそのアメリカの小母さんの顔が見てはゐられなくなつて、窓の方に眼を向けると、雪の原には月が一面に青々と光つて、なんだか白熊たちは雪達磨をこしらへてゐるのでした。",
              "citation": {
                "source": "夜汽車の食堂",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "上り初めると蝶ヶ岳が見える、この山もそれに続く熊村岳（宛字）も、谷から渦まき※る飛沫のような霧に、次第に包まれて来る、足許には白花石楠花や、白山一華の白いのが、うす明るく砂の上に映っている。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "このたびは霧がなかった、紫の花咲くクカイ草、蘭に似た黄色の花を垂れるミヤマオダマキが、肉皮脱落して白く立っている樅の木を、遠く見て、路傍にしなやかに俯向いている、熊笹が路には多い。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉門次はふと草原を切り靡けたような、路のあるのを見出して、太い短かい杖で、猪独活をあしらいながら、「熊が通った路だあ」と言った、草はよほどの重量を、載せたように、右に左に押し倒されて、その凹んだ痕が、峰の方へ、斜に切って、するすると登って行く。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "道端の熊笹が雨に濡れてゐるのが目に沁みるほど美しい。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "河向ひから池までの熊笹を切開いた路はぐしよ／＼に水浸しになつて歩きにくかつた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道端の熊笹が雨に濡れているのが目に沁みるほど美しい。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "河向いから池までの熊笹を切開いた路はぐしょぐしょに水浸しになって歩きにくかった。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹌踉めくままに静もりを保ち、聊か儀文めいた心地をもつてわれはわが怠惰を諫める、寒月の下をゆきながら、陽気で坦々として、しかも己を売らないことをと、わが魂の願ふことであつた！",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
