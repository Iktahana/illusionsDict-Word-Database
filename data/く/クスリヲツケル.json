          "literary": [
            {
              "text": "薬をつけるのに勝子の泣声はまだ鎮まらなかった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「薬をつけるだけですね。",
              "citation": {
                "source": "美智子と歯痛",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "女こじきがつくってくれた薬をつけると、ふしぎに痛みがうすらいで、その晩、親子は、はじめて、気もちよくねむりました。",
              "citation": {
                "source": "空にわく金色の雲",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "――薬をつけるわけにもいくまいが、医者に見せたらどうだ。",
              "citation": {
                "source": "放浪者",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は白い、カユといふ薬をつける、包帯して帰宅。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "くすりをつけると、くすりだいがいるから、びんばふが、いつそう、びんばふになる。",
              "citation": {
                "source": "源八栗",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
