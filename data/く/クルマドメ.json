        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "駅の終点には、安全のために頑丈な車止めが設置されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "列車が規定の速度を超え、車止めに衝突する事故が発生した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この線路の先には車止めがあり、その先は行き止まりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
