        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "坂道でトラックを停車させる際、必ず車止めを使用する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "航空機が駐機する際には、タイヤに車止めがしっかりと装着される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "安全確保のため、重機には必ず専用の車止めを置くように指示された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
