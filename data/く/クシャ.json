    "definitions": [
      {
        "index": 1,
        "gloss": "Buddhist sect originating in the seventh century",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
