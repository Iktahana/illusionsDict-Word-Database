    "definitions": [
      {
        "index": 1,
        "gloss": "clearly (standing out)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
