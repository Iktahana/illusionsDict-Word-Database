[
  {
    "uuid": "36647142-5de3-5e2c-b2b8-4eac6a054607",
    "entry": "食い込む",
    "reading": {
      "primary": "くいこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
