    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to bite into (e.g. rope into skin)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "宇宙万象の秋、人の心に食い込む秋思の傷みを咏じ尽して遺憾なく、かの芭蕉の名句「秋ふかき隣は何をする人ぞ」と双壁し、蕪村俳句中の一名句である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして急いで自分の腕時計を調べて、それからまるで食い込むように向うの怪しい時計を見つめました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに弊害があっても、人の心の奥にまで食い込む心配は少ない。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが次の日のこと、畜産学の教師が又やって来て例の、水色の上着を着た、顔の赤い助手といつものするどい眼付して、じっと豚の頭から、耳から背中から尻尾まで、まるでまるで食い込むように眺めてから、尖った指を一本立てて、「毎日｜阿麻仁をやってあるかね。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このままでは食い込むばかりだと、それがおそろしくなりたまりかねてひそかに店を売りに出した。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして言うのには、あの人に後添いを貰う気持があるか訊いてくれ、わてにはすこしだが、貯えもある、もと通り小屋に出てもよし、近所の娘に三味線を教えてもよし、けっしてあの人の世帯を食い込むようなことはしない、玉堂はん頼みます云々……「……年甲斐もなく、仲人を頼まれたわけだが、他あやんどないやね。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてソニーは、先を行くパーソナルコンピューターを追って台頭したこのワークステーション分野で、かろうじてコンピューターに食い込む手掛かりをつかんだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂に食い込む二人の下駄の音だけが聞こえた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "極寒の折とか長い行軍の時に草履の緒が足に食い込むのを防ぐために履くくらいである。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "石には苔の斑が薄青く吹き出して、灰を交えた紫の質に深く食い込む下に、枯蓮の黄な軸がすいすいと、去年の霜を弥生の中に突き出している。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んしろ、ああやって旦はんに何もせいで居られては、偉う大尽はんやかて、食い込むさかい無理もあらへん。",
              "citation": {
                "source": "栄蔵の死",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鱸が鈎を食い込むと、竿先を水中へ引き倒すのではあるまいかと思うほど、強引に引っ張る。",
              "citation": {
                "source": "那珂川の鱸釣り",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "宅の中がしんと静まって、誰の話し声も聞こえないうちに、初冬の寒さと佗びしさとが、私の身体に食い込むような感じがしました。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "二週間と見積ったのが、四日で済む事もあり、高が五日くらいと踏んだ作事に半月以上｜食い込む事もある。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく物理学的観念論者の一人であるエディントンも亦、食い込むような厚みのある説明を与える叙述力を持っているが、ジーンズはこの本で、もっと掌を指すように、又もっと手玉に取るように、対象を生々と転がしている。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "安物のクロスの鎖が首に食い込むのを感じ、危機に瀕した彼は、ある物体を見るということ自体が邪悪な奴にどんな効果があるのだろうと思った(*28)。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の細い首にぼくの指がどこまでも食い込む。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃は家賃が集まらないし、商売の方では元を食い込むし、これでもなかなか困っているのですよ。",
              "citation": {
                "source": "端午節",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵馬は、ついに離れて、仏頂寺の青眼に対する相青眼の形を取って、ジリジリと、その足の裏の大地に食い込むのがわかる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "残忍な鋸歯がムーアの鎖骨に食い込むと、気が遠くなり、痛みで吐きそうになった。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "圧迫はない、肉体に爪が残酷に食い込むこともない、恐怖におののくデンの肉体に、歯がかみつくこともない。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポートグィンは美しい場所であり、荒々しい起伏に富む盆地になっており、緑の盆地に海が食い込む様子は、きらきら光る銀の槍を突き立てたかのよう。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "受験準備へ食い込む分を人生観察で挽回しようと思って、診察にも成る可く立ち合うことに努めた。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "事があると何うしても食い込む。",
              "citation": {
                "source": "村の成功者",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "己は何年｜食い込むか知らぬが、牢を出たら誓って復讐してやる。",
              "citation": {
                "source": "一寸法師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、遁れ得べくもない縛めをもがき抜いて、半裸の白い肉体に縄目が食い込むばかりムチムチと波打ちもだえた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土の底ふかく食い込むように埋まっていたのは、うツ伏せになった一個の人体です。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大衆の要求を正しくみちびくことになにかの不足が生じている場合、または大衆の革命的行動の理論が客観的正当さを欠いている場合、つねに敵のちょう発がその弱点にくいこむということをハッキリ教えています。",
              "citation": {
                "source": "ふたつの教訓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手が誰であろうと、たとえ、金肥りの社会的寄生虫であろうと、利益の尻尾にくいこむダニであろうと……これは島村さんの言葉だが……何だっていいじゃないですか。",
              "citation": {
                "source": "別れの辞",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔いからさめれば、女房のくりごとも胸にくいこむ。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
