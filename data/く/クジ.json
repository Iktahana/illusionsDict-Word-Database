    "definitions": [
      {
        "index": 1,
        "gloss": "lottery",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "詳しいことは忘れたが、何でも庄屋になる人と猟師（加八という名になっている）になる人の外に、狸や猪や熊や色々の動物になる人を籤引きできめる。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、ゆっくり構えて、まあ、好きなら麦とろでも食べて、運の籤の性質をよく見定めなさいというのさ。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、彼女が彼女に出来なくて自分にさせようとしていることなぞは、彼女とて自分とて、またいかに運の籤のよきものを抽いた人間とて、現実では出来ない相談のものなのではあるまいか。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた「宇宙の形をしているから」とか「選挙のときの籤に使われる、従って寡頭政治を代表するものだから」ともある。",
              "citation": {
                "source": "ピタゴラスと豆",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今もお堂で御神籤を頂いたんですが、やっぱり凶と出たので……」と、女は苦労ありそうに細い眉を寄せた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "……がしかし……仕事のむずかしいのはここまでで、アトは何でもありません」「そんなものですかねえ」「その水雷の外側をランチのバスケットか何かに見えるように籠で包んで、籤取りできめた五、六人がボートに乗って、舟遊びみたいな恰好でズット沖に出てしまいます。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その呪いの的になる人は時々変りはしたけれども、どういうものかおせいは貧乏籤をひいた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御奥の老女は御神籤を下しに行く。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "飽までも運の悪いお葉は、第二の籤を取らねばならぬ不幸に陥った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "神籤を取れば凶と出る。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、思いながら寄って行くと、スピード籤の屋台が出ているのだった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日一日のおれの行動をスピード籤に賭けてみよう」　と、鶴雄は咄嗟に呟いた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まず賭けてみることだ」　籤がすっかり外れて、一文なしになって、今日一日暮すのも面白い……。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴雄は屋台を出ると、当り籤の番号の掲示板の出ている前へ立って、何の感情もなく、一枚一枚開いて行った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふん」　と、鶴雄は鼻を鳴らして、「――生意気な女だ」　後姿を見送りながら、スピード籤の屋台の隣に出ている「悲願！",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕にはこの百円を受けとる権利はない」「判らないわ」「僕はあのスピード籤を破りかけてたんだ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……なるほど、スピード籤は今日一日のおれの行動を決定しそうだぞ」「赤と黒」を愛読するという風変りな女スリに出会ったこと、そして無一文になってしまったこと……この二つの思いがけぬ出来事は、すくなくとも、今日これからの行動に何かの影響を及ぼしそうな予感がした。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三、四条河原町でスピード籤をひいたこと。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は掏られたんだと思いますね」　鶴雄は昨日四条河原町のスピード籤の屋台で弓子に掏られた経験から、そう言った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の物語の作者たちは、さうした悲しい數數の旅行の後で、それでも、漸く最後に取つて置きの籤をひかせて、首尾よく願望を成就させた。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにつけても、お金が欲しく、そろそろ富籤の当り番がわかった頃だと思いますが、私のは、たしか、イの六百八十九番だった筈です。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの富籤を、京の家の私の寝間、床柱の根もとの節穴に隠して置きましたが、お願いですから、親爺に用ありげな顔をして私の家へ行き、寝間に忍び込んで床柱の根もとの節穴に指を突き込み、富籤を捜し出して、当っているかどうか、調べてみて下さい。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このたびのまことに無分別の遁世、何卒あわれと思召し、富籤と観音像と、それから色紙の事お忘れなく、昔の遊び仲間の方々にもよろしくお伝え下され、陽春の頃には、いちど皆様そろって吉野へ御来駕のほど、ひたすら御待ち申し上げます。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し何が何様あろうとも、一生の苦楽を他人に頼る女のことであるから、善かれ悪かれ取宛てた籤の男に別れては堪るものではない。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は過日家を出てから、もうとても今じゃあ真当の事ア遣てる間がねえから汝に算段させたんで、合百も遣りゃあ天骰子もやる、花も引きゃあ樗蒲一もやる、抜目なくチーハも買う富籤も買う。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中にゃあ勝ちもした負けもした、いい時ゃ三百四百も握ったが半日たあ続かねえでトドのつまりが、残ったものア空財布の中に富籤の札一枚だ。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何となく陰気に薄暗くじめじめして、妙に気味の悪い厭な感じがしたので、夫人が直覚的に反対したにもかかわらず、ヘルンは一見して大いに気に入り、『面白いの家』『面白いの家』と、子供のように嬉しがって、是非それを買おうと言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "自身の苦慮が、毛むくじやらの大男の、やさしい聲を出さうとしての懸命の苦慮が、をかしかつたからである。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の試験にしくじった時もやはり仕方がないと思ったが、その時の仕方がないと今度のとは少し心持が違う。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに石楠花にとろけている生物が二個ある、一個は私である、一個は石楠花の花の中に没頭して、毛もくじゃらの黄色い毛だらけの尻を、倒しまに持ちあげ、蜜を吸い取っているアブである。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
