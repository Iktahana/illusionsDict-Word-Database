    "definitions": [
      {
        "index": 1,
        "gloss": "place where one can remove one's shoes before entering a house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "東向きの、屋根のない門をはいって突き当たりの玄関の靴脱ぎ石は、横降りの雨にぬれるような状態であったような気がする。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "讓は靴脱ぎへあがってそれから上へあがった。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に夕飯は客の分もできてゐたのだが、渠はそれを入らないと云つて、義雄と共に靴脱ぎへ降りた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "その目が飛び出たのかと思はれるほどやせてゐる顏を義雄は見ない振りでつか／＼と靴脱ぎをあがつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "譲は靴脱ぎへあがつて、それから上へとあがつた。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "店をはずれて、ひょろひょろとした柳で仕切った、その門を見ると、小児が遊んでいたらしく、めんこが四五枚、散に靴脱ぎのたたきの上へ散って、喇叭が一ツ、式台に横飛び。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りついた玄関の靴脱ぎ石の上には岡の細長い華車な半靴が脱ぎ捨てられていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隙間から覗くと、靴脱ぎの上にあった下駄も取り込んだらしく、板戸もぴったり締って、日当りの悪い庭の、立枯れの鉢植えの菊などが目についた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どいつも、こいつも不熱心な奴等だ」と、渠は靴脱ぎの土を右足の下駄で蹴つたが、勇の立つてゐる前だと氣がついて、それを取り消すかの樣なにが笑ひをする。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "義雄はいつもの通り默つて靴脱ぎをあがり、そこの障子を明けると、お君が事務室から編輯室をいそいでとほつてらしい、いやな目つきをしてこちらを見ながら、茶の間へ來るのが見えた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　朝、七時二十分の汽車に間に合ふ樣、義雄は薄野を出て、車を走らせる途中、旅かばんを取りに、ちよツと有馬の家へ寄り、靴を脱ぐのが面倒臭いから、障子が明いてゐるのを幸ひ、靴脱ぎのそばに立つて、「有馬君」と、聲をかけた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして靴脱ぎ石の上に鋏の大きな蟹が死んでいるのを見ると、学者たちを呼んでまいりました。",
              "citation": {
                "source": "椰子蟹",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、靴脱ぎの上を冷たく頤で指した。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきの客も、入り口だか、便所だか、靴脱ぎだか、物置だか分らぬような玄関を作ったのかもしれない。",
              "citation": {
                "source": "尋常一様",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りがけに気がついたのだが、小波邸の靴脱ぎには、大きな「下馬札」が、デンとばかり建っていた。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "志村はそこの靴脱ぎ石に庭下駄を揃えて、「あちらでございます」　と真暗な庭を指さす。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ルミコはこれを着て来たのよ」　玄関の靴脱ぎに横たわっているものを、ミヨコはヒトミに指さしてみせた。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダーク・グリーンのレイン・ウエアは、ルミコが脱ぎ捨てたままに、雨に濡れて靴脱ぎのタイルの上にひとかたまりとなっていた。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「住みやすいですよ」「玄関の靴脱ぎの四角いスペースをホールがＬ字型に囲んで、その延長として、二階への階段が奥にあって。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関の靴脱ぎの所と、初代の部屋の縁側の内庭に面した部分である。",
              "citation": {
                "source": "孤島の鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより狭い家だから、三尺のくつぬぎを隔てて家じゅうはすっかり見える。",
              "citation": {
                "source": "月の夜がたり",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　低い木戸をあけて、くつぬぎから声をかけた人があった。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関のくつぬぎの上には、彼の赤革の編あげ靴に並んで、飾りのついた黒いハイヒールの彼女の靴が、つつましやかに並んでいた。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "このくつぬぎ石は廻縁から庭へ出る時何時も踏んづけたものだった。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、あわてて逃げ出そうとしましたが、兄弟はもう、うしろから追いついて、青ひげが、くつぬぎの石に足をかけようとするところを、胴中をひとつきつきさして、ころしてしまいました。",
              "citation": {
                "source": "青ひげ",
                "author": "ペロー　Perrault",
                "note": "青空文庫"
              }
            },
            {
              "text": "石のくつぬぎに行儀よく並べた死骸を又丁寧に一匹ずつ火の中に放りこもうとして紙屑を燃やした。",
              "citation": {
                "source": "入梅",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝手がわかつているので、別にためらいもせず、縁側のくつぬぎのところへ来て、ピヤノの音に耳をすます。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "くつぬぎ石、苔のついた飛石。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々出てきては、くつぬぎの石の上に乗り、縁側に前足をかけて、家内の寝ている姿をのぞき、また床の下へはいって行くのでした。",
              "citation": {
                "source": "私の飼った犬",
                "author": "斎藤弘吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人のほかな人影が室に見えたためか、男は、くつぬぎの辺に、だまって蟇のような姿をして、うずくまったきりであったが、やがて高徳から、「して、どうだった。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
