[
  {
    "uuid": "4dd6b812-8bdd-5a84-8366-c07561d3cafd",
    "entry": "苦悶",
    "reading": {
      "primary": "くもん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
