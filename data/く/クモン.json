    },
    "definitions": [
      {
        "index": 1,
        "gloss": "anguish",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さりとて誰にこの苦悶を話しようもなく、民子の写真などを取出して見て居ったけれど、ちっとも気が晴れない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう訣であるから、学校へ往っても以前とは殆ど反対になって、以前は勉めて人中へ這入って、苦悶を紛らそうとしたけれど、今度はなるべく人を避けて、一人で民子の上に思いを馳せて楽しんで居った。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに僕が過去に於て苦悶したか。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾度か自殺を考へたほど、それほど思想上と生活上との、救ひがたい絶望的苦悶に陷入つて居たかを、君は少しも――眞に文字通りに少しも――知つてはくれないのだ。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　これで以て、一切の思想的苦悶が一蹴されてしまふのだ。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活上や家庭上のことに於ても、僕のあらゆる複雜した過去の苦悶、暗く絶望的な運命を忍從したり、それについて戰つたりしたことを、君は全つきり考へてくれないのだ。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕があの長い間、可成の苦悶にみちた生活を忍從してゐながら、書面上にも談話上にも、一も訴へるべき對手をもたず、獨り寂しく田舍に悲しんでゐたといふ一事は、考へるだけでも腹立たしい運命の皮肉である。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその少し前からして、彼が例の詩人らしい敏感性で、しだいに濃度を増してくる周圍の壓力を感じて居り、神經質の苦悶に耐へてることを氣付いてゐたが、果せるかな偶然の機會を捉へて爆發した。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた友の肉体に潜んだいろいろな苦悶と疾患とが、友を非常な神経質な針のさきのやうなちくちくした痛みを絶えず経験させた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "更らにこれらの詩篇によつて物語られた特異な世界と、人間の感覚を極度までに繊細に鋭どく働かしてそこに神経ばかりの仮令へば歯痛のごとき苦悶を最も新らしい表現と形式によつたことを皆は認めるであらう。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昂奮と怖れと苦悶に圧せられながら。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひっそりとした暗い町を今人間の形をした苦悶が火照って行き過ぎるのではないか。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚愕して飛びあがつたやうな町は、かかる苦悶そのもののアトモスフェアを突き破らうとでもするかのやうに必死となつてゐます。",
              "citation": {
                "source": "トレドの風景",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "薫は黙って吸わせたままに、足を上げ下げして、おとなしく泳いでいたが、小初ほど水中の息が続かないので、じきに苦悶の色を見せはじめた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "西欧人に比べて東洋人は生命を苦もなく棄てるのであるが、陳子文の死には過去から現代の過程のなかに生きる近代的な苦悶の潜んでいたことを米良は知るのである。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが氣の弱い、感じ易い、物事に單純過ぎる、人間的な苦悶を知らないお坊ちやん育ちの私だから、もう一圖に醫師の詞に脅かされてしまつたのだ。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その光の影には引き裂かれるやうな苦悶が、悲痛が、驚きが、失望が高く波打つてゐたのだつた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、私には戰慄が來た、苦悶が來た。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、コロロホルムの麻醉に、手術の痛みも、夢中な自分の詞も、私の苦悶も、私の昏倒も、そしてすべての人達の懸念も焦慮も知らずに過ぎたに違ひないお前を、何となく一番幸福者のやうに感じたのだつた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "随つて、芥川氏の智の視野に映じてくる処のものも、人生の、若しくは人間の悲哀、苦悶、憂鬱、寂寥、倦怠、幻滅――要するに暗き世の姿である。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "其證據には曾て戀の爲めに苦み悶えた人も、時經つて、普通の人となる時は、何故に彼時自分が戀の爲めに斯くまで苦悶したかを、自分で疑がう者である。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とも云えぬ苦悶が全身を圧え付けて冷たい汗が額から流れた。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "南向きに寝ている彼女は枕を横にはずして、蒲団から少し乗り出したようになって仰向けに横たわっていたが、その結び髪は掻きむしられたようにおどろに乱れて、額をしかめて、唇をゆがめて、白ちゃけた舌を吐いて、最期の苦悶の痕がその死に顔にありありと刻まれていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "一面では、シンクレエアが欧洲大戦当時、彼自身がとった、少なからぬ苦悶の後に武器を肯定した心の位置を書いたものであるという。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこの形式に彼の恐ろしい苦悶を盛りはじめたのである。",
              "citation": {
                "source": "詩集『戰爭』",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人はこれらの詩のなかにも彼の苦悶を讀まねばならぬ。",
              "citation": {
                "source": "詩集『戰爭』",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこれらの詩に於いて「絶望の歌」以後の更に深い精神的苦悶の時期を經てゐる。",
              "citation": {
                "source": "詩集『戰爭』",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その最後の条に、夫が病気で非常な苦悶をするのを見たすぐあとで、しかも夫の眼前で鏡へ向かってその動作の復習をやる場面がある。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は苦悶の無い遊びを憎悪する。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゅっこが、あんまり急いで行くもんだから、小さな子どもらは、追いつくために、まるで半分｜馳けた。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
