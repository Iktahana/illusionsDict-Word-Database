[
  {
    "uuid": "92589a2e-df26-529d-b6b1-43b1ff37b5d6",
    "entry": "苦情",
    "reading": {
      "primary": "くじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "complaint",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "家内のちょっとした物音や話声にも、感興を破られたといって苦情を言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と大聲に苦情を叫びながら、彼はゼウスの玉座の前に身を投げた。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の苦情が一段落すると、こんどは、五歳の女の子が、もう壕から出ませう、と主張しはじめる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "農民は駐在所へ苦情を持ち込んだ。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "讀まず、書かず、電話が掛からず、手紙が來ず、人に會はずの三日間で頭の疲れが直り、從つて胃の苦情もいくらか減つたやうである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々が今日の蚊帳に満足せぬまでも苦情を云わずに毎晩釣って寝ているのは、吾等の親もその親もこれを釣って寝たというだけの理由で、蚊帳といえばこんなものとあきらめているだけの事であろう。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしぁ、べらぼうめ、そんな苦情は、おれのとこへ持って来たって仕方がねえや、ばさばさのマントを着て脚と口との途方もなく細い大将へやれって、斯う云ってやりましたがね、はっは。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の原稿があまり専門的であった上に予定の頁数を超過するので編輯者の方から苦情が出た。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九〇一年にロンドンのチューブ地下鉄道が開設されたが、このために家が振動して困るという苦情が出たので、政府はそのために調査委員を設け、レーリーが委員長になった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘両手にて画家の目を塞ぎ、顔次第に晴やかになりて微笑み、少し苦情らしき調子にて。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "――土人街の日本の坊主頭から苦情は出ないのですか。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、昔からの国の習俗で、この日の神聖な早乙女に近よってからかったりする者は彼女達の包囲を受けて頭から着物から泥を塗られ浴びせられても決して苦情はいわれないことになっていたのである。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく十年の前から年々にこんな苦情を繰返していたのであるが、つい最近になってふとこの苦情を一掃するような一つの方法を発明した。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、猫を飼うのは彼女の自由で、誰もあらためて苦情をいうべき理由をもたなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのたくさんの猫が狭い家いっぱいに群がっているのが、見る人の目には薄気味の悪いような一種不快の感をあたえることがあっても、それだけではまだ飼主に対して苦情を持ち込む有力の理由とは認められなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると、苦情の理由が立派に成り立って、近所からたびたびねじ込まれた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "書いてある事に間違いがなければ、苦情の言いようはない。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どこかに人殺しがあった」という事実だけが正確でうそでなければ、それ以外の間違いについて新聞社に苦情を持ち込むほど物ずきな読者はまれであろうと思われる。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いや、器はちがわん……」といったようなはなはだやるせのない苦情を言っているらしい。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから六平太先生も、あまり実さんには苦情を言われないのじゃないかと思う。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "我儘過るとお清から苦情の出る場合もあったが、何しろお徳はお家大事と一生懸命なのだから結極はお徳の勝利に帰するのであった。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これには大庭家でも大分苦情があった、殊にお徳は盗棒の入口を造えるようなものだと主張した。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを制すれば門の扉の一枚ぐらい毀たれても苦情は言えなかった。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、当日、小作の挿画のために、場所の実写を誂えるのに同行して、麻布我善坊から、狸穴辺――化けるのかと、すぐまたおなかまから苦情が出そうである。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "○この頃、在来の義太夫狂言について版権を得たりと称し、大阪及び東京に事務所を置きて、各劇場の興行ごとに苦情をいい込む者あらわる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも在来｜已に行われいたる浄瑠璃本などに因って興行する者に対し、その苦情は無効なりと当局者に認めらる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯さへ狭くなつたところへ、こゝで又、奥行を一間二尺も切り縮められちやあ仕様がないが、それもまあ世間｜一統のことですから、わたしの家ばかりが苦情を云つても始まらないと、まあ諦めてゐたんです。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼のうちに見廻ると、方々の店から出て来て色々の苦情をならべ立てるので、夜が更けてから窃と見まはるのかも知れないと思つて、内へ這入つてその話をすると、かみさんも成程さうかも知れないと云つてゐました。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまに、大きくじょうぶになりますよ。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあどうして、そんなにたくさんのお金をこしらえたのか、はくじょうしろ。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
