    "definitions": [
      {
        "index": 1,
        "gloss": "to tie up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "袴短く、裾や袖は括緒があって之を括る。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "三萱刈りて、篠刈りて、編むで作る、炭俵、炭をつめて、繩もて括る、眞木ゆひし、繩を解きて、一括り、二括り、三括りに括る、大き俵、小さ俵、左から見、右から見、置いて見つ、積むで見つ、よろしき炭、また燒いて、復た燒き燒く。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "……括るなら、其の刀を。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すくみといふのは蹙めた儘の形が保たれるやうに死體の下から荒繩を廻して置いて首筋の處でぎつしりと括ることである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と茶の間でうつたうしく髪を結ひかけてゐたおくみは、青木さんにお礼を言つて、間もなく根だけを括ると、半ば髪を前に被つたまゝ、油手を拭いて封を切つた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「引っ括って見ましょうや」「……エッ……引っ括る……どうして……」「明朝……イヤ……今朝ですね。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "巷では、行逢う人から、木で鼻を括るような扱いを受けた殺気立った中に、何ともいえぬ間の抜けたものも感じられる、奇怪な世界であった。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "巷では、行逢ふ人から、木で鼻を括るやうな扱ひを受けた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "大ビラで売国奴の名を付けて古川某を引括る事が出来たんだ。",
              "citation": {
                "source": "人間レコード",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私はわざと北歐といはずに、文學が基礎として立つ言葉を同じくし、地理的に近接し、歴史、民族、風習の上からも、非常に密接な關係にある北歐の諸國をスカンヂナヴィアの名の下に、引つ括るめて、お話しようと存じます。",
              "citation": {
                "source": "スカンヂナヴィア文學概觀",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと同じようにあなた方と云うやはり一箇の団体の意識の内容を検して見るとたとえ一カ月に亘ろうが一年に亘ろうが一カ月には一カ月を括るべき炳乎たる意識があり、また一年には一年を纏めるに足る意識があって、それからそれへと順次に消長しているものと私は断定するのであります。",
              "citation": {
                "source": "現代日本の開化",
                "author": "――明治四十四年八月和歌山において述――",
                "note": "青空文庫"
              }
            },
            {
              "text": "縄なくて十重に括る虜は、捕われたるを誇顔に、麾けば来り、指せば走るを、他意なしとのみ弄びたるに、奇麗な葉を裏返せば毛虫がいる。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "縄は物を括る手段である。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父は人間社会の事に大抵通じているせいか、万に高を括る癖に、こういう自然界の現象に襲われるとじき驚ろく性質なのである。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "はゞきの裾の下肢を括る処ばかりに作つた脚絆を、はゞきといふ様になつて、さしぬきと改名した。",
              "citation": {
                "source": "小栗判官論の計画",
                "author": "「餓鬼阿弥蘇生譚」終篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "其頃は、折口が地形の名で、幾百里離れてゐても、苟も日本の土地でありさへすれば、何の聯絡なしに、勝手に幾らでも出来るはずの家名だ、とたかを括る様になつてゐた為、書きとめて置かなんだのが残念である。",
              "citation": {
                "source": "折口といふ名字",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣類をくるくると円めて、帯でひつ括るなり、ぽんと手前にはふり出して、いきなりざぶざぶと河の中に入つて行つた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我心は漂泊し放蕩する情調を括る不易の或物に向つて喘いでゐる。",
              "citation": {
                "source": "三太郎の日記　第一",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寄り添わずば、人知らずひそかに括る恋の糸、振り切って君は去るべし。",
              "citation": {
                "source": "薤露行",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩に括る緋の衣の、裾は開けて、白き裏が雪の如く光る。",
              "citation": {
                "source": "薤露行",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに行李を括るのは得意であった。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら父でもそう容易く高を括る訳に行かなかった。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ津田は兄だけに、また男だけに、話を一点に括る手際をお秀より余計にもっていた。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは装飾のためとも見られるし、または袖口を括る用意とも受取れた。",
              "citation": {
                "source": "博士問題とマードック先生と余",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "九州でクマ（隈）といったのもこれに当り、あるいはまた福良と称するのも小川内であって、そのいわゆる盆地の上下を括るところの急湍の地が、ツル（津留）であろうということはかつて述べた。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　乱雑の美　五、六合間の等高線をゆく、御中道の大沢近くくると、にわかに婉曲してひた下りに下る。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その男は立って、網棚から包みをおろして、手ばやくくるくると解きました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この愚僧は、たいへんおしゃれで、喫茶店へ行く途中、ふっと、指輪をはめて出るのを忘れて来たことに気がつき、躊躇なくくるりと廻れ右して家へ引きかえし、そうしてきちんと指輪をはめて、出直し、やあ、お待ちどおさま、と澄ましていました。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら」その男は立って、網棚から包みをおろして、手ばやくくるくると解きました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その男は立つて、網棚から包みをおろして、手ばやくくるくると解きました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
