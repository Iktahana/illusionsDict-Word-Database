    "definitions": [
      {
        "index": 1,
        "gloss": "all the way ... (to this remote place)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やがてお恵みが下ります時には、やさしくうつくしい夜の歌と櫂歌とをうたはうと思つてをります……（一九二九・一二・一二）",
              "citation": {
                "source": "我が祈り",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "街道を折れて、少し下り坂になる道をスタコラと歩いてゆくと、街道でしてゐた豆腐屋の喇叭の音は急に聞えなくなり、道の傍の、森の葉擦の音に私は淋しくなるのであつた。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "教会の附近の黄色い土塀つづきの、夕方はしづかり下りて来る彼処へ、ではまた落付いたな、あゝあゝと、僕は思ふのだつた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祖母ちやんは、忽ち起つて、干物を入れるために庭に下りた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も好都合なのは、その集積的な活動が一先づ結実し、それが下り坂になつたといふ時なのである。",
              "citation": {
                "source": "アンドレ・ジイド管見",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジイドの活動の始まるのは、その下り坂がもう殆んど下り切つたといふ時であつた。",
              "citation": {
                "source": "アンドレ・ジイド管見",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "我れ少年の日は、常に麥笛を鳴らして此所を過ぎ、長き煉瓦の塀を※りて、果なき憂愁にさびしみしが、崖を下りて河原に立てば、冬枯れの木立の中に、悲しき懲役の人人、看守に引かれて石を運び、利根川の淺き川瀬を速くせり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とかく物うち語りて、ちとこなたの、窶舍にも下りさせ給へ。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗闇阪を下りつめた角に荒物屋がある。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい新聞紙の包を大事そうにかかえて電車を下りると立止って何かまごまごしていたが、薄汚い襟巻で丁寧に頸から顋を包んでしまうと歩き出した。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四丁目で電車を下りると皿の包を脇の下へ抱えてみたが工合が悪い。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下り坂の茶店で休んだときにそこのお神さんが色々の火山噴出物の標本やラヴァやカメーの細工物などを売付けようとしたが、こしらえもののいかものだけはわが地質学者を欺く訳に行かないのがおかしかった。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園裏にて下り小路を入れば人の往来織るがごとく、壮士芝居あれば娘｜手踊あり、軽業カッポレ浪花踊、評判の江川の玉乗りにタッタ三銭を惜しみたまわぬ方々に満たされて囃子の音ただ八ヶまし。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三囲の稲荷堤上より拝し、腹まだ治まらねば団子かじる気もなく、ようやく百花園への道札見付けて堤を右へ下り、小溝に沿うてまがりくねりの道を行く半町ばかり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡頭に下り立ちて船に上る。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不折の油画にありそうな女だなど考えながら博物館の横手｜大猷院尊前と刻した石燈籠の並んだ処を通って行くと下り坂になった。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "有難しとボーイに礼は云うて早速頂戴するに半分ばかりにして胸つかえたれば勿体なけれど残りは窓から外へ投げ出してまた横になれば室内ようやく暗く人々の苦にせし夕日も消えて甲板を下り来る人多くなり、窮屈さはいっそう甚だしけれど吾一人にもあらねば致し方もなし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "苅谷氏に昨夕の礼をのべて船を下り安松へ上がる。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪にて海南学校出らしき黒袴下り、乗客も増したり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "飾り気一点なきも樸訥のさま気に入りてさま／″＼話しなどするうち京都々々と呼ぶ車掌の声にあわたゞしく下りたるが群集の中にかくれたり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "九つの歳父母に従うて東海道を下りし時こゝの水楼に※魚の塩焼の骨と肉とが面白く離るゝを面白がりし事など思い出してはこの頃の吾なつかしく、父母の老い給いぬる今悲しかり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "長良川木曽川いつの間にか越えて清洲と云うに、この次は名古屋よと身支度する間に電燈の蒼白き光曇れる空に映じ、はやさらばと一行に別れてプラットフォームに下り立つ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜松にては下りる人乗る人共に多く窮屈さ更に甚だしくなりぬ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより下り坂となり、国府津近くなれば天また晴れたり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大船にて横須賀行の軍人下りたるが乗客はやはり増すばかりなり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴉が下りて来て牛の脊中の赤い紙を牛肉と思ってつつくと、牛は蠅でも追う気でぴしゃりと尻尾ではたく、すると摺粉木の一撃で鴉が脆くも撲殺されるというのである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うの子供づれは須田町で下りた。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野へ着くのを待ち兼ねて下りる。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "模造日本橋は跡方もなくなって両側の土堤も半ば崩れたのを子供等が駆け上り駆け下りて遊んでいる。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新町から青山くんだりまで三円ばかしのお金を取りに来るような暇はない身体ですよ。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
