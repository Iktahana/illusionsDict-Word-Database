        "examples": {
          "standard": [
            {
              "text": "焚き火の後に残ったクリンカーをきれいに片付けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ボイラーの底には、燃えカスが固まったクリンカーが堆積していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "クリンカーの除去作業は、定期的に行われるメンテナンスの一部だ。",
              "citation": {
                "source": "幻辭AI",
