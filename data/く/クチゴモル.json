    "definitions": [
      {
        "index": 1,
        "gloss": "to hesitate to say",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "オズオズ口ごもる件の男。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「若い師匠が死んでから、おまえさんはもう師匠の家へはちっとも出這入りをしなかったかね」「へえ」と、弥三郎は口ごもるように云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "言い出そうとして、流石に、口ごもるのである。",
              "citation": {
                "source": "女人創造",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（奥田）　たとえば、……さあ、……（口ごもる）（しづ）（勢い込んで）わたくしは、もう、これだからいやなんです。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ウォーカー・ブラザース」と、広岡が口ごもる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここまではすらすらと答えたが、それからあとは、少しずつ口ごもるようになった。",
              "citation": {
                "source": "夏の夜の冒険",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいえ」　と夫人は口ごもるようにして答えました。",
              "citation": {
                "source": "墓地の殺人",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、信者は由良が黙っているのに向うから、まことにとんでもないと思う頃、自分も前は筮法をすすめられてあの学者の所へかよっていたが、娘が始終夢殿村から来ているのだから、用心をしていないと危いと、口ごもるように云ってから、由良を見返して顔をだんだん赧らめた。",
              "citation": {
                "source": "馬車",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――画から抜けだした女の顔は……」とばかりで口ごもる。",
              "citation": {
                "source": "一夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしまひには婦人までが鸚鵡がへしに 〔Tre`s bien?〕 と二度ばかり口ごもる。",
              "citation": {
                "source": "旅の繪",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば（苦しそうに口ごもる）いや、とてもあなたの前では言えないような事をしていますからね。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど彼女は、口ごもるようにして、それには答えず、「それはまたあとでわかります」と、困ったようにしかたなく笑っている。",
              "citation": {
                "source": "黒髪",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔をあからめて口ごもるんだって、生れつき授ってる手じゃないの。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう、僕……」と腕時計を見ながら、私は口ごもるように云った。",
              "citation": {
                "source": "燃ゆる頬",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしまいには婦人までが鸚鵡がえしに 〔Tre`s bien ?〕 と二度ばかり口ごもる。",
              "citation": {
                "source": "旅の絵",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たまには投げて勝ってみせろよ」　酔っ払った私が、ついむごいことを言うと、三根山はションボリして「巡業中、その稽古をしていますが……」　と口ごもる。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見ると、わたしは、その老婆の口ごもる声は、僧の唱和や、オルガンの音や、合唱隊の歌声よりもずっとさきに天にとどくのだと強く思わざるを得なかった。",
              "citation": {
                "source": "寡婦とその子",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ……」私は口ごもる。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙に口ごもるところ、それは唖に似てゐるといふより寧ろ、十吉には幸四郎の絶句ぶりが思ひだされて可笑しかつたが、この癖もやはり、この人のもつ陰影感を深める有力な因子にちがひなかつた。",
              "citation": {
                "source": "灰色の眼の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう、僕……」と腕時計を見ながら、私は口ごもるやうに云つた。",
              "citation": {
                "source": "燃ゆる頬",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と口ごもるようにいったあとで、「これからどちらへ？",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　人の顔をジロジロとぬすみ見はするが、決してまともには見ず、人に顔を見られることを臆したようなふうで口ごもるごとく丁寧な言葉をつかうこの男のさまを見ると、たとえそれがこの男の「手」かと疑っても裕佐は苦しいほど気の毒になるのだった。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、立証されるというのは、ただ、もし閣下が……と、博士が口ごもると、エセックスは高らかに笑った。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、それらが辿った経路と思しきものには、一つの暗い、口ごもるような恐怖の要素があったのだ。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "その奇形性は今なお比較解剖学会ミスカトニック支部会員の間で議論の元になり、結局は口ごもる元にもなっているのだ。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええと口ごもるのを、老女は自分の思いどおりに受け取った。",
              "citation": {
                "source": "夕靄の中",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに、彼らが何かを言い出そうとして口ごもるところをご覧なさい。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そりゃあ」　と、百合はしなだれかかるように肩をすぼめて、「厭んなっちゃうわね、思うことは何一つ言えやしないんだもの、――犬なら尻尾を振るところなんだけれど」　睨むような眼つきをしてから、くつくつと口ごもるように笑いだしたが伍一は妙に白けた気もちになってうしろの壁にもたれかかった。",
              "citation": {
                "source": "菎蒻",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ以上は言わん」　泣きつかんばかりだったので、レスブリッジが態度を軟化して、それならと口ごもると叔父が温室を横切り、布覆いの後ろへ消えた。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
