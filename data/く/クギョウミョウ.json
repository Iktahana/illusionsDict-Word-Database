          "literary": [
            {
              "text": "印度で之を五明と申しますが、聲明、因明、醫方明、内明、工巧明、斯う云ふ五種類であります。",
              "citation": {
                "source": "日本國民の文化的素質",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "工巧明が數術に當るのであります。",
              "citation": {
                "source": "日本國民の文化的素質",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは声明とて言語音声に関した一切の科学、医方明とて医学、因明とて論理学、工巧明とて工学、内明とて宗教的科学及び哲学でありますけれどそれをよく取り調べて明らかに通じて居る人はごく少ない。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            }
          ]
        }
