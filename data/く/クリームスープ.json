        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夕食＝トマトクリームスープと、プラム・プディングが、よかった。",
              "citation": {
                "source": "富士屋ホテル",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "大庭を連れて外出、不二アイスの二階で、チキンコロッケとトマトクリームスープ、シュガーコーン、ストロベリーショートケーキ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕、クリームスープにミニツステーキ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事は、トマトクリームスープと舌平目洋酒蒸に、鶏インコゝット。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "終ってニューグランドへ行き、トマトクリームスープに、チキンとヌードルのクリーム煮、それにアイスコーヒーとプディング。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "お粗末なオルドヴルに、クリームスープ、ハンバクステーキにコーヒー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルドヴル、クリームスープ、ビフテキシャリアピン、それにパンケーキスゼット。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "トマトクリームスープ、コールド・ラブスター、ヴィル・ピカタ、ゼリー、満腹。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラスカへ行き、オルドヴル、アスパラガスのクリームスープに、コーンタングとバミセリ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤山と会ひ、食事、にほひがしなくてうまくない、トマトクリームスープ、ピカタ、ピラフにアスパラガス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニューグランドへ行くと、浜田捷彦がゐたので一緒に食事、トマトクリームスープにラヴィオリ・ニコアス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時、ホテルのニューグリルへ屋井と行って、オルドブル、アスパラガスクリームスープ、白魚フライとカネロニー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから堀井とニューグランドへ行き、トマトクリームスープに、ミートボール、スパゲティ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "トマトクリームスープは、何と言っても此処第一、だがあとのペティ・パンと肉鶏の飯は、まづかった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "先へ食事しちまふ、トマトクリームスープにポークチャップ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルドヴルよし、トマトクリームスープよし、ベーキハムよし、ローストビーフよし、アイスクリームよし。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "トマトクリームスープ、こゝのは濃厚だが、まるでトマトジュースを温めたやうで、クリームスープの味はない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
