    "definitions": [
      {
        "index": 1,
        "gloss": "Minister of the Imperial Household",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
