[
  {
    "uuid": "0e2524e4-7d13-5298-83d7-3963c7849f40",
    "entry": "詳しくは",
    "reading": {
      "primary": "くわしくは",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
