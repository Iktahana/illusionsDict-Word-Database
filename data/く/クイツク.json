[
  {
    "uuid": "e2acc331-aabc-5b29-893c-1d81c1343df7",
    "entry": "食いつく",
    "reading": {
      "primary": "くいつく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-カ行",
