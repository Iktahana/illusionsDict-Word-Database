[
  {
    "uuid": "994021de-c2bd-5bdc-bdc0-e5df4d942e7b",
    "entry": "狂おしい",
    "reading": {
      "primary": "くるおしい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
