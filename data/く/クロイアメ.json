[
  {
    "uuid": "e8f404a6-1d29-551a-9bec-8e86692d022d",
    "entry": "黒い雨",
    "reading": {
      "primary": "くろいあめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "black rain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "全身にゾーッと生汗を掻きながら今一度、静かに左右を振返ってみたが、その彼の怯えた視線は、タッタ今通って来た台所の角の、新しい黒い雨樋の処へピタリと吸い寄せられた。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやら雷雨が来そうな模様で、黒い雨雲が湧きだして空を這い、しきりにそのもやもやした輪郭を変えていた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "見上げる軒端を斜めに黒い雨が顔にあたる。",
              "citation": {
                "source": "一夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の巴里は重く曇って、ともすれば黒い雨が通り過ぎる。",
              "citation": {
                "source": "ロウモン街の自殺ホテル",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの家はだだつ広い野原で、蒼黒い雨雲が屋根の代りになるのだよ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "『荒鷲』は、残った第一発動機をうならせながら、黒い黒い雨雲の中へかくれてしまった。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々僕の額から、圧し潰された癇癪が、どす黒い雨雲になつて走り出す、窓から、煙る雨脚を眺めてゐたり眺めてゐなかつたりすると、腐りかけた脊髄を冷いものがタラタラと這ひ滴れて行く。",
              "citation": {
                "source": "海の霧",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「広島と長崎に黒い雨が降って何十万という人間が死んだとよ」「ピカッと光ったら、みんな死んでたそうだ。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "指頭大の黒い雨で、くっついた所は重油か何かのように色がついた。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの爆発直後に生じた魔雲の本態はこれであり、かの大きな黒い雨もこうしてできたものであろう。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "東の方からは黒い雨雲がひろがって来て、時おりその方角から湿っぽい風が吹いていた。",
              "citation": {
                "source": "可愛い女",
                "author": "DUSHECHKA",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りはみぞれのような黒い雨が降っていました。",
              "citation": {
                "source": "随筆　寄席囃子",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い大きな屋根、おなじく黒い雨樋、その雨樋の落ちて来るのをうけた天水桶。",
              "citation": {
                "source": "雷門以北",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達はゲートルに黒い雨合羽を着て、山路を辿り始めた、それは午前一時頃である。",
              "citation": {
                "source": "心霊の抱く金塊",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "六日の午後、河原にふり注いだ大粒の黒い雨に、あなたの小さい屍がたたかれていました。",
              "citation": {
                "source": "いまだ癒えぬ傷あと",
                "author": "――放射線火傷で右手をうしなつた木挽きの妻と河原にうつ伏せて死んでいた幼女に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛をつかって黒い雨合羽に笠をかぶって一生懸命雨の中を働いて居ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "見あげると、青い空に白と鼠色の雲が重なりあい、ひと固まりの黒い雨雲が、南のほうから速い速度でひろがりつつあった。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い雨合羽を頭から被った角助は、後から抱きついた源十のために投げたおされた。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い雨雲がちぎれて飛ぶ間に、月の端が、不意に顔を出すかと思うと、一瞬にまたまっ暗になった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
