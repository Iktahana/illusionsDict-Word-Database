    "definitions": [
      {
        "index": 1,
        "gloss": "to poke one's nose into another's affairs",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いつもお人好しのやつだったから、こうして友人の事件に首を突っ込むなど、あいつらしいな。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "知っていて、陥穽に首を突っ込むにゃ当たらないもんなあ」小倉は行く先を忘れた田舎者のように当惑げにそこへ突っ立っていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がようやく起き上ると、女たちは一つの穴へ首を突っ込むように、ばたばたしながら、椅子の足をひっ掻いていた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "無軌道電車が黄包車の群れを追い廻しながら、街角に盛上った果物の中へ首を突っ込むと、動かなかった。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへまた他のが蹌踉けて来て首を突っ込む。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あと三十分東へ飛んで、そして、太平洋の波間に機首を突っ込むのだ。",
              "citation": {
                "source": "空飛ぶ悪魔",
                "author": "――機上から投下された手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "本棚の中に首を突っ込むようにして本を捜しながら、何かブツブツ独り言をいっていた。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はたかが町方の御用聞で、巾着切や屋尻切を追い廻すのが身上で、大名方の御家騒動に、首を突っ込むような大した働きのある人間じゃございません」　平次はさすがにあわてました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "御落胤殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "お町が可哀想だと思って乗り出したが、――入費は嵩んでも苦しゅうない――てな事を言う武家の紛々なんかに首を突っ込むのは嫌だ」　手の付けようがありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "大村兵庫の眼玉",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間が首を突っ込むほど開けるためには、どうしても三四人の力を協せなければならなかったでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "弥惣の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "事件に首を突っ込むほど分かったのは、まさしく悲劇の瀬戸際、欧州大陸へ流行る勢いだ。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この縁の下は、みんな薪だよ」　蓆を巻いて、床下へ首を突っ込むと、日頃、開墾するうちに心がけて運んだ木の根瘤だの、竹の根だのが、山をなすほど蓄えてある。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "首を突っ込むほどに困惑します。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜伊兵衛が姿を現わすのは分っていたので馬春堂の掛小屋へ首を突っ込むところを、二人一緒に御用にするところだったのが、悠々と万太郎が這入って話し込んでいたため、その機会を逃がしたのみか、またそこを出た万太郎が、袋地の捕物陣へ邪魔をしに来ました。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
