    "definitions": [
      {
        "index": 1,
        "gloss": "painful",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "階段を駆け上がったせいで息が苦しいが、止まるわけにはいかない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "骨折した箇所がズキズキと痛み、眠ることもできないほど苦しい夜を過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "重い病を患い、何ヶ月も苦しい闘病生活を続けている祖父の姿を見るのが辛い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "また他の者たちは、西洋詩の生硬な直訳を思はせるやうな、息苦しい悪い趣味の詩を発表して新らしがつて居た。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "野も山も新緑で、はだかになってしまいたいほど温く、私には、新緑がまぶしく、眼にちかちか痛くって、ひとり、いろいろ考えごとをしながら帯の間に片手をそっと差しいれ、うなだれて野道を歩き、考えること、考えること、みんな苦しいことばかりで息ができなくなるくらい、私は、身悶えしながら歩きました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "インタープリテーションでなく、まづは詩であるためには、苦しいと云へば苦しい、長い道を歩いたことであつた。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も苦しいのは、これが友人との交際に於いて出る場合である。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの睨み合いが苦しいのだ。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうした所は、単に温泉町そのものの気分が田舎めいて陰気くさいばかりでなく、周囲の自然そのものからして、妙に百姓じみて感じが重苦しい。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思うとなんだか呼吸が苦しいようである。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の敷金として、百圓くらゐ用意しなければならぬし、その他家財道具一切を買はなければならぬし、そのためには、どうしても、もう百圓は必要であらうし、とにかく、結婚當時の私には、著てゐる著物と、机と夜具、それだけしかなかつたのであるから、ずゐぶん心苦しいことが多かつた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたおひとりだと、あなただつて、お苦しいでせう？",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と苦しい法螺を吹いた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちよつと座談では言へるのであるが、ことごとしく純文學雜誌に「昨日、朝顏を植ゑて感あり」などと書いて、それが一字一字、活字工に依つて拾はれ、編輯者に依つて校正され、（他人のつまらぬ呟きを校正するのは、なかなか苦しいものである。",
              "citation": {
                "source": "義務",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "惡業の深い一人の作家だけは、どこへ行つても、何を見ても、苦しい。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、このような狭苦しい谷の中で、このような広濶な地を見られようとは思わなかった。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "碁盤の目ほどに窓の多いデパートメント、タンクを伏せたように重っ苦しい大屋根、長方形の箱を、手品師の手際で累積したようなアメリカ式鉄筋コンクリートの高層築造物は、垂直の圧力を通行人の頭上に加えて虚空の「通せん坊」をしあっている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "一行の汽車は、箱根｜火山彙を仰ぎ見て、酒匂川の上流に沿い、火山灰や、砂礫の堆積する駿河｜小山から、御殿場を通り越したとき、富士は、どんより曇った、重苦しい水蒸気に呑まれて、物ありげな空虚を天の一方に残しているばかり。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝苦しい夏の夜も、森と川の面から撫でるように吹いて来る、軽い風で涼しくなった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝苦しい、麹室のようなムンムンする、プロレタリアの群居街でも、すっかりシーンと眠っていた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "かますの乾物のように、痩せて固まった彼の母は、寝苦しいものと見えて、時々溜息をついていた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　暑苦しいために明けっ放した表から、誰かが呼んだ。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどい急坂を上る機関車のような、重苦しい骨の折れる時間が経った。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "喰み出さなくても、暮しは苦しい。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "近在の人らしい両親に連れられた十歳位の水兵服の女の子が車に酔うて何度ももどしたりして苦しさうであるが、苦しいとも云はずに大人しく我慢してゐるのが可愛想であつた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近在の人らしい両親に連れられた十歳くらいの水兵服の女の子が車に酔うて何度ももどしたりして苦しそうであるが、苦しいともいわずに大人しく我慢しているのが可哀相であった。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある時は「あなた、かくしているでしょう、きっとそうだ、あなたそうでしょう」とうるさく聞きながら、余の顔色を読もうとする、その祈るような気づかわしげな目づかいを見るのが苦しいから「ばかな、そんな事はないと言ったらない」と邪慳な返事で打ち消してやる。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "堅苦しいフウケでもなかろう。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼も夜もそのための尽きぬ嘆きに、ああ、わたしは、わたしに残れる僅かないのちの重味にさえ堪え兼ねている」「この堪えられない程、烈しい息切れと、苦しい動悸のする身体。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "病が苦しいから死のうと思うだけだ」「蛙の声が穴の中まで聞えて来る。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、そういう場合に飲もうとする努力は苦しいものですね」　若い獣神はしきりに咳き込んだ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでおれは美しい正方形のつめくさの絨氈の上で夕方までいろいろ踊るといふのはどうだ　あんな単調で暑苦しい蔬菜畑の仕事にくらべていくら楽しいかしれないと考へた。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "選手はじめて、はっとおのれの失敗に気づいて、恥ずかしいとも、くるしいとも、なんとも、どうも話にならない。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "distressing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
