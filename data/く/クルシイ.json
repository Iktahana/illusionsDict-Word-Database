[
  {
    "uuid": "4a542b34-c61e-5caf-943e-c4d06f4b7565",
    "entry": "苦しい",
    "reading": {
      "primary": "くるしい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
