    "definitions": [
      {
        "index": 1,
        "gloss": "camphor tree (Cinnamomum camphora)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
