    "definitions": [
      {
        "index": 1,
        "gloss": "leading a horse, cow, etc.",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
