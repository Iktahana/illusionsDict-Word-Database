        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "パタゴニア人に保護区政策をとれと、アルゼンチン政府と喧嘩をした……」　「知ってますとも。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "パタゴニア人に保護区政策をとれと、アルゼンチン政府と喧嘩をした……」「知ってますとも。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるべくせいの似たような人と、二人で一つずつかついで下さい。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭脳の働きが外方へ向くのを止められているので自然に内側へ向かって行くせいだと言われる。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせいい加減なところに埒を造って、そこから先にはなかなか出てこようとはしない。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　傲然としてしかも寂しく高らかに、（はは、はは、はははは、）（……………………）（疾くせい。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……学円　（伸上り納戸越に透かして見て）おい、水があるか、蘆の葉の前に、櫛にも月の光が射して、仮髪をはずした髪の艶、雪国と聞くせいか、まだ消残って白いように、襟脚、脊筋も透通る。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "食べさしておくせいだといえば、私ゃ一人で針仕事をしても、くらしかねることもないわ。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "屑ものを焼くせいだろうか。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "われはもくせい、ほのかなる花のさだめに、目見しらみ、うすらなやめばあまき香もつゆにしめりぬ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "もくせいもくせいがにほふよ。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにかやるせないようで、そのくせいい気持だ。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "おくっていかないわけは、あれからずっとごてんづとめで、たくさんにたべものをいただくせいか、ひどく頭痛がしていたからです。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "本気になって相手をさがせと厳しく云われたので、その後も怠らずに毎晩出あるいているが、月夜のつづくせいか、この頃はちっとも出逢わないで困っている」「それは御苦労さまでございます。",
              "citation": {
                "source": "半七捕物帳",
                "author": "槍突き",
                "note": "青空文庫"
              }
            },
            {
              "text": "その何物かは葉子のすぐ手近にありながら、しっかりとつかむ事はどうしてもできず、そのくせいつでもその力の下に傀儡のようにあてもなく動かされていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも、今からあんなちっちぇい娘を予約でもしておくんでげすかい」「変なことばっかりいうが、そんな小娘でもたずねてきたのかい」「来ただけじゃねえんだから、あっしゃみずくせいっていってるんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "並んでいっぷくせい」　右へ二人、左へ三人、行く手を塞いだ四五人に、あっさり揚心流当て身の拳あてて片づけながら道を開いておくと、「女つづけッ」　にったり打ち笑みながら、さッと駈け出しました。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "行け、行け、早う帰って忠義つくせい」　皮肉にあしらいながら馬上の二人をやりすごしておくと、五十三次名うての街道をわがもの顔に、のっしのっしと道を急ぎました。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "夥しい会合、催し、年中行事　泰平が続くせいか、いろんな芸術的の催しが盛になった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、くせいのもあるさうだ。",
              "citation": {
                "source": "ある日の印旛沼",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを解きにかかる皆さんは、名探偵の明智小五郎か、シャーロック　ホームズか、それともファイロバンズかエラリー　クヰーンか、とにかくせいぜい智能をふるはれたい。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを解きにかかる皆さんは、名探偵の明智小五郎か、シャーロック・ホームズか、それともファイロバンズか、エラリー・クイーンか、とにかくせいぜい智能をふるわれたい。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "格之介は、縁側の柱にもたれて、皆の話をきかぬような顔をしながら、そのくせいちばん気にしてきいていた。",
              "citation": {
                "source": "乱世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となくせいせいした気持なんだ。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何を措いても、早くせい！",
              "citation": {
                "source": "西湖の屍人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんといっても気がしまっていいのは十月頃、恰度、きんもくせいが匂うような頃は一番頭がすっきりして身も軽うなる心地がすることです。",
              "citation": {
                "source": "京の夏景色",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで、絵の具の滓ばかり食つて生きてゐるやうな寒子には、耳から来るパリのたそがれの風景はたまらなくせいせいと快適なものであつた。",
              "citation": {
                "source": "瑪瑙盤",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "せい子は情夫富岡某を頼つて上京中、あとより向井が呼び戻しに行つたが、せい子が復縁を拒絶した為、十二日風呂へ行くせい子を強迫して、自分の部屋へ連れ込み、またも復縁をせまつて口論となり、かつとなつて、手拭でせい子を絞殺し、自首して出たもの。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓなんか引いてしまったのはさびしいな』『そのくせいる妓はいつまでもいるんですけどもね』　こんなことをいって、Ｍはそこにあった紙刷物を引寄せた。",
              "citation": {
                "source": "日本橋附近",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
