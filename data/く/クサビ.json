        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "生活に打ち込まれた一本の楔がどんなところにまで歪を及ぼして行っているか、彼はそれに行き当るたびに、内面的に汚れている自分を識ってゆくのだった。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた一本の楔、悪い病気の疑いが彼に打ち込まれた。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つの溪の間へ楔子のように立っている山と、前方を屏風のように塞いでいる山との間には、一つの溪をその上流へかけて十二｜単衣のような山褶が交互に重なっていた。",
              "citation": {
                "source": "蒼穹",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう際にはセリュローズばかりでできた書籍は哀れな末路を遂げて、かえって石に刻した楔形文字が生き残るかもしれない。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも父が居なくなると、家の中は楔がゆるんだやうになつた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護婦は大きな磁盆にしこたま大小のメス、鋏、鋸、楔、止血ピンセット、鉗子、持針器の類を列べたのを持つて來た。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫れは鋸の切れ目に鐵の楔子をさし入れて、椀状の頭蓋を離すために、木の槌で輕くたゝく音だ。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れは自分の頭にその楔子をさし込まれたやうな苦痛を感じ始めた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "上から覗いて、山の崖が處々で松の姿を楔に入れて、づツしりと壓へて居る。",
              "citation": {
                "source": "月夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十人に近い被告が、ばら／＼になつて思念し行動した個々の犯罪事実を連絡のあるもの、統一のあるものにして了はうとするには、どこにか総括すべき楔点を先づ看出さなければならない。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "確かに今乗った下らしいから、また葉を分けて……ちょうど二、三日前、激しく雨水の落とした後の、汀が崩れて、草の根のまだ白い泥土の欠目から、楔の弛んだ、洪水の引いた天井裏見るような、横木と橋板との暗い中を見たが何もおらぬ。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕の家内は金魚ですよ」　酔いに紛れて、そういう人事には楔をうっておくつもりで、復一はこういうと、養母は「まさか――おまえさんはいったい子供のときから金魚は大して好きでなかったはずだよ」と云った。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は、粘土の板に硬筆をもって複雑な楔形の符号を彫りつけておった。",
              "citation": {
                "source": "文字禍",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、その原因として、中間に、こゝにいる葛岡さんというものを挟みはしましたが、しかし、これは気の毒ながら、挽木の鋸目に入れる楔のようなものです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭を楔のように細い竹と竹との間に押し込んだものと見えて、籠は一寸見た所では破れてはいない。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の島に於てさえ半ば忘れられた楔形文字的典礼。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは楔の如く車の間に介まりて、後へも先へも行くこと叶はず。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "或日彼は木の株へ唐鍬を強く打込んでぐつとこじ扛げようとした時鍛へのいゝ刃と白橿の柄とは強かつたのでどうもなかつたが、鐵の楔で柄の先を締めた其の唐鍬の四｜角な穴の處が俄に緩んだ。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉈の刀背で鐵の楔を打ち込んでさうして柄を執つて動かして見た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷底へついて見ると紐のちぎれさうな脚袢を穿いた若者が炭竈の側で樫の大きな榾へ楔を打ち込んで割つて居るのであつた。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "榾を運んで仕舞つたら楔で割つたのを二本三本づつ藤蔓の裂いたので括りはじめた。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして其瞬間に今まで動搖して居た心が楔子を打ち込んだやうにきつとした。",
              "citation": {
                "source": "商機",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しながら其一片と雖此を楔子に削る時大厦の柱をも堅固にすることが出來る。",
              "citation": {
                "source": "商機",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "その農家に楔でも打ち込んだやうに、小さな飯場が一つ建つてゐた。",
              "citation": {
                "source": "万福追想",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、傍にゐました、樵夫の子供は『占た』と、切り口にさしいれてあつた楔を手早く抜きましたので、野牛は切口に舌をはさまれてしまつたのです。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで祖母と母との手前に、暗に「善良な学生」を取りつくろひ、同時に自らの怠惰を責める楔とした。",
              "citation": {
                "source": "祖母の教訓",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は又詩にも勝った表現の楔子を音楽に於て見出そうとするものだ。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠直卿は茶臼山に駒を立てていたが、越前勢の旗差物が潮のように濠を塞ぎ、曲輪に溢れ、寄手の軍勢から一際鋭角を作って、大坂城の中へ楔のごとく食い入って行くのを見ると、他愛もない児童のように鞍壺に躍り上って欣んだ。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "門も板塀も昔の方が今のより古くさびていたように思われ、それから門から玄関までの距離が昔はもっと遠かったような気がする。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような官能の刺激を通じて、われわれ祖先以来のあらゆるわびしくさびしい生活の民族的記憶がよびさまされて来る。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
