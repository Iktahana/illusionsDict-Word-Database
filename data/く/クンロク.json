    "definitions": [
      {
        "index": 1,
        "gloss": "ozeki ranked wrestler unable to live up to the expectations of his rank",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
