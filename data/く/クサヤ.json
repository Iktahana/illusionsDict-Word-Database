        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（三）　土神の棲んでゐる所は小さな競馬場ぐらゐある、冷たい湿地で苔やからくさやみじかい蘆などが生えてゐましたが又所々にはあざみやせいの低いひどくねぢれた楊などもありました。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三）　土神の棲んでいる所は小さな競馬場ぐらいある、冷たい湿地で苔やからくさやみじかい蘆などが生えていましたが又所々にはあざみやせいの低いひどくねじれた楊などもありました。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が外へ出て迫つた感情をぴつたり並べたところで、一人の男がそゝくさやつてきた。",
              "citation": {
                "source": "白いシヤツの群",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「可哀相に、遠くさやらねえで、森山の且那のどこさ、金をやる代りに、働きにやるってようなごと出来ねえのがえ？",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわれて、あっしも急にげっそりとしましたから、さっそく用いましょうが、なんかお菜がござんしたかね」「くさやの干物があったはずだから、そいつを焼きなよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あきれちまうな、きのうくさやの干物で奈良づけをたべるまでは、とても調子のいいだんなでしたが、あれからこっち、また少し気が変のようじゃござんせんか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "くさやの干物に新口ができたとかいう評判ですが、そのことですかい」「しようのねえ風流人だな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "くさやの干物とまちがえるようなおにいさんに手の出るような安い品じゃねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちも珍しくさやいだ気持で、あれこれ案を出しあった。",
              "citation": {
                "source": "若い母親",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝の草花――薊やらみつくさやら――を採つてきて壺に投げ※した。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうはお前、どうしてそんなにのろくさやってるのさ！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "松魚の鹽辛くさからざるにあらず、くさやの干物最も甚し。",
              "citation": {
                "source": "肉食之説",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "まづそれまで、しばらくさやうなら。",
              "citation": {
                "source": "虹猫の大女退治",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "淵も瀬も清くさやけし。",
              "citation": {
                "source": "和歌の発生と諸芸術との関係",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "聴水忽ち眼を細くし、「さても甘くさや、うま臭や。",
              "citation": {
                "source": "こがね丸",
                "author": "巌谷小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "大ぶりな花弁の新鮮な重りを眺めているうちにその花びらの軟くさやかな裡に顔をうずめてしまいたいような心持になって来た。",
              "citation": {
                "source": "日記",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々私の家へ来ては、婆やのように、おばさん／＼と、くさやで、お茶漬を一杯呼んで下さいと言って、自家に無ければ、自分で買って来て、それを私には出来ないから、おばさんに焼いて、むしってくれって、箸を持ってちゃんと待っているのよ。",
              "citation": {
                "source": "別れたる妻に送る手紙",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそれらの一点に於て、殆んど信じ難い唐突な一瞬間に、盛夏の鮮やかな風物が、耀やく屋根が、懶うい径が、鳴きしぐれる蝉の音が、頭上に近くさやさやと鳴る微かな風が――忽ち展かれた窓のやうに、そして忽ち閉ぢられて行く窓のやうに、爽やかに滲み溢れて――そして又、闇のさ中へ還へるのである。",
              "citation": {
                "source": "蝉",
                "author": "――あるミザントロープの話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時の如きは、日本橋からくさやの干物、鱈の切身というようなもの一包を買い込んで、大袋の中へ投げ込み、たしかに持参した筈のがない、東京へ置き忘れて来た筈はないのに幾ら探してもない。",
              "citation": {
                "source": "百姓弥之助の話",
                "author": "第一冊　植民地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "くさやの干物と牡丹餅じゃ勝負になるまい。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "杯盤狼藉酒池肉林――というほどの馳走でもないが、沢庵の輪切りにくさやを肴に、時ならぬ夜ざかもりがはずんで、ここ離庵の左膳の居間には、左膳、源十郎、仙之助に与吉。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "家路を急ぐ鳥追いの破れ三味線、早い夕餉の支度でもあろうか、くさや焼く香がどこからともなく漂っていた。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "槍祭夏の夜話",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳の木立軽くさやぎおとなへ。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりぐらしの気らくさや、やとい人を遠ざけさえすれば、奥のひと間にいるのは、自分とあんどんだけ。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれくさや霜の花さく高の原　例のごとく東南の山原を一里半ばかり進んである山の麓の三軒家に着きました。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの御顔はまぎれもなくさやかですが、背景が全くないのは変に切ない気分よ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくさやみぬ藪鶯も啼き出でよ　　　　　　　　　　　栄太郎へ梅の戸へもと吉原の女客　　　　　　　　　　　せい子へ　そして、善孝へは、私の句でない、それは橘曙覧の歌の。",
              "citation": {
                "source": "紅梅の客",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "政も同時に「これはくさやの」と云いかけ、文次が急に口をつぐんだので、彼もあとは云わずに文次を見た。",
              "citation": {
                "source": "あすなろう",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "片向きに波をうって、光りながら、互いになにごとか囁き交わすかのごとく、やみまなくさやさやと揺れそよいだ。",
              "citation": {
                "source": "葦",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おみやのようすはすっかり変っており、それまでのじだらくさや、嬌めかしさはまったくみられず、兄である自分に対しても、はっきりと眼をあげてものを云った。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第四部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
