    "definitions": [
      {
        "index": 1,
        "gloss": "offering (e.g. to the gods)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今年の秋祭はわが帰省中にとの両親の考えで少し繰り上げて八月某日にする事ときめてあったが、数日来のしけで御供物肴がないため三日延びた。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "置所から色々の供物を入れた叺を持ってくる。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番大きな下の壇へは色々な供物の三宝が並べられる。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぼみと、それを包む薹とは、赤と白とを市松格子形に互層にして、御供物の菓子のように盛り上っている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　私が肉體を無視してそれを魂の供物にするやうな者でないことは、あなたも御存知でせう。",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃はわしの祭にも供物一つ持って来ん、おのれ、今度わしの領分に最初に足を入れたものはきっと泥の底に引き擦り込んでやらう。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃はわしの祭にも供物一つ持って来ん、おのれ、今度わしの領分に最初に足を入れたものはきっと泥の底に引き擦り込んでやろう。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度お供物にしたのですよ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "刻苦勉励、学問をも仕り、新しき神道を相学び、精進潔斎、朝夕の供物に、魂の切火打って、御前にかしずき奉る……媛神　私は些とも頼みはしません。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "初穂、野菜、尾頭付の魚、供物がずつとならんで、絵行燈や提灯や、色色の旗がそこ一杯に飾られて、稍奥まつた処にある祠には、線香の烟が濛として、蝋燭の火がどんよりちらついて居る。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "十「小田原の神に、霊がおあんなさればなおの事、捧げられる供物、お初穂が、その品物のために、若い娘の身に、過失のあることをお望みはなさりはせん。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お供物だと血迷っての、犬の首、猫の頭、目を剥き、髯を動かし、舌をべらべら吐く奴を供えるわ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの、雪を束ねた白いものの、壇の上にひれ伏した、あわれな状は、月を祭る供物に似て、非ず、旱魃の鬼一口の犠牲である。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これは稲荷殿へお供物に献ずるじゃ。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "都會に於ても同じやうに、かうした神神に供物を捧げる人人は、概ね皆社會の下層階級に屬するところの、無智で貧しい人人である。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿五日、壬子、陸奥国平泉保の伽藍等興隆の事、故右幕下の御時、本願基衡等の例に任せて、沙汰致す可きの旨、御置文を残さるるの処、寺塔年を追ひて破壊し、供物燈明以下の事、已に断絶するの由、寺僧各愁へ申す、仍つて広元奉行として、故の如く懈緩の儀有る可からざるの趣、今日寺領の地頭の中に仰せらると云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はあの人に説教させ、群集からこっそり賽銭を巻き上げ、また、村の物持ちから供物を取り立て、宿舎の世話から日常衣食の購求まで、煩をいとわず、してあげていたのに、あの人はもとより弟子の馬鹿どもまで、私に一言のお礼も言わない。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "パラオの神々の間では、善神は供物を供えられることが殆ど無い。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　憚り多いが、霊容の、今度は、作を見ようとして、御廚子に寄せた目に、ふと卯の花の白い奥に、ものを忍ばすようにして、供物をした、二つ折の懐紙を視た。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "堂にお供物の赤飯でもありはしないか、とそう思って覗いて、お前を見たんだ、女じゃ食われない、食いもしようが可哀相だ、といって笑うのが、まだ三十前、いいえ二十六七とも見える若い人。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "供物が出来たら、港の口へ幕を張って、準備をしてくれ」「よろしゅうございます」　清吉が往こうとすると権兵衛が留めた。",
              "citation": {
                "source": "海神に祈る",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「待て」「へい」「それから、供物の台は、沖の方へ向けて、つまり海の方へ向けるぞ」「承知しました」「普請初めの時のようにすればええ。",
              "citation": {
                "source": "海神に祈る",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "森戸家のほろびたのは三月二十日であるので、毎月の二十日には供物をささげ、家族一同がその祠に参拝するのを例としていた。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハース氏に聞いてみると、これは純粋なドイツの古習で、もとはある女神のためにささげた供物だそうな。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る農婦の、一昼夜も断続していた胃痙攣が、その御供物の一つの菓子でぴったりと止んだからだった。",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神の力だけを信じている農村の病患者を救うには、竹駒稲荷大明神の御供物、お神酒と言って医薬を施すより他には途がないものと思ったからで御座います。",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "被告は一度として貧しい祈祷者に薬物を混入した供物を与えた事実が無いではないか。",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご冥加でして、へい、どうぞ、お初穂を……」　お絹が柔順に、もの軟に取上げた、おでんの盆を、どういうものか、もう一度彦七がわざとやけに引取って、「飛んだお供物、狒々にしやがる。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "５向ふに、水車が、見えてゐます、　　苔むした、小屋の傍、ではもう、此処からお帰りなさい、お帰りなさい　　僕は一人で、行けます、行けます、僕は、何を云つてるのでせう　　いいえ、僕とて文明人らしくもつと、他の話も、すれば出来た　　いいえ、やつぱり、出来ません出来ません。",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "すすきの木菟は旬はずれで、この頃はその尖ったくちばしを見せなかったが、名物の風車は春風がそよそよと渡って、これも名物の巻藁にさしてある笹の枝に、麦藁の花魁があかい袂を軽くなびかせて、紙細工の蝶の翅がひらひらと白くもつれ合っているのも、のどかな春らしい影を作っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
