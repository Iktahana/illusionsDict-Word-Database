    "definitions": [
      {
        "index": 1,
        "gloss": "black vinegar, usu. produced from unpolished rice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "田舎のあぜみちに坐つてゐると、おほなみのやうな土壌の重みが、わたしの心をくらくする、土壌のくさつたにほひが私の皮膚をくろずませる、冬枯れのさびしい自然が私の生活をくるしくする。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "榛名富士その絶頂を光らしめとがれる松を光らしめ峰に粉雪けぶる日も松に花鳥をつけしめよふるさとの山｜遠遠にくろずむごとく凍る日に天景をさへぬきんでて利根川の上に光らしめ祈るがごとく光らしめ。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は煤煙でくろずみ、街の兩側には、無限の煉瓦の工場が竝んでゐた。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は煤煙でくろずみ、街の両側には、無限の煉瓦の工場が並んでゐた。",
              "citation": {
                "source": "散文詩集『田舎の時計　他十二篇』",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "打水した庭にくろずんだ鞍馬石が配置よく置き据えられ、それには楚々とした若竹が、一々、植え添えてあります。",
              "citation": {
                "source": "茶屋知らず物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、日の暮、寒靄に人ゆき消え、立木くろずみ、公園の辻、ポスト赤し。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "青く澄みわたつた月あかりの空の下に、古風な芝居の書割のやうに屋根がくろずんで見え、明るい窓が大きな行灯のやうに更けてゆく夜気の中にひかつてゐた。",
              "citation": {
                "source": "茜蜻蛉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "年来生活の活々した流れや笑を失った家と庭にはどこやらあらそえない沈滞が不健康にくろずみ澱んでいる。",
              "citation": {
                "source": "牡丹",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日みれば、明治の四十年代という時代の知識人が、一般にはまだ低くくろずんで眠らされていた女の世界から、僅かに誘い出した一人二人の女に、どれ程強烈な色と、角度を求めて、それを自身の趣味に誇張して創ったかと、おどろきを与えられる。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この旅館のおもてつきが又、いかにもその内部にふさわしく、無闇に間口ばかり広い二階｜建で、一階の外壁は漆喰も塗らないで赤黒い煉瓦が剥き出しになっているが、もともと汚ならしい煉瓦が烈しい天候の変化に逢って一層くろずんでいる。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "水は、はるかな海も、目の前の川も、一様にくろずんでいる。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "霜にうたれてちりちりと枯れはてた草木の上に、雪はくろずむほど降りこめた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "年処を経たオンコの珍しい巨大なのが一本、あたりの濶葉樹のなかにそびえ、緑というよりはむしろ、重くくろずんだまッ黒なときわ葉を密生させ、すッくと原野を睥睨していた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "両岸にはくろずんだ古い家々が音もなく立ちならんでいた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その紙のうえには、なんだかくろずんだ粉が、ほんの少量、ほこりのようにのっていた。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "見わたすかぎり、野山は黄色く、とりいれのあとのたんぼはくろずみ、空は雲一つなく晴れわたっていました。",
              "citation": {
                "source": "山の別荘の少年",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊主頭の上には、見る見るくろずんだきたないしみが目立ってきた。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "煤煙に、頬がくろずんでいた。",
              "citation": {
                "source": "ふるさとに寄する讃歌",
                "author": "夢の総量は空気であった",
                "note": "青空文庫"
              }
            },
            {
              "text": "煤煙に、頬がくろずんでゐた。",
              "citation": {
                "source": "ふるさとに寄する讃歌",
                "author": "――夢の総量は空気であつた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは遥かな海であつた、已にとつぷりと暮れた東南の紫は次第に深くくろずみ渡り、西方の水平線にはわづかに残る薄明がひろい寂寥を放つてゐたが、そのとき、深くうなだれた一人の男が永遠に帰らんとするものの如く、足を速めて西へ西へ海原を歩く像を見出してゐた。",
              "citation": {
                "source": "黒谷村",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、彼は雲をとおして、はるかの下に、くろずんだものを見つけました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴンドラの中には飛びちった血の痕がもうくろずんでいた。",
              "citation": {
                "source": "空中漂流一週間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "濁れる鈍の水脈くろずむひき潮に、堀江のわびしらや、そこれる水脈のかげ。",
              "citation": {
                "source": "有明集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "濁れる堀江川くろずむ水脈のはて、入海たひらかにかがやく遠渚。",
              "citation": {
                "source": "有明集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の下の男が立っている足もとの地面には、白や、紅や、青や、いろいろの草花が、月の光を受けてくろずんで咲いて、香っていました。",
              "citation": {
                "source": "月夜と眼鏡",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の下の男が立っている足もとの地面には、白や、赤や、青や、いろいろの草花が、月の光をうけてくろずんで咲いて、におっていました。",
              "citation": {
                "source": "月夜とめがね",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつに不思議なこともあればあるもので、主水正が、上の布を取りのぞくと、時代がついてくろずんだ桐の箱が出てきた。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "（船は南のくろずんだ海上を走り、暮れがたの暑さはなお消えず、雷鳴のひびく時に雨をもたらし、涼しげな月が帆柱の上にかかったのであった。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしのこれまでの経験ではいつも二日か三日くらゐ逗留してゐて、そしてぬけて出るのであつたが、かうして落ちついてゐるうちに、古い人情のこだはりが何の刺戟や新しみなくくされかかつて、妙にくろずんだ柿のしぶのやうにわたしの心を染めてくるのに、物憂いながらわたしは気づいてゐた。",
              "citation": {
                "source": "故郷を辞す",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは頭に記して一等賞は赤毛さんとしるし、雨寒い鷄頭のくろずむ庭を見てゐたとき、突然母屋のわたり廊下を來るたまさんのすがたを眼にいれた。",
              "citation": {
                "source": "めたん子傳",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
