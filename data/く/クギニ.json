        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "白い着物が、くぎにかかっています。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い上着も、くぎにかけてあります。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとぶきみなことか、その太い杉の赤茶けた幹の腹には、手足そろったわら人形が、のろいのあのわら人形が、両足、両手、胸、首、頭と、七本の三寸くぎに打ちえぐられて、無言のなぞと、無限の秘密をたたえながら、ぐさりとくぎづけになっていたからです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつを屋根うらべやにもっていって、大きなくぎにかけて、なかに水をつぎこんでみてくれ。",
              "citation": {
                "source": "森のなかの三人の小人",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "てんでんにはいって来ると、ヴァイオリン、ハープ、ふえなど自分の楽器を寝台の上のくぎにかけた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてみんなは点燈所にはいって、ランプをくぎに引っかけた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ」「まあ、シュリオさんは、水で死にましたよ……」「ええ、水で死んだ」「そう、あの人は水門に落ちて、くぎにひっかかって死んだのだ。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋは絵の一枚を壁からはずして、手紙をそのくぎにかけた。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに井上少年がかくれているともしらず、その男は、いまぬいだカニ怪人の衣装を、おしいれの中のくぎに、ひっかけて、またドアをしめてしまいました。",
              "citation": {
                "source": "妖星人Ｒ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの覆面が、やはり同じくぎにかけてあったのです。",
              "citation": {
                "source": "大金塊",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　小林君は、懐中電灯をポケットにおしこみ、大くぎに手と足をかけて、天井によじのぼりました。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭にめんした窓に走りより、そこに出ているくぎに、帯のはじをひっかけました。",
              "citation": {
                "source": "魔法人形",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女はくぎにひっかけた帯をつたって、庭へおりていきます。",
              "citation": {
                "source": "魔法人形",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
