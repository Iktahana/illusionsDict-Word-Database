        "examples": {
          "standard": [
            {
              "text": "健康食品としてクロレラを毎日摂取している人が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "クロレラは、豊富な栄養素を含む微細藻類の一種である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最近の研究で、クロレラの様々な健康効果が注目されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それは、東大のＴ教授のクロレラという藻の研究である。",
              "citation": {
                "source": "科学は役に立つか",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ教授のクロレラの研究は、日本の新聞にもたびたび報道されたことであるから、詳しい説明をする必要もなかろう。",
              "citation": {
                "source": "科学は役に立つか",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作用の一番強いのは、クロレラという緑藻で、日光が十分与えられると、一時間に自分の体積の五十倍の酸素をつくる。",
              "citation": {
                "source": "宇宙旅行の科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
