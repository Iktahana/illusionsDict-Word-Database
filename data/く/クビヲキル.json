[
  {
    "uuid": "7be5b9f5-1c8e-5f9a-94a9-627842ba220d",
    "entry": "首を切る",
    "reading": {
      "primary": "くびをきる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ラ行"
      ],
      "ctype": null,
