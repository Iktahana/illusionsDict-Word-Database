    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to fire from a job",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "警察ではシュッポンと首を切るぞ。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕でも太股でも手ごたえが変らん位で、首を切るとチャプリンと奇妙な音がして血がピューと噴水のように吹出しながらたおれる。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "合法的に出ている文学新聞を読んだからといって首を切る位だ。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "『宣しい』侍が長い刀をぬいて云った、――『これからお前の首を切る。",
              "citation": {
                "source": "術数",
                "author": "DIPLOMACY",
                "note": "青空文庫"
              }
            },
            {
              "text": "首を切る或は切られることが、首筋を洗って云々の言葉で表現されるには、かかる風習の裏付けがあって始めて可能であろう。",
              "citation": {
                "source": "風俗時評",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の神父は刑吏達に感謝の言葉を述べ、彼等の首を切る筈の刀を借り受けて押しいただいたのち、各々片手にはロザリオを片手には点火した蝋燭を捧げて、ナバレテは一刀のもとに首を刎ねられ、エルナンドは第一撃で耳の附根まで切られたが、立ち上つて天の方を望まうとして、第三撃で倒れた。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、首が落ちてからでも二足ぐらゐ歩けるだらう、といふぐらゐのことは言ひ張るかも知れぬが、そこからイキナリ、ぢやお前の首を切るから歩いてみろ、と言ふのは話が無茶だ。",
              "citation": {
                "source": "五月の詩",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天誅」とはどういうわけかと降蔵が尋ねると、天誅とは首を切ることだと浪士が言って見せる。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "『それから、パーシウス、ゴーゴンの首を切る時、その形を害うようなことのないように、ばっさりと、きれいに切るように気をつけてくれ。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "『今だ、』とクイックシルヴァは、パーシウスの傍を飛び廻りながら小声で言いました、『今こそ君がゴーゴンの首を切る時だ！",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをこゝで首を切るんでしたら他の職工が怒り出しまつせ！",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほうで、なんとかなる……首を切るなら切れ。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは実は私が見ておると中国の政治家というのは役人になるとよく人の首を切るが、失脚するとスグにお寺にはいって南無阿弥陀仏を唱えて居士になる、ということをいうたことをとりあげて、書いて呉れたものらしいですが、この書には魯迅さんが拇印を押して呉れてあるのです。",
              "citation": {
                "source": "魯迅さん",
                "author": "内山完造",
                "note": "青空文庫"
              }
            },
            {
              "text": "暇が出来たからといって、雇人の首を切るわけにもいかない。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりや、臨時工ばつかりにしときや、首を切るにもアツサリ切れるし、退職手当もチヨツピリで済むし、待遇からすべて、会社にや都合が良いだらうさ。",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "名校長が無暗に首を切る筈はない」「すると僕が切られたのは当然だと言うのかい」「先ずその辺だろう」「文句はあるけれど、喧嘩はしない。",
              "citation": {
                "source": "首切り問答",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "源太郎の首を切る位のことは、本當に一擧手一投足の勞だつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "御落胤殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "「右手に持つた出刄庖丁で、右手首を切る筈はない」　平次のさう言ふ言葉に力を得たものか、「お燗番の卯八さんが、碇綱を切つて投げた庖丁が當つたんです」　お蔦は顏を擧げてはつきり言ふのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "笑ひ茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "源太郎の首を切るぐらいのことは、本当に一挙手一投足の労だったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "御落胤殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "「右手に持った出刃庖丁で、右手首を切るはずはない」　平次のそう言う言葉に力を得たものか、「お燗番の卯八さんが、碇綱を切って投げた庖丁が当ったんです」　お蔦は顔を挙げてはっきり言うのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "笑い茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうだ進藤、あすはいよいよ、泉田筑後夫婦を小塚ガ原にひきだして首を切るのだ。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが、どうもなア、わしはブレインが彼の首を切る事が出来たかどうかが疑わしいんでな」「なぜですか？",
              "citation": {
                "source": "秘密の庭",
                "author": "THE SECRET GARDEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり第三者のものをごっそり奪い、首を切るけど、キミの喉は切らせないという同盟だな」　デンやハウスマンが連中を警戒させているわけじゃない。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "必ずしも首を切る必要はなかったかも知れない。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "何らおかまいなしに、今日はこちらの首を切り、明日はあちらの首を切る。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月革命後、人はもはやグレーヴの刑場で首を切ることをあえてしかねたし、恐れていたし、卑怯だったので、次のようなことがなされた。",
              "citation": {
                "source": "死刑囚最後の日",
                "author": "LE DERNIER JOUR D'UN CONDAMNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その場合に諸君は、彼の首を切ることが彼だけしか傷つけないと思うのか。",
              "citation": {
                "source": "死刑囚最後の日",
                "author": "LE DERNIER JOUR D'UN CONDAMNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼を殺すことによって諸君は彼の全家族の首を切る。",
              "citation": {
                "source": "死刑囚最後の日",
                "author": "LE DERNIER JOUR D'UN CONDAMNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳧さんは又○○紡績の人事課を背負って立つ老武者、首を切るのが半商売の人だ。",
              "citation": {
                "source": "負けない男",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「手首を切るのです」「あ、そうか」「手首を切って、その手首を湖のなかにつけておけば、血は流れ出て湖に吸い取られ、死にます」「死んだあと、そのカヌーをどうやって桟橋まで戻すの？",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
