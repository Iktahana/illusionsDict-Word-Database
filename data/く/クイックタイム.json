          "literary": [
            {
              "text": "ところが一九九二年一月になって、動画をマックで扱うクイックタイムという技術が登場してくると、レーザーディスクの存在意義はまた一段と薄れました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このクイックタイムの登場と前後して、ボイジャーはエキスパンドブックの刊行を始めます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "動画を扱う規格としてアップルが打ち出したクイックタイムを、こいつで幅広く生かそうという魂胆だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
