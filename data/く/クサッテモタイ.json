        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "腐っても鯛、間違っても、御用武士などにはおなりなさるなよ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（今こそ私娼でおちぶれてはいるが、昔は吉原の花魁だ、腐っても鯛、上玉だ。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腐っても鯛という諺はあるが、いかになんでもあゆである。",
              "citation": {
                "source": "インチキ鮎",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "三遊派という腐っても鯛の大きな大きな屋体骨を背負って立つには、あまりにも自分というものが非力過ぎた、貧弱過ぎた。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「呆気でも佐賀のもん、腐っても鯛の魚でござッす」　とお峯さんが加勢に入った。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
