[
  {
    "uuid": "bfe84edf-6f70-5270-95e0-ea58c8592f03",
    "entry": "狗肉",
    "reading": {
      "primary": "くにく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
