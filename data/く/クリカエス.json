    "definitions": [
      {
        "index": 1,
        "gloss": "to repeat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "科学者の仕事の生命は人の実験を繰り返す事でないと同様に画家の価値も不断に自分の「実験」を考えながら進んで行くところにあるのではあるまいか。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何から何までべた一面に書いたといふのではなくて、これにはプルウストの方法といふものがあつて、それによつて僕達は恰度經驗を二度繰り返すやうな思ひをさされるのだ。",
              "citation": {
                "source": "「親近」と「拒絶」",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "フリイデリイケはぼんやりした笑顔をしていつもこんな場合に繰り返す話をしてゐる。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると鐘がそれを更らに繰り返すのだつた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "一定の刺激に反応してそれに相当する一定の動作を繰り返すだけである。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史は繰り返すとすれば今に貴婦人たちやモガたちが等身大のリボン付きのステッキにハンドバッグでもつるしたのを持って銀座を歩くようになるとおもしろい見物であろう。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "目をあいたり閉じたり、舌を出したり引っ込ませたりするような簡単な動作を単調に繰り返すだけである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私はこれらの謎のやうな詩を總括して再びさきの獨斷を繰り返す。",
              "citation": {
                "source": "詩集『戰爭』",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「チュクチュクチュク」と始めて「オーシ、チュクチュク」を繰り返す、そのうちにそれが「チュクチュク、オーシ」になったり「オーシ、チュクチュク」にもどったりして、しまいに「スットコチーヨ」「スットコチーヨ」になって「ジー」と鳴きやんでしまう。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鳴き声は自分の経験した場合ではいわゆる「テッペンカケタカ」を三度くらい繰り返すが通例であった。",
              "citation": {
                "source": "疑問と空想",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には三声のうちの終わりの一つまた二つを「テッペンカケタ」で止めて最後の「カ」を略することがあり、それからまた単に「カケタカ、カケタカ」と二度だけ繰り返すこともある。",
              "citation": {
                "source": "疑問と空想",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この船の航海中に遭遇したいろいろな困難のエピソードについてはすでに新聞雑誌にかなり詳しく紹介されたからここに繰り返すまでもない。",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもし自然の歴史が繰り返すとすれば二十世紀の終わりか二十一世紀の初めごろまでにはもう一度関東大地震が襲来するはずである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実験科学では同じ実験を繰り返すことができるからまだいいとしても、天然現象を対象とする科学では、一度取り逃がした現象にいつまためぐり会われるかもわからないという場合がはなはだ多い。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "関東震災の損害がいかに大きくてもそれは八十年か百年かに一回の出来事であるとすれば、これを年々根気よくこくめいに持続し繰り返す火事の災害に比すれば、長年の統計から見てはかえってそれほどのものではないと言われよう。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその年以来他の草花は作るが虞美人草はそれきり作らないので、この無慈悲な花いじめを繰り返す機会に再会することができない。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくするとまた煙突の梯子へもどって来てそうして同じ遊戯を繰り返す。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "内蔵助が「目的はたった一つ」という言葉を繰り返す場面で、何かもう少しアクセントをつけるような編集法はないものかと思われた。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "理屈はぬきにして古今東西を通ずる歴史という歴史がほとんどあらゆる災難の歴史であるという事実から見て、今後少なくも二千年や三千年は昔からあらゆる災難を根気よく繰り返すものと見てもたいした間違いはないと思われる。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大概車の取っ手を三回まわす間に左の手が延び切って数十センチメートルの糸が紡がれ、それを巻き取ってから、また同じ事を繰り返す。",
              "citation": {
                "source": "糸車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五人、五六人という群れになって北山おろしの木枯らしに吹かれながら軒並みをたずねて玄関をおとずれ、口々にわざと妙な作り声をして「カイツットーセ」という言葉を繰り返す。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹くのと吸うのを交互に繰り返すと、ポペン／＼／＼というふうな音を出す。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "謡いも、舞いも、囃子も、すべてが伝統的の型を大切に繰り返すだけで、進歩も発達もない空虚なものである。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他一芸一能に達した者、又は、或る単純な操作を繰り返す商人もしくは職人等のそうした動作の中には多少ともに能的分子を含んでいないものはない。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "文は短けれど読みおわりて繰り返す時わが手振るい涙たばしり落ちぬ、今｜貴嬢にこの文を写して送らん要あらず、ただ二郎は今朝夜明けぬ先に品川なる船に乗り込みて直ちに出帆せりといわば足りなん。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがこの無遠慮な男の質問で始めて忘れていた内容の恐ろしさと、それを繰り返す自分の職業の不快さを思い出させられたのではあるまいか。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでくどいようでも同じ事を繰り返す事を許してもらいたい。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時代は進むばかりであとへはもどらないはずであるが、時代の波の位相のようなものはほぼ同じことを繰り返すのかもしれない。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしただ繰り返すだけではなくて、やはり何かしらあるものの積分だけは蓄積しているには相違ない。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "月が七句目のへんに来ているのは、表の月に照応してもう一度同じテーマを繰り返すことによって表の気分を継承した形である。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
