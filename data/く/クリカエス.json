[
  {
    "uuid": "cc9f9eb1-e469-547e-a164-a5f2d22f7607",
    "entry": "繰り返す",
    "reading": {
      "primary": "くりかえす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
