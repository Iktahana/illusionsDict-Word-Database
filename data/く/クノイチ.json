        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ポチは、妹と弟とをのければ、ぼくのいちばんすきな友だちなんだ。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが、ぼくのいちばんのお願いで、おまけに、たった一つのお願いなんだ。",
              "citation": {
                "source": "雪だるま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「雅子さんはぼくのいちばんに愛していた女だ。",
              "citation": {
                "source": "街頭の偽映鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "永峯はぼくのいちばんに愛していた男だ。",
              "citation": {
                "source": "街頭の偽映鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは永峯という偽映鏡を打ち砕くのが目的じゃなかったんで、雅子さんという偽映鏡を造り替えるのが目的だったから」「わたしには分かりませんわ」「ぼくのいちばんに愛していた人は、雅子さん、あなただったんです。",
              "citation": {
                "source": "街頭の偽映鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にぼくのいちばんに憎んだ人もあなただったんです。",
              "citation": {
                "source": "街頭の偽映鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると隣にいた沢村さんが、大きな声で、「青大将なのよ」とぼくのいちばん嫌う綽名を呼んでから、気持よさそうに笑い出しました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ぼくのいちばんいいものを入れるんだよ。",
              "citation": {
                "source": "ちょうせんぶなと美しい小箱",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはぼくのいちばんうれしいときで、ガロフォリにぶたれもしないし、晩飯にいもがもらえなくっても、どこかでなにか昼飯にもらって食べて来るから苦しいこともなかった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いまゝでまはつたお寺は、どこも鐘楼が空ッぽでしたが……　と、ぼくは、ぼくのいち早い発見について、海老塚さんに質した。",
              "citation": {
                "source": "にはかへんろ記",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで警視庁から、サーチライトを運んで、近くのいちばん高い建物の屋根の上にすえつけることになり、それでまた、三十分以上も時間がたってしまいました。",
              "citation": {
                "source": "鉄人Ｑ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
