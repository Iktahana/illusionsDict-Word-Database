    "definitions": [
      {
        "index": 1,
        "gloss": "with intense concentration",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "針助の背中の刺青に、食い入るように、きつく紐が掛けられる。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生時代にボートの選手をしていたひとは、五十六十になっても、ボートを見ると、なつかしいという気持よりは、ぞっとするものらしいが、しかし、また、それこそ我知らず、食い入るように見つめているもののようである。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四足の爪を土に食い入るように踏ん張って、耳を立て眼を瞋らせて、しきりにすさまじい唸り声をあげていた。",
              "citation": {
                "source": "木曽の旅人",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　矢も楯もたまらず紙をつかみ取り、ホームズはそれを卓上に広げ、ランプをかざして、食い入るようにあらためた。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "こわばる様はさながら古い大理石の彫刻のようで、父子に刹那視線を注いだが、すぐさま食い入るように部屋の反対側の何かを見つめる。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "令子は画面を食い入るように見つめながら、慶一の手をきつく握りかえす。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔓が、肩に食い入るように重い。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁撈長である船頭は、舟の上から食い入るようにいろの変ってきた海面を凝視している。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中は湯帷子に襷を肉に食い入るように掛けて、戸を一枚一枚戸袋に繰り入れている。",
              "citation": {
                "source": "あそび",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "食い入るように見詰めている。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は暮れかかる岩と森とを、食い入るように見据えたまま、必死にその誘惑を禦ごうとした。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "食い入るようにみつめながら、彼女等は囁き合う。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の、闇にきらめく、狂奮の瞳は、浪路に向けて、食い入るように注がれるのだ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私は、いかにも何気なさそうな風をして、ベイを選ぶのはいつか緒方自身に任せながら、目の前の、枯れた無花果の木のごつごつした枝ぶりを食い入るようにして見入っていた。",
              "citation": {
                "source": "幼年時代",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は食い入るように互の眼の中を見入った。",
              "citation": {
                "source": "蘇生",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二人は互に食い入るように眼と眼を見合った。",
              "citation": {
                "source": "二つの途",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい楽器になればなるほど、その細かな波動が、いっそう鋭く魂に食い入るように、ますます悲しい感じをそそるのであります。",
              "citation": {
                "source": "楽器の生命",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そういうお浦が、怨みと怒りで血走った眼を据え、食い入るように、下から、左門を睨み、地を這い、じりじりと進み、武者振りつこうとしているのであった。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷間の人々　三人の男が手をつないで、その周囲を廻っても、まだ余りはしないだろうかと、そんなにも太い銀杏の幹で、月光は完全に遮られ、闇のようになっているその中に、顔を見られるのを恥じながら、でも自分では相手の顔を、これが見納めといったように、食い入るように見詰めながら、桂子は云いつづけた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしの眼にだけ見えるのじゃ」　そういう姥の眼は水盤の面に、食い入るように注がれていた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……何んでもない、何んでもない」　そう云っている間も権守は、二つの穴から浮藻の顔を、食い入るように見詰めていた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで食い入るように聴き入っていた新十郎は、ホッと我に帰って、「ヤ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その三　魔教の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼を凝らし、頤をぐっとひいて、食い入るように、あの鋭い視線を絵に注いでいる。",
              "citation": {
                "source": "小林秀雄と美",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "地面へ顔を押しつけんばかりに不意に屈んだ藤吉は、孫右衛門の足跡を食い入るように眺めていたが、「松さん、昨夜雨の降ったのは――。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "三つの足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "眠たそうな子供の手を引き、大きな瞳で鯨を食い入るように見つめている。",
              "citation": {
                "source": "くじらようかん",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "食い入るように路地を歩み去る女の姿をみつめていた。",
              "citation": {
                "source": "軍国歌謡集",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、彼の胸の上には、喜太郎の大きな膝頭が、丸太のようにのっかっており、両手は、地べたに食い入るように、おさえつけられていた。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　次郎は、もうその時には、路ばたの木の根に腰をおろし、二人の顔を食い入るように見つめていた。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "新賀はそれを受取ると食い入るようにそれに見入っていたが最後に大きなため息をつきながら、それを次郎に返そうとした。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャンウーは、もういちど素速い視線をあたりに投げると、ううんと深いいきを吸い、それからくいいるように、その半ペラに見入っていた。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
