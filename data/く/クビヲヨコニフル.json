    "definitions": [
      {
        "index": 1,
        "gloss": "to shake one's head (in disagreement)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　ホームズもよく分からないという風に、首を横に振る。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "三田が否々といふつもりで首を横に振ると、子供もそれをうち消すやうに頭を横に振る。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（文部大臣首を横に振る）　大臣は危険でないと云はれる、それならば、上演禁止の理由は作品の思想と関係はないことになります。",
              "citation": {
                "source": "仏国議会に於ける脚本検閲問題",
                "author": "――ゴンクウルの『娼婦エリザ』――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまひに、誰がなんと云つても返事をせず、たゞ面倒臭さうに首を横に振るばかりである。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の手先である赤ブイの仙太殺しの一件を追求しても、首を横に振るばかりか、例の証拠をさしつけても一向｜恐れ入らなかった。",
              "citation": {
                "source": "疑問の金塊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（美緒が首を横に振る）……タンか？",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "美緒　……（首を横に振る）小母　まあまあ、綺麗にならはつた！",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（下を向いたまま、アイマイに首を横に振る）留吉　……ぢや、仕合せでは無えのか？",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（今度もアイマイに首を横に振る。",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "錢形とやら平次とやらに申付けて、下手人を搜し出して下さるやうにと頼まれて見ると、首を横に振るわけには行かねえ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "御宰籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "こがねまる　（うなだれたまま、首を横に振る）なよたけ　（険しく）こがねまる！",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こがねまる　（首を横に振る）好き……なよたけ　じゃ、その蝶々をなぜ殺したの？",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼び出してみると、「左様なことは存ぜぬ」　頑として、首を横に振る。",
              "citation": {
                "source": "大菩薩峠",
                "author": "三輪の神杉の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜明け頃、引き分けにすべきだと賭け手たちが言い出し、審判が首を横に振る中で、彼は、ありったけの力を込めて黒人の腕を傾けていき、テーブルにつくまで倒してしまった。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "余程巧く持ちかけないと首を横に振る。",
              "citation": {
                "source": "村一番早慶戦",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
