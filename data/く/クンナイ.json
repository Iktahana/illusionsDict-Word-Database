        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」と言わぬばかりに、しきりにくんくんないたりしました。",
              "citation": {
                "source": "やどなし犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "雇ってくんないかい」　私はいよいよ逃腰になってしまったが、その時に向うの扉が静かに開いたので、もしやと思って固くなっていると、最前の給仕を先に立てて、私と同じくらいに固くなった一人の紳士が入って来た。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "済まないが退いてくんないか。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「困ったなア、母ちゃんたら、買ってくんないんだもの！",
              "citation": {
                "source": "自然描写における社会性について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お嫁の口を世話してくんないって、憤って行っちゃったのかも知んないよ」　下駄の音がする度に、皆がひとりでに店から往来の方を見た。",
              "citation": {
                "source": "小村淡彩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十銭で何か食わしてくんないかな、十銭玉一つきりしかないんだ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「私は別れたくっても、別れてくんないんですもの。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉さん、五銭ほど俺にくんないかね……」　驚いて振り返って見ると、垢もぶれな手拭を首に巻いた浮浪者が私の後に立っていた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あ、そいで、さっきの事二三日すれば目鼻がつくんだけど、啓坊をひとつ、あずかってくんないかしら、けっして迷惑かけやしないし、明日にでもなったら、少し位とどけられるから……」「うん、その話ねえ、姉妹争いするの厭だけど、お互いに所帯を持ってるンじゃないの？",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "拾銭で何か食わしてくんないかな、拾銭玉一ツきりしかないんだよ。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「私別れたくっても、別れてくんないんですもの。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私んとこのパパあんなにいつもニコニコ笑ってるけど、とても淋しいのよ、あんたお嫁さんになってくんない。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くしてくんないかなあ。",
              "citation": {
                "source": "監獄挿話　面会人控所",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "センベツ包んでくんないか」「よしやがれ。",
              "citation": {
                "source": "退歩主義者",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ、ツルちゃん、戦争中は、皇大神宮に指圧療法、終戦後は、寝釈迦、お助けじいさん、一家ケン族みんな信仰しなきゃア、カンベンしてくんないんですからね。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも、貴下の愛人が、「妾も山へ登りたいわ、女性にだって登高本能はあることよ、だって妾、煙突なんかへ登りたくはないの、ねえ伴れてってくんない？",
              "citation": {
                "source": "案内人風景",
                "author": "百瀬慎太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "須永　……モモコさん、裸になって僕に見せてくんないかな？",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "須永　見せてくんないかなあ。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "須永　……だから、裸になって、見せてくんないかなあ。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "フルート聞かしてくんないかなあ。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "須永　今、じゃ、考えてくんないかな。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹いてくんないかな。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ビールを飲む）五郎　……あのね尾崎君、……何度も同じ事ばかり言ふやうで済まないけど、もう半月、この月末まで待つてくんないかなあ。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく伊佐子が持つてゐるから、後で、そいつをどうするか、君に一任するから、君が良いと思つた通りにしてくんないか。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（土間に降りる）よりちやん、私にも一本附けてくんない？",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上ですから――（馭者に大声で）小父さんよ、ちょっくら停めてくんない。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "壮六　（しょうことなしに、馭者に）おい、小父さんよう、ちょっくら、停めてくんない！",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "持つて行つてくんないかな。",
              "citation": {
                "source": "夜の道づれ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（歯の根が合わなくなっている）……こっちへ来てくんないか、おい！",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼むからこの俺を、ようく見てくんないか。",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
