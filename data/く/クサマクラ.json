    "definitions": [
      {
        "index": 1,
        "gloss": "overnight stay when traveling (travelling)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さては五十鈴の流れ二見の浜など昔の草枕にて居眠りの夢を結ばんとすれどもならず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その文中で花袋の近作、紀行文集『草枕』の中の事実に合っていない個所を注意した。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "草枕、旅の露宿に加えて、夢も皺かく老の身ゆえに、寝覚めがちな一夜であるのはもっとものことだが、この夜は別けて翁をして寝付かれしめぬものがあった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に『草枕』のモニューメントを築き上げた巨匠の鑿のすさびに彫んだ小品をこの集に見る事が出来る。",
              "citation": {
                "source": "夏目先生の俳句と漢詩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏目先生の「草枕」の主人公である、あの画家のような心の目をもった調律師になって、旅から旅へと日本国じゅうを回って歩いたらおもしろかろうと考えてみた事もある。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "花枕、草枕、旅枕、皮枕、縱に横に、硝子窓に押着けた形たるや、浮嚢を取外した柄杓を持たぬものの如く、折から外のどしや降に、宛然人間の海月に似て居る。",
              "citation": {
                "source": "大阪まで",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌によむ草枕、かりそめの旅とはいえど半月一月と居馴染めば、これもまた一種の別れである。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "で草枕の樣な主人公ではいけない。",
              "citation": {
                "source": "鈴木三重吉宛書簡―明治三十九年",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "較べものにゃあなりませんが、むかし琵琶法師の名誉なのが、こんな処で草枕、山の神様に一曲奏でた心持。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……凩に吹かれぬ前に、雪国の雪が不意に来て、其のまゝ焚附にも成らずに残つた、冬の中は、真白な寐床へ潜つて、立身でぬく／＼と過ごしたあとを、草枕で寐込んで居た、これは飛騨山の案山子である。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「猫」、「坊ちやん」、「草枕」、「ロンドン塔」、「カーライル博物館」、こんなものが好きだ。",
              "citation": {
                "source": "温情の裕かな夏目さん",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "○物乞ふこともうみはてゝ、　食うべず過ぎしは月あまり、　　　何事もたゞ忘るゝをたのしみに、　　　草枕ふたゝび覺ぬ眠に入らなむ。",
              "citation": {
                "source": "北村透谷詩集",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌によむ草枕、かりそめの旅とはいえど半月ひと月と居馴染めば、これもまた一種の別れである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "漱石の「草枕」は、当時自然主義文学に対して、はっきり対蹠的なものの典型としての計画のもとに書かれた作品であった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "漱石の「草枕」は、自然派の小説が「唯真を写しさえすれば仮令些の美しい感じを伝えなくとも構わぬわけだ」というらしいのに対して、「文学にして、苟も美を現わす人間のエキスプレッションの一部分である以上は、」「小説もまた美しい感じを与えるものでなければなるまい。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「私の『草枕』は世間普通にいう小説とは全く反対の意味で書いたのである。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「草枕」が文学史にとって興味深い点は、当時の思想のあらゆる面に強調してあらわれていた二元性が、この美と醜と対立させた漱石の観念のうちにも、その反映を見出していることである。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "草枕むすぶまもなきうたゝねのゆめおどろかす野路の夕立　此夜伏見に足をとゞむ。",
              "citation": {
                "source": "かけはしの記",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "霜白き冬の朝、しとしとと雪ふりつもる冬の夜、空曇りて陽は見えず寒き風吹きすさび手足の血も凍り骨も凍らんとする冬の日を度るは、ただひとり病める身の草枕日くれて野辺にうちふし異郷の旅に苦むごとし。",
              "citation": {
                "source": "枕上浮雲",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も、登美子は二階で蒲團を干しながら、何時の間にか、その蒲團の上に寢ころんで、秋の陽のかんかん射しこんでゐるところで、與田先生から借りてきた漱石の草枕を讀んでゐた。",
              "citation": {
                "source": "婚期",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "漱石の草枕のなかにも、小さい温泉場の一夜のなかで、「おれは泣く事の出來る男だと云ふうれしさ丈の自分になつてゐる」と云ふ言葉が書いてあつた。",
              "citation": {
                "source": "旅人",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇広く続ける中の市比野を探りて借れる草枕かな　市比野の温泉に著いて見ると、既にして薩摩平野は真暗な闇に掩はれてゐて、その中で僅か許りの灯を頼りに探り当てた様な市比野であつた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "行き当り飛蝗とともに草枕」と最前の浪花節の句をいってから笑いました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいにくの吹き降りで、不二見村の往還から寺の門まで行く路が、文字通りくつを没するほどぬかっていたが、その春雨にぬれた大覇王樹が、青い杓子をべたべたのばしながら、もの静かな庫裡を後ろにして、夏目先生の「草枕」の一節を思い出させたのは、今でも歴々と覚えている。",
              "citation": {
                "source": "樗牛の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "草枕、露も涙も、あらはなる、寝覚め恥づかし、武蔵野の月。",
              "citation": {
                "source": "鉄窓の歌",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "善は急げと支度して、「見事金眸が首取らでは、再び主家には帰るまじ」ト、殊勝にも言葉を盟ひ文角牡丹に別を告げ、行衛定めぬ草枕、われから野良犬の群に入りぬ。",
              "citation": {
                "source": "こがね丸",
                "author": "巌谷小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の如くに解して、「草枕旅ゆく人も行き触ればにほひぬべくも咲ける芽子かも」（巻八・一五三二）の歌の如く、衣に薫染せしめる事としたのであるが、続日本紀に拠るに行幸は十月十日（陽暦十一月八日）から十一月二十五日（陽暦十二月二十二日）にかけてであるから、大方の萩の花は散ってしまっている。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌の近くに、清江娘子という者が長皇子に進った、「草枕旅行く君と知らませば岸の埴土ににほはさましを」（巻一・六九）という歌がある。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "sleeping on grass in an open field",
        "register": "standard",
