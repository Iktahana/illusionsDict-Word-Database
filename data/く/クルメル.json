    "definitions": [
      {
        "index": 1,
        "gloss": "to lump together",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」と幾多の危懼、憂慮を包める声音、＝＝お謂でないよ＝＝は符牒のようなり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく祭りのための設けとは知られながら、いと長き竿を鉾立に立てて、それを心にして四辺に棒を取り回し枠の如くにしたるを、白布もて総て包めるものありて、何とも悟り得ず。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて泥棒達は風呂敷に包めるだけ品物を包んでしまふとさつさと出て行かうと致しました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "その面は和ぎて一点の怒気だにあらず、寧ろ唇頭には笑を包めるなり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし木部という事を先方からいい出すまでは包めるだけ倉地には事実を包んでみようと思って、ただにこやかに、「こんな所でお目にかかろうとは……わたしもほんとうに驚いてしまいました。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君のシスタアが友だちだし、先生のエルダアブラザアもいるんだし、どうにか方法がありそうなもんだねえ」「まア、放っておいてくれ、考えると苦しくなる」　胸にひそかに恋を包める青年の苦しさというような顔を郁治はして見せた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "つれなしと見つる浮世に長生へて、朝顏の夕を竣たぬ身に百年の末懸けて、覺束なき朝夕を過すも胸に包める情の露のあればなり。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂敷といふものは何と便利なものだらう、大小自由だ、大きいものも小さいものも一枚で包める、とてもトランクやケースやバツグが及ばない、たゞモダーンではない。",
              "citation": {
                "source": "行乞記",
                "author": "三八九日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "此類の學者は能く自ら欺き、また能く人を欺けども、人ありてその繁文を削り、その要旨を尋ねむとするときは、或はその包めるところ何の思想をもなさゞることあり、或は極めて平凡なる意味となることあり、或はその筋違なる想像なるを見ることありといへり。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡そ一甲｜拆（草木の新芽を包める薄き皮の開くこと）一敷栄（花のしげり咲くこと）、童子皆な来り報じて惟だ謹む。",
              "citation": {
                "source": "小国寡民",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸大名方へのお出入りも出来、内弟子外弟子ひっ包めると、およそ千人の門弟が瞬間に出来上ってしまいました。",
              "citation": {
                "source": "正雪の遺書",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一場の茶話だと思っていましたが上等のアイスクリームは全く紙へ包めるものでしょうか」お登和嬢「オホホ紙へ包むどころでありません。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "糞嚢に金を包めるなるべし。",
              "citation": {
                "source": "旃陀羅考",
                "author": "日蓮聖人はエタの子なりという事",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて何といっても日本人にはお米の御飯、さるかに合戦以来のおむすびが第一ですが、これに一寸趣向を加えて見ますと、先ず海苔をやいて半分に切り、それで包める位の大きさに御飯をにぎります。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その幅もカシワモチが包めるぐらい広かったが、しかしウスッペラではなくて人目にふれずに見事に天寿を全うしたキノコのように肉ヅキがふくよかであった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十二　愚妖",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅商人の脊に負える包の中には赤きリボンのあるか、白き下着のあるか、珊瑚、瑪瑙、水晶、真珠のあるか、包める中を照らさねば、中にあるものは鏡には写らず。",
              "citation": {
                "source": "薤露行",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ真理を包める人為的附加物は、之を除去せねばならぬのである。",
              "citation": {
                "source": "霊訓",
                "author": "SPIRIT TEACHINGS",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへ嘉平はいはずとも、物事万事小細工に、包めるものと思ふたは、おれの誤り、どこぞから、世間へぱつとしてからは、聟殿がなほ気の毒。",
              "citation": {
                "source": "移民学園",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "メーリオネース之を視て耀く槍を投げ飛ばし、牛皮のつゝむ圓盾に覘違はず打ち當つる、　160されども之を貫かず、鋭く長き槍はその根元に於て穗を碎く――デーイポボスは剛勇のメーリオネース突く槍を恐るるあまり、牛皮もて包める盾を腕のばし胸より隔て身を蔽ふ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしておそるおそる五枚ずつ重ねてある小判へ手を出した、熱くない、紙へ載せて包む、ちゃんと包める、中将は盟友の顔を見た、「こんてだ、へへへ、ばんぜだ」権頭も杢も坐り込んだ、「もでじょぶだ、こやて、あとさらてけばい、へへへばんぜだばんぜだ」三人は勇気千倍して包み始めた。",
              "citation": {
                "source": "三悪人物語",
                "author": "忍術千一夜　第二話",
                "note": "青空文庫"
              }
            },
            {
              "text": "このほか有価証券、預金の類をひっくるめると、十五万はたしかなところですから、銀行の方でも信用をしてくれるとは思っているんですが」　そういう間にも、その男は金縁の眼鏡の奥から、おせいの様子をちらりちらりと探るように見た。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "短氣なおやぢを威したり賺したりいひくるめるのは村でも此の四つ又一人なのである。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやただにそう言いくるめるばかりでなく、ぜひ買いたいと思わせてしまう。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、これを何れも同一の概念にひつくるめることは乱暴である。",
              "citation": {
                "source": "演劇論の一方向",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "話下手な栄蔵は、お金などを云いくるめる舌はとうていないので、否応なしに、お金がやめるまで、じいっとして聞いて居なければならなかった。",
              "citation": {
                "source": "栄蔵の死",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "現実の母は、叱る声も、怒る眼も在る代りには、だますこともでき、言ひくるめることもできる。",
              "citation": {
                "source": "母の上京",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "だますことも、言ひくるめることもでき、会はない前よりも却つて事態を好転させる見込みすら有り得るのである。",
              "citation": {
                "source": "母の上京",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "義理と人情とを対立させる場合をのぞき、この二つをひつくるめると、それは、ある意味で、人間の生き方にひとつの基準を与へるものである。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、姦物陣十郎は、鷺を烏と云いくるめる侫弁、「あいや方々｜偽でござるぞ、彼らの言葉をお信じ下さるな。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "物質的生産技術が実際的に実行され実地に運用される筈のものであることは、到底解釈学的にも言いくるめることの出来ない事実だから、之は世界の「解釈」にとって、甚だ厄介な代物と云わざるを得ないだろう。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
