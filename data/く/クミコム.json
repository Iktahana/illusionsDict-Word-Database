    "definitions": [
      {
        "index": 1,
        "gloss": "to fill (a container) with (water)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「そら、ポンプだ、というと呵々と高笑いで、水だらけの人間が総崩れになる中を澄まして通って、井戸端へ引返して、ウイなんて酔醒の胸のすく※でね、すぐにまた汲み込むと、提げて行くんです。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "園丁が来て花にやるために水を温室に汲み込むのを見ては、「あんなに太った百姓が大よだれをたらして居る。",
              "citation": {
                "source": "小さい子供",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとを汲み込むのは自分の役目ではないのか。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずバケツの孔を塞ぎ、手近な井戸の水を汲み込むことが、先決問題である。",
              "citation": {
                "source": "科学ブームへの苦言",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は目をつむって、最後の一杯を汲み込むと、盥から眼をそらしたまま、部屋に逃げ込んだ。",
              "citation": {
                "source": "孤島の鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おらア先生が、肌脱ぎになって水をくみこむところを見たが、肩なんかお前、松の根っこみてえだぞ」「何言ってやがんでえ。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
