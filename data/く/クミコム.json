[
  {
    "uuid": "eef80556-22d9-5299-accc-753a7673f4a5",
    "entry": "組み込む",
    "reading": {
      "primary": "くみこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to insert",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それかといって神経衰弱にかかった杞人でない限り、いつ来るかもわからない「審判の日」を気にしてその時の予算までを今日の計画の中に組み込むわけにも行かない。",
              "citation": {
                "source": "ロプ・ノールその他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイパーカードのマルチメディア機能を生かせば、音や動画を組み込むという、新しい特徴も出せます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがては、動画を組み込むこともできるだろう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その仕掛けを組み込むために、一つひとつつながりを見つけだしては張っていこうと考えたリンクでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶版になった自分の本を仕立て直すところから始め、動画や音、インターネットへのリンクを組み込むといった、新しい工夫にも手を染めた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにはいくつかの要素が含まれているが、先ず最初に形を取るのは、マックをＩＢＭのネットワーク体系ＳＮＡに組み込むという点だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばミシンにマイクロコンピューターを組み込むとして、それで何ができるかに自分が充分答えられないとしても、考えてみれば当然ではないか。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般的な索引の機能を組み込むことはもちろんだが、加えて彼は「連想索引★」という新しい仕組みを装置に持たせようと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＲＯＭに収めて組み込む方針が定められていたベーシック以外の言語を提供するためには、マイクロソフトは道を選ばざるをえなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本体内には拡張ボードを差し込むための増設スロットが五つ用意されており、オプションにまわされた容量一六〇Ｋバイトの五インチドライブを二台組み込むスペースが空いていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビデオ表示回路は本体に組み込むのではなく、増設ボード扱いとされていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来なら、ベーシックとＢＩＯＳを収めたＲＯＭは基板の上に組み込むのが当然だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "代わってＦＭ―11は、一六ビットの８０８８と八ビットの６８Ｂ０９Ｅという二つのＣＰＵを本体に組み込むことで、継承性の問題をすり抜けようとした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ウォズニアックは、ＲＯＭに焼いてマシンに組み込むベーシックの仕上げに追われていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＢＭ ＰＣは、フロッピーディスクドライブのコントローラーやマウス、プリンター、ＲＳ―２３２Ｃの接続端子を、増設ボード扱いとしてスロットに組み込む形をとっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "増設スロットに差し込むマウス接続用のボードとＭＳ―ＤＯＳに組み込むドライバーソフト、そしてマウス本体を、笹渕は担当者に頼み込んで日本に持ち帰った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "七二〇×五一二ドットの高解像度に加え、オプションにまわされたカラーボードを組み込むことで、五一二色中から任意の一六色を同時に表示できるようにしたグラフィックスの処理能力は、当時の対抗機種の中では傑出していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このためせっかく世界標準に沿ったはずのＪＸは、ジュニア用のボードを組み込むことができないという中途半端な互換性しか提供できなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当初からＯＳに漢字システムを組み込むことを理想としていた浮川は、アスキーとの提携解消後、この路線をさらにもう一歩推し進めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "戯曲はさうでもないが、小説の方は自分で全集を編むとなれば、これに組み込むことに大いに躊躇せざるを得ないものが少くない。",
              "citation": {
                "source": "「細雪」回顧",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おらア先生が、肌脱ぎになって水をくみこむところを見たが、肩なんかお前、松の根っこみてえだぞ」「何言ってやがんでえ。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
