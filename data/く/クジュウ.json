    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bitterness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "前に人に使われて働いていた時分は、生活の心配を離れて、専心に工夫に没頭したら、さぞ快いだろうという、その憧憬から日々の雑役も忍べていたのだがその通りに朝夕を送れることになってみると、単調で苦渋なものだった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎夜のように彼の坐る窓辺、その誘惑――病鬱や生活の苦渋が鎮められ、ある距りをおいて眺められるものとなる心の不思議が、ここの高い欅の梢にも感じられるのだった。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれは苦渋や不安や恐怖の感情で一ぱいになった一歩だ。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、順序に連絡が欠けている点さえ読む者に苦渋を与える。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に人に使われて働いていた時分は、生活の心配を離れて、専心に工夫に没頭したら、さぞ快いだろうという、その憧憬から日々の雑役も忍べていたのだが、その通りに朝夕を送れることになってみると、単調で苦渋なものだった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは逸作の腕に支えられながら、弟の医者にちょっと脈を検められ、「生きの身の」と、歌の頭字の五文字を胸に思い泛べただけで急いで帰宅の俥に乗り込んだだけを記して、早くこの苦渋で憂鬱な場面の記述を切上げよう。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗右衛門の苦渋の底から微笑が浮んだ。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると池上は、人の事でもそういう無邪気で長閑な話を聞くと何だか癪に触ると言って、その理由を苦渋そうに話しました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "映り返された二面の鏡その一つ／＼も、また再び意趣返しでもするように、映し返して来た鏡に向っても、また、共に映し返された鏡に向っても傍杖に苦渋な姿を何十何百かの分身の映像まで伴って反撃的に映り返して行く。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見詰めるのに堪えないで、自分がわき見をすればそれ等もわき見をして、そこにまた新なる眼の焦点に新なる分身の苦渋な姿が、自分よりも鋭く、自分を見詰めて来る。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟というのは安宅先生のあの中性型の美人の顔を、横着に、そして神経質な苦渋をも加えた、いくらか奇怪な趣のある青年でした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは熱帯国の木の実が焙じられた時、うめき出す濃情な苦渋の色そっくりだ。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "してみれば、子供の泣き声に惹かれるという坂田の詞のうらには、坂田の人生の苦渋が読み取れる筈だと言ってもよかろう。",
              "citation": {
                "source": "勝負師",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅費のつかい残りで、すぐに石油を買う体裁、なけなしの内金で、その夜は珍らしく肴を見せた、というのが、苦渋いなまり節、一欠片。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉岡の場合は日本画の新しい形式的確立の手段の立て方が、余りにも内省的だといつてもいゝほどに苦渋な方法を採つてゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦渋な暗い影もあれば、陰惨な醜い皺もある。",
              "citation": {
                "source": "心の絵",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「謹厳」が洋服を着たような満面苦渋の長谷川辰之助先生がこういう意表な隠し芸を持っていようとは学生の誰もが想像しなかったから呆気に取られたのも無理はない。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、この淋しい解釈は明らかに私を一種の苦渋と圧迫感へ誘ひ込んだ。",
              "citation": {
                "source": "アリア人の孤独",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔つたからというて無闇と手脚を伸すこともかなはず、呑みたいからというて矢鱈に水をあふることも許されず名状し難い陰気な泥酔状態を噛み殺して烏天狗のやうな顔つきを保つてゐることの苦渋を今や知る身となつてゐた。",
              "citation": {
                "source": "天狗洞食客記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「…………」「あゝ、私のこの困難苦渋は何に喩えたならば宜しう御坐いませう。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は苦渋な表情のままじっと煙草を吸っていたが、いきなり宮子の首を締めつけた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者自身としては題材のむずかしさ、苦しさに力の限りとっくんでゆく努力に自覚をあつめているうちに、この作家がこれまでかいて来た平明で、まとまりよくおさめられた作に見られなかった苦渋をにじませた。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそれは成功的にではなく、落第点とすれすれに、努力的な苦渋さを以てなされつつあるのだ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳永直の「他人の中」は、いくらかゴーリキイのあとを追った筆致であるが、山本有三の「路傍の石」とともに境遇的描写の範囲で少年の生活の苦渋を描いている。",
              "citation": {
                "source": "若き精神の成長を描く文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みずから山河巨大な中国に生れ合わした人民の一人として、中国の民衆生活を衷心から愛し、おかれている苦渋の生活を哀惜し、その未来の運命の発展に対して限りない関心をもっている。",
              "citation": {
                "source": "春桃",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "光線のたりないその事務室で、正直な某氏は、苦渋の面持ちであった。",
              "citation": {
                "source": "ある回想から",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦渋な、しかし真摯な作品である。",
              "citation": {
                "source": "解説（『風知草』）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い汚ない泥を無理に咽喉に押し込められて居るやうに、只窒息するばかりの不快な苦渋を感するばかりで、何を思ひ考ふる余裕もなかつた。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはもう氷河の話が出たころから、千鶴子の名前がいっぱいに膨れ襲いかかって来ていたのだが、それが塩野から無造作にそう云いかけられると、急に返事に詰り、云いようのない苦渋な気持ちで即答が出来かねるのだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
