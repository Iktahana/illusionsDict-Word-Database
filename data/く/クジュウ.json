[
  {
    "uuid": "87e5cbfc-64e0-5aba-b816-e2fcbbfaab81",
    "entry": "苦渋",
    "reading": {
      "primary": "くじゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
