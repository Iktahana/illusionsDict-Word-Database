[
  {
    "uuid": "eee8939a-ddff-53bb-8732-a55c6d1d5fdb",
    "entry": "腐す",
    "reading": {
      "primary": "くさす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
