    "definitions": [
      {
        "index": 1,
        "gloss": "national or local pride",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "振袖は案外真面目で、「……お亡くなんなすってから、あと、直ぐに大層な値になって、近常さんの品は、そうなると、お国自慢よ。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は無学な、お国自慢の一能楽ファンである。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は国自慢をした覚えはなし、自慢どころか一体嫌いなんだけれど、石屋根の家が崖にごつごつは酷いや。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎漢に限ツて国自慢をすると同じやうなもんだ。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "お国自慢10・19（夕）　米国の戦時通信記者として名高いゼエムス・バアンス氏が、今度の戦争の当初、白耳義にゐた折の事、ある日ブラツセルの市街を｜いてゐると、前方から独逸の自動車が一｜輛風を切つて飛んで来た。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼奴めが……」とバアンス氏は、それからといふもの、会ふ人｜毎にお国自慢をしてにこ／＼してゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆腐と英国人10・14（夕）　講談師細川｜風谷が、以前郵船会社の欧洲｜通ひの事務長をしてゐた頃、お国自慢の英国人に、何がな日本料理の珍しい物を見せたいものだと思つて、色々考へた末が、「豆腐にしよう、豆腐なら流石の英国人も吃驚するだらうからな。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩食後、同宿の行商老人と共に宿の主人から轟神社の神事について聞かされた、どこでもたれでもお国自慢は旅の好話題というべしである。",
              "citation": {
                "source": "四国遍路日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに国自慢のイギリス人でもシエイクスピアやミルトンを日本語に訳さうとはしなかつた。",
              "citation": {
                "source": "翻訳製造株式会社",
                "author": "戸川秋骨",
                "note": "青空文庫"
              }
            },
            {
              "text": "松田道夫さんの話に、蘭軒が筆話の序に、国自慢の詩を書して示すと、程であつたか江であつたか、「江戸つ子ちゆうつ腹」と連呼したと云ふことである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀内中将の話　お国自慢、信州蕎麦。",
              "citation": {
                "source": "蕎麦の味と食い方問題",
                "author": "村井政善",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　矢代はふとこう乱暴に云ってから、突然、「どうして僕はここへ来ると、こんなにお国自慢がしたくなるんだろ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもお国自慢になって、君には失礼だけれども、日本でむかしながらの気風を一番長持ちさせているのは、東北でも特に僕らの地方じゃないかと思うんだよ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファラーの人気はすごいもので一九〇六年一月二十六日、ニューヨークのメトロポリタンにデビュウした時は、お国自慢、世界一を自慢をするアメリカ人は有頂天になって、アメリカの生んだ世界的プリマドンナとして大騒ぎをしたそうです。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、誰にでも、とかく国自慢といふことがありますから、フランスでも、シェイクスピアを一面では非常に感心しながら、他面では何か難癖を附けたり、ある批評家らは、いや、惨虐に過ぎる部分が多過ぎるとか、悪趣味に堕してゐるところがあるとか、非難的な結論を添へてゐるのです。",
              "citation": {
                "source": "フランスに於けるシェイクスピア",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、この「郷土精神」は、往々にして、封建割拠の遺風のなかに埋没し、或は単にお国自慢となり、或は徒らに排他を事とし、時には、痼疾化した地方気質の露骨な表示に終始することすらあり、従つて、その反動もないわけではなく、恰も予言者の如く、郷土の懐を冷やかに見返るものが次第に多くなつて来たのである。",
              "citation": {
                "source": "地方文学の曙光",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "お国自慢　五月の利根川の若鮎は、私が食べた鮎のうち最もおいしい一つであるというのは、それはお国自慢であろう。",
              "citation": {
                "source": "利根川の鮎",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はお国自慢を恥じない。",
              "citation": {
                "source": "利根川の鮎",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の国々、どこへ行ってもお国自慢の鮎が棲んでいる。",
              "citation": {
                "source": "魔味洗心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸国自慢の鮎は、この初秋にとれるものをさすのであった。",
              "citation": {
                "source": "香魚と水質",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "実にお国自慢の鮎は多かった。",
              "citation": {
                "source": "香魚と水質",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "代表的なお国自慢は、鮎の多摩川である。",
              "citation": {
                "source": "香魚と水質",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がそれを訊いたわけではないのに、彼らのお国自慢が自然そこへ行くのである。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　またお祖母様のお国自慢と皆笑いました。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、なにもお国自慢でもなんでもない。",
              "citation": {
                "source": "味覚の美と芸術の美",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、この種の手合いは概していずれもお国自慢であり、自分の知っているものだけが美味いと思っている。",
              "citation": {
                "source": "道は次第に狭し",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史、人物、料理、産物など、時に応じ、人によってお国自慢の仕方も違う。",
              "citation": {
                "source": "椎茸の話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "お国自慢をする人は、それぞれみな採りたてを食べているから、古いのと比べてみて、そういうのだろう。",
              "citation": {
                "source": "椎茸の話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊あゆの産地ではめいめいお国自慢をしているが、結局はだいたいとれたての新鮮なのをすぐ食べること。",
              "citation": {
                "source": "料理メモ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
