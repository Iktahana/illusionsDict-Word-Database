    "definitions": [
      {
        "index": 1,
        "gloss": "black pine (Pinus thunbergii)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
