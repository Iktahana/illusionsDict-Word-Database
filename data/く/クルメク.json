[
  {
    "uuid": "dfda562b-6c59-554b-9025-94ac4c989fa6",
    "entry": "眩く",
    "reading": {
      "primary": "くるめく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
