[
  {
    "uuid": "9c071dc0-867c-58d3-afe7-feb3bd0a1774",
    "entry": "空位",
    "reading": {
      "primary": "くうい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "vacant post",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すべてのＨＭＮＭの提案は、空位のままに残されているこの王座をつかもうとする試みだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "混沌として降り狂つた雪のあとの晴た空位又なく麗はしいものはない。",
              "citation": {
                "source": "日の光を浴びて",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は缺員空位の村長の卓子の青い掛け布の上の、早咲の菖蒲を生けた頭勝ちの花瓶が一つ轉けたゞけで、其の餘のものはそつくり有姿のまゝであつた。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "御稲荷様既に空位によらず実力を以て油揚をせしむ。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに血気盛りの学生たるもの猶学校の空位空聞に恋々たる其の心事の陋劣にして其思想の旧套陳腐を脱せざる事真に憫笑すべきなり。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　第一、ひと口に空位とはいつても、寳ノ太后が亡くなつてこのかた五年あまりの年つきは、実質的には決して空位だつたわけではない。",
              "citation": {
                "source": "鸚鵡",
                "author": "『白鳳』第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてもう一人の男が英語教師の空位を充たす事になりました。",
              "citation": {
                "source": "私の個人主義",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までは闕位がなかったからいたし方もないが、前年の二月に左大臣公興がやめたので、くり合わせのやりようによっては、内大臣に空位を作ることも不可能でなくなった。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで朝廷では空位である左大臣へ、右大臣の尚経を転じさせ、その後に内大臣の公藤を移し、もって実隆を内大臣に任命した。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この頃、魯には三桓（大夫の三家）の乱があり、昭公は斉に亡命して空位時代であった。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　四十四歳、魯の定公即位、空位時代終る。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからおちやんなくしては畢竟ただの空位にすぎないではないか。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお姿を眺めました時に、世が世ならばこういう空位を擁するお方としてではなく、かかる英邁剛毅なお方をこそ、我が王国の指導者と崇めたい気持で、私は胸が一杯だったのです。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "空位は三年間におよんだ。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "その空位のあいだに、神武の子どもたちは相続争いのことで、反目しあった。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに、三年の空位があった。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇即国家説は、その空位を、証明することが困難である。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後にも、日本には、空位はたびたびあった。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "一個の生活自立さえ持たない身なのに、過去の古着にひとしい空位空名を持って、あわれなる今は昔の虚栄心の名残を満たしているのである。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまや北朝は空位空名でしかない。",
              "citation": {
                "source": "私本太平記",
                "author": "黒白帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い夕かげが流れて、そこらの垣根の木いちごの花だけが白くういている道を、腹いっぱいたべた牛と、日ごろのご恩をかえしたつもりの和太郎さんが、ともに満足をおぼえながらのろのろといきました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "森のはとが、頭の上のかごの中でくうくういっていました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
