    "definitions": [
      {
        "index": 1,
        "gloss": "dried bear's gallbladder (used in traditional Chinese medicine)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ほんとうはなめとこ山も熊の胆も私は自分で見たのではない。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくなめとこ山の熊の胆は名高いものになっている。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉛の湯の入口になめとこ山の熊の胆ありという昔からの看板もかかっている。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもとにかくおしまい小十郎がまっ赤な熊の胆をせなかの木のひつに入れて血で毛がぼとぼと房になった毛皮を谷であらってくるくるまるめせなかにしょって自分もぐんなりした風で谷を下って行くことだけはたしかなのだ。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ああ、娘は、茶碗を白湯に汲みかえて、熊の胆をくれたのである。",
              "citation": {
                "source": "栃の実",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前は、その形で、正真正銘の熊の胆、と海を渡って売りに来たものがあるそうだけれど、今時はついぞ見懸けぬ、と後での話。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊の皮、熊の胆を売るのは、そのころの木曾路の習いで、この一行はここまで来るあいだにも、たびたびこの毛皮売に付きまとわれているので、手代の義助はまたかという顔をして無愛想に断った。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊の皮が御不用ならば、熊の胆を買ってください。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「道中でうっかり熊の胆などを買うと、偽物をつかまされるということだ。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姐さんがそう言うのだから偽物でもあるまいが、熊の胆はもう前の宿で買わされたのでな。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は手に持つ煙管の火の消えるのも知らずに、熊の胆の押売りをする娘の白い顔をじっと眺めていたが、やがて突然に声をかけた。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その木曾街道で測らずも熊の胆を売る娘に出逢ったのである。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この三月の二十七日に、伊平さんの商売の手伝いをして三軒屋の立場茶屋へ熊の皮や熊の胆を売りに行きますと、あなた方にお目にかかりました。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊の胆と熊の皮とは高い値であるということを、彼等はふだんから聞いていたからであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし肝腎の熊の胆がどれであるか判らないので、三人は当惑した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは彼の備前屋の番頭の四郎兵衛で、かれは大きい薬種屋の番頭であるから熊の胆の鑑別が付くに相違ない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "備前屋へ熊の胆を売り込む相談について、かれは一旦｜躊躇したが、結局その仲間入りをすることになって、いずれ自分が起きられるようになったならば番頭に話してみようと受け合った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "何者かが彼等より先に死骸を掘り出して、熊の胆を盗み去ったのであろうという説明を聞かされて、彼はいよいよ驚いてがっかりした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、自分も一緒に死ぬ気であったが、そこへ六三郎と百助が駈けて来たので、急に怖くなって逃げ出したというわけです」「そこで、その熊の胆を盗み出したのは誰だか判らないのですか」と、わたしは又訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この方のお話をすると長くなりますから、手っ取り早く申し上げると、熊の死骸を掘り出して熊の胆を盗んだ奴は、備前屋の番頭の四郎兵衛でした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼間のうちに六三郎から死骸を埋めた場所を聞いて置いたので、日の暮れるのを待って忍んで行って、ひと足さきにその熊の胆を占めてしまったのです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々は熊の胆のやうな苦い皮肉を交へながら。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "姪は熊の胆を盃に溶かしてお菊に飲ませたりなぞした。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩をそびやかして諂い笑い、巧言令色、太鼓持ちの媚を献ずるがごとくするはもとより厭うべしといえども、苦虫を噛み潰して熊の胆をすすりたるがごとく、黙して誉められて笑いて損をしたるがごとく、終歳胸痛を患うるがごとく、生涯父母の喪にいるがごとくなるもまたはなはだ厭うべし。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにようやく笑いを停めると、こんどは笑いあきたか、急に熊の胆を嘗めたようなむつかしい顔になって、「では、こうしよう。",
              "citation": {
                "source": "今昔ばなし抱合兵団",
                "author": "――金博士シリーズ・４――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときは御遠慮なく、この枕をお使い遊ばせ」　村松検事がこれを見て熊の胆をなめたような顔をした。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく胃痛腹痛をやったから熊の胆と赤玉。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第二回　富山の薬と越後の毒消し≪富山県・新潟県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "奉書包みのようなちょッと物々しい包みでさすがに外形は歴史的な威風を示していたが、いまどきこういう骨董的な薬は、旅行者が富山ミヤゲに買ってく以外には注文がないそうで、熊の胆、赤玉も忘れられつつあるらしい。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第二回　富山の薬と越後の毒消し≪富山県・新潟県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "沈香、麝香、人参、熊の胆、金箔などの仕入、遠国から来る薬の注文、小包の発送、その他達雄が監督すべきことは数々あった。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこのくまのいは、自分が冬猟に出て打ったもので、けっして、ほかから受けてきたものでありません。",
              "citation": {
                "source": "手風琴",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
