    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to regret",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そんな井伏さんを見て、井伏さんを甘いなと、なめたら、悔いる事があるかも知れない。",
              "citation": {
                "source": "小照",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は自分の馬鹿を悔いる。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時が来ても、私がこの農場を解放したのを悔いるようなことは断じてないつもりです。",
              "citation": {
                "source": "小作人への告別",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の少しばかりの言葉がおぬいさんを泣くほどに苦しめたかと思うと、園は今夜の浅慮を悔いるような気にもなった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、過去の嘆きとか悩みとか、罪悪を悔いる気持ちとか、それらは体の皮膚にたまる老廃物と同じく人間の心象のはたらきに溜る老廃物です。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はもう何も申上ぐることもありません、又何も悔いる処はありません、私が只残念なのは、折角のヽヽが全くヽヽに終つたこと、それ丈であります。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "何物をも酒に代へて悔いることのない人が酒徒である。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "その身に箔をつけるため、将来のおのれの出世に備えるため、フランスに遊学の途端に、降って湧いた災難、その時とっさに自分の野望をからりと捨て、デンマーク国の名誉を守るために、一身を犠牲にして悔いる色が無かった。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」仕事を、全部犠牲にしても、悔いることは無いと思っていた。",
              "citation": {
                "source": "新樹の言葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）準之助氏は、自分のした悪事を悔いるよりは、妻の人を人とも思わざる思い上った考え方を憎悪する心が、燃え上った。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "当り前ならば、尋ねる友人の家に著いたのであるから、やれ嬉しやと安心すべき筈だに、おかしく胸に不安の波が騒いで、此家に来たことを今更悔いる心持がするは、自分ながら訳が解らなかった。",
              "citation": {
                "source": "浜菊",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "從來とてもおつぎは假令異性を慕ふ性情が漸く發達して來たとはいひながら、竊に其手を執られた時は、後では寧ろ悔いるまでも羞恥と恐怖とそれから勘次を憚ることから由つて來る抑制の念とが慌てゝ其の手を振り※らせるのであつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "其後手についた癖が何かにつけては煙管を掴ませるので、止めたことを彼は心に悔いることもあつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも更に悪いことには、人間はこの運命の狂いを悔いることなく、殆んど捨鉢な態度で、この狂いを潤色し、美化し、享楽しようとさえしているのだ。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼らは等しく葉子を見誤っていた事を悔いるように見えた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれが、罪を悔いる盛遠の心が、どんなに烈しいかを見てゐるがよい。",
              "citation": {
                "source": "袈裟の良人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか自分がさうして出た事を悔いるやうなその時の陰鬱な心持は、あとで考へると、飛んでもない拙らない災害を受ける事の或物を暗示したやうな氣特がした。",
              "citation": {
                "source": "赤い鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして生れもつかぬ片輪になつて了つて……」と、溜息をしつゝ、いつしか自分で自分を責め悔いるやうに言ふのであつた。",
              "citation": {
                "source": "赤い鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど私達は決してそれを悔いることはなかつたと思ひます。",
              "citation": {
                "source": "冬を迎へようとして",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉葉は笑つたりなどしたことを悔いるやうに、眞面目な顏をして急にだまつて了つた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "・白うつづいてどこかに月のある夜みち・寝苦しい月夜で啼いたはほととぎす・てふてふとまるなそこは肥壺・悔いることばかり夏となる・いつでも死ねる草が咲いたり実つたり　五月三十日晴、いよ／＼夏が来た。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "老来ます／＼惑ひ多く、悔いることばつかりなり。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "・つかれてもどつてひなたの寒菊・いちにち風ふき誰もこない落葉する・悔いるこゝろに日がてり小鳥きてなくか・霜晴れ澄みわたるほどに散るは山茶花　十二月四日　冬ぐもり。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……・なんとけさの鶯のへたくそうた・あるだけの酒をたべ風を聴き・悔いることばかりひよどりはないてくれても　　　――（このみち）――このみちをゆく――このみちをゆくよりほかない私である。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の日曜の祭日、絶好の行楽日だけれど、お天気が思はしくない、何だか気の毒に思ふ、嘆くなかれ、むろん悔いるなかれ、人々具足、ほどよく楽しめ。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "どろどろした彼の苦悩が、それらの手紙に吐け口を求めたものだったが、投函した後ですぐ悔いるようなものもあった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、この挙動が何か心の余裕をもっているように見えて、その実｜仮借のないあさましいものだことに十分気がついていたが、思いのほか町の更けているのを見ると、一層それがはっきりするようで、内心来たことを悔いる心にもなっていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、こちらも、それに対して、怒りを以てむくいることは出来なかった。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一階から五階までの間に群がっているたくさんの人の皮膚や口から出るいろいろのなまぬるいガスがここまで登りつめたのを、上からふたをしてしまったせいか、ここへ来ると空気が悪くて長くいるとこれが頭にきいて来る。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、ただなごやかな微笑をもってむくいるのだった。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
