[
  {
    "uuid": "b1f4f97f-4d33-56f2-8e8d-ddaa14bf8136",
    "entry": "悔いる",
    "reading": {
      "primary": "くいる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
