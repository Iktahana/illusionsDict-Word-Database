    "definitions": [
      {
        "index": 1,
        "gloss": "baby spider",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こいつあね、蠅じゃあ大きくって、駄目なの、小さな奴なら蜘蛛の子位は殺つけるだろう。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜘蛛の子は、糸を切られて、驚いて散々なり。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と三吉｜眼を刮きて疾呼すれば、わいわいと鯨波を揚げて蜘蛛の子の散るがごとし。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "散歩の人たちは、蜘蛛の子を散らすように、ぱあっと飛び散り、どこへどう消え失せたのか、お化けみたい、たったいままで、あんなにたくさん人がいたのに、須臾にして、巷は閑散、新宿の舗道には、雨あしだけが白くしぶいて居りました。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、猿の間に非常な混乱が起って、蜘蛛の子を散らすように八方へ逃げてしまった。",
              "citation": {
                "source": "忘恩",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こりゃ、いかん」「此のままにしておかれない」「負けたら、大変だ」「山の者を皆呼んで来い」　小舎の中の者は蜘蛛の子を散らすように外へ出た。",
              "citation": {
                "source": "死んでいた狒狒",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と叫ぶや、てんでに蜘蛛の子を散らすやうに飛び散つてしまつた。",
              "citation": {
                "source": "驚いた話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡て右側の湾の多い陸地は、深い山が櫛の歯のように海に迫り、蜘蛛の子を散らしたような磯馴松が一面に生い茂っている。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、あげ手の一団がまさしく蜘蛛の子を散らしたやうにパツと飛び散つた。",
              "citation": {
                "source": "鱗雲",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてベルが鳴る、長い廊下を生徒はぞろぞろと整列してきて、「別れ」をやるとそのまま、蜘蛛の子を散らしたように広場に散った。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここまで付いて来た農兵隊は、蜘蛛の子を散らすように逃亡した。",
              "citation": {
                "source": "乱世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "杓の水を喰った蜘蛛の子のごとく蠢めいている。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、フットボール競技場前の広場へ、アルバート広場に群っている通りな、いろんな物売りが出ていて、あっちから巡査がやって来るのを見るとパッと蜘蛛の子ちらすように逃げ出すところは、活々した日常生活の光景からの断片で、そこのところで笑わないものがなかった。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分檢屍官でゞもあろう白い服を被た役人と巡査とを乘せたオートバイが、その前に止まると、今迄梁の上に上つてゐた黒い人影は、蜘蛛の子のやうに散つてしまつた。",
              "citation": {
                "source": "梁上の足",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此一声で、蜘蛛の子を散らす如く、小使部屋は見る間に寂寞としてしまつたのであつた。",
              "citation": {
                "source": "俺の記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔戦国の時、駿河の今川義元、数万の兵を率いて織田信長を攻めんとせしとき、信長の策にて桶狭間に伏勢を設け、今川の本陣に迫りて義元の首を取りしかば、駿河の軍勢は蜘蛛の子を散らすがごとく、戦いもせずして逃げ走り、当時名高き駿河の今川政府も一朝に亡びてその痕なし。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも俄然「わーッ」という声が、門口に群れている藤兵衛の乾児――捕吏たちの間から湧き起こり、つづいて蜘蛛の子を散らすように、四方へ逃げ出したという意外な出来事が、惹起されたではありませんか。",
              "citation": {
                "source": "犬神娘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜘蛛の子のように暗い森を蔽うて至る文明の民は皆自分の同類である。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "食後障子を開け放しながら、寝転んで煙草をふかしていると、縁側に小さな蜘蛛の子が、すうっとあるかないかの糸を垂れて下りてきて、そのまま何処かへふうわりと風に飛ばされてしまった。",
              "citation": {
                "source": "金魚",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯の上の蠅同然、蜘蛛の子を散らしたように逃げたかと思うと、また集ってまいります。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで蜘蛛の子が逃げこんだように。",
              "citation": {
                "source": "蠅",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "味方はたちまち蜘蛛の子を散らすように四散して、電柱のかげや共同便所のうしろを利用してしまったというわけさ」「検事さんのお口にかかっては、こっちは皆シャッポや」と署長は苦笑いをした。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、敵の上陸、日本中の風の中を弾の矢が乱れ走り、爆弾がはねくるひ、人間どもが蜘蛛の子のやうに右往左往バタ／＼倒れる最後の時が近づいてゐた。",
              "citation": {
                "source": "続戦争と一人の女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと共に浜辺にいた村民漁夫たちが一時に仰天して、蜘蛛の子を散らすように走り出しました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "Ocean の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物人は蜘蛛の子を散らすように逃げだして、このまま捨て置けば幾人人間があやめられるか分からぬ危急の状景を示してきたので、小文吾は矢庭に闘牛場へ飛び下りた。",
              "citation": {
                "source": "越後の闘牛",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あの朝、遅くまで寝床に愚図々々してた時、天井からすっと蜘蛛の子が降りてきた。",
              "citation": {
                "source": "未来の天才",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるかなきかの細い一筋の糸を伝って、風よりも軽いちっちゃな蜘蛛の子が、室の中に澱んだ空気の間をぬけて、すーっと降りてくる拍子に、私の顔へぼやりと落ちかかった。",
              "citation": {
                "source": "未来の天才",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "微妙な一種の感触――それもあるかなきかの――に、ふっと眼を開くと、糸をたぐりながらくるくると動かしている手足の中にまるまった灰白色の蜘蛛の子は、私の顔から二三尺上の宙に浮んでいて、だんだん上へ昇ってゆく、と思ううちに、もう見えなくなってしまった。",
              "citation": {
                "source": "未来の天才",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピエロは、それを一しづくものこさず、ぺろ／＼とおいしさうに食べて、さもまんぞくしたやうに、しつぽをふりました。",
              "citation": {
                "source": "小犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "祇園精舍の鐘われがねならば、聞くものこれを厭はしとし、われ鐘ならずば好ましとせむ。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
