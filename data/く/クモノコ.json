  {
    "uuid": "e73598e8-2d5a-5e28-9132-20c12162d109",
    "entry": "蜘蛛の子",
    "reading": {
      "primary": "くものこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
