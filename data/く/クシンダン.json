[
  {
    "uuid": "551794cd-fddd-5109-ab0a-64d3a021fa1e",
    "entry": "苦心談",
    "reading": {
      "primary": "くしんだん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
