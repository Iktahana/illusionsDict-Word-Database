    },
    "definitions": [
      {
        "index": 1,
        "gloss": "account of the hardships one has encountered",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そんな、苦心談でもって人を圧倒して迄、お義理の喝采を得ようとは思わない。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はいまの人の小説はあまり読まない事にしているので、君の小説もたった一つしか拝見した事はないのだが、何でも、新型の飛行機を発明してそれに載って田圃に落ちたとかいう発明の苦心談、あれは面白かった。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白川が苦心談を聞いてゐるのさへ座に堪へない程であつた。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦心談、立志談は、往々にして、その反対の意味の、自己｜吹聴と、陰性の自讃、卑下高慢になるのに気附いたのである。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頑丈の鉄仮面をかぶり、ふくみ声で所謂創作の苦心談をはじめたならば、案外荘重な響きも出て来て、そんなに嘲笑されずにすむかも知れぬ、などと小心｜翼々、臆病無類の愚作者は、ひとり淋しくうなずいた。",
              "citation": {
                "source": "鉄面皮",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互いに無事を喜び合い、今までの苦心談を語り合い、この上は如何なる事があっても女の情に引かされまい。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかり喜んでしまって、自分の苦心談や、研究の内容なぞをドン底まで喋舌ってしまう。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかした時には師匠能静氏から指導された時の有益な苦心談などを述懐まじりで話して行く事もあったらしい。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロッス少佐のその発見については、永い苦心談もあるのですが、それはわづらはしいのでひかへます。",
              "citation": {
                "source": "パナマ運河を開いた話",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｍの字の秘密　記者がある老刑事さんを訪うて苦心談をきいていると、偶然こんな事を云い出した。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな話ばかりでは人情話どころか、不人情話と云うべきであるが、さきに殺された助右衛門の娘おまきと忰重次郎、この姉弟が父のかたきを尋ねる苦心談があり、結局は丈助が前非を悔いて切腹し、めでたしめでたしに終わることになっている。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、お大名のお膳番の苦心談といったようなものを、話しはじめようかと思っていた。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "武田をつかまへて得意になつて神無部落の組織の苦心談を一くさり辯じてゐる自分の姿がそこにある。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "入選した画家の苦心談を読んでみると、大抵影に忠実な細君が居て、塩断茶断をしたり、神様に百日の願を掛けたりしてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんある大財閥の血統の一人のこれは隠宅なので、構えが宏壮という種類のものではなく、隅々まで数寄を凝らしたお茶趣味のものだったが、でっぷり肥った婦人の三年にわたった建築の苦心談を聴くだけでも、容易なものではなかった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "義雄は渠を待ちながら、雜誌の刷り上り見本のページを繰つて見ると、雨敬、新戸部、山縣勇次郎、その他知名の人々の材料の外に、呑牛の人物評や逸事談、天聲の新聞編輯苦心談、北劍の中野天門談などがある。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "大家の苦心談などと云はるる中、人の悪き名人が、凡下の徒を翻弄する為に仮作したものも少くあるまい。",
              "citation": {
                "source": "雑筆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、くどくどしい苦心談は、抜きにして、さっそく解読法を述べることにしよう。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は又作家の苦心談でもよろしい。",
              "citation": {
                "source": "文芸鑑賞講座",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから又文芸以外の芸術に関する、一かどの作家の筆に成つた芸術上の議論或は苦心談も存外莫迦にはなりません。",
              "citation": {
                "source": "文芸鑑賞講座",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると其處にゐた友人梶原可吉君は、その話に誘はれて、彼の購書苦心談を彼一流の高調子で始めた。",
              "citation": {
                "source": "貝殼追放",
                "author": "購書美談",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、昼食のご馳走になり、地上勤務部隊の隠れた苦心談を聴きながら、以前支那兵営であつた宿舎を一巡した。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつとこゝまでに仕上げたのだといふ、破壊された鉄路の困難な修復工事について、一席、苦心談にちよつぴり手柄話を交へた、朴訥で至誠のあふれた話を面白く聴く。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雨蛙」その他の話から、三時頃まで居、作の苦心談しきりにされるが、遠慮なく云えば、やや八点五分の方――不肖の息らしい。",
              "citation": {
                "source": "日記",
                "author": "一九二四年（大正十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "『新青年』一冊と一九二九年二月□日新聞所載説教強盗タイ捕苦心談をよんだだけでも、人は如何に探偵術に科学が絶対権をもって居るか知ることが出来るだろう。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "美女は云うまでもなくツル子で、間宮坊介執筆のマニ教撮影苦心談ものっている。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村嘉平を元祖とする人々の場合は、嘉平の苦心談を探しだせばよいのであつた。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば嘉平の苦心談は、その註文主島津齊彬の意志がなくては生れないし、齊彬のさういふ前代未聞の註文は、當時の對内外關係をべつにしてはまつたく判斷出來ないであらう。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "當時は、作家の文學感想や苦心談を談話筆記といふ形式で掲載することが流行してゐた。",
              "citation": {
                "source": "編集者今昔",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあそんな騒ぎの飛ばっちりで、僕にも一つ板前の苦心談をやれという話になったが、実をいうとこれはちょっと困る。",
              "citation": {
                "source": "飜訳のむずかしさ",
                "author": "神西清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
