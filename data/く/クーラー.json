        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「外は35度もあるから、クーラーを最強にして冷えるのを待とうよ」と彼女が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古いアパートのクーラーは効きが悪く、いくら設定温度を下げても一向に涼しくならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夜通しクーラーをつけっぱなしにしていたせいか、朝起きたら喉がカラカラに乾いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "早くいって、食堂のクーラーで涼もうぜ」「きみは、その格好で涼んだら、風邪ひきますよ」　ワラが、パンツ一枚の山崎を鼻で嗤う。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「クーラーはあるのかしら」　彼女が言った。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ありますよ」　僕はクーラーのボタンを押した。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「広々として素敵ね」　居間の南側の隅にクーラーが立っていた。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのクーラーのスイッチを川島はオンにした。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の夜、クーラーのおかげでほんのりと涼しい寝室のなかで、ふたりは長椅子にすわって話をした。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "クーラーで冷やされた客間の空気のなかに、美しくすっきりと、百合絵は立っていた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "哲也はウオーター・クーラーの水をグラスに半分ほど注ぎ、ゆっくりとそれを飲んだ。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「五人も乗ると、ハンドルの感じが、ぜんぜんちがう」　やがてクーラーが、きいてきた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
