    "definitions": [
      {
        "index": 1,
        "gloss": "looking on with surprise",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "然れども開元の盛時に当りて、一行阿闍梨、陛下万里に行幸して、聖祚疆無からんと奏したりしかば、心得がたきことを白すよとおぼされしが、安禄山の乱起りて、天宝十五年｜蜀に入りたもうに及び、万里橋にさしかゝりて瞿然として悟り玉えりとなり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」わたくしは始て読んで瞿然とした。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "南洲一見して瞿然たり。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "久助君のからだのなかに、ばくぜんとした悲しみがただよっていた。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "模　樣かくぜんめぢの外秋澄み方角すでに定まり大藍色天電線うなる電線目をつらぬき。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "模樣かくぜんめぢの外秋澄み方角すでに定まり大藍色天電線うなる電線目をつらぬき。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はがくぜんとして自分を省みた、そして恥ぢた、何といふ醜い私だつたらう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝はしゆくぜん身心の新たなるを覚えた、私はやうやくまた一転化の機縁が熟してきたことを感じる。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "徹夜不眠、しゆくぜんとして寝床から起き上つた、あゝ、どんなに思ひ悩んだことか。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近二ヶ月間の変化を考へると、私はしゆくぜんとする、自然も私もすつかり変化した。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "未明起床、しゆくぜんとして省悟するところがあつた。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れたり曇つたり酔うたり覚めたり秋はゆく　十一月二十七日　曇――晴、道後湯町、ちくぜんや。",
              "citation": {
                "source": "四国遍路日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はしゆくぜんとして私を観た。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "『鉄鉢の句』こゝまでくれば、もう推敲といふやうなものからは離れる、私はしゆくぜんとして、因縁の熟するのを待つばかりである。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし相撲というものは何か僕にはばくぜんとした反感に近いものを与えやすかった。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "不意にむほんをおこされたやうで、隆吉はしやくぜんとしない。",
              "citation": {
                "source": "崩浪亭主人",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」富士男はがくぜんとした。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう思うとドノバンはがくぜんとした。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　一同はがくぜんと顔を見あわした。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "歓迎　凶漢どもを撃退し、負傷せるドノバンをたんかにのせて、左門洞へひきあげんとした富士男の一行が、いま左門洞のほとりに少年たちとケートのさけび声をきいたのでがくぜんとした。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤くぜんざいとかいてある。",
              "citation": {
                "source": "京に着ける夕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばくぜんとした恐怖に声をふるわせながら、わたしはなにも見えないと答えた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙に古めかしい壁かけがさがっていたり、王朝ふうの蒼味をおびた椅子や花瓶がおいてあったりして、――などと、ばくぜんとこんなことを考えているうちに、自分がいま、いかにけんのんな状態にいるかに気がついた。",
              "citation": {
                "source": "放浪作家の冒険",
                "author": "西尾正",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は様々にそんなことを考えながら心持よく風にふかれ、段々奥へ入って行って、あの山からぐるりとまわって（左へ）あたり前の山中らしくぜんまいなど生えた径をぬけるとお墓がありました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、日本労働運動史の初ページは明治初めだが、そんな旗のない時代から、ばくぜんと、千二百年前の人間たちでも、原始ストともいえる疼きを見せていたことが、それらの正倉院文書の中に知るのだった。",
              "citation": {
                "source": "美しい日本の歴史",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてが女体のあらゆる部分を、ばくぜんとかたどっているように見えた。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがの影男も、その着想のむざんさに、がくぜんとした。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、あいての侍はがくぜんとして、五、六歩あとへさがりました。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでそのおかたの御口上には、ちくぜんのかみこと、昨年以来よぎないしあわせで柴田どのとかっせんにおよび、さいわい武運にめぐまれてこゝまでおしよせてまいりましたが、むかしをおもえば総見院さまにおつかえ申した朋輩のあいだがらゆえ、御一命までを申しうけようとは存じませぬ。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちくぜんどのはお市｜御料をいけどりにしたくてそろ／＼おくの手を出しおったと、味方はもとより敵の陣中でさえそんなひょうばんが立ったくらいでござりまして、此のおあつかいをまじめにきくものはござりませなんだ。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
