    "definitions": [
      {
        "index": 1,
        "gloss": "two halves of the whole",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
