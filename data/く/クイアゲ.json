[
  {
    "uuid": "a02534ee-41e0-5cbf-a908-67e167cf95c5",
    "entry": "食い上げ",
    "reading": {
      "primary": "くいあげ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
