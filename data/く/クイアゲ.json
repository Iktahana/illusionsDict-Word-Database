    "definitions": [
      {
        "index": 1,
        "gloss": "losing one's means of livelihood",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "剥製の獣じゃあるめえし、傷口に、ただの綿だけ押し込んどいて、それで傷が癒りゃ、医者なんぞ食い上げだ！",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "目に見えて刻々水量を増してゆく赤い流れは土城の下部をぐっと食い上げている。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしまたそれが出来るにしても、そうそう永く研究していたでは飯の食い上げになろうというもの。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうすればもっとよくなるのではないかと思う点が多々あるが、いや、これが良くなったら、映画は脅威で、おまんまの食い上げだから、よくなってはいけないのだと、黙っているのである。",
              "citation": {
                "source": "映画界・小言幸兵衛",
                "author": "―泥棒しても儲ければよいは困る※―",
                "note": "青空文庫"
              }
            },
            {
              "text": "「飯の食い上げ――脹れっ面――天国婆――おしまいの一口――その他。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれたちが、夜をムダに過していちゃ、飯の食い上げになるだろうじゃねえか」「だから、私も家へ帰るのよ」「家へ？",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゃくい網を持った者は岩を伝って往って、下へ流れて往こうとする魚をしゃくいあげた。",
              "citation": {
                "source": "岩魚の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幽霊藻が相変らず咲いていると思うと、不思議にそれが懐かしいような気になって、そこらに落ちている木の枝を拾って、その藻をすくいあげて、まあどういう料簡でしょう、その濡れた草を自分のふところへ押し込んだのです。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "好奇心はいよいよ募って、女の童は息もせずに見つめていると、女はやがてその青い藻を手の上にすくいあげて、しずくも払わずに自分の頭の上に押し頂いた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍艦から大陸へ　わが海軍の駆逐艦にすくいあげられたきょうだいは、たちまち艦内の人気者になりました。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では誰のアミが現代のアクタモクタをホントにしゃくいあげることができるだろう？",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、「誰のアミが現代のアクタモクタをホントにしゃくいあげることができるだろう？",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学が現実を「ホントにしゃくいあげる」ということは、どういうことだろうか。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お早う……」　伸子は、丁度｜襟をつけかけていた衣服を両腕ですくいあげながら寝台から立上った。",
              "citation": {
                "source": "七階の住人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "…………　乗馬は拍車にいきり立つと、土煙を力一杯にすくいあげて、斜な陽に鹿毛の毛並を躍らせた。",
              "citation": {
                "source": "シベリヤに近く",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すくいあげて、とりあえず、コンクリートのたたきの上に置いておいた。",
              "citation": {
                "source": "奇怪な話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、不忍池の濁水は、貸ボートの浮んでることよりも、蓮の青葉の繁茂してることよりも、なお一層、子供等が数ひきの小魚や小蝦をしゃくいあげてくれることによって、生きてる清水の幻想を与える。",
              "citation": {
                "source": "文学以前",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "千世子はＨのあらを出来るだけすくいあげて考えた。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ターネフとニーナは、いつの間にか、自国の汽船にすくいあげられ、これもぶじに、横浜上陸となった。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽船の上にすくいあげた以上は、なんとしてもかれの意識をよみがえらせねばならない。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルゾン号にすくいあげられたのは、それから四、五時間のちだったという。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪物の足が小またをすくいあげた。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "折々手にすくいあげて少しずつこぼして工合を見る。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから木田さんは、また暫くぼくたちを更にほれぼれと撫で廻していたが、やがてぼくたちを両手ですくいあげると、別の大きな機械台の上へ連れていった。",
              "citation": {
                "source": "もくねじ",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを切り取ると、両手ですくいあげられるほどの僅かな分量のものでしかなかった。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、その真赤な硬い藻を両手ですくいあげたその所員は、急に両手をふるわせ、悶絶してしまった。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はて――」　局長は、櫂を借りて、二号艇の血の海のなかから、気になるその手首をそっとすくいあげた。",
              "citation": {
                "source": "幽霊船の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "小鳥なんかは、一度に二十羽や三十羽は、ナイフの先ですくいあげて食べるのでした。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "小男だから、いつも相手をすくいあげるようにして、しわんだ、よく光る茶っぽい眼でみつめながら、いうのである。",
              "citation": {
                "source": "白い道",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "……中洲の四季庵にごぶさたしてから、もう、久しくなる」　と、ぼやきながら、煙管で煙草盆をひきよせ、五匁玉の粉ばかりになったのを雁首ですくいあげて、悠長に煙をふきはじめる。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "都鳥",
                "note": "青空文庫"
              }
            }
          ]
        }
