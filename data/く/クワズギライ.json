    "definitions": [
      {
        "index": 1,
        "gloss": "disliking a certain food without having tried it",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
