        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「黙っててくんろよ。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ここへ打ちまけて見せてくんろ。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「また來てくんろよう！",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいらにもあんないい翼をつけてくんろよ」　親あひるはそつぽを向いて聞えないふりをしてゐたが、眼には涙が一ぱいでした。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより、水を一杯飲ませてくんろ」　父親の吾平爺はそう言って、呻りつづけるのだった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おめえ行ってくんろ。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ知ってするごんだよ、だから放っといてくんろ、畜生！",
              "citation": {
                "source": "田舎風なヒューモレスク",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その髯を俺にくんろ！",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "友達｜甲斐に、もう一軒だけ、つきあってくんろ、いいかッ」　帆村が、私の顔の前で、酔払いらしくグニャリとした手首をふった。",
              "citation": {
                "source": "西湖の屍人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うん、教へてくんろよ、親切な姐さんたち！",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "先の旦那がなくなられますと、すぐ手紙が参りまして、儂はなくなった人の甥っ子だが、別荘さ譲り受ける事になったゞから、前々通り管理していてくんろっていって来ましたゞ。",
              "citation": {
                "source": "青服の男",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺ア年だで、皆の衆やってくんろと尻ごみするのだ。",
              "citation": {
                "source": "共同耕作",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか、はあ、気をしずめてくんろよ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」としばらく考え込んで、「女の頬にこの呪文――お、そりゃあそうと、あの高札のこったがの、あんなべら棒な物を立てやがった張本人はいったいどこのどなた様だか、彦、御苦労だがお前ちょっと嗅いで来てくんろ。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "巷説蒲鉾供養",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつ、ようく、村一統のためを思うて考えてくんろて、仙太郎さ！",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ワッ、た、助けてくんろッ」　お村は四ん這いになって飛出しました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "朱塗の筐",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ワツ、た、助けてくんろツ」　お村はよつん這ひになつて飛出しました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "朱塗りの筐",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっと畑さ行って与次郎がいたらよんで来てくんろ」　与次郎が縁側に廻ると、祖母は炉ぶちで煙管をはたきながら、「お前、茶壺しらねえか？",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はどこの家でもかまわずに、入って行っては、「酒えくんろー」とねだる。",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥にいた祖母やその他の者も出て来て、半ば気味悪く半ばめずらしそうに、だまって庭に立っている善を見ていると、暫くして彼は低い声でかなりはっきりと、「酒えくんろー」と云った。",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よーく覚えててくんろよ、俺らおめえを憫然に思ってただが、俺ら貧乏だ、どねえにもすっこたあ出来なかっただかんな？",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オーイ、誰来てくんろよ――オーイ」　近所の桃林で働いていた三人の百姓は、びっくりして仕事の手を止めた。",
              "citation": {
                "source": "禰宜様宮田",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オーイ来てくんろよ――沼だぞ――」「あら、オイ禰宜様の声でねえけえ？",
              "citation": {
                "source": "禰宜様宮田",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ころげるようにして、小屋へ馳けつけた彼は、いきなり出ようとする空椅子を捕まえると、ギューギュー自分の体を押しつけながら、「乗せてくんろ！",
              "citation": {
                "source": "禰宜様宮田",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつ、ようく、村一統の為を思うて考えてくんろて、仙太郎さ！",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「皆の衆、おれも乗せてくんろよ」一人の若者が食指動いた風に、群衆の中からそう叫んだ。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その悪い野郎の手足をぶっ挫いて、首ったまをひっこ抜いてやるがいいだ、皮をひん剥いて土産に持って来てくんろえ」「そうだ、身の皮をひん剥いて来てくろ」　弥市もはだしではねながら、叫んでいた。",
              "citation": {
                "source": "似而非物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やれやれ、おそくなったで腹が減ったんべえ、甥っ子のとけえいったらの、今朝がた鹿を射ったそうで、肉を少し分けて貰って来ただ、今夜はそれを煮てやるだからもうちょっと辛抱してくんろよ」　外はいま黄昏であった。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おらといっしょに、むこうの森の中まで、きてくんろ。",
              "citation": {
                "source": "妖星人Ｒ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
