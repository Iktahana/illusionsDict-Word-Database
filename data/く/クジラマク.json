    "definitions": [
      {
        "index": 1,
        "gloss": "black and white striped curtain (used at funeral service)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "校舍をめぐらした紅白の鯨幕が風をはらんで獅子舞ひのやうに見えた。",
              "citation": {
                "source": "摩周湖紀行",
                "author": "――北海道の旅より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "千光寺山には紅白の鯨幕がちらほら見えた。",
              "citation": {
                "source": "田舎がえり",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　門前には、白黒の鯨幕を張りめぐらし、鼠いろの紙に忌中と書いたのが、掲げてある。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "白黒の鯨幕、四｜旒の生絹、唐櫃、呉床、真榊、四方流れの屋根をかぶせた坐棺の上には、紙製の供命鳥をかざり、棺の周囲には金襴の幕……昔は神仏まぜこぜ、仏式七分に神式三分の様式なんです。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠木戸を二カ所につくって三方に桟敷をしつらえ、まンなかの空地へ鯨をころがしてこれを鯨幕で四方からかこい、いよいよ客がつまると一挙にぱッと幕を取りのけ、黒天鵞絨に金糸銀糸で鯨波を刺繍した裃を着た美しい女の口上つかいが鯨の背に乗って口上をのべる。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "両国の大鯨",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょうしょう吐気が来かかったころに、ボーボーと鯨船で吹く竹法螺の音が聞え、それがきっかけで、白黒だんだらの鯨幕がさッと取りはらわれる。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "両国の大鯨",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯨幕をはりめぐらした玄関から、故人の柩の前まで、更にそこから出口まで、白布がしきつめられ、柩の横に、礼装の親族が立ち並んでいた。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四　これが、ほんとの一国対一国の煙火陣ならば、鯨幕をひき、押太鼓、陣羽織、あだかも戦場の対陣のような空気が立つところであるが、今夜は、藩の次席家老のせがれと一煙火師との果し合いだから、暗夜の大河に人影はほんの僅か、寂寞として、用意の足音もいと静かである。",
              "citation": {
                "source": "銀河まつり",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "サツと一陣の晝の風が吹くと、棺の後ろの鯨幕が動いて、何やら不吉な呻き聲――。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "生き葬ひ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鯨幕の後ろを見るんでせう」「さうだよ」　が、併し、それは無駄でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "生き葬ひ",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯨幕の後ろは、僅かに人間一人通れるほどの通路で、一方の口は群衆六百の眼玉の光る庭に開き、そして他の一方の口は、内廊下の――其處には藤屋の番頭や手代や、伜の彌吉や――多勢内輪の者の居るところに開いて居るのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "生き葬ひ",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人の後ろから、伜や番頭が一緒に出て來たぢやありませんか」「すると善八を鯨幕越しに刺した曲者は何處へ消えたんだ」「わかりませんよ」「鯨幕の蔭からあの騷ぎの中へ出て來た者はなかつたか」「氣が付きませんね。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "生き葬ひ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「驚きましたね、親分」「驚くひまに、幕の蔭へ廻つて、指でその穴のあたりを押して見てくれ」「へエ」　八五郎は鯨幕の裾を潜つて、裏へ出ました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "生き葬ひ",
                "note": "青空文庫"
              }
            },
            {
              "text": "錢形平次の眼の前で、人一人殺して見せ度くなつたのさ」「驚いた野郎ですね」「棺の中でうめき聲がして、敷いた白い布がサツと赤くなつて、皆んなそれに氣を取られて居る時、そつと鯨幕の裾を潜つて出るのは、手品によくある術だが、うまい事を考へたものさ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "生き葬ひ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま山は紅葉のまっさかりで、山腹山上、ところどころに鯨幕やむらさきだんだら染の陣幕が、樹間にひらめいて見える。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "広前にはりめぐらした鯨幕、また別れわかれに陣どった諸家の定紋幕が波のようにハタハタと風をうつ。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いきや、時にあなたなる西側の鯨幕をしぼって、すらりと姿をあらわした壮漢の手には、遠目にもチカッと光る真槍が持たれていた。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物はハッと息をのんだが、そのとき、あなたの幔幕やこなたの鯨幕のうちで、しゅんかん、ワーッという侍たちの声があがった。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「ああ、ざんねんだ……」　と太い息をついたが、ふと気がついてみると、そこは奉行小屋の裏手らしく、すぐ向こうから十｜数間のあいだには、ズッと鯨幕がはりめぐらしてあって、一方の帳には黒く染めぬいた葵の紋印が大きく風をはらんでいる。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　上流の福知山からも五里半、下流の宮津からも五里半の中央に選ばれたその日の曠場たる桔梗河原には、五町余りの長方形に、青竹の矢来を結いめぐらし、三つ扇の定紋打った幔幕の桟敷には福知山の領主松平忠房が老臣近侍を左右にして居並び、別に黒の鯨幕の蔭には試合に出る剣士の花形が鳴りを鎮めて控えていた。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かと覗いて見ると、だんだらの鯨幕を張り廻し、人寄せの陣太鼓を山鹿流もどきに叩いて、飛び入りの武芸天狗を歓迎している賭け剣術であった。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "型の通りな鯨幕が一文字に張ってある側には、小屋主の楽屋らしい蓆囲いが見え、その前には一本の棒杭を打って、新木の尺板に墨黒々と、　＝日下無敵｜叡山流投げ槍の開祖。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時も同じに、松平忠房の鯨幕をヒラリと刎ねて、颯爽たる姿を現した痩せぎすの青年は、すなわち春日新九郎。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
