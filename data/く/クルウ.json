    "definitions": [
      {
        "index": 1,
        "gloss": "to go mad",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "印度人の小作りなのが揃って、唯灰色に荒れ狂うスクリーンの中で、鑿岩機を運転しているのであった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私に附き添って居た者が気がついて私を診察室の方へ連れて這入ろうとした時に、廊下の突き当りの中庭を隔てた一棟の病房から、けたたましい狂女のあばれ狂う物音が聞こえ始めました。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は花田君子柳の下に棄てて、カバレット銀座、未来の情婦、万国の血をみて狂うメイ・フレデリック、私を見るや彼女の情熱死物狂い（その頃喫茶店インタナショナルの芸術家は珈琲とフランス菓子に驚歎して昆虫類が今後人間に代ってエゴイズムと排他主義、実行する。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の運命の墓誌銘をつくるために妾は女だてらに気が狂うほど急がしいのです。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の運命の墓誌銘をつくるためには妾は女だてらに気が狂うほど急がしいのです。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャズも客観的に鑑賞するものではなくて、自分で踊り狂うと同価値の活動そのものだからである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明けても暮れても姫の名を呼んで、どうぞ一度逢わせてくれと泣き狂うので、屋敷中の者も持て余した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "子ゆえに狂う母の心と、その母を取り鎮めようと努めている家来どもの苦心と、それに対しても余りに強いことも云われない破目になった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの道死ぬるものなら一足でも前へ進んで、世間の者が夢にも知らぬ血と泥の大沼の片端でも見ておこうと、そう覚悟がきまっては気味の悪いも何もあったものじゃない、体中｜珠数生になったのを手当次第に掻い除け※り棄て、抜き取りなどして、手を挙げ足を踏んで、まるで躍り狂う形で歩行き出した。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "近い岬の岩間を走る波は白い鬣を振り乱して狂う銀毛の獅子のようである。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "眩しいような真昼の光の下に相角逐し、駈けり狂うて汀をめぐる。",
              "citation": {
                "source": "ある幻想曲の序",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、いまに気が狂うのかも知れません。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして新約の時代に到って、サタンは堂々、神と対立し、縦横無尽に荒れ狂うのである。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりに、キヌ子にむだ使いされたので、狂うような気持になっているのかも知れない。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、吠え狂うような、はしたない泣き方などは決してしない。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぢゃ、声さへ発たうにも、咽喉が狂うて音が出ぬぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうじゃ、声さえ発とうにも、咽喉が狂うて音が出ぬじゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナントまあ、渦巻き狂う塵だろう。",
              "citation": {
                "source": "塵",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "『そうよ懐が寒くなると血がみんな頭へ上って、それで気が狂うんだろうよ』と言ったのは長屋の者らしい。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途中で、車の前面の幌にはまったセルロイドの窓越しに見る街路の灯が、妙にぼやけた星形に見え、それが不思議に物狂わしくおどり狂うように思われたのであった。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時計はよく狂うので、あまりあてにはならなかったけれど、反射鏡をいかに調節してみても、クロモゾームの配列の具合がしっかりとは見極められないので、およその時間はわかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘が恋狂うとか恨み死にとかいうことでもあったら肝に堪える悲痛な嘆きに苦しみはすれ、男として得意のところもあろう。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白き牡丹の大輪なるに、二ツ胡蝶の狂うよう、ちらちらと捧げて行く。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂高く、天近く、仰げば遥かに小さな少年の立姿は、狂うがごとく位置を転じて、腕白く垂れたお雪の手が、空ざまに少年の頭に縋ると見た。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二個の頭、獅子頭、高いのと低いのと、後になり先になり、縺れる、狂う、花すれ、葉ずれ、菜種に、と見るとやがて、足許からそなたへ続く青麦の畠の端、玉脇の門の前へ、出て来た連獅子。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしても今日のうちに日光まで辿り着かぬと予定の行路が狂う。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は嘗て物に狂うたことがないと高言が出来る。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男を見て、病人は何か言いたげに唇を震わせしが、あわれ口も利けざりければ、指もて其方を指示し、怒り狂う風情にて、重き枕を擡げしが、どうと倒れて絶入りけり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お鶴は総六の小屋に生れて、そこでこの年まで育ったので、あたかも浪の打附って様々に砕くるのが、旭に輝き、夕陽に燃え、月にあらわれ、時雨にかくるる、牡丹の花に、雌雄の獅子の狂う状を自然に彫刻んで飾ったような、巌を自然の石垣は、二階屋に住むものの馴れた階子段に異ならず。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう誰だって胸中からもくもく湧いてくるうれしさに笑い出さないでいられるでしょうか。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
