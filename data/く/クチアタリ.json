          "literary": [
            {
              "text": "風薫る初夏の時候に応じたまことに気分のよい、また口当たりのよいものである。",
              "citation": {
                "source": "鮑の宿借り作り",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで飲みやすいかと騙されて飲むと、もともと苦くて口当たりの悪いのに変りはないのです。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "人口当たりニューヨークの火事はロンドンの四倍だ。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは既に知られていた化合物がビタミンとなった唯一の例であり、今では口当たりの良い“ナイアシン”の名称が与えられている。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            }
          ]
        }
