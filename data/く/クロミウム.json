        "examples": {
          "standard": [
            {
              "text": "クロミウムは、ステンレス鋼の製造に不可欠な元素だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼のネックレスは、クロミウムでコーティングされていて輝きが美しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "体内におけるクロミウムの役割について、専門家が解説した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "何しろ蓄音機用の針たるや、市場に鬻がれているものは千差万別で、同一の会社からも、低音、半音、高音、特大音、或はクロミウム針、竹針、等々が売り出されている有様だから、これでは迷わないわけに行かぬであろう。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "クロミウム針　最近クロミウムを使った硬度の高い針が出来て、七十五回から百回ぐらいまで取り替えずにそのまま使えると称されているが、これはしかしいわゆる宣伝文句であって、私の経験によれば、大抵三十面ぐらいでいけなくなるようである。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹針よりは鋼針がよく、更にクロミウム針がよい。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
