    "definitions": [
      {
        "index": 1,
        "gloss": "to wrap up (in)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
