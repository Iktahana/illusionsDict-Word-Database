    "definitions": [
      {
        "index": 1,
        "gloss": "black porgy (Acanthopagrus schlegeli)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "肝油その他の臓器製薬の効能が医者によって認められるより何百年も前から日本人は鰹の肝を食い黒鯛の胆を飲んでいたのである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鯒や黒鯛のぴち／＼はねる、夜店の立つ、……魚市の處は？",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、いはうとして……昨日に懲りて口をつぐんで、一寸容儀を調へた、が黒鯛。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒鯛ならああいう竿で丁度釣れますのです。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒鯛ほどの大きさで、太く鮮やかな數本の竪縞を有つた魚が一番多く、岩蔭の孔らしい所から頻りに出沒するのを見れば、此處が彼等の巣なのかも知れない。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒鯛ほどの大きさで、太く鮮やかな数本の竪縞を有った魚が一番多く、岩蔭の孔らしい所から頻りに出没するのを見れば、此処が彼らの巣なのかも知れない。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "細長い姿のさよりやうぐいはその群までも細長く續いて、折れつ伸びつ、ちよこ／＼と泳いで行き、黒鯛はおほく獨りぽつちでぼんやりとその大きな體を浮かせ、何か事があるとぴんと打たれたやうにかき沈んで忽ち何處へやら消え去りました。",
              "citation": {
                "source": "樹木とその葉",
                "author": "海邊八月",
                "note": "青空文庫"
              }
            },
            {
              "text": "道ゆき鰡と黒鯛と、黒鯛と、鰡と、のうえ肥前山をば、やんさのほい、けさ越えた、ばいとこずいずい。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯釣の船を浮べて、岸近く寄つてくる黒鯛を突き刺す光景なぞも、こゝではさうめづらしくない。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "・ひとりゐて蜂にさされた　雨の蛙のみんなとんでゐる午後、樹明さんが黒鯛持参で来訪（モチ、銘酒註文）、ゆつくり飲む、夕方、山口まで進出して周二居を驚かす、羨ましい家庭であつた、理解ある母堂に敬意を表しないではゐられなかつた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "海津は「ケエヅ」とよんでいただかねば江戸ッ児には承知が出来ず、何んだ黒鯛の子かァ……などは少々お話にならぬ筋だ。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか海鰻の蒲焼に黒鯛の塩焼、鰕の鬼殻焼」「まるで品川へ行ったようだな」「はい、みな品川から夜通しで廻りますので。",
              "citation": {
                "source": "怪異暗闇祭",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣りの腰掛で最前から、一人でちびりちびり、黒鯛の塩焼で飲んでいる旅商人らしい一人の男。",
              "citation": {
                "source": "怪異暗闇祭",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "手釣りの黒鯛を沖で叩いて締めた刺身、つづいて丸い伊豆石を敷いた大鉢の中には鮎が見えた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まア、大きいお魚、黒鯛ですわね」　おかあさんの声。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "７　朝起きたら、だいどころに、大きい黒鯛がかごのなかにありました。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田さんのおじさんは、黒鯛を昨日、船橋でおかいになって、それを僕の家に持って来て下さったのだそうです。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒鯛は、おかあさんがおやきになりました。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとうさんが、僕と静子に、「黒鯛」という題で作文を書いてごらんとおっしゃいました。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒鯛は大きい眼をしています。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「黒鯛っておさかな、にくらしくなったわ。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、黒鯛なんて、おさかなにおめにかかったのは、今朝がはじめてで、いままで絵でみたくらいなもので、たべたこともなかったのだもの‥‥」「健ちゃん待っててね、出来ても待っててね」「ああいいよ、そのかわり静子が出来たら待っているんだよ」　二人はかたく約束しました。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「黒鯛って寒いところのおさかなかしら」ときかれても僕はだまっていることにしました。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒鯛の潮汁旨しと雖ども、大船の艫に附て人の糞を喰ひし魚なり。",
              "citation": {
                "source": "肉食之説",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三浦は黒鯛に似た形の、暗紫色に黄味を帯びた二尺｜許の無名｜魚や「小判｜冠り」を釣つて大得意である。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "くろだい　くろだいはだれもいなくなっただいどころで、じっと大きい眼をあけていました。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "くろだいは、だいぶくたびれたので、眼をとじようとしましたが、ここは海の中ではないので、ねむることが出来ません。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねむるのにつごうのよい岩かげもないし、砂地も塩水もないので、くろだいは心ぼそくなりました。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "くろだいは、ふとんがほしいとおもいました。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "くろだいは、じっと耳をすませていました。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
