          "literary": [
            {
              "text": "高田は遂に男を組み伏せる。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（甚作は叫びながら逃げかゝるを、手先等は追ひまはして組み伏せる。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "物音に驚いた看守と雜役夫とがかけつけて漸く組み伏せるまで、若者は狂氣のやうに荒れ狂つた。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "物音に驚いた看守と雑役夫とがかけつけてようやく組み伏せるまで、若者は狂気のように荒れ狂った。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまに顔をだすと、たちまち、先生と追いつ追われつの活躍となり、しかし結局先生を組み伏せるのは私の方であるし、当人の身にもツライことで、たのしいものではない。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛び込んで行っては組み伏せる。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「神妙にせえ」「あツ」　必死に爭ふのを、巧みにあしらつて、組み伏せると、何んな合圖があつたものか、御用の提灯を振り翳して、宙を飛んで來たガラツ八。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "人肌地藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "「神妙にせえ」「あッ」　必死に争うのを、巧みにあしらって、組み伏せると、どんな合図があったものか、御用の提灯を振り翳して、宙を飛んで来たガラッ八。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人肌地蔵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
