    "definitions": [
      {
        "index": 1,
        "gloss": "class (of students)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その時その林檎と、果実商組合とは何の関係もない。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうにも、かなわないので、真正面から取り組んでしまった。",
              "citation": {
                "source": "緒方氏を殺した者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿命と言い、縁と言い、こんな言葉を使うと、またあのヒステリックな科学派、または「必然組」が、とがめ立てするでしょうが、もうこんどは私もおびえない事にしています。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もまたヴァイオリンよりヴァイオリンケエスを気にする組ゆえ、馬場の精神や技倆より、彼の風姿や冗談に魅せられたのだというような気もする。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "太宰は坊主頭のうしろへ両手を組んで、「言葉はどうでもよいのです。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "植木が好きで、學校のぐるりに樣々の植木を、優雅に配置し、ときどき、ひとり、兩手をうしろに組んで、その植木の間を、ゆつくり縫つて歩いてゐた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その料理屋に於いて、この佳き日一日に挙行せられた結婚式は、三百組を越えたという。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "表現方法を考慮しては、自分で自分の個性的な情緒とみえるもの、即ち自分の抽象情緒を組立てることが近代的諸作家のやつたことなのである。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これも未来の立派な政治家ですな」　校長は背ろ手を組んで、同意の笑を満面に湛えてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ彼女は、彼等のともすれば冷化さうな竹山仕打組の中間勢力を保たせるために必要な女として、最早解雇されて十日近くになるのに、未だにみんなに揉み廻されて日を送つてゐるのである。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は皆、その中では真剣になつて人生と取組み合ひ全力を出しきつて文学と四つ角力をとつてるのに、詩や俳句を作る時は、乙に気取つた他所行きの風流気を出し、小手先の遊び芸として、綺麗事に戯むれてゐるといふ感じがする。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の子供たちの悦ぶ玩具は、物理學を應用した種々の機械類の模型であり、飛行機や、電信機や、潛水艦やのメカニカルな組立玩具である。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『足を蹈んだのは僕が惡かつた、惡かつたから謝罪る、ねえ君、これは僅かだけれど膏藥代に、な、納めて呉れ玉へ、さあ』對手の心事、酒代にありと見て取つた若紳士は、事の組し易きを喜んで、手早く握つた銀貨、二枚、三枚、光る物手をすべつて男の掌に移るよと見る間に「呵」と叫んで紳士は身を轉換した。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その朝は早々起きて物置の二階から祭壇を下ろし煤を払い雑巾をかけて壇を組みたてようとすると、さて板がそりかえっていてなかなか思うようにならぬのをようやくたたき込む。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車の往来が織るような街の両側の人道の並木の下には手を組んだ男女の群が楽しそうに通っている。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙の右半はそれだけであとは空白であるが、左半の方にはややゴタゴタ入り組んだ街路がかいてある。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "美々しい回しをつけた力士が堂々としてにらみ合っていざ組もうとすると、衛士だか行司だかが飛び出して来て引き分け引き止める。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ森閑として、読者は、思わずこの世のくらしの侘びしさに身ぶるいをする、という様な仕組みになっていた。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのこと、ありのままに山岸へ告げたところ、山岸しさいらしく腕組み、「君、それが惡い。",
              "citation": {
                "source": "先生三人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と何の事やら、わけのわからんやうな事を悟り澄ましたみたいな口調で言ひ、兩腕をうしろに組み、ひとり家を出て、あちらこちら海岸を逍遙し、苅薦の亂れ出づ見ゆ海人の釣船　などと、れいの風流めいた詩句の斷片を口ずさみ、「人は、なぜお互ひ批評し合はなければ、生きて行けないのだらう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "取組を、四、五番見ましたが、あまり、わかりませんでした。",
              "citation": {
                "source": "國技館",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本當に怒つて取組んだら、誰にも負けないだらうと思ひました。",
              "citation": {
                "source": "國技館",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "用事があつたので、照國、五ツ島の取組を見て、それだけで歸りました。",
              "citation": {
                "source": "國技館",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四、五番を見ただけですから、自信を以ては言へませんけれど、力士の取組に、「武技」といふよりは、「藝技」のはうを、多く感じました。",
              "citation": {
                "source": "國技館",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀明水に達したるは午後七時に垂んとす、浅間社前の大石室に泊す、客は余を併せて四組七人、乾魚一枚、麩の味噌汁一杯、天保銭大の沢庵二切、晩餐の総べては是の如きのみ、葉マキ虫の葉を綴りて寝ぬる如く、一同皆｜蒲団に包まりて一睡す。",
              "citation": {
                "source": "霧の不二、月の不二",
                "author": "――明治三十六年八月七日御殿場口にて観察――",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を伸し合う針葉樹は、格子縞を、虚空に組み合せている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿屋の店頭には、かがり火をたき、白木の金剛杖をたばに組んで、縄でくくり、往来に突きだしてある。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの落葉松は、小御岳では風雪と引っ組んで、屈曲｜匍匐しているに似ず、亭々として高く、すらりと延び上っている自然のままの、気高さに打たれる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "石から石の上を飛びめぐる鶺鴒と筋交ひに、舟は両崖の迫つた間の急湍を、櫂を休めて悠々と乗つ切る、川には筏に組む材木が漂ひながら岩に堰かれてゐる、王子製紙会社の紙の原料で、中部の支社で、製するのだといふ。",
              "citation": {
                "source": "天竜川",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎坊附近の、黄紅朱樺の疎らな短木の中を、霧は幾筋にもなって、組んず、ほぐれつして、その尖端が愛鷹山の方向へと流れて行く、振り返れば、箱根｜火山彙には、雲が低く垂れて、乙女峠から金時山の腰へかけて、大河の逆流するばかり、山と山との間は、幾つにも朝雲が屯ろして、支流が虚空の方々に出来る。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
