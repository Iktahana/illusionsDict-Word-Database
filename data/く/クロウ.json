  {
    "uuid": "5a9b4b66-c17b-5e04-9586-e1b56ed231f6",
    "entry": "クロウ",
    "reading": {
      "primary": "クロウ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "crow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "フクロウは、たいこがないので、かわりに、自分のおなかをたたきました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "フクロウはたいこをたたき、コオロギは口笛を吹き、黒いキリギリスはハーモニカを吹き鳴らしました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、あたしがオンドリだったら、そんなメンドリは、けいべつしてやるわ」　ニワトリたちのいるすぐ上に、フクロウのおかあさんが、だんなさんと子供たちといっしょに、すわっていました。",
              "citation": {
                "source": "ほんとにそのとおり！",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "フクロウのおかあさんは、羽をばたばたさせながら、言いました。",
              "citation": {
                "source": "ほんとにそのとおり！",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "メンドリのくせに、自分が、メンドリであることを忘れてしまってね、自分の羽をみんなむしりとって、オンドリの気をひこうっていうんですからね」「プルネー　ギャルド　オー　ザンファン（子供たちに、気をおつけ）」と、フクロウのおとうさんが、フランス語で言いました。",
              "citation": {
                "source": "ほんとにそのとおり！",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな話は、子供にはよくないからね」「でも、おむかいの、フクロウさんには話してやりましょう。",
              "citation": {
                "source": "ほんとにそのとおり！",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人は、だれとおつきあいしても、評判のいいひとですからね」こう言って、フクロウのおかあさんは飛んでいきました。",
              "citation": {
                "source": "ほんとにそのとおり！",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ホー、ホー、ホホー」と、二羽のフクロウは鳴きながら、おむかいの、ハト小屋にいる、ハトにむかって言いました。",
              "citation": {
                "source": "ほんとにそのとおり！",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "フクロウだけは、まだ、巣にかえっていませんでした。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大丈夫、フクロウだよ」　フクロウって、ヘビを食べるんじゃなかったかな。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "バックロウは、奥から、令子、いまはいないが義晴、山崎の順に腰をおろしている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "――物語は、佳境の頂上で、勇士セント・アンドリウが、キクロウプスの館に幽閉された美姫ヘレナを救け出す為に翼のあるゼブラに打ちまたがつて、城内深く躍り込んだ三色版の挿絵のある頁が開かれて、私はその上に突つ伏して涎を垂らしてゐた時であつた。",
              "citation": {
                "source": "鬼の門",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして傍らの「ヒストリイ・オヴ・デビルズ」の辞書は、「キクロウプス――古代ギリシヤ、ユーリピデスの悲歌に、はじめて引用されたる怪物の名称なるも、起原は、地中海に出没せるカレドニアの海賊の間に信仰されたるデモーネンの謂なり。",
              "citation": {
                "source": "鬼の門",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この怪物は、巨大な頭の眉間に向日葵のやうな爛々たる一個の目玉を有し、良民にはその姿を識別すること能はざれども、海賊のためには、その眼球の輝きが道知る術の役立をなすと信ぜられ、当時の海賊船の一室にはキクロウプスの偶像が恭々しく飾られたりと伝ふ。",
              "citation": {
                "source": "鬼の門",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "（私は、はじめ、たゞこの薄暗い部屋の中で、息苦しい孤独の演技に耽りながら、あはよくば、声だけ立てゝ、屋上のキクロウプスを驚ろかせてやらう――位ゐのつもりだつたのに！",
              "citation": {
                "source": "鬼の門",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "真実私の耳には、キクロウプスの口笛を想はせられる陰々たる吹雪の音が響くのであつた。",
              "citation": {
                "source": "鬼の門",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "クロウバが生ひ繁つてゐる初夏の丘の芝生である。",
              "citation": {
                "source": "競馬の日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "コトニヨルト、我国ニハ「シロウトハクロウトヲ支配ス」トイウ法則ガアルノデハナイカト思ウガマダ調ベテモミナイ。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "カソリック詩人のポール・クロウデルも、日本に来たときは、お濠の石垣を詩につくったし、日本の柳、三味線、徳川時代の服装の女を配した夢幻劇をつくった。",
              "citation": {
                "source": "中国に於ける二人のアメリカ婦人",
                "author": "――アグネス・スメドレーとパァル・バック――",
                "note": "青空文庫"
              }
            },
            {
              "text": "名の示すごとく養老院で、収容者のなかで手の動くものは何かの手工芸をして一週間一クロウネずつ貰う。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "一クロウネは約わが半円である。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らにとって一週一クロウネはどんなにか待たれる享楽であり贅沢であろう！",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちいさな田園に小さな家が建っていて、一季節四百クロウネで夏のあいだ労働者の避暑に貸す。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧富にかかわらず一日二クロウネ半が、手術から医薬から看護から間代食費まですべてをふくむ入院料だという。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茶一杯一クロウネ十四オウル。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく、「バクロウが牛の掘り出しものでもさがすように」新人が売り出された。",
              "citation": {
                "source": "しかし昔にはかえらない",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「バクロウが牛の掘りだしものをさがすように」ジャーナリズムに見つけ出され、製造された新人の多くが、本質的に新しい文学を創る力をもつものでなかったことを、火野葦平はむしろ、欣然として認めている。",
