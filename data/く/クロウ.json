[
  {
    "uuid": "95883929-ed71-5836-980f-705226b9557d",
    "entry": "苦労",
    "reading": {
      "primary": "くろう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "trouble",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "所でラヴェルなんてバッハが見たら苦労性なデコラトゥールだ。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで萩原氏は文学的苦労人である。",
              "citation": {
                "source": "萩原朔太郎評論集　無からの抗争",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくてこそ、かの成巧者達が、大抵頸の硬い中庸主義者であり、殆んど理論なくカンでばかり体験し、苦労を咬み殺した人達であることが分ります。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の苦労もないから外見的には陽気でさへある。",
              "citation": {
                "source": "非文学的文士",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "之に反して、貧しき境遇にあるもの、生れながらによきキリストの血を受けて長く苦労せる人人の心には、自然とやさしい人情の種が蒔かれて居た。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "描写が下手だから苦労するのである。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉より他になかったとしたなら、この全体主義哲学は、その認識論に於いて、たいへん苦労をしなければなるまい。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "権威ある批評をしようと思ったら、まず、ご自分でも或る程度まで製作の苦労をなめてみる事ですね。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活の苦労にもまれて来た顔である。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と私が笑いながら言ったら、「やあ、このたびは御苦労。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の頃に苦労して、それがその人のために悪い結果になつたといふ例は聞かない。",
              "citation": {
                "source": "純真",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな「臆病な苦労」をしています。",
              "citation": {
                "source": "自信の無さ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦労性の妻君が余りに赤坊の泣き声が変なので庭を横切つて来てそこから覗いてゐる所だつた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうせ、安つぽいお調子屋ばかりの感情家ばかりの世の中だからそれ程苦労性にならなくつたつて。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は往診して他人といふ無責任な人達にもてなされて帰つて来ると苦労性な皆が不快だつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だつてね、太つたくせに顔の陰が尖るつて質の女は一度ツンとすると其の後はもう理由もなしにツンとし通すものだから……」「こいつ大した苦労性だな、気の小さい……」　夕方行くとＳ子は最も他人行儀を示した。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "病院から引取って形ばかりでも葬式をすませ、妹と姪とを自宅に引取るまでの苦労を今更のように思い浮べてみる。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の頃に苦労して、それがその人のために悪い結果になったという例は聞かない。",
              "citation": {
                "source": "純真",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬまで車を引っ張る馬のように、死ぬまで苦労を背負わせるんだ。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は尺に近い赤魚を、サンザン苦労して引つ張り上げ、魚籠に入れる直前に落した。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦労してゐるんだからね、お前たちも贅沢を云つてはいけないよ」　と、ふだんから云つてあるのだ。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし間もなくそれが常習的年中行事となると、今度はそれが大きな苦労の種となった。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、少数の学者や自分のような苦労症の人間がいくら骨を折って警告を与えてみたところで、国民一般も政府の当局者も決して問題にはしない、というのが、一つの事実であり、これが人間界の自然方則であるように見える。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "颱風災害防止研究機関の設立は喜ぶべき事であるが、もしも設立者の要求に科学的な理解が伴っていないとすると研究を引受ける方の学者達は後日大変な迷惑をすることになりはしないかという取越苦労を感じないわけには行かないようである。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはあまりの取越苦労かも知れぬが、とにかく灯火の色という事は実用上重要で研究すべき問題だと思う。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "市会議員の舌の鳴物入りの忠言なんかはこの道で苦労している彼等には真面目に対手になってはいられなかった。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かんこちりめんといふ、これは苦労して働いた家刀自の愛のやうな感じのちりめんで、やはりその頃母の古着のなかにあつたやうに覚えてます。",
              "citation": {
                "source": "縮緬のこころ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "重ね重ねの母胎の苦労である。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどい苦労は確にしたのだな」　それに凝りずに、娘はなおも苦労を迎えてそれを支えた成長の肋骨を増やす積りでいる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那経済恐慌の主因をつくった英国の政策が、上海英国財閥の没落の過程をつくろうとは。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
