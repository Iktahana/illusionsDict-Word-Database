[
  {
    "uuid": "05c3557c-0f29-500b-8f6a-d1376e01c667",
    "entry": "狂い",
    "reading": {
      "primary": "くるい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
