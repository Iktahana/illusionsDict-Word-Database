    "definitions": [
      {
        "index": 1,
        "gloss": "Pacific island flatsedge (Cyperus cyperoides)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これは岩崎灌園の著『本草図譜』巻之七にその図が出て、灌園はそれを「水莎草（救荒本草　磚子苗注）水生のかやつりぐさなり苗葉三稜に似て陸生［牧野いう、陸生の意味分らぬ］より長大なり高さ三四尺武州不忍の池に多し」と書いている。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場のガードをくぐつて坂を登ると、暗い煤ぼけた古道具や、安物の足袋など店に竝べた、昔の宿場そつくりの町がある。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "君たちは、たったいま、一の鳥居をくぐっただけだ」「ちぇっ！",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は汗を拭い、ちょっと威容を正して門をくぐり、猛犬はいないかと四方八方に気をくばりながら玄関の呼鈴を押した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『喧嘩だ、喧嘩だ、』背中を突かれて驚く男、袂をくぐられて間誤付く女、跳ね飛ばされて泣くは子供、足下を攫はれて轉ぶが年寄、呆氣に取られた人人の間を縫て、矢の樣に走つて行く一人の男。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "煤の埃の中にして捨松ここに思ふ樣老店の主人三代の暖簾をくぐる町人は幾度同じ夢を見て繰り返したる榮落に街の繁華は見たるなり。",
              "citation": {
                "source": "煤掃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬はどっちへ行こうかと云う風で立止っていると、女の子は馬の腹をくぐって前へまわってまたダーダーと云いながら新屋敷の方へ引いて行った。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島は龜の甲羅から降りて、龜に案内をせられ、小腰をかがめてその正門をくぐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由な空へ出るのには一度罎の底をくぐらなければならないという事が蠅にも小さな私にも分らないと見える。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の隧道を抜けていよいよ上高地の関門をくぐったとき一番に自分の眼に映じた美しい見ものは、昔から写真でお馴染の大正池の眺めではなくて、恰度その時雲の霽間にその全貌を現わした焼岳の姿と色彩とであった。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを「潜る」という語を聯想して「くぐ」と読んでおりますが、これは「くく」で濁らないのです。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、ただ一台だけが防禦の網をくぐって市の上空をかけ廻ったとする。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは迷路のように曲折しながら、石畳のある坂を下に降りたり、二階の張り出した出窓の影で、暗く隧道になった路をくぐったりした。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹が涙で眼を光らして、Ｔ「隣り村へお嫁に　行くぐらいなら」　と言って、Ｔ「いっそ天狗様に　喰われて　死んだ方が倖せです」　と言う。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、燃え擴がつてゆく廊下と競ひ、彼のはうに熱くなつて倒れてくる扉をくぐり拔け、彼を焦がさうとする階段を過ぎり、漸くにしてその狂ひに狂へる建物から逃れ出た。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳独秀が呉松路通インタナショナル理髪館で変装して上海の共同租界から各国兵の監視をくぐってオランダ船で逃れた当日は、彼は失業工人の一団を率いて特別戒厳令のなかに潜伏していた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてサイレンが鳴りやむと、夜の急行列車が都会のアーチの門をくぐるように動きだした。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居裏の二枚看板、ちゃちなぽん引にうっかりつれこまれようとして、あわてて羽織｜芸妓の裾のもとをかいくぐって、食傷路地に出てくると、鶴源の板前が瑪瑙色に塗った魚類の食楽地獄だ。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "割引電車の青い労働帽の炎のような太陽が燃えて、世が明けわたると、半開のビルデングの鎧戸を汚れた袴をはいた女事務員がくぐり、表情の失せた勤め人たちが、破れたわい襯衣から栄養不良の皮膚をのぞかせて鏡のように磨かれた石造の建物に吸いこまれた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていつとなく青木さん夫婦は、かつては夢にも想像しなかつた質屋の暖廉くぐりさへ度重ねずにはゐられなくなつてしまつた。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もしない者、何も知らない」　危険をくぐってやる仕事にかけては、俺の方がうわ手だ。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからおもむろに、支那人の手によって、国境をくぐりぬけ、サヴエート国内へもぐりこんで行った。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、毎晩、その下をくぐりぬけ、氷で辷りそうな道を横切って、ある窓の下に立ったのであった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "慄悍な動物は、弾丸をくぐって直ちに、人に迫って来る。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、鉄条網をくぐりぬけ、窓の下へしのびよった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵舎の樋から落ちた水は、枯れた芝生の間をくぐって、谷間へ小さな急流をなして流れていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関から狭い廊下をくぐって案内された座席は舞台の真正面であった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちもうあっちでもこっちでもその黒いつるつるした変なものが水から飛び出して円く飛んでまた頭から水へくぐるのがたくさん見えて来ました。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんたうにそのいるかのかたちの〔〕おかしいこと二つのひれを丁度両手をさげて不動の姿勢をとったやうな風にして水の中から飛び出して来てうやうや〔しく〕頭を下にして不動の姿勢のまゝまた水の中へくぐって行くのでした。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "門をくぐると左側に花屋があった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
