[
  {
    "uuid": "c72d3683-feb6-5407-9a31-e0bb5f8bab1b",
    "entry": "口に上る",
    "reading": {
      "primary": "くちにのぼる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
