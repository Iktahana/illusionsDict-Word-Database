        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれども、僕は生きて行かなくちゃいけないのです。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、俺は、奴の鼻に行かなくちゃいけない。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "星になるには、それ相応の身分でなくちゃいかん。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ね、そら、あの鉄砲打ちの小さな変な人ね、そしてね、『おい、こんどはも少しよく、粉にして来なくちゃいかんぞ。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが病気のけだものは死んだら棄てなくちゃいけないでしょう。",
              "citation": {
                "source": "バキチの仕事",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう進軍をやめなくちゃいかん。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでね、僕は少し向うへ行かなくちゃいけないから今日はこれでお別れしよう。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、しっかり談判しなくちゃいけないと考えて耕一はどきっとしました。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時僕たちにかけられたら花がみんな散ってしまってまるで実にならないだろう、だから前は本当にこわがったんだ、僕たちだってわざとするんじゃない、どうしてもその頃かけなくちゃいかないからかけるんだ、もう三四日たてばきっと又そうなるよ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうきっとその辺にさえ居れや、空へ騰って行かなくちゃいけないような気がするんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "では今日の所は、私からよくお客さまにお詫を申しあげて置くから、これからよく気をつけなくちゃいけないよ。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと正々堂々とやらなくちゃいけない。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活能力のない落伍者のことまであたしたちはいちいち考えなくちゃいけないの」「みんな同じ日本人じゃないか」「だって……」　と、宮子は鶴雄のむきになるのが面白いらしく、「――ひとのことは放って置いたらどう……？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日小隊長は腹部に激痛を訴えたので、驚いた婆さんは灸を据えたが、医者は診て、こりゃ盲腸だ、冷やさなくちゃいけないのに温める奴があるかと、散々だった。",
              "citation": {
                "source": "電報",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『男には、とりわけ紳士と云う奴には気をつけなくちゃいけないよ。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこし、休まなくちゃいけない」　こう言いながら、ヨハンネスは、そこにひざまずき、手を合せて、夜のお祈りをとなえました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしたって、今度は僕が書かなくちゃいけないんだ。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは、きょうは、寝ていなくちゃいけませんよ。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「おまえは今から心がけて人生の本ものの味わいを味わわなくちゃいかん」と口癖にいった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「しかし、多少は知っていなくちゃいけないね。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「行かなくちゃいけない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐伯に返さなくちゃいけないんだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界的な文豪を以て任じている人は、それくらいのところが無くちゃいけない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の子は、こうでなくちゃいけない、と変なほめかたをした。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（伝兵衛）　殴らなくちゃいけねえ。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "正気にかえるまで殴らなくちゃいけねえ。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
