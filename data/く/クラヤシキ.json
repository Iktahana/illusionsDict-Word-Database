    "definitions": [
      {
        "index": 1,
        "gloss": "daimyo's city storehouse",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
