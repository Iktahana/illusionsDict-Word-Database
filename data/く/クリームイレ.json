        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "壁のむこうで、ざわめく音や話し声が聞えていたが、扉があいて従僕が盆に空のコップやクリーム入れやラスクの籠をのせて出て来た時には、それが急にはっきりと聞こえだした。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "白光と毒素　女給はクリーム入れましょうかとたずねる。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンド・バッグが二個、一つは鰐革、一つはエナメル、開けて見ると立派なコンパクトやらクリーム入れやら、女の持つものがぎっしり詰っている、私はガタガタ慄るえて、どうにもふるえが止りません。",
              "citation": {
                "source": "魂の喘ぎ",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペン皿には御存知の赤い丸い球のクリーム入れがあって、太郎が二階へ来ると、私はいそいでそれをかくすの。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
