[
  {
    "uuid": "c94deafd-a617-5d83-ae75-ce05ab105a4e",
    "entry": "汲み取り",
    "reading": {
      "primary": "くみとり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
