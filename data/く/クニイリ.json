    "definitions": [
      {
        "index": 1,
        "gloss": "visiting one's constituency",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
