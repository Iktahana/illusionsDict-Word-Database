        "examples": {
          "standard": [
            {
              "text": "高温下では金属材料のクリープ現象が顕著になるため、設計には注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長期間荷重がかかる構造物では、クリープによる変形を考慮しなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このプラスチックは、わずかな力でも時間をかけるとクリープを起こしやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 2,
        "gloss": "creep (of an automatic-transmission vehicle)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
