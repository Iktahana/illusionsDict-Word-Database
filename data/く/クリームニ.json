    "definitions": [
      {
        "index": 1,
        "gloss": "food simmered in cream",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "渡辺篤を誘って、アラスカで夕食、トマトのポタアジュと、チキンクリーム煮にコーン・フリッター。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "小石川の三井邸のすっぽんのクリーム煮も忘れない、礼儀正しいフランス料理だった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時、ビクターへ行ったが吹込室がノびてゐるので、大洋食堂で、ポークチャップとオムレツに、チキンクリーム煮を平げて「軽い食事を終った」と言ったら、鈴木静一がトタンにくさった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "終ってニューグランドへ行き、トマトクリームスープに、チキンとヌードルのクリーム煮、それにアイスコーヒーとプディング。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "名物食堂のデンツーで、鶏のクリーム煮とスパゲティ食べて座へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊勢蝦のチーズ焼、鳥のクリーム煮、次にパンケーキ・スゼットでおしまひ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房同道十一時に出て、教文館の富士アイスで食事、チキンクリーム煮入りのホットケーキといふのは大ゲテ物。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロブスタークリーム煮うまかった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "チキン・クリーム煮。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅の液をアイスクリームにする事も出来ましょうか」お登和嬢「ハイ出来ますとも、アイスクリームといえばモー出来ていますから持て参ります。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "十分間ごとにこうして中を攪き廻すと一時間以上過ぎた時分大概は中が固まってアイスクリームになっています。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでモット上等のアイスクリームにするのはどう致します」お登和嬢「そうですね。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスクリームには色々の香料を入れたのがありますね。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしもアイスクリームが人であったら生意気な娘はその五銭のアイスクリームに恋愛するかもしれない。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、壁はクリームになり、カーテンはピンクになり、デンキスタンドのシェードに、姉はみどり、私はうすねずみ色に花のとんだのを母は与えてくれた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十八歳まで生きて来て、そう、アイス・クリームになってこの世を去りますのも、みな神様の思召でございます。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "南風吹かば　――モンテ・カルロの巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こら、クリームに蓋をせんか。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミルクと一緒に穏やかに沸騰させて濃い糊状にすると、前もってミルクで薄めたクリームに、決して不味ではなくクリームの味を邪魔することはない硬さも表面的な豊かさを、与えるからである。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "この混合物は完全に冷やすとクリームに混ぜる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶さじ１杯のこの混ぜ物処理をしたクリームに数滴のヨードのアルコール溶液を入れると、瞬間的に濃い紺色になり、この詐欺を検出することができる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方への尊敬をもって、トマス・リディアード　どんなセンスまたは分別を持った人が、プディングやクリームにそんなに危険な成分を混ぜる無知な料理人の判断を信用するのだろうか？",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランドリュはマダム・クゥシェの家へ自由に出入りするようになると、財産収得に邪魔なアンドレェを先に片付けることにし、グラン・ブゥルヴァールのキャフェに呼びだして、アガール糖内で培養した肺炎菌を生クリームにまぜて食わした。",
              "citation": {
                "source": "青髯二百八十三人の妻",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "自転車に赤い旗を立てて、「エー、アンパンに食パン」「牛乳にサイダー」「アイスクリームにキャンディー」　と、さながら映画館の一回の終わりのようだ。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃は二円のクリームに三円八十銭の不用な香水をつけて買わされるのだから、ひとの境遇にも同じようなことが起って、わたしだって巣鴨へ便利で市内で、電話があって、余り危険でないという住場所の必要のために、此だけの辛棒しているのだから、あなたもそう思いなさい、と。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鉋の上で一塊の氷を前後に動かすと、下にある皿が、いわば鉋屑ともいう可きものを受け、それに砂糖少量を加え、粉茶で香をつけるのだが、非常に涼味ある小菓で、我々が子供の時雪でつくった、アイスクリームに近いものである。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "「外側はふいた様に綺麗になっているがね、ソラ御覧、中のクリームに、こんな完全な指の跡がついているから」　明智はそういって、いたずら小僧みたいなズル相な表情をした。",
              "citation": {
                "source": "一寸法師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "（だからシュウクリームにチョコレートを附けた、エクレールとは全然違う）　丁度同じ時代に、東京市内には、パンじゅう屋というものが、方々に出来た。",
              "citation": {
                "source": "甘話休題",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "バアでマンハッタンをのみ、食堂へ、ポタアジュ、コールドラブスター、肉に七面鳥、アイスクリームにウイスキソーダ一杯のみ、いゝ心持になり、自動車で宿へ帰ると又入浴。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
