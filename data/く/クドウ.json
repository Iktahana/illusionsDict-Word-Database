    "definitions": [
      {
        "index": 1,
        "gloss": "ward road",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「あいにくどうも、お相手を申上げる者がいないので。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "焚火焚火、人々は手足の関節から、血の循環が一秒一秒止まったように、意識された、今凍えて行くのだということも解る、早くどうかしろと神経が知らせてくれる、誰の顔を見ても、蝋のように白い、マッチ箱は燐寸一本さえ、烟を立てることなしに、空になったほど、何もかも、ビショ濡れになった。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹はゆさゆさとゆすれ大へんにむしあつくどうやら雨が降って来そうなのでした。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お早くどうか願ひます。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お早くどうか願います。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜はもうぼくどうしても探そうとおもって羊飼のミーロと二人で出て来たんだ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全くどうも私がいけなかったのです。",
              "citation": {
                "source": "葡萄水",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全くどうも相済みません。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、斯う世の中が乱れては全くどうも仕方ありません。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "気が着けば、あの、かくれ滝の音は遠くどうどうと鳴って、風のごとくに響くが、掠れるほどの糸の音も乱れず、唇を合すばかりの唄も遮られず、嵐の下の虫の声。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へい、大きに――」　まったくどうものんびりとしたものだ。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "定重　　くどうも申すやうなれど、お家を大事と思召されて……。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日々々のらくらしているばかりで何一つ為事らしいものも持ってはいなかったが、それでも立派な法学士で――そんな肩書なぞは全くどうでもいいのだが――兎に角三十歳近い大人であった。",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "この邊の奴らにつきあひもなくどうせろくでもない　貝肉の化物ぐらゐに見えるだらうよ。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くどうにかして下さい。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったくどうしてかな？",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのごくどうめが」「おじさん、そいでもね、まちがえて持ってきたんだってよ。",
              "citation": {
                "source": "うた時計",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやさ、七くどう云う事はない、何で俺が門を窺うた。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女学校を出て既に三四年もたち、自分の体を早くどうにか片付けなければならない大事な時期だというのに、弟のお守りなんかに日を送っていることはつらかった。",
              "citation": {
                "source": "晩春",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっととにかくどうにか収まったらしいが、そちこちの形勢がまだ蜜蜂の函の穏かならぬ呟きをひそめていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」前川は、秘密の核心を衝かれたように、憂鬱な顔になって、「しかし、こんなに早くどうしてあの店が分ったんでしょう。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実は全くどうだかわからない、ただ以上のような場合が今後にもありうるものとすれば、私は多くの善良な象のためにまたその善良な飼養者のために、これだけの事を参考のために書いておくのもむだな事ではあるまいと思ったのである。",
              "citation": {
                "source": "解かれた象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はもう全くどうしていいかわからなかった。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとは傷が多くどうも埃っぽいし、染みもいくつかある。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから全員で階段を昇り、部屋に入って、扉の裏にかけてあった化粧着を見ましたので、台をひっくり返してしばらくどうにか注意を引きつけておいて、僕はこっそり戻り、懐を探りました。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったくどうしてこんな真似を！",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直者のシュタイラーは追伸で、婦人はスイス人医者の診察を頑として拒むので、私に受けてもらえるならたいへんありがたいこと、そして自分の責任が重くどうにも参っている旨が言い添えてあった。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ああ、）　それ覗くまでもなく、立ったままで、……今暗がりへ入った、も一人の後を軒下にこう透しながら、（しばらくどうぞ。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして遠い処をわざわざおいで下さるにも及ばんでした、貴方御苦労でしたな、宜しくどうぞ、ちとこれから出懸けんければならんですから。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに結論を急ぐなかれ、死ぬとも生きるとも早くどうにかきめてもらいたいというのは凡夫のいう事に候う。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
