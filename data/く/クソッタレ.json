        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "気が立ってくると、糞ったればばあ、とぬかすんですよ。",
              "citation": {
                "source": "山吹の花",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「糞ったれどもめ、あいつらは確かに食いますよ。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "シュローダーにそう言ったら、彼は、「このクールな糞ったれめ！",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "糞ったれの地獄で我々が味わう以上に恐ろしいものだろうぜ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを説明する前に、悪いがこれらの糞ったれたトラックをどけて、ザクースカをどこかにやってくれないか？",
              "citation": {
                "source": "西洋科学は素晴らしい",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本当に何がやりたいのか、魂の声に耳を傾けろ」　倒れ続けるくそったれドミノどもは、繰り返しオレにそうささやくのだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "くそったれた奴が――――――何かをこっそり用意してやがったみてえじゃねえか。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "くそったれ野郎のメイザーは誰かがこの忌々しい単調性の檻から飛び出し遂せるのを恐れていたんだ――誰か彼奴に呪いをかけるか、夜、血でも啜るかしてくれたらいいのにな！",
              "citation": {
                "source": "ピックマンのモデル",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんでえ女なんか、女なんか相手にするかえ、喧嘩は男と男でするもんだ、なにいってやんでえ」「くそったれあまア」　小さい子供の一人が、こう悪態をつくなり逃げだした。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ざまあみやがれ、くそったれあまア」三　半次はおちづの手を振り放し、掴まれていた腕を撫でながら、さもいまいましそうに唾を吐いた。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たんと駄々をいうて、この年老った母を困らせるがよいわ」「困らしてやるとも、くそったれ婆め、鬼婆め！",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "くそったれの新聞売り子め。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
