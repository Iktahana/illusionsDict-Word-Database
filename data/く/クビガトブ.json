        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "臙脂屋のじじい、それ、おのれの首が飛ぶぞ、用心せい、そもそも我等の企と申すのはナ」と云いかけて、主人の面をグッと睨む。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大井の小路と云う小路には夜よる馬の首が飛ぶように走っていた。",
              "citation": {
                "source": "鷲",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様の首が飛ぶんだぞ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鷹のゆくえ",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間に洩れたら貴様たちの首が飛ぶぞ」　ふたりは土に頭を摺りつけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鷹のゆくえ",
                "note": "青空文庫"
              }
            },
            {
              "text": "なめたまねしやがると首が飛ぶぞ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "気をつけてものをいわねえと首が飛ぶぞッ」「は……？",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "控えろ、町人、首が飛ぶぞ、とでも叱って来るんでございますか」「にぶい奴じゃな。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ十両以上の金高になれば首が飛ぶという時代ですから、悪い奴も自然こそこそが多かったんですね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "仮面",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも軽い罪ならば格別、ひとつ間違えば自分の首が飛ぶというような重罪が発覚したかと思うと、大抵の素人はぼうっとなってしまって、早くいえば酒に酔ったようになって、なんにも云えなくなってしまうのです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三つの声",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時、下手まごつくと首が飛ぶし、それかというて、後込みしとると一揆からひどい目にあうしのう。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、どんなに遅くても二、三日じゃ」「首が飛ぶのがかい」　小助は、蒼白い顔に苦笑をもらしながら、そういった。",
              "citation": {
                "source": "乱世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "外聞だの刑期だのという問題ではなく、すんでのことに、この首が飛ぶところであったのだ。",
              "citation": {
                "source": "ピストルの蠱惑",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "御領主にも関係しているらしい一大事なんて、吉かれ凶かれそうした事件に掛り合っては、まかり間違えば実際首が飛ぶ。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "首が飛ぶかも知れないのに……」「殺人強盗の中にはアンナ性格の奴が時々居るもんだよ。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たわ言を並べおるうちに、首が飛ぶぞ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ほ、ほ、首が飛ぶは、怖ろしいに相違ありませぬが、はだしにては、下に下りられませぬ」「黙れ！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同は、急に不安に襲われ、帆村より先に、前室へ逃げだそうとしたが、そこを動けば、また自分の首が飛ぶのじゃないかという恐れから、どうしていいか分らず、結局その場にへたへたと坐りこんでしまった。",
              "citation": {
                "source": "鬼仏洞事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "迂濶にいうと首が飛ぶ。",
              "citation": {
                "source": "紅白縮緬組",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」同じく――これは東検島へ根拠地を移してのちの記事なのだが――「人々は我々一行の不成功を悲しみ、酒を飲んだ後なぞは、陸上だったら首が飛ぶような摂政攻撃に、花を咲かせた。",
              "citation": {
                "source": "撥陵遠征隊",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互いさま、いつ首が飛ぶか知れない身の上なんだから考えてみると、おとなしくしているだけ損なわけさね」　与吉は、ことばより先に、大きく頭上に両手を振りみだして、「チョッ！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "首が飛ぶ……と思うと、与吉は、このままわらじをはいて、遠く江戸をずらかりたかったが、そうもいかない。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "眞直ぐに申上げないと、お前達二人とも殺しの卷添へで、ガン首が飛ぶぞ」　こんな時には、八五郎の方が遙かに睨みがきゝます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "女の足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "危なく首が飛ぶところさ」　八五郎がまた餘計なことを言ふのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "華魁崩れ",
                "note": "青空文庫"
              }
            },
            {
              "text": "二言といってみろ、首が飛ぶぞ。",
              "citation": {
                "source": "沓掛時次郎　三幕十場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "真っ直ぐに申上げないと、お前たち二人とも殺しの巻添えで、ガン首が飛ぶぞ」　こんな時には、八五郎の方が遥かに睨みがききます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "女の足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "「冗談じゃないぜ、今も社会部長から散々油を絞られて居たんだ、そんな馬鹿な事件に、『足の勇』のような向う見ずの男を出す法は無いってね、今請求すると首が飛ぶかも知れないぞ、お小遣位ならオレが出して置くよ。",
              "citation": {
                "source": "呪の金剛石",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「つまらねえ遠慮じゃないか、お前の首が飛ぶか飛ばないかの大事な岐れ目だよ」　口を出したのは、八五郎でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人違い殺人",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなら、自分が引取って世話をしてやろうか――いつ首が飛ぶか知れない身、なお危ない危ない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "壬生と島原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥棒なんざあ、お前さん、馬鹿のする仕事さ、人に隠れて、コッソリとやって、見つかれば首が飛ぶ、それでいくら儲かるもんだ、泥棒のかせぎ高なんて、知れたもんじゃないか」「ふふん……」と七兵衛が、それを聞いてそらうそぶきました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "みちりやの巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
