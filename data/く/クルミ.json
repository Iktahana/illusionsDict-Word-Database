        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうして、山榛の木、沢胡桃などが、悄然と、荒れ沢の中に散在している。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どこかで雨を避けておいで」　と返事をしたまま、私は魚を釣り続けてゐたのだが、堤には小さな胡桃の木以外には生えてゐなかつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄の方が、釣り竿を堤防の石垣の穴にさし込んどいて、「かうして屋根を葺くんだよ」　と云つて、堤の上に乾してあつた乾草を胡桃の枝に渡して、屋根を葺いてやつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄妹は五尺にも足らぬ胡桃の木の下に、二尺角位に乾し草の屋根を葺いて、その下に雫で背中を濡らしながら、木の幹を抱き、向き合つて跼んでゐた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「飴を塗った胡桃の串刺しはいかが？",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラジュウムの雁宮澤賢治青ざめた薄明穹の水底に少しばかりの星がまたたき出し、胡桃や桑の木は薄くらがりにそっと手をあげごく曖昧に祈ってゐる。",
              "citation": {
                "source": "ラジュウムの雁",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みづから塗れる伯林青の、　　むらをさびしく苦笑ひ、胡桃覆へる石屋根に、　　　　いまぞねむれと入り行きぬ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは通る人の運命を暴露して見せる路だ」　背負い枠の娘はもうその路をあるききって、葉の落ち尽した胡桃の枝のなかを歩いていた。",
              "citation": {
                "source": "闇の書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖の全景は、月宮よりして、幹紫に葉の碧なる、玉の枝より、金色の斧で伐つて擲つたる、偉なる胡桃の実の、割目に青い露を湛へたのであらう。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まつたく一寸胡桃に似て居る。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡桃と、飴煮の鮴の鉢、鮴とせん牛蒡の椀なんど、膳を前にした光景が目前にある。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "笛は、胡桃を割る駒鳥の声のごとく、山野に響く。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして氷豆腐や胡桃をうんと買いこんだ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡桃の実で肥やしたんじゃな！",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓢箪に宿る山雀、胡桃にふける友鳥……「いまはじめて相分った。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「文字ノ精ガ人間ノ眼ヲ喰イアラスコト、猶、蛆虫ガ胡桃ノ固キ殻ヲ穿チテ、中ノ実ヲ巧ニ喰イツクスガ如シ」と、ナブ・アヘ・エリバは、新しい粘土の備忘録に誌した。",
              "citation": {
                "source": "文字禍",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　胡桃の根附を、紺小倉のくたびれた帯へ挟んで、踞んで掌を合せたので、旅客も引入れられたように、夏帽を取って立直った。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "上丸、上々丸など稱へて胡桃いつもあり。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで喰べた胡桃の飴菓子。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏のすゑ、長月はじめ、あはれ、日も薄らうすらに、薄黄なる歎沁みゆく浮羅爛勤の広葉の青み、あるはまた大木の胡桃、憂愁のかげのふかみに、燃えのこる熱き日ざしは黄に透かし暮れて薫れる。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆腐イ……豆腐イ……　テウチ胡桃の淡紫の幹――坂をのぼりきりたるところより貯蔵庫（柑子類の植物を入れたる）の煉瓦壁見ゆ。",
              "citation": {
                "source": "春の暗示",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの老いた胡桃のこずゑにある。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の日胡桃の老木ながめつつ、けふも胡桃をわりゐたり。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡桃の梢の青空よ、ねもごろなれやいつまでも。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹白樺のはやしのなかに胡桃の木ひとり老いたり。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "なほ、本集の装幀に当つて、かの『篁』『月と胡桃』の時と同じく中山省三郎君の共力を得た事を感謝する。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆腐イ……豆腐イ……　テウテ胡桃の淡紫の幹――坂をのぼりきりたるところより貯蔵庫（柑子類の植物を入れたる）の煉瓦壁見ゆ。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五年前のことゝ記憶するが胡桃澤勘内君が松本から上京された際自分も折よく故人の宅で同君及び他の同人諸君と會合が出來た。",
              "citation": {
                "source": "記憶のまゝ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「尤も私達の所では、男の人が娘に取入らうとする時には、先づ最初に贈物をするのが普通だね、くるみか香料入りのパンか何か買つて来るのが。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」カムパネルラが、不思議さうに立ちどまって、岩から黒い細長いさきの尖ったくるみの実のやうなものをひろひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
