    "definitions": [
      {
        "index": 1,
        "gloss": "directly (from someone's mouth)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
