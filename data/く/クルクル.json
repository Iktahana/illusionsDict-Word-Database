    "definitions": [
      {
        "index": 1,
        "gloss": "whirling",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "バレリーナがステージの中央でくるくると華麗に回転し、観客を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "風車が海風を受けてくるくると回り、のどかな漁村の風景に彩りを添えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子供たちが手をつなぎ、くるくると回りながら楽しそうに歌を歌っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "」その男は立って、網棚から包みをおろして、手ばやくくるくると解きました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」鳥捕りは風呂敷を重ねて、またくるくると包んで紐でくくりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　窓の外の、まるで花火でいっぱいのやうな、あまの川のまん中に、黒い大きな建物が四棟ばかり立って、その一つの平屋根の上に、眼もさめるやうな、青宝玉と黄玉の大きな二つのすきとほった球が、輪になってしづかにくるくるとまはってゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の子はまるでパイを喰べるやうにもうそれを喰べてゐました、また折角剥いたそのきれいな皮も、くるくるコルク抜きのやうな形になって床へ落ちるまでの間にはすうっと　灰いろに光って蒸発してしまふのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」達二は、垣根のそばから、楊の枝を一本｜折り、青い皮をくるくる剥いで鞭を拵え、静に牛を追いながら、上の原への路をだんだんのぼって行きました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空がくるくるくるっと白く揺らぎ、草がバラッと一度に雫を払いました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五、六匹死んだ金魚は外に取り捨てられ、残った金魚はなまこの水鉢の中にくるくる輪をかいてまわっていた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき室内で大人はかんがへこんでゐた、大人の思想がくるくると渦まきをした、ある混み入つた思想のぢれんまが大人の心を痙攣させた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無氣味な風に吹き煽られて、入りまじりにくるくるらせられ、そしてそれから墜落し、しかも墜落しながら、また向きを變へて行きながら。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、牛部屋では、鞍をかけられた牛が、粉ひき臼をまわして、くるくる、真中の柱の周囲を廻っていた。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛は彼の背後をくるくる廻った。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　コーリヤは眼が鈴のように丸くって大きく、常にくるくる動めいている、そして顔にどっか尖ったところのある少年だった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "くるくる廻ってへたばらないやう御用心。",
              "citation": {
                "source": "電車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だまされたという人は大抵お酒に酔ったり、臆病でくるくるしたりした人です。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　窓の外の、まるで花火でいっぱいのような、あまの川のまん中に、黒い大きな建物が四｜棟ばかり立って、その一つの平屋根の上に、眼もさめるような、青宝玉と黄玉の大きな二つのすきとおった球が、輪になってしずかにくるくるとまわっていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の子はまるでパイを喰べるようにもうそれを喰べていました、また折角剥いたそのきれいな皮も、くるくるコルク抜きのような形になって床へ落ちるまでの間にはすうっと、灰いろに光って蒸発してしまうのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　一郎はせなかがシィンとしてまはりがくるくる青く見えました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たちが笛なんか吹かなくたって星はみんなくるくるまわるさ。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな芝居であったかほとんど記憶がないが、ただ「船弁慶」で知盛の幽霊が登場し、それがきらきらする薙刀を持って、くるくる回りながら進んだり退いたりしたその凄惨に美しい姿だけが明瞭に印象に残っている。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬が結局窓の日蔽幕に巻き込まれてくるくる回る、そうなると奇抜ではあるがいっこうにおかしくない。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "色白くふっくりふくれた丸ぽちゃの顔、おとがい二重、まつげ長くて、眠っているときの他には、いつもくるくるお道化ものらしく微笑んでいる真黒い目、眼鏡とってぱしぱし瞬きながら嗅ぐようにして雑誌を読んでいる顔、熊の子のように無心に見えて、愛くるしく思いました。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "芹川さんの兄さんとは、女学校に通っていたときには、毎朝毎夕挨拶を交して、兄さんは、いつでも、お店で、小僧さんたちと一緒に、くるくると小まめに立ち働いていました。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」葉藏は、おどけものらしく眼をくるくると丸くして言ふのである。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、どんな木の葉、草の葉でも、安雄さんの手でくるくるとまかれ、安雄さんのくちびるにあてると、ピイと鳴ることができたからです。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら」その男は立って、網棚から包みをおろして、手ばやくくるくると解きました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ね、そうでしょう」鳥捕りは風呂敷を重ねて、またくるくると包んで紐でくくりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれが名高いアルビレオの観測所です」　窓の外の、まるで花火でいっぱいのような、あまの川のまん中に、黒い大きな建物が四｜棟ばかり立って、その一つの平屋根の上に、眼もさめるような、青宝玉と黄玉の大きな二つのすきとおった球が、輪になってしずかにくるくるとまわっていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
