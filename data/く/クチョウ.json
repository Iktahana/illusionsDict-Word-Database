[
  {
    "uuid": "fc94d9b8-02c0-5d66-93f7-0a66aa83751c",
    "entry": "区長",
    "reading": {
      "primary": "くちょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
