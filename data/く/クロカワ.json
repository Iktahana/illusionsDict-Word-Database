    "definitions": [
      {
        "index": 1,
        "gloss": "black-dyed leather",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "少しばかりのシヤツや衣類を纏めて、それから溜めて置いた紙幣を黒革の紙入れに捻ぢ込んだ。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、本文通り、黒革縅の大鎧、樹蔭に沈んだ色ながら鎧の袖は颯爽として、長刀を軽くついて、少し屈みかかった広い胸に、兵の柄のしなうような、智と勇とが満ちて見える。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸には源氏箙をたたいてどよめきけり」といふところ迄は、うつとりお耳を傾けて居られましたが、それに続けて、「あまりの面白さに、感に堪へずや思はれけん、平家のかの船の中より齢五十ばかりなる男の、黒革威の鎧著たるが、白柄の長刀杖につき、扇立たる所に立つて舞ひすましたり。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小型の黒革製の文書袋をこの男が左手に携えていたのだ、そして、それは居合せた一人の事務員の鋭い観察眼によると、革紐で自分の手頸にしっかりと結びつけられてあったのだ。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯人の代りに通りの向うから、一見何処かの外交員らしい洋服の男がたった一人、手に黒革のカバンを提げてやって来る。",
              "citation": {
                "source": "石塀幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "坐って弾くのだろう、という慶一の予想をうらぎって、片桐はゆっくりと、黒革の幅広のストラップをかけ、立ったまま素早くチューニングして、速いパッセージを弾きはじめた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそれから二時間としないうちに、山荘へは黒革の鞄を提げた医者らしい男が慌だしく駈けつけたり、数名の警官が爆音もけたたましくオート・バイを乗りつけたりして、岳陰荘はただならぬ気色に包まれてしまった。",
              "citation": {
                "source": "闖入者",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "シェードを除った客席では、一人の中年紳士が黒革の鞄を膝の上に乗せて、激しく揺れながらもとろとろとまどろみ続ける。",
              "citation": {
                "source": "白妖",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "とそこに、袖丈の短い洋服からシャツのはみでた無骨な手に黒革の手提トランクを提げ、真新しい赤靴を穿いて突つ立つてゐる男は、別れた妻の三番目の弟の修一ではないか。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "靴は仲間のローズに世話をしてもらつて、やつとの思いで買つた中古の黒革のハイヒール、或る男が、わたしのことを、初荷の馬だねと云つたけれども、その時に意味が判らなかつたけれど、あとで、その意味をきいてとても癪だつた。",
              "citation": {
                "source": "淪落",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四角い黒革の手提鞄と、薄汚ない畳椅子を左右の手に提げていたが、あとから這入って来た看護婦が、部屋の中央に湯気の立つボール鉢を置くと、その横に活溌な態度で畳椅子を拡げた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の手に黒革の折鞄、俗にいわゆる往診鞄を携えているのは、言わずと知れたお医者さんである。",
              "citation": {
                "source": "愚人の毒",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭領と見える四十五六の男は、さすがに黒革の鎧を着、鹿角を打った冑を冠り、槍を小脇にかい込んでいた。",
              "citation": {
                "source": "弓道中祖伝",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、私は床の間の本箱の側に飾られた黒革のトランクや、革具のついた柳行李や、籐の籠などに眼を遣りながら、言った。",
              "citation": {
                "source": "遁走",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "――照子は黒革のハンドバックを取って、編輯局長といういかめしい肩書のある尾高の方へ、真直にやって行きました。",
              "citation": {
                "source": "道標",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして屍体の背中をすこし持ちあげると、その下に隠されていた小さな黒革の日記帳をとりだした。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはポケット型というのであろう、たいへん小さな冊子で黒革の表紙もひどく端がすりきれて、その色も潮風にあたって黄いろく変色していた。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして黒革の手袋をはめたまま、井上一夫、三十三歳と左手で書っきょりました」　帆村は呻った。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドクトルはなおも口をモガモガさせて、黒革の手袋をはめた手に握った細い洋杖をふりあげて、いまいましそうにうちふった。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "見れば、熊かと疑うばかりに顔中｜鬚茫々で、その両眼は炯々として野獣のように輝いているという怪人物、身には汚れきった洋服を着、妙な長細い黒革作りの鞄を肩から吊るしたところの姿にはどこやら見覚えがあった。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "近づいて来る自転車の車体には房一の往診用の黒革の鞄と同じ格好のものがとりつけられてゐた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はカーキ色の乗馬ズボンに拍車のついた黒革の長靴をはいてゐた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥った円顔の上に小さな束髪をつけ、大きな黒革の鞄を手にしてる様子が、変に道化じみていた。",
              "citation": {
                "source": "幻の彼方",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇妙な黒い棺桶のような荷物をよく見れば、金色の厳重な錠前が処々に下りている上、耳が生えているように、丈夫な黒革製の手携ハンドルが一つならずも二つもついていた。",
              "citation": {
                "source": "ヒルミ夫人の冷蔵鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は黒革のハンドバッグに五通の手紙をしまいこんだ。",
              "citation": {
                "source": "女",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンナに黒革のトランクをおろすようにいって下さい。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い半ズボンに、当時はまだ珍らしかつた黒革のランドセルを背負つて登校するその子の姿は、西洋の家庭小説の挿絵で見る小公子そのままであつた。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に黒革のハンド・バッグが置き忘れてある。",
              "citation": {
                "source": "灰色の眼の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒革張りに錠前角当ての金具が光って、定紋のあったとおぼしき皮の表衣はけずってあるが、まず千石どころのお家重代のものであろう。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒革張りに真鍮の鋲を乱れ打ちに打った、津賀閑山が騒ぎまわっている、あの鎧櫃だ！",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
