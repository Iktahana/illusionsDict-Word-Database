    "definitions": [
      {
        "index": 1,
        "gloss": "to reel",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "月夜に往来へ財布を落しておいて小蔭にかくれて見ている、通行人があたりを見廻わしてそれを拾おうとするときに、そっと手許の糸を手繰ると財布がひとりでするすると動き出すというような深刻な教育法をも実行した事があったようである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ、山の中の氷の下から、数珠を手繰るように落ちて来る、峡間の水ほど力の強い、自由の手も少いであろう。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の戸を繰ると、あらたかな日の光が部屋一杯に射し込んだ。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうところへ誰かが出て来ると、さあ周章て鉄砲を隠す、本を繰る、生憎開けたところと読んで居るところと違って居るのが見あらわされると大叱言を頂戴した。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷鳴の音の波の振幅は多くの場合に耳の近くで雨戸を繰る音に比べて大きなものではないのに雷の音は著しく大きいと考えるのはやはり直接の感官を無視して音響の強度の距離と共に感ずる物理的方則を標準としているのである。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどそのころに枕もとのガラス窓――むやみに丈の高い、そして残忍に冷たい白の窓掛けをたれた窓の外で、キュル、キュル／＼／＼と、糸車を繰るような濁ったしかし鋭い声が聞こえだす。",
              "citation": {
                "source": "病院の夜明けの物音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この将校の顔から髪から髯からページを繰る手つきから、大きく肥った指先までが、その書物と自然に調和して全体が一つのまとまった絵になっていた。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一冊の書物を読むにしても、ページをパラパラと繰るうちに、自分の緊要なことだけがページから飛び出して目の中へ飛び込んでくれたら、いっそう都合がいいであろう。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし客が入口の扉を繰るやさすが名料理店の節度が其処に待ち受けている。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処とも無く糸車を繰る音、それに交って水車の音。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そなたの導力が手繰るまにまに、やがてわたしも、そなたと一つ世界に運び上げられよう。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「普通の彫金なら、こんなにしても、また、こんなにしても、そりゃ小手先でも彫れるがな」　今度は、この老人は落語家でもあるように、ほんの二つの手首の捻り方と背の屈め方で、鏨と槌を繰る恰好のいぎたなさと浅間しさを誇張して相手に受取らせることに巧みであった。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "はて、何時の間に、あんな處に水車を掛けたらう、と熟と透かすと、何うやら絲を繰る車らしい。",
              "citation": {
                "source": "二た面",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も初手の内は二軒三軒と心覚えにしておいたが、蛇の道は蛇じゃ、段々その術に長ずるに従うて、蔓を手繰るように、そら、ぞろぞろ見付かるで。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それじゃあ風の吹く晩には、糸を繰る音が聞えるだろうか。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はて、何時の間に、あんな處へ水車を掛けたらう、と熟と透かすと、何うやら絲を繰る車らしい。",
              "citation": {
                "source": "一席話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "須臾して妻はや馬に乘りてゆらりと手綱を掻繰るに、帚は燃したり、婢の乘るべきものなし。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "棚の埃を拂ひながら、地名辭典の索引を繰ると、糸崎と言ふのが越前國と備前國とに二ヶ｜所ある。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、發着の驛を靜岡へ戻して繰ると、「や、此奴は弱つた。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸奧の十綱の橋に繰る綱の　　絶えずもくるといはれたるかな――千載集「旦那――あの藤の花、何うだ。",
              "citation": {
                "source": "飯坂ゆき",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手にものなき一人、一方に向い、凧の糸を手繰る真似して笑う。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳶なら油揚も攫おうが、人間の手に持ったままを引手繰る段は、お互に得手でない。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、うっかりらしく手に持った女の濡手拭を、引手繰るようにぐいと取った。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "近間ではあるし、ここを出たら、それこそ、ちちろ鳴く虫が糸を繰る音に紛れる、その椎樹――（釣瓶おろし）（小豆とぎ）などいう怪ものは伝統的につきものの――樹の下を通って見たかった。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が手を離すのと、笊を引手繰るのと一所で、古女房はすたすたと土間へ入って行く。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ははは、」　人も無げに笑う手から、引手繰るように切符を取られて、はっと駅夫の顔を見て、きょとんと生真面目。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸も掛けない素の白身、雪の練糸を繰るように、しなやかなものである。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……幕へ衝と消える時は、何ものか居て、操りの糸を引手繰るように颯と隠れた。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　扱帯を手繰るように繰返して問返した。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "松の内は大供小供入り乱れて、到るところに糸を手繰る。",
              "citation": {
                "source": "思い出草",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
