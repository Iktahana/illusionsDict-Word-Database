        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "名詞の換言で日が暮れようアスファルトの上は凡人がゆく顔　顔　顔石版刷のポスターに木履の音は這ひ込まう",
              "citation": {
                "source": "春の日の怒",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "真昼の光はあつても少しくであり、それもやがて暮れるとしてのことのやうであり、此処では、紅の花も、やがて萎れて黝ずんだ色になるとしてのことである。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "南京陷落の日に萩原朔太郎歳まさに暮れんとして兵士の銃劍は白く光れり。",
              "citation": {
                "source": "南京陷落の日に",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天寒く日は凍り歳まさに暮れんとして南京ここに陷落す。",
              "citation": {
                "source": "南京陷落の日に",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にせかれて止むべき憂ひのみ永く殘りてわが情熱の日も暮れ行けり。",
              "citation": {
                "source": "廣瀬河畔を逍遙しつつ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の新らしい詩の表現は、丁度、愛する妻と共に日暮れの街を歩きながら、楽しい買物の話をするやうな、平易な親しさの中に、力強い情熱のひびきをこもらせたものであつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が暮れかけて来たころ、私はやっと立ちあがって、死んだように、ぼんやりなってお寺へ帰ってまいりました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の暮家路に遠き人ばかり　薄暮は迫り、春の日は花に暮れようとするけれども、行路の人は三々五々、各自に何かのロマンチックな悩みを抱いて、家路に帰ろうともしないのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋なくて日暮れんとする春の水　こうした春の郊外野景を描くことで、蕪村は特殊の画才と詩情とを有している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶯の声遠き日も暮れにけり　春の暮方の物音が、遠くの空から聴えて来るような感じがする。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春雨や暮れなんとして今日も有「暮れなんとして」は「のたりのたり」と同工風。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の燈やゆかしき奈良の道具市　秋の日の暮れかかる灯ともし頃、奈良の古都の街はずれに、骨董など売る道具市が立ち、店々の暗い軒には、はや宵の燈火が淡く灯っているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にこの師走の市へ行く鴉　年暮れて冬寒く、群鴉何の行く所ぞ！",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和九年二月著者我が心また新しく泣かんとす冬日暮れぬ思ひ起せや岩に牡蠣漂泊者の歌日は斷崖の上に登り憂ひは陸橋の下を低く歩めり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しだいに暮れゆく海波の上既に分列の任務を終へて艦等みな歸港の情に渇けるなり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま秋の日は暮れ行かむとし風は人氣なき小徑に散らばひ吹けどああ我れは尚鳥の如く無限の寂寥をも飛ばざるべし。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空しく君を望み見て百たび胸を焦すより死なば死ねかし感情のかくも苦しき日の暮れを鐵路の道に迷ひ來て破れむまでに嘆くかな破れむまでに嘆くかな。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて、墨田堤を水神に出でにしころは、日は全く暮れたり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の暮れるまでは影も見えず、夜はいつの間にか現われてガラスに貼り付けたように身動きせぬ。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海にも空にも船にも歳は暮れかかっている。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙ってじっとしている人々の顔にも年が暮れかかっている。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "六つになる親類の子供が去年の暮れから東京へ来ている。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁に出した花瓶の枯菊の影がうら淋しくうつって、今日も静かに暮れかかっている。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのふ過ぎ、けふと暮れ、明日またかくこそ有るべけれ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の思ひ出摘み溜めしれんげの華を　　夕餉に帰る時刻となれば立迷ふ春の暮靄の　　　　土の上に叩きつけいまひとたびは未練で眺め　　さりげなく手を拍きつつ路の上を走りてくれば　　　　（暮れのこる空よ！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "晃平が、先刻、未だ日の暮れないうち、朝飯の菜にとて、山款冬数十茎を折って来たのを、みんなして、退屈｜凌ぎに、繊維を抜いては、鍋へ投げ入れる。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　温泉宿から梓川に沿いて、河童橋を渡り、徳本の小舎まで来た、飛騨から牛を牽いて、信州へ山越しにゆく牧場稼ぎの人たちが、行き暮れて泊まるところだ。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくの如きは、古くから日本の文学を裏付けてゐる無常観で、あまりに常套な、又あまりに感傷的な句ではあるが、しかも時の姿、流れの姿は、人の身の上ばかりでなく、川それ自身の栄華をすら、鼠色に暮れゆく川上の、遠山に沈む斜陽のうす黄色の中に、うすら寒い谷の影を、描き出されるやうになつた。",
              "citation": {
                "source": "天竜川",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "日は暮れ、雨さへも降り出したので、寒さは又増した。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "自覚的な何物をも観せてくれないで神経生存の報告をして下さる。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
