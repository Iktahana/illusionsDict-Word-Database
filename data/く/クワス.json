    },
    "definitions": [
      {
        "index": 1,
        "gloss": "kvass",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一六三八年アムステルダム板リンショテンの『航海記』一一二頁に、ゴア市の郊外マテヴァクワスなる土堤へ羊や牛の角を多く棄つる。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡瓜の漬けかた、クワスの作りかた、赤坊のとりあげかたを誰にでも親切に教えてやるのも、この祖母さんなのであった。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてこの日は、犢の冷肉を一皿とクワス一本を平らげてから、広大無辺な我がロシア帝国の地方によっては、よく言い草にされている、謂ゆる『鞴のような大鼾』をかいて寝こんでしまうことで、どうやら幕になったらしい。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるでただのクワスじゃないか。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ドゥニャーシャに花束をわたす）ロパーヒン　ついでにクワスをおれに持ってきとくれ。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドゥニャーシャ登場、ロパーヒンにクワスを差出す。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（丸薬を受けとり、手の平へあけて、ふっと吹いて口へほうりこみ、クワスでのみくだす）この通り！",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "同様にして、クワスでノドをうるおそうと思って手にとると、またしても、いやはや、たとえば油虫といったたぐいの、極度に無礼千万なやつがはいっている。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "或家ではクワスを飮ませ、或所ではパンを食はして呉れる。",
              "citation": {
                "source": "六號室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "或家ではクワスを飲ませ、或所ではパンを食わしてくれる。",
              "citation": {
                "source": "六号室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "並木道の入口にコップ一杯五カペイキの向日葵の種やリンゴ、タバコを売っている屋台店があり、一軒の屋台店では腸詰だのクワスだのを売っていた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『さよう、ある年の春、わたしの領地の付近で、百姓たちが鉄道線路の土手で仕事をしましたが、若い農民の普通の食物は、パンとクワス（ライ麦より製したロシヤ独特の弱酒精飲料）と玉葱ですが、それでも元気で達者に生きています。",
              "citation": {
                "source": "クロイツェル・ソナタ",
                "author": "KREITSEROVA SONATA",
                "note": "青空文庫"
              }
            },
            {
              "text": "じょうずに焼かれたパンが三いろに、葡萄酒が二本、修道院でできるすばらしい蜂蜜が二壜、それに近在でも有名な、修道院製のクワスを入れた大きなガラスの壺などが出ていた。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「もう済みましたよ」とアリョーシャは答えたものの、その実、修道院長の台所で、パンを一切れにクワスを一杯飲んだだけであった。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬は水、ミルク、油、クワス（ロシアのビール）で抽出された。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
