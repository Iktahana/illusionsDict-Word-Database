[
  {
    "uuid": "f0bc439b-0384-5f94-bbd1-cc10928f6c17",
    "entry": "クワス",
    "reading": {
      "primary": "クワス",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
