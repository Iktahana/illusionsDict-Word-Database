    "definitions": [
      {
        "index": 1,
        "gloss": "to loose",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「こんなんですけど、寛げるかと思って、自分で縫って見たの。",
              "citation": {
                "source": "機関車",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、固くなっていた体を強いて寛げるようにした。",
              "citation": {
                "source": "文妖伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鬼の霍乱でしょう」　と翌日店員達は当分｜寛げる積りだった。",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "くつろげるアルプスの村々でもうら寂しい山道であっても、誰かと行き交えばもれなく顔をさっと一瞥、するどく人改めをすることから、ただ歩くにも追っ手の危険があると強く確信していることがわかる。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "平九郎は彌平次に眼くばせして、いづれも鯉口をくつろげる。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "のんびりとくつろげる。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "身をゆつくりとくつろげることだ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二人きりの時をねがうよりも却って第三者のあった方がどことなしくつろげる」と云うのは事実である。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "けい　あの人達がくるのに、いくらかでもくつろげるかと思って、お蔵の中から昔のお道具を引張り出して来たのですが……。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、どうやら呼吸が苦しいのらしく、時々発作的に咽喉元をくつろげるような真似をする。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きのう貰った五家宝切っておいで、お茶も願いますよ」　やっとわが家でくつろげるという風に、伸子は子供らしい顔つきになって好物の五家宝をたべた。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "佃が壁貼りをやめて、せめて、茶の一杯も仲間に入って飲んでくれたらどんなに和一郎も自分もくつろげるだろうかと、伸子は残念に思った。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じことであっても、きのうからきょう、きょうから明日へと流れつづくと、その流れは自然で、その心くばりにおいても一緒の感じでくつろげる。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐藤喜十郎もそちらを見たが、藤也は短刀のぎらぎらする光りと、衿をくつろげる久良馬の姿を見て、ひとたまりもなくその眼を伏せた。",
              "citation": {
                "source": "初夜",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "くつろげるようにカラー・テレビが置いてあるし、週刊誌や漫画のつまった書棚もある。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そういうことなら、貴方は梨とチーズのデザートでくつろげるってわけですね」「それくらいにして！",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "アストラ人は水陸両方でくつろげるし、海底で遊んでいると、面白そうなものを見つけて興奮し、引き上げて見れば、鉄箱すなわち潜水艇と分かった。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮎には早し、涼みの人は元よりなし、ほかに客らしい声もせず、至って閑散なところが殊に三人にはくつろげる。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは公務の疲れをいやす茶荘で、上屋敷でも下屋敷でもないところから、十分、くつろげる家である。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "鳴門の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
