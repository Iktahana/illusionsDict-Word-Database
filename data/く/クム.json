    "definitions": [
      {
        "index": 1,
        "gloss": "to draw (water)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼の別の句愚に耐えよと窓を暗くす竹の雪　もこれとやや同想であり、生活の不遇から多少ニヒリスチックになった、悲壮な自嘲的感慨を汲むべきである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸からつるべで水汲むのだが、冷してある水瓜にあたらないやうに、つるべ槽を下ろさなければならない。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "更くる夜　　内海誓一郎に毎晩々々、夜が更けると、近所の湯屋の　　水汲む音がきこえます。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "温色の興奮を味わい尽した魂が補色残像として冷色のうちに沈静を汲むのである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビーカーに水を汲むのでも、マッチ一本するのでも、一見つまらぬようなことも自分でやって、そしてそういうことにまでも観察力判断力を働かすのでなければ効能は少ない。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めのうち、清三は夏休み中、池の水を汲むのを手伝ったり、畑へ小豆の莢を摘みに行ったりした。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "槽を使う（諸味を醤油袋に入れて搾り槽で搾ること）時に諸味を汲む桃桶を持って来いと云われて見当違いな溜桶をさげて来て皆なに笑われたりした。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "京一は、いつも桃桶で諸味を汲む役をやらせられた。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃桶で汲む諸味の量が多いとか、少いとか、やかましく云った。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは青空よい天気まえの家でも隣でも水｜汲む洗う掛ける干す。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（こう身の上を話したら、嬢様を不便がって、薪を折ったり水を汲む手助けでもしてやりたいと、情が懸ろう。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼山について休んだ処で、渋茶を汲むのはさだめし皺くたの……然ういへば、来る道の阪一つ、流を近く、崖ぶちの捨石に、竹杖を、ひよろ／＼と、猫背へ抽いて、齢、八十にも余んなむ、卒塔婆小町を正で見る婆さんが、ぼやり、うつむいて休んでゐた。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼家じゃア二三日前に買立の銅の大きな金盥をちょろりと盗られたそうだからねえ」「まアどうして」とお源は水を汲む手を一寸と休めて振り向いた。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの井戸は多摩川から上水を木樋でひいたもので、その理由から釣瓶で鮎を汲むなどと都会の俳人の詩的な表現も生れたのであるが、鮎はいなかったが小鯉や鮒や金魚なら、井戸替えのとき、底水を浚い上げる桶の中によく発見された。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちやつとおうめやせな、貴下、水船から汲むが可うすえ。",
              "citation": {
                "source": "錢湯",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水を汲む、胡瓜を刻む。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "真三は、この膏濃い入道は、処も、浅草だと言う……むかしの志道軒とかの流を汲む、慢心した講釈家かなんぞであろうと思った。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃ、しゃくるぞ、水｜汲むぞ、べっかっこだ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が住めば水も要ろうで、何も釣瓶の音が不思議と云うでは、道理上、こりゃ無いのでありまするが、婆さんに聞きました心積り、学生の方が自炊をしてお在と云えば、土瓶か徳利に汲んで事は足りる、と何となく思ってでもおりましたせいか、そのどうも水を汲む音が、馴れた女中衆でありそうに思われました。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "・陽がとゞけば草のなかにてほほづきの赤さ・つく／＼ぼうしもせつなくないてなきやんだ　　　改作追加・秋空の井戸がふかうなつた・雲が澄む水を汲むげんのしようこの花　九月五日秋晴、終日寝ころんで読む、牧水の紀行文集を読んでゐると一杯やりたくなる。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と謂ひながら茶を汲むで呉れる。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの井戸は多摩川から上水を木樋でひいたもので、その理由から釣瓶で鮎を汲むなどと都会の俳人の詩的な表現も生れたのであるが、鮎はゐなかつたが小鯉や鮒や金魚なら、井戸替へのとき、底水を浚ひ上げる桶の中によく発見された。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "好事の人の就て汲む者の如き、終に往時の一夢たらんのみ。",
              "citation": {
                "source": "水",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し歌は顕昭｜阿闍黎の論じた如く、詩は祇園南海の説いた如く、其裏に汲めば汲むべき意の自然に存して居るものである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とお源は柄杓で、がたりと手桶の底を汲む。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆さん甘酒を早く、」「はいはい、あれ、まあ、御覧じまし、鳩の喜びますこと、沢山奥様に頂いて、クウクウかいのう、おおおお、」　と合点々々、ほたほた笑をこぼしながら甘酒を釜から汲む。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "長順　乗円、其方もわが心はえ汲むまいな。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みよ空にまぼろしの島うかびて、樹木いつさいに峯にかがやき、憂愁の瀑ながれもやまず、われけふのおとろへし手を伸べ、しきりに齒がみをなし、光る無禮の風景をにくむ。",
              "citation": {
                "source": "光る風景",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みよわが光は空にあり、空は白金、ふきあげのみづちりこぼれて、わが賽は魚となり、卓上の手はみどりをくむ。",
              "citation": {
                "source": "純銀の賽",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて茎の頂上にむくむくと一つの団塊が盛り上がったと思うとまたたくまにその頭がばらばらに破れて数十の花弁が花火のように放散した。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
