    "definitions": [
      {
        "index": 1,
        "gloss": "scruff of the neck",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
