[
  {
    "uuid": "5ebaf7ab-2ca6-5f7f-aac8-73e647763dc9",
    "entry": "雲をつかむ",
    "reading": {
      "primary": "くもをつかむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-マ行"
      ],
      "ctype": null,
