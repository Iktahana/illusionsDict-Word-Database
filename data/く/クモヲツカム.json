    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to not have a clear picture of the situation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「私にはまだ雲をつかむようだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲をつかむ尋ね物というが、これは空を飛ぶ尋ねものである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鷹のゆくえ",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと子供の玩具同様のものであるから、どこで買ったか殆ど雲をつかむような尋ね物であったが、田舎の人は詰まらないものを買うにも、とかく暖簾の古い店をえらむ癖があるのを知っているので、かれは先ず馬喰町の近所で最も名高い小間物屋に眼をつけて、案外に安々とその手がかりを探り出すことが出来たのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雪達磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、そこで様々なる余技を考へるにつけ、今更途方に暮れて、不図これらの師匠からのことに思ひ及んで見たが、それらの何れをとりあげて見ても、まるで雲をつかむようであり謂然とするばかりであつた。",
              "citation": {
                "source": "気狂ひ師匠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "市九郎をただ一度さえ見たこともない実之助にとっては、それは雲をつかむがごときおぼつかなき捜索であった。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでにふたりの子どもをかぎ出すことからして難事なところへ、行った先散った先が雲をつかむような八百八町とすれば、じつに難事中の難事でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "道々僕は、先生の渡された暗号――無論僕ははじめそれを暗号だと思った――を、色々に考えて解こうとしたが、まるで雲をつかむようだった。",
              "citation": {
                "source": "闘争",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は緊張した、しかし何処か雲をつかむやうな、淡い空虚を感じながら、とにかく持場々々へ出動しなければならなかつた。",
              "citation": {
                "source": "フアイヤ・ガン",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事は、勿論、まるで雲をつかむ様な空想ではあるが、これから先、いいにしろ、悪いにしろ、どうせぶつかって見なければ分らない事なのだから、実際の私の行末はまっくらな、辛い事ばかりかもしれないけれど、よく想像して居る方が一番いい。",
              "citation": {
                "source": "熱",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "初め役人連は例のナポレオンの話を持ち出しかけたが、その口の下から、そんなことを切りだそうとしたことを後悔した、それというのも、ノズドゥリョフが調子にのって、とても本当と思われないばかりか、まるで雲をつかむような馬鹿げきった話を喋りだしたからである。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然な折が來るまで、名古屋のその知人の處で働いて、その上で皆に逢ひにかへりませうと云ふ約束で、孝次郎は名古屋へ發つて行つたけれども、尋ねる住所は燒けてゐて、津田の行つたさきは雲をつかむやうでわからなかつた。",
              "citation": {
                "source": "雨",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙の中にいる姿の見えない人を捕まえるのですから、それこそまったく雲をつかむようなものでした。",
              "citation": {
                "source": "お山の爺さん",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "するうち彼には、自分にとつてはたゞ漠然と雲をつかむやうにしか思へない「年月」が房一の中にはつきり現れてゐるのを感じた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "★　意外なことになった上に、事件の正体が益々雲をつかむようだから、この役は紳士探偵新十郎が適任だと決して、その日のうちに古田巡査が新十郎にこの旨を伝えた。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより全国へ手配してあの大金庫を探しださせるのがいい」「そんなことよりも、さっき幽霊が大金庫を持ってどっちへいったか、その目撃者はないか、それを大急ぎで調べる事ですよ」「そんなものを見たという者は、ただ一人も現われないよ、怪しげな雲をつかむような話だから、頼みにはならないよ」「困ったねえ。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "『火星兵団』という言葉があるからには、こっちでも大いに警戒して、早く『地球兵団』ぐらいこしらえておかなければ、いざという時に間に合わないって」「ふふん、まるで雲をつかむような話じゃ。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四の用意は、もし衝突が起っても、我々日本人だけを死なさずに、何とか助ける方法はないものかどうか」「雲をつかむよりむずかしい話だ」「第五の用意は……」「わしは、もうたくさんだ。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一人の婦人の訪問者については、まつたく雲をつかむやうな話で、その婦人を見たといふたつた一人の人物、事務所の受附けの少女は、たゞ、洋服の、背の高い、三十ぐらゐの婦人といふだけで、人相や、声などについて細かいことをたづねると、それは、ひとりでに大庭常子そつくりの女性になるといふ、厄介な証人でした。",
              "citation": {
                "source": "誰でもない……自分でもない",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の狙いつつあるものが描けるかどうかは目下は雲をつかむようだ。",
              "citation": {
                "source": "「信長」作者のことば",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう時に買い手の目が利くと大モウケができるのさ」「だって雲をつかむような取引きじゃアないか。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "バカにされたとしか思われねえや」「キミの社長が製材所の倅なら雲をつかむような取引きはしないさ。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "七兵衛おやじは思慮があるだけに雲をつかむようだが、ウスノロの奴は、なあに直ぐと、とっ捕まえますよ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰から話をきいて何を調査に来たのか、まことにどうも雲をつかむようである。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その一〔判官巷を往く〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕府方の勝利は疑いないとか、大勝利は近いうちにあるとか、そんな雲をつかむようなことばかりです。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　まったく、雲をつかむような話なのだけれど、おじさんのいうことを聞くと、なんとなく、そうかもしれぬと思うのです。",
              "citation": {
                "source": "緑色の時計",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、雲をつかむようで、考えたことが、なんであったか、まったく見当がつきません。",
              "citation": {
                "source": "世の中のために",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、やっぱり雲をつかむようだったのです。",
              "citation": {
                "source": "世の中のために",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "われらはかような考え方の哲学を総括して橋杭哲学と名づけるが、実際の橋杭のほうは深く打ち込むほど堅固になり、ついには土台の岩石に達するに反し、哲学の橋杭は深く打ち込むほど確実性が減じ、ついには雲をつかむごときことになるゆえ、かれとこれとを同様にくらべるのは大きなまちがいである。",
              "citation": {
                "source": "我らの哲学",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲をつかむやうな話ですわ。",
              "citation": {
                "source": "浅間山",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、あの雲をつかむような、銅や、金や、銀を掘り出すのと、わけがちがったからです。",
              "citation": {
                "source": "金が出ずに、なしの産まれた話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
