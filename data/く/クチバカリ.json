[
  {
    "uuid": "7039cb5b-f9f2-5181-9835-24dcf562bc88",
    "entry": "口ばかり",
    "reading": {
      "primary": "くちばかり",
      "alternatives": [
        "くちばっかり"
      ],
      "is_heteronym": true
    },
    "grammar": {
