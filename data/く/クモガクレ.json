[
  {
    "uuid": "3e5759d8-50ed-5314-97a0-52921165e7fa",
    "entry": "雲隠れ",
    "reading": {
      "primary": "くもがくれ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
