[
  {
    "uuid": "4d8777a5-036b-5a56-bdd0-fac0660ceb66",
    "entry": "燻らす",
    "reading": {
      "primary": "くゆらす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
