    "definitions": [
      {
        "index": 1,
        "gloss": "to drive mad",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "音頭取が一つ拍子を狂わせるとたちまち怪我人が出来るそうである。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白梅の花を見て色のないのを責めるような種類の云わば消極的な抗議が、時と場合によっては幅を利かして審査の標準を狂わせるようなことも全くないとは云われない。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての仕掛けはこの車の同時調節によって有効になるので、試みにわざとちょっとばかりこの調節を狂わせると、もう受信機の印刷する文句はまるきり訳の分からぬ寝言にもならない活字の行列になってしまうのである。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰に水をさされたのか知らないが、お絹が飛んでもない疑いや妬みに心を狂わせるというのも、つまりは自分が無沙汰をかさねた結果である。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直に言ってしまえば、さなきだに乱れかかっている父の心をいよいよ狂わせるばかりか、自分のためにも都合のよくないことが出来するのは見え透いている。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも畢竟は病いのためで、病いが父の心を狂わせるのであろうとも考えたので、彼はまじめに父の相談相手になろうともしなかった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルパンなどは理知と感情とが並行していて、恋人に対する情熱などは、彼の驚くべき理知力を生むかまどのように思われるが、ホームズになると、恋愛やその他の感情は、推理を狂わせる邪魔者になっているようである。",
              "citation": {
                "source": "ホオムズの探偵法",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の報告はさらに忠通の心を狂わせる種であった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにも若ものの運命を狂わせる試験地獄の祟りがあったわけだが、それが庸三の不断の悩みでもあった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生の言葉一つで、私の運命は狂わせることもできるのよ。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の殺された男は、昨日の午後七時五十一分三十秒に、あの懐中時計を狂わせる原因を得ている。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月二十九日午後七時五十一分三十秒に、あの時計を狂わせる原因を得ているというのだな。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではそのニッケル貨幣が、時計を狂わせることになったのではないだろうか？",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれ共ごく稀には、自分の日常生活の習慣に支配された様な形になって、純にその人の精神なり何なりに接せずには居られないと云う感じより、読まなくちゃあならないと云う謂わば一日中の手順を狂わせる心持悪さから一枚なり一枚なり読む事がある。",
              "citation": {
                "source": "無題（四）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、その赤色をクリヴォフ夫人の赤毛に対称するとなると、いかにも標準を狂わせるような、強烈な眩耀が想像されてくる。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を狂わせる極地特有の孤独のなかで、彼の頭はますます冴えるばかり。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊賀殿の観察を狂わせる程の乞食、いよいよ只者では無さそうだな。",
              "citation": {
                "source": "首頂戴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「妾、近々伊丹屋の家を、出てしまうかもしれませんの」「あなたが伊丹屋のお家を出て、一人住みでもなされたら、江戸中の若い男達は、相場を狂わせるでございましょうよ。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時、こういう発作が非常に猛烈におこって、かの幻影に対する不可抗力的の憧憬がわたしを狂わせるようになったので、私は往来へ飛び出して不思議な家の方へ走ってゆくと、遠方から見た時には、固くとじられた鎧戸の隙間から光りが洩れているらしく思われたが、さて近寄って見ると、そこらはすべて真っ暗であった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "廃宅",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うに小林の文章は心眼を狂わせるに妙を得た文章だ。",
              "citation": {
                "source": "教祖の文学",
                "author": "――小林秀雄論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し彼の文章の字面からくる迫真力というものは、やっぱり私の心眼を狂わせる力があって、それは要するに、彼の文章を彼自身がそう思いこんでいるということ、そして当人が思いこむということがその文学をして実在せしめる根柢的な力だということを彼が信条とし、信条通りに会得したせいではないかと私は思う。",
              "citation": {
                "source": "教祖の文学",
                "author": "――小林秀雄論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の濃艶は彼の心を狂わせるが、それは愛ではない。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "ラッパチーニの娘　アウペパンの作から",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば酒は昔から「気違い水」とも名づけきたったが、脳の働きの調子を狂わせるものは酒のほかにもなおたくさんにある。",
              "citation": {
                "source": "脳髄の進化",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自然に反する――浮ぶはずがない」という以前の曰くの代りに「自然に反する――コンパスを狂わせる」という信条だった。",
              "citation": {
                "source": "黒船前後",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "血腥い噂が天地をこめて人の心を狂わせるのが戦国時代の有様であった。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつを俺が働き出すと、せっかくの相場が狂ってしまう、どうもね、相場を狂わせるのは、世間様に対して相済まない。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その観察を自分に合せてゆがめてあるので、多く訊いてもムダであるし、むしろ観点を狂わせる害があった。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "かほどの苦心を重ね術をつくして死体詰めの行李を運びだしたのは、殺した場所と時間を狂わせるため。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その四　ああ無情",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱の横腹にいっぱい牛の絵がついているんだものねえ」「でも、出発の時刻をくるわせることはできないよ。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
