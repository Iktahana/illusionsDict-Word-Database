    "definitions": [
      {
        "index": 1,
        "gloss": "to smoke",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "雪の中で燻る枕木は外へは火も煙も立てなかった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "話の本筋が燃えたと思ふと、直ぐそれは作者の亢奮に燻る。",
              "citation": {
                "source": "「青空語」に寄せて（昭和二年一月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "とやっぱり芬とする懐中の物理書が、その途端に、松葉の燻る臭気がし出した。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い夜草深い野の中で、一匹の獣の心は燻る。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "誘はれるでもなく覓めるでもなく、私の心が燻る……冬の明け方残んの雪が瓦に少なく固く枯木の小枝が鹿のやうに睡い、冬の朝の六時私の頭も睡い。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と蚊遣香は、小刻を打つて畝つて、せつせと燻る。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おお、燻る燻る、これは耐りませぬ、お目の悪いに。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどきは鬱々として生命を封付けられる恨みがましい生ものの気配いが、この半分｜古菰を冠った池の方に立ち燻るように感じたこともあるが、復一はそれを自分の神経衰弱から来る妄念のせいにしていた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、過去に泊って忘れていたそれ等の宿の情景が燻るように思い出されて来る。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の鮒で脂は落ちていますが身は新しいので燻る山椒と醤油の香ばしい匂と共にあまい滋味の湯気が周りに立ち拡がりました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "炉に燻る香の匂いと床の間の花の籠った匂いでおまえは頭が痛いといった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "火は葡萄染の深帳、花毛氈や、銀の籠、また、羅のころも、緑髪、わかき瞳に炎上の匂香熱く、『時』の呼吸、瞬き燻る『追懐よ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖母を畫けりと覺しき小幅の前に捧げし燈明は既に滅えて、燈心の猶｜燻るさま、一點の血痕の如し。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぷす／＼と燻る煙が蚊を遠く散亂せしめる。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "卯平は時々鹽鮭の一切を古新聞紙の端へ包んで來ては火鉢へ鐵の火箸を渡して、少し燻る麁朶の火に燒いた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は戰地から歸つた時はどこかで病院を開くといふ大志を懷いて居たのだがそれが僅か一年半でこんな間に合せの醫院に燻るやうに成つてしまつた。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚侍のは、浦にたくあまたにつつむ恋なれば燻る煙よ行く方ぞなき今さら申し上げるまでもないことを略します。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "かう云ふのが実に因果と謂ふのでございませうね」　金煙管の莨の独り杳眇と燻るを手にせるまま、満枝は儚さの遣方無げに萎れゐたり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、小坂部はあいにくに燻る落葉の煙りを袖に払いながら訊いた。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "市街の大半を占めてゐる焼跡には、仮屋建ての鑿の音が急がしく響き合つて、まだ何処となく物の燻る臭気の残つてゐる空気に新らしい木の香が流れてゐた。",
              "citation": {
                "source": "札幌",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "市街の大半を占めてゐる燒跡には、假屋建ての鑿の音が急がしく響き合つて、まだ何處となく物の燻る臭氣の殘つてゐる空氣に新らしい木の香が流れてゐた。",
              "citation": {
                "source": "札幌",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "プスリプスリと燻るような気※を吐いて、散々人を厭がらせた揚句に、僕は君に万斛の同情を寄せている、今日は一つ忠告を試みようと思う、というから、何を言うかと思うと、「君も然う所帯染みて了わずと、一つ奮発して、何か後世へ残し玉え。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥に家族の寝台がある土間に床几と卓を並べ、燻る料理ストーブが立っているわきの壁に、羊の股肉とニンニクの玉とがぶら下っている。",
              "citation": {
                "source": "石油の都バクーへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は腫れものに触るように庸三を取り扱ったが、ぷすぷす燻る憎悪の念をどうすることもできなかった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの時……原子爆弾で破滅した、あの街は、銀色に燻る破片と赤く爛れた死体で酸鼻を極めていた。",
              "citation": {
                "source": "火の唇",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は古びたオーバーを着込んで、「寒い、寒い」と顫えながら、生木の燻る火鉢に獅噛みついていた。",
              "citation": {
                "source": "廃墟から",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は古びたオーバーを着込んで、「寒い、寒い」と顫へながら、生木の燻る火鉢に獅噛みついてゐた。",
              "citation": {
                "source": "廃墟から",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの時……原子爆弾で破滅した、あの街は、銀色に燻る破片と赤く爛れた死体で酸鼻を極めてゐた。",
              "citation": {
                "source": "火の唇",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ問題でも、今まで焼芋の皮の燻る、縁の焦げた火鉢の傍で考えた事が発表せられた代りに、こん度は温室で咲かせた熱帯の花の蔭から、雪を硝子越しに見る窓の下で考えた事が発表せられるだろう。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "弱者への慰めのテエマが、まだ当分は、映画の底に、くすぶるのではあるまいか。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
