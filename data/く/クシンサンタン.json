    },
    "definitions": [
      {
        "index": 1,
        "gloss": "taking great pains",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いずれも苦心惨憺の結果になる導きの教えを遺されております。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ううむ、ううむ、と大袈裟に唸りながら、めちや苦茶に鎌を振りまはして、時々、あいたたたた、などと聞えよがしの悲鳴を挙げ、ただもう自分がこのやうに苦心惨憺してゐるといふところを兎に見てもらひたげの様子で、縦横無尽に荒れ狂ふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから大阪弁の「そうだ」は文字には書けず、私など苦心惨憺した結果「そうだ（す）」と書いて、「そうだす」と同じ意味だが、「す」を省略した言葉だというまわりくどい説明を含んだ書き方でごまかしているのである。",
              "citation": {
                "source": "大阪の可能性",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "又は白粉の濃淡や頬紅の掛け引きなんぞでせめて正面から見た感じなりと誤魔化そうと、明け暮れどれ位苦心惨憺しておられるか知れませぬ。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は拠んどころなく、参考書を購ふのだとか洋服をつくらなければならないからとか云ひ、本は好い加減の安物を積みあげたり、洋服はチラリと見せただけで曲げ込んだりして、苦心惨憺の揚句、漸く月々百円ほどは工面して、送つてゐた。",
              "citation": {
                "source": "茜蜻蛉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "といった風に散々に首をひねらせ、苦心惨憺させ、昏迷疲労させた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間と空間のあらん限りを馳けめぐって、脳髄の正体を突止めて行ったポカンの苦心惨憺の蹤跡をモウ一度くり返して辿ってみるがいい。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その犯罪の被害者らしい精神病者や自殺者が、地上到る処にウヨウヨしているに拘わらず、その犯行の手がかりとなるべき暗示材料、その他の証拠が見当らないために、本当の研究が発表出来ないという悲惨事に直面して、あらゆる苦心惨憺を続けている。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……諸君はここに於てか、今迄の若林博士の苦心惨憺の怪所業の一々が、何を意味しておったか……という事を、悉く明白に理解されたで御座いましょう。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして苦心惨憺して三年前に脱獄してからというもの、それこそ生命を削る思いをして、お前を探しまわったことを考えても、お前なしに俺が生きてゆけない人間になりきっていることが、いくらかわかるだろう』……ホホホ。",
              "citation": {
                "source": "継子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペトログラードのネバ河口に在る信号所の地下室にこの人間レコード製造所が在ることを日本の機密局では大戦以前から知っていて、苦心惨憺して、その遣り方を盗んでおいたんだ。",
              "citation": {
                "source": "人間レコード",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰る途中、畑に顛落して、つき指をしたり、苦心惨憺、やっとの思いで妻子のもとに帰ったのだが、妻は尋常の夫の放蕩とのんきに思いこんでいるらしく、チクチク皮肉をいうばかりか、子供たちにも私を悪者と教えこんでいた。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの二葉亭の書かれた作品はすべて「言文一致」で、恐らくその表現に苦心惨憺された事であつたらう。",
              "citation": {
                "source": "言文一致",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二葉亭自身は苦心惨憺した文章であらうが、必然にそこに到着したといふのは、おのづから生れた姿である。",
              "citation": {
                "source": "言文一致",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこれら二つの謎を集め、総称して「唐寺の謎」と云い、その謎をひそかに解いた上、その黄金を手に入れようとして、織田信長や唐姫の徒や、香具師の猪右衛門や玄女たちが、苦心惨憺したのであった。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "民衆芸術とやらを標榜して、どんな役者にでもやれさうな芝居を書いてゐれば、それや、偶には上演料もはいるだらうが、こいつは別の話で、在来の芝居から一歩でも踏み出さうとして、折角、苦心惨憺した作品を、毎月、どれくらゐ、われわれは古雑誌の中に見出すことだらう。",
              "citation": {
                "source": "幕は開かない",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから真面目に働いて、一揆をどうにか成功させ、その百姓の辛苦の一部を、除去いてやろうと苦心惨憺、指揮する山県大蔵の行為が、彼には馬鹿らしく見えるのであった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「苦心惨憺いたしたあげく、復讐を首尾よくとげられたのじゃ、ご加増は至当でござろうよ」と、戸ヶ崎熊太郎も横からいった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、さういふ事情の中で、多くの先駆者たちが、如何にして新しい国劇の樹立を計らうかと苦心惨憺したのでありますが、時あたかも西洋に於ては、例の近代劇運動の後を亨けて様々な演劇の流派が入り乱れてをりました。",
              "citation": {
                "source": "日本の新劇",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "大庭　　（大きな溜息を吐く）児玉はさつきから、起つたり、蹲んだり初男をおぶつたり抱いたり、初男は頻りに駄々をこねてゐる様子だが、物をいはせまいとして苦心惨憺の体である。",
              "citation": {
                "source": "五月晴れ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "わかりました」　志村鈴江は、さう言つて、洋罫紙五六枚にこまごまと認められた、例の苦心惨憺たる説得の文句を黙読しはじめた。",
              "citation": {
                "source": "ある夫婦の歴史",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "道庵はそれがために苦心惨憺しました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本という国は、幸か不幸か系図を貴ぶ国柄で、たとえば征夷大将軍になるには、どうしても源氏の系統をこしらえなければならず、たまたま土民の中、乞丐の間から木下藤吉郎のような大物が生れ出でても、その系図の粉飾には苦心惨憺したものです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の部分は、ほとんど完全に設計が出来、順調に工事も進行し、大砲の据附けでさえが、駒井の知識と、技能を以て、立派に完成の見込みがついたのにかかわらず、蒸気機関だけは苦心惨憺を重ねて、未だその曙光を見ないという有様であります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "Ocean の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために、いずれの家庭でも主婦が苦心惨憺しているのである。",
              "citation": {
                "source": "食べもの",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "――神は全知全能だから、処方に苦心惨憺ということもあるまいが、すらすらと処方をお決めになっても、全き愛にましますから、処方の間違いは絶対にない。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "村田君が私の病気をよくするために苦心惨憺ようやく手に入れた魚だから、ほかの元気な者に食わせてはせっかくの苦心に対して申しわけない、とも言えるだろう。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼怒沼間にも建設したき希望にて計画中である、尾瀬原と尾瀬沼間の道の修繕もなさなければならず、赤貧の山人苦心惨憺たるものがある。",
              "citation": {
                "source": "尾瀬沼の四季",
                "author": "平野長蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男も私達の祖師様のように、三十年もの間一本の木を、苦心惨憺して育てたのだよ。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこまで持って行くにはだいぶ苦心惨憺たるものがあったのだろう。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
