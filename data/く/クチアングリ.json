        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」と、村長は口あんぐりの体で言つた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "動かぬ魂、坐つたまま、びくともせぬに、口あんぐり。",
              "citation": {
                "source": "したゆく水",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "来てみて、はじめて口あんぐりと握飯を食う始末……焼跡をうろついて、あやしまれでもしては、このうえ気の利かない骨頂。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヨタ者は承知で来てみたが、お差止めには口あんぐりだ」と言いながら、道庵はワザと大きな口をあんぐりとあいて、看板の上を見つめていたが、犬にでも喰いつかれたように、「あっ！",
              "citation": {
                "source": "大菩薩峠",
                "author": "弁信の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう奴に御勘定奉行をさせれば、公儀の金を掴み出して、女郎買いをもやり兼ねないと、神尾も底の知れない馬鹿さ加減に、口あんぐりとその面を見直していると、鐚はいよいよいい気になり、「このお刺身の大盤振舞がスミますてえと、その次には、もう一つ、あっ！",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「スティーブン、これはどういうこと」　ビートリスは口あんぐりだ。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイダが息を呑んだ、姿見に我が身を見て、まさしく口あんぐり。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
