    "definitions": [
      {
        "index": 1,
        "gloss": "dark bay (horse coat color)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
