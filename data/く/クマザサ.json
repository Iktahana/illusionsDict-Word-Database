    "definitions": [
      {
        "index": 1,
        "gloss": "kuma bamboo grass (Sasa veitchii)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "このたびは霧がなかった、紫の花咲くクカイ草、蘭に似た黄色の花を垂れるミヤマオダマキが、肉皮脱落して白く立っている樅の木を、遠く見て、路傍にしなやかに俯向いている、熊笹が路には多い。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "道端の熊笹が雨に濡れてゐるのが目に沁みるほど美しい。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "河向ひから池までの熊笹を切開いた路はぐしよ／＼に水浸しになつて歩きにくかつた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道端の熊笹が雨に濡れているのが目に沁みるほど美しい。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "河向いから池までの熊笹を切開いた路はぐしょぐしょに水浸しになって歩きにくかった。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋傘を振り腕を拡げて手に触れる熊笹を毟って行く。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "徑を歩いてゆく私の影はすくすくと立つた杉の柱を※折して來る、冬の日よりもまだ弱い日向のなかにあらはれ、木立のなかに消えたり、熊笹の上を這つたりした。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはどこかの山から取って来た熊笹だか藪柑子だかといっしょに偶然くっついて運ばれて来た小さな芽ばえがだんだんに自然に生長したものである。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、足もとの熊笹を珍らしそうに眺めていますね。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは池畔の熊笹のうへに腰をおろし、背を樫の古木の根株にもたせ、兩脚をながながと前方になげだした。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは池畔の熊笹のうえに腰をおろし、背を樫の古木の根株にもたせ、両脚をながながと前方になげだした。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂を下りて熊笹の繁る所に来ると彼は一寸立どまり「聞えるだらう、川の音が」と耳を傾けた、「ソラ……聞えるだらう、あれが空知川、もう直ぐ其処だ。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二人は、頭を没する熊笹の間を僅に通う帯ほどの径を暫く行と、一人の老人の百姓らしきに出遇つたので、余は道庁の出張員が居る小屋を訊ねた。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊笹の径を通りぬけると果して、思ひがけない大道が深林を穿つて一直線に作られてある。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから見渡すことのできる一面の土地は、丈け高い熊笹と雑草の生い茂った密林でした。",
              "citation": {
                "source": "小作人への告別",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊笹は人の身の丈を没すという深さ、暗い林の遠くには気味の悪い鳥の声がして、谿川の音は物凄いように樹立の間に唱っている。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍の一喝、小牛大の猛犬｜忽ち縮み上がりて熊笹の間へ逃げ込んでしまった。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それから鎌を貸しな、滅多に人の通わぬ処、路はあっても熊笹ぐらいは切らざあなるまい。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ト、今まで、誰一人ほとんど跫音を立てなかった処へ、屋根は熱し、天井は蒸して、吹込む風もないのに、かさかさと聞こえるので、九十九折の山路へ、一人、篠、熊笹を分けて、嬰子の這出したほど、思いも掛けねば無気味である。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "川に沿うて熊笹の藪が生い茂っていた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこか此処かと声する方を辿って行くと、彌が上にも生い茂れる熊笹や歯朶の奥に於て、確に人の呻くを聞いた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査は進んで熊笹を掻分けると、年の頃は五十ばかりの坑夫｜体の男が、喉を突かれて倒れていた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は引組んだままで崖から転げ落ちると、下には幸いに熊笹が茂っていたので、身体には別に怪我もなかった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔の※い男は盛相の蓋に玄米で焚いてあるぐたぐたの飯を分け、起って熊笹の葉を二三枚｜執って来てそれにのっけて僧の前にだした。",
              "citation": {
                "source": "岩魚の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……樹の枝じゃ無い、右のな、その崖の中腹ぐらいな処を、熊笹の上へむくむくと赤いものが湧いて出た。",
              "citation": {
                "source": "朱日記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが一ツも鳴かず、静まり返って、さっさっさっと動く、熊笹がざわつくばかりだ。",
              "citation": {
                "source": "朱日記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖だ、椴松だ、熊笹だ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊笹の柔かそうな微風の深い斜面の裾にはまた、紅の華魁草に似た花が見渡すかぎりのお花畑を作っていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、熊笹の大なだれの波のうねりは驚くべく光滑に、また底に暗んで、しかもいかにも寝よげな絨氈の青みを重ねた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "どう見たところで熊笹峠にせよ箱根の新道ほどの危険な懸崖はなかったと思えた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
