          "standard": [],
          "literary": [
            {
              "text": "欧州には、金を取れども尽きぬ袋の話多く、例せば一八八五年版クレーンの『伊太利俗談』に三条を出す。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "例せばクレーンの『伊太利俚譚』に、貧しい児が叔父に小さき驢を貰う、その下に風呂敷さえ拡ぐれば、銭を便して満てる。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイルランドの名門メクチュレーンはクレーンの犬の意味で、この一族は犬肉を喫えば死んだという（一九〇八年版ゴムの『歴史科学としての俚俗学』二八六頁）。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その堀と堀の間には、たくましいクレーンの群が黒々と聳え立って、その下に押し潰されそうな白塗りの船員宿泊所が立っている。",
              "citation": {
                "source": "カンカン虫殺人事件",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき僕は、先年、本所の工場で働いていた友人がクレーンに跳ねとばされて重傷を負ったとき入院した江東外科病院を思いだした。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "○遠くの空にはあっちに一つ、こっちに一本クレーンがある。",
              "citation": {
                "source": "窓からの風景（六月――）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "千駄木小学校と郵便局の立つの　　　林町にクレーン※〔欄外に〕○八つ手、○食べたいような柔かい柿の木の若葉○房々とした楓、　或楓の赤い実○高い青空をはいて靡いている（東北の風に）さいかちの古い飾羽根のような梢。",
              "citation": {
                "source": "窓からの風景（六月――）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔欄外に〕　遠いクレーンの頂上に一枚むしろだかズックの袋だかがとりつけられ、更に遠い空には薄あかい光をふくんだ灰色の雲の大きいかたまりがある、○どういうわけか　そこの雨戸の一番下の棧のところに特別ひどく泥がたまっていた。",
              "citation": {
                "source": "窓からの風景（六月――）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒々とそびえ立つクレーンの下に、細長い姿を見せているのは、武田大佐が心血をそそいで造りかけているわが海のライオン、『富士』潜水艦ではないか。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方の六時ごろ、大クレーンの下で働いている二人のところへ、昭和遊撃隊司令官から、にわかに秘密命令が来たのだ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ありゃナ、クレーンが、動いている音さ！",
              "citation": {
                "source": "夜泣き鉄骨",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なに、クレーンが※」　一同が、思わず声を合わせて、叫んだ。",
              "citation": {
                "source": "夜泣き鉄骨",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "クレーンというのは、格納庫のように巨大な、あの第九工場の内部へ入って、高さが百尺近い天井を見上げると判るのだが、そこには逞しい鉄骨で組立てられた大きな橋梁のような形の起重車が、南北の方向に渡しかけられている。",
              "citation": {
                "source": "夜泣き鉄骨",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、クレーンだった。",
              "citation": {
                "source": "夜泣き鉄骨",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その橋梁の下には、重い物体をひっかける化物のようにでっかい鈎が、太い撚り鋼線で吊ってあり、また橋梁の一隅には、鉄板で囲った小屋が載っていて、その中には、このクレーンを動かすモートルと其の制動機とが据えてあった。",
              "citation": {
                "source": "夜泣き鉄骨",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」わしは、クレーンの運転手をやっている男を、人垣の中に呼んだ。",
              "citation": {
                "source": "夜泣き鉄骨",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「クレーンが、真夜中に動き出すてのは、本当かな」「わたしは、ナなんにも、存じませんです。",
              "citation": {
                "source": "夜泣き鉄骨",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、クレーンのスウィッチは、必ず切って帰りますで、真夜中に、ヒョロヒョロ動き出すなんて、そんな妙なことが……」　そこまで云った政は、発作みたいな様子となり、言葉のあとをブツブツ口の中で呟いて、それから急に気がついたかのように、ワナワナ慄える両手を、周章てて背後に隠したのだった。",
              "citation": {
                "source": "夜泣き鉄骨",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ク、クレーンが……」　懐中電灯の薄ら明りに、はじめて照し出された怪物は何であったろうか。",
              "citation": {
                "source": "夜泣き鉄骨",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはあの巨大な鉄骨で組立てられたクレーンが、物凄じい響きをあげて、呀ッという間に、全速力で一同の頭上を通り過ぎたのであった。",
              "citation": {
                "source": "夜泣き鉄骨",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「電灯を、点けろッ」　わしは、クレーンがまだ動いている裡だったが、決心をして、号令をかけた。",
              "citation": {
                "source": "夜泣き鉄骨",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「クレーンを動かすスウィッチが、入っているかどうかを調べるんだ。",
              "citation": {
                "source": "夜泣き鉄骨",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "オイ、政はいるかッ」わしは、クレーン係の、若い男を呼んだ。",
              "citation": {
                "source": "夜泣き鉄骨",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その硝子蓋の上から指しながら、クレーン係の政が呻った。",
              "citation": {
                "source": "夜泣き鉄骨",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このスウィッチが、開いているなら、クレーンの上へ、電気が行きっこ無いんです」「だが可怪しいぞ」とわしは云った。",
              "citation": {
                "source": "夜泣き鉄骨",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「クレーンは確かに動いたんだ。",
              "citation": {
                "source": "夜泣き鉄骨",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "クレーンはモートルでしか動けないんだ。",
              "citation": {
                "source": "夜泣き鉄骨",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よし、では念のために、クレーンの上へ昇ってみよう」わしは云った。",
              "citation": {
                "source": "夜泣き鉄骨",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なに、クレーンへ昇る――」　一同は、互に顔を見合わせて、恐怖の色を濃くした。",
              "citation": {
                "source": "夜泣き鉄骨",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいかッ」　わしはそういうなり、壁際へ進んで、クレーンに攀じ昇る冷い鉄梯子へ、手をかけた。",
              "citation": {
                "source": "夜泣き鉄骨",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
