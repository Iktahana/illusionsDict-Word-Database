        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "奥の知れないような曇り空のなかを、きらりきらり光りながら過ってゆくものがあった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "曇り空でも洩れる陽射しが、温かくて明るさを運んでくれるのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "休業のはり札して、ぴたりと扉をとざした、何とか銀行の窓々が、觀念の眼をふさいだやうに、灰色にねむつてゐるのを、近所の女房らしいのが、白いエプロンの薄よごれた服裝で、まだ二時半前だのに、青くあせた門柱に寄り添つて、然も夕暮らしく、曇り空を仰ぐも、ものあはれ。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……ハッハッハッ……ザマを見ろ……アハアハアハアハ」七本の海藻　曇り空の下に横たわる陰鬱な、鉛色の海の底へ、静かに静かに私は沈んで行く。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪はほとんど小降りになったが、よく見ると鉛を張ったような都の曇り空と膠を流したような堀河の間を爪で掻き取った程の雲母の片れが絶えず漂っている。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝の曇り空が黎明に覗かれてやゝレモン色に華やいでいます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月のはじめ、永い日も、午から雨もよいの、曇り空で、長屋建の平屋には、しかも夕暮が軒に近い。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　鮒釣りに行かう――と私の妻が曇り空を眺めていひ出した。",
              "citation": {
                "source": "山峡の村にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "日にしたらちょうど十三日、普通ならば十三夜の月が、今ごろはまぶしいほどに中天高く上っているべきはずですが、おりからの曇り空は、かえって人さらいの下手人をおぴき出すにはおあつらえ向きのおぼろやみです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五日前に、近年にない大雪が降ってから、毎日曇り空が続き、今日もまた、ちらちら白いものが降っております。",
              "citation": {
                "source": "髭の謎",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "目をあげて向うを見ると、月も星もない曇り空に、尾根のような駅の屋根が、高く黒々と浮きだしていた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚い鼠色の曇り空を通して、遅々たる陽あしを感じてはひとり苛々した。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それかあらぬかその晩の九時頃に一台の新しい箱自動車が、曇り空の暗黒を東に衝いて福岡を出た。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一面に白波を噛み出した曇り空の海上の一点を凝視しているうちに吾輩は、裸体のまんま石のように固くなってしまったよ。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "別れつる鼠の色の外套がおほへる空の心地こそすれ　今し方男に別れて来た女の心をその上にある曇り空で象徴しようとした試みであつて、別れた男の外套の鼠色が空に拡がり、それが心にうつることにしたのである。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "小雨ぎみの曇り空に、そしてまた地上に、いつのまにか流れ渡ってきた明るい静かな斜陽は、終戦後にもたらされた自由に似ていた。",
              "citation": {
                "source": "或る日の対話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝からの曇り空は遂に淡路に珍らしい雪を降らした。",
              "citation": {
                "source": "淡路人形座訪問",
                "author": "竹内勝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏のおわりに近い日の午後のことで、台風ぎみの曇り空に、雲の行き足がだんだん早くなっていく。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "重い曇り空から、細雨が粗らに落ちていて、木斛の葉も柳の葉も、夾竹桃の茂みも、しっとり濡れていたが、篠懸の葉下のベンチはまだ乾いていた。",
              "citation": {
                "source": "広場のベンチ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙幣束のはいってる鞄を抱えながら、重い曇り空の下を、十内は思い沈んで歩いた。",
              "citation": {
                "source": "広場のベンチ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その朝も彼は早く起き出して、どんよりした曇り空ではあったが、空地に出て行き、暫く歩いてるらしかったが、俄に駆け戻ってきて、女中のキヨに手真似で変事を知らせ、正枝の室の扉を打ち叩いて叫んだ。",
              "citation": {
                "source": "椿の花の赤",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "曇り空の薄ら日で、風もなかった。",
              "citation": {
                "source": "波多野邸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "曇り空の蒸し暑い日でした。",
              "citation": {
                "source": "白蛾",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、或る曇り空の蒸し暑い日、久しぶりに焼酎の配給がありまして、その上直吉の野菜物への御礼にと隣家から焼酎の贈り物もありまして、直吉は、借家主の坪谷仁作と共に、縁端で杯を交わしました。",
              "citation": {
                "source": "土地に還る",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして暗灰色の曇り空の中にちょっぴりした鮮かな雪の色は思いがけなく僕の心に錐のような痛みを感じさせた。",
              "citation": {
                "source": "石ころ路",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "曇り空の下の風見車に似ていた。",
              "citation": {
                "source": "幻の彼方",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝、起き上って、前日来のことがはっきり頭に返ってきた時――妙に顔を見合わせられない気持で相並んで、曇り空の下の河原の景色を眺めた時、深い底知れぬ悲しみが胸を閉ざしてきて、僕は手摺につかまったまま、ほろほろと涙をこぼしたのです。",
              "citation": {
                "source": "野ざらし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "曇り空の下のどんよりした薄明りに、漸くそれと知られる、まるで夕暮のような夜明けだった。",
              "citation": {
                "source": "悪夢",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今井は縁先に蹲って、その雨脚や曇り空をいつまでも眺めてることがあった。",
              "citation": {
                "source": "変な男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "星の光も見えない曇り空の闇夜なんだ。",
              "citation": {
                "source": "道連",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
