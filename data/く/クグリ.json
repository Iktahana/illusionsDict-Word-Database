        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうして、水はこれらの石の間を潜り、上を辷って蜿ねる。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "イワス（岩壁の截り立っているところ）にぶつかると、水が深くて急であるから、森の中へ潜り込む、そうしてまた森から吐き出されては、谷の中へと飛び込む。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "禁制の官林に潜り込んで、何か内密の稼ぎをするらしい。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "当主は、寝ている処を、いきなり丸太ん棒、それも樫の木の、潜り門用の閂でドサッとやられたので、遺言を書こうにも書くまいにも、眼の覚める暇がなかったのであった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "船室に潜り込んだが最後、もう頭が上がらぬ。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来ることなら老女が自分を乗せかけている果しも知らぬエスカレーターから免れて、つんもりした手製の羽根蒲団のような生活の中に潜り込みたいものだと思った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人の研究を記述した論文を如何によく精読したところで、その研究者自身の頭の中まで潜り込む事が出来ない以上は、その人の得た結果を採用するという事にはやはりこのイズムの匂がある。",
              "citation": {
                "source": "鸚鵡のイズム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "板石と水の隙間は、やっと勝子の頭ぐらいは通せるほどだったので、兄は勝子を差し上げながら水を潜り、下手でようやくあがれたのだった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見る間に檜を後に潜り抜けると、私が体の上あたりへ出て下を向き、（おいおい、松本へ出る路はこっちだよ、）といって無造作にまた五六歩。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の苔蒸す欄干を葉がくれに、桁を蔦蔓で埋めたのが、前途に目を遮るのに、橋の彼方には、大磐石に堰かれて、急流と奔湍と、左より颯と打ち、右より※と潜り、真中に狂立つて、巌の牡丹の頂に踊ること、藍と白と紺青と三｜頭の獅子の荒るゝが如きを見るとせよ。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この川は吹弾歌舞の地として有名なる○柳橋の下を潜り、また浅草橋左衛門橋美倉橋等の下を経、豊島町にて一水の左より来るに会す。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "深川側は既に説けり、日本橋側にありては仙台堀の対岸に神田川に達するの一水西北に入るあり、（既説）中洲の背後より箱崎と蠣殻町との間に存する一水あり、油堀と大川との会するところより下流に豊海橋の下を潜りて西北に入る一水あり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "指定された通りに裏門の潜り戸から這入ると、そこいらのベンチに待っていたらしい訪問着姿の未亡人が出迎えた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "厳めしい鉄門の鉄柵越しに門前の様子を見定めると、電光の様に小潜りを出た。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどアノ日の目を恐れて流し先を潜りまわる溝鼠のような息苦しい一生を送る憐れさ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆前船の暗い影の下を潜り、徳二郎は舟を薄暗い石段の下に着けた。",
              "citation": {
                "source": "少年の悲哀",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝より君が来宅までわが近郊の散歩は濁水暫時地を潜りし時のごとし。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯もそのままお源の後から布団の中に潜り込んだ。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "単なる理知の問題として考えずに、感情にまで潜り入って、従来の文化的教養を受け、とにもかくにもそれを受けるだけの社会的境遇に育ってきたものが、はたして本当に醇化された衝動にたやすく達することができるものであろうか。",
              "citation": {
                "source": "想片",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来ることなら老女が自分を乗せかけている果しも知らぬエスカレーターから免れて、つんもりした手製の羽根蒲団のような生活の中に潜り込み度いものだと思った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあとを見済ましでもしたかのように、老人は、そっと潜り戸を開けて入って来た。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御飯はいくらか冷たいかも知れないわよ」　老人は見栄も外聞もない悦び方で、コールテンの足袋の裏を弾ね上げて受取り、仕出しの岡持を借りて大事に中へ入れると、潜り戸を開けて盗人のように姿を消した。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "有りはしないが暖簾を潜りそうにして出た処を、捌いた褄も淀むまで、むらむらとその腕白共に寄って集られたものである。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒髪は乱れて頸に縺れ頬に懸り、ふッくりした頬も肉落ちて、裾も袂もところどころ破れ裂けて、岩に縋り草を蹈み、荊棘の中を潜り潜った様子であるが、手を負うた少年の腕に縋って、懐紙で疵を押えた、紅はたちまちその幾枚かを通して染まったのである。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一郎はすばやく帯をしてそれから下駄をはいて土間に下り馬屋の前を通って潜りをあけましたら風がつめたい雨のつぶと一緒にどうっと入って来ました。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」いつか一郎のおじいさんが潜りの処でそらを見上げて立っていました。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな潜りがあいてゐる。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」助手は潜りを入つて行く。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "バナナン大将｜手籠を持ちてその下を潜りしきりに果実を収む。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "脱心たりと心｜急立ち、本郷の通へ駈出でて、東西を見渡せば、一町ばかり前に立ちて、日蔭を明神坂の方へ、急ぎ足に歩み行く後姿はその者なれば、遠く離れて見失わじと、裏長屋の近道を潜りて、間近く彼奴の後に出でつ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
