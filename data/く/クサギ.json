        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "臭木の実の紅と黒とはもはや何の潤ひもなく萎へて了つた。",
              "citation": {
                "source": "蜜柑山散策",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "後丘の栗や臭木が白い葉裏を見せて揺れてゐる。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他冬｜青木、椿、楢、櫨、楝、椋、とべら、胡頽子、臭木等多く、※などの思ひがけないものも立ち混つてゐる。",
              "citation": {
                "source": "沼津千本松原",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "臭木と書くのであらうとおもふが、この木はその葉も枝も臭い。",
              "citation": {
                "source": "家のめぐり",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "くさぎるや畠の殖蒜。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "※を探しつゝくさぎの芽をも見付けた。",
              "citation": {
                "source": "家のめぐり",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
