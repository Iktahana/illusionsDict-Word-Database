[
  {
    "uuid": "7a915bfe-d82a-5f30-bcaf-89cc6d80df00",
    "entry": "屈託",
    "reading": {
      "primary": "くったく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
