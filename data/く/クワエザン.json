          "literary": [
            {
              "text": "【例題一】　次頁のような加え算がある。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "１９９２　　２９７１　　９７１２＋　２９１７――――――　１７５９２　同じ加え算でも、「覆面算」ふうなものが加わった場合がある。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "【例題二】　Ｎという文字で現わされた数字が五箇所に入っている加え算である。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "加え算、引き算、掛け算、割り算と全部揃っています。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの丸い珠が、加え算や引き算で、指先から押し動かされるのを見ていると、珠の方が却って、人をこばかにしているようだ。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はたつの前に喉を突き出し、算術の加え算をする。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "船を水に浮かべてその上にこの牛をのせ、どこまで沈んだかをしるして置いて、あとでその印のところまで数多い石を積み、その重さを加え算すれば、わけなく牛の目方がわかるというのである。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
