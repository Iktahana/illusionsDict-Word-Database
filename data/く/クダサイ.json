        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何か、僕に、食べさして下さい。",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "きんとんでもよい、何でもよい、　　何か、僕に食べさして下さい！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "降りくる悲しみを少しもうけとめないで、安易で架空な有頂天を幸福と感じ做し自分を売る店を探して走り廻るとは、なんと悲しく悲しいことだ……３神よ私をお憐み下さい！",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "神よ私をお憐れみ下さい！",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "この私の弱い骨を、暖いトレモロで満たして下さい。",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ神よ、私が先づ、自分自身であれるやう日光と仕事とをお与へ下さい！",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だ、そんなことかと諸君は云はれるでもあらうが、まあまあ鳥渡待つて下さい。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "駄目です』などと夫人にからかわれ、『あ、どうしよう、私この鼻』など言って悄気返り、『真ッぴら、真ッぴら』と、今おぼえたばかりの日本語を面白がって使ったりして、夫人や女中たちを大笑いさせたりしているのだが、その後で、『しかし、よく思うて下さい。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日経よむと墓を弔いするで、よろこぶの生きるです』『あなた、ほかの世、坊さんと生れて下さい』『ああ、私願うです』　人間よりも、虫や鳥の方が幸福だと言ったヘルンは、人生について、悲哀の外の何物をも知らなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして田舎の、寂しい寺に埋めて下さい。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた、子供とカルタして遊んで下さい。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "と質問してみて下さい、と答えて逃げ去ったとかいう話しがあるけれども、何千万年まえの世界には、どんな動物がいたか、一億年のちにはこの世界はどんなになるか、そんな話は、いったい実になるものかどうか。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またおひまの折には、おたよりを下さい。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、お笑いになって下さい。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま、この仕事を大急ぎで片づけてしまいますから、それまで鳥渡、待っていて下さいね。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごらん下さい、私はいまこうしています、ああしていますと、いちいち説明をつけなければ指一本うごかせず咳ばらい一つできない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上衣をお脱ぎになって下さい。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいしいものは、何もございませんが、どうぞ、お箸をおつけになって下さい。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっかり、ひとつ召し上って下さい。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、でも、」上の姉さんは伏目になって、「決してお気になさらないで下さい。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊田の、なくなつた「お父さ」は、私にずいぶん力こぶを入れて、何かとはげまして下さいました。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が中学校で少しでも佳い成績をとると、おどさは、世界中の誰よりも喜んで下さいました。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか、あの、小心にめんじて、おゆるし下さい。",
              "citation": {
                "source": "六月十九日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "変らず、身辺の良友の言を聴き、君の遠大の浪漫を、見事に満開なさるよう御努力下さい。",
              "citation": {
                "source": "砂子屋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊田の、なくなった「お父さ」は、私にずいぶん力こぶを入れて、何かとはげまして下さいました。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だから不服な僕を追つ放して下さいつてのですよ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ではもう少したってから来てください。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あした放課后みなさんとうちへ遊びに来てくださいね。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの罪を許しわたくしの呪をお解きください。",
              "citation": {
                "source": "龍と詩人",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までいろいろわがままばっかしいってゆるしてくださいね。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
