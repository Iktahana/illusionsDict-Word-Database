        "examples": {
          "standard": [
            {
              "text": "シェフは巨大なクリーヴァを振り下ろし、大きな肉の塊を骨ごと豪快に断ち切った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "そのクリーヴァの鋭い刃先には、長年の使用で刻まれた無数の傷跡が残っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ホラー映画の怪人が、血に濡れたクリーヴァを手にゆっくりと近づいてくるシーンが怖すぎた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "エルドリッジ・クリーヴァーは『氷の上の魂』で、心をこめて次のように書いた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈オレの青いスエードの靴だけは踏みつけるなよ〉」（武藤一羊・訳より）　エルヴィス・プレスリーを肯定するためのクリーヴァーの思想的な拠点は、おなじ本で次のようにのべられている。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカという階級社会が、クリーヴァーの言うように人間のなかで〈からだ〉と〈こころ〉をひきはなしておこうとはかりつづけるのであれば、〈からだ〉と〈こころ〉とがひとつになることは、その階級社会にとって最大の威嚇であるはずだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
