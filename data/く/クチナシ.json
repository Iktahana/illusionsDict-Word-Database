[
  {
    "uuid": "8ebca21e-bb12-5d62-9b37-be6cc054caeb",
    "entry": "梔子",
    "reading": {
      "primary": "くちなし",
      "alternatives": [
        "クチナシ",
        "しし",
        "さんしし"
      ],
      "is_heteronym": true
    },
    "grammar": {
