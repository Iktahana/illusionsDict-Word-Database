      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Cape jasmine (Gardenia jasminoides)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そしてその下草にところ／″＼山梔子が咲いてゐた。",
              "citation": {
                "source": "梅雨紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "梔子の花でないのは、一目見てもはじめから分ってます。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ち掛けた日が少時竹藪を透して濕つた土に射し掛けて、それから井戸を圍んだ井桁に※んで陰氣に茂つた山梔子の花を際立つて白くした。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつは、濕める梔子の別れのゆふべ泣き濡れしあえかの胸に、今もはた「日」は殘らめとささやきつ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはあの山梔子という花を御存じですか」　と不意に王子は尋ねました。",
              "citation": {
                "source": "オシャベリ姫",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その山梔子の樹は名前を『口なし』と書くので、昔からこの国の人々が大好きでした。",
              "citation": {
                "source": "オシャベリ姫",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがお城を離れれば離れるほど山梔子の花が少なくなって、しまいにはどちらを向いてもにおいもしなければ、白い花も無いようになりました……。",
              "citation": {
                "source": "オシャベリ姫",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いと甘き梔子の映えあかるにほひのなかに、埋もれつつ愁ふともなくただひとりありけるほどよ、あはれ、さは通りすがりのちやるめらの肩をかへつつ、ひとうれひ――ひいひゆるへうと荷擔夫の吹きもゆきしを。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その空は時雨月、清らなる色に曇りて、時節のきはみなき鬱憂は池に映ろひ落葉の薄黄なる憂悶を風の散らせば、いざよひの池水に、いと冷やき綾は乱れて、ながながし梔子の光さす入日たゆたふ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "その空は時雨月、清らなる色に曇りて、時節のきはみなき欝憂は池に映ろひ落葉の薄黄なる憂悶を風の散らせば、いざよひの池水に、いと冷やき綾は亂れて、ながながし梔子の光さす入日たゆたふ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "二ひとつは、濕める梔子の、別れのゆふべ泣き濡れしあえかの胸に、今もはた、『日』は殘らめとささやきつ。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "邸の植込をいてゐる時、青白い梔子の花蔭に、女郎蜘蛛が居睡りをしてゐるのを見つけでもすると、真つ青になつて、抜脚して逃げ出したものだ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "次兄にその名称を訊くと、梔子だといった。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "次兄にその名称を訊くと、梔子だといつた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "上原の妻は偶｜山梔子の飯を炊いでゐたので、それを重箱に盛つて持たせて帰した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、山梔子孃の手紙に貴方が身體の弱いのに無理ばかりしてゐるといつて氣づかつて來ましたが、かうやつて山の中で氣ままにしてゐる私はともかくも、本當に貴方こそ無理をなすつてはいけませんね。",
              "citation": {
                "source": "七つの手紙",
                "author": "或女友達に",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方が何處かの海邊に行つていらつしやるとの事、一週間ばかり前に山梔子孃からいただいた手紙で知つては居ました。",
              "citation": {
                "source": "七つの手紙",
                "author": "或女友達に",
                "note": "青空文庫"
              }
            },
            {
              "text": "楓、桜、梅、檜葉、梔子、無花果、沈丁花、椿など、雑多な樹木で、熊笹の数株まで添えてありました。",
              "citation": {
                "source": "崖下の池",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "山梔子、山百合の香である。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはしばしば家を移したが、その度ごとに梔子一株を携え運んで庭に植える。",
              "citation": {
                "source": "十日の菊",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "梔子の実の赤く熟して裂け破れんとする時はその年の冬も至日に近い時節になるのである。",
              "citation": {
                "source": "十日の菊",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "傾きやすき冬日の庭に塒を急ぐ小禽の声を聞きつつ梔子の実を摘み、寒夜孤燈の下に凍ゆる手先を焙りながら破れた土鍋にこれを煮る時のいいがたき情趣は、その汁を絞って摺った原稿罫紙に筆を執る時の心に比して遥に清絶であろう。",
              "citation": {
                "source": "十日の菊",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆を擱いてたまたま窓外を見れば半庭の斜陽に、熟したる梔子｜燃るが如く、人の来って摘むのを待っている……。",
              "citation": {
                "source": "十日の菊",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜梔子の実を煮、その汁にて原稿用罫紙十帖ほど摺る。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之一大正六年丁巳九月起筆",
                "note": "青空文庫"
              }
            },
            {
              "text": "梔子の実は去冬後園に出でゝ採取し影干になしたるもの。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之一大正六年丁巳九月起筆",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛乳の煮立つのに心づき男は小鍋を卸してコップにうつすと、女は丁度化粧を終り紫地に飛模様の一枚小袖に着換えて縫のある名古屋帯をしめ、梔子色の綾織金紗の羽織を襲ねて白い肩掛に真赤なハンドバックを持ち、もう一度顔を直すつもりで鏡の前に坐った。",
              "citation": {
                "source": "ひかげの花",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "巵子　くちなしは花のすねものなり。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "餡入りの餅のほかにいろいろの形をした素焼きの型に詰め込んだ米の粉のペーストをやはり槲の葉にのせて、それをふかしたのの上にくちなしを溶かした黄絵の具で染めたものである。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓からは、手入のよく行き届いた庭の一部が眺められ、雨に咲いている、くちなしの強い甘い匂いが、ときどき、かすかにうっとりとするほど、部屋の中に揺れて来るのであった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそこらの陰地やじめじめした水溜の附近を、揃ひのくちなし色の羽をさも見せびらかすやうに、ひよくりひよくりと気取つた身ぶりで長い尻尾を振りながら、爪立ちして歩き廻つてゐる。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
