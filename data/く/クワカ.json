        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……北極洋冬季航路開発を遅延挫折させた、モスクワ科学アカデミー教授エス・エル・カルピンスキー博士の反革命的行為は、ただいま、午前十時、公判終結によって、次のように闡明いたしました。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "上古より旧く我邦に作られている重要植物の一でクワ科に属する一年草である。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "クワ科の落葉樹でその学名を Ficus Carica L. といい、俗にその果を Fig と呼ばれる。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "イチジクは前述の通りクワ科に属する。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じクワ科のドルステニア（Dorstenia）の花は普通の花穂とイチジクとの中間を辿っているとみてよかろう。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスクワか、ペトログラードかへ」と、イワノウィッチが彼女に対して、深い愛情を表しながらきいた。",
              "citation": {
                "source": "勲章を貰う話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスクワから出した手紙なんだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬ二、三日前に、父はモスクワから一通の手紙を受取ったが、それを見て父は非常に興奮した。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「モスクワ」は小説として発表されており『文芸』の編輯者はモスクワかえりの「作家」として紹介しているのであるが、作家というのは何でも彼でも文字を書くものを総てひっくるめて呼ぶ名ではないのである。",
              "citation": {
                "source": "文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスクワからレーニングラードへ行って、郊外の「子供の村」と呼ばれる昔の離宮のある公園町の下宿に暮していて、その報知の電報をうけとった。",
              "citation": {
                "source": "父の手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは明日モスクワから日本へ向って送り出されるべきものだ。",
              "citation": {
                "source": "モスクワの辻馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪解け後は乾ききったモスクワから来るとそういう風景は、水っぽく寂しく、いかにもヨーロッパ北部の感じだった。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車はいくらかかるとか、モスクワから何マイルあるとかいうことを調べる。",
              "citation": {
                "source": "ソヴェト・ロシアの素顔",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くともここに押しよせた連中は二十分の停車時間の間に、たった一人ののぼせた売子から箱かインク・スタンドか、或はＹのようにモスクワから狙いをつけて来ている巻煙草いれかを、我ものにし、しかも大抵間違いなく釣銭までとろうと決心して、ゆずることなく押し合い、かたまっているのだ。",
              "citation": {
                "source": "新しきシベリアを横切る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっとモスクワから乗りつづけて来たものは長い旅行が明日は終ろうとする前夜の軽い亢奮で。",
              "citation": {
                "source": "新しきシベリアを横切る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスクワからウラジヴォストクまで九千二百三十五キロメートル。",
              "citation": {
                "source": "新しきシベリアを横切る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "農村でもラジオは非常に発達して、モスクワから何百露里も離れた田舎でメーデーの音楽やスターリンの演説を聞ける。",
              "citation": {
                "source": "ソヴェト同盟の芝居・キネマ・ラジオ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスクワから五千キロメートル離れたシベリアのコシヒ・バルナウーリスキー地方に「五月の朝」という共産農場がある。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスクワから五千キロメートルへだたった田舎の片隅で、文化の光がそこまでひろがった。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "農村で、集団農場のクラブへさえ集まれば、モスクワからのラジオが聴ける。",
              "citation": {
                "source": "ソヴェト同盟の婦人と選挙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――図書室の本が、まだモスクワから届かないんだってさ。",
              "citation": {
                "source": "明るい工場",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "主任は日本の女がモスクワから遠い炭坑を見学に来たのを珍しがって忙しいにもかかわらず、「あなたはどうしてドン・バスを見学する気になったんですか？",
              "citation": {
                "source": "ドン・バス炭坑区の「労働宮」",
                "author": "――ソヴェト同盟の労働者はどんな文化設備をもっているか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二八年の秋、私はモスクワからヴォルガ河を下って南ロシアへ旅行した。",
              "citation": {
                "source": "マクシム・ゴーリキイによって描かれた婦人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学生騒動はモスクワから始って、各都市に波及した。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "郵便局長の夫人も郡警察署長も、青い羽根をつけた婦人も、白い羽をつけた婦人も、ジョージヤ人の公爵チプハイヒリッゼフも、ペテルブルグから来た役人も、モスクワから来た役人も、フランス人のククーも、ペルフノフスキイも、ベレベンドフスキイも――みんな立ちあがって踊りだした……。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスクワから一日おくれに到着する「イズヴェスチャ」が老教授の膝の上にあった。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大勢の人間が、有給休暇でモスクワから去っても、あらゆる場所にそれよりもっと大勢の人々が熱心に書き、働き、演説をし、モスクワは一刻もゆるまず前進している。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "イグナート・イグナートウッィチのところへモスクワからプラウダと農民新聞が来る。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスクワから帰って来る時、丁度こんな風にたえ間なく雪が降り、黒い木が猪の背中の毛のように見える沿海州の山の間を通過するシベリア鉄道の車室で、わたしはタイプライタアを打っていた。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋「赤い貨車」（改造）をモスクワから送った。",
              "citation": {
                "source": "年譜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
