    "definitions": [
      {
        "index": 1,
        "gloss": "Moraceae (family of flowering plants)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
