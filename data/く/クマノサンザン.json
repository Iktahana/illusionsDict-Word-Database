    "definitions": [
      {
        "index": 1,
        "gloss": "three main Kumano shrines (Kumano Hongu Taisha, Kumano Nachi Taisha, Kumano Hayatama Taisha)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
