        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "うれひて蒼き柏ゆゑ、　　馬は黒藻に飾らるゝ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おふくろも子も乾上っちまう。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "茅葺きの家も、囲炉裏も、地酒も、髯みしゃの親爺も、おふくろも――それらは安らかさと、輝かしさに満ちている――すべてが自分から背を向けて遠くへ飛び去ってしまった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おふくろもその当座は気が転倒しているもんですから、なんにも気が付かなかったんですが、きのうの朝、長火鉢のまん中の抽斗をあけようとすると、奥の方に何かつかえているようで素直にあかないんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "おふくろも娘の書いたものに相違ないと云うんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おふくろもとうとう承知して、娘を奉公にやることに決めましたよ」と、半七老人は云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "――餓鬼も、おふくろも泣いているです。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那でなけりゃ、内地へ帰っちゃ、親爺もおふくろも、生存さえ出来ない。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "親爺もおふくろも、兄も、それから僕も、田植えと、田植えのこしらえに額や頬に泥水がぴしゃぴしゃとびかゝる水田に這入って牛を使い、鍬で畦を塗り、ならしでならした。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "親爺も、おふくろも、虹吉も満足だった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "諒安はそのくろもじの枝にとりついてのぼりました。",
              "citation": {
                "source": "マグノリアの木",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "くろもじはかすかな匂を霧に送り霧は俄かに乳いろの柔らかなやさしいものを諒安によこしました。",
              "citation": {
                "source": "マグノリアの木",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「郷里にもちょっと寄ったがね、おやじもおふくろも、額の皺が五六本ふえて少ししなびたくらいの変化だった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "くろもじの木の匂が月のあかりといっしょにすうっとさした。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春らしいしめった白い雲が丘の山からぼおっと出てくろもじのにほひが風にふうっと漂って来た。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドッドド　ドドウド　ドドウド　ドドウ、　甘いざくろも吹き飛ばせ　酸っぱいざくろも吹き飛ばせ　ホラね、ざくろの実がばたばた落ちた。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月十日「ドッドド、ドドウド、ドドウド、ドドウ、　ああまいざくろも吹き飛ばせ、　すっぱいざくろも吹き飛ばせ、　ドッドド、ドドウド、ドドウド、ドドウ　ドッドド、ドドウド、ドドウド、ドドウ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ドッドドドドウドドドウドドドウ、あまいざくろも吹きとばせ、すっぱいざくろも吹きとばせ、ドッドドドドウドドドウドドドウ、ドッドドドドウドドドードドドウ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とおふくろも外を覗くやうにする。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の親父もおふくろも、たった今わたしの宿へたずねてきた。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "手ぶくろもおいてきてしまった。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "かわいそうに、ゲルダは、くつもはかず、手ぶくろもはめずに、氷にとじられた、さびしいフィンマルケンのまっただなかに、ひとりとりのこされて立っていました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「毎度ありがとうございます」「時におふくろも兄貴も達者かえ」　お吉の兄は左官で、阿母はもう五十を越しているということを半七は識っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやじもおふくろも死んじまった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "仄かに残るものは、「おやじもおふくろも、俺を叱らなかった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹はもう死んでいる、お里のおふくろも死んでいる、だれにも遠慮気兼ねもいらないと思った。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "中二　親父は勿論、おふくろも頻りにそれを気に病んでいるようですから、私は努めてその迷いを打ち破ろうとしているんですが……。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
