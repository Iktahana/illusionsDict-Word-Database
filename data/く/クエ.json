[
  {
    "uuid": "32fd1c21-5876-5317-94c0-4466f1224201",
    "entry": "九絵",
    "reading": {
      "primary": "くえ",
      "alternatives": [
        "クエ"
      ],
      "is_heteronym": false
    },
    "grammar": {
