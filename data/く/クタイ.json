[
  {
    "uuid": "8ff55fbc-a4ea-5938-80bc-493e3bc92514",
    "entry": "躯体",
    "reading": {
      "primary": "くたい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "frame (of a building)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「裸女結髪」の女の躯体には古瓢のおもしろみがある。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついに、みずから掘ったその坑に虎はがくんと躯体を鼻をついた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに太陽の光線は赭くたいへん足が疲れたのだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし大多数の読者がこの点について一通りの予備知識を備えているものと仮定してもおそらくたいした不都合はあるまいと思う。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは送り狼になりたくたい」　そう思ったので、小沢はもうサバサバした声で言った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの水には、いまどきまったくたいした利目があるわ。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "がやがやとさわぎたてて、いやもう、まったくたいへんでした。",
              "citation": {
                "source": "モミの木",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったくたいへんな人で、ごったがえすような、ありさまだったよ。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「止して下さい、貧乏くたい話は」それで流石の父も口を噤みました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察が喧しいから、女の子もみないなくなったし、この部屋だって今は応接間に使ってるぐらいだから……」「とにかくたいしたものよ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれど、その途中の路用が何として……」「何の、やくたいもない心配じゃ。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうすると、花鳥の夜伽をした者には、そのあしたきっと鰻めしを食わせてくれるのだね」「御牢内で鰻めしなんか食べるには、たいそうお金がかかるのだそうですが、毎日きっと誰かに食べさせてくれました」「むむ、まったくたいそうな金持だな。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くたいまつ燃やせッ」「どっちだッ、どっちだッ、姿が見えねえじゃねえかッ」「こっちだッ、こっちだッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「……考えたこともないですけれど、きっと、すごくたいへんだろうと……」「そうか。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつきから奧で聞いてゐりやあ、手前たちは兄弟揃つて、よくも口から出放題の惡體もくたいを列べ立てやあがつたな。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し離れて三人の武士、高くたいまつをささげている。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくたいもくたいばかり言うて。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うん、全くたいへんなんだよ。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今にもホスゲン瓦斯の堆肥に似た臭が鼻をつくかと心配されたが、四分たち、五分たっても、なんの変った臭もして来ず呼吸はふだんと変りなくたいへん楽であった。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "王　　美くしゅうは熟れても、心のやくたいものうくされはてたのが多いのじゃ。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、お婆さんは新聞をたたみ、男はねくたいへ手をやり、女は一せいにバッグをあけて鼻のあたまを叩き出す。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "かやうな事は千百年以前に御存知ゆゑ、言うても言はいでもの事を、はれ、やくたいもない。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "かほはやくたいにて、夫ゆゑ御返事もいたし不申候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮にお付きしていて親しく思召される役人のほかに殿上役人の中で特に宮のお愛しになる人たちだけを数にして微行のお遊びのつもりであったのであるが、大きな勢いを負っておいでになる宮でおありになったから、いつとなくたいそうな催しになっていき、予定の人数のほかに左大臣家の宰相中将がお供申し上げた。",
              "citation": {
                "source": "源氏物語",
                "author": "総角",
                "note": "青空文庫"
              }
            },
            {
              "text": "○私しおけしてながくあるものとおぼしめしハやくたいニて候。",
              "citation": {
                "source": "手紙",
                "author": "文久三年六月二十九日　坂本乙女あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛皮の目出帽――吹雪のときにこれをスッポリかぶると目を凍傷することがなくたいへん暖い。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "カフェーで働くことも厭になると、私はその頃、ひとりぐらしになっていたたい子さんの二階がりへ転り住んで、暫くたい子さんと二人で酒屋の二階で暮らしました。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みじめな者は私一人じゃないか、私はぺしゃんこにくず折れた気持ちで、片づけて行くたい子さんの白い手を見ていた。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の世にも生きて響くたいした手紙ではないか。",
              "citation": {
                "source": "尼たちへの消息",
                "author": "――よく生きよとの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖の面はガラスのごとくたいらかで、水はなんともいえぬほどすんでいる。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
