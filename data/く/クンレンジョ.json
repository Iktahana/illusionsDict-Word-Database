        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "小学校を出てからも青年訓練所で、また、同じような思想を吹きこまれた。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三期に這入って帝国主義戦争が間近かに切迫して来るに従って、ブルジョアジーは入営する兵士たちに対してばかりでなく、全国民を、青年訓練所や、国家総動員計画や、その他あらゆる手段をつくして軍国主義化しようと狂奔している。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　青年訓練所を出た奴が、一年六カ月で、帰休になると喜んでいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」特曹は、訓練所出の一群を指さした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　口の曲った特務曹長は、同じ訓練所出の松下に、満足げに頷ずいて見せた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　訓練所出の、上品ぶりたい倉矢が仰山げに笑った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　高取が幅のある声で訓練所を抑えつけた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "訓練所出の、倉矢までが、浮かぬ顔で何か考えこんでいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか、学校も、青年訓練所も、在郷軍人会も、彼等の××のための道具となっている。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "進歩的な両性の社交場がほかに一つもないとすれば、低調ながらも大衆的にはこんなところも、人間的な一つの訓練所ともならないこともなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄の健は、畠からすぐ市街地の「青年訓練所」に廻ったらしく、夕飯時に家に帰らなかった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「青年訓練所」に通えば、とにかく兵隊の期間が減る、そう聞いていた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――健達の通っている「青年訓練所」も、その「修養倶楽部」で毎晩七時からひらかれていた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「青年訓練所」では、※の旦那が「修養講話」をやった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "健達は「青年訓練所」から演習の見学のために、一日だけ参加しなければならなかった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時迄も百姓ばジッとさせて、何時迄も勤勉に仕事ばさせて置くためには、新聞でこい、雑誌でこい、紀元節でこい、徴兵検査でこい、青年訓練所でこい、機動演習でこい、学校でこい、みんなその目当てのためにドンドン使ってしまうんだ。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　同じことを「青年団」や「青年訓練所」のもの達にも云って歩いた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人とも青年訓練所へ通っているらしく、その台所前の狭い空地で、魚芳たちは「になえつつ」の姿勢を実演して興じ合っているのであった。",
              "citation": {
                "source": "翳",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロサンジェルスの本部を買うために五十万ドル投げ出したし、ミシガン州のマキナック島には、訓練所を維持している。",
              "citation": {
                "source": "再武装するのはなにか",
                "author": "――ＭＲＡについて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのサーニが、臓品分配のことから刃傷沙汰を起し、半殺しの目にあってシベリアの雪の中に倒れていたところを、その地元の「嘗て浮浪児たりし人々のコンムーナ」すなわち少年労働訓練所に救護された。",
              "citation": {
                "source": "作品のテーマと人生のテーマ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の友人に大井広介といふのがあつて、彼の家は新宿御苑の近所にあるのだが、その隣りへ内原訓練所の生徒が上京して合宿してゐた。",
              "citation": {
                "source": "模範少年に疑義あり",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると内原訓練所の生徒は全員新宿御苑へ逃げこんでしまつて、そのために焼夷弾のうちに消しきれず火事にして十軒ばかり焼けてしまつた。",
              "citation": {
                "source": "模範少年に疑義あり",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察犬訓練所で一年以上も訓練された飛びきり優秀犬なのよ。",
              "citation": {
                "source": "南京虫殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "草色服に真赤い兵隊帽青年訓練所生徒「若けい野郎児ら鉄砲担いでどこぞへ？",
              "citation": {
                "source": "飢えたる百姓達",
                "author": "今野大力",
                "note": "青空文庫"
              }
            },
            {
              "text": "訓練所へ入る前、彼は工場をやめて、家の仕事を手伝っていたのだ。",
              "citation": {
                "source": "米",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "定臣　　そつちが青年団なら、こつちは訓練所の監督だ。",
              "citation": {
                "source": "富士はおまけ（ラヂオ・ドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠　　（包みを背負つて起ち上り）訓練所の監督はいいが、娘の監督は大丈夫か。",
              "citation": {
                "source": "富士はおまけ（ラヂオ・ドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つの証拠でありますが、最近、この村の青年訓練所の人達が、在満軍人慰問金を集めるために、活動写真をやりました。",
              "citation": {
                "source": "飢餓地帯を歩く",
                "author": "――東北農村惨状報告書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "実業補習学校と青年訓練所とを一緒にしようという「青年学校」案を、××××に一蹴された腹癒せとしては、出来すぎた案だと思ったのに、之は又老教育専門家達によって、一蹴されそうである。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
