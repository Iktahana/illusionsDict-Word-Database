        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すぐに安物らしい白地の博多帯をさぐってみると……どうだ……ムクリムクリ……ヒクリヒクリと蠢く胎動がわかるではないか……たしかに姙娠五箇月以上である。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてクリムソンレーキを水に薄く溶かしたよりもっと鮮明な光を持った鱗の色に吸いつけられて、思わずぼんやりと手の働きをやめてしまう。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、クリム・サムギンという人物の詰らなさ。",
              "citation": {
                "source": "長篇作家としてのマクシム・ゴーリキイ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、今日は哀愁の満ちたベルレーヌの詩をよみルドン、マチス、クリムトの絵を見る。",
              "citation": {
                "source": "初夏（一九二二年）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「一人もないさ」「たからせるんでいいことにしとくのね」　○ゴーリキイが何故クリムを主人公として「四十年」を書いたか。",
              "citation": {
                "source": "日記",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「四十年」の主人に何故クリムを選んだか、と頻りに考えられる。",
              "citation": {
                "source": "日記",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーガス博士といいますが、クリムスビーに住んで鑑識研究所を開いています。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は、ひところ、警視庁でも活躍していた人ですが、今は、自分の研究所に立て籠っています」「クリムスビーですか。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこでしょうか、その、クリムスビーというのは」「クリムスビーというと、北海へ注ぐハンバー河口を入って、すぐ南側にある小さい町です。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃあ、私はすぐ、そのクリムスビーへいって、アーガス博士にお願いしてみましょう」「いま、紹介状を書いてさし上げます、ミスター・Ｆ！",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」15　午後遅くクリムスビーの駅に下りて、仏天青はおどろいた。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼下に見えるクリムスビーの町の上には、照明弾が、およそ二三百個も、煌々と燃えていた。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "福士大尉は、情報報告のため、直ちにこのクリムスビーを発足すべく、アンの亡骸をそっと下に置いて、立ち上った。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "色素は芸術家が使うウルトラマリン、カルミンおよびクリムソン・レーキ；アントワープ・ブルー、クローム・イエロウおよびインディアン・インク；だけではなく、普通のペンキ屋が使う粗野な色素もあるていど混ぜ物処理をされている。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその臣民がクリム韃靼人の侵掠を受けて苦しんだので、女帝はこの、おそらくは正当な口実に基づいて、クリミア全部を占領し、擾乱的隣人の大部分を駆逐し、残りのものをもっと平穏な生活法を採用せざるを得なくさせたのである。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛び飛びに白の無地を交へて、クリムソン・レーキ、ウルトラマリン、ビリジヤン及びガムボージの各色を配した。",
              "citation": {
                "source": "「いろは」の五色ガラスについて",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからついこの間六十八歳で立派な生涯を終ったクリムサムギンのおじいさん［自注４］のことについて少し勉強し、あしたの朝早起きするのを楽しみに、このお喋りを終ったら寝ます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "［自注４］クリムサムギンのおじいさん――百合子はマクシム・ゴーリキーの伝記を書こうとしていた。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「四十年」の大作でクリムの性格は発展的に描かれていなかった。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにある優しさを、立派な人間たち、芸術家たちは知っている面白さ、「クリム・サムギン」の中にね、サムギンが「ああお前になって見たいと思うよ」というところがあって、私はどんなにおどろいたでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽子はキング・クリムゾンの『太陽の戦慄※』をダビングしたテープを光江に貸した。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "康子の来るまでに清三は二杯の牛乳を空けた、時間にしたら二十分たっぷりであろう、いらだたしい眼が、何度か壁のクリムトの複製画に止まった。",
              "citation": {
                "source": "須磨寺附近",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "払ひをすませ（特別扱ひと見えて五円也）銀座へ出て、不二アイスへ寄り、ハムエグスとタンシチュウを食ひ、アイスクリムソーダを二杯。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
