          "standard": [
            {
              "text": "彼はクロアチア人で、とても陽気な性格だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "クロアチア人の友人が、故郷のワインをプレゼントしてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "多くのクロアチア人が、サッカーや水球などのスポーツに熱中している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "もしも東ローマの著述家たちが彼等の隣人に對して活溌な關心をもつてゐなかつたとしたならば、歴史家の云ふ如く、ロシア人、ハンガリア人、セルビア人、クロアチア人及びブルガリア人の早期に就いての我々の歴史的知識は「白紙」であつたであらう。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            }
          ]
        }
