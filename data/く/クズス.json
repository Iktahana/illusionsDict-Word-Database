[
  {
    "uuid": "b6d55b6e-e50b-5e52-81b7-f9b35becbf50",
    "entry": "崩す",
    "reading": {
      "primary": "くずす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
