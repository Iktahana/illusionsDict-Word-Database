    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to destroy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まず、全身に関しては、姿勢を軽く崩すことが「いき」の表現である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらのすべてに共通するところは、異性への運動を示すために、眼の平衡を破って常態を崩すことである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "正式な平衡を破って、髪の形を崩すところに異性へ向って動く二元的「媚態」が表われてくる。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の秋小さな盛りにしていた土を崩すだけだったから何でもなかった。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち石滝のある処で、旅客は岸｜伝に行くのであるが、ここを流るるのは神通の支流で、幅は十間に足りないけれども、わずかの雨にもたちまち暴溢て、しばしば堤防を崩す名代の荒河。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、片褄を少し崩すと、ちらめく裳、紫の袖は斜になった。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "対手の節の隙間を切って、伸縮みを緊めつ、緩めつ、声の重味を刎上げて、咽喉の呼吸を突崩す。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいつも、けちけちしている癖に、ざらざら使い崩すたちなので、どうしてもお金が残りません。",
              "citation": {
                "source": "みみずく通信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と代官婆が土蜘蛛のようにのさばり込んで、（やい、……動くな、その状を一寸でも動いて崩すと――鉄砲だぞよ、弾丸だぞよ。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりお前、私のお客、この大空の霧を渡って輿でおいでのお亀様にも、途中失礼だと思ったから、雨風と、はたた神で、鷹狩の行列を追崩す。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその唄の下に高い問答のやうな調子が長く續く所のあるのは、濱邊の聲高の生活が靜かな夕波の曲節を崩すのによく似て居るのである。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幇間なかまは、大尽客を、獅子に擬え、黒牡丹と題して、金の角の縫いぐるみの牛になって、大広間へ罷出で、馬には狐だから、牛に狸が乗った、滑稽の果は、縫ぐるみを崩すと、幇間同士が血のしたたるビフテキを捧げて出た、獅子の口へ、身を牲にして奉った、という生命を賭した、奉仕である。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに門人中坐容を崩すものがあったのを見て、大喝して叱した。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "女や酒に身を持ち崩す男があるように、形而上的｜貪慾のために身を亡ぼす男もあろうではないか。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁のこうした稽古振の裡面には、よしや日本中の能楽が滅亡するとも、自分の信ずる能楽の格だけは断じて崩すまい。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　綾子夫人は、指先で椅子の腕を軽く叩きながら、今までの態度を、急に無雑作な調子に崩すと、いった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、紀久子は叫ぼうとするその身構えから、姿勢をさえ崩すことができなかった。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "除けよ、とあるので、附添と、愛吉は、山を崩すがごとく、氷嚢を取り棄てた。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがもう一方で、電子化が崩すものもある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽織は猩々緋、とを見ず、故に競い掛かりて切り崩す、中村｜戈を振るって敵を殺す事あまたなれども中村を知らざれば敵恐れず、中村ついに戦歿す。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "思想や信仰は自ら作るもので人から与えるべきものでないから、求めるものの方が間違ってるが、左に右く二葉亭は八門｜遁甲というような何処から切込んでも切崩す事の出来ない論陣を張って、時々奇兵を放っては対手を焦らしたり悩ましたりする擒縦殺活自在の思弁に頗る長じていた。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "手癖の悪い娘が出来たり、虚栄のために身を持ち崩すお嬢さんが出来たりしている。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "関森はさういふ持前の顔つきをいささかも崩すことなしに、会話の断れ日毎にそんなやうなワラヒ声を挙げるといふ奇癖の所有者であつた。",
              "citation": {
                "source": "沼辺より",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の採集は膜翅から直翅に移つてゐたので、少なからず食指が動いたが、折角の姿勢と未曾有の恍惚状態を崩すのが惜しまれて尚も微動さへ浮べなかつた。",
              "citation": {
                "source": "夜見の巻",
                "author": "「吾が昆虫採集記」の一節",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟻の巣を突きくずすと大騒ぎが始まる。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "指程の腸詰十八を白葡萄酒で煮て冷してから匙でくずす。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると、課業にうんで、かすかなといきをもらしながら、すこししせいをくずすが、またすぐ、熱心に先生の方をながめるのであった。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから社を取りくずすと、縁の下には一匹の灰色の蛇がわだかまっていて、人々はあれあれといううちに、たちまち藪のなかへ姿をかくしてしまった。",
              "citation": {
                "source": "月の夜がたり",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "このパーソナルコンピューター市場を切りくずす提案理由を、ＵＮＩＸは結局示しえなかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、船員としての因襲的な悪徳にはしみない性格であったが、「菓子で身を持ちくずす」のであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
