        "examples": {
          "standard": [
            {
              "text": "クールー病は、パプアニューギニアの部族の間で過去に流行した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プリオン病の一種であるクールーは、共食いの習慣と関連付けられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "医学の進歩により、クールー病の原因が解明された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "クールーの町に完全を志した工匠がいた。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼があらゆる点から見て適当な材木を見つけだした前にクールーの町は白い廃墟となり、彼は塚の一つに坐って杖をけずりにかかった。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、じぶんを見物しようとして、東ヴェンメンヘーイからもトルプからもスクーループからも、たくさんやってくるだろう。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ある日のことたまたま、クールーブルーの司祭であったかまたはポンピエリーの司祭であったかちょっとわからないが、あるりっぱな主任司祭が、たぶんマグロアールに説かれてであろう、司教に次のことを尋ねてみた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
