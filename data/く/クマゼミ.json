          "literary": [
            {
              "text": "磴たるや、山賊の構えた巌の砦の火見の階子と云ってもいい、縦横町条の家ごとの屋根、辻の柳、遠近の森に隠顕しても、十町三方、城下を往来の人々が目を欹れば皆見える、見たその容子は、中空の手摺にかけた色小袖に外套の熊蝉が留ったにそのままだろう。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊蝉最初の声、油蝉も鳴いた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊蝉が、むかうの方で、ちよいと鳴いた、今夏最初の声である。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――熊蝉が鳴く、真夏の歌だ、油蝉も鳴きだした、それは残暑の声だらう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "まつたく猛暑だ、油蝉熊蝉が鳴きだした。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとにうるさい位だ」　熊蝉が、あちらこちらの樹に止って、ここを先途と鳴いていた。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
