    "definitions": [
      {
        "index": 1,
        "gloss": "nine levels of Amitabha's Pure Land",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "二人はある時奥沢の九品仏の庭に立った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあとで死ねば九品蓮台の最上位にだって生まれることができるでしょう。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうした事情と同じやうに、松林桂月氏の画壇的位置も、その作品の地位は、その作品の本質を語られないで、保たれてゐるといふ感がまことに深い、桂月氏がいつか九品庵の展観に出品した『田家雪』といふ作品を、或る批評家がかう書いてゐた『この雪に爺や何処より帰り来たらん、漁の具合はどうだ。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど、いかにも神聖清淨の地と思はるるは、奧澤の九品佛（淨土宗）と、谷原村の新高野山（眞言宗）と也。",
              "citation": {
                "source": "東京の近郊",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓさんが帰ると、Ｙ、急に九品仏に行こうといい出した。",
              "citation": {
                "source": "金色の秋の暮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三井の横を抜け、竹藪を抜け、九品仏道と古風な石の道しるべについて行ったら、Ａ氏の農園のすぐ横に出た。",
              "citation": {
                "source": "金色の秋の暮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "九品仏は今は殆ど廃寺に等しい。",
              "citation": {
                "source": "金色の秋の暮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "九品仏その他、駒沢からこの辺にかけて、散歩するに気持よいところが沢山ある。",
              "citation": {
                "source": "是は現実的な感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月二十九日（金曜）　八木さんヤスム十月三十一日（日曜）快晴関さん、三沢さん九品仏に行くこの中に三体ずつ、頭デッカチの金仏。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "文武官九品以上、蕃客等、各位に陪す。",
              "citation": {
                "source": "國文學の發生（第三稿）",
                "author": "まれびとの意義",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐渡を離れる時に、四とせ経てけふ立ちそむる佐渡島を　いつきて見るやのりのともし火という一首を、九品仏の堂上の額に題して去った。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "六朝時代には天下の官吏を九品中正の方法で選擧し、全く貴族の權力で左右したのであつて、當時の諺に上品無寒門、下品無勢族といふ事があつたが、隋唐以來此弊を破るために科擧を行ふことゝなつた。",
              "citation": {
                "source": "概括的唐宋時代觀",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおその極楽には九品の階級があって、たとい五逆十悪の如き諸の不善の業を具している程のものでも、死ぬる時に善知識に遇うて妙法を聞き、念仏すれば、下品下生の極楽へは生れる事が出来るとさえ説いているのである。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "御公儀御法会の時、於京都九品派の出家諷経に出座ある時、御不（布）施物の外に施行下さるゝ由、総て施行は乞食非人に被下事也。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "左すれば九品宗・時宗抔、踊念仏も修行する宗旨は、他宗と違ひ物貰に近きものと見えたり。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "其末に御影堂扇折、九品寺の茶筅売等、俗体にて衣を着する類、平人よりは一等軽き者なれば、鉦打・鉦扣等又其下にも置くべき者にて、百姓とは縁組等も不致、別物に立置事也。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は「九品蓮台の中には、下品といふとも」と同じく紙に書いて答える。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、側の壁には、「三尊来迎便りあり、九品往生疑なし」ともかかれていて、今更に父が最後の時まで、欣求浄土の念を捨てなかったことも知った。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "泊雲、泊月、躑躅、浜人、はじめ、九品太、月斗、一転、梅史、桜坡子等と共に。",
              "citation": {
                "source": "五百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふみはづす蝗の顔の見ゆるかな昭和三年十月秋風に草の一葉のうちふるふ流れ行く大根の葉の早さかな昭和三年十一月十日　九品仏吟行。",
              "citation": {
                "source": "五百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『玉藻』、二八、三）俳諧九品仏　私はかつて『俳諧｜須菩提経』というものを書いた。",
              "citation": {
                "source": "俳句への道",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "以下｜下品下生に至るまで九品の仏のそれぞれの俳句は、それぞれの天分に従って採る。",
              "citation": {
                "source": "俳句への道",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇治鳳凰堂の扉画『九品往生相』は、正面の分厚い木造の大扉に、大和あたりを思わす青緑山水が大きく描き出され、損傷のひどいのはなげかれるが、緑青や丹の顔料が強い墨線とともに断続して、当年の結構を想見させる。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝から九品仏のロケ、寺の事務所で支度して、「愛染かつら」のパロディー場面、移動を主として数カット。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧侶だけでも、五岳の碩学、洛中洛外の禅律、八宗の沙門、余す者なく集会して、九品の浄土、五百阿羅漢、三千の仏弟子、目前にあるがごとし――と当時の目撃者はその状況を誌している。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼくほんたうはよく知りません、けれどもそんなんでなしにほんたうのたった一人の神さまです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠いろの薄い卵の殻にはＫといふ字が、赤くほんのりと書かれてゐた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼくほんとうはよく知りません、けれどもそんなんでなしにほんとうのたった一人の神さまです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼくほんとうはよく知りません。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほのおはすきとおってあかるくほんとうに呑みたいくらいでした。",
              "citation": {
                "source": "若い木霊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
