    "definitions": [
      {
        "index": 1,
        "gloss": "hoe-shaped helmet crest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
