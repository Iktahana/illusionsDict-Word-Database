    "definitions": [
      {
        "index": 1,
        "gloss": "sense of humiliation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "室子はそういう場合、得体の知れぬ屈辱感で憂鬱になる。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいえ、もう、それには、とはげしく拒否して、私は言い知れぬ屈辱感に身悶えしていた。",
              "citation": {
                "source": "黄金風景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "がまんできぬ屈辱感にやられて、風呂からあがり、脱衣場の鏡に、自分の顔をうつしてみると、私は、いやな兇悪な顔をしていた。",
              "citation": {
                "source": "新樹の言葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の死に対する疑惑や、母の生活に対する憤懣や、自己の運命に就いての屈辱感や、そうしたものが一時に火となって、彼の中に燃え上った。",
              "citation": {
                "source": "妖氛録",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は庸三に屈辱感を抱かせないために、細心の注意を払うことを忘れなかった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "謹直な教師たちに屈辱感を与えたにちがいないその問題は、しかし、愈物的条件の切迫した来春どんな形で再燃するだろうか。",
              "citation": {
                "source": "女性週評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとき、トルストイは、不幸なアンナが切迫した愛の思い、屈辱感、憎悪と悲しみとの混乱のなかで、カレーニンの玄関に入ったときヴェールを脱ぐだろうか脱がないだろうか、外套はどうするだろうと、作者トルストイが何日も苦心したということが伝えられている。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この切ない経験、効果はなくて屈辱感ばかりをのこした経験から、日本のわたしたちは、決して何も学んでこなかったわけではなかった。",
              "citation": {
                "source": "世紀の「分別」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その心の底には高見山で安子にからかわれたことの屈辱感があったのだ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶縞のお召に羽織は黒の小紋錦紗に藍のぼかし糸をつかった縫紋の背が品よくみえたが、ふと、その紋が家の麻の葉ぐるまだと気付いて紀久子はこみあげてくる屈辱感からさっと顔色を変えた。",
              "citation": {
                "source": "父",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "癩者を救ふ第一の道は、癩者のもつ屈辱感を除去するにある。",
              "citation": {
                "source": "頃日雑記",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今もありありその時のＴの手の重味というか、触感というか、それを激しい屈辱感とともに肩先へ蘇らすことができる。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "もの狂おしい屈辱感に気が遠くなったのだ。",
              "citation": {
                "source": "身体検査",
                "author": "ソログーブ・フョードル",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体検査のときの屈辱感は、少年の心にいつまでも残っていた。",
              "citation": {
                "source": "身体検査",
                "author": "ソログーブ・フョードル",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ私は強い屈辱感を抱いて、この医院を去るより他はなかった。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "徴兵検査の時の屈辱感を思い出すまでもなく、再び私の性欲は猛烈に昂進する。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧しい彼が洋食の名を知つてゐるはずはないし、だいいち御馳走されること自体が、ませた屈辱感を呼びさますのである。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "（貴様は、あの娘にも、今日死ぬと誓った）　竜太郎は広間の入口に突っ立ったまま、言いようのない屈辱感に襲われて、赤面した。",
              "citation": {
                "source": "墓地展望亭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには杉子の心の中でひしがれた矜恃があるばかりでなく、伊田そのひとのために杉子が感じる屈辱感に似たものもあるのであった。",
              "citation": {
                "source": "杉子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわり、あなたのことについて、わたしは誰からもひとことも話されていませんよ」　煮えたぎるようだった女のいらだちとぼんやりした屈辱感は、伸子のその話しぶりでいくらかずつ鎮められて行くらしかった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にとっての「愛」、それは、私が努力すればするほど、歯ぎしりするような絶望と屈辱感、わずらわしい不自由しか私にはくれないのだ。",
              "citation": {
                "source": "軍国歌謡集",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "戰爭への怒り、あなたたちへ對しての責任感、べつな意味での屈辱感や敗北感がごつたになつて胸に大きなかたまりを盛りあがらせます。",
              "citation": {
                "source": "いまだ癒えぬ傷あと",
                "author": "――放射線火傷で右手をうしなつた木挽きの妻と河原にうつ伏せて死んでいた幼女に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、狂女おゆみの出来事に続く今日の失敗は、救いようのない屈辱感で彼自身を圧倒し、うちのめした。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "駈込み訴え",
                "note": "青空文庫"
              }
            },
            {
              "text": "板の間で冷や飯を食べ、雑巾バケツの側で叱られ、又、おかみさんの足腰を揉ませられる事よりも、それは奴隷的な屈辱感に汚される心地であった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、こんな血の滲むような屈辱感や、たれのとも知れない嘲笑がもととなって、ついには情欲のきわみに達するほどの快感が始まるのだ。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "５　さて、借問するが、自分自身の屈辱感の中にさえ、快感を見いだそうなどと企らむような人間が、はたして多少なりと自己を尊敬し得るものだろうか？",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "さる公爵に招かれた時、饗宴の席から除け者にされたモーツァルトが雇人達と一緒に食事をさせられて、「雇人扱いにされた」という屈辱感と激怒のため酔っ払いのように蹌踉として帰り、翌る日もまだ平静な心持になれなかったとさえ伝えられている。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "街の悪童の漫罵の中に、泥酔した父親を背負って帰る屈辱感が、ベートーヴェンの負けじ魂を一層｜頑なものにし、荊の道を渋面作って踏み破る最初のスタートになったのであろう。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは神聖を冒涜されたというふうな、威厳を示すつもりらしいが、反対に、秘していた自分の弱点をあばかれたための、屈辱感のあらわれのようであった。",
              "citation": {
                "source": "超過勤務",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が美しからぬ娘で、人に愛されるようなことはないと固く信じていた志保は、それを門人たちの嘲弄であると思い、屈辱感のためにはげしく身が震えた。",
              "citation": {
                "source": "菊屋敷",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
