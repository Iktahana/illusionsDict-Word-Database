          "standard": [
            {
              "text": "若手パイロットたちは、教官の指導のもと訓練機でタッチアンドゴーを繰り返した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "引退した戦闘機が一部改造され、現在は次世代のパイロットを育てるための訓練機として使われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "雲一つない青空を、オレンジ色に塗装された訓練機が軽快なエンジン音を立てて飛んでいった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ロンドン郊外の飛行場からは、夜となく昼となく、訓練機がとび上がって来て、ロンドン上空に絶え間なく爆音をとどろかせていたそうである。",
              "citation": {
                "source": "抗議する義務",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
