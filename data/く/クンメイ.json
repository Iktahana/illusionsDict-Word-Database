[
  {
    "uuid": "6a6d52a9-f6a4-5359-8be5-75886c0c8675",
    "entry": "君命",
    "reading": {
      "primary": "くんめい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
