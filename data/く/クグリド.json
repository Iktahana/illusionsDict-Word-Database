        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "指定された通りに裏門の潜り戸から這入ると、そこいらのベンチに待っていたらしい訪問着姿の未亡人が出迎えた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあとを見済ましでもしたかのように、老人は、そっと潜り戸を開けて入って来た。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御飯はいくらか冷たいかも知れないわよ」　老人は見栄も外聞もない悦び方で、コールテンの足袋の裏を弾ね上げて受取り、仕出しの岡持を借りて大事に中へ入れると、潜り戸を開けて盗人のように姿を消した。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し男は「ままよ」の安心で、大戸の中の潜り戸とおぼしいところを女に従って、ただ只管に足許を気にしながら入った。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨がまたしめじめと降りかけた時に、私たちは養狐場の高い板囲いの潜り戸を開けてもらっていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると不意に男湯の潜り戸があき、男湯に体の純白な女が、獣よりも身軽に躍り込んで来た。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の商売でありませんから、下総屋はもう大戸をおろして、潜り戸の障子に灯のかげが映しているので、わたくしは藤助を指図して、外から唯今と声をかけさせました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀八がすぐに潜り戸をあけて表を覗く。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そんなことを考へると此一日が挟まれた事位ゐは自分に取つても他人に取つても他愛もない事だ、といふやうな心で、三村のことばかりを案じながら潜り戸を入つた。",
              "citation": {
                "source": "白明",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とばかりに空々しくうけ流しながら愴惶と潜り戸を脱け出た。",
              "citation": {
                "source": "公園へ行く道",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "利休は潜り戸を開けて、なかに入った。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブツ／＼云ひながら、呼ばれた者は小さい潜り戸を、蹲みながら出て行つた。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにまた一つの潜り戸があって、それを婆さんが開けてくれた。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽ち、戸がぱったりと落ちると、潜り戸が開いて、中から匂いを立てた女が突然参木の手をとった。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、突然｜右側の潜り戸をがらりと開けて、小供を抱いた一人の男が、地震だ／＼、大きな地震だと云つて出て来た。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中は客の夜具を運んで来て、離座敷の潜り戸を閉めて行った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の若者は、前後をソッと見廻した後で、潜り戸の上をコツコツコツと三つ叩いた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "建仁寺のひどく壊れた外廻りを見廻し、自分は黙って潜り戸をあけた。",
              "citation": {
                "source": "又、家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茶番のいる広い土間の入口の潜り戸をはいってゆくと、平日に増してお茶番の銅壺は煮たち、二つの茶釜からは湯気がたってどこもピカピカ光っていた。",
              "citation": {
                "source": "大丸呉服店",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラムプを吹消して、手探りで草鞋を穿いて、地面へジカに置いた座布団の上にドッカリと坐って、潜り戸に凭りかかりながら腕を組んで眼を閉じた。",
              "citation": {
                "source": "骸骨の黒穂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀次は潜り戸からすこし離れて坐ったまま一心にその様子を見ていた。",
              "citation": {
                "source": "骸骨の黒穂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで一層気を付けておりますとこの小女っちょ奴え、潜り戸に凭れかかる振りをしてマン中の桟から掛金までの寸法を二本指で計ってケツカルので……ヘエ。",
              "citation": {
                "source": "骸骨の黒穂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "友木は潜り戸や裏木戸に手をかけて見たが、ビクともしなかった。",
              "citation": {
                "source": "罠に掛った人",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "潜り戸に隙があって、押すと訳なく開いた。",
              "citation": {
                "source": "罠に掛った人",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "友木は潜り戸を押し開けて、中庭を走りながら、もしやその辺に血に染んだ短刀を持った伸子が気絶でもしてはいないかと、眼を忙しく動かした。",
              "citation": {
                "source": "罠に掛った人",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もしお急ぎでしたら、彼方の製本に出す雑書の中を探して頂きましょう」　鎮子に示された右手の潜り戸を上げると、その内部の書架には、再装を必要とするものが無雑作に突き込まれていて、ただＡＢＣ順に列んでいるのみだった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近この潜り戸を通った人物を御記憶でしょうか」「マア、そんな事ですか。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "間も無く、ちり、りんと鈴が鳴つて、門の潜り戸が幽かに開いた。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると至極交通に便なところへ出る」　と博士は、壁の釦を押し、壁に仕掛けてあった秘密の潜り戸を開いて、指した。",
              "citation": {
                "source": "毒瓦斯発明官",
                "author": "――金博士シリーズ・５――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
