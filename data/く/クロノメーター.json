        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "望遠鏡の焦点面に平行に張られた五本の蜘蛛の糸を横ぎって進行する星の光像を目で追跡すると同時に耳でクロノメーターの刻音を数える。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日午前十一時とかに東京天文台から放送される時報を受け取ってクロノメーターの時差を験するためである。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いい塩梅に精巧なクロノメーター式の導火装置は、帆村と私の手で取除くことができた。",
              "citation": {
                "source": "獏鸚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
