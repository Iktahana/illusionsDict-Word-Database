        "examples": {
          "standard": [
            {
              "text": "クルド人は独自の言語と文化を持つ中東の民族だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人はクルド人のルーツを持っており、彼の話は興味深い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "国際的な会議で、クルド人の代表者が現状を訴えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "トルコマン族は常に、クルド族及びアラビア族と闘っているが、後者はしばしばやって来て、彼らの家畜の角を折り、また彼らの妻や娘を奪い去るのである２）。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一例をいえば、彼の作品中最大の人気者である「スペックルド、バンド」（この作はオブザアヴア誌の人気投票などでも第一位を得ている）から深夜の密室に悪魔を待伏せする恐怖、異様の口笛、まだらの蛇などのスリルをのぞいて、いったい何が残るのであるか。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者諸君、諸君はこの話を読んで、ポオの「モルグ街の殺人」やドイルの「スペックルド・バンド」を聯想されはしないだろうか。",
              "citation": {
                "source": "Ｄ坂の殺人事件",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
