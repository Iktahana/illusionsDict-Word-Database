        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "陳列されてある商品全部が自分のもので、宅へ置ききれないからここへ倉敷料なしのただで預けてあると思えば、金持ち気分になりすますことも容易である。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お神は置き場がないので、倉敷料を払って質屋の倉へ預けるのだとか、番頭に頼んで手入れをしてもらうのだとか言っていたが、実は手元の苦しい時の融通であることもだんだん銀子に解って来た。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒川俊子嬢は広島県豊田郡本郷町の出身で、尾道高等女学校を卒業して、東京共立女子専門学校本科二年在学中、昭和十三年十月二十五日倉敷病院で腹膜のため亡くなつたのである。",
              "citation": {
                "source": "追悼記",
                "author": "原杞憂",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴木氏が以前｜備中の倉敷在にゐる或る友人を訪ねた事があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "児島虎次郎氏に４・13（夕）　この十四日から三日間、中之島の公会堂で作品展覧会をする児島虎次郎氏には、倉敷の大原孫三郎氏といふ保護者があるので、その暢気な生活ぶりは、貧乏人の多い洋画家仲間に大分羨ましがられてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その本に序文を書いておられる有名な倉敷労働科学研究所の暉峻義等氏でさえ、著者がその点にふれていないことには言及しておられないのである。",
              "citation": {
                "source": "職業婦人に生理休暇を！",
                "author": "――自然なことを自然なように――",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉敷にあった研究所は大原氏の手を離れて東京へ来て、日本労働科学研究所となり、やがて財団法人になるとこの所長は云っている。",
              "citation": {
                "source": "日本の頭脳調べ",
                "author": "――特に自然科学者に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉敷には有名な大原コレクションがありますが、この倉敷で文化講演会があっても、総同盟あたりが締めつけにしている工場では、工場というところは働くためのところです、とポスター一つはせらず、講演会へ娘たちを出してよこしません。",
              "citation": {
                "source": "社会と人間の成長",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉敷の妹からも、その途中彼に立寄ってくれと云って来た。",
              "citation": {
                "source": "永遠のみどり",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "……倉敷の姪たちへの土産ものを買いながら、彼は何となく心が弾んだ。",
              "citation": {
                "source": "永遠のみどり",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉敷駅の改札口を出ると、小さな犬を抱えている女の児が目についた。",
              "citation": {
                "source": "永遠のみどり",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "●昭和二十一年四月四日　東京都大森区馬込東二ノ八九九末田方より　倉敷市元町四二七　深川恭子宛　卅日に上京した。",
              "citation": {
                "source": "書簡",
                "author": "家族・親族宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十五日か六日に出発、途中倉敷と本郷へ立寄りますから広島へ着くのは卅日頃となるでせう。",
              "citation": {
                "source": "書簡",
                "author": "家族・親族宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの絵ならたしか倉敷に行けば見られるはずだつた。",
              "citation": {
                "source": "氷花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、彼は倉敷の妹のことも思ひ浮べると、無性にそこへ行つてみたくなつた。",
              "citation": {
                "source": "氷花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉敷駅で下車すると、彼ははじめて、静かな街にやつて来たやうな気持で、あたりの空気を貪るやうに吸つた。",
              "citation": {
                "source": "氷花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういふわけか倉敷の二人の姪の姿が心を温めてくれるやうであつた。",
              "citation": {
                "source": "氷花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉敷の妹からも、その途中彼に立寄つてくれと云つて来た。",
              "citation": {
                "source": "永遠のみどり",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "……倉敷の姪たちへの土産ものを買ひながら、彼はなんとなく心が弾んだ。",
              "citation": {
                "source": "永遠のみどり",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉敷駅の改札口を出ると、小さな犬を抱へてゐる女の児が目についた。",
              "citation": {
                "source": "永遠のみどり",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "山口、倉敷の学校は同じく明倫と名けたが、堂と云はずして館と云つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "日当りのいい部屋だってね」「ええでも先から知ってるの、とってもひどい階子よ」　倉敷で本を買って来て私に一冊くれ（代金こちらもち）あといく冊か「これはうちの」とかくすようにする。",
              "citation": {
                "source": "日記",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この七日にはどうしても帰京しなければならない用事がある上、こんどはどうしても倉敷の美術館にいってエル・グレコの「受胎告知」を見てきたいので、奈良には三四日しかいられないことになりました。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、帰りみち、途中で日がとっぷりと昏れ、五条野あたりで道に迷ったりして、やっと月あかりのなかを岡寺の駅にたどりつきました……　あすは朝はやく奈良を立って、一気に倉敷を目ざして往くつもりです。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「セガンティニは僕はあの倉敷の美術館にあるのしか知らないな。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "作州｜英田郡｜海内村田中氏の文書に「倉敷山下において成行の処云々」、江州八幡の天正十四年の文書には、宛名を安土山下町中としてある。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえりに倉敷で一寸おりて大原コレクションを見ようかと思いましたが、これまた汽車のつづきがわるくて、あのあたりで急行にのりついだりしたら、立って東京迄かえらなければならないでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "代価を過分――といっても、材木や、薪として売り飛ばすよりは過分な代価を払っての上に、倉敷料としての見つもり若干を与えて、そのままにし、季節に実を取るだけの約定なのだから、売ってかえって保護をされているようなもの――取引も至極円満に進行して行きました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ聴けよ、鶏啼くらしき。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の日なかのにくしみに、泣かぬ君ゆゑその唇に青く、黄の粉の恐ろしきにくらしき翅をすりつくる。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
