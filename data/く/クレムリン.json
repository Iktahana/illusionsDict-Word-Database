    "definitions": [
      {
        "index": 1,
        "gloss": "Kremlin (citadel in Moscow)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "白濁した河の向うの塵埃の多い淡褐色の丘の上に、金色に塗られた丸いクレムリンのドウムが見える。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "クレムリンの建築は赤黒い刺繍を見ているようで奇怪な面の感じである。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その悩みと望みと、クレムリン宮殿の外壁と劇場広場の鳩とに、資本家のない国はあたらしいダイナモのような力と、生硬と、自己期待と、宗教的感激とをもって沈黙のうちに運転している。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "グジコフ筆「窓の静物」とガボリュボフの「クレムリン」「雪景」。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "色彩的なクレムリンの塔と物見台、二千何百の教会――ナポレオンが踏んだであろう同じ土をふんでいる私に、いつしか過去の夢が取り憑いていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は見る、合図ののろしと家を飛び出てクレムリンへ逃げこむ蟻のような十二世紀の市民のむれを。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史と風雨で色のついた大クレムリンの石垣にそって、通行人と異臭のなかをイベリアンの門をくぐろうとすると、左の壁にマルクスの言葉「宗教は国民の亜片なり」が彫ってある。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒ずんだ円い囲いに苔が枯れ、中央の石柱には死刑囚をつないだ鎖がいまだに垂れさがって、段に立って振り返ると、ちょうど頭のうえにクレムリンの時計台、その前面に、大王が出御して死刑見物を享楽したという高楼が、多くを見てきたくせに黙りこくってそびえていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスクワのレーニン研究所所属レーニン博物館へ行ったものは、レーニンがウリヤーノフという本名で中学生だったころ、どんなに行状のよい優等生であったかを知るとともに、クレムリンに政府が引越して来てから、レーニンがどんな室に住んでいたかも、見ることが出来る。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "及び、これまでは革命前の通り、クレムリンに近い所謂劇場広場を中心として、モスクワ河の北（元の中心地域）に主な劇場があった。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "復活祭・降誕祭は、反宗教宣伝の日となり、クレムリンの外壁にあった辻堂などもとりはらわれた。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "クレムリンの古めかしい壁の外をギーとまわって、菩提樹の下にベンチの並んでいる公園の横を通り、電車は次第に工場の多い区域に進みます。",
              "citation": {
                "source": "従妹への手紙",
                "author": "――「子供の家」の物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "クレムリンの時計台にとりつけられたラジオ拡声器は絶えずピアノ行進曲を広場中に撒きちらし、「帝国主義とファシズムの犠牲者に　階級の兄弟プロレタリアートからの　挨拶を！",
              "citation": {
                "source": "勝利したプロレタリアのメーデー",
                "author": "――モスクワの五月一日――",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　クレムリン城内と向いあって、四角にモスストロイ（モスクワ土木課）がある。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "後は日の照りつけるクレムリンの壁だ。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス國の金笏かロムバアデイの鐵冠か全歐洲の大權か榮華のはてと今ぞ見る夕日の影はクレムリン（十）なれが淋しき塔の上。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月七日（土曜）　朝十二時頃よりクレムリンの中の歴史博物館へ行ったが、ブブノワ女史の紹介して呉れた人居ず。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのままクレムリンをずっと見ながら抜けて、モスクワ河を彼方岸へ出て、エハガキにあるような位置から、クレムリンを眺めた。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "クレムリンの持って居る色彩。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○今日はモヤの誕生日にして、自分コムナールで、カビヤ、オッカ、鶏、カウカーズ〔コーカサス〕の店でスリッパなど買い、散々クレムリンを歩いた揚句だからクタクタになって部屋へ戻った。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここ、クレムリンへ入る陸橋をとおして、ずっと下り坂になった彼方の展望よろし、　雪、黒い立木、スキーをする男の子、スレッジをする小さい子、犬をつれた女、　きのう一人で散歩したとき居た男が、やはりトウェルスカヤ〔街路名、現在のゴーリキー通り〕の先のところで、松の枝を売って居た。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔欄外に〕　泣いた顔を洗ってベゲテリアン食堂へ行き、宿へ一寸かえってから、クレムリンの方へＹずんずんゆく。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "クレムリンの壁に※1917―1928と巨大なイルミネーションがともって、暗い空に赤旗が翻って居る感じ、赤いイルミネーションで群集が体は暗く、顔だけ赤くうき立たせて散歩する感じ。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはクレムリンの中が引越して来る筈の新建築。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月十八日　金　朝 ВОКС へ集ってクレムリンの見物。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "新クレムリン宮殿は、突兀たる氷山の如く擬装されてあった。",
              "citation": {
                "source": "地軸作戦",
                "author": "――金博士シリーズ・９――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この新クレムリン宮も、あと三時間以内には水中に没するぞ。",
              "citation": {
                "source": "地軸作戦",
                "author": "――金博士シリーズ・９――",
                "note": "青空文庫"
              }
            },
            {
              "text": "宰相は、新クレムリン宮を後にするに際して、委員の一人をしてネルスキーに叱責の言葉を伝達せしめられた。",
              "citation": {
                "source": "地軸作戦",
                "author": "――金博士シリーズ・９――",
                "note": "青空文庫"
              }
            },
            {
              "text": "従而エスパニヤ軒の酒場といへば一般にいはゆる酒場と種類も品格も異るやうに言はれてゐるが、クレムリン宮殿や法王庁の内部にすら当然の疑惑と憶測の横行しやすい今日、田舎の話にしてからが聊か迂闊千万である。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            }
          ]
        }
