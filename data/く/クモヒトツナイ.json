    "definitions": [
      {
        "index": 1,
        "gloss": "cloudless (sky)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
