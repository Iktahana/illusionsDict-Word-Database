        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "外では、星が冴え冴えと輝き、空には雲ひとつない。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "健康を考えると雲ひとつない快晴でなければ外へ出られず、訪ね来て単調な毎日を打破してくれる友人もない。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "日がぱあつと當つて、それがまだ何物をも温めてゐない、もうかなり肌寒いやうな朝など、起き拔けにふところ手をして山を見に出ると、そんな朝は淺間はきまつて雲ひとつない山肌を冷え冷えと見せてゐる。",
              "citation": {
                "source": "初秋の淺間",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には雲ひとつない位に晴れ切った日だった。",
              "citation": {
                "source": "風立ちぬ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "舟の底に横になり、雲ひとつない青空を眺めていると、長いこと忘れてきた平静さに吸い込まれるようにおもわれた。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だんなさま、このとおり雲ひとつない上天気でございます。",
              "citation": {
                "source": "大根とダイヤモンドの話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "目がクラクラ、胸がドキンドキンして、あまりいいお天気の日など、雲ひとつないうらうらと晴れ渡った群青の大空から、今にもなにかこう世界中をぶッ潰してしまいそうな大きな大きなガラス玉でも転がり落ちてきそうな気がしてたまらなく恐ろしかった。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "大気は澄みきっていて、雲ひとつない青空に、太陽だけが白く輝いている。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲ひとつない蒼空から霧のように降りこめる陽のひかりに、庭木の影がしんとしずまって、霜どけのまま乾いた土がキチンと箒の目を見せている。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨あがりの上天気で、きょうもさぞ暑くなりそうな、雲ひとつない曙の空に、有明月が残っている。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "蕃拉布",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲ひとつない空の一角に、キラリと銀翼が光つた。",
              "citation": {
                "source": "美談附近",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽はぎらぎらと照り、雲ひとつない無慈悲な空は黒いと言ってもよく、あたかも足元の真っ黒な沼地を映すかのようだった。",
              "citation": {
                "source": "ダゴン",
                "author": "DAGON",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋭い雷声を合図に、白い雲ひとつないその天空に打ち揚げられ、細かな白金の矢をきらめかせ茶褐色の煙をただよわせて、透明な、はてしない大空の滴るような紺青のなかに溶け、音もなく消えて行く花火。",
              "citation": {
                "source": "昼の花火",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三の一　雲ひとつない空にこうこうと月がかがやいていた。",
              "citation": {
                "source": "峠の手毬唄",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道をはさむ林は深くなってそよ風も通わなくなり、日光は雲ひとつない青空からじりじりと照りつける。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の青春はまだ雲ひとつない空のように青い。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
