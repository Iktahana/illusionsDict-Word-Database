    "definitions": [
      {
        "index": 1,
        "gloss": "traveling patent-medicine salesman",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
