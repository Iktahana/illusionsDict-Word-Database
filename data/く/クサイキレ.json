    "definitions": [
      {
        "index": 1,
        "gloss": "strong smell of grass (esp. in summer heat)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何しろ路傍の草いきれが恐しい、大鳥の卵見たようなものなんぞ足許にごろごろしている茂り塩梅。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "難儀さも、蛇も、毛虫も、鳥の卵も、草いきれも、記してあるはずはないのじゃから、さっぱりと畳んで懐に入れて、うむとこの乳の下へ念仏を唱え込んで立直ったはよいが、息も引かぬ内に情無い長虫が路を切った。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十｜里まはりに笠三｜蓋と諺にも言ふ、その笠三｜蓋とても、夏は水のない草いきれ、冬は草も見ぬ吹雪のために、倒れたり、埋れたり、行方も知れなくなつたと聞く。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "草いきれは幻の煙を噴く。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちかきころ水無月中旬、二十日余り照り続きたる、けふ日ざかりの、鼓子花さへ草いきれに色褪せて、砂も、石も、きら／＼と光を帯びて、松の老木の梢より、糸を乱せる如き薄き煙の立ちのぼるは、木精とか言ふものならむ。",
              "citation": {
                "source": "紫陽花",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "新前橋驛野に新しき停車場は建てられたり便所の扉風にふかれペンキの匂ひ草いきれの中に強しや。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はげしい草いきれと、土の匂の中に顔を押付けたまま、彼は長い間、泣いた。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "息もつかず、もうもうと四面の壁の息を吸って昇るのが草いきれに包まれながら、性の知れない、魔ものの胴中を、くり抜きに、うろついている心地がするので、たださえ心臓の苦しいのが、悪酔に嘔気がついた。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月　向日葵、向日葵、百日紅の昨日も今日も、暑さは蟻の數を算へて、麻野、萱原、青薄、刈萱の芽に秋の近きにも、草いきれ尚ほ曇るまで、立蔽ふ旱雲恐しく、一里塚に鬼はあらずや、並木の小笠如何ならむ。",
              "citation": {
                "source": "月令十二態",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ路傍の草いきれが可恐しい、大鳥の卵見たやうなものなんぞ足許にごろ／″＼して居る茂り塩梅。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "難儀さも、蛇も、毛虫も、鳥の卵も、草いきれも、記してある筈はないのぢやから、薩張と畳んで懐に入れて、うむと此の乳の下へ念仏を唱へ込んで立直つたは可いが、息も引かぬ内に情無い長虫が路を切つた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まわりにはいよ／＼草いきれが立ちかけて、露で粘っていた葉と葉とが、ぴん／＼はね弾けます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓地は無縁の草いきれ、また、ねもごろの水かげろふ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "額髪の女童も交りて、ほつほつと、ひとりひとりに、軽き提げ重きはかつぎて、あなかなし五浦少女、草いきれ暑き小径を、潮しぶく東の磯の潮見堂、その母家まで、山越え野越え。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに光り輝く光線、風、草いきれ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "強い強い草いきれである。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年はもちろん健脚らしく、僕も足の弱い方ではないが、なにしろ七月の日盛りに土の焼けた、草いきれのする田舎道をてくるのだからたまらない。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "若々しい青葉の晩春で、搾りたての牛乳を流したような靄が草いきれを含んで一面に漂っていた。",
              "citation": {
                "source": "機関車",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれ、と心をまず丹田に落つけたのが、気ばかりで、炎天の草いきれ、今鎮まろうとして、這廻るのが、むらむらと鼠色に畝って染めるので、変に幻の山を踏む――下駄の歯がふわふわと浮上る。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑い日が草いきれで汗びつしりに成つて居る彼等の身體に時刻が過ぎたと枝の間から強い光を投掛けて促す迄は、稀には痺れた足を投出して聞きも聞かせもしなくて善い噺を反覆してのみ居るのである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "擽るような五月の軟風が咽せかえるばかりの草いきれを孕んで来て、かるく、白木綿の窓帷を動かしていた。",
              "citation": {
                "source": "都会地図の膨脹",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸す様な草いきれと、乾いた線路の土砂の反射する日光とで、額は何時しか汗ばんだ。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸す樣な草いきれと、乾いた線路の土砂の反射する日光とで、額は何時しか汗ばんだ。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝晩は東京の四月頃の陽気であったが、昼になると、急に真夏のような強い太陽の光熱が目や皮膚に沁通って仄かな草いきれが、鼻に通うのであった。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "出血する叢や、黄金の草いきれが、かれらの皮膚を浸した。",
              "citation": {
                "source": "鳥獣剥製所",
                "author": "一報告書",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏などは東京座や川上座へゆくには、道が暑くてたまらないほど小蔭ひとつない草いきれのしている土地であった。",
              "citation": {
                "source": "マダム貞奴",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "咽ぶほど強烈な草いきれや、茸のかおりが鼻につく、私はそれを貪るように吸い込む。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これですか、機械おおいは……」　千二少年は、機械の上にかけてあった油くさいきれをとって、いい気な博士の肩にかけてやった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
