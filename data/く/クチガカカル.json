          "literary": [
            {
              "text": "今では二人で六十円も取ってくれるし、おたねはおたねで、こんな器量よしやけに、ええ所から口がかかるしな。",
              "citation": {
                "source": "父帰る",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "日立からの口がかかるまでは、科学分野を中心にしたライターになれないかと考えていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、新聞記事などによると、落ちたミスたちにも、これが機会となって、ずいぶん諸方から良いお嫁のくちがかかるそうである。",
              "citation": {
                "source": "押入れ随筆",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
