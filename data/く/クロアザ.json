        "examples": {
          "standard": [
            {
              "text": "彼女の頬には、チャームポイントのような小さな黒あざがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の背中にある黒あざが、成長と共に少し大きくなった気がする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "医者は、その黒あざは特に心配ないと言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一山いくらのお皿の上には、まっ黒くなったバナナだの、青かびのはえかけたみかんだの、黒あざのできたりんごだのがのっていました。",
              "citation": {
                "source": "水菓子屋の要吉",
                "author": "木内高音",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いたことに黒あざの痕跡がない。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、うしろから、半面黒あざになった男の首がにらんでいた。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
