    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gathering of haiku poets",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこに某社中の俳句会が開かれたのである。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "△放浪によりてえたる貧しき収穫より――旧作□美しき人を泣かして酒飲みて調子ばづれのステヽコ踊る旅籠屋の二階にまろび一枚の新聞よみて一夜をあかす酒飲めど酔ひえぬ人はたゞ一人欄干つかみて遠き雲みる酔覚の水飲む如く一人に足らひうる身は嬉しからまし　　　　　　　△　△　△△先日の句会では愉快でした。",
              "citation": {
                "source": "雑信（二）",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――夜は句会、とほる君、箕三楼君、入雲洞君、そして私、つゝましい、たのしい会合だつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉翁の行脚は、私たち俗人から見れば、ほとんど蕉風宣伝のための地方御出張ではあるまいかと疑ひたくなるほど、旅の行く先々に於いて句会をひらき蕉風地方支部をこしらへて歩いてゐる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五人のもの、毎夜ここに集い、句会をひらいているというのである。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉士、月狂、天馬と僕との四人が集まって句会でもやる時にはきまって誰か一人が遅れるか欠席した。",
              "citation": {
                "source": "四五ニズム述懐",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "句会がはねて、喫茶店でお茶でも飲んで、その次はさてどうするかと云ふことになると、皆で二三十分も迷った。",
              "citation": {
                "source": "四五ニズム述懐",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し例の俳句会には無之候。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅沢君は若いときから俳句の趣味があったが、七、八年前からいよいよその趣味が深くなって、忙しい閑をぬすんで所々の句会へも出席する。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "自宅でも句会をひらく。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の俳句会ならば無論に欠席するのであるが、それではないとわざわざ断り書きがしてある以上、何かほかに趣向があるのかも知れない。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "当夜の非番で、村の或る家の俳句会に出席した帰り路である。",
              "citation": {
                "source": "鴛鴦鏡",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬坡もわれわれの俳句仲間であるが、今夜の句会には欠席してこんなところに来ていたのである。",
              "citation": {
                "source": "鴛鴦鏡",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この春になってから、冬坡がとかくに句会を怠けがちであったのも、そんな捫着のためであったということが今わかりました。",
              "citation": {
                "source": "鴛鴦鏡",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ氏は信州の日本アルプスに近い某村の小学校教員を勤めていて、土地の同好者をあつめて俳句会を組織しているので、私の所へもときどきに俳句の選をたのみに来る。",
              "citation": {
                "source": "雪の一日",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になって句会がある。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後四時、第三回洋上句会がある。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋上句会第四回があった。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に昨日の俳句会の会稿らしき者｜載せあり。",
              "citation": {
                "source": "明治卅三年十月十五日記事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋空一碧、今夜の月はうつくしからう、結庵三度目の名月、観月句会を催ほすのである。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の井師五十歳祝賀句会へ打電――アキゾラハルカニウレシガルサントウカ野菊、りんだう、石蕗、みぞそばの花、とり／″＼に好きだ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……午後、約束通りに山口の周二居へ出かける、君の入営送別句会を催ほすといふのである、句会といつたところで、家族の方々と会談して名残を惜しまうといふのである。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は雑草句会、例によつて例の如し。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "山口の句会へ行く、椹野川づたひに歩いて行つた、春景色、そして私は沈欝であつた、いつ訪ねても周二居はしづかであたゝかである、湯田温泉も私のかたくなにむすぼれた身心をほぐしてくれた、おいしい夕飯をいたゞいて、若い人々と話して、終列車で戻つた、まことによい一日一夜であつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "やまぐちの会へ出かける、途上、老乞食に逢ふ、彼と私とは五十歩百歩だ、いつものやうに湯田で入浴、ああ温泉はありがたい、Ｓさんのお宅でよばれる、うまかつた、それから句会、Ｋさん、Ｈさん、Ａさんの青春をよろこぶ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時過ぎて周二居訪問、いつものやうに本を借り御馳走になる、そして句会。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中漫談　　　　　九月廿八日の行乞中の特種――□西村のお嬢さんに句会の事を話さうと思つて立寄つたら、女中さんがあはてゝ皿に米を盛つてくれた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪中吟行、神戸大阪の同人といつしよに、畑の梅林へ、梅やら雪やら、なか／＼の傑作で、忘れられない追憶となるだらう、西幸寺の一室で句会、句作そのものはあまりふるはなかつたが、句評は愉快だつた、酒、握飯、焼酎、海苔巻、各自持参の御馳走もおいしかつた。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の北朗居は賑やかだつた、句会といふよりも坐談会だつた。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体に青味の勝った暗い絵で、顔が画面一杯に大きくかいてあった。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
