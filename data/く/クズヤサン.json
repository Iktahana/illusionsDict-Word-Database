        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すると真夜中すぎになって、どこかで、「もしもしくず屋さん、くず屋さん。",
              "citation": {
                "source": "文福茶がま",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「くず屋さん、そんなにおどろかないでもいいよ。",
              "citation": {
                "source": "文福茶がま",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは、貧乏のくず屋さんだ。",
              "citation": {
                "source": "雪の降った日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの人ですか、くず屋さんです。",
              "citation": {
                "source": "雪の降った日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんと正直なくず屋さんではありませんか。",
              "citation": {
                "source": "雪の降った日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "きよが、田舎から帰ると、お母さんは、くず屋さんがとどけてくれた手紙をお渡しになりました。",
              "citation": {
                "source": "雪の降った日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女のくず屋さんが、とどけてくれたのです。",
              "citation": {
                "source": "雪の降った日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "話をきくと、そのくず屋さんは、夫に死なれてから、二人の子供を育ててきたのだそうです。",
              "citation": {
                "source": "雪の降った日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お母さんが、くず屋さんのお家をきいておいてくださったので、きよは、お礼にいくのに、そう捜して歩かなくともよかったのです。",
              "citation": {
                "source": "雪の降った日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、くず屋さんの家はじきわかったが、表の戸が閉まっていました。",
              "citation": {
                "source": "雪の降った日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母さん、あのくず屋さんがきたら、僕のいらないおもちゃと、絵本をやってね。",
              "citation": {
                "source": "雪の降った日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　善吉が、こう答えると、信一は、目をまるくして、「いまなら、くず屋さんにやると、いいんだね。",
              "citation": {
                "source": "赤土へくる子供たち",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
