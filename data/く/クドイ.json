[
  {
    "uuid": "39af7b88-ab82-5fbf-be0c-aad2637e6ccd",
    "entry": "諄い",
    "reading": {
      "primary": "くどい",
      "alternatives": [
        "クドい"
      ],
      "is_heteronym": false
    },
    "grammar": {
