    "definitions": [
      {
        "index": 1,
        "gloss": "using the strongest words possible",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕の詩の中では、郷土望景詩數篇が最も氣に入つたらしく、口を極めて賞讚してくれた。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）當時文壇の名家等は、口を極めて「思ひ出」を激賞した。",
              "citation": {
                "source": "名詩集「思ひ出」の眞價",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文弱と言つてなげいてゐたひともあつたやうでございますし、なんと優雅な、と言つて口を極めてほめたたへてゐたひともございました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊びも気が利き、宴席などの濶達自在な振舞いを口を極めて讃美した。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、私は私を悪評した人の文章を、腹いせ的に悪評して、その人の心を不愉快にするよりは、その人の文章を口を極めてほめるという偽善的態度をとりたいくらいである。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "口を極めて彼らは李陵の売国的行為を罵る。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今口を極めて李陵を讒誣しているのは、数か月前李陵が都を辞するときに盃をあげて、その行を壮んにした連中ではなかったか。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔子がいつも口を極めて賞める顔回よりも、むしろ子貢の方を子路は推したい気持であった。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや……お手柄じゃったお手柄じゃった……」「まことにお手際で御座いました」「ハハハ……平馬殿はこう見えても武辺一点張りの男じゃからのう……」　二人は口を極めて平馬を賞め上げながら盆を重ねた。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、一昨年、私が或る老婦人の手記を中心にした創作を書いた時には口を極めて賞讃されました。",
              "citation": {
                "source": "江戸川乱歩氏に対する私の感想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "罰というものはあのような奴に当るものじゃ」　と口を極めて悪態を吐いていたが、あんまり度々云うので筆者はその科白を暗記してしまった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日のような『大仏供養』を見た事がない」　と楽屋で老人連が口を極めて賞讃したのに対し翁はタッタ一言、「ウフフ。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、酔が廻って来ると、彼等がもうあと三年いるべき学校を、口を極めて罵倒した。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "……むろん崑崙茶といったら、お茶仲間の評判の中心で、魅惑のエースと認められている事だし、お出入りのお茶屋が又チャンチャン一流の形容詞沢山で……崑崙茶の味を知らなければ共にお茶を談ずるに足らず……とか何とか云って、口を極めて誘惑するんですから、下地のある連中はトテモたまりません。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は猶口を極めて小室の人柄を褒め、思遣り深い殿樣、下々の思ひつきのよいことまで言うて、かういふことになるのも全く神々の御計らひ眞に有難いことやと涙を拭いて悦んだも無理ならぬことである。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、井伏の高邁なる自信を口を極めて賞讚すると同時に、弟の不甲斐なさを嘆じて遂に彼を泣かせてしまつた。",
              "citation": {
                "source": "彼に就いての挿話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「町から来たる妻に、口を極めて罵らる。",
              "citation": {
                "source": "病状",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一刻前以上に口を極めて、偉さうに意味あり気な言葉ばかりを連ねて周子を非難した。",
              "citation": {
                "source": "秋・二日の話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今後彼の悪口を云ふ友達に出遇つたら、自分は口を極めて反対するであらう。",
              "citation": {
                "source": "松竹座を見て（延若のこと）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "飮仲間の父に對つてはいつも自分のことを賞めそやして、貴君は少し何だが、御子息はどうして中々のものだ、末恐しい俊童だ、精一杯念入にお育てなさるがいゝ、などと口を極めて煽てるので、人の好い父は全くその氣になつてしまひ、いよいよ甘く自分を育てた。",
              "citation": {
                "source": "古い村",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "父母はこの一二年前よりの自分の成績の惡くなつたことを口を極めて叱責し、聲をひそめて、初太郎を見ろと言つた。",
              "citation": {
                "source": "古い村",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "房州半島と三浦半島とが鋭く突き出して奥深い東京湾の入り口を極めて狭く括つてゐる。",
              "citation": {
                "source": "岬の端",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "抱一は好き嫌いの劇しい感情家であったが、紅葉が大嫌いで、談紅葉に及ぶごとに口を極めて痛罵するので、その度毎に、「君は喰わず嫌いだよ。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この難解の訳文を平易に評釈して世間に示し、口を極めて原作と訳文との妙味を嘖々激称したは石橋忍月であった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ済まぬ事をしたと、朝飯もソコソコに俥を飛ばして紹介者の淡嶋寒月を訪い、近来｜破天荒の大傑作であると口を極めて激賞して、この恐ろしい作者は如何なる人物かと訊いて、初めて幸田露伴というマダ青年の秀才の初めての試みであると解った。",
              "citation": {
                "source": "露伴の出世咄",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "『をけら詣』は、極月大晦日の夜、京都八坂神社に、元朝の齋火を貰ひに參詣するものが、道の摺違ひに互ひに見ず知らずの男女に、口を極めて惡態を吐き合ふ事實を辨へた上でないと、何を歌つたのか一寸見當がつき兼ねませう。",
              "citation": {
                "source": "詩集の後に",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだまだ数え立てると限りもないが、要するにトドの詰まるところ文化生活の理想は何かと考えて来ると、彼等が学生や腰弁時代に口を極めて罵っていた、ブルジョアの金殿玉楼生活だという事になるようである。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "勉助の態度が余りに礼儀に欠けてゐるのが不快なので、わたしが無口になつてゐると、彼はわたしが兄妹等に対して親の恩でもかさに着て、わがまま三昧に増長してゐる――と現に姉妹共は口を極めて罵つたこともあるのだ。",
              "citation": {
                "source": "茜蜻蛉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛読に値する二人の新しい作家を同時に友達に得られるなどとは私にとつては全く稀有の現象だつたが、大分前に私は枝原の或る小篇を亦、あまり口を極めて推賞しすぎたゝめに、彼は近頃嘗ての私の賞讃辞をおそれて、創作気分に頓坐を来してゐた。",
              "citation": {
                "source": "泉岳寺附近",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローラは次々に展開されて来る新しい風景を口を極めて賞め讚へながら――、「去年のロメリアで、先生達と一緒にレーキ・サイドへ行つた時に見た景色に似てゐる。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
