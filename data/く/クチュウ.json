[
  {
    "uuid": "14a5ba70-d8a4-5ac6-8e43-d3a4e1765274",
    "entry": "苦衷",
    "reading": {
      "primary": "くちゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
