[
  {
    "uuid": "a44df0a0-6207-5eca-aa0e-b58db26c60b9",
    "entry": "黒酒",
    "reading": {
      "primary": "くろき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
