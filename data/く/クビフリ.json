        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あけてみると、まず第一に現われたのは首振り人形。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに味をしめて、さかゆきをするたんびに、おせんべやの店へとりにゆくと、首振り婆さんは、私の家の門の桜の木の上へ出そめた三日月を指さして、「のん、のん、此処にも、あすこにも。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "町の構成",
                "note": "青空文庫"
              }
            },
            {
              "text": "機嫌のよい女中におぶさって帰ってくると、すぐおせんべやの首振りお婆さんに見せにいった。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "町の構成",
                "note": "青空文庫"
              }
            },
            {
              "text": "首を傾ける度に、骨が可なり大きな音を立てゝ鳴るのが、老僧の昔しからの特徴で、右に左に、首振り人形のやうにすると、骨がコトン／＼と鳴つた。",
              "citation": {
                "source": "ごりがん",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "この面白い首振りのところで、茂太郎が、ふっと蘆管の吹奏をやめてしまったのは惜しいことです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「イヤや」と私は、眼エつぶったまま強う首振りました。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「イヤや」と私はまた首振りました。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
