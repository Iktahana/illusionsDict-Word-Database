        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "同じくびっくりした壁の前のギャルソンは、急いでその方へ駆けて行ったが、すぐ一抱えにクラッカーの束を持って来て、テーブルの上へ投げ出した。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝肉祭　もう、そのとき、クラッカーを引き合って破裂させる音は、大広間一面を占領し、中から出た玩具の鳴物を鳴らす音、色テープを投げあうわめき、そしてそこでも、ここでも、※々として紙の冠りものを頭に嵌めて見交し合う姿が、暴動のように忽ち周囲を浸した。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "半島の岩礁はメトロポール、白砂はクラッカー・クリーム。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "食卓には日本製の造花を飾り、皿にクラッカーと紙旗とをのせたのを並べてある。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこからかクラッカーが鳴り、ふたたび灯がつく。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志と長田が、クラッカーを鳴らす。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "義晴が、コカコーラの缶とクラッカーの箱を山崎に手わたした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこの前の大戦争の最中だったのでパンがなく、パンの代りにクラッカーを食べさせられたのには閉口いたしました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると思いがけなく、ソーダ・クラッカーというビスケットのようなもので、塩味のつよいものが、ぎっしりはいっていた。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに、ソーダ、クラッカーは、怪魚たちをよろこばせた。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソーダ、クラッカーをなげるたびに、数百ぴきの怪魚たちは水面から宙にはねあがり、落ちてくるクラッカーを途中で自分の口に入れようと争った。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それに　アナ・マライア　どうも　しなもの　まんびきしてる　――　あれだけの　クラッカー　どこいった？",
              "citation": {
                "source": "ジンジャー＆ピクルスのはなし",
                "author": "THE TALE OF GINGER AND PICKLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "デッキ・ゴルフに興じて喉がかわいている十一時のアペリチフ時刻になると、食堂のボーイが、大きな盆にすましスープの茶碗をたくさんならべ、クラッカーを添えて持ち廻り、客の取るに任せた。",
              "citation": {
                "source": "ブイヨン・ドンゾール",
                "author": "――十一時の肉の煮出し――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピーナツか、馬鈴薯を薄く切って揚げたものくらいですますことも出来るし、少し上等でも、クラッカーにペースト類を塗りつけて出す程度である。",
              "citation": {
                "source": "パーティ物語",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やむを得ず私は罐詰のスープ、デヴィルド・ハムやクラッカース等の食糧品や、石油ランプ、ナイフ、フォーク、スプーン等を注文した。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞之助達は、テーブルの上に数々の前菜、―――いつの間に用意してあったのか、鮭の燻製、アンチョビーの塩漬、鰮の油漬、ハム、チーズ、クラッカー、肉パイ、幾種類ものパン、等々がまるで魔術のように一時に出現して置き切れぬ程に並べられた光景を見ると、先ずほっとした形であった。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐々木ニスヽメラレテクラッカー二個ニクラフトチーズ少量ヲ添エテ食ベ、紅茶一杯飲ム。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "標的は、クラッカーだった。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "アニマル・クラッカーはひと箱だけ、そして残りは、丸くて薄い、さくっと砕けるソーダ・クラッカーだ。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "桟の横幅いっぱいにクラッカーの標的を並べては、端からひとつずつ、ぼくは撃ち砕いていった。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "標的を撃ちつくすと、クラッカーの箱を持って桟までいき、桟の上に残っているかけらをフロアに落とし、あらたに標的を並べ、デスクまで戻ってまた撃った。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "桟の上に、標的のソーダ・クラッカーが、ひとつだけ残っていた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガスのカートリッジを装填しなおしたぼくは、そのクラッカーに狙いを定めた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、丸いクラッカーを粉々に砕いた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "砕けたクラッカーは、飛び散った。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "フロアには、むこうの端からこちらの端まで、壁から一メートルほどの幅のなかに、砕けたクラッカーが敷きつめたかのようにびっしりと、白くあった。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その壁に沿って、フロアの上には、こまかく砕かれたクラッカーが、まるで敷きつめたかのように、広がって落ちていた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "フロアに置いてあったクラッカーの箱のなかから、いくつかのクラッカーをつまみ出した。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
