      {
        "index": 1,
        "gloss": "grass and straw (as fodder for horses, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
