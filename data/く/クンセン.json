          "literary": [
            {
              "text": "葷羶を食ふことを忌むに至つた後、邦人の思想は身體と共に變じたのを疑はない。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "佛陀は葷羶を禁じてゐる。",
