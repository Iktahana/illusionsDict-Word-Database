    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Mr",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だつて君そこに浮気があります浮気は悲しい音楽をヒヨツと忘れさせること度々です空　空　空やつぱり壁は土で造つたものでした。",
              "citation": {
                "source": "不可入性",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君は僕を、「ほがらか」でないといふ。",
              "citation": {
                "source": "酒場にて（定稿）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、輝き出でるや、諸君は云ひます、「あれでああなのかねえ、不思議みたいなもんだねえ」。",
              "citation": {
                "source": "酒場にて（定稿）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二※月くらゐして、やつぱりその同人の集りのあとで、谷君他三人ばかりが、円タクの中からオイデオイデをするから行つてみると、これから牧野さんを誘ひ出しに行くから乗れといふのである。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷君がこれから出掛けて飲みませんかといふと、出たさうだし出たくなささうであつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷君の方で早速遠慮を示したので、結局出掛けないことになつて、「では二階に行かうか、此処は子供が目を覚ますんで話が出来ないんだ」と牧野さんは云つた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラシックはテンポが遅いどころか、「ああした深いことをもう云つてのけたのか」と、君が若しミュジックなるものの存在に耳を触れるに相応しければ当然感ずる次第なのであつたかも知れない。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに猶、諸君も嫌ひではない冗舌は、此処に十分に按配されてをり、直き直きに抽象語を以てしなければ、かの「意味がない」と云つて嘯く、平盤な心情の人達のためには、十分哲学的学術的な言葉も此処には見出されるのである。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の我々の感性に近いもの、寧ろ民謡でさへある殉情詩が、此の殉情的な国で、今迄読まれなかつたなぞといふことは不思議だと、今度此の全集の第一巻が出た後では、諸君も必ずやさうお思ひになることと思ひます。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "草野心平詩集『母岩』中原中也　草野心平君の第三詩集『母岩』が出た。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "草野君の感覚は非常に正確なものである。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして草野君の仕事は何時も感覚第一になされてゐる。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "草野君は酒を飲んで酔ふと殆んどそのたびに眠る。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "草野君の感覚を僕は好きだ。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ舟にのりて行かば、くるほしきなみの亂れもここちよく、ちのみごの夜びえする、あやしきこゑもきかであるべきに、ふるとせひとにかくれて、わがはぐくみしいろぐさのはや涸れぬとぞ、けふきけば薄葉に涙しをるる、よしゑやし、悲しきものはあだがたき、君ならなくに、はやも我が世をのがれいでばや。",
              "citation": {
                "source": "浮名",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、いま新らしき遊戲は行はれ遠望の海さんさんたるにわれ諸君とゆびさし眺望してながく塔下に演説す。",
              "citation": {
                "source": "交歡記誌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君がもし一個の林檎に如何にも惚れ惚れとしたら、それを描きたくなるであらう。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "要は、その林檎に如何にもほれぼれとしたら諸君は芸術家だといふことだ。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直に云つて、だから辻野君の印象は私の中で、結局稀薄なものであつたのだが、今度訃報が来た時には、ハツと思つた。",
              "citation": {
                "source": "逝ける辻野君",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂはまたそれを感ずるから、「君等の考へてることは違ふ」とかなんとかいふ、とまれ形勢は悪くなるから、それ聴く方は漸く面倒臭がりだすから、尚も云はうとすれば声は次第に金切声になるとか、怒りつぽくなるとする。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さてはＢ君、俺の金がツケメかな」とＡ君が試みに思ふとする。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、「君の暮しが、もつと楽だつたらいいだらうなァ」。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だ、そんなことかと諸君は云はれるでもあらうが、まあまあ鳥渡待つて下さい。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も君なら君にそれを生んで呉れと要求するものはないのであるから、君がそれを生まうとなら、別して誠実でなければならないものを、文士の方が却て一般世人よりはよつぽど実がないとあつては、それで何が文学であらう！",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今仮りにそれをＡ君といふことにすると、Ａ君は云ふのだ。",
              "citation": {
                "source": "非文学的文士",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "通路を距てて直ぐの向ひ側には、鉄道従業員の妻君みたいなのが、胸をはだけて赤坊に乳を飲ませてゐる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなくんば、詩はただ技だけのことになつて、それでは、人々の心にとゞくものとならない。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "女　あゝ、あの河島さんは直きに、何処かへ行くんですつて。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "女　女は出来ない方がよくつたつて、出来ると言つて置くんだわ！",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあ、僕は失敬するよ」佐竹は小声でそう呟き、金側の腕時計を余程ながいこと見つめて何か思案しているふうであったが、「日比谷へ新響を聞きに行くんだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
