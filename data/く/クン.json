  {
    "uuid": "ca3c0a06-f5ca-56fb-b5b9-4ba17f73594b",
    "entry": "葷",
    "reading": {
      "primary": "くん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
