[
  {
    "uuid": "c759bd53-44e4-526f-b8a9-e150186d5e8e",
    "entry": "君",
    "reading": {
      "primary": "くん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "接尾辞"
