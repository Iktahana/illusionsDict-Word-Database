    "definitions": [
      {
        "index": 1,
        "gloss": "crank (mechanism)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
