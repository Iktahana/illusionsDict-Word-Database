    "definitions": [
      {
        "index": 1,
        "gloss": "member (of a group led by a kumigashira)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "踊の組子なら影の垣に引っ込されてスターにだけ浴せかけられる取って置きの金色照明を浴びたようで何だか恥かしい――わたしは威張って見えやしないだろうか。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、部屋の遠くのすみずみや、あるいは組子細工の円天井の奥の方は、どんなに眼を見張っても視力がとどかなかった。",
              "citation": {
                "source": "アッシャー家の崩壊",
                "author": "THE FALL OF HOUSE OF USHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枚の紙のみ張ってある組子の無い障子はこの間まで春風を心地よく受けてふわりふわりとしていた。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　秋葉の小平を捕頭にした、三十八人の組子に、町の彌次馬を加へてざつと六七十人の一隊は、錢形平次の家を中心に、神田明神下の町家を、虱潰しに家搜しを始めたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "頬の疵",
                "note": "青空文庫"
              }
            },
            {
              "text": "来るにしても、あの顎の長んがい野郎を始め、血のめぐりの悪い子分や、組子を二、三十人はつれて来るだろう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蔵屋敷　翌る六月一日、八丁堀組屋敷は早暁から門外を堅め、与力同心組子の数を尽して、真に鉄桶の人垣を作りました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕物頭は與力笹野新三郎、これは名目だけで、實權は錢形平次が握つたも同樣、それに淺草下谷から狩り集めた組子がざつと三十人。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "母娘巡禮",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十人の組子は、適當な間隔を置いて、八方から根岸に入りました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "母娘巡禮",
                "note": "青空文庫"
              }
            },
            {
              "text": "「や、己れツ」　闇の中に激しい爭ひは續きましたが、やがて自身番に待機した御用の提灯が一ぺんに飛んで出ると、錢形平次を捕頭に、五六人の組子の手に犇々と縛り上げられて居るのは、何んと、浪人の居留木角左衞門と飴屋の甚助とそして女後家のお大の三人ではありませんか。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お長屋碁會",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　　　　　　×　　　　　　×　これは大變な大捕物でしたが、八丁堀から與力笹野新三郎が出役、十二人の組子が夜中に足立屋を襲つて、主人徳右衞門を始め、女房のお種、それに新に入つた番頭手代などを捕へ、嚴重なお調べの上、一味五人、處刑されて落着しました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "金の番",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　　　　　　×　　　　　　×　その晩、兩國の料理屋、鶴喜の離室を借りて、年に一度の參會を開いてゐた道具屋の一隊は、石原の利助の子分を先鋒とする、八丁堀の組子に十重二十重に取圍まれ、多勢の怪我人まで拵へて、盡く召捕りになりました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "平次屠蘇機嫌",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「こいつは近頃の大捕物になりますが、組子の用意をお願ひいたします」「何人位？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "竹光の殺人",
                "note": "青空文庫"
              }
            },
            {
              "text": "錢形平次が捕頭で、手下の組子が十人、わざと眞晝を選んで、八方から一擧に岩根半藏の浪宅を圍んだのは、それから一刻ばかり後のことです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "竹光の殺人",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「こいつは近頃の大捕物になりますが、組子の用意をお願いいたします」「何人ぐらい？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "竹光の殺人",
                "note": "青空文庫"
              }
            },
            {
              "text": "銭形平次が捕り頭で、手下の組子が十人、わざと真昼を選んで、八方から一挙に岩根半蔵の浪宅を囲んだのは、それから一刻（二時間）ばかり後のことです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "竹光の殺人",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　その晩、両国の料理屋、鶴喜の離屋を借りて、年に一度の参会を開いていた道具屋の一隊は、石原の利助の子分を先鋒とする、八丁堀の組子に十重二十重に取囲まれ、多勢の怪我人まで拵えて、尽く召捕りになりました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "平次屠蘇機嫌",
                "note": "青空文庫"
              }
            },
            {
              "text": "御用聞、下っ引、狩り集めた組子の総勢は二十八人、銭形平次は治太夫を援けて、全部の掛け引の責任を持ったことは言うまでもありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "猿回し",
                "note": "青空文庫"
              }
            },
            {
              "text": "口幅ったいようだが、拙者剣は東軍流、槍は宝蔵院流、小太刀は卜伝流、ことごとく皆伝だ、曲者の十人や二十人に恐れる拙者では無い、拙者一人が道を塞げば、池の端の一本道で、此方の防ぎは大丈夫、今晩の組子はことごとく向う側へ行って宜しい。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "猿回し",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何処へ行く、お前は誰だ」　同心伊藤治太夫は二、三人の組子を従えてその前に立塞がりました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "猿回し",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の端妙月庵を襲った晩、二十八人の大勢の組子を狩り出した同心伊藤治太夫は、面目を失して引退り、その日は銭形平次たった一人に任せて、二度目の恥を掻く機会を避けたのは誠に賢いことでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "猿回し",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あッ、しまった牢やぶりがわかった」　そのとき風雨をついて、あわただしく板木がなるとつづいておこるホラ貝のひびき、半鐘の乱打、わめきたてる人ごえ、まさに牢番同心の連中は縄をといて、きゅうを囚獄与力｜石出帯刀につげ、たちまち役人組子をくりだして、嵐の夜中ながら、伝馬町じゅうの大そうどうになったのです。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "追いすがる二手、三手の組子はおもわぬ大猿に道をふさがれ、たじろぐ眼の前へ夜霧の煙幕、あれよあれよとじだんだふむばかりです。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、たったいま引込んだ関守の組子が、得物を携えて関屋の前後からバラバラと現われたかと見ると、弁慶の前後をとりかこんでしまったから、道庵が、またもあっと魂消ました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "道庵の魂消たのに頓着なしに、そこで関守の組子が弁慶の行手を遮ると、いったん引込んだ富樫がまた出て来て、「弁慶、待て！",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "組子は突棒、刺叉、槍、長刀を取って、弁慶に打ってかかるから、弁慶も金剛杖では間に合わず、ついに太刀の鞘を外して、縦横無尽にそれを斬り散らす騒ぎになったから、見物は喜びますけれど、道庵は身の毛をよだてました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "（まず窮民に仕事を）　と考えたことも、秀吉が、かつては、その窮民の子であった思いが、すぐ施策にも出たのであるし、なおまた、みすみす旧明智党の組子と知れている流離の者をも、大法事の工事に使うなどという寛度は、到底、信長には見られなかったところである。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "要所に、手配を伏せておく、かれが組子の岡ッ引ということは、うしろで見ている金吾の目にも分りましたが、「ム……そうか」　と何かうなずいて、囁き合うと、金吾をさし招いて釘勘はまたすぐにその横丁を走り出して、河岸ぷちへ出てゆく様子。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と――その目の前の往来を掠ッて、十四、五人ずつ二組ばかりの捕手と組子が、手に手に十手をしのばせて、忍川の川尻へ真ッ黒になって馳けて行く――。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この袋地では、釘勘が、夜半から暁にかからぬうち、きっと、日本左衛門を網の魚にしてみせるといい払って、宵から八方の暗がりへ組子を伏せていたのです。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに人影ありと見て、下の捕り物を組子にまかせ、自身屋上によじ登って来てみたところが、見当らぬ日本左衛門と万太郎とがそこに影を重ねていたので、猶予なく、うしろから差廻した十手の閂、「御用」と、一つ絞ってみたのであります。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
