    "definitions": [
      {
        "index": 1,
        "gloss": "one's lord and one's father",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夜はＫ――君父子に誘はれて觀月樓といふ料理屋に赴いた。",
              "citation": {
                "source": "鳳來寺紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "一生定正を君父の仇と覘って二度も失敗なっている。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後青衣子君来訪、抱壺君父子と共に会飲、しめやかな酒であつた。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "小松殿の御事は云ふも更なり、年寄り給ひたる父上に、斯かる嘆を見參らする小子が胸の苦しさは喩ふるに物もなけれども、所詮浮世と觀じては、一切の望に離れし我心、今は返さん術もなし、忠孝の道、君父の恩、時頼何として疎かに存じ候べき。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "他目にも數あるまじき君父の恩義｜惜氣もなく振り捨てて、人の譏り、世の笑ひを思ひ給はで、弓矢とる御身に瑜伽三密の嗜は、世の無常を如何に深く觀じ給ひけるぞ。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで始て君父の為めに身を棄てるということも出来ると云うのですね。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "親王は憤怨あらせられ、父君に上書して、臣夙に武臣の專恣を憤つて、坊主であつたものが戎衣を被て、世のそしりを受け、而して、たゞ、君父のためにこの身を忘れた、朝廷の人は誰ひとり役に立つものはない、臣ひとり空拳を張つて強敵に抗したわけである。",
              "citation": {
                "source": "滑川畔にて",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてかく天子崩じ諸侯薨じた場合に、その人に相當せる諡を議定せんには、勢ひ臣子として、その君父生前の行爲を批評せねばならぬ。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "こは甚だ君父の尊嚴を損ずる譯である。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて東晉以來、支那教界の大懸案となつた、沙門が君父に拜禮を行ふべきや否やの問題は、『明律』によつて最後の決斷を與へられた。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "臣は條件なしに、君（君父）に服從せなければならぬ。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "謂將有逆心而害於君父者。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "抑も日本の國體は家族主義を基礎としたのでありまして、日本は君父一體であります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "君父一體、忠孝一本が我が國體でありますから、さう云ふ國柄であることを考へると、其基礎をなす家族主義と云ふものは、是非とも維持して行かなければなりませぬ。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "君父夫の三綱は、人倫の常においては何れも尊きものであって、その間に差などはないものである。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きんまもん」なる霊神は、「真物｜君父」の義に過ぎない。",
              "citation": {
                "source": "熟語構成法から観察した語根論の断簡",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の侍は、君父の仇をそのままに差｜措いては、生きて人交りができなかった。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、一方ではまた、仇討は仇討だ、君父の仇を討ったものが、たとい公儀の大法に背けばとて、やみやみ刑死に処せられるはずはない。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く今朝風日佳、北窓過新雨、謝客開吾秩、山妻来有叙、無禄須衆眷、八口豈独処、輪鞅不到門、饑寒恐自取、願少退其鋭、応接雑媚鍼、吾骨天賦予、不然父母国、何必解珪※、今而勉齷齪、無乃欺君父、去矣勿聒我、方与古人語、　星巌集を読めば彼も亦屡々貧を歌へり。",
              "citation": {
                "source": "頼襄を論ず",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　子貢が、あからさまに孔子の意をたださず、伯夷・叔斉のことをたずねて、衛君父子の争に対する孔子の態度をさぐつたところに、彼の人物があらわれていて面白い。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「彼等といえども、まさか君父を弑するような命令には従いますまい。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "是を以て、或は君父に順はずして乍た隣里に違ふ。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと以下三つの白馬連峯の雪形に関しては、地元の多くの人々に教を乞うたが、中でも北城村森上新田の矢口森栄君父子、同村大出の松沢元太郎氏に負うところ多大である。",
              "citation": {
                "source": "残雪の幻像",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "与倉君父子が、ひと目会うのも、別れるのも」「あとに遺るお子が御成人の後のためにも、やはりここへお抱き申しあげて来たほうがよろしいかとぞんじますが」「ただ、案じられるのは、お産婦の奥さんだ。",
              "citation": {
                "source": "日本名婦伝",
                "author": "谷干城夫人",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖賢の道なくしては、君父の大義なく、経世の明もない。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
