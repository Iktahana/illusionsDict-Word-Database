        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところで、ひとつやくそくしてくれなきゃいけない。",
              "citation": {
                "source": "蟹のしょうばい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ、やくそくだから、わたしのお父さんの毛もかってくれたまえ。",
              "citation": {
                "source": "蟹のしょうばい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "早や早やも土は凝りて、岩角の犬羊歯が下、枯れ枯れの雑木の根ごと、そくそくと氷柱さがれり。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ただここにひとつおやくそくしていただきたいことがございますが――。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでは、このひとつのことを、おやくそく、くださいまし。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ふたりの手をとって、もしふたりのすんでいる町を通ることがあったら、きっとたずねようと、やくそくしました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思って龕燈を用意していると、それとも知らずに、予想どおり、いとも奇怪な一道の妖気が、突如右門の身辺にそくそくとおそいかかりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、その森の中へずかずかはいっていくと、そくそくとそびえている杉の木立ちを一本一本丹念に見調べていましたが、と、――そこのいちばん奥の別して大きい一本の前まで歩み近づくや同時に、名人のもろ足がぴたりくぎづけになったかと見えるや、その両眼が物におびえでもしたかのごとく妖々としてさえ渡りました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではおやくそくのとおり、あなたは私のものですよ。",
              "citation": {
                "source": "ぶくぶく長々火の目小僧",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そのうしろ姿にしぐれそぼふる九月末の、ふけまさった秋の夕やみが、そくそくと迫っていきました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙も出ずに、ただ胸がそくそくと迫って来るような悲しさだ。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、最もおどろくべきことは、政治の面で、内閣のからやくそくとすっぽかしに対して、わたしたちの抗議がどんな形で示されているかまるで知らないことです。",
              "citation": {
                "source": "新しい卒業生の皆さんへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の姦吏などハよほど勢もこれあり、大勢ニて候へども、龍馬二三家の大名とやくそくをかたくし、同志をつのり、朝廷より先ヅ神州をたもつの大本をたて、夫より江戸の同志はたもと大名其余段々と心を合セ、右申所の姦吏を一事に軍いたし打殺、日本を今一度せんたくいたし申候事ニいたすべくとの神｜願ニて候。",
              "citation": {
                "source": "手紙",
                "author": "文久三年六月二十九日　坂本乙女あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫よりたがいにさき／″＼の事ちかい候て、是より、もふつまららぬ戦ハをこすまい、つまらぬ事にて死まいと、たがいニかたくやくそく致し候。",
              "citation": {
                "source": "手紙",
                "author": "慶応元年九月九日　池内蔵太家族あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった三人の会員で淋しいので、おいおい、人をふやして行こうとやくそくしました。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "富岡はそくそくとペンを走らせてゐる。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "死刑を宣告された人間が、その時から、誰にでも、物優しくなるやうな、そくそくとした淋しさで、人の心を恋ひしがつてゐたやうなものだつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日に会う（Ａ）やくそく　晴れて、爽やかなる日。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでとうとうこんだのやくそくも出来て。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼくはきみに頭があがらなくなったね」　　　　　　　　　二　商売を早くしまってチビ公はやくそくどおり柳光一の誕生日にいくことにした。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンニングということがはやりだした、それは平素勉強をせない者が人の答案をぬすみみたり、あるいは謄写したりして教師の目をくらますことである、それには全級の聯絡がやくそくせられ、甲から乙へ、乙から丙へと答案を回送するのであった、もっと巧妙な作戦は、なにがしの分はなにがしが受け持つと、分担を定める。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "げだものの跫音は雪の上にそくそく鳴っているような気がした。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ターマンがたとひどんな男であらうと、お金をうけとつてやくそくした薬です。",
              "citation": {
                "source": "シロ・クロ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌日は早速横浜で唱うやくそくだったので、私は看護婦や皆につかまりながらまだ病後の足をたどたどと横浜の記念会館まで行って唱うた。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは後に身延隠棲のところでも書くが、その至情はそくそくとしてわれわれを感動させるものがある。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "色、形、味はひもかはらず、など我父母かはらせ給ひけんと方違へなる恨めしさ、涙おさへがたし」　そくそくとして心に沁みる名文である。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど貴艇団にやくそくする、明日九時、本艇はふたたび、貴艇団のまん中へ引きかえすであろう。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあんだギンネコ号はやくそくどおり、ちゃんと引っかえしてきたじゃないか」　テッド隊長も、気ぬけがしたように、近づくギンネコ号の姿を見て、指先をぴちんと鳴らした。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
