[
  {
    "uuid": "2fc1a4e3-a778-5076-b090-04158aa2144f",
    "entry": "比べる",
    "reading": {
      "primary": "くらべる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
