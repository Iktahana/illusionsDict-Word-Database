[
  {
    "uuid": "c57b3b3c-3661-5e20-bc48-f66a25a1eadf",
    "entry": "訓育",
    "reading": {
      "primary": "くんいく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
