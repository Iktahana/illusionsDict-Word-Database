        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "わしとも少し強く握手すればまあ黒焦げだね。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中も一荷背負つてくれようとする處を、其處が急所だと消口を取つた處から、再び猛然として煤のやうな煙が黒焦げに舞上つた。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒焦げ死体はその二三間先にもあった。",
              "citation": {
                "source": "死体の匂い",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒焦げになった死体があっちこっちに散らかっていた。",
              "citation": {
                "source": "死体の匂い",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "溺死人のように脹れあがった者、腐った魚のように半身がどろどろになった者、黒焦げになった者、そうした死体が二町四方もあろうと思われる所を掩うて見えた。",
              "citation": {
                "source": "死体の匂い",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その被服廠跡と電車通りとを隔てた溝の中は、幾百幾千とも判らない、目刺鰯の束を焼いたようになった黒焦げの死体で埋まっていた。",
              "citation": {
                "source": "死体の匂い",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりはむしろ、半ば黒焦げになった一握りの麦粒のほうがはるかに強く人の心を遠い昔の恐ろしい現実に引き寄せるように思われた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正十二年九月、渋柿）　　　　　　　＊　震災の火事の焼け跡の煙がまだ消えやらぬころ、黒焦げになった樹の幹に鉛丹色のかびのようなものが生え始めて、それが驚くべき速度で繁殖した。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "関東震火災の数日後このへんの焼け野を見て歩いたとき、この庭園の周囲の椎かなんかの樹立ちが黒焦げになって、園内は避難民の集落になっていた、その当時の光景を想い出した。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は到るところに船が焼けてその上に二三人の避難者の黒焦げになつて焼死してゐるのを眼にした。",
              "citation": {
                "source": "地震の時",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥蔵の※間を焼灰の堆かい上を蹈んで、半分落ち掛ってる黒焦げの桁を潜ると、柱一本も残らぬ焼原であった。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "朦々と白い煙の立罩めた中に柱や棟木が重なって倒れ、真黒或は半焦になった材木の下に積重なった書籍が原形のまゝ黒焦げとなって、風に煽られる度に焼けた頁をヒラ／＼と飛ばしていた。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "私から云い寄るなんて、そんな事はありませんでした……」私は黒焦げの女を思い出しつつ気味悪く否定した。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "柱がみんな黒焦げになって、壁が落ちて向ふが透いて見えた。",
              "citation": {
                "source": "焔",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "柚子味噌をこしらへる、去年の事を思ひだす、酔うて柚子釜を黒焦げにして井師に笑はれたが。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は失策一つしでかした、御飯をしかけて忘れてゐたのである、せつかくの御飯を黒焦げにしてしまつた、私もだいぶ老耄したらしいわい！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "併も肉と石炭と黒焦げの軟骨とから成る恐ろしい髑髏の面を剥いで見ると剥き出した齒が物凄くも白く光つて兩顎はその儘になつてゐることが發見された。",
              "citation": {
                "source": "無法な火葬",
                "author": "VIOLENT CREMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらも、顔を黒焦げにしてゐて、痩せた背を炎天に晒し、水を求めては呻いてゐる。",
              "citation": {
                "source": "夏の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらも、顔を黒焦げにしていて、痩せた脊を炎天に晒し、水を求めては呻いている。",
              "citation": {
                "source": "夏の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪子は箒と塵取とを持つて来てくれ、私は熱灰を塵取の中に握り込むやうなことをしたが、畳の上にあちこち黒焦げが残つた。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "君を黒焦げにしちゃっちゃ、元も子もなくなるからね。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとだよ、然らば黒焦げになる日中はどうするか。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は炭燒きをしてゐた男が、急に麺麭屋に變つて、この頃では一流の店になつてゐますが、ときどき今でもその男はうつかりすると麺麭を眞つ黒焦げに燒いてしまふさうです。",
              "citation": {
                "source": "匈奴の森など",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はてね」「灰皿に真黒焦げになって紙の燃え糟がございました。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さんだって黒焦げだ。",
              "citation": {
                "source": "天主閣の音",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "禿鷹が上っていた山こそ国中で一番高い山で、そこに雷の神が雷を落としたものですから、頂上の岩の上にいた禿鷹は、それに打たれて、黒焦げになって死んでしまったのです。",
              "citation": {
                "source": "コーカサスの禿鷹",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は大急ぎでおりて見ますと、大国主神はまっくろこげになって、山のすそに倒れていらっしゃいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときは殺人光線が貴様たちの全身を、まっくろこげに焼いているときじゃ」　ああ、あぶないあぶない。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなれば帆村も一彦もくろこげになって死ぬというのですから、二人の命は、もはや風の前の蝋燭とおなじことです。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その、伊賀の暴れん坊源三郎、とうとう彼らの策に乗り、今は真っくろこげの死体となった――？",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
