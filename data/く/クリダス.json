[
  {
    "uuid": "9dc20453-8f7e-590a-ba57-ab27e90a66b8",
    "entry": "繰り出す",
    "reading": {
      "primary": "くりだす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
