        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「君も知つてるだらうが、Ｓ子はデカタンのやうでピューリタニックなところを持つた女だし、それにあんな処で遊廓町で歌ふやうな歌を歌つちやあ困るぢやないか。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉はやはり山の峡谷のやうな所に、そこだけで一廓をなしてゐなければいけない。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長崎を立って時津に向かう途中でロシア人専門の遊廓だというところを通ったら二階から女どもが見下ろして何かしら分らないことを云って呼びかけた。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大網の尖端は、紐のように太く揺れて、アール・ヌーボー式の図案に見るような、印象の強い輪廓を作って、幾筋となく繋がっては、環を作る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "雄大なる白河内岳が、円く眼の前にボーッと立つ、この山を中心として、雲の大暈が、幻のように圏を描いてひろがる、日輪の輪廓がひろがって黄色い葵の花のように、廻転するかと思われた。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩は鋼鉄のように硬くなりながらも、イワベンケイ、ミヤマダイコンソウ、ムカゴトラノオなど、黄紫のやさしい花を、点々とその窪洞に填めながら、ギザギザに尖っている輪廓を、無数に空に投げ掛けている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "足もとは暗いが、木の梢だけは、夜の空にかっきりと黒く張って、穂高の輪廓は、ボーッと、物干棹でも突き出したように太く見える。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "神楽殿の傍には、周囲六丈四尺、根廻りは二丈八尺、と測られた神代杉がそそり立って、割合に背丈は高くないけれど、一つ一つの年輪に、山の歴史の秘密をこめて、年代の威厳が作り出す色づけと輪廓づけを、神さびた境内の空気に行わたらせている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "表裏に廻り、左右から見直しても、「あなたこなたも同じ姿」の八字の輪廓と、円錐の形式とは、連嶺構造の山と、鋭利に切り込まれた深谷を見た目からは、浅いものに見せるかも知れぬ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "また山の頭のギザギザは、白くなったために、輪廓がハッキリして、一本一本の尖りまで見える。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "十間許り下流で釣つてゐる男の子の姿も、夕暗に輪廓がぼやけて来た。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "長なす黒髪を項の中から分けて豊かに垂れ下げ、輪廓の正しい横顔は、無限なるものを想うのみ、邪なる想いなしといい放った皎潔な表情を保ちながら、しら雲の岫を出づる徐なる静けさで横に移って行く。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛍光のような幽美な光りが女神の身体から照り放たれ、その光りの輪廓は女神の身体が進めば闇に取り残され、取残されては急いで、進む女神の身体に追い戻る。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いて見かへるに暴れ者の長吉、いま廓内よりの歸りと覺しく、浴衣を重ねし唐棧の着物に柿色の三｜尺を例の通り腰の先にして、黒八の襟のかゝつた新らしい半天、印の傘をさしかざし高足駄の爪皮も今朝よりとはしるき漆の色、きわ／″＼しう見えて誇らし氣なり。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いて見かへるに暴れ者の長吉、いま廓内よりの帰りと覚しく、裕衣を重ねし唐桟の着物に柿色の三尺を例の通り腰の先にして、黒八の襟のかかつた新らしい半天、印の傘をさしかざし高足駄の爪皮も今朝よりとはしるき漆の色、きわぎわしう見えて誇らし気なり。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「傾城は金でかふものにあらず、意気地にかゆるものとこころへべし」とは廓の掟であった。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、絵画については輪廓本位の線画であること、色彩が濃厚でないこと、構図の煩雑でないことなどが「いき」の表現に適合する形式上の条件となり得る。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば鼻の大きい人の鼻を普通の計測的の大きさの比以上に廓大して描いたり、喜怒の感情の発現を誇張した身振りで示すがごときは、最も月並な慣用手段である。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いて見かへるに暴れ者の長吉、いま廓内よりの歸りと覺しく、裕衣を重ねし唐棧の着物に柿色の三尺を例の通り腰の先にして、黒八の襟のかゝつた新らしい半天、印の傘をさしかざし高足駄の爪皮も今朝よりとはしるき漆の色、きわ／″＼しう見えて誇らし氣なり。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後も幾度か、僕は牧水氏と一所になり、よく淺草公園の裏通りや、吉原の遊廓などを歩き※つた。",
              "citation": {
                "source": "追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして路傍で拾つた繩の帶を卷きつけながら、平然として吉原遊廓へ登り込んだ。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "または廓の日ぐれどきにあちこち動く赤襟の美しい姿を珍らしがつた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯父の急激な對蹠的な轉向を輪廓づけた、その圖形が妥當であるかないか、それは問題にしようとは思はない。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその前にあるものが、光って、輪廓がはっきりして、恐ろしく単純に見えたっけ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くは自分の輪廓に圧されているように背中を曲げている。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は巨大で腿のあたりは猶太女の輪廓をもって、皮膚は荒れて赤らんで堅固な体躯をしていた。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつのわれにはかわらじを、何とてさはあやまるや、世にただ一人なつかしき姉上までわが顔を見るごとに、気を確に、心を鎮めよ、と涙ながらいわるるにぞ、さてはいかにしてか、心の狂いしにはあらずやとわれとわが身を危ぶむようそのたびになりまさりて、果はまことにものくるわしくもなりもてゆくなる。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしなあ、段段こすくなつてくるわあね。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "出さなきゃ、ふんだくるわよ」　お加代はいきなり相手の手を掴んだ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし、かあさんよんでくるわ。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
