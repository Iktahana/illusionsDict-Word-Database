    "definitions": [
      {
        "index": 1,
        "gloss": "a well equipped with a pulley for drawing water",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "我等が祖先のニュートンはいかにエライ者であったかと云う事を考えると隣の車井戸の屋根でアホーと鴉が鳴いた。",
              "citation": {
                "source": "窮理日記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸は舊時代の遺物と謂ツても可い車井戸で、流しの板も半腐になツて、水垢と苔とで此方から見ると薄ツすり青光を放ツてゐた。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "半壊れの車井戸が、すぐ傍で、底の方に、ばたん、と寂しい雫の音。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "出口には車井戸があって婢の一人が物を洗っていた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "車井戸の向うには一軒の離屋があった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "車井戸の鎖の音や物を投出す音が、ぐゎんぐゎんと空気に響くのである。",
              "citation": {
                "source": "新万葉物語",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも宗匠は飛んだことだったが、なにか心当りはありませんかえ」と、半七は車井戸の柱によりかかりながら先ず訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "冬の金魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "広くとった庭にはけいこ弓の矢場がずっと奥までつづいて、そのこちらに車井戸、井戸にとなって物干し場、――ひょいと目を向けると、小春日のあたたかい日ざしを浴びてひらひらと舞っている幾枚かの干し物が見えました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが仕上ると次は車井戸を仕掛ける設備だ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "車井戸は門型に木を組んでそれに車を取り付けるのだが、二本の柱の頭を凸形に切り込み、その上に渡す横木に二つの穴をあける作業が、簡單なものに見えてなかなかさうではなかつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "古風な鎖でたぐる車井戸へゆく右手に、十ばかり地蔵の並んだところがあった。",
              "citation": {
                "source": "道灌山",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎娘になって、初々しく顔を赤めてお茶を召し上れか、車井戸のつるべを上げたり下げたりしていると、私も娘のように心がはずんで来る。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "キイラリ　キイラリ、車井戸のつるべを上げたりさげたりしていると、私も娘のように心がはずんで来る。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると薄暗い台所の中央に深い車井戸があって、長い綱の垂れ下った底には水が鏡のように覘いていた。",
              "citation": {
                "source": "雲の裂け目",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、側へゆくと、それは Masula という名の、車井戸だったのだ（この Masula というのは、あるいはこの地方の小舟の名であったかもしれぬ。",
              "citation": {
                "source": "一週一夜物語",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "辛うじて、瓦屋根の、同じ門のつくりの、鉄道の役員の官舎らしい家の前に来ると、其処の傍に車井戸があつて、肥つた下女が朝日を受けて、井戸の鏈を音高く繰つて居た。",
              "citation": {
                "source": "父の墓",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のいるすぐわきのところに、車井戸のような仕掛けで受付から郵便物だの通信類だのと運び上げるものがあって、それが間断なくギーギーきしッていた。",
              "citation": {
                "source": "六月",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "車井戸をすっかり雪で包んでお菓子の様に甘そうに、あすこから水が出ようなどとは思われない形になって居る。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の有様、車井戸、井戸枠に腰掛けてる高島田の女、その女がすーっと下りてきて襟を締めつけたこと、それが一々、陰影のない明るさで浮び上っていた。",
              "citation": {
                "source": "古井戸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "室中がぱっと明るくなったが、その光の届かないどこか奥深い暗闇の中に、庭や車井戸や女のことが、くっきりと浮出していて消えなかった。",
              "citation": {
                "source": "古井戸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い綺麗な庭の中に車井戸があったり、庭の古井戸の跡に赤ん坊の泣声がしたり、女の首がどこからか転ってきたり、其他いろんなことだった。",
              "citation": {
                "source": "古井戸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして新たに拵え直されたものは、昔通りの車井戸だった。",
              "citation": {
                "source": "古井戸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、車井戸の音ははっきり聞えてきた。",
              "citation": {
                "source": "古井戸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああ、金ちゃんちの三ちゃんが井戸へ落っこってしまったア」　今まで米友を取巻いていた子供連が、面の色を変えて叫び出し、河岸に近いところの車井戸の井戸側へ集まりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸一貫になったかと思うと、車井戸の釣縄の一方をあくまで高く吊し上げて、釣瓶を車へしっかりと噛ませておいて、その縄を伝って垂直線に井戸の底へ下って行きました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「拙者の住むところは、いつでも化物屋敷だ、躑躅ヶ崎の古屋敷もかなり化物じみていた」と言っている時に、不意に、裏手の車井戸がキリキリと鳴りました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰か井戸で水を汲んでるな」「左様でございますね」「水を汲んじゃいかんと言え」「それでも、御前」「いや、水を汲んじゃいかん、拙者はあの車井戸の音が大嫌いだ」「おおかた、お嬢様が水を汲んでいらっしゃるのでございましょう」　お角も、車井戸で水を汲んでいる者があることを気がついていました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "車井戸の音が嫌いだという神尾の心理状態を、怪しまないわけにはゆかないが、これも酒の上での我儘が出たものと思って、神尾の言うことを軽く受け流しています。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにも拘らず、裏の車井戸はキリキリと鳴っています。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
