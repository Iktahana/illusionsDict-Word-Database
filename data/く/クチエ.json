    "definitions": [
      {
        "index": 1,
        "gloss": "illustration appearing in the first pages of a publication",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
