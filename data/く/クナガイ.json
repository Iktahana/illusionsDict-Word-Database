        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "然しルモオルと結婚した。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼津　八月十八日小泉八雲　この情緒纏綿たる手紙は、新婚当時の手紙ではない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚十数年、ヘルン既に五十｜歳を過ぎ、二人の男児と一人の女児の親となってる晩年の手紙である。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ子供が出来ない頃、この新婚の若夫婦は、山陰道の辺鄙な島々を旅し歩いた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "新婚まもなく若い稚気のぬけなかった夫人は、恐らく恐怖にふるえながらも、人生の最も楽しく忘れ得ない夢を経験したのだ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルン夫妻の結婚は、すべての点において特異であり、世の常の凡俗な夫婦関係とちがっていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人と結婚して間もない頃、雨でずぶ濡れになった小猫を拾って帰り、その泥だらけのままの猫を懐中に入れて、長い間やさしく暖めていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が結婚致しましたのは、松江に来てからのことで、二十四の秋でございますから、当時としてはずいぶん遅い結婚でございました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと、美しい結婚できます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "臆病な私には、人の結婚の世話など、おそろしくてたまらなかった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、小生と雖も、貴兄の幸福な結婚を望んでいる事に於いては人後に落ちないつもりだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、小坂氏と相談して結婚の日取をきめた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅君は、結婚式の日まで一週間、私の家に滞在する事になっているのだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このたびの結婚の事に就いては少しも言わず、ひたすら世界の大勢に就き演説のような口調で、さまざま私を教え諭すのであった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚に感激を持っていません。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　四月二十九日に、目黒の支那料理屋で大隅君の結婚式が行われた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その料理屋に於いて、この佳き日一日に挙行せられた結婚式は、三百組を越えたという。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚式は午後五時の予定である。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんとお母さんとは、結婚してから十二年経つても子供が生れなかつた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和八年十二月、結婚。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の人生に於ける唯一の理想は、重役の娘と結婚して、郊外の文化住宅に住み、何も他に為すことがなく、新婚の妻と朝から晩までイチヤついて居たいのである。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "郊外の安文化住宅で、新婚の若夫婦がいちゃつくという意味ではない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝへ新に入り来りし二人連れはいずれ新婚旅行と見らるゝ御出立。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新婚後まもないことであったと思う。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の初節句、結婚の披露、還暦の祝い、そういう機会はすべて村のバッカスにささげられる。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、ことしのお正月に、甲府の人と平凡な見合ひ結婚をして、けれども私には一錢の貯金も無し、すぐに東京で家を持つわけに行かなかつた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の敷金として、百圓くらゐ用意しなければならぬし、その他家財道具一切を買はなければならぬし、そのためには、どうしても、もう百圓は必要であらうし、とにかく、結婚當時の私には、著てゐる著物と、机と夜具、それだけしかなかつたのであるから、ずゐぶん心苦しいことが多かつた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚してもう十年以上にもなるのだが、未だ世繼が無いのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、まるっきり、からだをおおうものがないので、ひいさまは、ふっさりとこくながい髪の毛で、それをかくしました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、まったくながいながい、いんきな冬でした。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
