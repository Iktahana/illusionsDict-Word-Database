        "examples": {
          "standard": [
            {
              "text": "ムッソリーニが率いた黒シャツ隊は、イタリアの政治に大きな影響を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "黒シャツ隊の行動は、当時の社会に大きな混乱をもたらした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史書には、黒シャツ隊による暴力的な弾圧の記述があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ナチスの突撃隊、ファッショの黒シャツ隊等は、この傾向に示唆を与えているのではなかろうか。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタリアの黒シャツ隊とかヒットラーの突撃隊等はその傾向を示したものと言える。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国においては平和誓約連合の構成員と黒シャツ隊の構成員が幾分重なってきたようだ。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
