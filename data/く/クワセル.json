[
  {
    "uuid": "108b8508-2797-5126-a08d-7974d33bfcaf",
    "entry": "食わせる",
    "reading": {
      "primary": "くわせる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
