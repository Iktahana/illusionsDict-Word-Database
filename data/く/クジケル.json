    "definitions": [
      {
        "index": 1,
        "gloss": "to be disheartened",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "首が葢に觸るので骨の挫けるまで抑へつけられてすくみが掛けられた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "がつたりと氣が挫けると同時に病んでゐるからだの苦しさに氣づいた。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "高をくくって軽く動かそうとされると、猛然癇を立てるけれども、所謂情理をつくして折入ってこちらの面目をも立てた形で懇談されると、そこを押し切る気が挫ける律気で常識的な市民の俤が髣髴としている。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋の九分九厘は黄金の前には、脆くも挫けるものであった。",
              "citation": {
                "source": "柳営秘録かつえ蔵",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「向ふぢや此方に信用がないかも知れないが、此方ぢや又向ふに信用がないんだ」と宗助は威張つて云ひ出したが、御米の俯目になつてゐる樣子を見ると、急に勇氣が挫ける風に見えた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "安藤竜太郎が最後の言葉を発した時、群集の一団の気分は、そのまま挫けるか破裂するかの、頂点に達した。",
              "citation": {
                "source": "電車停留場",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨の節々の挫けるやうな、疼きを覺えた。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨の筋々が、挫けるやうな疼きを覚えた。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨の節々の挫けるやうな、疼きを覚えた。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨の節々の挫けるような、疼きを覚えた。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして、私はこの目的を遂げないうちに挫けることのないように決心し、天の加護を願いながら、めげない熱心さをもって広大な無人境をよこぎりつづけると、ついに遠くに大海が見え、水平線の限界となった。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは試合ぶりが世にも、荒っぽいものであって、小手を打たれると小手が折れる、横面を張られると耳がつぶれる、胴を取られると肋骨が挫ける、もしそれお突きでやられようものなら、そのまま冥途へ行かなければならない。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "挫ける勿れ、折ける勿れ、神州は必ず滅びざるなり」と言い贈れり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "「向うじゃこっちに信用がないかも知れないが、こっちじゃまた向うに信用がないんだ」と宗助は威張って云い出したが、御米の俯目になっている様子を見ると、急に勇気が挫ける風に見えた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "威張るよりほかに悪気のない人で、一度挫けるとこんな人は案外気の良い生地が出るのでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初は心が挫ける思いがした。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことでへなへな気が挫けるようでどうする。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっかりしろ三十六、貴様は挫けるのか、世間の奴等に万歳を叫ばし度いのか、大きな嘘吐きとして嘲笑されたいのか、元気を出せ、貴様は選ばれた男だぞ、忘れるな、いいか、起て、起てそして確りとその両の足で立上って困苦や窮乏を迎えろ、貴様にはその力があるぞ。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今だ、今ゆかぬと気が挫ける。",
              "citation": {
                "source": "泥棒と若殿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――青木という人だな」と彼は呟いた、「町廻りのほうか、奉行所詰のほうか、とにかく青木というあの与力のやったことだろう」　どうするつもりだ、そんなふうにしておれをなだめようというのか、そんなことでおれの怒りが挫けるとでも思っているのか。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は全身から力がぬけ、気持がみじめに挫けるのを感じた。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "半途で挫けることなく、いったん出発したからには、汽車が軌道のうえを突進するような勢で、途中にどんな障碍があってもこれを乗り越えてまっしぐらにすすみなさい」　ついで左部彦次郎が起った。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は以前にも増して凛としてみえたし、どんな非難の眼にも嘲笑の声にも挫けるようすはなかった。",
              "citation": {
                "source": "四日のあやめ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "作左衛門は咄嗟に横へ翳した太刀で受け止めたが、柄手から腰も挫けるほどな圧力を受けてたじたじと乱れ足になったところ、得たりと背後の男が袴腰を避けて突き出した一刀が作左衛門の脾腹を突きとおすよと見えた。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は云わないが、　彼が、私が会うと心がくじけることをおそれ、又自分も、戻したい気になると思って行かないのか。",
              "citation": {
                "source": "一九二三年夏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ディスク二台、一二八ＫバイトのＲＡＭで二八万五〇〇〇円という価格にのみ対応する必要を感じた浜田は、ＪＸの発表の直後から製品寿命を終えかかったＰＣ―９８０１Ｆの仕切り値を大幅に下げて店頭の実勢価格を低めに誘導することで、日本ＩＢＭの出鼻をくじけると考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はい」「もし、ここでお前の志がくじけることあらば、わしは、お前の御奉公の精神をうたがう。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度や二度のシクジリでくじけるようじゃア、人間の値打はありやしねえや。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この様子では、せっかく九州の旅をしているのに、佐世保だけがまるで、遠くはるかなる外国のような気がして、志気大いにくじけるではありませんか。",
              "citation": {
                "source": "エキゾチックな港街",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも母はくじけることなく、ドミトリを大学に入学させたいと思って、トボルスクから遥々とモスクワを目指して旅に出ました。",
              "citation": {
                "source": "メンデレーエフ",
                "author": "石原純",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
