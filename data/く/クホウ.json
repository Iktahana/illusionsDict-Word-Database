    "definitions": [
      {
        "index": 1,
        "gloss": "conventions to be followed in composing Japanese poetry",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
