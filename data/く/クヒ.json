  {
    "uuid": "24f2a998-307d-56b8-bb92-aff52db4c663",
    "entry": "句碑",
    "reading": {
      "primary": "くひ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "slab with a haiku cut on it",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "名月や池をめぐりて夜もすがら　例の芭蕉の句碑の立っている所である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の句碑（松はみな枝たれて南無観世音）の前で撮影、私も久しぶりに法衣をもとうた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅間大神里宮芭蕉句碑――婦支飛寿石者浅間能野分可哉天然製氷所が散在してゐる。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉句碑（一つぬいで――）。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "書き忘れたが、途中、中佐都といふ部落に蕉翁句碑があつた。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "早い朝湯にはいつてから日和山の展望をたのしむ、美しい港風景である、芭蕉句碑もあつた。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "街はづれの潮音寺境内に杜国の墓があつた、芭蕉翁らの句碑もあつた、なつかしかつた。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊良湖明神はありがたかつた、閑静なのが何よりだ、御手洗は汲上井戸だがわるくなかつた、磯丸霊神社とあるのもうれしかつた、芭蕉句碑もあつた、例の句――鷹一つが刻んであつた。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥居峠、古戦場、御野立所、遊園地、句碑二つ。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉の句碑二つ、明治天皇聖績碑（東郷大将題）。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後は柿の会第二回句会を開催する、来会者は六名――一洵、月村、柳女、布佐女、和蕾、無水――だけだつたが、親しみのある会合であつた、夕方一先づ散会、一洵無水和蕾の三君は居残つて、朱鱗洞の句碑建設について相談した。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼食はぬき、ポストまで出かける、一洵、和蕾、無水君を訪ねて、句碑句会のことを相談する、腹がペコ／＼では散歩もおもしろくないので早く帰る、帰つて来てもフラ／＼だ。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "句会の事句碑の事で、午後、和蕾君を訪ねる、不在、無水君を訪ねる、また不在、さらに局の藤君を訪ねる、碧君にも逢つた。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方から柿の会三月例会、一洵、三土思、無水、藤君、和蕾の五君だけ来庵、今晩は女性を欠いだ、なごやかな句座であつた、席上で朱鱗洞句碑建立の具体案がやゝまとまつたのはよかつた、十一時頃散会。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……散歩、和蕾さんを訪ねて朱鱗洞句碑の相談をする、あまり寒いので早々帰庵。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "余戸の子規句碑を観る。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽ち岩頭に芭蕉の句碑あり。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　七、軽井沢に芭蕉の句碑あり。",
              "citation": {
                "source": "病牀雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "因に言ふ、追分には「吹き飛ばす石は浅間の野分かな」の句碑あるよし。",
              "citation": {
                "source": "病牀雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "風葉は「身長今｜一寸」を希望とし、春葉は「四十迄生きん事」を希望とし、紅葉は「欧洲大陸にマアブルの句碑を立つ」を希望とす。",
              "citation": {
                "source": "雑筆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし木の下や池のほとりに古人の句碑の立つてゐるのは僕には何か時代錯誤を感じさせない訣には行かなかつた。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああ、あの大きい句碑の前にね。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし木の下や池のほとりに古人の句碑の立っているのは僕には何か時代錯誤を感じさせない訳には行かなかった。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああ、あの大きい句碑の前にね――それでもまだ張り子の亀の子は売っている。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ萩寺と云えば、その頃はまだ仁王門も藁葺屋根で、『ぬれて行く人もをかしや雨の萩』と云う芭蕉翁の名高い句碑が萩の中に残っている、いかにも風雅な所でしたから、実際才子佳人の奇遇には誂え向きの舞台だったのに違いありません。",
              "citation": {
                "source": "開化の良人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのとき小倉の袴に朴齒の畫學生はいま、去年も今年も、三圍祠畔の句碑の苔を掃ふことのできない身を嘆いてゐる。",
              "citation": {
                "source": "九月朔日",
                "author": "心猿",
                "note": "青空文庫"
              }
            },
            {
              "text": "句碑ばやりの昨今、誰の眼にもすぐとまるやうな目拔の所でなかつたのが、何よりも仕合せである。",
              "citation": {
                "source": "九月朔日",
                "author": "心猿",
                "note": "青空文庫"
              }
            },
            {
              "text": "一周忌に建てられたこの句碑も、既知未知、流派主張を問はない全國俳人有志六十餘人の純粹な據金で出來あがつた。",
              "citation": {
                "source": "九月朔日",
                "author": "心猿",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小さな句碑の前に、無限の感慨をこめて黙思する人は、果していくたりゐるだらう。",
              "citation": {
                "source": "九月朔日",
                "author": "心猿",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓦礫のまま荒れ果てた寺内に、なかば埋沒した名井長命水や芭蕉雪見の句碑、名犬六助塚、柳北の碑などを探り、お互ひに寂しい氣持を抱いて土手にでた二人は、澁茶をすするべく門前の櫻餅屋のガラス戸を引いた。",
              "citation": {
                "source": "桜もち",
                "author": "心猿",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
