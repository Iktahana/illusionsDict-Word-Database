        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「燻製鮭のサンドウイッチ、キァビヤ。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根裏より燻製の猿、鰐の子などが古血のように固まって垂れて居る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「けさは燻製の鰊と、ボイルドした鱈とをコックさんが用意して来てるね。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨今の私の詩歌は燻製の鰊だ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "燻製の鰊と桐の花と一緒にされるものか。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥では燻製の鰊や、蟹の鑵詰の鑵や、シトロン、麦酒の瓶などが、売品として、二、三の卓上に飾り立ててもあった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "タロ芋の切つたのと、燻製らしい魚の切身が載つてゐた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "タロ芋の切ったのと、燻製らしい魚の切身が載っていた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "番人の野津由氏は、鱒の燻製と新しき鱒を燒きたるものとを饗す。",
              "citation": {
                "source": "上州沼田より日光へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "燻製の魚のような香いと、燃えさしの薪の煙とが、寺の庫裡のようにがらんと黝ずんだ広間と土間とにこもって、それが彼の頭の中へまでも浸み透ってくるようだった。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "川崎船が燻製鰊のように、すっかり斜めにブラ下がってしまうことがある。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の燻製が出来そうだ」「冗談じゃねえど。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホーテンスはこの土地の名産であるところの一種の鱒の燻製をたいへんに褒めて食べた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへまた、燻製の顔をした、モンペ姿の婦人がやつて来ると、ハンドバツクを下に置きぐつたりと膝を伸した。",
              "citation": {
                "source": "夏の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへまた、燻製の顔をした、モンペ姿の婦人がやって来ると、ハンドバッグを下に置きぐったりと膝を伸した。",
              "citation": {
                "source": "夏の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と郵便局長が、さっそくマデーラを一杯ひっかけて、オランダチーズの大きな一切れと、バタをつけた蝶鮫の燻製とを頬ばりながら、言った。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物が惡いといふばかりではあるまいが、着物だけの好みからいつても、干物のやうな、燻製の品物のやうな見かけがする。",
              "citation": {
                "source": "夏の女",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "燻製の鮭やさんまに裝飾のほどこしやうはないが、男性と女性の區別をよく知つて、（おつくりの上からの事だけを斷つておく）もうちつと上手に取るべき道があつたらうにと思ふ。",
              "citation": {
                "source": "夏の女",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "燻製になつて、自ら鏡にむかふのも氣持の惡いやうな澁紙面をつくるにも及ばない。",
              "citation": {
                "source": "夏の女",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなものから立つ匂いは林檎だの、奥の方にどっさりつるしてある燻製魚だのの匂いと混りあって独特の親しみある匂いで天井の低い店じゅうを充しているのであった。",
              "citation": {
                "source": "広場",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、手間どってイクラだの酸っぱくした牛乳だの小魚の燻製だのを買った。",
              "citation": {
                "source": "広場",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その所々には、クルージイと呼ばれて魚油を点す壁灯や、長い鎖のついた分銅を垂している、古風な時計などが掛けられているのだから、もしそこに石炉や自在鉤や紡車が置かれてあったり、煤けた天井に、腹を開いた燻製の魚などが吊されているとすれば、誰あろうがこの家を、信心深い北海の漁家とみるに相違ない。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外飾り窓の中の軍艦三笠も、金線サイダアのポスタアも、椅子も、電話も、自転車も、スコツトランドのウイスキイも、アメリカの乾し葡萄も、マニラの葉巻も、エヂプトの紙巻も、燻製の鰊も、牛肉の大和煮も、殆ど見覚えのないものはない。",
              "citation": {
                "source": "あばばばば",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も燻製の鯡の匂に顔だけはちよいとしかめてゐる。",
              "citation": {
                "source": "あばばばば",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "――保吉は突然燻製の鯡を買ひ忘れたことを思ひ出した。",
              "citation": {
                "source": "あばばばば",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "手百姓の爺さんの、汚れた、硬い、節くれだつた手、ちよいと見ると、褐色の、朝鮮｜人蔘の燻製のやうな手、おお、之がほんたうの労働の手、これがほんたうの祈祷の手。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "盛合わせ皿には、燻製の鮭、パン片に塗りつけたキャビア、鮒の串焼、黄いろい生雲丹、ラドッシュ。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら燻製にしても、羊特有の、あの動物園みたいな悪臭は消えるものか」「まあ、黙って、これをごらん下さい」　密使油が、包を派手にひろげると、中から鼠色の大きな動物が現れた。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはカンガルーの燻製でございます」「カンガルーの燻製？",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月十八日　火　○いつかトゥウェルフスカヤ〔街路名、現在のゴーリキー通り〕で買って食べてすっかりすきになった魚のくんせいしたのはオーブラという。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
