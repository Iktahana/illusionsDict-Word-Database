        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "で氏郷は、利家は武辺なり、北国三州の主なり、京都までの道すがらに足に障る者もなく、毛利は有りても浮田が遮り申す、家康｜上洛を心掛けなば此の飛騨が之有る、即時に喰付て箱根を越えさせ申すまじ、又諸大名多く洛に在りて事起らば、猶更利家の味方多からん、と云ったと云う。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏郷が家康に喰付けば、政宗が氏郷に喰付きもするだろうが、それは兎に角として、氏郷は利家｜贔屓であった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその足で牡蠣船の階段をおりて狭い電話室の喰付いてゐる入口へと行つた。",
              "citation": {
                "source": "牡蠣船",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その通りにすぐ門口を喰付けたり、奥深く引込んだりした人家が、ぼつぼつ門燈を見せて歯の抜けたやうに並んでゐたが、もう多く寝てゐると見えて人声もしなかつた。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母屋から鍵の手のやうに折れ曲つた所に小さな軒を喰付けた離屋は、端板一つで母屋と繋がつてゐた。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は四枚あるガラス戸を彼方此方と動かして見たが、一枚板のやうにびつちりと喰付いてしまつて動きもしなかつた。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、何処へかお出掛けになる時は毎でも俺がお伴を仰付かるから子、君達が指でもさせば直ぐワンと喰付く。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして兩膝頭と顎が喰付くやうに、圓まつて寢込んでしまつた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを怪んで訊ねると、『何有、私なんかモウお婆さんで、夫の側に喰付いてゐたい齢でもありません。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣ずからの寒暄の挨拶が喰付きで、親々が心安く成るにつれ娘同志も親しくなり、毎日のように訪つ訪れつした。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も今母親の写真を見て文三は日頃｜喰付けの感情をおこし覚えずも悄然と萎れ返ッたが、又｜悪々しい叔母の者面を憶出して又｜熱気となり、拳を握り歯を喰切り、「糞ッ止めて止まらぬぞ」ト独言を言いながら再び将に取旁付に懸らんとすると、二階の上り口で「お飯で御座いますヨ」ト下女の呼ぶ声がする。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "放さないとこの手に喰付ますよ」「喰付たいほど思えども……」と平気で鼻歌。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、此目的で、最初は小狐に居た頃喰付いた人情本を引続き耽読してみたが、数を累ねると、段々贅沢になって、もう人情本も鼻に附く。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒に酔うた事ないてや」「そんならこの腕に喰付いてみんかい」　木乃伊の爺さん一杯機嫌らしく、片肌を脱いで二の腕を曲げて見せると、真四角い木賃宿の木枕みたいな力瘤が出来た。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩に喰付かれたが、嬉しいらしく女中を振返ってニコニコと笑った。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな奴に「人間に喰付かれた犬は如何なる病気を感染するか」とか「猫の失恋ヒステリーの治療法｜如何」とかいったような問題と一緒に、数十匹の犬や猫を宛てがっておくと大抵、半年、乃至、三年ぐらいで解決して来る。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人間に喰付かれた犬は泥棒犬になる」とか「三味線に張って猫ジャ猫ジャを弾く」とかいう論文を提出して博士になる。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリクリ坊主の額が脳天から二つに割れて、又｜喰付き合った創痕が、眉の間へグッと切れ込んでいるんだ。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「喰付く犬が居るよ。",
              "citation": {
                "source": "犬",
                "author": "レオニイド・アンドレイエフ　Leonid Andrejew",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同が広々とした畷へ出て、村の入口に架っている小さな橋を渡ろうとすると、突然物陰から、飛白のよれよれの衣物を着た味噌歯の少年が飛出して来て、一番背の高い自分に喰付こうとした。",
              "citation": {
                "source": "秘められたる挿話",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い幅のあるリボンを蝶々の樣に頭の上に喰付けて、主人に負けない程の勢で、小さな手を握り固めてさつと前へ出した。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして多能な彼の手によって刻まれた、胴から下のない蛇の首が、何物かを呑もうとして呑まず、吐こうとして吐かず、いつまでも竹の棒の先に、口を開いたまま喰付いているとする。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬太郎の方で須永の評判でも持ち出そうものなら、いつまででもその問題の後へ喰付いて来て、容易に話頭を改めないのが例になっていた。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし間違いなく彼らの影を踏んで後から喰付いて行こうとするなら、どうしても一足先へ出て、相手に気のつかない物陰か何かで、待ち合せるよりほかに仕方がないと考えた。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨日持つて出たきりの辨當の中にはこち／＼になつた飯粒が喰付いてゐた。",
              "citation": {
                "source": "不良兒",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルコール漬だから形は残って居ても息は絶えて死んで居るのだが、それを二年｜許り経って壜の口をポンと抜いたら、中から蛇がずうッと飛出して、栓を抜いた方の手頸へ喰付いたから、ハッと思うと蛇の形は水になって、ダラ／＼と落て消えたが、是は蛇の幽霊と云うものじゃ。",
              "citation": {
                "source": "真景累ヶ淵",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "小刀の中身の柄がささる溝が浅くなく深くなく僅かに余裕があって膠が入り込んでピッタリ喰付くのを良しとする。",
              "citation": {
                "source": "回想録",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外部から喰付けた砂糖とは違うさ」　こんな説明が既に細君には空っぽうな理窟であった。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに雪片がくっつき合っているのはつまり寒気がさほどひどくなくて雪片が温まっているからなので、ごくごく寒い摂氏零度以下二十余度にもなるともはや雪片に湿り気がなく従ってみんなバラバラに粉のようになってしまう。",
              "citation": {
                "source": "雪の話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最前から見物していたキャラメルの仲間のミンツ、ボンボン、チョコレート、ドロップス、飴玉の仲間の元禄、西郷玉、花林糖、有平糖なぞはソレというので馳け寄って、双方入り乱れてゴチャゴチャに押し合い掴み合っているうちに、みんなお互いにくっつき合って動けなくなってしまいました。",
              "citation": {
                "source": "キャラメルと飴玉",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
