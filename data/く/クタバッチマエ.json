        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「へん、シンガポールから迎えのこぬうちにくたばっちまえ。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの日本の小猿め、早くくたばっちまえばいいものを。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……くたばっちまえ。",
              "citation": {
                "source": "或る作家の厄日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（あくび）いっそさっさと、くたばっちまえばいいになあ。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みんなは蔭で、さんざん悪口を云ったものだ」と老人は続けた、「因業じじいだとか、厄病神だとか、早くくたばっちまえとかさ、ところが、――或るとき躯の調子がおかしくなり、医者に診てもらうと、腰椎カリエスだということがわかった」　辰弥はびっくりしたように眼をみひらいた。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼ばばあ、くたばっちまえ――、という第一｜矢でそれは始まり、相当な無頼漢でも思い及ばないような、豊富な語彙を駆使して呪いと悪罵と嘲弄をあびせかける。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
