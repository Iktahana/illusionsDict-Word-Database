          "standard": [
            {
              "text": "最新のバギーに乗り込み、クワタのコースを猛スピードで駆け抜けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "休日は趣味のクワタで林道を走るのが、彼にとって一番のリフレッシュだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "クワタは四輪駆動なので、砂浜のような不安定な場所でも安定して走行できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "午後八時マンチュリヤの税関、ここでモスクワタイムというのになる。",
