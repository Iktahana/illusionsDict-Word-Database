        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "少い髪を櫛目を透かしてぺっとりと撫でつけている。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇　後頭部に心持ち黄色い白毛が半月型に残っているのを綺麗に櫛目を入れていた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その文樣は釉をかける前に櫛目、象嵌などいつて、櫛樣のものや釘や箆などで文樣をつけ、其儘にして釉をかけたのもあれば、又雲鶴手など彫つたところに白土を象嵌してから釉をかけたのもある。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚れた白い上着に、花模樣のぎらぎらと光りのしたスカート、櫛目もない亂れた髮、蒼ざめた顏の色、大きい黒の石のはいつた奇妙な指輪をわざわざ右の人差し指にはめたところは、何としても、昔の娘の姿とは思へない。",
              "citation": {
                "source": "暗い花",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫛目のよく通る日本人の髪を切るなんてイミ無いわ」「まあ待て待て。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪をこってりと櫛目だてて分け、安物だがズボンの折目はきっちり立った荒い縞背広を着たその男は、黒い四角い顔で私を睨み、「そこへかけて」　顎で椅子をしゃくった。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なりはこの間と変りなく、撫子模様のめりんすの帯に紺絣の単衣でしたが、今夜は湯上りだけに血色も美しく、銀杏返しの鬢のあたりも、まだ濡れているのかと思うほど、艶々と櫛目を見せています。",
              "citation": {
                "source": "妖婆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お帰りあそばせ」　丁寧にこうお辞儀をするその櫛目のはいったばかりの頭髪へ夫人の眼がいった。",
              "citation": {
                "source": "女心拾遺",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どす黒く腐敗した瓜に鬘を被せるとこんな首になろうか、顎にも眉にも毛らしいものは見当たらないのに、頭髪だけは黒々と厚味をもったのが、毎日油をつけるのか、櫛目も正しく左右に分けられていた。",
              "citation": {
                "source": "いのちの初夜",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、頭髪はそれとは反対に驚くほど真黒で、きちんと櫛目を入れて分けられ、鼻下にはやはり念入りに短く刈りこんだ漆黒の髭をはやしてゐた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "匂やかな薄化粧の装いが鮮かで、髪の櫛目が水っぽく電燈の光を反射して輝いている。",
              "citation": {
                "source": "黒髪",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "筬の櫛目を覗いて見た。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お顔のうえの頬ひげと口ひげの間にどんなふうに畦道をつけるか、捲毛の巻き工合をどうするか、おぐしの櫛目をどう入れるか、そのやり方一つ、そのちょっとした呼吸ひとつで、お顔の表情ががらり変ってしまうんですものね。",
              "citation": {
                "source": "かもじの美術家",
                "author": "TUPEJNYJ HUDOZHNIK",
                "note": "青空文庫"
              }
            },
            {
              "text": "はげた茶の帽子に、藍縞の尻切り出立ちと、陽炎さえ燃やすべき櫛目の通った鬢の色に、黒繻子のひかる奥から、ちらりと見せた帯上の、なまめかしさ。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "顎はいつもきれいに剃ってあるし、髪にはキチンと櫛目がはいっている。",
              "citation": {
                "source": "キャラコさん",
                "author": "蘆と木笛",
                "note": "青空文庫"
              }
            },
            {
              "text": "漆黒の長髪を櫛目も見えるほどに品のいいオールバックに撫でつけ、すこしうつむき加減になって香りの高い西洋煙草を燻らしている。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ、衣服は埃ひとつつかぬほどに入念にブラッシをかけられ、頭髪にも丁寧に櫛目が入れられてある。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "この‘Slip ware’の一種に‘Comb ware’と呼ばれるものがあって、線を引いた後、横に櫛目を篦でつけるため、虎斑のような模様を呈する。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "童子の好んだ青い扇のような芭蕉は、もう破れた竜旗のようにはたはたと夕風に櫛目を立てていた。",
              "citation": {
                "source": "後の日の童子",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "流行のハイカラ扮装で、ポマードをしこたまつけ、櫛目をきちんと立てた髪はうしろ頭まで分け目を見せ、刷毛でみがき上げた白い指にはさまざまな指輪をでこでこにはめ、チョッキには金鎖を光らしていた。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず見えたのは、美しく櫛目の通った丸髷だ。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝、櫛目を入れておいたきれいな髪――。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆつくりいつくしめば、いつくしんだだけ人様に対して反動を廻すとかなんとか、さういふ自他のけぢめを掻き毟つたやうな行為は少くなるんだし、自分としてもコクのある気分でゐられるんだ。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気は梅雨で重たくしめり、地上は一面の桑畑である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しなやかに光沢のある鬢の毛につつまれた耳たぼ、豊かな頬の白く鮮かな、顎のくくしめの愛らしさ、頸のあたり如何にも清げなる、藤色の半襟や花染の襷や、それらが悉く優美に眼にとまった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは男子には関係のないだけに、街頭は街頭でも、何となくしめやかにしとやかに行われている。",
              "citation": {
                "source": "千人針",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三疋とももう白い腹を上へ向けて眼はつぶって口も堅くしめて半分死んでゐました。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三疋とももう白い腹を上へ向けて眼はつぶって口も堅くしめて半分死んでいました。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年までは私がファニーの手を堅くしめるとファニーも負けずにしめ返したのに、今年はどうしても堅く握り返すことをしない。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "追いつかれるから」　大臣の子は決心したように剣をつるした帯革を堅くしめ直しながらうなずきました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
