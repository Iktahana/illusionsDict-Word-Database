        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのすこしさきの町角に杯口屋のおくんちゃんの家がある。",
              "citation": {
                "source": "源泉小学校",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もうもたなくなって来た」「そうらしい、ね、くんちゃんと子供と、どっちがもたない？",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなったら、彼の本と彼のオルガンとお母様、お父様、くんちゃん、みっちゃん、誰と誰を皆連れて行ってあげ様などとさえ思った事があった。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくんち、すごくちいさいんだ。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だって、ぼくんち、すごくちいさいんだもん……」「きっとへいきだよ。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈ぼくんち〉ってどこ？",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だいじょうぶ、ものすごおくちいさいから、ぼくんち。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「てっきりまだ、ぼくんちだとおもってた！",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えっと、ぼくんち。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、ぼくは、ぼくんちに、たったひとつおきざりにしてきたんだ！",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれかのいったことをくりかえす……ぼくんちにある花は、いっつもむこうからしゃべりかけてくるのに……』20　さて、王子くんが、さばくを、岩山を、雪の上をこえて、ながながとあゆんでいくと、ようやく１本の道に行きついた。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼくもね、きょう、ぼくんちにかえるんだ……」　それから、さみしそうに、「はるかにずっととおいところ……はるかにずっとむずかしいけど……」　ぼくは、ひしひしとかんじた。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくんちはちいさすぎるから、どれだかおしえてあげられないんだけど、かえって、そのほうがいいんだ。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはね、まず小林さんが、近所の五つくらいの男の子を、男の子ですよ、それをつれて、ぼくんちへ遊びに来るんです。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おくんちのこと　オクンチはもちろん「御九日」であるが、九州北部では一般に秋の祭をそう呼び、必ずしも九日でないところから、これを供日宮日などと書く土地もあり、従って意味が広くなって、八日の鞴祭をカジヤグンチなどという方言さえ出来た。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
