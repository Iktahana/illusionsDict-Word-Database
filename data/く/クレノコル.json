        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "遠くの山並みに、まだ夕日の名残りが暮れ残っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "忙しい一日が終わり、窓の外には寂しげな夕暮れの光が暮れ残っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "宴もたけなわだが、そろそろお開きの時間だ。外はもう暮れ残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "或る日のこと、長い炎暑の一日の終りを告げるものの十分余りの通り雨が馳せ過ぎたあとで、至は自分の居間に充てられた離れの縁に籐椅子を持ち出して、暮れ残る空の明るさに心を吸ひとられてゐた。",
              "citation": {
                "source": "垂水",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとの一隊はバラバラと上野の森へ、暮れ残る道を取って返します。",
              "citation": {
                "source": "芳年写生帖",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "残雪だけが暮れ残る。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
