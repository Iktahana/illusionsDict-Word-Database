    "definitions": [
      {
        "index": 1,
        "gloss": "to linger (faint light of twilight)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
