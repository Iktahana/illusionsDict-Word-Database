        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "然しその海の上にも星変り、月変つて、――と茲で、私の目は漸く海を去つて、なんだか海と空との中間の奥といつた感じの方角に、過ぎ逝ける諸世紀が、黒光りする中世の武具の色をして、堵をなして潜んでゐるやうに感じられる。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "靈智萩原朔太郎ふるへる、微光のよるに、いつぱつ、ぴすとるを撃つ、遠方に、金の山脈、かすかな、黒曜石の發光。",
              "citation": {
                "source": "靈智",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しだいに四方を眺むれば、遠き地平を超え、黒き眞冬を超えて叫びしんりつす、ああ聖地靈感の狼ら、かなしみ切齒なし、にくしんを研ぎてもとむるものを、息絶えんとしてかつはしる。",
              "citation": {
                "source": "巡禮紀行",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪峡宮沢賢治塵のごと小鳥なきすぎほこ杉の峡の奥よりあやしくも鳴るや　み神楽いみじくも鳴るや　み神楽たゞ深し天の青原雲が燃す白金環と白金の黒の窟を日天子奔せ出でたまふ",
              "citation": {
                "source": "雪峡",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "開墾宮沢賢治落ちしのばらの芽はひかり樹液はしづにかはたれぬあゝこの夕つゝましくきみと祈らばよからんをきみきたらずばわが成さんこの園つひにむなしけん西天黄ばみにごれるに雲の黒闇の見もあへず",
              "citation": {
                "source": "開墾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔なべてはしけく　よそほひて〕宮沢賢治なべてはしけく　　よそほひて暁惑ふ　　　　　　改札をならび出づると　　ふりかへる人なきホーム　　　陸の橋歳に一夜の　　　　旅了へしをとめうなゐの　　ひとむれに黒きけむりを　　　そら高く職場は待てり　　　春の雨",
              "citation": {
                "source": "〔なべてはしけく　よそほひて〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔霜枯れのトマトの気根〕宮沢賢治霜枯れのトマトの気根その熟れぬ青き実をとり手に裂かばさびしきにほひほのぼのとそらにのぼりて翔け行くは二価アルコホール落ちくるは黒雲のひら",
              "citation": {
                "source": "〔霜枯れのトマトの気根〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒のサージの背広を着て、テカテカに光るネクタイを締めてゐる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝私は寝床の中で、夏らしく黒く撮れたその写真をみたのだつた。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "湾も、港市――その家々も、たゞ一様にドス黒く見えてゐる。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのマストは黒い、それも煤煙のやうに黒い、――黒い、黒い、黒い……それこそはあの有名な旅順閉塞隊が、沈めた船のマストなのである。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には、晴れた空の一部分に黒い濃い雲形定規のやうな雲があつて、一寸欠け初めたばかりの月が、みえたり隠くれたり、可なり威勢よく渡れ亙つてゆくのが見られた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "柱はすべて、黒く太し。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと私は友の背後に立つ二つの黒い投影を見て驚いた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "海デ沢山遊ビ黒クナリマシタ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして気味わるく物凄い顔をした、雲助のような男たちに脅やかされたり、黒塚の一軒家のような家に泊って、白髪の恐ろしい老婆に睨まれたりした。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして眞黒の群衆が、何十萬とも數知れずに押し合ひながら、お玉杓子のやうに行列して居る。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩いてゐる人たちも、一樣に皆黒いトンビを着て、田舍者の煤ぼけた樣子をして居る。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒川弥太郎、酒井米子、花井蘭子などの芝居であった。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずいぶん痩せ細っているようであったけれども身丈は尋常であったし、着ている背広服も黒サアジのふつうのものであったが、そのうえに羽織っている外套がだいいち怪しかった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼黒い両頬が桃の実のようにむっつりふくれた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒の蝶ネクタイを固くきちんと結んだままで、女給たちにはついに一指も触れなかった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場はときたま、てかてか黒く光るヴァイオリンケエスを左腕にかかえて持って歩いていることがあるけれども、ケエスの中にはつねに一物もはいっていないのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の胸には借金の穴が黒くぽかんとあいている。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場の蒼黒い顔には弱い西日がぽっと明るくさしていて、夕靄がもやもや烟ってふたりのからだのまわりを包み、なんだかおかしな、狐狸のにおいのする風景であった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼黒くでらでらした大きい油顔で、鼻が、――君レニエの小説で僕はあんな鼻を読んだことがあるぞ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜景萩原朔太郎高い家根の上で猫が寢てゐる猫の尻尾から月が顏を出し月が青白い眼鏡をかけて見てゐるだが泥棒はそれを知らないから近所の家根へひよつこりとび出しなにかまつくろの衣裝をきこんで煙突の窓から忍びこまうとするところ。",
              "citation": {
                "source": "夜景",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔ゆがみつゝ月は出で〕宮沢賢治ゆがみつゝ月は出でうすぐもは淡くにほへり汽車のおとはかなく恋ごゝろ風のふくらしペンのさやうしなはれ山の稜白くひかれり汽車の音はるけくなみだゆゑ松いとくろしかれ草はさやぎてわが手帳たゞほのかなり",
              "citation": {
                "source": "〔ゆがみつゝ月は出で〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗谷〔一〕宮沢賢治まくろなる流れの岸に根株燃すゆふべのけむりこらつどひかたみに舞ひてたんぽゝの白き毛をふく丘の上のスリッパ小屋に媼ゐてむすめらに云ふかくてしも畑みな成りてあらたなる艱苦ひらくと",
              "citation": {
                "source": "宗谷〔一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、手紙をろくろく見ずに、声立てて読みました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
