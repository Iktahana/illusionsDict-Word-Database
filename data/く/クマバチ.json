    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese carpenter bee (Xylocopa appendiculata circumvolans)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ひとしきりあの藪の前にある枇杷の古木へ熊蜂が来て恐しい大きな巣をかけた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "根元の洞に、毎年熊蜂が巣を作る。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽気な陽気な時節ではあるがちょっとの間はしーんと静になって、庭の隅の柘榴の樹の周りに大きな熊蜂がぶーんと羽音をさせているのが耳に立った。",
              "citation": {
                "source": "雁坂越",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドン尻に、め組の惣助、婦ばかりの一群には花籠に熊蜂めくが、此奴大切なお嬢の傍を、決して離れる事ではない。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一｜時彼の藪の前にある枇杷の古木へ熊蜂が来て可恐い大な巣をかけた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長は、たたき落とされた熊蜂の巣みたいに、かっとなって憤った！",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし旦那の所属してゐる政党と、村との関係とを説得することが出来たら、熊蜂や、蚯蚓や、山雀も出迎へに引出しただらう。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の悪者はドンドン追っかけて行ったが、その中の一人はあまり上ばかり見ていたので、うっかりして熊蜂の巣に足を踏み込んだ。",
              "citation": {
                "source": "猿小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いて飛び退くと、そのあとから何千何万とも知れぬ熊蜂が一度に鬨と飛び出して、三人の悪者に飛びかかって、滅茶滅茶に刺して刺して刺し殺してしまった。",
              "citation": {
                "source": "猿小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪者共が死んでしまうと、小僧は悠々と樹の上から降りて来て、「ヤア、熊蜂共。",
              "citation": {
                "source": "猿小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊蜂共はブンブンと喜んで、「これさえ下されば、私共は生命も何も要りません」　と土に這い付いてお礼を云った。",
              "citation": {
                "source": "猿小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな熊蜂や蟒蛇も棲んでいる。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "異聞総録・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか、これに熊蜂がとまつたから、これはと思つてそつと見物してゐたところ蜂の槍が折れてしまつて、蜂は這々の態で飛び去つたことがある――といふ挿話を雪太郎は附け加へたりした。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "無數の小蜂を舞ひ込めて襲ふ花の匂ひの隙間から、突如として閃くやうに旋囘して來る熊蜂の鋭い風。",
              "citation": {
                "source": "榛名",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "病室の障子窓からすぐ手の届く所へまで枝を張つてゐる柿の木が、白い小さな花をぽたぽた落す間を、一刻を惜むやうに忙しげに飛び移つてゐる蜜蜂は、ジガ蜂にくらべるとただ善良な律儀者にしか見えなかつたし、山賊のやうな熊蜂は鈍重な愛嬌者であつた。",
              "citation": {
                "source": "ジガ蜂",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二百発の砲弾は、まるでいたずら小僧の群を襲う熊蜂の群のように、敵艦にとびついていったが、まことにふしぎな、そして奇怪な光景であった。",
              "citation": {
                "source": "のろのろ砲弾の驚異",
                "author": "――金博士シリーズ・１――",
                "note": "青空文庫"
              }
            },
            {
              "text": "近い南瓜畑では熊蜂のうなる音がぶんぶん聞えていた。",
              "citation": {
                "source": "田舎医師の子",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれが熊蜂であったなら、鱒の奴、ひどい目にあうのだ。",
              "citation": {
                "source": "魔味洗心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃袋へ嚥み下したところで足長蜂や蜜蜂であったなら、間もなく往生しようが、大きな熊蜂であると、軽くは死なぬ。",
              "citation": {
                "source": "魔味洗心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "寄宿舎から、その春、入寮したばかりの若い生徒たちは、一群れの熊蜂のように、うなりながら、巣離れていった。",
              "citation": {
                "source": "麦藁帽子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お寺の門に熊蜂が巣をかけている。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "兆青流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "「和尚さんは熊蜂を飼っていなさるのかね」「そうではないが、実は怖しくて十何年というもの手が出ない。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "兆青流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊蜂にやられると死んでしもう。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "兆青流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "大変なことになるぞ」　あの大男が熊蜂の総攻撃をうけて、ふくれ上って死んだぶんには、葬式はお手のものでも、棺桶に一苦労しなければならない。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "兆青流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊蜂はワッと真ッ黒にむらがって、門の下一面にまいくるっているが、ホラブンの身体にはフシギにたからぬようである。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "兆青流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の前に熊蜂がワンワンむらがるのに彼はちッとも気にとめず、「チョーセイ。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "兆青流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぎさに水を求めにくる蛇をも襲わんとし、熊蜂、蜥蜴をも、ひと呑みにする。",
              "citation": {
                "source": "雪代山女魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ますます不思議に不思議を重ねて、しきりに樹のきれるを待ちおりしに、やがて倒れたるを急ぎ見れば、欅のうしろに縞蛇の腹部より切断したると、熊蜂の大いなる巣とありたり。",
              "citation": {
                "source": "おばけの正体",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりその原因は、欅の空洞に熊蜂が巣を作りし所へ、蛇が蜂の子を取らんとてその巣にさわり、無数の蜂が一時に鳴り出だしたる出来事である。",
              "citation": {
                "source": "おばけの正体",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "寄宿舍から、その春、入寮したばかりの若い生徒たちは、一群れの熊蜂のやうに、うなりながら、巣離れていつた。",
              "citation": {
                "source": "麥藁帽子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
