        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "絵葉書屋へはいったら一面に散らした新年のカードの中には売れ残りのクリスマスカードもあった。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリスマスカードをよこすくらいで、たいしたことは、いってこないんだ」「メッセージは、『元気かい、いけなくてゴメン。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　あの年の八月に絵はがき、十二月にクリスマスカード、それからたしか翌年と、令子は慶一に三枚のハガキを送ってきた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "隅っこの方に小さな教会のついて居るクリスマスカードが見える。",
              "citation": {
                "source": "少年・春",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリスマスカードをデザインする課題が出されました。",
              "citation": {
                "source": "“青い顔”",
                "author": "間所紗織",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですからクリスマスカードにハロインやイースターの色を使うのは，お祝いのカードを黒ワクにデザインするように間違いだったようです。",
              "citation": {
                "source": "“青い顔”",
                "author": "間所紗織",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は外に出かけて、クリスマスカード用の絵の具を買ってくる。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリスマスカードや絵はがき等だ。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
