    "definitions": [
      {
        "index": 1,
        "gloss": "breaking (into pieces)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "絶壁の下なる大深谷からは、霧がすさまじいいきおいで、皺嗄れ声を振り立てて上って来る、近づくほど早くなるかと思うと、端から砕けてサアッと水球を浴びせる、そうして呻りながら、尾根につかまり、槍先へ這いずり上って、犠牲になる生霊もがなと、捜し廻っている。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、石と恋人の体とは砕け合って、赤い細い石になって、ベルトの上へ落ちました。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "県庁の入口に立っている煉瓦と石を積んだ門柱四本のうち中央の二本の頭が折れて落ち砕けている。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの不幸な人々のうちのきわめて少数なあるものだけは、微塵に砕けた残骸から再生する事によって、始めて得た翼を虚空に羽搏きする。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の方へ下りる坂脇の稲荷の鳥居も、柱が立って桁が落ち砕けていた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピアノが台の下の小滑車で少しばかり歩き出しており、花瓶台の上の花瓶が板間にころがり落ちたのが不思議に砕けないでちゃんとしていた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれでも海べに出ていちばん見飽かずおもしろいと思うのは、遠い沖の果てから寄せて来ては浜に砕ける、あの波でしょう。",
              "citation": {
                "source": "夏の小半日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝙蝠傘の上などに落ちて凍った雨滴を見ると、それが傘の面に衝突して八方に砕け散った飛沫がそのままの形に氷になっている。",
              "citation": {
                "source": "凍雨と雨氷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "町全体が一つの薄い玻璃で構成されてる、危険な毀れやすい建物みたいであった、ちょっとしたバランスを失っても、家全体が崩壊して、硝子が粉々に砕けてしまう。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "長女と長男を死なせた時には彼女の心も砕けたと思われたがそれもやり通して来た。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "西空は一面に都会の夜街の華々しいものが踊りつ、打ち合いつ、砕けつする光の反射面のようである。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "態度に肩を怒らしたところがなくて砕けていた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "醍醐の入江の口を出る時｜彦岳嵐身に※み、顧みれば大白の光｜漣に砕け、こなたには大入島の火影｜早きらめきそめぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は布団翻のけ、つと起ちあがりて、紀州よ我子よと呼びし時、目眩みてそのまま布団の上に倒れつ、千尋の底に落入りて波わが頭上に砕けしように覚えぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "風落ちたれど波なお高く沖は雷の轟くようなる音し磯打つ波砕けて飛沫雨のごとし。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々荒跡を見廻るうち小舟一｜艘岩の上に打上げられてなかば砕けしまま残れるを見出しぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "煉瓦はちょうど落雁か何かで出来てでもいるようにぼろぼろに砕けてしまった。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この瞬間に、私の頭の中には「煉瓦が砕けるだろうか、砕けないだろうか」という疑問と「砕けるだろう」という答とが、ほとんど同時に電光のように閃いた。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその声が煉瓦のまだ砕けない前に完了したのであったか、それとも砕けるのを見てから後であったのか、事柄の経過したすぐ後で考えてみても、どうしてもよくわからない。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果として後日私がこの経験を人に話す場合に「煉瓦が砕けるだろうと思って見ていたら、果して砕けた」と云ってしまう恐れがある。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大腿骨が砕けた黒岩は動けなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "へしゃがれた蟹のように、骨がボロ／＼に砕けていた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの恋は砕けたのだ。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その歩くたびに瑪瑙はガリガリ砕けたのです。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とチュンセ童子が肩の骨の砕けそうなのをじっとこらえて申しました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "干潮で荒い浪が月光に砕けながらどうどうと打ち寄せていました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く「われは横綱らしく強いところを見せようとして左の腕を大きくぶるんと振って相手を片手で投げ飛ばそうとしたが、相手は小さすぎて、われの腕はむなしく相手の頭の上を通過し、われはわが力によろめき自ら腰がくだけて敗れたのである。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただむやみに歩くだけの道ならあるが、散歩といふ感じを特に持つやうな所は附近にない。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里の喫茶店で、街路にマロニエの葉の散るのを眺めながら、一杯の葡萄酒で半日も暮してゐるなんてことは、話に聞くだけでも贅沢至極のことである。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "想像するがままに任せた山、感情を塗りかえした山、その山の暗き森と、深い谷、過去へと深く行き、遠く行くだけ、紀念は次第に成熟する、石の上を走っている水の面の経緯は、幾世の人の夢を描いては消し、消しては描いているのである。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
