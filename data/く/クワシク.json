[
  {
    "uuid": "75bb8b3a-cc65-5c06-a406-5741a750737b",
    "entry": "詳しく",
    "reading": {
      "primary": "くわしく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
