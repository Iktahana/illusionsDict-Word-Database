    "definitions": [
      {
        "index": 1,
        "gloss": "deserted and lonesome",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
