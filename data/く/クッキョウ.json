[
  {
    "uuid": "3c26590c-73be-5c39-9296-5cc263ba1f21",
    "entry": "屈強",
    "reading": {
      "primary": "くっきょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞-の形容詞",
