      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "robust",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "二十四、五かと思われる屈強な壮漢が手綱を牽いて僕らの方を見向きもしないで通ってゆくのを僕はじっとみつめていた。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "屈強の青壮年が体重をささえるために支柱とするはずはないからである。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、二人の巡警は、棺車を守る七八人の屈強な男の敵じゃなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此徳二郎といふ男は其頃二十五歳位、屈強な若者で、叔父の家には十一二の年から使はれて居る孤兒である。",
              "citation": {
                "source": "少年の悲哀",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と振上げた顔を見れば年頃二十六七、背高く肩広く屈強の若者である。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この徳二郎という男はそのころ二十五歳ぐらい、屈強な若者で、叔父の家には十一二の年から使われている孤児である。",
              "citation": {
                "source": "少年の悲哀",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "帽子は被らず、頭髪を蓬々と抓み棄てたが、目鼻立の凜々しい、頬は窶れたが、屈強な壮佼。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が屈強な客が居合せた。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右に就て当局のその後の調べに依ると同未亡人を甥の妻木という青年と一緒にその旅立ちの前夜に殺害して大金を奪って去ったものは九段高林家の後嗣で旧名音丸久弥といった屈強の青年であることがわかった。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼とんびといふから、赫ら顔の、口のあたりに、もぢやもぢやと無精ひげの生えた、眼のぎよろりとした、屈強の男かと思つて出て来た役人は、庭にちよこんと坐つてゐる痩せぎすの、悲しいばかりに柔和な坊さんを見て拍子ぬけがした。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "水色ちりめんのごりごりした地へもって来て、中身の肉体を圧倒するほど沢瀉とかんぜ水が墨と代赭の二色で屈強に描かれている。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い屈強な下婢が二人左右に――姉も妹も痩せ形ながら人並より高い背丈を、二人の下婢の肩にかけた両手の力で危ふく支へて僅かに自由の残る片足を覚束なげに運ばせて来る。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時、レヤチーズは、はじめてボートの支度を下知して、四、五の船客をまずボートに抱き乗せ、つぎに船員の、妻子のある者にも避難を命じ、自分は屈強のいのち知らずの若い船員五、六名と共に船に居残り、おのおの剣を抜いて敵兵の襲来を待機した。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも屈強の供の武士三十人、なんの躊躇も無くつぎつぎと駒を濁流に乗り入れ、大浪をわけて若殿のあとを追った。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に第三の男は屈強な筋肉の、正に典型的の漁夫顏である。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角此踊といふものは、かかる屈強なる、最早分別も出た男のするものとしては甚だ馬鹿氣たものである。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "担いでいるのは年貢を取りに来る乾分の男ともう一人屈強な乞食です。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い屈強な男でした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "屈強な男子達で、狂暴な男性狂者の監禁室の看守ででもあるらしい。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが僕の出身の學校なのです、四十｜幾歳の屈強な體躯をした校長大島氏は、四五｜人の教員を相手に二百｜餘人の生徒の教鞭を採つて居られます。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるに些か思う所存あって、今宵｜新手村の上空を飛行せしに、たまたまこの山中に汝の姿を見受けし故、忍術の極意を以って木遁を行いしが、最前よりの汝の働き近頃屈強なり。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのタイルの片隅に横たえられた長椅子にタキシードを着た屈強の男が三人、腕組みをして並んでいたが一眼で用心棒という事がわかる。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時二十歳前後の屈強の青年であった梅津利彦氏なども、やはり突飛ばされた組で、当時九歳か十歳であった筆者ですらもその例に洩れなかった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "背の高い若い男で、驚くほど屈強で、顔は浅黒く恐ろしげ、手足と胸はヘラクレスのようでした。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭を仕切る塀は高さ三フィートで煉瓦造り、上に横木がついていて、屈強な巡査がもたれかかっていた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と男は日焼けした屈強な救助者たちを疑わしそうに見て、「随分たくさんおるようだが。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その通り、事態はもうすでに、この支えとなる人物がこの屈強な農夫とその養女を救いに来なければならない段にまで来ていた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十前後の屈強な身體で、眼尻のたるんだ、唇の厚ぼつたい男であつた。",
              "citation": {
                "source": "梅雨紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう雨降りの日には、くっきょうなものがあったとおもって、それをくつの上にはきました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵は七人であるとはいえ、くっきょうのおとなどもで、食人鬼のごとくどうもうなる暴漢である、味方は数こそ多いが、筋骨いまだ固まらざる十六歳に満つや満たずの少年たちである、これを思うと、だれもみな一まつの不安を感ぜずにはおられなかった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
