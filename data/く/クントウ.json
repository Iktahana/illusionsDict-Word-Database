[
  {
    "uuid": "6240ecca-a84a-50d8-ab18-ddc4f5d15294",
    "entry": "薫陶",
    "reading": {
      "primary": "くんとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
