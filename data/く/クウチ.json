    "definitions": [
      {
        "index": 1,
        "gloss": "vacant land",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "或時神明館の横の空地に、軽業が掛かつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "２猫が鳴いてゐた、みんなが寝静まると、隣りの空地で、そこの暗がりで、まことに緊密でゆつたりと細い声で、ゆつたりと細い声で闇の中で鳴いてゐた。",
              "citation": {
                "source": "曇つた秋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "古寺やほうろく捨てる芹の中　荒廃した寺の裏庭に、芥捨場のような空地がある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、その空地や、新しく均らされた土の上には、亜鉛屋根だの、軒燈だの、白木の門などが出来て、今まで真鍮の鋲を打つたやうな星の光もどうやら鈍くなり、電気燈が晃々とつくやうになつた。",
              "citation": {
                "source": "亡びゆく森",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "道端、街角、寸隙の空地、あらゆる所に樅の小林が樹ちます。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思って庭を見ると、いつの間にか三人は庭の空地に来ておった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅への誘いは、私の疲労した心の影に、とある空地に生えた青桐みたいな、無限の退屈した風景を映像させ、どこでも同一性の方則が反覆している、人間生活への味気ない嫌厭を感じさせるばかりになった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、わたしはどこへ行くのか知らない、わたしのゆく道路の方角では、長屋の家根がべらべらと風にふかれてゐる、道ばたの陰気な空地では、ひからびた草の葉つぱがしなしなとほそくうごいて居る。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　五　じいさんは所在なさに退屈がって、家の前にある三坪ほどの空地をいじった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この中庭の方は、垣に接近して小さな花壇があるだけで、方三｜間ばかりの空地は子供の遊び場所にもなり、また夏の夜の涼み場にもなっている。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際両側に広い空地を控えたこの垣根では嵐が吹き通したり、雨に洗われたり、人の接近する事が頻繁であったりするので蜂にとってはあまり都合のいい場所ではない。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし長屋は右側ばかりで、左側の空地は紺屋の干場にでもなっているらしく、所まだらに生えている低い秋草が雨にぬれて、一匹の野良犬が寒そうな顔をして餌をあさっていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "その奥は空地になっていて、そこには大きい掃溜めがあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "空地では家を建てるのか人びとが働いていた。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここを登りつめた空地ね、あすこから富士がよく見えたんだよ」と自分は言った。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "トその壁の上を窓から覗いて、風にも雨にも、ばさばさと髪を揺って、団扇の骨ばかりな顔を出す……隣の空地の棕櫚の樹が、その夜は妙に寂として気勢も聞えぬ。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "青き旗、白き旗、二三本その前に立ちて、うしろはただちに山の裾なる雑樹斜めに生いて、社の上を蔽いたる、その下のおぐらき処、孔のごとき空地なるをソとめくばせしき。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、現在の航空地図はまだほんの芽ばえのようなもので普通の地形図に少しばかり毛のはえたものである。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来に、あるいは佇み、あるいはながながと寝そべり、あるいは疾駆し、あるいは牙を光らせて吠えたて、ちょっとした空地でもあるとかならずそこは野犬の巣のごとく、組んずほぐれつ格闘の稽古にふけり、夜など無人の街路を風のごとく、野盗のごとくぞろぞろ大群をなして縦横に駈け廻っている。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "空地の犬の巣に踏みこんで、一時に五匹の犬を相手に戦ったときはさすがに危く見えたが、それでも巧みに身をかわして難を避けた。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それから百人の人たちを連れて大三は森の空地に来ました。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこは柏や楢の林の中の小さな空地でした。",
              "citation": {
                "source": "谷",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは林の奥の古い墓地で苔むす墓が四つ五つ並んでその前にすこしばかりの空地があって、その横のほうに女郎花など咲いていることもあろう。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方この地方には名物の夕凪の時刻に門内の広い空地の真中へ縁台のようなものを据えてそこで夕飯を食った。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の方に少しばかり空地があって、その真上に向ヶ岡の寄宿舎が聳えて見える。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一面におり立った群れの中に一か所だけ円形な空地があるのはどういうわけかと思って考えてみた。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後で学校の森林へ入り、掌と足尖とで森の空地をかもしかのように四つん這いになって跳び歩き、またいろいろの他の獣の歩きかたを示されました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍に、総井戸を埋めたと云う、扇の芝ほど草の生えた空地があって、見切は隣町の奥の庭。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて風説も遠退いて、若菜家は格子先のその空地に生える小草に名をのみ留めたが、二階づくりの意気に出来て、ただの住居には割に手広い。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とて見返る祠は、瓦斯燈の靄を曳いて、空地に蓮の花の紅いがごとく、池があるかと浮いて見える。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
