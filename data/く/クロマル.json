    "definitions": [
      {
        "index": 1,
        "gloss": "black spot",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "テスト用紙の答えには、黒円で正しい選択肢が囲まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "グラフのデータポイントは、小さな黒円で示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の描いた抽象画には、大小様々な黒円が配置されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "じっさい、売物の黒円帽をかぶって売物の煙管をくわえたレクトル・エケクランツは｜弾ねのない売物の大椅子に腰を下ろして――つまり売物のひとつになり切って、眼のまえの狭い往来を眺めくらしていることが多かった。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "追い迫ってくるロケットは、ちょっとだけ横になっただけで、暫くすると、また元のように丸い黒円にかえった。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
