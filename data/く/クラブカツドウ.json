        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "オリエンテイションの最後は、クラブ活動の説明だった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "『寮にもクラブ活動は必要だろう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつらは、「特別クラブ活動」と称して、自習時間中に、堂々とロックンロールを聴いている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれたちだけで、まじめにクラブ活動をつづけようぜ」「ひっひっひ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志や慶一のような例外はあるが、建前では、全員がなにかのクラブ活動に参加しているはずなので、平日の場合、夕食までは、だれもがいそがしくすごすことになっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "例年なら進学率が一〇〇パーセントに近いこの高校では、クラブ活動は二年生の秋、少なくとも三年になるまでには引退となり、学生たちは受験の準備に取りかかりはじめる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに放課後のクラブ活動にはサッカーを選び、授業の終わった四時ごろから、毎日二時間ほどボールを追った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は授業も早く終ったし、クラブ活動もなかったんで、二時ごろだったと思う。",
              "citation": {
                "source": "はやい秋",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごく少数は図書館へいき、それよりもすこしだけ多い数の生徒たちは、それぞれのクラブ活動の場へむかった。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "試験すればいいのに」「昨日、記念の行事がありました」「なになの、それは」「ブラス・バンドの演奏と、クラブ活動で舞踏をしている人たちの踊りの発表と。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
