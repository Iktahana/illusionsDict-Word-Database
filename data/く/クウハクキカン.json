          "literary": [
            {
              "text": "もし六年間の空白期間が、天與の内容への充實として送られてゐたなら、豈、その人の多幸のみかはである。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも長い空白期間を置いて、はじめて……。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから本当は、二日か三日に過ぎない修羅の時間よりは、一年にわたる空白期間の方に、より多くの事件や問題も起こっていたにちがいない。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
