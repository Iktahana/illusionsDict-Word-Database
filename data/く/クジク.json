    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to sprain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "又攘夷論者も、鎖国主義的攘夷論でなくて、国家の面目を傷け、国体の尊厳を毀り、国民の意気を挫く脅迫的開国、城下の盟約開国に悲憤慷慨する尊皇愛国的な攘夷論者であつた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "不行跡から淋病を得、暴飲から心臓異常を来たし、無茶な行動から筋骨を挫くようなことは、招いて得た疾病である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "王たちまち智臣の教えを忘れその馬に向い、我三海を征服せるも北海のみいまだ降らず、それを従えたら汝に乗らぬはず、それに先だって足を挫くとは不心得の至りと言った。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、弱きを助けて強きを挫くという侠気も含まれているには相違ないが、その以外に刺客とか、忍びの者とか、剣客とかいうような意味が多量に含まれている。",
              "citation": {
                "source": "女侠伝",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大日本、朝日の國の信者たち、努めよ、名にし負ふアンチクリストの力を挫く義軍の先驅、上れ、主の如く磔刑に。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "マーキュ　猫王どの、九箇あるといふ足下の命が只一つだけ所望したいが、其後の擧動次第で殘る八箇も叩き挫くまいものでもない。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロレタリア・農民の階級的攻撃を挫くために、支配階級はありとあらゆる文化機関、印刷物、ラジオを通して戦争熱を煽っている。",
              "citation": {
                "source": "国際無産婦人デーに際して",
                "author": "――作家同盟各支部に婦人委員会をつくれ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、それらの勇敢な良心的な若い息子や娘等の努力をも、未だ打挫くだけ、暗い伝習の力はつよい。",
              "citation": {
                "source": "花のたより",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下に愛すべき青春を轢挫く世俗の車輪は、ヘッセのみるところでは、所謂現実的な人々の生活に対する真の愛の欠乏である。",
              "citation": {
                "source": "若き精神の成長を描く文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはあわてて、泳ぐやうに飛びつきざま、忌々しい嵌木の床でつるりと足を滑らして危なく鼻柱を挫くところだつたが、やつと踏みこたへてその手巾を拾ひあげた。",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三　正理を守りて身を棄つるとは、天の道理を信じて疑わず、いかなる暴政の下に居ていかなる苛酷の法に窘しめらるるも、その苦痛を忍びてわが志を挫くことなく、一寸の兵器を携えず片手の力を用いず、ただ正理を唱えて政府に迫ることなり。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつ大志を抱くものは往々貧家の子に多きものなれども、衣食にも差支うるほどにて、とても受教の金を払うべき方便なく、ついに空く志を挫く者多し。",
              "citation": {
                "source": "学校の説",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "後方へか、横へか――避けて、その勢いを挫く外に方法がなかった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "べきん、めりっ、と、戸を、木を折り、挫く音が聞え出した。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸、七瀬が入り込んだとあれば、また、いかなる手段にて、敵を挫く策略が生れて参るかも知れぬ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "その九十郎、今は本心、嬲るのは止めだ、討って取ろうと、そう決心したらしく、刀を中段へ構えて凄く、競り詰めて行く足も鋭く、しかも剣道の定規に則り「先々の先」を挫くの気合！",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三掛け声のその一つ、敵のかかるを挫くのそれだ！",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "剣禅を打して一丸とし、無刀、わずかに十手と縄もて、悪魔を擒縛するがごとく、悪人を縛し挫くにあった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪人と見れば忽ち拳を上げて打って懲らすような事もあり、又貧乏人で生活に困ると云えば、どこまでも恵んでやり、弱きを助け強きを挫くという気性なれども、至極｜情深い人で無闇に人を打つような殺伐の人ではございません。",
              "citation": {
                "source": "業平文治漂流奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "万世一系の皇室を上に戴き、未だ曾て一度も外敵に屈したことがないのみならず、肇国以来、駸々として国力の発展を見つゝ、今や、亜細亜の解放を宣して強大米英の鋒先を挫くべく、決然起つたのが、われわれ日本人であります。",
              "citation": {
                "source": "青年の矜りと嗜み",
                "author": "――力としての文化　第四話",
                "note": "青空文庫"
              }
            },
            {
              "text": "機械の猛威を封じ、物量の優勢を挫くものは、仮に精神力といふ面から見ても、勇気だけではなく、それはより以上優秀な機械の創案及び利用を含み、かつ、一層根本的には、破毀と抵抗の巨大な夢を織り込んだ秘策善謀であつて、その力の源泉は、国民知能の結集、及びその最高水準の遺憾なき活用である。",
              "citation": {
                "source": "心理の洞察",
                "author": "――政治に求めるもの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分ばかりをたのむ慢心、不謙遜な人の心を挫くためにあたへ給ふた神様の鞭でありませう。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を打懲らし、取挫くの力においては自信の有り余る米友が、人を救う段になると、溺死人の一人をどうすることもできないのを、身も世もあらぬほどに口惜しがって、「ちぇッ、その立派な医者を、おいらがひとつ探して来るから、それまで死なさねえようにして置きな」と言い置いて米友は、驀然に走り出しました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は相手の気勢を挫くつもりで、その言出すのを待たず、「お金のはなしじゃないかね。",
              "citation": {
                "source": "申訳",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本が東亜新秩序建設となって今迄の物質的から精神的に生き、弱肉強食の帝国主義的考えから離脱して、弱い者を助け、強い者を挫くと云う所に生き、一宿一飯の恩にも深く感じ、憐れを持ち実利よりも恥を重んずると云う日本精神の発現以外に私は東亜新秩序と云うものが出ないのであると思います。",
              "citation": {
                "source": "現下に於ける童話の使命",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そなたの国の人々、わけても男たちは、弱きをたすけ、強きを挫くのが、持つて生れた気象と聞いてゐましたが……」「いや、できればさうしたいといふのが本心でございませう。",
              "citation": {
                "source": "虹色の幻想（シナリオ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "切っ先をもって敵を攻めて、出ずれば突くぞ退けば追うぞ、避けたら踏んでぶっ放すぞと、竹刀先をもって挫くのである。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大納言の気合をもって、切っ先挫きに挫くのであった。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして児童らに報本反始の大義至誠と、弱きを助けて強きを挫く、すなわち日本精神を植え付けなくてはならぬ。",
              "citation": {
                "source": "日本的童話の提唱",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "野次馬の顏は自己告白の勇氣を挫くに足るものではない。",
              "citation": {
                "source": "三太郎の日記　第三",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
