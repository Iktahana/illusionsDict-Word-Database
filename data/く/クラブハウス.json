        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "荒川放水路の水量を調節する近代科学的｜閘門の上を通って土手を数町川下へさがると右にクラブハウスがあり左にリンクが展開している。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖水の向う縁の在所を示すように間を置いてクラブハウス、鱒孵化場などの灯が点々と蛍のようです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのゴルフ場の番人が、真夜中になって、クラブハウスの窓から、はるか向こうのゴルフ場の一隅に、怪火がゆらぎ（これは一郎のもっていた懐中電灯のことだ）それから朝になっていってみると、約百頭のもぐらが、折角手入れしてあったゴルフ場のフェアウェイを、めちゃめちゃに掘りかえしてあったというのだ。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "スコッチブロスにコーンにクラブハウスサンドウィッチ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルドヴルとオニオングラタン、舌平目の洋酒煮に、クラブハウスサンドイッチ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルドヴル、オニグラ、舌平目にクラブハウス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルドヴル、チキンスープ、平目のグラタン、クラブハウス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "観光ホテルのグリルで、豆のポタージュとフライエグス、クラブハウス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルのグリルでスープ、フィレソール、アメリカンクラブハウス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピータースより、ポタージュとクラブハウスサンドイッチをとる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
