        "examples": {
          "standard": [
            {
              "text": "相撲の土俵には、四隅に異なる色の房が吊るされているが、黒房は玄武を表す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "横綱土俵入りの際に、黒房の下で多くの観客が声援を送った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "黒房は、冬の季節と北の方角を象徴していると言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "もちろん男もヨーロッパ風の服装をした者が多く、それでも黒房のついた赤いタルブシュ（謂わゆるトルコ帽）だけはかぶっている。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
