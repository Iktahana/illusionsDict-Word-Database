    "definitions": [
      {
        "index": 1,
        "gloss": "the wise readily adapt themselves to changed circumstances",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "市場の動向を見極め、社長は君子豹変の勢いで事業計画の全面的な見直しを命じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「朝令暮改」と批判されたが、彼は君子豹変こそが生き残りの鍵だと信じていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "過去のこだわりを捨てて新しい技術を取り入れる姿勢は、まさに君子豹変だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "自由と束縛、君子豹変ということにもなるんだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリスト精神と君子豹変のわけでも、どんと一発言ってやればよかったんだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君子豹変は嘉すべきであるが、併し『紀行』と『修正』との間には、ジードにとってどんな出来事が起きたというのだろう。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "the wise make no scruple in suddenly changing their demeanor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "舞台に上がった瞬間の彼の君子豹変ぶりには、観客全員が息を呑んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "それまでの迷いを断ち切った彼女の君子豹変した決断力が、チームを勝利に導いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "政治家としての彼の身のこなしは、まさに君子豹変、状況に応じて鮮やかに変化する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
