[
  {
    "uuid": "ce32d6bd-e571-5c1b-81ed-2948d52ba6a1",
    "entry": "空前",
    "reading": {
      "primary": "くうぜん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "unprecedented",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "むしろ空前絶後と言いたいくらいに考えていた筆者であった。",
              "citation": {
                "source": "道成寺不見記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗けたのか」　と頬を膨らましてスゴスゴ引き退るトタンに大爆笑と大拍手が敵味方から一時に湧き返るという、空前絶後の不可思議な盛況裡に、無事に予定の退却となった。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "▲将軍、空前の大演説　宿に着いてから日没までは、各々感心にも日記その他の整理をした。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "在京の主なる俳優は殆ど全部出演し、わが劇界空前の名誉なりと喧伝せらる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "清談、閑談、俳談、其中庵空前の――敢て絶後とはいひきらない――賑やかさ喜ばしさであつた。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうの後場はもっと下るかも知れないが構わずに買え……外電のキューバ島の空前の大豊作は嘘だ……」　私はこの意味がちょっと解らなかった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら浪漫派の運動は単に詩壇の一局部にのみ、小波動を以て興ったのでなく、実に文学と芸術と、社会思潮の全般にわたって興ったところの、空前の花々しき大運動だった。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又は虚子が空前の大才で在来西洋人の用を足して来た分類語では、其の作物に冠する資格がないと云う意味でもない。",
              "citation": {
                "source": "高浜虚子著『鶏頭』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争と名のつくものゝ多くは古来から大抵｜斯んなものかも知れないが、ことに今度の戦争は、其仕懸の空前に大袈裟な丈に、やゝともすると深みの足りない裏面を対照として却て思ひ出させる丈である。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しも單に日本の警察機關の成績といふ點のみを論ずるならば、今度の事件の如きは蓋し空前の成功と言つても可からうと思ふ。",
              "citation": {
                "source": "所謂今度の事",
                "author": "林中の鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "各流家元をはじめ長唄界総動員の豪華演奏で、空前の盛事であつた。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人の眼球を一転して、吾国の歴史に於て空前絶後なる一主義の萌芽を観察せしめよ。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　四月二十八日午前九時　今日は空前の早起致し候ため、実は雨でも降るかと心配仕り候処、春光嬉々として空に一点の雲翳なき意外の好天気と相成、明け放したる窓の晴心地に、壁上のベクリンが画幀も常よりはいと鮮やかに見られ候。",
              "citation": {
                "source": "渋民村より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ等はすべて、この空前絶後の鼻の裁判開始前の光景であります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "検事が真先に被告の無罪を主張するという事も空前絶後の一つに数えられたからであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにその死後に於ける裁判に於ても、この本領を空前絶後にまで発揮し得た事を嘉する。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "空前の警戒陣であつた。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "太都夫の如きは命に替へてもと神に念じつゝある決心の色はおのづから人の目にもつくほど故、以心傅心に騎士全體の氣を引き立て其氣組の旺なことは實に空前のことゝいふ有樣であつた。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「唐代は詩文ともに最も隆昌をきわめ、支那においては空前絶後ともいうべき時代でありますから、小説伝奇その他の文学に関する有名の著作も甚だ多く、なにを紹介してよろしいか頗る選択に苦しむのでありますが、その中でわたくしは先ず『酉陽雑爼』のお話をすることに致します。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもその時の怕さつたら全く空前絶後だつたわ。",
              "citation": {
                "source": "〔婦人手紙範例文〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼ノ愚昧ナル善人ガ斯ル惡魔ノ喇叭卒ニ使役セラレテ其レヲ日本ニ向ツテ吹キシコトハ米國史上空前ノ恥辱ナリトス。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはさて置き、曠野城の嫁入り前の女子が昼間｜稠人中で裸で立ち尿をした空前の手際に、仰天して一同これを咎めると、女平気で答うらく、この国民はすべて意気地なしで女同然だ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく高値を払うて教えを受けた中にアペルレースはギリシア空前の画聖、その妙技について一、二談を挙げんに、かつて諸画師と競うて馬を画くに、審査員他の輩に依怙す。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は自分ながら凡そそんな資格には欠けてゐるのを知つてゐたが、真向から私を信じて（空前のことだ、私が人から信じられるなど――）左様な独り決めをしてゐる雪子の今の身の上を考へると、別に否応もなかつた。",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな場合は空前にして絶後なんだから弱輩共は精々喜んでおいたらよからうよ。",
              "citation": {
                "source": "青白き公園",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "培養液として選んだのは第二村木液と仮に私が命名している生理液です」　熱心な聴衆のある者の間には、この大胆な、学界空前の発表に対して、折々驚歎の私語がおこった。",
              "citation": {
                "source": "人造人間",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "不良性と震災後の推移　清浄無垢な少年少女の空前の不浄化は、東京人の堕落の中でも最も深刻な意味を持っている。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "学理と実際……鉄とセメントの化け物然として、吾が国の建築界空前の盛観を作るかのように見えた。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一時間でも早く、私の手許にのこっている第二号機からロケット内の渋谷博士にインタービュウし、空前の探検譚と処女航路の風景とを手にいれんがためであった。",
              "citation": {
                "source": "ある宇宙塵の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、それらのどの国々においても、空前の大地震が起こり、新しい火山の活動となり、日本と同様に、極度の混乱をきわめているという事情が判明したのであった。",
              "citation": {
                "source": "第五氷河期",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
