    "definitions": [
      {
        "index": 1,
        "gloss": "big and round (esp. of eyes)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "虱がわいたとかで、つむりをくりくりとバリカンで刈ってしもうた頭つきが、いたずらそうに見えていっそう親の目にかわゆい。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "くりくり頭に桃色のへこ帯がひとり、角子頭に卵色のへこ帯がふたり、何がおもしろいか笑いもせず声も立てず、何かを摘んでるようすだ。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "くりくりと毛を刈ったつむり、つやつやと肥ったその手や足や、なでてさすって、はてはねぶりまわしても飽きたらぬ悲しい奈々子の姿は、それきり父の目を離れてしまった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "くりくりとしたつむり、赤い縞の西洋前掛けを掛け、仰向いて池に浮いていたか。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年はうむといったが、ぐたりとしてまた臍をくりくりくり。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "くりくり坊主の桃川如燕が張り扇で元亀天正の武将の勇姿をたたき出している間に、手ぬぐい浴衣に三尺帯の遊び人が肱枕で寝そべって、小さな桶形の容器の中から鮓をつまんでいたりした。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "くりくりくりくりくり。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕に何か用でもあってですか」　トシオは曇って居ると云われたことも忘れて、その眼をくりくり丸くして、一層、お祖父さんの顔をみつめました。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　又三郎はまっ黒な眼を少し意地わるそうにくりくりさせながらみんなを見まわしました。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつは頭をくりくりの芥子坊主にしてね、着物だって袖の広い支那服だろう、沓もはいてるねえ、大へんかあいらしいんだよ、一番はじめの日僕がそこを通ったら斯う言っていた。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたまをまん中だけ残して、くりくり剃って、恭しく両手を拱いて、陳氏のうしろに立っていました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、喜美子はそんな綽名をべつだん悲しみもせず、いかにも達磨さんめいたくりくりした眼で、ケラケラと笑っていた。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "目のくりくりした丸顔で、玉も撞くし映画も見るが、浪曲は何よりも好きで、機嫌のいい時は楽燕張りの節廻しで、独りで南部坂を唸ったりしていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "三味線に囃されてちょんぬけをやり、裸になる代りに酒を呑まされ、ヘベれけになって座敷を出たまでは覚えているが、帰ってから二階で親爺に介抱されたような気もするが、あのくりくりした目で見ていられたようにも思われ、それが幻覚であったようにも思われた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "三味線に囃されてちょんぬけをやり、裸になる代りに酒を呑まされ、へべれけになって座敷を出たまでは覚えているが、帰ってから二階で親爺に介抱されたような気もするが、あのくりくりした目で見ていられたようにも思われ、それが幻覚であったようにも思われた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "兩脚の筋肉もくりくりと丸くふくれて來た。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供つぽいくりくりした丸い眼に魅力があつて、この地方の人たち皆に敬愛せられてゐるやうだ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "描眉毛もうすく、鼻もうすく、脣もうすく、耳も肉がなく、小さかったが、大きな朝鮮人らしくない、くりくりした眼附が割にその顔を派手にしていた。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "石垣の間から、とかげがちょろ、ちょろと出てきて、彼の鼻の先まで来ると、不思議そうに、その小さな瞳をくりくり動かして、彼を眺めた。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで人間かと思われるほど、くりくりした目のにんぎょうが、葉と葉のあいだにぶらさがっていました。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい顔に、くりくりした、漆のように黒い目を光らして、小さくて鋭く高い鼻が少し仰向いているのが、ひどく可哀らしい。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「綾小路さんがいらっしゃいました」と、雪は籠の中の小鳥が人を見るように、くりくりした目の瞳を秀麿の顔に向けて云った。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八っちゃんそれは僕んだよ」　といっても、八っちゃんは眼ばかりくりくりさせて、僕の石までひったくりつづけるから、僕は構わずに取りかえしてやった。",
              "citation": {
                "source": "碁石を呑んだ八っちゃん",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかく、雨戸をあけな」　あけさせてみると、いかさま座頭仙市がそりたてのくりくり頭をかかえるようにして、こちらに背を向けながら、じつに必死と震えているのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お次はなんじゃ」「酒屋の甚兵衛めにござります」「その隣のくりくり頭をしたおやじは何者じゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            }
          ]
        }
