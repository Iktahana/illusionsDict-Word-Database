    "definitions": [
      {
        "index": 1,
        "gloss": "peafowl (incl. the male peacock, female peahen, and young peachick)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
