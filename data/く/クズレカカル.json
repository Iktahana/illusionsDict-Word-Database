[
  {
    "uuid": "cab2a030-a673-5d69-b2ca-286753cf82c3",
    "entry": "崩れかかる",
    "reading": {
      "primary": "くずれかかる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
