        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "車停むるところへ、はや馴れたる末の姫走り来て、「姉君たち『クロケット』の遊したまへば、おん身も夥になりたまはずや、」とわれに勧めぬ。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "車とどむるところへ、はや馴れたる末の姫走り来て、「姉君たち『クロケット』の遊びしたまえば、おん身もなかまになりたまわずや」とわれにすすめぬ。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピヤノと竝んだ書棚の中にはミセズ・オリファントやクロケットなどの小説が詰まつてゐた。",
              "citation": {
                "source": "湖水めぐり",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――幕――第二幕クロケットのコート。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしディヴィー・クロケットのＴシャツはもうなく、いまではスパイロ・アグニューのＴシャツが売られている。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
