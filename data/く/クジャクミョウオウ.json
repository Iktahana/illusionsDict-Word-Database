    "definitions": [
      {
        "index": 1,
        "gloss": "Mahamayuri (deity usu. depicted riding a peacock)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
