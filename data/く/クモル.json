    "definitions": [
      {
        "index": 1,
        "gloss": "to get cloudy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今日ぁ午まがらきっと曇る。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば「鉄砲の遠音に曇る卯月かな」というのがある。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ道理で、坂は照る照る鈴鹿は曇る＝といい、袷遣りたや足袋添えて＝と唱える場合には、いずれも疲を休めるのである、無益なものおもいを消すのである、寧ろ苦労を紛らそうとするのである、憂を散じよう、恋を忘れよう、泣音を忍ぼうとするのである。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何、脱げば可さゝうなものだけれど、屋根一つ遠くに見えず、枝さす立樹もなし、あの大空から、遮るものは唯麦藁一｜重で、赫と照つては急に曇る……何うも雲脚が気に入らない。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうあ午まがらきっと曇る。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な「古池やかわず飛び込む水の音」はもちろんであるが「灰汁桶のしずくやみけりきりぎりす」「芭蕉野分して盥に雨を聞く夜かな」「鉄砲の遠音に曇る卯月かな」等枚挙すれば限りはない。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になると曇るので気づかずにいたが、もう九日ぐらいだろうかと思われる上弦というより左弦ともいうべきかなり肥った櫛形の月が、川向うの密生した木立の上二段ほどの所に昇っていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し晴れてゐた空が急に曇ると霰が夕立ちのやうにさあつと激しく音を立てゝ寄せて來る。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時は又氣温が急にゆるんで空が春らしく薄曇る。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "生際曇る、柳の葉越、色は抜けるほど白いのが、浅黄に銀の刺繍で、これが伊達の、渦巻と見せた白い蛇の半襟で、幽に宿す影が蒼い。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、半ば乱れた独言、聞かせぬつもりの声が曇る。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處へ病上りと云ふ風采、中形の浴衣の清らかな白地も、夜の草葉に曇る……なよ／＼とした博多の伊達卷の姿で、つひぞない事、庭へ出て來た。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ道理で、坂は照る／＼鈴鹿は曇る＝といひ、袷遣りたや足袋添へて＝と唱へる場合には、いづれも疲を休めるのである、無益なものおもひを消すのである、寧ろ苦勞を紛らさうとするのである、憂を散じよう、戀を忘れよう、泣音を忍ばうとするのである。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の涙に曇る顏を見て『あら、叔父さんは如何かして。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　振袖の声が曇ると、多津吉も面を伏せた。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と声が曇ると、「…………。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲の行方は山なりや、海なりや、曇るかとすれば又眩き太陽。",
              "citation": {
                "source": "五月より",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時候が丁ど梅雨にかゝるから、雨の降らない年の、月ある頃でも、曇るのであらう。",
              "citation": {
                "source": "祭のこと",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……もの案じに声も曇るよ、と思うと、その人は、たけだちよく、高尚に、すらりと立った。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とただ懐かしげに嬉しそうにいう顔を、じっと見る見る、ものをもいわず、お民ははらはらと、薄曇る燈の前に落涙した。",
              "citation": {
                "source": "女客",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "口惜や、われら、上根ならば、この、これなる烏瓜｜一顆、ここに一目、令嬢を見ただけにて、秘事の悟も開けましょうに、無念やな、老の眼の涙に曇るばかりにて、心の霧が晴れませぬ。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人に聞かれたのでは極りが悪いね……」　西明寺を志して来る途中、一処、道端の低い畝に、一叢の緋牡丹が、薄曇る日に燃ゆるがごとく、二輪咲いて、枝の莟の、撓なのを見た。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月　向日葵、向日葵、百日紅の昨日も今日も、暑さは蟻の數を算へて、麻野、萱原、青薄、刈萱の芽に秋の近きにも、草いきれ尚ほ曇るまで、立蔽ふ旱雲恐しく、一里塚に鬼はあらずや、並木の小笠如何ならむ。",
              "citation": {
                "source": "月令十二態",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともすれば曇ることもあつた。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "加奈子は裸の赤ん坊の温気で重量器の磨き上げた真鍮の鎖が曇るストックホルムの優良児の奨励共進会を思い出した。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃霧はそそぐ……甘く、また、重く、くるしく、いづくにか凋れし花の息づまり、苑のあたりの泥濘に落ちし燕や、月の色｜半死の生に悩むごとただかき曇る。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十一年八月　　魔国のたそがれうち曇る暗紅色の大き日の魔法の国に病ましげの笑して入れば、もの甘き驢馬の鳴く音にもよほされ、このもかのもに悩ましき吐息ぞおこる。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十一年八月　　蜜の室薄暮の潤みにごれる室の内、甘くも腐る百合の蜜、はた、靄ぼかし色赤きいんくの罎のかたちしてひそかに点る豆らんぷ息づみ曇る。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ち、ち、ち、ち、ともののせはしく刻む音……さもあれや、雨はまたゆるにしとしと暮れもゆくゆめの曲節……いづこにか鈴の音しつつ、近く、はた、速のく軋、待ちあぐむ郵便馬車の旗の色見えも来なくに、うち曇る馬の遠嘶。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "煤煙くもる裏街の貧しき家の窓にさへ斑黄葵の花は咲きたり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
