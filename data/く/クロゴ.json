    "definitions": [
      {
        "index": 1,
        "gloss": "stage assistant dressed in black",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "月光うけて失神し　　庭の土面は附黒子。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論黒子だから顏なんぞ一つだつて見えやしない。",
              "citation": {
                "source": "自分の變態心理的經驗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣服の左前なくらいはいいとしても、また髪の毛のなでつけ方や黒子の位置が逆になっているくらいはどうでもなるとしても、もっと微細な、しかし重要な目の非対称や鼻の曲がりやそれを一々左右｜顛倒して考えるという事は非常に困難な事である。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "襟半の若亭主、半三郎の嫁にというお話で一杯頂戴して、腕に縒をかけて調べ上げましたので、両親は勿論のこと、本人さえ知らぬ尻の割目の黒子までも存じておりまする」「はははは。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒子を着た助手などはほとんどただぼやけた陰影ぐらいにしか見えないのである。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄色く光る障子を背景にして、黒子のように黒く点ぜられたその蝿は、六本の脚の微細な動きかたまでも清逸の眼に射しこんだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして四角い俥の背の真中あたりへ、わずかに、ちょん、と見せて居た切下げの髪の後姿も、小さく小さく、ぽつんと一つ黒子を打った様になった頃、俥は野のはてに近い小学校と、鎮守様の杜の間へとうとう隠れて仕舞ったのである。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に黒子を抜いた時の硝酸が入っていた。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦同士も見惚れたげで、前へ※り、背後で視め、姿見に透かして、裸身のまゝ、つけまはいて、黒子が一つ、左の乳の、白いつけ際に、ほつりとある事まで、よう知つたと云ふ話。",
              "citation": {
                "source": "三人の盲の話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……其の黒繻子に、小辨慶の藍と紺、膚の白さも可いとして、乳房の黒子まで言ひ當てられました、私が其の時の心持、憚りながら御推量下さりまし。",
              "citation": {
                "source": "三人の盲の話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "色の浅黒い、中高な、右の頬の黒子が目にたつ、お糸さんは佳い女の方ではなかつた。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "両肩が強く骨立つて頸が益益長く見える、賤げな左の頬の黒子と鍵の様に曲つた眼尻と、ひつくり返すやうな目付をして人を見る癖と、それから遇ひさへすれば口説上手にくどくど云ふ口。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "船か雁か、か、ふとそれが月影に浮ぶお澄の、眉の下の黒子に似ていた。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳朶に黒子も見えぬ、滑かな美しさ。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はちまきをした顔の横っちょうに、まるい萩の葉が一まい、大きな黒子みたいにへばりついていました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "建文帝の左の御趾には黒子ありたまいしことを思ひ出でゝ、亮近づきて、御趾を摩し視るに、正しく其のしるし御座したりければ、懐旧の涙｜遏めあえず、復仰ぎ視ること能わず、退いて其由を申し、さて後自経して死にけり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この指一本、妙の身体を秘した日にゃ、按摩の勢揃ほど道学者輩が杖を突張って押寄せて、垣覗きを遣ったって、黒子一点も見せやしない、誰だと思う、おい、己だ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その神さんの傍に鼻の黒子の眼につく可愛い女が、人なつこい顔をしていた。",
              "citation": {
                "source": "変災序記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻も大きければ、口も大きい、額の黒子も大入道、眉をもじゃもじゃと動かして聞返す。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "和尚はまじりと見ていたが、果しがないから、大な耳を引傾げざまに、ト掌を当てて、燈明の前へ、その黒子を明らさまに出した体は、耳が遠いからという仕方に似たが、この際、判然分るように物を言え、と催促をしたのである。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　小鼻に皺を寄せて、黒子に網の目の筋を刻み、「御都合じゃからお蝋は上げぬようにと言うのじゃ。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と快げに、小指の尖ほどな黒子のある平な小鼻を蠢かしたのである。",
              "citation": {
                "source": "山の手小景",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはこの番頭にはじめて興味ある関心を持ち出しまして、試に、「いくら耳だけ、福耳にしたって、眼尻に泣｜黒子があっちゃあ駄目じゃないの」　と突き崩してみます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓜子、瓜子は眼の下の小さ黒子歯にあてつつ、歯にあてつつ、愚しく美しく時は過ぎぬ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓜子、瓜子は眼の下の小さ黒子齒にあてつつ、齒にあてつつ、愚しく美しく時は過ぎぬ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "七兵衛はやはり無言で、娘の右の耳の下にある一つの黒子を見つめながら、探るようにまた訊いた。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "気をつけて見ると、右の耳の下に証拠の黒子がある。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の耳の下には何時も見ている小さな黒子さえあった。",
              "citation": {
                "source": "怪僧",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は黒子に終わるのみだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、青白い兄の顔には黒子が一つもなかった。",
              "citation": {
                "source": "嫂",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            }
          ]
        }
