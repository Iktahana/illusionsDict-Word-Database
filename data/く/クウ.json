  {
    "uuid": "dd779772-d7fa-527e-8c30-622a32a4fe82",
    "entry": "くう",
    "reading": {
      "primary": "くう",
      "alternatives": [
        "くー"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "感動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "phew",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
