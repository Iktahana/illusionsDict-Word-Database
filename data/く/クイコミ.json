[
  {
    "uuid": "a1b752bb-0d81-5bef-a3ef-3a4cfbd49c79",
    "entry": "食い込み",
    "reading": {
      "primary": "くいこみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
