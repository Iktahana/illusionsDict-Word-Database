        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "瓜わらべはくねくね可憐な鳴声を立てて鼻面を翁の胸にこすりつけた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "くねくね曲った山路をならんでのぼりながら、雪は、なにかの話のついでに、とつぜん或る新進作家の名前で私を高く呼んだ。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼は肥えたからだをくねくねさせてその油土くさい外套を脱ぎ、眞野へ手渡した。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山路はゆるい傾斜をもつてくねくねと曲つてゐた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、むっちり肉のついた肩や、盛り上った胸のふくらみや、そこからなだらかに下へ流れて、一たん窪み、やがて円くくねくねと腰の方へ廻って行く悩ましい曲線は、彼女がもう成熟し切った娘であることを、はっと固唾を飲むくらいありありと示していた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "といへば、はや察せられるやうに、口繩坂はまことに蛇の如くくねくねと木々の間を縫うて登る古びた石段の坂である。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼黒く燻んだ古代人形はほぼ一定の律動をもって動く、くねくね、きゅーっぎゅっとく。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟は更紗染めの蒲團の下でからだをくねくねさせて何か言はうとしてゐるらしかつたが、私の方を盜むやうにして見て、そつと微笑んだ。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女史はからだを、くねくねさせて、「あの、いただけないんざますのよ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車がくねくね電光型に曲折しながら山をのぼるにつれて、野山が闇の空を明るくするほど真白に雪に覆われているのがわかって来た。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたいよう、いたいようと叫びながら、からだを苦しげにくねくねさせて、そのうちにころころ下にころがっていった。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その山間の小駅から、くねくね曲った山路を馬車にゆられて、約二十分、谷間の温泉場に到着した。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その山間の小駅から、くねくね曲つた山路を馬車にゆられて、約二十分、谷間の温泉場に到着した。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりは寢床のうへに坐つて、くねくねと曲つた線のひかれてあるボオル紙へ駒をならべ、早い將棋をなんばんとなくさした。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おや、誰か居るのかなとも思はれ、蒲團から上半身をくねくねはみ出させて腕をのばし襖をあけてみたら、若い尼が立つてゐた。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三造にはくねくね曲った小路がよく分らなかった。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋食とちがう、星の名や」　君枝は肩をくねくねさせて笑い、「――ほな、南十字星は……？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、帰れといわぬだけ、――いや、何一つ口を利かずに、ついて来るのに任せて、やがて、高台寺の道を清水の参詣道へ折れ、くねくねと曲って登って行くと、音羽山が真近に迫り、清閑荘というアパートが、森の中にぽつりと建っていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内人達はしばらくその両方を見比べていたが、やがて、そのくねくね曲った方の一方に攀じのぼると、背中に負って来た棒や板や蓆などを、その枝と枝との間に打付けて、忽ち其処に即製の桟敷をこしらえ上げて了った。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "突き当って右へ折れると、ポン引と易者と寿司屋で有名な精華学校裏の通りへ出るし、左へ折れてくねくね曲って行くと、難波から千日前に通ずる南海通りの漫才小屋の表へ出るというややこしい路地である。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉の下から、一筋の赤い血が流れ出ていまして、くねくね曲がりながら通路の反対側まで続いていて、壁の下に血だまりを作っていたんです。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには脂ぶとりにふとった水へびが、くねくねといやらしい白茶けた腹をみせていました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者桂月氏は、松の枝の屈折の仕方に人工的なものを加へない、描写の上では加へてゐるが、対象の事実を歪曲しない、これらの松の枝は、くねくねといろいろの角度に曲つてゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしが先に参りますわ」　いっしょに水煙が上がって、波間に彼女の姿はくねくねと動いたとみえたが、まさにそれは人魚です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "村正騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの、もうし馬方さん、身延のお山へはまだ遠うござんしょうかと、袂をくねくねさせながら、やさしく言うんでね。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のその袂をくねくねさせて赤い顔を致した椋鳥とやらに、身共も共々どじょうにして貰おうゆえ、急いでついて参れ」「ありがてえ。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "――きっとあの手でやられたんだ、おいらにさっき道をきいたあの伝でね、袂をくねくねさせながら恥ずかしそうに近よって来るんで、ぼうッとなっているまにスラれちまったんですよ。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
