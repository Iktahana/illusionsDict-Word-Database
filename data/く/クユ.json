        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "悔ゆれど及ばず、かなたなる境内の鳥居のあたりまで追いかけたれど、早やその姿は見えざりき。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "新人の懺悔は、罪を悔ゆるのではなくして、罪を忘れたいといふ一念である。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悔ゆれど及ばず、かなたなる境内の鳥居のあたりまで追ひかけたれど、早やその姿は見えざりき。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（悔ゆるともいまは詮なし）見よ！",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "末段更に、財主の妹を殺したる一條を難じて「その氣質はかねて聞たる正直質樸のものたるに、これをも殺したるはいかにぞや………さてはのち我にかへりて大にこれを痛み悔ゆべきに、」云々と言はれたり。",
              "citation": {
                "source": "「罪と罰」の殺人罪",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "悔ゆれどもせむすべ知らに。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "悔ゆとも将た奚ぞ及ばん。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悔ゆるとも将た奚ぞ及ばん。",
              "citation": {
                "source": "牡丹燈籠　牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "行かんと欲するところに行き、住まらんと欲するところに住まりて、さて不幸に遭はば、そは自ら作せるなれば、悔ゆることもあらざるべし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "古木などむやみに伐り散らすは人気を荒くし、児童に、従来あり来たりし旧物一切破壊して悔ゆることなかるべき危険思想を注入す。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "外人が鋭意して真似んともがく所以のものを、われにありては浪りに滅却し去りて悔ゆるなからんとするは、そもそも何の意ぞ。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては一大事、医師の診察によりて、分娩の事｜発覚せば、妾は兎も角、折角｜怠りたる母上の病気の、又はそれが為めに募り行きて、悔ゆとも及ばざる事ともならん。",
              "citation": {
                "source": "母となる",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては一大事、医師の診察によりて、分娩の事発覚せば、妾はともかく、折角怠りたる母上の病気の、またはそれがために募り行きて、悔ゆとも及ばざる事ともならん。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "衆一語を發するものなく、各自の行動の聊か輕卒なりしを悔ゆるかの如くであつた。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しお品が死んだ時野田への立ち際がよくなかつたことを彼自身の心にも悔ゆる處があつたので強ひて厭な勘次へ挨拶をして一時なりとも肩身を狹くせねばならないのを厭うて遂憶劫に成るのであつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば最後に彼は「これをもて我れ自ら恨み（自己を諱み嫌い）、塵と灰との中にて悔ゆ」と悔改の涙を出すに至ったのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「我れ知る汝は一切の事をなすを得給う」といい、また「われ汝の事を耳にて聞きいたりしが今は目をもて汝を見奉る、これをもて我れ自ら恨み、塵灰の中にて悔ゆ」という。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いうまでもなく「これをもて我れ自ら恨み塵灰の中にて悔ゆ」との彼の大なる謙遜の結果である。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "退いてはこれを悔ゆるも、又折に触れて激すれば、忽ち勢に駆られて断行するを憚らざるなり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し身の楽と心の楽とを併享くべき幸無くて、必ずその一つを択ぶべきものならば、孰を取るべきかを知ることの晩かりしを、遣方も無く悔ゆるなりけり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "悔ゆるところがない。",
              "citation": {
                "source": "スケツチ",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "誠実にして悔ゆるところなし――これだけで人間は十分だ。",
              "citation": {
                "source": "心理の縦断と横断",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "衆生済度に働きながらも尚その裏に動く慾心を正直に悔ゆるところは他人の真似の出来ぬ徳であらう。",
              "citation": {
                "source": "闘戦勝仏",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は頭のものを取ることを、忘れたという盗賊としての失策を、或いは無能を、悔ゆる心は少しもなかった。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の血を見る事を恐れず明暮れを只争闘と罪悪に暮して悔ゆる所のない哀れな不具な心を持ったものどもでも、一度若しこの美くしさをしみじみと感じたならば、悔いと安心の涙にむせびながら尊い美を感謝するに違いない――――と。",
              "citation": {
                "source": "繊細な美の観賞と云う事について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "志村と逢つたことを悔ゆることにならうとのおそれだつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺すのも、恐れるのも、悔ゆるのも、自殺するのも、けっして当人が勝手にやった訳ではない。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "笹村の頭には、結婚するつもりで近ごろ先方の写真だけ見たことのある女や、以前大阪で知っていた女などのことが、時々思い出されていたが、不意にどこからか舞い込んで来たこうした種類の女と、爛れ合ったような心持で暮していることを、さほど悔ゆべきこととも思わなかった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫くゆくと自転車を坂の下に落として、自分一人は草を掴めば上れるが、自転車を置いとくわけにもいかずといふ災難者にあつた。",
              "citation": {
                "source": "（七銭でバットを買つて）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "れいの低い声で、「きょうは八十八夜」そうひとこと呟いたかと思うともう、てれくさくてかなわんとでもいうようにむっくり立ちあがって両肩をぶるっと大きくゆすった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
