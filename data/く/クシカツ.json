          "literary": [
            {
              "text": "そして、帰り途に草餅や串カツなども釣った。",
              "citation": {
                "source": "瀞",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "まッすぐ支局へ行けばよかったものを、新京極をブラついて、串カツで一杯ひっかけたりしたから、支局へ現れたのが、十一時五分だ。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀井と梅田地下のスエヒロで串カツとカレーライス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の終り、外へ出る元気もなく部屋でスエヒロの串カツとライスカレーを食ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "山がやといふ串カツ屋みたいなとこへ入る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんにゃくのみそでん、串カツ、卵やき、皆お粗末で不味し。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
