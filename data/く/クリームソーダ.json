        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "アメリカ映画はヤンキー教の経典でありチューインガムやアイスクリームソーダの余味がある。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地の利を生かし、父や知り合いのつてを頼って部品を集めたウォズニアックは、近くに住むハイスクールの後輩のビル・フェルナンデスを引き込んで、クリームソーダ片手に数週間ぶっ続けで作業に取り組んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューターとして機能する最小限のハードウエア構成で仕上げられたマシンは、クリームソーダコンピューターと名付けられた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九五四年二月に生まれ、ホームステッドハイスクールでジョン・マッカラムのエレクトロニクスの授業の洗礼を受けていたスティーブン・ジョブズは、自分以外にもこの世に才能を持った人間が存在していることを、クリームソーダコンピューターによって思い知らされた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "年下の少年に披露したことに満足することなく、ウォズニアックはクリームソーダコンピューターに世間の注目を集めようと、地元の『サンノゼマーキュリー』紙の記者に連絡をとった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリームソーダコンピューターは永眠して、ウォズニアックの天才ぶりが世に知れ渡るのはもう少し遅れることになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは資生堂でアイスクリームソーダを飲んだ。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂糖菓子やドラッグストアの詰め合わせ、アイスクリームソーダや人口香料、は他の強力な原因である。",
              "citation": {
                "source": "簡約医学史",
                "author": "A Concise History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツナシマで理髪し、舟和でチョコレートアイスクリームソーダをのむ、宿酔気味で色々水分を欲する朝だ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "座へ出ると、アイスクリームソーダ二杯に、コゝアを一杯、アイスウォター限りなくのむ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "中村屋でコーヒーとアイスクリームソーダを飲み、砧村へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
