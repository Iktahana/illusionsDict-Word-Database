    "definitions": [
      {
        "index": 1,
        "gloss": "to descend",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それでも、わからないならば、黙って引き下るばかりである。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "潮入時なりければ、流を下るが却りて水に逆らふなりけり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠義なハルメソンとその子が王の柩を船底に隠し、石ころをつめたにせの柩を上に飾って、フィヨルドの波をこぎ下る光景がありあり目に浮かんだ、そうしてこの音楽の律動が櫂の拍子を取って行くように思われた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西郷像の方へ行きたれども書生の群多くてうるさければ引きかえしパノラマ館裏手の坂を下る。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　性温厚の浦島も、そんなにまでひどく罵倒されては、このまま引下るわけにも行かなくなつた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次第に喬木の森林に入った、白く光る朽木は、悪草の臭いや、饐えたような地衣の匂いの中に立ち腐れになっている、うっかり手が触れると、海鼠の肌のような滑らかで、悚然とさせる、毒蚋が、人々の肩から上を、空気のように離れずにめぐっている、誰も螫されない人はない、大樺池を直ぐ眼の下に見て、ひた下りに下る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここ「天地の境」五、六合目の等高線、森林を境として、山を輪切りにしたところの御中道を彷徨する私は、路の出入に随って、天に上り、地を下る、その間を、鳥と、虫と、石楠花が、永久｜安棲の楽土としている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "天子山脈の上に、湖水をたたえたような雲は、山の落ち口に添うてはい下る。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　乱雑の美　五、六合間の等高線をゆく、御中道の大沢近くくると、にわかに婉曲してひた下りに下る。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "向ふ岸もまた黒いいろの崖が川の岸を下流に下るにしたがってだんだん高くなって行くのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱海へ下る九十九折のピンヘッド曲路では車体の傾く度に乗合の村嬢の一団からけたたましい嬌声が爆発した。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二荒の山にまします女神だち歌のわく子にさちあらせたまへ翌日朝早く案内者一人｜召し具し二人きおいにきおいて滝壺に下る。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この傾向を逆に見れば、もっと古い時代に溯れば、更に多くの音があったのが、時代の下ると共に他の音と同音になって遂に奈良朝におけるごとき八十七音になったのではあるまいかと思われる。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥州にいる牛若丸に逢いたくなった母｜常盤が侍女を一人つれて東へ下る。",
              "citation": {
                "source": "山中常盤双紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしてもシカゴからセントルイまで三百二十二マイルの流れを下るには十一日くらいかかるから、この間には病菌は大抵死滅するだろうという事に帰着したようである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　進藤、ジリジリ下る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の頂上を暫らく行くと、又、次の谷間へ下るようになっていた。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二重硝子の窓を通して、空の橇が馭者だけを乗せて、丘の道を一列につゞいて下るのが見えた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　副官が、命令を達するために、次の部屋へ引き下ると、彼はまた叫んだ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘を下ると、浅い谷があった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『いっそのこと山上の小屋に一泊して噴火の夜の光景を見ようかという説も二人の間に出たが、先が急がれるのでいよいよ山を下ることに決めて宮地を指して下りた。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "トロッコは、山を下ることが愉快であるかのように、するすると流れるように線路を、辷っていた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし今汽車がやって来たらはねおりるかぶら下るかだ。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて斯う云うふうに火はあつく、乾かし、照らし騰る、水はつめたく、しめらせ、下る、鳥は飛び、またなく。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向う岸もまた黒いいろの崖が川の岸を下流に下るにしたがってだんだん高くなって行くのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "斜めに袈裟になって結目がすらりと下る。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」合はせて六｜里余、あの磽※たる樵路を、連もなく、と思ふと、三｜角先生に宜しく、と挨拶して、ひとり煢然として峠を下る後態の、湖は広大、山毛欅は高し、遠見の魯智深に似たのが、且軍敗れて、鎧を棄て、雑兵に紛れて落ちて行く宗任のあはれがあつた。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊女の句に名高き○駒形の駒形堂を右に見、駒形の渡船場を過ぎ、左には長屋｜越に番場の多田の薬師の樹立を望みて下ること少許すれば○厩橋に至る。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "金ですむ事なら、わけないけれども、女たちが、それだけで引下るようにも思えない。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さびしや空はひねもす白金、はやわが手かたく合掌し、瞳はめしひ、腦ずゐは山路をくだる。",
              "citation": {
                "source": "偏狂",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
