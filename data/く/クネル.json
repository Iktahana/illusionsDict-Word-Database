[
  {
    "uuid": "164ddf5d-6564-5358-be5c-026d4d7fc543",
    "entry": "くねる",
    "reading": {
      "primary": "くねる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to bend loosely back and forth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何ものにも捉はれない野蛮人めいた狂暴無智の感情の大浪と、そのうねりくねる所の狂的なリズム。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "あつとも言はず、色男、搖るやうにわな／＼と身をくねると、がつくりと成つて、腰から先へ、べた／＼と膝が崩れる。",
              "citation": {
                "source": "麥搗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あら、裾の方がくすぐつたいとか、何とかで、娘が騷いで、まづ二枚折の屏風で圍つたが、尚隙があいて、燈が漏れさうだから、淡紅色の長じゆばんを衣桁からはづして、鹿の子の扱帶と一所に、押つくねるやうに引かけて塞いだのが、とに角一寸媚めかしい。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "枝はといえば、みんな、ねばねばした長い腕で、まるで、ミミズのようにまがりくねる指を持っていました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夜は早くねるかえ。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "裳裾のようにパッとひらいた頽廃の夜が、葉鶏頭の花にも似た強烈な色彩に揺れて、イヴニングドレスの背中をくりぬいて見せた白い素肌が、蛇のようにくねると、そのくぼみに汗が汗ばみ、女の体臭を男の体臭が絞り出すような夏の夜の踊りに、体の固い若いダンサーのステップもいつか粘るのだった……。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "急流が曲がりくねる深い谷を流れ、大平原では冬に銀色の雪、夏にはアルカリの灰が一面に広がる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ顔を合わせればどうかというと、すねるような、くねるような、その素ッ気のなさ加減、傍で見る婆さんの目にも気の毒なくらい。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "源吉は、常連らしく、何気なさそうな顔をして、松喜亭のドアーを潜ると、昼でも薄暗いボックスの中に、京子のピチピチとくねる四肢を捕えた。",
              "citation": {
                "source": "鉄路",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お風呂に入ったらねむくなって何も出来ず早くねる。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "葡萄粒をわたりくねれる毛虫かな　　　あふひ怒り蛇の身ほそく立ちし赤さかな　　　同白豚や秋日にすいて耳血色　　　久女　美しい葡萄粒を這いくねる毛虫。",
              "citation": {
                "source": "大正女流俳句の近代的特色",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月十日（月曜）　昨夜、すっかり水で体を拭いて、本当に早くねるつもりのところやっぱりなかなか眠れなかった。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちはそうとは知らずにきいているから、君の結論をきくと、オヤオヤ、あれはみんなここへくるための道中か、ムダな道を曲りくねるものだと思って、いっぺんに興がさめてしもう。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "上身も初めよりは多く曲がりくねる。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（湾内の曲がりくねる水は王宮をめぐり、夕日は波に照り映えて橋は弧を描く。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "（河口は曲がりくねること蛇のごとく、市街は浅いなぎさに連なって建つ。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何が何やら、少しもわかりませんね」「死骸は羽織を着て居るが、羽織の紐が取れて居るだらう、――この通り飛んでもない方に抛り出してあるが」　平次は部屋の隅から、つくねるやうにしてあつた二本の紐を持つて來ました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "五月人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は新聞といふ紙の上をくねる女の指先を折々薄目を開けて見入つた。",
              "citation": {
                "source": "はるあはれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後兄はねることもよくねるし、飲むこともかなりよく飲んだが、それでいてだんだん大人しくなって、幸いなことには、とうとう七十五まで生きながらえた。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲がりくねる迷路の構造が絶望的なまでに複雑なのか、あるいはいつにない歩行の振動のために天井から岩の屑が落下し、帰り道を塞いでしまったのか。",
              "citation": {
                "source": "千里眼の村",
                "author": "クリスマス・ストーリー",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜の手紙でかたくお約束したとおり、最もおそくて十一時迄、早くてはもっと早くねることにします。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時にはかえれません）おそくなったのではなくて、確に自分でおそくしたのだから、そうとして次の晩でも早くねる。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんやも又早く早くねるの。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は早くねるのよ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の体は二十四日以来可成りの無理があったから、随分気をつけてマッサージもまた始め、昼間よくねるようにしておりますから御心配下さいますな、何といっても体の大きい五つの子供をだくのは骨よ、体中にしまりのない子なのだから重さは非常なもので、皆、可愛がりながらヘコたれます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでくねりくねる。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "くねる運動は常に前進のみを意味しないというところに悲劇があるのね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜早くねるのがたのしみです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲がりくねる細い道の両側に商店が建てこむ様子と雰囲気が、彼には楽しかった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
