        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しだいに暮れゆく海波の上既に分列の任務を終へて艦等みな歸港の情に渇けるなり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくの如きは、古くから日本の文学を裏付けてゐる無常観で、あまりに常套な、又あまりに感傷的な句ではあるが、しかも時の姿、流れの姿は、人の身の上ばかりでなく、川それ自身の栄華をすら、鼠色に暮れゆく川上の、遠山に沈む斜陽のうす黄色の中に、うすら寒い谷の影を、描き出されるやうになつた。",
              "citation": {
                "source": "天竜川",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが心は鉛のごとく重く、暮れゆく空の雲をながめ入りてしばしは夢心地せり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが心は鉛のごとく重く、暮れゆく空は墓のごとし。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月雨も夕暮れも暮れゆく春もこの二人にはとりわけて悲しからずとりわけてうれしからぬようなり、ただおのが唄う声の調べのまにまにおのが魂を漂わせつ、人の上も世の事も絶えて知らざるなり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "門を出ずれば角なる茶屋の娘軒先に立ちてさびしげに暮れゆく空をながめいしが、われを見て微かに礼なしぬ、貴嬢はこの娘を憶えいたもうや。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度は一人残っていると強情を張りましたので、母だけ先に帰りましたが、私は日の暮れかかりに縁先に立っていますと、叔母の家は山に拠って高く築きあげてありますから山里の暮れゆくのが見下されるのです。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま室内にひとりで坐つて暮れゆくたましひの日かげをみつめるそのためいきはさびしくしてとどまる蠅のやうに力がないしづかに暮れてゆく春の夕日の中を私のいのちは力なくさまよひあるき私のいのちは窓の硝子にとどまりてたよりなき子供等のすすりなく唱歌をきいた。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまし接吻……歓語……　　　七　うめき暮れゆく日、血に濁る床の上にひとりやすらふ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、薔薇、暮れゆく今日をそぞろなり、わかき喘に図らずも思ひぞいづる。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "声もなき国の白楊、列長う両側に顫へわななき、色青き蝋の火のほの暗みおびゆるごとく、広きより狭み暮れゆく其果の遠き切目に、仄かなる噴水の香ぞひとり密かに泣ける。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は暮れゆくなか、椅子に腰掛けていた。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮れゆくそらに心細くなりしわれは、はやかへらむといへど、聴かずして漕出で、岸辺に添ひてゆくほどに、人げ遠き葦間に来りしが、男は舟をそこに停めつ。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸じゅうの混雑を一つに集めたかと思われるような両国にも、暮れゆく秋の色と匂いとが漲っているように見えるのが、このごろの薄寒い朝の景色であった。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "花を踏みては、和らかき踵にしめる紅色の名殘の色をかへりみて、暮れゆく春を惜しむかな。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "古き甕は碎けたり、壞片を手に拾ひて、心憂ひにえ堪へず、暮れゆく日をも忘れぬ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "午すぎの明るい日は建物の大きい影を斜めに地に落として、その影のとどかない築山のすそには薄紅い幾株かの楓が低く繁って、暮れゆく秋を春日絵のようにいろどっていた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "水音のこゝろのふるさと波がしろくくだけてはけふも暮れゆく待てば海路のよか船があつた、紫丸に乗せてもらうて竹原へもどることが出来た。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮れゆく春への手向けの幣の袋かと見える。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　模糊として暮れゆく、海にむかって聳ゆる山の、中腹に眼をやりながら、モルガンは心に祈るようにすら言った。",
              "citation": {
                "source": "モルガンお雪",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは珊瑚の色したる灰なり、暮れゆく春の竈場なり。",
              "citation": {
                "source": "妄動",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒きかな、寒きかな、東京は霙となりて今日も暮れゆく。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ言葉にはもう何十年の昔しからこの山に住み馴れた經驗から雲の動靜や暮れゆく山の色、空の夕燒の模樣で天候を卜する知識を得てゐるらしい。",
              "citation": {
                "source": "箱根の山々",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "さよなら暮れゆくまどにて幸恵　　母上さま　　父知里高吉宛大正六年四月一日付（旭川発信）拝啓まへからしばらく御心配下さいました旭川区立職業学校受験の結果は、幸に四等にて合格いたしましたから何卒御安心下さいませ。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは上かなと思って、念のために上を向いてみたが、暮れゆく空には、高いところに断雲がゆっくり動いているだけで、やはり何も見当らなかった。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひろびろと暮れゆく田ンボ。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "清澄の茂太郎は、房総第一の高山の上に立って、煙波浩渺として暮れゆく海をながめて、茫然として立ちつくしていましたが、星を見るには、まだ時刻が少し早いのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "Ocean の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その用地の境内に立って、日比谷公園から宮城方面の暮れゆく夏の夜の黒い樹木の上には、折柄片破れ月が澄みきった星空に光っている。",
              "citation": {
                "source": "アーニイ・パイルの前に立ちて",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "白帆斜陽を帶びて、霞にくれゆく春の夕暮いとあはれなり。",
              "citation": {
                "source": "春の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆく春くれゆく春のかなしさは白髪頭の蒲公英のむく毛がついついとんでゆく風がふくたびとんでゆき若い身そらで禿頭。",
              "citation": {
                "source": "どんたく",
                "author": "絵入り小唄集",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
