[
  {
    "uuid": "1e4d08c0-36ef-5d6f-ad23-4d99e079be53",
    "entry": "悔い",
    "reading": {
      "primary": "くい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "regret",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ゆっくりかまえて、一日一日を、せめて悔いなく送りたまえ。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄は、今耕二にツツケンドンな口を利いて来たことが忽ち悔いられた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは尚悔いて恨みず百｜度もまた昨日の彈劾を新たにせむ。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新年來り、百度過失を新たにするも、我れは尚悲壯に耐へ、決して、決して、悔いざるべし。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな井伏さんを見て、井伏さんを甘いなと、なめたら、悔いる事があるかも知れない。",
              "citation": {
                "source": "小照",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹はむしゃくしゃすると同時に堪えぬなつかしさの痛み、悔いないでよいことへの悔い――そういったことでごちゃごちゃになっていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの娘は、あまり偉くなりすぎたよ」　口惜しさと悔いがぎざぎざと胸を噛んだ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは日々ここに居て罪を悔い王に謝する。",
              "citation": {
                "source": "龍と詩人",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に書いてしまったものを今更悔いても仕方がないが、一度慚愧の念に襲われては、何事にも無頓着なる予と雖も、さすがに躊躇するのである。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分もいまさらのごとくわが不注意であったことが悔いられる。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の自分はただただ自分を悔い、自分を痛め、自分を損じ苦しめるのが、いくらか自分を慰めるのである。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の不注意を悔いて、自分の力なきをなげいて泣くよりほかはない。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今更なんぼ悔いても仕方がないけど、私は政夫……民子にこう云ったんだ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "思えば民子はなが年の間にもついぞ私にさからったことはなかった、おとなしい児であっただけ、自分のした事が悔いられてならない、どうしても可哀相でたまらない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし後ではやはり助手のなかった事を悔いた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして君に逢つたことを密かに悔いた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は自分の馬鹿を悔いる。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "一途に悔いていればいい。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、二三｜日その疲れの拔け切らないのに今更自分の愚さを悔いたやうな始末だつたが、支那人が二｜日も三｜日も戰ひつづけて平氣だといふのは、一つは確に體力のせゐに違ひない。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は、これまで、あまりに真面目で、おとなしかった自分達のことを悔いていた。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗教類似の信仰に夢中になって家族を泣かせるおやじもあれば、あるいは干戈を動かして悔いない王者もあったようである。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」言つてから悔いた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はすでに六本の徳利をからにしたことを、ちくちく悔いはじめたのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何たる残刻無情の一語ぞ、自分は今もってこの一語を悔いている。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここまでお話ししたのでございますから、これから私の女難の二つ三つを懺悔いたしましょう。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時が来ても、私がこの農場を解放したのを悔いるようなことは断じてないつもりです。",
              "citation": {
                "source": "小作人への告別",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悔い改めよ、その人は天国に入るべければなり……へへ、悔い改めら、ら、られるような罪人なら、俺は初めから罪なんか犯すかい。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが世間が、不景気だ、ボヤボヤしてはゐられないと云へば云ふ程、インテリにとつてその世間たるや住みにくい世間となる。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、友達として一言忠告させて貰ふなら、その生活ぶりに、時として余りに野放図なものがあるので、謂はば必要以上に衰弱して居る日があつて、そんな日に出来た詩は、あの感覚と同居しにくい抽象概念を招きすぎて、読者を混乱させる場合がある。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の降る日（兄のうたへる）萩原朔太郎雨の降る日の縁端にわが弟はめんこ打つめんこの繪具うす青くいつもにじめる指のさき兄も哀しくなりにけり雨の降る日のつれづれに客間の隅でひそひそとわが妹のひとり言なにが悲しく羽根ぶとん力いつぱい抱きしめる兄も泣きたくなりにけり",
              "citation": {
                "source": "雨の降る日",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
