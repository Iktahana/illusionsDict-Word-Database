      {
        "index": 1,
        "gloss": "bringing ruin upon oneself by extravagance in food",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
