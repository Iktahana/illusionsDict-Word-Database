    },
    "definitions": [
      {
        "index": 1,
        "gloss": "quadrature",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "泥棒は邪魔になるので、「こんちくしょう、こんちくしょう」　と払い除けようとしましたが、なかなか払い除けられません。",
              "citation": {
                "source": "虻のおれい",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖マルティンのちくしょうめ」　とジャンはジャンで見えない目からくやし涙を流します。",
              "citation": {
                "source": "かたわ者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんちくしょう、早く言え」　と言うなり坊さんを押えつけて鉈をふり上げました。",
              "citation": {
                "source": "ツクツク法師",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（野中）（呻く）ううむ、ちえっ、ちくしょう！",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "がちょうの　たんじょうび新美南吉　ある　おひゃくしょうやの　うらにわに　あひるや、がちょうや、もるもっとや、うさぎや、いたちなどが　すんで　おりました。",
              "citation": {
                "source": "がちょうの　たんじょうび",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏切りやがって、ちくしょうめ！",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "風の如くアトリエを飛び出し、ちくしょうめ！",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそのとき、どろみぞからあがっていた石太郎は、ちくしょうと口ばしって、目にもとまらぬ敏捷さで、いたちを地べたへたたきつけた。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "春吉君は、いつも水藻のような石太郎が、こんなにはっきり、ちくしょうっという日本語を使ったこともふしぎだったし、こんなにすばしこい動作ができるということも不可解な気がした。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯉のこくしょうぐらいは誰でも知っているが、何分にもさかなが大き過ぎるので、殺して食うのは薄気味が悪かった。",
              "citation": {
                "source": "鯉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　すぐにアリ・ババは、きげんよくしょうちしました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大きなひろばでは、こどもたちのなかでも、あつかましいのが、そりを、おひゃくしょうたちの馬車の、うしろにいわえつけて、じょうずに馬車といっしょにすべっていました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここからすぐに追っかけるんだ」「ちくしょうッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちくしょうッ」「いてえ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどね、ちくしょうめ、さあ来い！",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちくしょうめ、やけにうれしくなりゃがったね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちくしょうッいけねえ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちくしょうめ、ふざけたまねをやりやがって、どいつか沈めやがったなッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちくしょうッ、ひと足先にずらかりましたぜ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちくしょうめ、なんだって気短におっ死にゃがったんでしょうね！",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちくしょうッ、ざまあみろい！",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、ちくしょう、ひとりで目鼻をつけてやろうと、けさ起きぬけにお番所へ出かけていったら――」「何がどうしたというんだよ」「人ごろしがあったっていうんですよ」「ウフフ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちくしょうめ、すっかり世の中が明るくなりゃがったじゃねえか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月万歳、雪やこんこん、ちくしょうめ、降りやがるなと思ったら、きょうにかぎってこのとおりのぽかぽか天気なんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょいと見ると、このお組屋敷の門前を変な女がちらくら走っていやがるからね、夜ふけじゃあるし、ちくしょうめ臭いなと思ったんで、まっしぐらに飛んできたら、このうちの中へすうと消えたんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちくしょうめ、さてはあの女へび、ひと皮ぬいで逃げやがったね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く呼んできな」「ちくしょうめ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
