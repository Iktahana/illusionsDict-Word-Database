          "literary": [
            {
              "text": "しかしそれは勿論口称だけのことで、未だ文字を以てこれを表わすことは無かった。",
              "citation": {
                "source": "国号の由来",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥棒は邪魔になるので、「こんちくしょう、こんちくしょう」　と払い除けようとしましたが、なかなか払い除けられません。",
              "citation": {
                "source": "虻のおれい",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
