    "definitions": [
      {
        "index": 1,
        "gloss": "chain mail (armor, armour)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし泳ぎの達人であった王は、盾の下で鎖帷子を脱ぎ捨てここを逃げのびてヴェンドランドの小船に助けられたといううわさも伝えられた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "王は黄金を飾った兜をきて、白地に金の十字をあらわした盾と投げ槍とを持ち、腰にはネーテと名づける剣を帯び、身には堅固な鎖帷子を着けていた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「道理こそ、鎖帷子の扮装だ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か蛇の鱗のやうに光る物があると思つたら、それは戦争の時に使ふ鎖帷子や鎧だつた。",
              "citation": {
                "source": "着物",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎖帷子と鎖入鉢巻の用意をして、七八町のあとから見えがくれに後を追って行く。",
              "citation": {
                "source": "鍵屋の辻",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつでも対手になってやるという覚悟で、勿論鎖帷子、白昼堂々と槍を立てて又五郎は行く。",
              "citation": {
                "source": "鍵屋の辻",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎖帷子、ほうら鎖頭巾、どうじゃ、こうちゃんとした扮をするといい男だろうがの、今に喧嘩でもしてみろ、三人や五人ならおくれはとらぬぞ。",
              "citation": {
                "source": "鍵屋の辻",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "又五郎同じく二十四歳、小者一人、喜蔵というに十文字の槍をもたせ後ろを押える人として叔父の川合甚左衛門、四十三という男盛り、若党与作に素槍を担がせ、同じく熊蔵を従えた主従十一人鎖帷子厳重に、馬子人足と共に二十人の一群、一文字の道を上野の城下へ乗入れてくる。",
              "citation": {
                "source": "鍵屋の辻",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "文「明けろ」　前のように鎖帷子を取って風呂敷に包んで寝ました。",
              "citation": {
                "source": "業平文治漂流奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎖帷子に身を固めて、大ダンビラを肩でしごくと、後ろから眞つ赤な朝日が出る、――皆んな極つた型のあるものだ」　平次はすつかり茶かし氣味です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お局お六",
                "note": "青空文庫"
              }
            },
            {
              "text": "振袖の下へ鎖帷子を着せて置いたので、力任せで刺した匕首も、五分とは斬らなかつたよ」「――」　錦太郎は何べんかお福に飛びかゝりさうにしましたが、その都度、平次の眼に威壓されて、キリキリと齒を喰ひしばるばかりです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "ガラツ八祝言",
                "note": "青空文庫"
              }
            },
            {
              "text": "振袖の下へ鎖帷子を着せておいたので、力任せで刺した匕首も、五分とは斬らなかったよ」「…………」　錦太郎は何べんかお福に飛びかかりそうにしましたが、その都度、平次の眼に威圧されて、キリキリと歯を喰いしばるばかりです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "ガラッ八祝言",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎖帷子に身を固めて、大ダンビラを肩でしごくと、後ろから真っ赤な朝日が出る、――みんな極った型のあるものだ」　平次はすっかり茶化し気味です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お局お六",
                "note": "青空文庫"
              }
            },
            {
              "text": "回廊の終わりには、常ならぬ光輝の姿、人ならぬ背丈の女性の姿が、頭からつま先まで煌びやかな鎖帷子を纏っていた。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は目を上げ、鎖帷子を着た姿の背後に血のように真っ赤な朝日が昇ろうとしているのを見た。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時亂軍の勇士たるヂオメーデース祈り曰ふ、113　鎖帷子の類か。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "……除村久良馬は黒の紋服に仙台平の袴をはき、下は白で、鎖帷子を着けているのが見えた。",
              "citation": {
                "source": "初夜",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海豚の如く水中に跳躍して居る何十匹の動物を見ると、其等は皆体の下半部へ鎖帷子のような銀製の肉襦袢を着けて、人魚の姿を真似た美女の一群でありました。",
              "citation": {
                "source": "金色の死",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸之進は綸子の着物に大口｜袴、武者鉢巻をしてたすきをかけ、下に鎖帷子を着たものものしい姿であったが、三之丞は木綿の着物に葛布の短袴、わら草履という無雑作な恰好だから、おそろしく対照が奇妙であった。",
              "citation": {
                "source": "備前名弓伝",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は貴婦人達が騎乗槍試合に彼女達の名誉をかけて戦いに行く騎士達に、甲冑、剣、兜、鎖帷子、馬を与えたんじゃなかったかしら？",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "獰猛そうな毛虫眉も、厚く上にめくれている唇も、大きな野太刀も鎖帷子も、着ている獣の皮も。",
              "citation": {
                "source": "宮本武蔵",
                "author": "地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪華では住吉神社、京では清水寺、男山八幡宮、江戸では浅草の観世音、そのほか旅の先々で受けた所の神々や諸仏天は、今こそ、自分の肌身を固め給うものと信じて、ばばは、鎖帷子を着たよりも、心丈夫だった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "とびおりた五尺の体もまた、信念の鎖帷子をきこんでいるのだった。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "追々と集まってくる剣客はおのおの鎖帷子の着込みに、筋金入りの白鉢巻をなし、門下を併せて二、三百人余り、意気天を衝いて犇々と詰めかけた。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "肌着は浅黄羽二重の綿入、鎖帷子を着こみ、茶裏の黒小袖の袂を短く縫いこみ、両臂には一重差の甲無し籠手を貫き、大真田の襷をかけ、鎖股引に陣草鞋。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "当日、懐中にお持ちあって」　と、贈ってくれる者もあるし、わざわざ鎖帷子を届けてくれる者だの、また、台所へは、大きな鯛や酒菰が何処からか運ばれて来るし、巌流は身の置所もなかった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから戸棚からくさりかたびらを出して、頭から顔から足のさきまでちゃんと着込んでしまいました。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云いながら、四方八方から、飛びかかりましたが、何分とのさまがえるは三十がえる力あるのですし、くさりかたびらは着ていますし、それにあまがえるはみんな舶来ウェスキーでひょろひょろしてますから、片っぱしからストンストンと投げつけられました。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのイラクサをおまえさんの足で踏みちぎって、それを麻のかわりにして、それでおまえさんは長いそでのついたくさりかたびらを十一枚編まなければならない。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうくさりかたびらは一枚でき上がりました。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
