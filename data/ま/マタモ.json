        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いつか島が又もとの岸とくっついてゐた。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とはなしに陸さんの門前の方へ廻り何とか云う人の門につきあたり左の方を注視したけれども先生の庭の方へ出でる道はない　仕方はないから又もとへ戻って先生の前へ来た。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく／＼と語れば、「そは承けがたき事」と打かたぶき打かたぶきするほどに、又も一声二声うちしきれば、「あれが声を郭公とや。",
              "citation": {
                "source": "すゞろごと",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "地主の小作料の引上げや、立入禁止、又も差押えがある。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごろりと轉げて大の字なり、坐團布を引寄せて二つに折て枕にして又も手當次第の書を讀み初める。",
              "citation": {
                "source": "都の友へ、Ｂ生より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんから蒼白い彼の顔が更に蒼ざめているのを見て、女房の胸には又もや動悸が高くなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼娘が又もや一人の女を屠ったのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "白地の浴衣を着た女、酒屋の下女を啖い殺した女、小間物屋の女房を啖い殺した女、それが又もやここにあらわれて、赤裸の若い女を啖い殺したのであろうとは、誰の胸にもすぐに浮がび出る想像であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "母のお豊はむしろ我が子をすすめて出してやるほどであったが、久次郎の参詣が初めの一七日が過ぎて更に二七日となり、又もや三七日となり、四七日とつづくようになったので、店の番頭どもは少し不安を感じて来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしてもたゞ今は又もやとんだ無礼をはたらきました。",
              "citation": {
                "source": "電車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一晩睡らないで、頭のしんしん痛む豚に、又もや厭な会話を聞かせたのだ。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そう言い捨てて又二階へ上り、其の「ロマネスク」という小説を書き続けて居ると、又も、佐吉さんの一際高い声が聞えて、「酒が強いと言ったら、何と言ったって、二階の客人にかなう者はあるまい。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "剃ってあげましょう、と親切に言って下さるので、私は又も断り切れず、ええ、お願いします、と頼んでしまうのでした。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "樺の木は折角なだめようと思って云ったことが又もや却ってこんなことになったのでもうどうしたらいゝかわからなくなりたゞちらちらとその葉を風にゆすってゐました。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "樺の木は折角なだめようと思って云ったことが又もや却ってこんなことになったのでもうどうしたらいいかわからなくなりただちらちらとその葉を風にゆすっていました。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、この家政婦の行方不明をキッカケにして、忘れかけていた煙突問題が、又もや、生き生きと私の頭に蘇って来たから不思議であった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "無言のままシッカリと私の手を握ったので又も緊張させられた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホホホ」　彼女は又もフーッと青臭い息を私にマトモに吹きかけた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝、早よう……孫の墓へ参りました帰り途に、裏通りを近道して、祇園町へ帰ろうと致しましたれば……あ……あの桃の花の上がっておりまする、蔵元屋の……お墓の前で……」　すこし落着きかけた婆さんの歯抜け※が又もガタガタ言い出した。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝早よう……ふうむ……」　本堂に近い柴垣の処で立止まった良助は、又もや腕を組んで、今出て来た墓所の奥の暗がりを振返った。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頬冠りの蔭の物凄い眼付を見ると和尚が又もやガタガタ震え出した。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "思い込んだ涼しい瞳で赤猪口兵衛の恐縮顔を見上げると、又も破れ畳にピッタリと額をスリ付けた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "御尤も御尤も」　頭を下げたままの半三郎の眼から又も涙がハラハラと落ちた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなに遠くへ歩いたおぼえはないが……と不思議に思い思いモトの階段を降りて、反対側の階段を昇ると、又も素晴らしく巨大な、知らない時計店の前に出た。",
              "citation": {
                "source": "恐ろしい東京",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「も一ツ」と今度は徳二郎が注でやつたのを女は又もや一呼吸に飮み干して月に向て酒氣を吻と吐いた。",
              "citation": {
                "source": "少年の悲哀",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "代を聞くと果して二十錢だといふ、喜んで買ひ取り、石は又もや雲飛の手に還つた。",
              "citation": {
                "source": "石清虚",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "又も文句に塞ったが、気を引きたてて父の写真を母の前に置きながら「父上さんをお伴れ申してのお願いで御座います。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "であるから賊になった上で又もや悶き初めるのは当然である。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、俺のこの宿酔の頭では、一杯ひつかけてから行かなければ、とても相談にはのられやしないぞ」といふやうなわけで私はまたも其処に入り、どうせこんな所の日本酒はまづいからと思つたのでビールを註文。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の感傷性がまたもや唸り出した。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
