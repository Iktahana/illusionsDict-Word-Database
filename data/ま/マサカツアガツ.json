    "definitions": [
      {
        "index": 1,
        "gloss": "true victory is victory over oneself",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
