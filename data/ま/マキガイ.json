          "standard": [
            {
              "text": "海岸で美しい巻き貝をたくさん拾った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "巻き貝の殻には、自然が作り出した不思議な模様がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この巻き貝は食用になり、酒蒸しにすると美味しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それは、煙管貝のような格好で全体灰色をした一種の巻き貝であって、長さはせいぜい五六｜分ぐらいであったかと思う。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "島原から山本さんがトッポという大きな巻き貝をおみやげに持って来られた。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋の中はまきがいっぱいはいっていた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            }
          ]
        }
