        "examples": {
          "standard": [
            {
              "text": "今日はまさにマーフィーの法則が発動した一日だった。何もかも裏目に出たよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「傘を持ってこなかった日に限って雨が降る」というのは、マーフィーの法則の典型的な例だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はいつも最悪の事態を想定するタイプで、マーフィーの法則を信じている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "じつに勝手な言いぐさではあるが、『マーフィーの法則』ででもがんがん儲けて、今後も算盤勘定には合わなくても残すべき価値のあるこうした貴重な本を形にまとめ上げていっていただきたい。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
