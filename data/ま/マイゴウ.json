    "definitions": [
      {
        "index": 1,
        "gloss": "every issue or number",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『松』を毎号贈って下さる浜松の同人諸君に感謝する。",
              "citation": {
                "source": "三八九雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "論文欄は毎号紙数の大多部を占むると共に、又常に比較的他欄より幼稚なる傾向有之候が、本号も亦其例外に立ち難く見受けられ候。",
              "citation": {
                "source": "渋民村より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "面識はなかったが、かつてこのおっさんが編集長をやっていた『パソコンワールド』という雑誌を、オレは毎号買っていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯ういふ女の雑誌が出ましたと毎号郵便で送る。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん聞いてみると、与次郎は従来からこの雑誌に関係があって、ひまさえあればほとんど毎号筆を執っているが、その代り雅名も毎号変えるから、二、三の同人のほか、だれも知らないんだと言う。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "『近代文学』創刊号以来、毎号執筆している埴谷雄高の『死霊』には、この作者のその身魂を投じて悔いない心意気につくづく頭がさがります。",
              "citation": {
                "source": "ある手紙",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "『文藝春秋』は毎号実話物を掲載しているし、『新潮』にも事実小説と銘うった作品が掲載されたことがある。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "どなたが送って下さいましたか『ホトトギス』を毎号頂いて居りました。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "図書館は毎号面白い。",
              "citation": {
                "source": "マイクロフォン",
                "author": "「新青年」一九三三年七月",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、読んでますとも、毎号欠かさずに。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、自分はそのことについて、この頃『ナップ』へ毎号つづけて書いている。",
              "citation": {
                "source": "「鎌と鎚」工場の文学研究会",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルジョア雑誌は毎号かかさないように新しい時代の幸福とか恋愛とか結婚の問題をとりあげて沢山のページをさいています。",
              "citation": {
                "source": "生きるための恋愛",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎号そこにいろいろな作家が短い自由な感想をのせているのであるが、九月号のその雑誌に「新胎」を書かれた舟橋聖一氏も、本月はこの欄に一文をよせておられる。",
              "citation": {
                "source": "夜叉のなげき",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "紐育の週刊の探偵小説雑誌には毎号この種の興味ある考え問題、たとえば暗号などを掲げて読者を考えさせ、その解答が次号に出るようになっていた。",
              "citation": {
                "source": "科学的研究と探偵小説",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロレタリア啓蒙婦人雑誌『働く婦人』に毎号加えられる支配階級の不法な弾圧は、日本プロレタリア文化連盟、即ち全日本のプロレタリア文化運動の上に加えられる敵の弾圧として、徹底的に強力に抗議されなければならない性質のものである。",
              "citation": {
                "source": "婦人雑誌の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ『働く婦人』の事務のために働いていただくことはこういう次第で出来ませんが、お話の様子ではあなたは『働く婦人』を毎号お読みのようですから、先ず、直接購読者となり、追々『働く婦人』を中心としたサークルをこしらえて行ったら実にいいと思います。",
              "citation": {
                "source": "「我らの誌上相談」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その理由は、われわれにとって面白くためになる『働く婦人』が毎号発禁になると全く同じです。",
              "citation": {
                "source": "日本プロレタリア文化連盟『働く婦人』を守れ！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中でいけないのがあるとか「時評」にわるいところがあるとか、つまり毎号意地悪く発禁攻めにしても大衆の伸びる力はおそろしい。",
              "citation": {
                "source": "ますます確りやりましょう",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてほとんど毎号、その頃になってようやく知れて来たロシアの共産党政府の無政府主義者やサンジカリストに対する暴虐な迫害や、その反無産階級的反革命的政治の紹介に、僕の全力を注いだ。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、秋水にもこんどは是非毎号筆を執って貰いたい。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか、毎号いくつかの短篇小説がのせられた。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は毎号々々かうして貧弱だとかつまらないとか云ふ非難を耳にしながらも何時もねうちのない雑誌ばかり編輯して居ります。",
              "citation": {
                "source": "読者諸氏に",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "□毎号不着のハガキがきつと一二枚づゝは来ますがなるべくならば十日以前におしらせが願ひたいのです。",
              "citation": {
                "source": "編輯室より（一九一五年五月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の子なほかの山に住むといふ見れば朝夕煙たつかな　明治の末年故上田敏先生が大陸の象徴詩を移植しようとして訳詩の業を起され、当時の明星が毎号之を発表してそのめざましい新声を伝へたことがある。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "大衆的啓蒙雑誌「大衆の友」「働く婦人」などは毎号発禁つづきであった。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "而し私の一方ならぬ多忙と浅学、専門的に系統だった研究考察は到底覚束ないが、ただ古今の句を比較して毎号素人らしい研究をつづけて見たく思っている。",
              "citation": {
                "source": "桜花を詠める句",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　誌の毎号の発行に当り、余は記憶に捜って話しつつ筆記してもらい、それをいささか修正したるものに過ぎぬから、遺漏も多く記憶違いも少なかるまい。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "この老人連は私の関係している日本及日本人の毎号へ出吟してくれらるる仲間なのだ。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
