        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ドラマのクライマックスで、強引な主人公がヒロインに股ドンをするシーンに胸がキュンとした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "冗談で友人に股ドンをしてみたら、予想外に真顔で迫られてしまい、逆にこっちが動揺した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "股ドンは、壁ドンよりもさらに相手を逃がさないという威圧感と親密さを強調する動作だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "またドンドン靴でける。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その諸国での名を少し挙げると、英語でアッスまたドンキイ、ラテンでアシヌス、露語でオショール、独語でエセル、ヘブリウでチャモール（牡）アトン（牝）、アラブでカマール、トルコでヒマール、梵語でラーサブハ等だ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "わーッ」またドン助だ。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らが来る、またドンドン先へ行く。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼もまたドン・アントニオをなんとかしてこの世から葬りたいものだと、このうえもなく神経質になっていた。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
