    },
    "definitions": [
      {
        "index": 1,
        "gloss": "woman",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まんさんとして漂へば、　　　水いろあはき日曜の、馬を相する漢子らは、　　　　こなたにまみを凝すなり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そろそろ、まんさんたる自分の生涯の中に一筋｜貫くものがあるのに気がつき出した。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『ヤア、まんさんか。",
              "citation": {
                "source": "歸國",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔歩まんさんとして出かける、岐陽君を訪ねる、酒、さらに呂竹さんを訪ねる、そしてＦをＳを訪ねて酒。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔歩まんさんとして戻つたのは三時頃か、アルコールのおかげで前後不覚。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――酔樹明さうらうとして（まんさんとしてではない）来る、何といふ悩ましい姿だらう、どんなに悩んでゐるかは解りすぎるほど解る、すぐ寝た、対座するにはどちらも堪へきれないのである、お茶漬をたべて、すこし元気が出て、帰つていつた、樹明よ、くよ／＼するなよ、君らしくもないぞ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉桜の水たまりでは蛙がしんみり鳴き、料理屋では名残の花見客がドンチヤン騒いでゐた、私たちも酔ふた、酔歩まんさんとして、自動車に揺られて戻つた、戻るなり前後不覚でぐつすりと睡つたのである、ありがたし／＼。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "心易くなったので、私は近所の子供なみに、「おまんさんのお尻ぴいーんこ、ぴいーんこ」　と言ってからかった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔つぱらつた三人は必然的に街へ出かけた、そしてまた飲んでさらに酔ふた、私と敬坊とは腕を組んで、さうらうまんさんとして駅前の宿屋に泊つた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度来て居るこまんさんは私が帰る三日前に来たのですわ。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "『栄一様、昨日こまんさんが来ましてな。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄一様、此頃は毎晩毎晩、あの可愛いこまんさんと、打ちくつろいで話が出来るだらうな。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "此頃はこまんさんも綺麗になつたな』　云はせて置けば勝手に復讐をやつて居る。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "町でね、笑さん、こまんさんが今度看護婦になつたゞらうな、あの女中が。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔歩まんさんと、何か歌って行く。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こんなところへ、ちょうど穆弘が通りかけて、ここにいたかと、李逵を塾から引っ張り出して、酔歩まんさんたる彼の腕を小脇にかかえ、遮二無二、山寨へ連れて帰った。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その足もとは、まんさんとして、彼の意のままには運ばれて行かない。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
