      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "staggering",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "円タクで白山坂上にさしかかると、六十恰好の巌丈な仕事師上がりらしい爺さんが、浴衣がけで車の前を蹣跚として歩いて行く。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たといきさまが、観音様の化身でも、寝ちゃならない、こら、行けというに」　　　　　　　三「伯父さんおあぶのうございますよ」　半蔵門の方より来たりて、いまや堀端に曲がらんとするとき、一個の年紀少き美人はその同伴なる老人の蹣跚たる酔歩に向かいて注意せり。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京には、こういう娘がひとりで蹣跚の気持ちを牽いつつ慰み歩く場所はそう多くなかった。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京には、かういふ娘がひとりで蹣跚の気持ちを牽ひつつ慰み歩く場所はさう多くなかつた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民学校教師、野中弥一、酔歩蹣跚の姿で、下手より、庭へ登場。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうわけで、僕は仏蘭西へ――わけても、この「よひどれ」の詩人が、そこの酒場でアプサンを呷り、そこのマロニエの並木の下を蹣跚とよろめいて行った、あのパリへ行きたいと思ったのです。",
              "citation": {
                "source": "十年",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体私は、此叔父の蹣跚した千鳥足と、少しでも慌てた態を見た事がなかつた。",
              "citation": {
                "source": "刑余の叔父",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "老いたる教師ハツバス・ダアダアのボルゲエゼ家の車の章に心づきて、蹣跚たる歩を住め我等を禮したるは、おもはずなる心地せらる。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは蹣跚として階を下り、舟を喚びて水の衢を逍遙せり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは又蹣跚として階を上り、おぼつかなき孤客の夢を結びぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おつう、よきこと起せ」勘次はさういつて自分も一つに蹣跚けながら立つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖に面したる三階の上の、厭かぬ眺めはあれど、第二公園の梅に心ひかれて、醉歩蹣跚として去る。",
              "citation": {
                "source": "水戸觀梅",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "」斯う言つて彼は欄干を離れると、自分ながら可笑しい程足がフラフラした、ちよつと踏み止まつて今度は故意に蹣跚とした。",
              "citation": {
                "source": "公園へ行く道",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "純造よりも五寸がた丈の高い西岡はそのガツシリした偉躯を蹣跚とさせながら洞ろな声を張り挙げて切りに拙い歌をうたつた。",
              "citation": {
                "source": "坂道の孤独参昧",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "………………　私は蹣跚としながら、それでも足音を忍ばせなければならないと云ふ意識はあつて、静かに階段を降りてゐた。",
              "citation": {
                "source": "痴想",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう云ふことを振返って考へ込むと、彼は心の底から一つの細力が湧いて来て、蹣跚きさうな身体を支へて呉れさうな気がした。",
              "citation": {
                "source": "閑人",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちらの樽、こちらの樽の蔭からむくむくと起き上る人達を見ると執れも私の戦友共が、蹣跚たる夢に飽きて、もう一度私達夫妻の合奏に伴れて花々しくカロルを踊つて、今宵の慕を閉ぢよう――と云ふのであつた。",
              "citation": {
                "source": "酒盗人",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロレ　　灰色目の旦が顰縮面の夜に對うて笑めば、光明の縞が東方の雲を彩り、剥げかゝる暗は、日の神の火の輪の前に、さながら醉人のやうに蹣跚く。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "大道も狭いと云わんばかりに蹣跚いてゆく酔漢の背後に、半纏着の男はつつと迫っていった。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　覆面のない十数名の団員はてんでに喚きながら、怪しき黒影の上に殺到していったが、あらあら不思議、どうした訳か分らないが、彼等は拳を勢いよくふりあげたのはよいが云いあわせたように、よろよろと蹣跚き、まるで骨を抜きとられたかのように、ドッと床の上に崩折れてしまった。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、大酔した嘉平次が、蹣跚として自分のお長屋へ帰ろうとして、台所口を出たときだった。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "社長は蹣跚と行つて椅子に倒れ懸りながら、「何をするツ」と云ふ。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "町帰りの酔漢が、何やら呟き乍ら蹣跚とした歩調で行き過ぎた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "町歸りの醉漢が、何やら呟き乍ら蹣跚とした歩調で行き過ぎた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟻はすつかり喰べ酔つたが、それでも人間のやうに片手を他の鼻先で拡げて金を貸せとも言はないで、唯もう蹣跚と、其辺を這ひ廻つてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹣跚と立ち上つて、「何か一つ遣つ付けませうかな。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は柄杓で水を浴せ掛ると、鶩は恰も噂好なお婆さん振て、泥の中を蹣跚しながら鳴いて逃げて行きました。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は東京でごわす」　と恍け顔に言｜淀んで、見れば手に提げた菎蒻を庭の隅へ置きながら蹣跚と其処へ倒れそうになりました。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "まんさんとして漂へば、　　　水いろあはき日曜の、馬を相する漢子らは、　　　　こなたにまみを凝すなり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そろそろ、まんさんたる自分の生涯の中に一筋｜貫くものがあるのに気がつき出した。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
