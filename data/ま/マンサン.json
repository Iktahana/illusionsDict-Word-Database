[
  {
    "uuid": "8ecef58a-9f50-554f-8dd1-2db2137a91d3",
    "entry": "蹣跚",
    "reading": {
      "primary": "まんさん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-たる",
        "副詞-と"
      ],
