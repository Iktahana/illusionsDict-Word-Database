    "definitions": [
      {
        "index": 1,
        "gloss": "(one's) beloved daughter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
