        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一度工場外ニ足ヲフミ出シテ見レバ分ル通リ、当工場ハマサニ「Ｙノフォード」タル名ニ恥シクナイ充分ノ待遇ヲ、ソノ時間ノ点カラ云ッテモ、ソノ賃銀ノ上カラ云ッテモ、皆サンニ与エテ居ルノデアリマスカラ、コノ際決シテ、カヽル宣伝ニ附和雷同セザル様、呉々モ申述ベテ置ク次第デアリマス。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋ニハ電気ガツイテ居マスカラハッキリワカリマス。",
              "citation": {
                "source": "夢の殺人",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "オカネハ、イツモノヨウニ、ハンヲ、オシテ、アリマスカラ、コノママキョクヘ、トリニユキナサイ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "オカネハ、イツモノヤウニ、ハンヲ、オシテ、アリマスカラ、コノマヽキヨクエ、トリニユキナサイ。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "スグトツテキテオアゲシマスカラ。",
              "citation": {
                "source": "カヘルサント、コホロギサン",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年ノウチニワタシハ、コタンヘカヘリマスガ、マタ、コンド、アガリマスカラ、ドウカ、ヨロシクネガヒマス。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、案内役の――だから通弁でもある張青年に質問すると、張青年は、中華民国流不得要領の笑い方をしながら「コノ、ニッポンコクノ紳士ハ、アタクシ、アマリ好キデワアリマセン、ナゼトイウニ、眼ガスルドスギマスカラ――と、このように蘭亭さん申して居ります。",
              "citation": {
                "source": "赤げっと　支那あちこち",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ソレヨリ、此附近ニ巨キナ海坊主ガ出マスカラ注意シテ下サイ。",
              "citation": {
                "source": "流血船西へ行く",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私ノ家ニハ犬ヤネコガヰマスカラ、ウサギハベツニシテ、ゲンカンニオイテアリマス。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "野村曰ク、デモハ夜遅クマデ続キ、霞ヶ関カラ銀座ヘ出テ十時ニ解散スル、今カラ浜作ヘイラッシャレバ、八時迄ニハ帰レマスカラ大丈夫デス、但シ少シ遠廻リシテ市ヶ谷見附カラ九段ヲ経、八重洲口ヘ出テ行ケバ、デモニ打ツカル恐レハナイト思イマス、ト云ウ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供達ガ来ルトウルサクナリマスカラ、早イ方ガヨゴザンスヨ」ト、婆サンガ云ウ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "予ヲ寝室ニ送リ込ンデシマウト、「今スグ来マスカラ、チョット待ッテヽネ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アタシモシャワーヲ浴ビマスカラ」ト、自分ダケ浴室ヘ引ッ返シタ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後怱々鈴木氏ヨリ電話、「颱風ガ来ルト困リマスカラ本日ノ鍼ハ休マセテ戴キマス」トノコト。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪ヲパーマネントニシ、耳ニイヤリングヲ下ゲ、唇ヲコーラル・ピンクダノパール・ピンクダノコーヒー・ブラウンダノニ塗リ、眉ニ黛、瞼ニアイ・シャドウヲ着ケ、フォールス・アイラッシュデ附ケ睫ヲ着ケ、ソレデモ足リナイデマスカラーデ睫ヲ長ク見セヨウトスル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬ハイロ／＼ゴザイマスカラ、ドルシンモオイヤ、ノブロンモオイヤデシタラ、取リ敢エズパロチンノ注射デモシテ見マショウ、一時ノ苦痛ハ凌ゲルト存ジマス」注射ノ結果ヤヽ軽快ニ赴ク。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ドウナサイマスカ、博士モ決シテ無理ニスヽメテハオラレマセン、オ気ガ向カナケレバオ止メニナッタ方ガヨロシイト云ッテオラレマスカラ、マアヨクオ考エニナリマシテ、―――」コノ間ノ晩、子供ニ不意討チヲ喰ッテ泣カサレタコトガ未ダニ胸ニ残ッテイ、コンナ場合ニ何トナクアレガ不吉ノ前兆ノヨウニ思イ出サレル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「隣ニ佐々木サンガ寝テヽクレヽバ何カアッタッテ安心ジャナイカ、ネエ、颯チャンハコッチデ寝テオクレヨ」「煙草ガ吸エナイノガ困ルワ」「吸ッタライヽサ、イクラデモ吸ッテオクレ」「ソンナコトヲシタラ佐々木サンニ叱ラレチャウワ」「オ咳ガヒドクッテイラッシャイマスカラネ」ト、佐々木ガアトヲ引キ受ケル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜ハオ寒ウゴザイマスカラ明日ニナサイマシタラ」佐々木ガ驚イテ制シヨウトスル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ソンナモノハ戴キマセンヨ、コレデ宜シケレバマダゴザイマスカラ、イクラデモ仰ッシャッテ下サイ」佐々木ハ何ニ使ウノカ全ク見当ガツカナイラシク、呆気ニ取ラレテイル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "真っ赤なマスカラを塗ったモニカ・フリントとブラウン・フォックスを纏ったポーラ・ハートが旗をつかみ、濡れたセメントに触れないように気をつけながら折り畳んだ。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
