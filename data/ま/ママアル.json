    "definitions": [
      {
        "index": 1,
        "gloss": "to be not uncommon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
