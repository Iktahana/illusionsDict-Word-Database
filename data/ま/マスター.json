    "definitions": [
      {
        "index": 1,
        "gloss": "to master (a skill)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "英語をマスターするには、毎日継続して学習することが重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は数年かけて、ついに高度なプログラミングスキルをマスターした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この武道の奥義をマスターするため、師匠の元で修行を積んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "コーターマスターは、メーツに、「どうもおかしい」旨を告げた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "――尤も、コーターマスター達は、神経衰弱になるほど骨を折った。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつ等あ」　ブリッジを歩きまわっていた、一運（一等運転手）は、コーターマスターに云った。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「揃って帰っちまやがったじゃないか」　コーターマスターは、コムパスを力委せに蹴飛ばしながら、「サア」と、気のない返事をした。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おかしいじゃないか、おい」　一運は、チャートルーム（海図室）にいる、相番のコーターマスターを呼んだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オーイ」　相番のコーターマスターが、タラップから顔を覗かすと、直ぐに一運は怒鳴った。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーターマスターは、「おもて」へ入った。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーターマスターは、ボースンの耳へ口をつけた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ところで、話ちがいますけど、貴方キネマスターで誰がお好きですか？",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国語を、これから充分にマスターしなければならぬ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうぐあいに、すべての点で藤井先生はいなかの気ふうにならされ、のみならず、いなかふうをマスターするようにさえなったのだが、石太郎の、授業中にときどき音もなくはなつ屁にだけは、あくまで妥協できなかったのである。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "予の卓子の周圍には二人の人――マスター・オヴ・アーツの學位を有する外電係と新しく社會部に入つた若い、肥つた法學士――とが集つてゐた。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "マスターこと「おっさん」の柳吉もボックスに引き出されて一緒に遊んだり、ひどく家庭的な雰囲気の店になった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "女給たちには面白い見もので、マスターが悪いと表面では女同志のひいきもあったが、しかし、肚の中ではどう思っているか分らなかった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "建物全体をイルミネーションで包み、飾窓には、これから顔を見せにくるはずのシネマスターの大きな写真が何枚も貼り出されてあった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来はＭＳ―ＤＯＳ用のこのマシンに１メガバイトちょいのＢＴＲＯＮのＯＳ（商品名はＥＴマスター）を載せ、別売のエディターをプラスすれば日本語ワープロとお絵書きにはすぐに使える。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブリッジにいたコーターマスターの小倉が、何かわからぬことを、からだじゅうで怒鳴りながら、物すごい勢いでブリッジから飛びおりて来て、サロンデッキを艫の方へかけて行って、そのタラップをまた飛びおりた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時、ブリッジからコーターマスターが降りて来た。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オーイ、行くぞーっ」と、当番のコーターマスターがブリッジから怒鳴った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "当番のコーターマスターは、梯子をのぼり切ると、すぐに、小倉を取っつかまえた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "水夫では、波田、コーターマスターでは小倉が、今夜の当番であった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーターマスター四人をも起たせて見よう。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは、もし、コーターマスター全部が承知したら、コーターマスターの室でやろうじゃないか」と小倉が言った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーターマスターがはいらなかったら「おもてでいいさ」ということになった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまではもちろん、絶対に秘密、しかし内容を秘してコーターマスターを説くことは小倉、君に一任しよう。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、コーターマスターが駆け込んで「ウォーニン」をとれと伝えた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らが、皆まだ上がり切らないうちに、コーターマスターが飛んで来た。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、ブリッジから、非番になったコーターマスターがおりて来て、ボースンの伝馬が、巻き浪に巻き込まれて顛覆したが、人命だけは人足に救われたことを知らせた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
