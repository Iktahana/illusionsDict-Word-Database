  {
    "uuid": "4d690ddb-bea5-5580-a2d4-ada96fa9f224",
    "entry": "マレ",
    "reading": {
      "primary": "マレ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Malé (Maldives)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "マレイの glak も同様である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "名古屋へんの言葉で怒ることをグザルというそうであるが、マレイでは gusari となっている。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マレイ語で頭髪を剃るのは chukor であり女の髪を剃るのが tokong である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マレイの理髪師は tukang chukor また tukang gunting である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他「瘤」の仲間にはマレイの gmbal, ロシアの gorb, ズールーの kuhan, ハンガリアの 〔gomb, csomo'〕 等である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の頭部「かうべ」「くび」に連関して「かぶと」「かむり（冠）」「かぶり」「かぶ（株）」「かぶ（頭）」「くぶ（くぶつち）」「こぶ（瘤）」「かぶら（蕪菁）またかぶ」「かぶら（鏑）」「こむら（腓）」「こむら（, マレイの kpala は「かむり」「かぶり」の類である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギリシアやマレイとほとんど同一である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう立場からすれば例えば土佐の地名を現在あるいは過去の日本語で説明しようとするよりは、むしろこれらの地名とアイヌ、朝鮮、支那、前インド、マレイ、ポリネシア等の現在語との関係を捜す方が有意義である。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またマレイで「コタ」は町。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またマレイ「ニアタ」は用材樹木。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはまたマレイの「コータ」堡塁とのある関係を思わせる。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでターバンを巻いた印度人、皮膚の色褪せたペルシヤ人、半黒焼のマレー人、亡国的なポルトガル人などの群に交って北京を出発してから半ヶ月後、支那の現代のシステムに出現した支那女との恋を棄てて北京以来の友である陳子文と米良は病み疲れていた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならずこのシュテンドウシがアラビアから来たマレイ語で「恐ろしき悪魔」という意味の言葉に似ており、もう一つ脱線すると源頼光の音読がヘラクレースとどこか似通ってたり、もちろん暗合として一笑に付すればそれまでであるが、さればと言って暗合であるという科学的証明もむつかしいような事例はいくらでもある。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば南洋エファテの Aso（燃える）Asua（煙る）サモアの Asu（煙）や、マレーの Asap（煙）（マレイでは火山は Gunong berasap すなわち煙山とも Gunong berapi 火山ともいう。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マレイ語から語頭のＬを除くと日本語に似るものの多い事はすでに先覚者も注意した事である。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マレー半島に奇襲上陸、香港攻撃、宣戦の大詔、園子を抱きながら、涙が出て困った。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレハ　タイヘン　ウツクシク　ミエタノデ　花タチハ　コノヤウナ　セカイニ　ウマレテ　キタ　コトヲ　ヨロコビアヒマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オヤ、ヲバサン、アカンボガ　ウマレルノデスカ」「モウ　ウマレテ　ヲリマス。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "タケノコタチハ　トホクヘ　イキタガツテ　シヨウガ　ナイノデ、オカアサンノ　タケガ、「ソンナニ　トホクヘ　イツチヤ　イケナイヨ、ヤブノ　ソトニ　デルト　ウマノ　アシニ　フマレルカラ」ト　シカツテ　ヲリマシタ。",
              "citation": {
                "source": "タケノコ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「トテ　トテ　トテ　ト　ミナ　ミナ　アツマレ　ケンヲ　モテ、　トテ　トテ　トテ　ト　テツパウ　カツゲ　ハタヲ　モテ、　トテ　トテ　トテ　ト　ソレ　ソレ　イソゲ　センサウヘ、　トテ　トテ　トテ　ト　トテ　トテ　トテ　ト」ト　ヲトコ　ハ　フキマシタ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コドモタチヤ、コノ　バシヤハネ、オマエタチガ　マダ　ウマレナカツタ　ジブン、マダ　ジドウシヤト　イフ　モノガ　ナカツタ　トキ、ムラカラ　マチノ　テイシヤバマデ　マイニチ　カヨツタ　モノダヨ。",
              "citation": {
                "source": "フルイ　バシヤ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂子は巴里の美術服装家マレイ夫人に招聘されて六年間の仏蘭西滞在中、ロンドン在留同胞有志の懇望で、海一つ越えて一ヶ月程活花を教へに行つた。",
