        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "酒とウイスキイと魔法瓶とお茶と蜜柑と林檎と、折詰の料理と、味噌焼の握飯とが、白茶けた柔かな草の上にひろげられたのだ。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "魔法瓶に湯を入れてもらって出発し、だいぶ奥まで木を引き出す馬の歩いた跡を伝う。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前は藤橋ホテル等によらず、昼食にもこの餅をたべていたが、近頃はホテルに休んで暖い昼食をし、魔法瓶に熱いお茶を入れてもらったりしてできるだけ楽をする。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中禿の温厚らしい支配人は、叮嚀に分けた頭を叮嚀に下げて、紅茶を入れた魔法瓶を手ずから提げて来て最上階の見事な部屋に案内した。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かしらシテヤラレタという感じに打たれながらベルを押すと、ボーイが来ないで、支配人が、魔法瓶と新聞を両手に持って這入って来た。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "魔法瓶に入れて来たな。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "三郎は、しばらく小さい胸をいためて、考えていたが、やがて思いついたのは、今沸かしたコーヒーを、魔法瓶の中に入れて、司令室にいる艇長のところへ持っていくことだった。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速魔法瓶にコーヒーをつめて司令室へ持っていった。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏と違って大して汗をかきもしませんから、余り大きな水筒を持って行く必要もありますまいが、魔法瓶に熱いお茶でも入れていらっしやい。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "魔法瓶の用意はしてなかったので、木箱を使うより仕方がない。",
              "citation": {
                "source": "白い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けっきょく標本を日本まで持って帰ることになり、特大の魔法瓶を用意し、その中に氷とドライ・アイスとを入れて、飛行機に積みこむことにした。",
              "citation": {
                "source": "白い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "魔法瓶は、断熱のほうは安心であるが、こわれる心配がある。",
              "citation": {
                "source": "白い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "酸素は圧縮ガスの形で運ぶと、ボンベの目方が中身の十倍くらいかかるので、液体酸素にして、大型の魔法瓶に入れて運ぶ。",
              "citation": {
                "source": "宇宙旅行の科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やむをえないお茶の会などには魔法瓶に水を詰めてお伴がついてゆく。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おチビさん、きょうは魔法瓶も来ているの」　チビさんが笑いながらいった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "魔法瓶だの気圧計だのというものには特別の興味を持ち、かつそれを利用したがるのである。",
              "citation": {
                "source": "雪の十勝",
                "author": "――雪の研究の生活――",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとうその思いが一部叶って魔法瓶を買うことの出来た時の無邪気な喜びようには誰もが心を惹かれた。",
              "citation": {
                "source": "雪の十勝",
                "author": "――雪の研究の生活――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の助手をしていた頃も、毎日ブリキの弁当箱に、サンドウィッチと、魔法瓶入りの珈琲と、果物と菓子とを入れたものを持ってきたが、どれも二人前くらいはいっているので、トムは閉口していた。",
              "citation": {
                "source": "娘の結婚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわてふためく芳衛さんやトクさんを差図して魔法瓶に熱い紅茶を詰めさせ、厚い毛の下着とブランデーをルックザックにいれて背負うと、キュッと口を結んで玄関からすべりだした。",
              "citation": {
                "source": "キャラコさん",
                "author": "雪の山小屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャラコさんは、ふと気がついて、ルックザックから魔法瓶を取り出し、熱い紅茶を茶碗に注いで、それを梓さんのほうへ押しやった。",
              "citation": {
                "source": "キャラコさん",
                "author": "雪の山小屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "よんどころないパァティなどには、姉の一人が、魔法瓶に蒸溜水を詰めてついて行くので有名だった。",
              "citation": {
                "source": "蝶の絵",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はい」　魔法瓶の湯を急須に注いでから文吉たちの湯呑みをとり出していると、「早く」「はいはい」　湯呑みをさし出すと、「あついっ！",
              "citation": {
                "source": "日めくり",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々が食後に摂っていた珈琲も不快そうに顔を顰めていたが、魔法瓶は珍しかったとみえて……殊にそこから湯気の立った熱い珈琲の迸り出てくるのを、世にも怪訝そうに眺めているのであった。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを俺にすすめると、「あたしもいただこう」と自分はウィスキーを、そうだ、威士忌を――それもジョニー・ウォーカーの黒を無造作にコップについで、開水瓶（魔法瓶）の湯で割った。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "上海は生水が飲めないので、俺の宿屋でも魔法瓶がそなえてある。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
