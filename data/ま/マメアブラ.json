          "literary": [
            {
              "text": "ふつう市場で、てんぷら油として売っているのは、大豆油である。",
              "citation": {
                "source": "琥珀揚げ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　これが豆油の精製しない方で、こっちが精製した方です。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "動物性と同じくらいに消化れますと云われたので急に豆油がありがたくなった。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり天麩羅などにできますかと聞くと、無論できますと答えたので、近き将来において一つ豆油の天麩羅を食ってみようと思ってその室を出た。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こうして採集したヤニを、今度は油紙に豆油をしいた上に流して、一寸ぐらいの深さにしといて、そいつを二日間直射日光に当てる。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
