          "literary": [
            {
              "text": "彼はまだ頑に呆然と待ち望んでゐる、満目蕭条たる己の晩年に、美しい記憶以上の記憶が甦つてくる奇蹟を。",
              "citation": {
                "source": "画集",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう木の葉がすつかり落ちて、満目蕭条といふ眺めでしたけれども、いゝお天気で……」「あら、ずるいわ……」「曾根の青年諸君が二人、峠まで道案内をしてくれました」「意気投合ね、すつかり？",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "満目蕭条の冬の野山こそ、わたくしの行く手にふさわしい眺めでございました。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
