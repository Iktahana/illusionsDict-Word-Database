    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to lose",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "決して負けることがないのです。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が這入ると負けるが宜いかへ。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "拳闘場では印度人の闘士が負ける度に歓声があがる。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、わざと負ける。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その癖負けず嫌ひだものだから、負けると口惜しさのあまりに意地になつてやるといふ風になる。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "持主は自分の犬が勝つと喜び、負けると悲観する。",
              "citation": {
                "source": "戦争について",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は緒が短いためになお負けるような気がした。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「古鉄砲の張宗昌が、新しい独逸銃に負けるっていう胸算用だな……」「なに、張大人が勝ったって負けたって、何もかまいやせんじゃないか。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「勝つも負けるもねえじゃないか、そこらの蟻は、大砲を持ってきて、一となめに、なめッちまえばいゝじゃないか！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、こんな日に限って負けるんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日にも悪魔の誘惑に負けるような事がありませぬうちに…………。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "喧嘩すりゃあ負けるものだから、そんな弱い事を言うのだろう。",
              "citation": {
                "source": "章魚の足",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "口はややこれらに負けるようだが、厚い唇はきっと結んでいる。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども日本では狐けんというものもあって狐は猟師に負け猟師は旦那に負けるときまっている。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいえどかれません、じゃ法令の通りボックシングをやりましょうとなるだろう、勝つことも負けることもある、けれども僕は卑怯は嫌いだからねえ、もしすきをねらって遁げたりするものがあってもそんなやつを追いかけやしない、あとでヘルマン大佐につかまるよってだけ云うんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "負けると食われるぞ。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小は四五｜尺より大は二三｜丈位いの數てば端艇諸共海底に引込まれんず有樣、けれど此時此鐵鎖が如何して放たれやうぞ、沙魚が勝つか、私が負けるか、釣れると釣れぬは生死の分れ目、日出雄少年は眼をまんまるにして、此凄まじき光景を眺めて居つたが、可憐の姿は後から私を抱き『オヽ、危い事！",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨牌の好きな、そしていつでも負ける草香君も行つた。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも祟りに負けるなと、言うて、一生懸命、仰向かしった枕をこぼれて、さまで瘠せも見えぬ白い頬へかかる髪の先を、しっかり白歯で噛ましったが、お馴染じゃ、私が藪の下で待つけて、御新造様しっかりなさりまし、と釣台に縋ったれば、アイと、細い声で云うて莞爾と笑わしった。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其奴に、負けるな、押潰せ、と構わず褥を据えましたが、夜露を受けたが悪かったか、もうお医者でも間に合わず。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとなげのないわけだけれど、こういう行き懸かりになってみると、どうも負けるのは残念だ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "和尚さんは白餡入りの饅頭六つ賭けるさかい、豹ぼんは」何も賭けるものがなく、蓮池から亀の子一匹掴えて、負けると和尚に呉れてやることになった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな弱い相手に負けるのはおかしい。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに日は暮れるしおなかはすくし、二人とも疲れてイヤになって来ましたが、負けるのが口惜しいからやめる訳にゆきません。",
              "citation": {
                "source": "二人の男と荷車曳き",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからの女は出来るだけ学問をしなければ外国に負けることをお話して、お許しを受けて来ました。",
              "citation": {
                "source": "キキリツツリ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "必ず負けるのである。",
              "citation": {
                "source": "桜桃",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "負けるような気がして、いやである。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "権利がなくつて負けるのはまだしもだが、権利がある上に負けるのは二重の敗北である。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "中津はひげ面のひげを青く剃り、稍々ちゞれる癖のある、ほこりをかむった渦まける髪をきれいに梳って、油の臭いをプンプンさしていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、高取、なまけるな！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
