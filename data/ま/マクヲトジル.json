        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "惜しまれながらも、この名店は今月末をもって百年の歴史に幕を閉じる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夏の甲子園は、決勝戦の劇的なサヨナラ勝ちで幕を閉じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "太陽が水平線に沈み、穏やかな一日が静かに幕を閉じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
