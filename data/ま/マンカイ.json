    "definitions": [
      {
        "index": 1,
        "gloss": "full bloom (esp. of cherry blossom)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "武田神社は、武田信玄を祭ってあって、毎年、四月十二日に大祭があり、そのころには、ちょうど境内の桜が満開なのである。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "サクラの満開の日と、生れた日と、こんなにピッタリ合うなんて、なんだか、怪しい。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "変らず、身辺の良友の言を聴き、君の遠大の浪漫を、見事に満開なさるよう御努力下さい。",
              "citation": {
                "source": "砂子屋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手水鉢の向かいの梅の枝に二輪ばかり満開したのがある。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "七、八分という見頃から満開にかけてはとうとう見損ってしまった。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏中ぽつりぽつり咲いていたカンナが、今頃になって一時に満開の壮観を呈している。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小涌谷辺は桜が満開で遊山の自動車が輻湊して交通困難であった。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、十分前には一つも開いていなかったのが十分後にはことごとく満開しているのである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座の市場では阿片の花が陽気に満開し、薬種屋の前では群集が巡邏に口輪を嵌めている。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると一座が急に浮かれて酒盃がかるやかに夜目にも白い運河を越えて、日本流の歓待のなかで青い花が満開して、思いがけなくもアダの顔がそこにあらわれてくるのを認めるのであった。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕間になると彼女は放蕩親爺の好色眼と若い男たちの漫然とした不可解な顔と、理智的な侮蔑のなかをクジャクのように満開して、奈落から通ずる楽屋へ座頭のヤマジ・マツノスケを訪ねた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　庭と中庭との隔ての四つ目垣がことしの夏は妙にさびしいようだと思って気がついて見ると、例年まっ黒く茂ってあの白い煙のような花を満開させるからすうりが、どうしたのかことしはちっとも見えない。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯村のその大衆浴場の前庭には、かなり大きい石榴の木が在り、かっと赤い花が、満開であった。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一粒の草花の種子が発芽してから満開するまでの変化を数分の間に完了させることもできる一方では、また、弾丸が銃口を出て行く瞬間にこれに随伴する煙の渦環や音波の影の推移をゆるゆると見物することもできる。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年紀は二十三、四、姿はしいて満開の花の色を洗いて、清楚たる葉桜の緑浅し。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯屋の遠いことや、買物の不便なことや、一々かぞえ立てたら色々あるので、わたしもここまで引込んで来たのを悔むような気にもなったが、馴れたらどうにかなるだろうと思っているうちに、郊外にも四月の春が来て、庭にある桜の大木二本が満開になった。",
              "citation": {
                "source": "郊外生活の一年",
                "author": "大久保にて",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏畑の三本、前の家の二本、いずれも老木、満開のころは、一人で観るのにもったいないほどであった。",
              "citation": {
                "source": "三八九雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "花は満開のうちに眺むべきである。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "合浦公園の桜は、いま、満開だといふ話であつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大川の土手の陰に、林檎畑があつて、白い粉つぽい花が満開である。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "弥生の末から、ちっとずつの遅速はあっても、花は一時に咲くので、その一ならびの塀の内に、桃、紅梅、椿も桜も、あるいは満開に、あるいは初々しい花に、色香を装っている。",
              "citation": {
                "source": "絵本の春",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お庭の満開の桃の花が私を見送っていて、思わずふりかえったが、私は花を見て居るのではなかった。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その満開の一枝に寒くぶらんとぶらさがっている縄きれを見つめていた。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其日にはどの枝も殆ど満開であつた。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さし俯向いた頸のほんのり白い後姿で、捌く褄も揺ぐと見えない、もの静かな品の好さで、夜はただ黒し、花明り、土の筏に流るるように、満開の桜の咲蔽うその長坂を下りる姿が目に映った。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月末頃から咲き出した紅椿の上枝の花は、少し萎れかかって花弁の縁が褐色に褪せているが、中部の枝には満開の生き生きした花が群がり、四月下旬の午後になったばかりの精悍な太陽の光線が、斜めにその花の群りの一部を截ち切っている。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから或る年の暮、青山墓地通りの満開の桜の下を二人は歩いて居た。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "淡紅満開の花の盛り上る梢は、一斉に連なり合って一樹の区切りがつき難い。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――桜が満開でございましょう。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　植物園では仏桑花、ベコニア、ダリア、カーネーション、それにつつじが満開であった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
