        "examples": {
          "standard": [
            {
              "text": "この豊かな実りをもたらす大地こそ、我らが誇るまほらだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "山々に囲まれたその村は、まるで桃源郷のようなまほらであった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古の詩人は、美しい故郷を「まほら」と呼んで詩に詠んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "七『ひと日樹の實を啄ばむと、谿のまほらへ降りたまま、山の嫗の蠱ものに、夫は迷ひてかへらぬ。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "長歌の方は、「父母を見れば尊し、妻子見ればめぐし愛し、世の中はかくぞ道理」、「地ならば大王います、この照らす日月の下は、天雲の向伏す極、谷蟆のさ渡る極、聞し食す国のまほらぞ」というのが、その主な内容で、現実社会のおろそかにしてはならぬことを云ったものである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            }
          ]
        }
