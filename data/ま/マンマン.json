[
  {
    "uuid": "668f1477-cb16-5850-8ad6-3c825010457b",
    "entry": "万々",
    "reading": {
      "primary": "まんまん",
      "alternatives": [
        "ばんばん"
      ],
      "is_heteronym": false
    },
    "grammar": {
