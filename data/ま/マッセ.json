  {
    "uuid": "7db9da65-1f90-5fbe-9183-0ff42eb19f2e",
    "entry": "まっせ",
    "reading": {
      "primary": "まっせ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "let's do it",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "不思議不思議……ほかにあの蔵元屋の家付の者はおりまっせんかナア。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この下手人がわからねば妾ゃ死んでも浮かばれまっせん。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "幽霊船の歩に取られたような顔つきで、漕出したげでござりますが、酒の匂に我慢が出来ず……　御繁昌の旦那から、一杯おみきを遣わされ、と咽喉をごくごくさして、口を開けるで、さあ、飲まっせえ、と注ぎにかかる、と幾干か差引くか、と念を推したげで、のう、ここらは確でござりました。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「噂をすれば、芸妓はんが通りまっせ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲良くやってまっせ。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼうふらが湧きまっせ」　と、ビールの瓶を持った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、いきなりはいって来た男が、「おっと……、それ、あけちゃ困りまっせ」　と、道子の手を払おうとした。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、僕かて石油がなんぜ肺にきくかちゅうことの科学的根拠ぐらいは知ってまっせ。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日に、一杯ずつ、一週間も飲みはったら、あんたの病気くらいぱらぱらっといっぺんに癒ってしまいまっせ。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えさしてもらいまっせ。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人と相談さしてもらいまっせ」　政江は興奮の余り、便通を催した。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お伴さしてもらいまっせ」　いうだけは云ったが、初乃は、権右衛門は大変酔っていると思った。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "言わしてもらいまっせ。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、皆さん、私が猿を舞いまっせ。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　他吉はたまりかねて、「居りまっせエ、へえ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "居りまっせ」　と、両手をあげてどなった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら、お門ちがいや、うちの孫はまだ十やさかいな、おまはん仲人したかったら、散髪屋のおばはんとこイ行きなはれ」「聴こえるがな、聴こえたら、また朝日軒のおばはん頭痛を起しまっせ」　広島生れの玉堂は下手な大阪訛りで言って、ちょっと赧くなった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "他吉は出て行く時、「おばはん、君枝をたのんどきまっせ」　と、言った。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の丸湯へ戻り、ふと女湯の障子にはめられた赤、紫、黄、青の色硝子に湯槽の湯がゆらゆらと映って、霞んでいるのを、いつもとちがうしみじみとした美しさだと見上げていると、「上り湯ぬるおまっせ」　羅宇しかえ屋のお内儀の声がし、暫らくすると、季節はずれの大正琴の音がきこえて来た。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんたが維康さんと晴れて夫婦になる日を待ってまっせ」おきんに言われて蝶子は泣けた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "送って廊下へ出ると柳吉の妹は、「おうちの苦労はお父さんもこの頃よう知ったはりまっせ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎は笑って、「それなら、今夜はまあ、気を利かせて貰うことにして、明日からずっとこの家へ来てもらいまっせ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "危のおまっせ」　と、金切声で叫び、そして転んで、あはははと笑った。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
