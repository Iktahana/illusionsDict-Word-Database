          "literary": [
            {
              "text": "思ふにハネバシとしては、これはすでに末期症状のものでしたらう。",
              "citation": {
                "source": "吉原ハネ橋考",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベッドに横たわる一人の男、明らかに肺結核の末期症状だ。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵国からも末期症状と見られるだろう。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに北条幕府のみだれが末期症状であろうとも、あれで、“世直し”を行ろうなどは片腹いたい。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            }
          ]
