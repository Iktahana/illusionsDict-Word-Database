        "examples": {
          "standard": [
            {
              "text": "日本語の文書では、漢字とひらがなの交ぜ書きが一般的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供向けの絵本は、読みやすいように漢字にふりがなをつけたり、交ぜ書きにしたりしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最近のSNSでは、若者を中心に独自の交ぜ書きが使われることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さらに句読点の処理や数字の表記、漢字の使い方、和文の中に欧文を交ぜ書きする際はどうすれば読みやすくなるかといったさまざまな点に関して、本作りに携わる人たちは工夫を重ね、成果を分かち合ってきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
