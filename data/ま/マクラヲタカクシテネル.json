        "examples": {
          "standard": [
            {
              "text": "試験勉強は完璧だったから、今夜は枕を高くして寝られそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "重要なプロジェクトが無事に完了し、ようやく枕を高くして寝ることができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は会社の問題を解決し、安堵して枕を高くして寝た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ですからあの後家さんが生きている間は、枕を高くして寝る事が出来ません。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "動物園の檻を抜け出した野獣みたいなやつが、ノソノソ町を歩いていたのでは、東京じゅうの人が枕を高くして寝ることができないわけだ。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
