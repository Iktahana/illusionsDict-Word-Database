        "index": 1,
        "gloss": "bouffant cloth cap (traditionally worn by old people and monks)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
