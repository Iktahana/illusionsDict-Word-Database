    "definitions": [
      {
        "index": 1,
        "gloss": "as far as the eye can see",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
