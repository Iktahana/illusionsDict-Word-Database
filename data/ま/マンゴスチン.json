        "examples": {
          "standard": [
            {
              "text": "南国フルーツの女王と呼ばれるマンゴスチンは、甘酸っぱくて美味しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "市場で新鮮なマンゴスチンを見つけたので、いくつか買ってみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "マンゴスチンの白い果肉は、とてもジューシーで上品な甘さがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "柿の型をした紫の殻を裂くと、綿の花のような房が甘酸く唇に触れるマンゴスチンも珍らしかった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "マンゴスチンと申す茄子の如き色形せるもの、皮やむくべき、甘き汁を吸ふ事やすると惑ひ居り候ひしに、鈴木の来りて、二つに竪に割りて中子を匙にて食へと教へ申し候。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
