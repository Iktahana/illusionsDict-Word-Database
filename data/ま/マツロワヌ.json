        "examples": {
          "standard": [
            {
              "text": "辺境の地に住む服わぬ民たちは、中央政府の命令を無視して自給自足の生活を続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「権力者に決して服わぬその孤高の精神が、多くの若者を惹きつけている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "服わぬ神々を力でねじ伏せるのではなく、対話によって和解の道を模索すべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "当代の政治に順服わぬ徒輩を一気に殲滅す下拵えを私にせよというのでした。",
              "citation": {
                "source": "正雪の遺書",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平沙には匈奴王にまつろわぬところの、無数の種族の蛮人達が、現れたり隠れたりして敵意を示した。",
              "citation": {
                "source": "沙漠の美姫",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまつろわぬスサブル神（赤の他人）を平定した前世代はヒダの地へ天ツ船でのりこんだんだろう。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛騨・高山の抹殺――中部の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いや我らが御旗を捧げて、まつろわぬ者どもを折伏するのだ」「靡かぬものとてはござりますまい」「日本ばかりか異国さえも靡くよ」吉野へ！",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
