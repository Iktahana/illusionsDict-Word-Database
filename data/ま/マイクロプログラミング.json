        "examples": {
          "standard": [
            {
              "text": "マイクロプログラミングは、CPUの制御装置を設計する手法の一つである。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このCPUアーキテクチャでは、マイクロプログラミングを用いて命令セットを実装している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この新しいチップ、マイクロプログラミングで柔軟に命令を拡張できるんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "だが浜田はこの装置の開発作業を通じて、マイクロプログラミングと呼ばれるこうした手法の有効性を実感していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七三（昭和四十八）年八月に発表されたオフィスコンピューター、システム１００は、マイクロプログラミング方式をとっていたが、マイクロコンピューターの採用にはいたっていなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイクロプログラミング方式の採用で低価格化と小型化を推し進めたというハードウエアの特長に加え、さまざまなアプリケーションをあらかじめ用意しておくというソフトウエアの備えによって、システム１００はコンピューターの利用の裾野を広げようと狙っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "通信制御装置の開発でマイクロプログラミングの手法を体験した浜田俊三は、初代のシステム１００の開発にあたってもこの技術を選んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
