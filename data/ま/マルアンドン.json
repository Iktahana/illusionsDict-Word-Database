          "standard": [
            {
              "text": "時代劇のセットに置かれた丸行灯が、夜の長屋の路地をかすかに、情緒深く照らしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "老舗旅館の玄関先に吊るされた丸行灯に、格式高い屋号が墨書きされていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "和紙を透かした丸行灯の柔らかな明かりは、現代の照明にはない独特の趣がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "黒い天井に差す丸行灯の丸い影が、仰向く途端に生きてるように見えた。",
              "citation": {
                "source": "夢十夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸行灯が灯っていた。",
              "citation": {
