    "definitions": [
      {
        "index": 1,
        "gloss": "to keep a watch (on)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
