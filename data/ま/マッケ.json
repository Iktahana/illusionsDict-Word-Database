        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この話をして間もなく、お父様の心安くしていらっしゃる安中という医者が来て、或る大名華族の末家の令嬢を貰えと勧めた。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "大田原家は素一万二千四百石であったのに、寛文五年に備前守政清が主膳高清に宗家を襲がせ、千石を割いて末家を立てた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "今｜手許に末家の系譜がないから検することが出来ない。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に医者の年長者には先ず多紀の本家、末家を数える。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "多紀氏ではこの年二月十四日に、矢の倉の末家の庭が既に逝いて、暁湖がなお存していた時に成ったもので、庭の楽真院を、「武鑑」には前から楽春院に作ってある。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この地は鍋島家の末家邸であったかと記憶する。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "春嶽の宗家・末家の感を超える勤皇行為、篤胤門に入つて復古運動に走つた雪江、この主従が苦しんだ板挟みの境遇、薩州その他の堪へ難い圧迫にさいなむ苦衷は、曙覧の心を悲壮なものとしたに違ひない。",
              "citation": {
                "source": "橘曙覧",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "程近い旧藩主の邸内に、藩の人たちが御末家と呼ぶお家がありました。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊達藩は大きく昔は他にも窯場を有っていたが、山の目焼、切込焼、畑山焼、末家焼等いう名のみ残って悉く絶えた。",
              "citation": {
                "source": "現在の日本民窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今親戚のところへ疎開してまっけど、また大阪市内で本屋しまっさかい、雑誌買いに来とくなはれ」と、三ちゃんは既に捲土重来の意気込みであった。",
              "citation": {
                "source": "起ち上る大阪",
                "author": "――戦災余話",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、言うときまっけどね。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうせ婿の新太郎から来た手紙や思いまっけど、なんぞ言うとりまっか。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "売れてくれると宜しおまっけど、さて開いて見たら、耳かきぐらいしか売れへんのとちがいまっか」　種吉はちょっと照れた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええもんや言うことは聴いてまっけど……」　しかし、本当に次郎と一緒にそんなとこへ行ってもよいものかと、君枝は躊躇した。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとよりその頃は既に身うけされて、朝鮮の花街から呼び戻され、川那子家の御寮人で収まっていたお千鶴は、「――ほかのことなら辛抱できまっけど、囲うにこと欠いて、なにもわての従妹を……」　と、まるで、それがおれのせいかのように、おれに食って掛った。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、お言葉はありがたく頂戴しまっけど、どうも、人を笑わすいう気になれまへんので……」　赤井がそう断ると、傍で聴いていた白崎はいきなり、「君、やり給え！",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ところで、おばはん、けったいな事訊きまっけど、おまはん字ィはどないだ？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "関東煮屋をやると聴いて種吉は、「海老でも烏賊でも天婦羅ならわいに任しとくなはれ」と手伝いの意を申し出でたが、柳吉は、「小鉢物はやりまっけど、天婦羅は出しまへん」と体裁よく断った。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「児がいちゃ、じゃまっけだから、あっちへやりましょうよ」　それは二人でいるにこしたことはなかった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのろくろ首をひっこめろッ」「じゃまっけで見えねえじゃねえか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいじょうぶだ、へびはいねえよっていってやりましたら、おれさまともあろうものが、こまっけえやつの下風についてたまるけえと、こんなことをガミガミ言いのこしまして、どこかへずらかっちまいましたんですよ」　いっているところへ、どうもやることなすことが伝六流でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃまっけだから、こっちへ引っこんでいな」「いいえ、だんな、お黙り！",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんてまあこまっけえんだろうね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "するてえと、あのお公卿さまが、からだのこまっけえ割合に、奇態に吹き矢を当てるんでね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "長居はじゃまっけじゃねえか」　しかるに、その伝六が表へ出ると、「ね……！",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「…………」「じゃまっけだな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "生かしておきゃ仲間にじゃまっけだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "おめえ、がらはこまっけえが、なかなか気のきいたことをぬかすやつだな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「塚本君、えらいお邪魔しまっけど、実はちょっと聞きたいことがおまんねん。",
              "citation": {
                "source": "猫と庄造と二人のおんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「二階らしおまっけど、階下へかて降りて来まっしゃろ。",
              "citation": {
                "source": "猫と庄造と二人のおんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
