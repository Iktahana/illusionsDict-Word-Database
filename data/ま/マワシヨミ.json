        "examples": {
          "standard": [
            {
              "text": "一冊しかない貴重な漫画を、クラスメイト全員で回し読みした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "雑誌を回し読みして、最新のファッション情報を共有する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "文芸部の部誌は、部員たちの間で回し読みされた後、図書室に置かれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "だが、破れてないし、司祭から司祭へ熱心に回し読みしている。",
              "citation": {
