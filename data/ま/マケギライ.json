    "definitions": [
      {
        "index": 1,
        "gloss": "hating to lose",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ドッチも鼻梁の強い負け嫌いの天狗同志だから衝突するのは無理はない。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、同時に頗る負け嫌いであった。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "負け嫌いの甚だしいは、人に自分の腹を看透かされたと思うと一端決心した事でも直ぐ撤去して少しも未練を残さなかった。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在自分の口から言出して置きながら、人に看透かされたと思うと直ぐコロリと一転下して、一端口外した自家意中の計画をさえも容易に放擲して少しも惜まなかったのはちょっと類の少ない負け嫌いであった。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間並のお世辞上手な利口者なら町内の交際ぐらいは格別｜辛くも思わないはずだが、毎年の元旦に町名主の玄関で叩頭をして御慶を陳べるのを何よりも辛がっていた、負け嫌いの意地ッ張がこんな処に現われるので、心からの頭の低い如才ない人では決してなかった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "十　椿岳の畸行作さんの家内太夫入門・東京で初めてのピヤノ弾奏者・椿岳名誉の琵琶・山門生活とお堂守・浅草の畸人の一群・椿岳の着物・椿岳の住居・天狗部屋・女道楽・明治初年の廃頽的空気　負け嫌いの椿岳は若い時から誰でも呑んで掛って人を人臭いとも思わなかった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、二葉亭は極めて狷介な負け嫌いであると同時にまた極めて謙遜であって、如何なる人に対しても必ず先ず謙虚して教を待つの礼を疎かにしなかった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体が負け嫌いの病気に勝つ方で、どんなに苦しくても滅多に弱音を吹かなかった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "清少納言はこの時期にも宮仕えしていたのであったが、彼女の負け嫌いな気質と結びついて現れている当時の常識の姿として、枕草子の中にはこの気立のすぐれたおおらかな中宮のあわれに、優婉な宮廷生活は描き出されていないで、この人の華やかであった時の物語、情景、印象などがとり集められている。",
              "citation": {
                "source": "山の彼方は",
                "author": "――常識とはどういうものだろう――",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとなしい美津に負け嫌いの松の悪口を聞かせるのが、彼には何となく愉快なような心もちも働いていたのだった。",
              "citation": {
                "source": "お律と子等と",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体そんな云い懸りを云うような所へ周旋する君からしてが不埒だ」「おれが不埒か、君が大人しくないんだか、どっちかだろう」　山嵐もおれに劣らぬ肝癪持ちだから、負け嫌いな大きな声を出す。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその人と正式に結婚してくれないかね」　と私は言うが、女がとりあわないのにも理由があり、私は甚だ嫉妬深く、嫉妬というより負け嫌いなのだ。",
              "citation": {
                "source": "いずこへ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ彼の負け嫌いと執念深さは、尋常一様のものではなかった。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "如是閑は、中野は非常な負け嫌いだったから、自分の意思の通りにならぬことを悲観したのだろうという。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "負け嫌いのくせに、本を漁ろう考えもなく、ただ酒ばかり飲んで、月日を後へ送ってる。",
              "citation": {
                "source": "曲亭馬琴",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこれが互に負け嫌いな居士と古白君との永久の別離であったのである。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女に特有な負け嫌いな精神が強く働らかなかったなら、彼女はお秀の前に頭を下げて、もう救を求めていたかも知れなかった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さよう、あれは癇性で、気位が高くて、負け嫌いな女ですよ。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "――高慢で見栄坊で負け嫌い。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆらい、三男はすばしっこくて負け嫌いの暴れん坊と商標の定ったものだ、しかるに平之助は全然その逆であった。",
              "citation": {
                "source": "風流化物屋敷",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若さと負け嫌いと、そうして相手が兄だったから云えたのだろう、あのとき自分は勝ったのだ。",
              "citation": {
                "source": "四日のあやめ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ少々不満であったのは、当の瑠璃子から何の反響もないことだが、こちらから手紙をやった訳ではないのだから、新聞記事を読んでも例の負け嫌いで、態とそしらぬ振りをしているのかも知れない。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい一昨年ごろ、坂本から上って来た若者で、はじめは、房の厨中間として働いていたが、なかなか、学才があるし、賤しくないし、少し才気走った嫌いはあるが、感情家で負け嫌いなところから、堂衆に取り立てられて、今では学僧のなかに伍している朱王房だった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ福の神でも祀ってある場所がちがうと、もう両方へ詣ることは出来なかったのを見ると、仲の善くないのは神様ではなくて、やはり山と山との背競べのように、土地を愛する人たちの負け嫌いが元でありました。",
              "citation": {
                "source": "日本の伝説",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
