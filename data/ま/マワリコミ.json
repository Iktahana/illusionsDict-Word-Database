        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "が一案が浮かんで、御者は玄関の戸から走り出て芝地を回り込み、例の長いフランス窓のところへ向かった。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "稜線を回り込み未踏の世界を瞥見しようとした時の緊迫した期待感は到底筆舌に尽くし難く、山地の向こうの領域が既に目にし横断してきた地とは本質的に異なると考える理由が皆無だったとしてもその点に変わりはなかった。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "早暁の幽鬼じみた灰色の光がカーテンの縁に回り込み光景に一層の恐ろしさを付け加えた。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "用心してさっと回り込み、マッチを擦って頭上にかざした。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "けものがすぐ近くまできたとたん、ひらりと身をかわして、木のうしろへまわりこみました。",
              "citation": {
                "source": "いさましい　ちびの仕立屋さん",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "千葉周作と聞いて、伊勢万作もはっとし、まわりこみながら、すばやくそっちを見、そして幹太郎に頷いた。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "波が消える地点からさらに大きく左にまわりこみつつ、ふたりのサーファーはパドリングで視界にあらわれた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きく左へまわりこみつつスピードをあげ、道路のむこう側のガードレールに、突っこんだ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
