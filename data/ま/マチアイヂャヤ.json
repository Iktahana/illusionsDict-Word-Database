    "definitions": [
      {
        "index": 1,
        "gloss": "meeting place for assignations, drinking, etc.",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "通称は又兵衛、長谷川町の待合茶屋である。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして停車場の前の待合茶屋にやすんで、用もないのに隱岐を電話に呼び出したりするのであつた。",
              "citation": {
                "source": "痴日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　小田原を出発する私達は主に明方の一番車であつたが、停車場の前の入木亭といふ待合茶屋へ乗り込んで、天候の次第を待たなければならなかつた。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "幇間を罷めて後、鍋屋横町に待合茶屋を出した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "あてのうちは待合茶屋とは違ふさかい。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十ばかりの待合茶屋のお神さんみたような人がまいりまして。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人「アノ私はね、浜町の待合茶屋でございますがね、何うも私は性来お世辞がないんですよ、だもんだからお母さんが、手前の様に無人相ぢやア好いお客は来やしないから世辞を買つて来いと、小言を云はれたので態々買ひに来たんです、何うか私に宜さゝうな世辞があるなら二ツ三ツ見せて下さいな。",
              "citation": {
                "source": "世辞屋",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "車は電車通から急に左へ曲り、すぐまた右へ折れると、町の光景は一変して、両側ともに料理屋待合茶屋の並んだ薄暗い一本道である。",
              "citation": {
                "source": "寺じまの記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "貸座敷、待合茶屋、芸者家などの亭主と客との間もまた同じことで、此両者の対談する場合は、必ず女を中心にして甚気まずい紛擾の起った時で、然らざる限り対談の必要が全くないからでもあろう。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "北鄰は待合茶屋なり。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之一大正六年丁巳九月起筆",
                "note": "青空文庫"
              }
            },
            {
              "text": "久米秀治氏細君営業の待合茶屋なり十月十日。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之一大正六年丁巳九月起筆",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしの母の語る所を聞くに三河屋の妹徳は後に池の端に待合茶屋を出した。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その頃に細君とは別れて、浅草のなに太郎とかいう名妓に恋され、その名妓は彼のために身ぬけとかいう冒険を敢えてして結婚し、旅まわりなどにもいっしょに付いてまわったのであるが、現在、彼女は元の土地の浅草で、ある格式の高い待合茶屋の女中がしらをしながら、彼の呼びよせるのを待っているということだった。",
              "citation": {
                "source": "陽気な客",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "待合茶屋の豆腐やそら豆ではあきたらない。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
