    "definitions": [
      {
        "index": 1,
        "gloss": "to make round",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そしてまたしばらく噛んで丸める動作を繰り返していた。",
              "citation": {
                "source": "蜂が団子をこしらえる話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "はつと驚く間もあらせず、妻の傍をすり抜けて、両手を子供の頭と膝との下にあてがふが早いか、小さい体を丸めるやうに抱きすくめた。",
              "citation": {
                "source": "An Incident",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちぎった書き崩しを拾って、くちゃくちゃに揉んだのを披げて、皺を延ばして畳んで、また披げて、今度は片端から噛み切っては口の中で丸める。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の本人から見て取れるのは、血の気の失せた土気色の顔に、垂れ下がった瞼、開ききった瞳孔で、椅子に座ったまま身体を丸める姿は、落ちぶれた上流の人間そのものであった。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "綿打弓でびんびんとほかした綿は箸のやうな棒を心にして蝋燭位の大きさにくる／＼と丸める。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを自分の才力で丸めるのが時に取っての興味のようにも思えた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は書散らしの紙を苦茶苦茶に丸めると、口の中へ投り込んだ。",
              "citation": {
                "source": "痴想",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "母も煙草が好きで、よく長煙管でスパスパやっていたが、例の不器用なたちとして、その火皿に刻みを詰める時、指先でそれを丸めることが足りないので、長い刻みの尾が煙管の先にぶらさがっていることが毎度であった。",
              "citation": {
                "source": "私の母",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（九郎助拾い集めて掌中に丸める）牛松　じゃ、稲荷の兄い、ごきげんよう。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "九郎助あわてて丸める）弥助　誰が書いたんだろう。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "……しかし何をいうにもこの談判委員を承った連中というのが、人を丸める事にかけては専門の一流揃いと来ているんだ。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は医者でないが丸薬を丸める位の事は屹と出来るから、何卒世話をして貰いたいと云うと、岡部も私の身の有様を気の毒に思うたか、私と一緒になって腹を立てゝ容易く私の云う事を請合い、「ソレは出来よう、何でも江戸に行け。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて封筒を再びクル／＼と丸めると、屑籠の中へ押込んで、何喰わぬ顔で又掃除を始めた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（この村の人を丸めるのは訳は無いが、江戸の役人は、俺の逃げたのを聞いているだろう。",
              "citation": {
                "source": "寺坂吉右衛門の逃亡",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい熱心にそれに耳を傾けてゐた私は、その時はじめてその女と自分とがいつか知らず識らずの裡に暖爐の方へ背中を丸めるやうにして互に身をよせてゐるのに氣がついた位だつた。",
              "citation": {
                "source": "生者と死者",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕り方たちは、御用提灯を振りかざして、獲物を狙う獣物のように、背中を丸めるようにして、押しつけて来るのだったが、さりとて急には飛び込めない。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａは表に至急親展とあるので、ちょっと箸を下に置くと、すぐ封を開いたが、少し読み下すと同時に包んである写真を抜いて裏を見るや否や、急に丸めるように懐へ入れてしまった。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「叩き売っても、まず……三万両は確かだろう」　私は白紙をクルクルと丸めると、着物の袂に無造作に投げこんだ。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして堺氏は中間にあつて、儒・佛・耶すべてがよろしいと、われわれを丸めるのでありました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも夜なべ仕事に拵えるので、お父様がお薬を調合してお出しになると、大きな乳鉢でつなぎになる薬を入れ――ヒヨスもはいったようでした――乳鉢で煉り合せ、お団子くらいのよいほどの固さになった時、手に少し油を附けて、両手で揉んで、右の親指の外四本の指先に少しずつ附けて、左の掌で丸めるのです。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "リャボーヴィチは頭からすっぽり毛布を引っかぶって、からだを蝦みたいに丸めると、想像の中で例のちらちらする幻を拾いあつめて、一つの完全な姿にまとめ上げようとしだした。",
              "citation": {
                "source": "接吻",
                "author": "ПОЦЕЛУЙ",
                "note": "青空文庫"
              }
            },
            {
              "text": "贋コショウは亜麻仁かす（アマの種子から油を絞ったかす）、粘土および一部のトウガラシからなり、塊を作り、まず最初に篩を通し、次に桶の中で転がして丸める。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、ものは相談だが、貴殿との話しあいいかんによっては、拙者が左膳を丸めるなり片づけるなりして、乾雲丸をお手もとへ返したいと思うが、お聞き入れくださるか」　栄三郎は解しかねる面もち。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "人と対坐しながら鼻くそを丸める。",
              "citation": {
                "source": "くせ",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つくのも、こねるのも、丸めるのも、おおむね身内だけで行うので、特別に日当を払う必要はない。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄の竜介はもう中学生になっていて、餅を丸める仕事にあき足らず、しきりに餅つきの作業に参加したがって、父や母にたしなめられていた。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行くと自分の家の餅つきは、主役とまでは行かないが準主役で、餅を丸めるという重要な仕事を与えられている。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は外套を丸めると僕の膝にどさりと置いた。",
              "citation": {
                "source": "蜆",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ろ」　とびきり美しい羽毛を丸めると、ビー玉より小さくなった。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うん」「それでは……」　日ごろの剽軽に似あわず、深刻めいた顔付の豆八は、紙片をくるくると丸めると、ランプの火に投じた。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
