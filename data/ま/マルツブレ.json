        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「丸つぶれ」でなく、「丸つぶし」と言っているのも妙である。",
              "citation": {
                "source": "無題",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「丸つぶれ」でなく、「丸つぶし」と言つてゐるのも妙である。",
              "citation": {
                "source": "無題",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前のような年少の者の肩にしなだれかかって峠を越えたという風聞がもし国元に達したならば、父や兄たちの面目が丸つぶれじゃないか。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしの面目が丸つぶれじゃ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志のお気に召さなかったら、面目丸つぶれのところだった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三歳の童子にも勘定はできることならん」　右の議論によれば名分は丸つぶれの話なれども、念のためここに一言を足さん。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何百年来ささえて来た一城のあるじたる大名の面目が、そこで丸つぶれになるだろう。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "御周旋くだされた阿部さまの面目も丸つぶれとなる。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "丹頂の鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "……気障なことを言うようですが、これだけの人数を動かしておいて、今晩はやって来ませんでした、また明晩のお楽しみじゃ、北町奉行所の面目は丸つぶれ、たいへんな物笑いになるわけですが、そいつは間違いなく今晩やって来るんですか。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "蕃拉布",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、もし宋国の医師に依て生命が長らえたとあっては、我が国医術の面目も丸つぶれになるし、効き目がなければ、面謁して意味はないであろう。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしみつからなかったら、うちは丸つぶれになってしまうんだよ。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A DOG OF FLANDERS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こいつを調べた日にや、うけ合ひ盆前丸つぶれだよ」「親分、――あの手筥が變ぢやございませんか」　音吉に言はれて、平次はもう一度引返しました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "櫛の文字",
                "note": "青空文庫"
              }
            },
            {
              "text": "是が非でも島田を斬らねば新徴組の面目丸つぶれじゃ」「しかし、本来を言えば島田にはなんの怨みもない、落度はこっちにあるから自業自得じゃ」「そうでない、我々同志が敵でもあり、公儀にとっても油断のならぬ島田虎之助、ぜひとも命を取らにゃならぬ」　低く話すつもりでも高くなりがちな芹沢の声音。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴鹿山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺の顔は、丸つぶれだ。",
              "citation": {
                "source": "井伏鱒二によせて",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とか「俺の人格は、丸つぶれだ。",
              "citation": {
                "source": "井伏鱒二によせて",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとらしいです」「他所者に、縄張の中で、御馳走の撰り食いをされちゃあ、他の者の顔は、丸つぶれじゃないか」「まあ、わたしに委せといて下さい」　角助は、そういって、自信ありげに、うなずき、指の短い両拳を握って、反っくりかえらせた胸を、どすんと、たたいた。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "大庭の親方の顔も、藤本さんの顔も、おれの顔も、丸つぶれになってしもうた。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは彼の面目は丸つぶれです」「その言い方だと、まるで貴方が彼の心を良く読めてた様に聞こえるけど、とてもそうは思えないわ」ミショノー嬢が言った。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた方は負けて、面目丸つぶれ。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局この会談は思ったほど面目丸つぶれじゃなかった。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の面目は、まるつぶれになるのではないでしょうか。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生はとにかく、それでは僕の面目までまるつぶれだ。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの裏切者は今頃は面目まるつぶれだよ。",
              "citation": {
                "source": "動物園の一夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には仏道修行はとても出来ないが（仏弟子としての面目まるつぶれだ）俳諧修行なら出来る、現に日夜それに全身全心をうちこんでゐる、俳諧修行もまた仏道修行の一つとはいへないだらうか。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「後生だから、何とかしとくれよ――さうでないと、新吉さんの顔はまるつぶれぢやないか」　おはまは娘を掻き口説いた。",
              "citation": {
                "source": "一の酉",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "警視庁の無能が、新聞の論説となり、投書の機関銃となり、総監をはじめ各部長の面目はまるつぶれだった。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一座の面目まるつぶれじキないか。",
              "citation": {
                "source": "退歩主義者",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の男の子の面目まるつぶれというモンモンたる心事になやんだのはムリがない。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "消え失せた沙漠――大島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの時、いやにお世辞がよく、たんと御馳走をしてくれたのはいいけれど、そのもてなしの最中に、伯父のやつこんなことを言いやがった――実はナ鈴川、昨年わしの知行が水かぶりで二百石まるつぶれになってしまった。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "内々は、伊賀の連中ということがわかっていますから、林念寺前の柳生の上屋敷へ、そっと照会があったんですが、そんな、いっぽん腕の浪人者に斬り殺されるような者が、一人ならず、ふたり、三人、剣が生命の同藩から出たとあっては、柳生一刀流の面目まるつぶれですから、高大之進が応対して、さようなものは存ぜぬ。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
