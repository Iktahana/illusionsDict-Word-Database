    "definitions": [
      {
        "index": 1,
        "gloss": "makimono",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "例へば安宅の関で弁慶が勧進帳とて読み上げる巻物の正体を、覗かれかゝると笑ふ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "室津の宿屋の主人はかなりのお婆さんであったが、われわれ二人の中学生の初旅を珍しがって大変にもてなしてくれた上に「珍しいものを見せて上げよう」と云って持出して来たのが一巻の絵巻物であった。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この鯨の絵巻物はおそらく昔の御鯨方に伝わった最貴重な伝書のようなものではなかったかと思う。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大和大峰いりのほら貝は聞えないが、町から野、野から山へと、秋草をわたり、落葉松の枯木をからんで、涼しくなる鈴の音は、往さ来さの白衣の菅笠や金剛杖に伴って、いかに富士登山を、絵巻物に仕立てることであろうか。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「年賀はがきの宛名を一つ一つ書いてゆく間に、自分の過去の歴史がまるで絵巻物のように眼前に展べられる。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一巻の絵巻物が出て来たのを繙いて見て行く。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻物の中にはところどころに真黒な墨で塗りつぶしたところがある。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議な事には巻物の初めの方に朽ち残った絵の色彩は眼のさめるほど美しく保存されているのに、後の方になるほど絵の具の色は溷濁して、次第に鈍い灰色を帯びている。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵巻物の最後にある絵はよほど奇妙なものである。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は十六七の頃にはもう濃く礬水をひいた薄美濃紙を宛てがって絵巻物の断片を謄き写しすることも出来たし、残存の兜の錣を、比較を間違えず写生することも出来た。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い絵巻物のあるものを見ていたらその絵の内容とその排列に今のレビューと実によく似たものがあることに気が付いた。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その世界では現在あるような活字で印刷した書物の代りに映画のフィルムのようなものが出来ていて、書庫の棚にはその巻物がぎっしり詰っている。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説でも歴史の本でも皆そういう巻物になっていて、それを机上の器械にはめてボタンを押すとその内容が器械のスクリーンの上に映写されて出て来るというのである。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その重々しさは四条派の絵などには到底見られないところで、却って無名の古い画家の縁起絵巻物などに瞥見するところである。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後日再び奥州から大軍の将として上洛する途上この宿に立寄り懇ろに母の霊を祭る、という物語を絵巻物十二巻に仕立てたものである。",
              "citation": {
                "source": "山中常盤双紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵巻物というものは現代の映画の先祖と見ることが出来る。",
              "citation": {
                "source": "山中常盤双紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵巻物の色々な場面の排列、モンタージュまた一つの場面の推移をはこぶコマ数の按配、テンポの緩急といったようなものに対する画家の計画には、ちょうど映画監督、編輯者のそれと同様な頭脳のはたらきを必要とすることがわかる。",
              "citation": {
                "source": "山中常盤双紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうことから考えてみると、この絵巻物は、一方では勧善懲悪の教訓を含んでいると同時に、また一方ではおそらく昔の戦乱時代の武将などに共通であったろうと思われる嗜虐的なアブノーマル・サイコロジーに対する適当な刺戟として役立ったものであろうと想像される。",
              "citation": {
                "source": "山中常盤双紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにつけて想い出されるのは、仏教や耶蘇教の宗教画の中にも、この絵巻物の中に現われているような不思議な嗜虐性要素のしばしば現われることである。",
              "citation": {
                "source": "山中常盤双紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四面に海をめぐらす大八州国に数千年住み着いた民族の遠い祖先からの数限りもない海の幸いと海の禍いとの記憶でいろどられた無始無終の絵巻物である。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてかの有名な高山寺蔵の絵巻物の画面を思い起こしながら、「絵巻物と活動時代」という一つの論題に思い及んだ。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵巻物というものの最初のイデーはおそらく舶来のものかもしれないが、ともかくこれはかなりに偉大なイデーである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵巻物では、一つの場面から次の場面への推移は観覧者の頭脳の中で各自のファンタジーにしたがって進転して行く。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻物に描かれた雲や波や風景や花鳥は、その背景となり、モンタージュとなり、雰囲気となり、そうしてきたるべき次の場面への予感を醸成する。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うに絵巻物と、その後裔であるところの活動映画も言わばやはり一種の「時の器械」である。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし心の世界の過去と未来はいろいろな絵巻物の紙面に自由に展開されているからおもしろい。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "富田渓仙の巻物にはいいところがあるが少し奇を弄したところと色彩の子供らしさとが目についた。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる科学の書物は百鬼夜行絵巻物である。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際科学の巻物には始めはあっても終わりはないはずである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子芋の煮たてはうまきものなり。",
              "citation": {
                "source": "明治卅三年十月十五日記事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            }
          ]
        }
