        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "黄色の待宵草が、夏の夜の道端でひっそりと花を開き始めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「竹久夢二の詩にも出てくる待宵草は、どこか寂しげな美しさがあるよね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夕暮れ時に散歩をしていると、甘い香りを漂わせる待宵草の群生に出会った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "朝旱割れそめにし稲沼に、　　いまころころと水鳴りて、待宵草に置く露も、　　　　睡たき風に萎むなり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "fragrant evening primrose (Oenothera stricta)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
