    "uuid": "11b49497-26f5-5eff-94d8-60275dee7219",
    "entry": "マトリックス",
    "reading": {
      "primary": "マトリックス",
      "alternatives": [
        "マトリクス"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
