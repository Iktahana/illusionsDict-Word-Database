    },
    "definitions": [
      {
        "index": 1,
        "gloss": "erasure",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "早瀬は潔く云々以下、二十一行抹消。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も大衆文学に限らず、近代の小説は、多かれ少なかれ、商業的価値を眼中において書かれる場合が多く、凡ての小説が大衆文学化しつゝあることは事実であるが、このことは、大衆文学の特質を抹消するものではなく、却つて、大衆文学の勝利、従つて、文学作品の商品化を意味するのである。",
              "citation": {
                "source": "商品としての近代小説",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、「芸術的価値」は社会的価値であるといふ、わかりきつた説を繰り返すことに忙しい「一元論者」たちは、この明々白々たる事実を無視し、現実にある芸術的価値を頭の中でのみ抹消して、私の「二元論」を撃破し得たと称するのである。",
              "citation": {
                "source": "諸家の芸術価値理論の批判",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ色々な都合で固有名詞だけは、抹消したり、変改したりしたが、事実そのものには一点一画も私は修正を加えなかった。",
              "citation": {
                "source": "私はかうして死んだ！",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "森幹事が福引を披露して、『――そのわけは、娘々が大騒ぎ』のところで原稿の文章を切ることにして、そのあとの『というのであるが』以下『センセイショナルなものを……』までを削除しなければいかん」　と、梅野十伍は苦笑しながら、十行ばかりのところを、墨くろぐろと抹消した。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月の末から三月の中旬頃まで、寒波との闘争につかれて（抹消）衰弱し、胃を害していたが、この頃は眼に見えて恢復して来た。",
              "citation": {
                "source": "獄中通信",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "（抹消）――嵐子の学校の様子色々知らせて欲しい。",
              "citation": {
                "source": "獄中通信",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "（抹消）嵐子の学校の様子を細かく知らせること。",
              "citation": {
                "source": "獄中通信",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば彼の屍体は完全に抹消されたことになります。",
              "citation": {
                "source": "人間灰",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "君のお宅にも、多分、死んだ農奴でまだ戸籍簿から抹消ってないのが相当あるでしょう？",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして物の美事に人間世界から神様を抹消した『物を考える脳髄』は、引続いて人間を大自然界に反逆させた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの利得金で堪能するためには、まず船場四郎太を戸籍から抹消する必要がある。",
              "citation": {
                "source": "地虫",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隨つてもう今日では作者名などは抹消されてもいゝほどにあの校歌は早稻田學園のものになつてゐると私は思つてゐる。",
              "citation": {
                "source": "校歌「都の西北」と私",
                "author": "相馬御風",
                "note": "青空文庫"
              }
            },
            {
              "text": "その「詩集」の部分は赤インキで抹消し、その備考欄には、同じ赤インクで、次のように記されてあった。",
              "citation": {
                "source": "仙人掌の花",
                "author": "山本禾太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "抹消登記の方は、僕がしてあげます。",
              "citation": {
                "source": "白い朝",
                "author": "――「正夫の童話」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（数字抹消）事ハ決マリタリ。",
              "citation": {
                "source": "断層顔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここのところに抹消されたる文字があるが、これはどう読むんだろう」「抹消、すなわち読まなくていい文字だ」「だってこれを読まないと文章が舌足らずだぜ」「文芸作品じゃないからそれでもよかろう」「記録文学の名手が、ここでだけ手をぬくのは変だね。",
              "citation": {
                "source": "断層顔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨猿の姿も、魚精のかげも幽黝の底に抹消された。",
              "citation": {
                "source": "岩魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、すべてはまだ終ったのではなくて、あいつの、過去の憶い出をほとんど抹消する目をみはるような罪を、まだまだ犯すにちがいない、ということを、ぼんやり感じていた。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は、アイルランドで起った場面を憶い出さないようにできるだけ抹消しようとし、そのことにはいっさい触れず、私にも私の不運のことについては何も語らなかった。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに一時栄えた昭和の軍人政府は日蓮宗の経文の或辞句をさえ抹消させながら、世に山家集と七部集の存することを忘れて問わなかった。",
              "citation": {
                "source": "冬日の窓",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて飯田武郷氏の日本紀通釈の如きもこれに従い、ハセツカベと訓めるは甚だしき誤りなりと喝破せられてハシヒトの訓を取り、新版国史大系本の日本紀の如きに至っては、おそらく平安朝以来の傍訓（少くも釈日本紀以来の傍訓）たるべきハセツカベを抹消して、無条件にハシヒトと改めているのである。",
              "citation": {
                "source": "間人考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔欄外「原本廿三日より廿九日迄記事なし」トアリ、朱線ヲ引キ胡粉デ抹消〕九月三十日。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之一大正六年丁巳九月起筆",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔欄外「原本十月一日及二日欠記事」トアリ、朱線ヲ引キ胡粉デ抹消〕十月三日。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之一大正六年丁巳九月起筆",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔欄外「原本五日より七日まで記事を欠く」トアリ、朱線ヲ引キ胡粉デ抹消〕十月八日。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之一大正六年丁巳九月起筆",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに一時栄えた昭和の軍人政府は日蓮宗の経文の或辞句をさへ抹消させながら、世に山家集と七部集の存することを忘れて問はなかつた。",
              "citation": {
                "source": "冬日の窓",
                "author": "永井壮吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、真理をあざむく教誨師の前にあるいは、懐中時計を用意する（二行抹消）無情極まる監獄医の前に（一行抹消）ああ……やさしいやさしい海の浪音！",
              "citation": {
                "source": "再生の日の海を眺めて",
                "author": "――その日牢舎を出でたる一革命家の歌える",
                "note": "青空文庫"
              }
            },
            {
              "text": "新憲法のおかげで、あらゆる前科が戸籍から抹消されたということを、あさひは知らなかったのである。",
              "citation": {
                "source": "虹の橋",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなら、お尋ねしますが、あの斬られた娘の両親の中でも、あの父親は腹からの町人で御座いまっしょう」「ヘエヘエ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソコにはソコがありまっしょうがなあ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
