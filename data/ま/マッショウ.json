[
  {
    "uuid": "b2d6566d-7794-50c5-9bfe-e33994a51cc5",
    "entry": "抹消",
    "reading": {
      "primary": "まっしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
