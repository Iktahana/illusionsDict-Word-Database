        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "矢車草、車百合、ドウダンなどが、栂や白樺の、疎らな木立の下に、もやもやと茂っている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の登った北米のフッド火山は、大なる氷河が幾筋となく山頂から流れているにもかかわらず、麓の高原は乾き切って、砂埃とゴロタ石の間に栽培した柑橘類の樹木が、疎らに立っているばかり。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎坊附近の、黄紅朱樺の疎らな短木の中を、霧は幾筋にもなって、組んず、ほぐれつして、その尖端が愛鷹山の方向へと流れて行く、振り返れば、箱根｜火山彙には、雲が低く垂れて、乙女峠から金時山の腰へかけて、大河の逆流するばかり、山と山との間は、幾つにも朝雲が屯ろして、支流が虚空の方々に出来る。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "西風が強いかして、傾斜の土に疎ら生えしている、丈の短い唐松や、富士薊が、東に向いて俯向きに手を突いている。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正年間の大噴火に押し出した泥流を被らなかったと思われる部分の山腹は一面にレモン黄色と温かい黒土色との複雑なニュアンスをもって彩られた草原に白く曝された枯木の幹が疎らに点在している。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の通りは疎らになった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "左翼の疎らな森のはずれには、栗本の属している一隊が進んでいた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな通りを外れて街燈の疎らな路へ出る。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "圧しつけるような暗い建築の陰影、裸の並樹、疎らな街燈の透視図。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前の日光のなかで静かに影を畳んでいた公孫樹は、一日が経たないうちにもう凩が枝を疎らにしていた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何をしに自分は来たのだ」　街へ出ると吹き通る空っ風がもう人足を疎らにしていた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "バ……妖怪が……」　まだ薄暗い方丈の、朝露に濡れた沓脱石まで転けつまろびつ走って来た一人の老婆が、疎らな歯をパクパクと噛み合わせて喘いだ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この真直なる路の急に左に折るるところに立ち木やや疎らなる林あり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時またもや時雨疎らに降り来たりぬ。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "土橋を斜に烏森、と町もおどろ／＼しく、やがて新橋驛へ着いて、づぶ／＼と其の濡幌を疊んで出で、※と明く成つた處は、暴風雨の船に燈明臺、人影黒く、すた／＼と疎らに往來ふ。",
              "citation": {
                "source": "大阪まで",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「額広く鼻は高く、きれの長い末上りのきつい目、朶の無いような耳、おとがい細く一体に面長で、上髭薄く、下鬚疎らに、身のたけはすらりと高い方で。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏手は極疎らな垣根で小川に接して居る許りであるが、そこには欅、樫、櫻、無花果などの樹がこんもりと繁つて居り、低い葡萄棚の下が鷄の小屋になつて、始終鷄の聲がしてゐる。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場の構内と街道へ續く廣い空地との間には疎らな黒塗の柵があつて、その根本のところにちよろちよろと青草が出てゐるが、肥料が足りないと見えて元氣がない。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その緩い坂はほんの十五六歩ほどの長さしかありませんが、左右に疎らな草木に挟まれて、登って行くこの径からは世界のどこを歩いて行くのかすっかり周囲の地理的関係を忘れさしてしまうような感じをさす不思議な影響がありました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "でワルトンは不審そうに黙ってアイリスと同じように、晩春の午後の陽射しを受けて淋しく燻し銀色に輝く白樺の幹や、疎らな白樺の陰影に斜めに荒い縞目をつけられて地味に映えて居る緑の芝生を眺めて居た。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "心なき林の木木も相｜凭りて枝こそ交せ、年毎に落ちて死ぬなる木の葉さへ、朝風吹けば、朝さやぎ、夕風吹けば、夕語りするなるものを、人の世は疎らの林、人の世は人なき砂漠。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "見上げると、疎らな裸木の枝の間から星が鮮かに光っている。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達の眼の下は五十坪ほどの空地で、その周囲にはずっと疎らな林が続いている。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄汚ない長い顔には、白く乾いた脣のまわりに疎らな無精髭がしょぼしょぼ生えて、それが間の抜けた表情を与えてはいるが、しかし、又、其の、間の迫った眉のあたりには、何かしら油断の出来ない感じをさせるものがあるようだ。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「退け退けッ」　疎らになった群衆の背後から、今出たばかりの旭がキラキラと映し込んで来た。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は既に明け放れて山霧全く霽れ、雨足も亦｜疎らになった。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "栢の老木が疎らな林をなしているのが見えた。",
              "citation": {
                "source": "太虚司法伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ二つと夢中に噛んで、ひよつと上を見るといつか疎らになつた林の眞上いつぱいに例の妙義の岩山が眞黒い樣に聳え立つてゐるのが見えた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "桃の實",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて樹立が疎らになって、右左両方へ梢が展くと、山の根が迫って来た。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供等は疎らな枯蘆の邊からおりて其處にも目掘りを試みる。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
