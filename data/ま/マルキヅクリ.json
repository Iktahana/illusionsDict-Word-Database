        "examples": {
          "standard": [
            {
              "text": "森の中に建てられた丸木造りのコテージは、木の香りがしてとても落ち着く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その公園の休憩所は丸木造りになっており、周囲の自然景観に溶け込んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "丸木造りの伝統的な工法を守り続ける職人の技を、後世に伝えたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "二つ三つ薄暗い林を拔けて、すこしそこいらが明るくなつたところに、更らに何處までも續いてゐさうに思へる落葉松林を背負ひながら、一つの丸木造りのコツテエヂが認められた。",
              "citation": {
                "source": "生者と死者",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "古びたロシア風の丸木造りで小さい家の下には誰も住んでいず、二階に、三十をいくつか出ている年ごろのオリガが石油コンロ一つ、ブリキのやかん一つという世帯道具で暮していた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
