        "examples": {
          "standard": [
            {
              "text": "候補者は選挙前に、具体的な政策を盛り込んだマニフェストを発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の掲げるマニフェストは、若者からの大きな支持を集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "前回の選挙で掲げたマニフェストが、どれだけ達成されたか検証する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "で、そのマニフェスト（？",
              "citation": {
                "source": "プルウスト雜記",
                "author": "神西清に",
                "note": "青空文庫"
              }
            },
            {
              "text": "シュルレアリズムというのは、前大戦後にとびだした畸型児であるが、文学の方ではアンドレ・ブルトンなどが旗持ちで、彼はシュルレアリズムのマニフェスト（宣言）というものを書いている。",
              "citation": {
                "source": "安吾巷談",
                "author": "教祖展覧会",
                "note": "青空文庫"
              }
            },
            {
              "text": "このマニフェストというのはコケオドシの実にツマラヌものであった。",
              "citation": {
                "source": "安吾巷談",
                "author": "教祖展覧会",
                "note": "青空文庫"
              }
            },
            {
              "text": "マニフェストの著者が「国家としての国家」と云ったのは無論イデー的乃至無的な菩薩国のことでなくて、イギリスやフランスやドイツのことだった。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
