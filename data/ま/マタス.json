    "definitions": [
      {
        "index": 1,
        "gloss": "to keep (a person) waiting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "君が妾を待たすなんてけしからんなあ！",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "日歩は払ふと金主に約束して金主をも待たすことにした。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "六日待たすとはしびれを切らしおった。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴公も、年頃の娘をあまり待たすのは罪じゃないか。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "次ぎの間で待たすのが、よつぽど失禮ぢや。",
              "citation": {
                "source": "ごりがん",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "三八六三）前略下恋に何時かも来むと待たすらむ情左夫之苦下略　（巻十七。",
              "citation": {
                "source": "『さびし』の伝統",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "四〇七四）前略何時しかも使の来むと待たすらむ心｜左夫之苦南風ふき下略　（巻十八。",
              "citation": {
                "source": "『さびし』の伝統",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を待たすことに一向｜頓着しないのも有名なる学士の習慣だった。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも全く何の意味もなく待たす也。",
              "citation": {
                "source": "雪今昔物語",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほつと見送る、安心の、刹那を破る大欠伸『いつまで己れを待たすんだ。",
              "citation": {
                "source": "したゆく水",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり待たすのはへんだ。",
              "citation": {
                "source": "軍国歌謡集",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "人心が少しでも明るくなり、景気が活気づいて来た時には、音楽の調子がすぐ明朗になつてくるし、その反対の場合には、音楽がまたすぐ憂鬱になつてくる。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君の方は子供の帽子を気にして直しているが、子供はまたすぐに阿弥陀にしゃくり上げる。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このやうな魔物は、最も憎むべきものであり、かつまたすみやかに退治しなければならぬものである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またすぐ眼の下のまちまでがやっぱりぼんやりしたたくさんの星の集りか一つの大きなけむりかのやうに見えるやうに思ひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもほんのちょっとの間、川と汽車との間は、すすきの列でさへぎられ、白鳥の島は、二度ばかり、うしろの方に見えましたが、ぢきもうずうっと遠く小さく、絵のやうになってしまひ、またすゝきがざわざわ鳴って、たうたうすっかり見えなくなってしまひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合には第一にこれらの分布を知り、またすべての弱点に対する歪みの限界値を知り、同時にすべての弱点における歪みの刻々の現状を知るを要す。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また理論家か実験家かと聞かれれば、そのおのおのであり、またすべてであったと答える外はない。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このようにして人夫等が大勢かかって、やっとそれが出来上がったと思う間もなく式が終って、またすぐに取りくずさなければならないであろう。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでまたすつかり感激し、「おお兄弟」と呼んで握手をする。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィンクは今の声がまたすれば好いと思って待っている。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、その存在をたしかめると、安心したやうにまたすぐ穴の所へ飛び降りて來た。",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "親爺は、一度味をしめると、それをいいことにして、またすゞを内地へ帰らした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと向うを見たら何か黒いものが波から抜け出て小さな弧を描いてまた波へはいったのでどうしたのかと思ってみていたらまたすぐ近くにも出た。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉吉は朝いつもの時刻に眼をさましてから寝そべったまま煙草を二、三｜服ふかしてまたすうすう眠ってしまった。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またすぐ眼の下のまちまでがやっぱりぼんやりしたたくさんの星の集りか一つの大きなけむりかのように見えるように思いました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもほんのちょっとの間、川と汽車との間は、すすきの列でさえぎられ、白鳥の島は、二度ばかり、うしろの方に見えましたが、じきもうずうっと遠く小さく、絵のようになってしまい、またすすきがざわざわ鳴って、とうとうすっかり見えなくなってしまいました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "楢夫は目をつぶったまゝ一寸顔をしかめましたがまたすうすう息をしてねむりました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとどよめきに沸き返りまたすーっと収まってゆく場内の推移が、なにか一つの長い音楽のなかで起ることのように私の心に写りはじめた。",
              "citation": {
                "source": "器楽的幻覚",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾たびとなく人びとがわっわっとなってはまたすーっとなっていったことが何を意味していたのか夢のようだった。",
              "citation": {
                "source": "器楽的幻覚",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
