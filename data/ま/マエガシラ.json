    "definitions": [
      {
        "index": 1,
        "gloss": "rank-and-file wrestlers in the highest division",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "小浅間への登りは思いのほか楽ではあったが、それでも中腹までひといきに登ったら呼吸が苦しくなり、妙に下腹が引きつって、おまけに前頭部が時々ずきずき痛むような気がしたので、しばらく道ばたに腰をおろして休息した。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "助手は根元で無造作に結へてある元結を切つて、兩耳の後ろと旋毛の邊にかけて前頭部と後頭部の髮を二束に分けた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "顏の上には前頭部の髮の毛がもつれあつて物凄く被ひかぶさつてゐる。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根は低いのに揺れると来て、この前頭痛で懲々したから、今度は歩行くつもりで、今朝小田原からたって来たが、陽気は暖かだし、海端の景色は可し、結句｜暢気で可い心持だ。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "艶やかに兀げた前頭からは光りが走った。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "グスタフソン警視は會釋しながら、「二人とも前頭部を割られとるやうだね。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "メンコには、それぞれお角力さんの絵が画かれていて、東の横綱から前頭まで、また西の横綱から前頭まで、東西五枚ずつ、合計十枚、ある筈なんだが、一枚たりない。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……天麸羅のあとで、ヒレの大切れのすき焼は、なかなか、幕下でも、前頭でも、番附か逸話に名の出るほどの人物でなくてはあしらい兼ねる。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "横頬から特に前頭部へかけて黒い斑の長生※が群着していた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "『貴殿の前頭の発達は、予の期待以下ではある。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二図イに示す通り、以前頭巾の頂後を短く突出したが、追々それがロのごとく長い尾となって垂れ下りついに地に触るるに及んだ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "相撲の番付にしたら、りっぱな幕の内もまず前頭五枚めあたりよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦痛の色は彼れの厳粛な前頭部を一層淋しく変化せしめた。",
              "citation": {
                "source": "アリア人の孤独",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ、進や、お前頭悪くしたんでないかッて云ったら、お母アの方ば見もしないで、窓の方ば見たり、自分の爪ば見たりして、ニヤ／＼と笑うんだ……。",
              "citation": {
                "source": "母たち",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "金庫のそばには、五十四五位に見える、痩形の、顔面骨の尖った、前頭部の禿あがった男が、両手をしばられ、猿轡をはめられて倒れていました。",
              "citation": {
                "source": "祭の夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "死因に関しては前頭部の後方の打撲傷による内出血説と咽喉部を強くしめつけられたための窒息致死説との二つの説にわかれ、どちらが先に行われたかわからないということになり、多分、何者かが、彼の脳天にしたたか打撃を加えたあとで、すぐに咽喉をしめつけたものであろうということになった。",
              "citation": {
                "source": "鉄の規律",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "主筆は、體格の立派な、口髭の嚴しい、何處へ出しても敗をとらぬ風采の、四十年輩の男で、年より早く前頭の見事に禿げ上つてるのは、女の話にかけると甘くなる性な事を語つて居た。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "主筆は、体格の立派な、口髯の厳しい、何処へ出しても敗をとらぬ風采の、四十年輩の男で、年より早く前頭の見事に禿げ上つてるのは、女の話にかけると甘くなる性な事を語つて居た。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "横綱や大関は別として、三役や前頭のいいところに坐るには、何も格別｜画が上手でなくともいい、発行人に幾らか出版費の足し前を出すとか、それとも絵の二三｜幅も寄附すればいいので、さうした訳合でかなりの地位に据わつてゐる雛つ児画家も少くはない。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついてはこゝいらに――」番附屋は扇子の尻で前頭の中軸どこを指ざした。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "（12）　此等の記録によると、蒙古人は前頭と左右兩側頭に髮を留めて、他は皆剃り去つたものと見える。",
              "citation": {
                "source": "支那人辮髮の歴史",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "前頭に留めた髮は、今日の南支那の婦人の前髮の如く、その儘に垂下し、兩側頭に留めた髮は、之を辮み綰げて、幾分わが古代の耳鬘の如くして、その餘端を垂下したのである。",
              "citation": {
                "source": "支那人辮髮の歴史",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "『竹崎季長蒙古襲來繪詞』を見ても、國中の蒙古人は皆二個の辮髮――不思議に何れも前頭の留髮はないが――を垂れて居る。",
              "citation": {
                "source": "支那人辮髮の歴史",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "前頭には一束の髮を殘して、その餘は剃り捨てる。",
              "citation": {
                "source": "支那人辮髮の歴史",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "創傷は、顱頂骨と前頭骨の縫合部に孔けられている、円い鏨型の刺傷であって、それが非常なお凸であるために、頭顱の略々円芯に当っていた。",
              "citation": {
                "source": "後光殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "松本順造はもう六十の年配だが、身体は頑丈で、印刷物を読む時以外は老眼鏡を用いず、浅黒い顔と禿げ上った前頭部とに重々しい貫祿がある。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなりつんのめつて前頭部を強打した。",
              "citation": {
                "source": "天才になりそこなつた男の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "前頭なんてえものも、引退すると、こんなものかね。",
              "citation": {
                "source": "ニューフェイス",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "和漢朗詠集に載つた白楽天の、『前頭には更に蕭条たるものあり』といふ句と、定家の、『見わたせば花も紅葉もなかりけり』や、西行の、『心なき身にもあはれは知られけり』と、相通ずるやうなものである。",
              "citation": {
                "source": "『さびし』の伝統",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
