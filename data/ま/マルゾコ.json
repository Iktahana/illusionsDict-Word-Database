        "examples": {
          "standard": [
            {
              "text": "「理科の実験で、加熱効率を上げるために丸底フラスコを使用した」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この中華鍋は丸底になっているから、強い火力で一気に炒めるのに適している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "丸底のバッグは荷物を入れると安定しないが、見た目が柔らかい印象になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "クックの伝説からは、何だか峨々たる高山のような感じを受けるが、ほんとうは、丸底の盆を伏せたような、だらだらの山である。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にもいったように、マウナ・ロアは、丸底の盆をふせたようななだらかな傾斜の山である。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
