        "examples": {
          "standard": [
            {
              "text": "プロジェクトを成功させるためには、適切なリスクマネジメントが不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼のチームは、優れたマネジメント能力によって常に高い成果を出している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "企業研修では、若手社員向けにマネジメントの基礎を学ぶ機会が提供される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "〈ザ・ヒルビリー・キャット〉と愛称をつけられたエルヴィス・プレスリーは、ボブ・ニールのマネジメントのもとに、カントリー・アンド・ウエスタンのショウに加わり、巡業公演に出た。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "無料コンサートのマネジメントはまったく無責任だったが、三〇万人もの人々があつまった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽の面では小川が大きく手助けをし、ライブ・ハウスへの出演をとりきめるなどのマネジメントには、レコード会社のディレクターがあたっている。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
