        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「なーんだ、オマンコか」　と、ワラがしゃがみこんで笑った。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "従者ノ泥路ニ苦シマンコトヲ慮リ天ノ曙トナルヲ待ツテ発ス。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベイ・アンド・ブック印のナイト・デクスター氏にキャムレット百二十、キャムレット端切れ詰合せ百、青ダッフル二十、シャルーン百、キャリマンコ五十、シェンソイとハムハム各三百。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の神は人類の堕落状態を憐れんで、これに共同態の結成や文化的な生活の術を教えしめるため、その子マンコ・カパクとママ・オェロ・ワコとの兄妹を地上に送った。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "マンコ・カパクは農業を教え、ママ・オェロは紡織の術を教えた。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "このマンコ・カパクが初代のインカで、その後代々慈悲の伝統を守り、温和な支配を続けて、インカ帝国の大をなした。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような権力を有するインカの位は、マンコ・カパク以来王統一系を以て伝えられたと云われている。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "マンコ・カパク以来の男系の子孫は悉くインカと呼ばれた。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならずアタワルパは、当の相手のワスカルを、またその弟のマンコ・カパクをも、殺しはしなかった。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその直後に、正統の王位継承者たるワスカルの弟マンコが現われ、王位を要求すると共にスペイン人の保護を求めた。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて彼は、正当のインカたるべきマンコ・カパクを携えて、一五三三年十一月十五日、首府クスコに入城したのであった。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "マンコはピサロの手によって戴冠されインカの位に即いた。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "その原因の一つは、遠征隊の留守中にインカ・マンコが独立を計ったことである。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "でマンコの軍を撃退しつつクスコに迫って、ピサロの弟ゴンサロ及びエルナンドに町の明渡しを要求した。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃になって知ったのは、ウシンコッコ、ウンマンコッコ　薩摩チンチノコマ　　　　　　　　　駿河｜駿東郡ベコノツノツキ　　　　　　　　羽後秋田郡などです。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野草雑記",
                "note": "青空文庫"
              }
            }
          ]
        }
