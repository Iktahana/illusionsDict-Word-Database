    "definitions": [
      {
        "index": 1,
        "gloss": "sword for self-defense",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "守り刀ようの姫君の物、若い母親への多くの贈り物等が乳母に託されたのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "守り刀、天児などを持って少将は車に乗った。",
              "citation": {
                "source": "源氏物語",
                "author": "薄雲",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは、お前のお母様が家へ来るときに持って来た守り刀なのだ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは、お前のお母様が家へ来るときに持つて来た守り刀なのだ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "七瀬の手は、いつの間にか、守り刀の袋へかかっていた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、血まみれの守り刀を、投げ捨てたかったけれど、指が、柄に食いついてしまってはなれない。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちの方の二品は、こりゃ錦の袋入りの守り刀と来ている、もう一つはズッシリとしたこの重味、この二つとも、殿様からの御拝領なんだろう、まだ結び目も解かず、封も切らずにあるやつが、手つかずこっちへ授かったというのも返す返す有難え話だ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に刀の小柄を突き刺して、それに錦の袋に入れた守り刀様のものがぶらさげてありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは裲襠も守り刀も、共に見覚えのある品でありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "駒井甚三郎は再びこの不快な一種の曝し物に眼を注ぐことはなかったけれど、ほどなくその裲襠と守り刀の袋とは、何者かの手によって取外されて、どこへか隠されてしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅の守り刀は綿更紗の袋で鍔元を包んで、それを腰にさした。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お咲殿、そなたも守り刀で！",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご奉公ももうこれまで、私は自害なと致します」　帯に挟んだ守り刀を鳰鳥は手早く取り出した。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "合爾合姫　（独語）この札荅蘭族へ輿入れする時、父の瑣児肝失喇から渡されたこの守り刀が、こんな役に立とうとは思わなかった。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "清盛は枕もとから銀の蛭巻をした小長刀を離さず、常に寝所に守り刀として置いていたが、ある夜急に消えた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第五巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃丸屋の嫁が里に歸され、染五郎と逢引の合圖を交してゐるのを見て、惡賢い左陣は、女下駄で足跡まで拵へて罪をお絹に轉嫁しましたが、川に捨ててあつたお絹の守り刀については、不思議なことに何んにも知らなかつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "紅い扱帶",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところで、この守り刀の鞘は何處にあつたのかな、――少し泥が附いて居る樣だが」　平次は、血染の短刀と並べてある、螺鈿入りの鞘を取り上げました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死骸の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "その隙を狙つて扉を開けた上、花嫁の懷中から守り刀を奪ひ取つて胸へ二度も突き立てるなんて器用な事は出來さうもないぜ」「へーツ」　八五郎も少し困りました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死骸の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　芝口の路地――花嫁の駕籠を入れたといふあたりを搜し當てた平次と八五郎は、提灯を振り照らして念入りに調べて見ましたが、血潮の跡は愚か、守り刀の鞘についた、淡赤い泥に似寄りのものもありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死骸の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "提灯を貸せ」　平次はそれに構はず、庭へ降りて四方を見廻して居りましたが、やがて、駕籠を据ゑた跡らしいものを撒水の濕りの上に見出すと、其邊の土などを念入りに調べた末、「――この泥だよ、八、守り刀の鞘に附いて居たのは。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死骸の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "「仲人の伊賀屋さんが、守り刀を見付けたといふのは、此箪笥の上でせうな」　平次は主人の秋山佐仲に訊ねました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死骸の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "花嫁のお喜美はそれをお茶らかして笑つたに違ひない――男はカツとして、駕籠の中で手にさはつた女の守り刀を引拔き――夢中になつてその胸を刺したが、ハツと氣が付くと、自分のやつた罪の恐しさに、血染の短刀を持つたまゝ家の中に飛び込み、面喰つて箪笥の上に置いたことだらう」「――」「お前はそれを見た。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死骸の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それに、萬一の場合は、伜の罪を引受けるつもりで、死骸の膝の上にあつた守り刀の短刀を拔いて、力任せに死骸の胸に突き立てた」　平次は靜かに言ひきつたのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死骸の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "お玉が縁側でチラと見たといふ人影がお鐵だつた」「へエ」「短刀は町人の物、お玉の持つて來た守り刀だつたらう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "持參千兩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃丸屋の嫁が里に帰され、染五郎と逢引の合図を交しているのを見て、悪賢い左陣は、女下駄で足跡までこしらえて罪をお絹に転嫁しましたが、川に捨ててあったお絹の守り刀については、不思議なことに何にも知らなかったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "紅い扱帯",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところで、この守り刀の鞘は何処にあったのかな、――少し泥が付いている様だが」　平次は、血染の短刀と並べてある、螺鈿入りの鞘を取り上げました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死骸の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "その隙を狙って扉を開けた上、花嫁の懐中から守り刀を奪い取って胸へ二度も突き立てるなんて器用な事は出来そうもないぜ」「ヘーッ」　八五郎も少し困りました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死骸の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　芝口の路地――花嫁の駕籠を入れたというあたりを捜し当てた平次と八五郎は、提灯を振り照らして念入りに調べて見ましたが、血潮の跡は愚か、守り刀の鞘についた、淡赤い泥に似寄りのものもありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死骸の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "提灯を貸せ」　平次はそれに構わず、庭へ降りて四方を見廻して居りましたが、やがて、駕籠を据えた跡らしいものを撒水の湿りの上に見出すと、その辺の土などを念入りに調べた末、「――この泥だよ、八、守り刀の鞘に付いていたのは。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死骸の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "「仲人の伊賀屋さんが、守り刀を見付けたというのは、この箪笥の上でしょうな」　平次は主人の秋山佐仲に訊ねました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死骸の花嫁",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
