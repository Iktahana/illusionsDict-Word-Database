    "definitions": [
      {
        "index": 1,
        "gloss": "visit (to a religious site, e.g. shrine, temple, grave)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「お差支へなければ、ぢや、お宅へ参りませう」とあんな奴が促した。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろしいの時、大久保に参ります。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『外に参りよき物見る。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『この痛み、もう大きの、参りますならば、多分私は死にましょう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えてみると、僕たちだって、小さい時からお婆さんに連れられてお寺参りをしたり、またお葬式や法要の度毎に坊さんのお経を聞き、また国宝の仏像を見て歩いたりしているが、さて、仏教とはどんな宗教かと外国の人に改って聞かれたら、百人の中の九十九人は、へどもどするに違いないのだ。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅行の目的は、もしも運がよかったら鯨を捕る光景が見られるというのと、もう一つは、自分の先祖のうちに一人室戸岬の東寺の住職になった人があるのでその墓参りをして来るようにという父からの命をうけていたことである。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時一人の家来があはたゞしく王の前に参り「たゞ今二人の蘭人がこれに見えて、王に戦勝の祝の品を持つて来たと申して居ます。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸子へ参りました」　なるほど障子に名物とろろ汁、と書いてある。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小松技師は帰りしなに、少し改って「実はお願いがあって参りましたのですが」　と言って、暫く黙っていたが、主人が気さくな顔をして応けているのを見て安心して言った。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夕方、とうとう、鷹がよだかのうちへやって参りました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　よだかは泣きながら自分のお家へ帰って参りました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「私は、今｜事務所から、こちらで働らけと云われてやって参りました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔はあ、では一寸行って参ります。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっから来たろうって云ったら風で飛ばされて参りましたでしょうて云やいいや。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の朝は夜があけたら直ぐ市川へ参ります」　母はなお詞を次いで、「なるほど何もかもこうなる運命かも知らねど今度という今度私はよくよく後悔しました。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやくと、「民さんのお墓に参りにきました」　切なる様は目に余ったと見え、四人とも口がきけなくなってしまった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子のためには真に千僧の供養にまさるあなたの香花、どうぞ政夫さん、よオくお参りをして下さい……今日は民子も定めて草葉の蔭で嬉しかろう……なあ此人にせめて一度でも、目をねむらない民子に……まアせめて一度でも逢わせてやりたかった……」　三人は眼をこすっている様子。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は当分毎日お墓へ参ります……」　話しては泣き泣いては話し、甲一語乙一語いくら泣いても果てしがない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かような事実を知っておくことが、古典研究の上にどんな効果を齎らすかということを、もう時間が参りましたけれども、少しばかり述べてみたいと思います。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "協会の諸兄によろしく（八月十五日）　それから書き忘れましたが何か本を一冊（何か僕に「やッたらどうや」とお考えになるものがありましたら結構ですが……）　これだけ書くのに便所へ油汗かきに行く事二回、これから第三回目に参ります。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "児分、襖の外から、　「親分、石松兄哥が帰って参りました」　「そうか、帰ったか」　と次郎長、紺久に、　「帰って来ました」　「じゃ、次郎長どん、儂はお暇しよう。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処へ行きます」　「俺の代りに金毘羅様へお礼参りに行って来て貰い度え」　「へえ、承知致しました……？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "清水から手紙を言付かって参りました」　「お父っつあん、清水から手紙ですって」　「なに、清水から手紙」　「きっと兄さんからよ」　旅人、手紙を渡して、　「確かにお渡し致します。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪枝が嬉しそうに「父上様Ｔ「よい事　聞いて参りました」　嘉助が「何だ？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "）いつでも参りますわ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは花と柑子とを持って参りますよ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "海軍記念日は、ことしも、また、そろそろやってまいります。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が暮れかけて来たころ、私はやっと立ちあがって、死んだように、ぼんやりなってお寺へ帰ってまいりました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、大隅さんから、是非、という御返事がまいりました。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大隅君から、こんな電報がまいりましてね、」私は、いまは、もう、なんでもぶちまけて相談するより他は無いと思った。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
