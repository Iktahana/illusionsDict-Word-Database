    "definitions": [
      {
        "index": 1,
        "gloss": "to take seriously",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "誇るに西洋料理七皿をもってする、式のごとき若様であるから、冷評せば真に受ける、打棄って置けば悄げる、はぐらかしても乗出す。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来ても、それを一から十迄｜真に受ける訳には行かない。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に、時世時勢とでもいふのか、何ひとつ真に受けるといふことが無くなつた！",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな事を真に受けるものは、中学生の中にもゐないでせう。",
              "citation": {
                "source": "売文問答",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし人の好い読者の中に、一人でもああ云う小説を真に受ける男女があって御覧なさい。",
              "citation": {
                "source": "或恋愛小説",
                "author": "――或は「恋愛は至上なり」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男の云う事を真に受けるな、何を云っても嘘と思え、――おれはそんな意味を伝えたいと思った。",
              "citation": {
                "source": "藪の中",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが真に受ける奴は一人も無い。",
              "citation": {
                "source": "橋の下",
                "author": "フレデリック・ブウテ　Frederic Boutet",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな嘘を真に受けるとは、……　使　しかし誰でも真に受けますよ。",
              "citation": {
                "source": "二人小町",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来ても、それを一から十まで真に受ける訳には行かない。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "お豊、母さんの言ってる事ア皆うそだぜ、真に受けるなよ」　「おほほほ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お豊、母さんの言ってる事ア皆うそだぜ、真に受けるなよ」「おほほほ。",
              "citation": {
                "source": "小説　不如帰",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑談を真に受ける奴があるものか。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑談を真に受ける奴が、あるものか。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しじゅう、何かしら、大きな商売などをもくろんでいたりなどしまして、それをまた、不思議に、人さまが真に受けるのでございます。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小さい嘆美者には、お延のいうすべてを何でも真に受ける癖があった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の挨拶に相当の割引をして見る彼も、そこにはつい気がつかなかったため、彼は自分の前でする夫人のお延評を真に受けると同時に、自分の耳に聴こえるお延の夫人評もまた疑がわなかった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや時々｜冗談を言うと人が真に受けるので大に滑稽的美感を挑撥するのは面白い。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり人の云う事を真に受けると馬鹿を見るぜ。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し太宰が佐藤春夫は悪人なり、とか、山岸外史は低能児なりとか書いてあつたと仮定したら或はそれを真に受ける人も無いとは限るまい。",
              "citation": {
                "source": "井伏鱒二は悪人なるの説",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし井伏鱒二は悪人なりと放言して置いても井伏鱒二は良心の苛責を受ける筈もなく、また好漢井伏鱒二を知る程の人間で太宰の宣言を真に受ける愚人も居ないのを知つて太宰は安心し、また井伏に最後の甘えつぷりを見せてずばりと井伏鱒二は悪人なりと断言して行つた。",
              "citation": {
                "source": "井伏鱒二は悪人なるの説",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなおとぎ話を真に受けるのは昔のギリシャ人と現代の赤ん坊だけだよ！",
              "citation": {
                "source": "夕映えのむこうの国",
                "author": "時代を超えた童話",
                "note": "青空文庫"
              }
            },
            {
              "text": "言ったとしても、三元が真に受けるものか」「そら、言ったんだろ。",
              "citation": {
                "source": "黄色い日日",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにもそれを真に受けるには及びません。",
              "citation": {
                "source": "鰐",
                "author": "ドストエウスキー　Fyodor Mikhailovich Dostoevski",
                "note": "青空文庫"
              }
            },
            {
              "text": "「土台、わしが死んだと誰がそんなばかげたことをいうたかしらんが、それをまた真に受けるお母さんもお母さんじゃ」　そんなこというたって現在お前の嫁のきみ子が、お前の骨壷を抱いて戻ってきて、私の膝に泣きくずれた。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の恭しい言葉づかいも彼のかしこまった礼節も、彼はそれをわしに拒むことができないのだと思うと、どうしてそれを真に受けることができようか。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "個人的にそれが好きだから、という説を多くの人がいまも受けとめたままでいるが、監督自身の言葉を真に受けるとするなら、女上位の場面は彼の確固たる映画的な主義主張にもとづいたものだった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼ら自らが動かしている物がどうして動くのかも知らなければ、彼ら自ら把握し操作する機械を我々の前に分析叙述することもできないではないか）、どうして彼らのナイル河の干満の原因に関する所論などを真に受ける気になれようか。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十男の非常に聡明な彼が、あの様な子供だましの脅迫状を真に受けるというのは、何か滑稽な感じがしたけれど、彼にしてはあんなものでも、真面目に怖がるだけの充分の理由があったことに相違ない。",
              "citation": {
                "source": "孤島の鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな年端もゆかぬ子供の愛をまにうける者がどこにあるでしょう！",
              "citation": {
                "source": "寡婦",
                "author": "モオパッサン",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度お訪ねしたいなどと、亭主持の女にいはれて、それをまにうける私も愚かであつたが、正直のところ、不在中、もしかしてやつて来はせぬかと禁足された気持だつた。",
              "citation": {
                "source": "老残",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
