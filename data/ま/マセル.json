[
  {
    "uuid": "ff57d783-378b-5910-ae71-bf6f11f614a6",
    "entry": "老成る",
    "reading": {
      "primary": "ませる",
      "alternatives": [
        "マセる"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
