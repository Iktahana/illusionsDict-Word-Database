      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be precocious",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あまりに自我の強い芸術は、無意識、つまり法悦的境地を欠くから、感覚の性質が如何によくとも、人をジツクリと楽ませることが出来ない。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、私としては、良心を澄ませる、即ち謙虚な気持を修熟させることが第一だと思ひ、従つて、当分発表するものは、旧作であるから、それがつまらないからといつて、如上の考へをも愚であるとされたくない。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして意識はどつちみち人を悲しませるものです。",
              "citation": {
                "source": "小林秀雄小論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大事なしかもかなり六かしい事柄の核心を平明にはっきり呑込ませる術を心得ているようであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "単になるべく沢山の鳥を殺して猟嚢を膨らませるという目的ならとにかく、獲物と相対してそれに肉薄する緊張が加速度的に増大しつつ最後に頂点に到達するまでの「三昧」の時間に相当の長さのあることだけから見てもこれは決してそれほどつまらないものではないだろうと思われる。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "憤ると頬つぺたを膨らませるんでね。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前だつて憤ると頬つぺたを膨らせやしないかい」「とつても膨らませるんだよ。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "理科の教科書ならばとにかく多少でも文学的な作品を児童に読ませるのに、それほど分析的に煩雑な註解を加えるのは却って児童のために不利益ではないかと思うというようなことを書き送ったような気がする。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでもおあがりなさい」　鉢を差し出してやると、娘は嬉しそうに食べ、水を掬って来て飲ませると、娘はやっと元気を恢復した様子、そこで娘の身元ばなしが始まりました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでダンサーに身の上話をさせることによって悪漢騎手の旧情夫の存在を観客に呑込ませる。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうすれば、言葉と白墨の線とによって、大きさや角度や三角函数などの概念を注ぎ込むよりも遥かに早く確実に、おまけに面白くこれらの数学的関係を呑み込ませる事が出来る。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "光の反射屈折に関する基礎法則を本当によく呑込ませることに全力を集注し、そうしてそれを解説するに最適切な二、三の実例を身にしみるように理解させれば、その余の複雑な光学器械などは、興味さえあらば手近な本や雑誌を見てひとりで分かることである。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人に読ませるための創作意識の最も稀薄な俳句において比較的自然な心持が反映しているのであろう。",
              "citation": {
                "source": "夏目先生の俳句と漢詩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "オゾンを作るには交番電流を特別な変圧器に通じ、この器内に生じた瓦斯を給水管中に吸い込ませるようにしてある。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎のあぜみちに坐つてゐると、おほなみのやうな土壌の重みが、わたしの心をくらくする、土壌のくさつたにほひが私の皮膚をくろずませる、冬枯れのさびしい自然が私の生活をくるしくする。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "物を喰べさせるのも、薬を飲ませるのもみんなわたしの手でするのでしょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま私の中にあるものを越えて私を進ませるほど充分に強い本なんぞが一體あるでせうか？",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きていてしじゅう喰べものの好き嫌いをし、人をも自分をも悩ませるよりその方がましではあるまいか――　子供は、平気を装って家のものと同じ食事をした。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒竜江にはところどころ結氷を破って、底から上ってくる河水を溜め、荷馬車を引く、咽頭が乾いた馬に水をのませるのを商売とする支那人が現れた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人は一回、銅片一文を取って馬に水を飲ませるのだ。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は笑ってすませるような競争者がなかった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」七　少佐は、松木にとって、笑ってすませる競争者ではなかった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "富蔵は一旦気絶したが、川春の店の者が見つけて内へ連れ込んで、水や薬を飲ませると、すぐに息をふき返して、何事もなく済んでしまったのです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦場だからな」「鰻でも取りますか」「それがよかろう」　鰻の蒲焼を註文して、二人は早い夕飯を済ませると、七月の日もかたむいて来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "植民地へよこされては、ブルジョアをます／＼富ませるために命がけで働いてやっているんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故、役員は、死者を重傷者にして病院へかつぎこませる。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "封筒の表書をすませると、彼はそんな國、そんな町が一體存在したのかどうかも疑はしかつた。",
              "citation": {
                "source": "川端康成第四短篇集「心中」を主題とせるヴァリエイシヨン",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこまでも指を滑り込ませる温かい腹の柔毛――今一方の奴はそれを揃えた後肢で踏んづけているのである。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものを教えますと覚えますのにさぞ骨が折れて切のうござんしょう、体を苦しませるだけだと存じて何にもさせないで置きますから、だんだん、手を動かす働も、ものをいうことも忘れました。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦い薬を飲ませるには杯の縁に蜜を塗らなければならない、と言っている。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
