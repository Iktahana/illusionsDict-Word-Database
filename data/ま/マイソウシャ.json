        "examples": {
          "standard": [
            {
              "text": "この古い納骨堂に眠る埋葬者たちの名前を刻んだ石碑は、長い年月を経て風化している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "教会に隣接する墓地には、歴代の司祭たちが埋葬者として名を連ねている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "埋葬者の身元を確認するため、保存状態の良い衣類や所持品の調査が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "会社にてあらかじめ地面を買い入れ、その一部分を埋葬者に売り渡すなり。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "各瞬間は酷薄な埋葬者となる。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
