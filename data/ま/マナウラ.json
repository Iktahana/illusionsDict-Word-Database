        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "故郷の風景は、今でも私の眼裏に鮮やかに焼き付いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の優しい笑顔が、別れた後もずっと眼裏から離れない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "苦労した若き日の記憶が、ふとした瞬間に眼裏に蘇ることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "凝重穎鋭の二句、老先生｜眼裏の好学生を写し出し来って神有り。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに、「眼裏塵あれば三界は窄く、心頭無事なれば一｜床寛なり」　です。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
