        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「フーン、ツマンナイネ、ア、シロイ　ハツパガ　トンデ　ユク」「アレハ　ハツパヂヤ　ナイコト、テフテフヨ。",
              "citation": {
                "source": "デンデンムシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "イツモハ　ナカヨシダツタノデスケレド、アンマリ　マンナカノ　ホシガ　サムイ　サムイト　イフノデ　ホカノ　二ツノ　ホシニ　イジメラレタノデシタ。",
              "citation": {
                "source": "ナガレボシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "スルト　トツゼン　マンナカノ　ホシガ、ダマツテ　ツート、下ノ　ハウヘ　スベツテ　イツテ　シマヒマシタ。",
              "citation": {
                "source": "ナガレボシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダ　ヒノ　デナイ　ウチカラ　ヲトコハ　ハタケノ　マンナカノ　ヲカノ　上ニ　ノボツテ、ラツパヲ　フクノデ　アリマシタ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "タレノ　カゲ新美南吉　マチノ　マンナカニ　ヒロツパガ　アリマシタ。",
              "citation": {
                "source": "タレノ　カゲ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒロツパノ　マンナカニ　マルイ　カゲガ　ヒトツ　オチテ　ヰマシタ。",
              "citation": {
                "source": "タレノ　カゲ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケレド　ヒロツパノ　マンナカノ　カゲハ　ウゴキマセンデシタ。",
              "citation": {
                "source": "タレノ　カゲ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "トコロガ　ユウガタニ　ナツテ、タイヤウガ　オチテ　シマフト　ヒロツパノ　マンナカノ　マルイ　カゲハ　ナクナツテ　シマヒマシタ。",
              "citation": {
                "source": "タレノ　カゲ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウミ　ノ　マンナカ　ニ、オオキナ　イワ　ガ　アリマシタ。",
              "citation": {
                "source": "山のコドモ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十銭白銅貨なんて、そんなツマンナイ物品ではないのである。",
              "citation": {
                "source": "白銅貨の効用",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "故郷が恋しい、母サンやお祖母サンガ居ナイカラ僕ツマンナイヤ、とは、幼い藤村の手紙に決して率直に書かれなかったであろう。",
              "citation": {
                "source": "藤村の文学にうつる自然",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "カルチュアやマンナーや骨肉の姑息な愛（私は父母を愛するのに何の自信もありません）は第二義以下のことです。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "天からマンナが降るのを待ってるみてえだ。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "餌は牛乳、茶、スープ、キセリ、マンナヤ・カーシャ、やき林檎とオレンジの汁、その他は自身の皮下脂肪。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔イスラエルの民がアラビアの曠野にて食せるものにて（出エヂプト、一六・一三以下）こゝにては神の恩惠を指す【曠野】マンナに因みて淨火を指せり。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "高かりし者、醫學に關する著作多し〔世の爲〕世に屬する利慾のため〔まことのマンナ〕キリストのまことの教へ。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "マンナについては淨、一一・一三―五註參照八五―八七〔葡萄の園〕寺院。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "神恩を忘れ恒心なく神及び導者に背けるため屡※神怒りに觸れしこと聖書に見ゆ（申命、三二・一八等）〔マンナ〕アラビアの曠野にて食へる（出エジプト、一六・一三以下）〔導者〕モーゼ一三三―一三五〔アンナ〕聖母マリアの母堂アンナ。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "三つ並べるのじゃなくて、マンナカへ一つ、両端へ各々一つずつ、離せるだけ離しておいてある。",
              "citation": {
                "source": "将棋の鬼",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のハゲは脳天、マンナカから薄く徐々に円形をひろげるという見た目にカンバシカラヌ最下級品であるけれども、本人の目には見えないという強味がある。",
              "citation": {
                "source": "無毛談",
                "author": "――横山泰三にさゝぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "下町のお江戸のマンナカに生れて育ったチャキ／＼なんだ。",
              "citation": {
                "source": "ニューフェイス",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノハラノ　マンナカデ　カゲヲ　ミタラ、二ツトモ　チイサナ　チイサナ　カゲデシタ。",
              "citation": {
                "source": "こいぬ　の　ちびすけ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この郡のマンナカあたりの村から塙保己一が生れている。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日、芝山内の山門の前、道のマンナカに大石が一ツころがっていた。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにモモと足クビの包みの方はマンナカのスネに当る部分がなく、二の腕とテノヒラの包みの方もマンナカのヒジから手クビの部分がぬけてるな。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二十　トンビ男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに三度目の包みからそうだったが、楠がオヤと思って、ここに何かがあるかと思ったバラバラ包みのマゼ方、左右対照、マンナカの脱落、それは今やハッキリと彼の早合点で、ナンセンスな軽率にすぎなかった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二十　トンビ男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそもこの事件にあなたが深入りした発端は、最初の二ツの包みをあなたが拾ったインネンですが、またそのインネンを裏づけたものは、第一と第二の包みの中味が右と左の部分のマゼ合わせが同じくて、またマンナカの部分が欠けているのが対照的でそこに何かがあるんじゃないかと思われたせいですね。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二十　トンビ男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三ツ目の包みから、左右のマゼ合わせもなく、またマンナカの欠けてる一致も存在してやしなかったからです。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二十　トンビ男",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右対照とマンナカの欠けてる一致という点についてだけは、たしかに早合点で、軽率でした。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二十　トンビ男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
