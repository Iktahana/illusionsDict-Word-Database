    "definitions": [
      {
        "index": 1,
        "gloss": "to pass through town",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "月光の下、ひとり深夜の裏町を通る人は、だれしも皆こうした詩情に浸るであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ位隔てなくした間柄だに、恋ということ覚えてからは、市川の町を通るすら恥かしくなったのである。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、町を通る人達の一人一人が自分の友達ででもあるやうに感じられた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "固より口実、狐が化けた飛脚でのうて、今時町を通るものか。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（清正公樣の前だよ……煎豆屋の角、唐物屋の所……水天宮樣の横通………）　と所々で、――釣臺に附いてくれました主人が聲を掛けて教へますのを、あゝ、冥途へ行く路も、矢張り、近所だけは知つた町を通るのかと思ひました。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前年その長屋の表町に道普請があって、向側へ砂利を装上げたから、この町を通る腕車荷車は不残路地口の際を曳いて通ることがあった。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし唐土長安のハイカラ、新しい買たての靴で、キユツ／＼などとやり、嬉しさうに、爪先を見て、ニヤ／＼と町を通る。",
              "citation": {
                "source": "人參",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬へば惚れ合つた男女二人が話をしながら横町を通る時でも、晴天の時と、雨天の時とは、話の調子が餘程違ひますからね。",
              "citation": {
                "source": "小説に用ふる天然",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「宇田川町を通ると、影や道陸神の子供達があたしの影を踏んで……。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　弓子は先斗町を通るのははじめてだったが、路地の中ですれちがった芸者をつかまえて、「桔梗家ってどこでしょう……？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひっそりとした寺がいくつも並んだ寺町を通る時、ぱっと暗闇に強い木の香がひらめいた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、ふたりの手をにぎって、いつかふたりの町を通ることがあったら、きっとたずねていくよ、と約束しました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、同じ月、同じ夜の其の命日は、月が晴れても、附近の町は、宵から戸を閉ぢるさうです、眞白な十七｜人が縱横に町を通るからだと言ひます――後で此を聞きました。",
              "citation": {
                "source": "雪靈續記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、同じ月、同じ夜のその命日は、月が晴れても、附近の町は、宵から戸を閉じるそうです、真白な十七人が縦横に町を通るからだと言います――後でこれを聞きました。",
              "citation": {
                "source": "雪霊続記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひっそりとした寺がいくつも並んだ寺町を通るとき、木犀の匂いがした。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月末の残暑の強い日に、かれは今日もてくてくあるきで、汗をふきながら、下谷御徒町の或る横町を通ると、狭い路地の入口に「この奥にかし家」という札がななめに貼ってあるのを見付けた。",
              "citation": {
                "source": "月の夜がたり",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひっそりとした寺がいくつも並んだ寺町を通るとき、木犀の匂いが光った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ふたりの手をとって、もしふたりのすんでいる町を通ることがあったら、きっとたずねようと、やくそくしました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "休日の前日が来て、小菅の内へ帰る度に通新町を通る。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "予もかつて、ある妖狐を畜って富を致す評ある人が町を通ると、生まれて数月なる犬児が吠え付き、その袖や裾に噛み付いて息まず、それを見いた飼主が気の毒がってその犬児を棄てた始終を黙って見届けた事がある。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その往復毎日北元町を通るんで、つい、職業柄、お仕事の容子を覗いて見たような訳なんで……」　光明氏はちゃんと何もかも知っている。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "石川光明氏と心安くなったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でも場末のさびしい薄暗い町を通ると、ときどきに昔なつかしい子供の花火をみることもある。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんでも二、三日まえ、あいつが御成道の横町を通ると、どこかの古道具屋らしい奴と紙屑屋とが往来で立ち話をしている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "化け銀杏",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼は店先に坐つて町を通る人達に、自慢の髯を見せつけるのを何よりの道楽とし、夜になると髯の夢ばかり見てゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Ｐのおじさん、株屋殺しの真犯人は、今夜十一時半頃Ｙ町を通るはずです」「え、どうしてそれが分かった。",
              "citation": {
                "source": "現場の写真",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々、内儀さんは櫛巻にした病人らしい頭をすこし擡げて、種々雑多な物音、町を通る人の話声、遠い電車の響までも聞いた。",
              "citation": {
                "source": "死の床",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "お島は町を通るごとに目についていた、通りの飲食店や、町がさびれてから、どこも達磨をおくようになったと云う旅籠屋などに、働きに入ろうかとさえ思ってみることもあったが、それらのお客が皆な近在の百姓や、繭買などの小商人であることを想ってみるだけでも、身顫が出るほど厭であった。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "町を通るごとに、どれもこれも相当に行き立っているらしい大きい小いそれらの店が、お島の腕をむずむずさせた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
