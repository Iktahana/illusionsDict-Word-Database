[
  {
    "uuid": "bfeac616-6880-57e5-93f1-8cd1edbdb109",
    "entry": "町を通る",
    "reading": {
      "primary": "まちをとおる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
