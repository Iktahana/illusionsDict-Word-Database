        "examples": {
          "standard": [
            {
              "text": "休暇を利用して、カリブ海に浮かぶ美しい島、マルティニークを訪れることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "マルティニークの市場では、色鮮やかなスパイスや新鮮な南国のフルーツが売られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その小説の舞台は、フランス文化とカリブの伝統が混ざり合うマルティニークだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "場所では、マルティニークと松江、美保の関、日御崎、それから焼津、食物や嗜好品ではビステキとプラムプーデン、と煙草。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水夫たちは皆、マルティニーク、シント・ユースタティウス、ハヴァナ、ポート・ロイヤルからやってきた混血の破落戸どもだった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "新人二十人をインドより、スペイン人をマルティニークより、オランダ人二人をスリナムより積載。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
