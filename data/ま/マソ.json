    "definitions": [
      {
        "index": 1,
        "gloss": "Mazu (Chinese goddess of the sea)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "また、最も多数の崇信を得ておるのは媽祖と名づくる女神である。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "○同市媽祖廟正門の壁の浮彫　ここのは皆いい。",
              "citation": {
                "source": "台湾の民藝について",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○宜蘭について　宜蘭の媽祖廟の神棹はこんど見たもののうちで最もいいものの一つだ。",
              "citation": {
                "source": "台湾の民藝について",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "或いは媽祖の信仰が後に入ってきて、影響を与えているかとも想像せられぬことはないが、ともかくも一年一度の祭の日を境に、定まった方角の風が吹き出すということは、この島限りでの経験であり、それが海上の旅に利用せられるのは、新たに採用した慣行とは言うことができない。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "村外れの茶店で昼飯を食った時に店先で一人の汚い乞食婆さんが、うどんの上に唐辛子の粉を真赤になるほど振りかけたのを、立ちながらうまそうに食っていた姿が非常に鮮明に記録されている。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の暑い盛りだと下帯一つの丸裸で晩酌の膳の前にあぐらをかいて、渋団扇で蚊を追いながら実にうまそうに杯をなめては子供等を相手にして色々の話をするのが楽しみであったらしい。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを享樂しつゝ、しばらくつぶつてゐた眼を開くと、門内の前庭に焔を洗つたやうなカンナの花瓣が思ふさまその幅廣の舌を吐いてゐた。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓向うの壁がかぶりつきたいほどうまそうな狐色に見えた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはいまその電燈を通り越す。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう風に、『古事記』には清濁を書き分けてあるけれども、たまたまそうでないものもあるように見えることもある。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその一端を指でつまんで高く空中に吊り下げた真下へ仰向いた自身の口をもって行って、見る間にぺろぺろと喰ってしまって、そうしてさもうまそうに舌鼓をつづけ打った。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたまそういう環境を恵まれた人にはまた存外そういう研究に熱心な人が稀である。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして味方のすべてのものは、いまその旗が、ずつと彼等の前方にあるのを見た。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "スパリスパリといかにもうまそうである。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はともかくこの巣を来年の夏までこのままそっとしておこうと思っている。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがわれわれの眼にはさもさもうまそうに飲んでいるように見えた。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "露天店の、たった一箇二銭か三銭の山梨を、うまそうに頬張らして貰うしおらしい奴もあった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹三郎は、如何にも、うまそうに、むさぼり吸った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士たちの、うまそうな、嬉しげな様子を見ると、とうとう深山軍曹も手を出した。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　山仕事から帰った父母は、うまそうに芋を食っていた。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "京一は、芋粥ばかりを食い、他の家族は、麦飯に少しの芋粥を掛けてうまそうに食った。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたまその子口あきて、　　楊の梢に見とるれば、元信斎は歯軋りて、　　　　　石を発止と投げつくる。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かん子もあんまり面白いので四郎のうしろにかくれたままそっと歌いました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのままその俯向いた拍子に筋が抜けたらしい、横に流れようとするのを、婦人は優しゅう扶け起して、（おお、よくしたねえ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此室が宜かろうという蔵海の言のままその室の前に立っていると、蔵海は其処だけ雨戸を繰った。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "別にうまそうでもないが、しかしまたあわてて吐き出すのでもなく、平然ときわめてあたりまえなような様子をしてすましているのであった。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "郷里の家の長屋に重兵衛さんという老人がいて、毎晩｜晩酌の肴に近所の子供らを膳の向かいにすわらせて、生のにんにくをぼりぼりかじりながらうまそうに熱い杯をなめては数限りもない化け物の話をして聞かせた。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一方ではまた、自分の田舎では人間の食うものと思われていない蝗の佃煮をうまそうに食っている江戸っ子の児童もあって、これにもまたちがった意味での驚異の目を見張ったのであった。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが実にさもうまそうに、ひと口しゃくっては首をゆすり上げ、舌鼓を打って味わっているように見えるのである。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのままそつとドアをしめて、廊下にしばらく立ちつくした。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
