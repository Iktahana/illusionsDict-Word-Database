    "definitions": [
      {
        "index": 1,
        "gloss": "leaving everything up to someone else",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は妻の為す通りに任せている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その料理屋には、神前挙式場も設備せられてある由で、とにかく、そのほうの交渉はいっさい小坂氏にお任せする事にした。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いつたい此の会社の社長といふ男は、会社としての収入のみを考慮の中に入れたが、俳優其の他の傭入や解雇は、全然竹山俳優監督係に任せ切りだつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "換言すれば著者は、すべての藝術的意圖と藝術的野心を廢棄し、單に「心のまま」に、自然の感動に任せて書いたのである。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな太鼓や鐘があぜ道にすえられて赤裸の人形が力に任せてそれをたたく。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "想像するがままに任せた山、感情を塗りかえした山、その山の暗き森と、深い谷、過去へと深く行き、遠く行くだけ、紀念は次第に成熟する、石の上を走っている水の面の経緯は、幾世の人の夢を描いては消し、消しては描いているのである。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂上内院火口の西壁、剣ヶ峰の側からなぎ落されて、直線に突き切ること三里、力任せにたち割った絶壁の斜面に、墜石崩石は、ざっくばらんにほうりだされている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "善重氏は、文墨のたしなみがあり、菅原白竜山人のかけ幅や、板垣退助伯が清人霞錦如の絵に題字せられた幅物などを愛蔵せられて、私たちの見るに任せられた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでそのままに自然に任せておけばどうなるだろう。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして滅亡するか復興するかはただその時の偶然の運命に任せるということにする外はないという棄て鉢の哲学も可能である。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "健忘症の政治家や気まぐれな学界元老などの手に任せておくにはあまりに大切な仕事である。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "偉れて立優っているこの女神に対しこの流れの方向の感情に心を任せるとき、却って気持は自然に近いことを老翁は発見した。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々はしかし文部省あたりの調査や審議に任せて安心しているわけにはゆかない。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会民衆の恣意に任せて安堵しているのも間違っている。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に云った第一の方法、すなわち心理過程の追究を読者に任せる方法でも、その読者を導いて普遍的な心理的経験を遂行させる事が必要であるが、その作に価値を与えるためにはその経験が単に普遍であるのみならず、それが読者にとってなんらかの意味で新しいものであり、また更に新しい問題を提供するものでなければならない。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "只予の性質として人の子とあるものが只自己一身の功業にのみ腐心するは不都合である、両親を見送っての後ならば、如何なることを為すとも自己の一身は自己の随意に任せてよいが、父母猶存する間は父母と自分との関係を忘れてはならぬ。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "相続後の家政は大概、書記や執事や代言人に任せてあって、彼自身は大審院の役をつとめるだけであった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "タムソンの仕事ぶりを見ていたレーリーは、“Thomson rather ran away with it.”と云って一切をこの若者の手に任せてしまった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそういう人間が、全く気任せに自由に「そこはかとなく」「あやしう」「ものぐるほしく」矛盾も撞着も頓着しないで書いているところに、この随筆集の価値があるであろう。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "※かの女は窓に凭れたまま、何もかも任せ切つたやうな氣もちで、うつとりと、心を張りつめて、夢中で何時間も過すのだ。",
              "citation": {
                "source": "窓",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "その明りの處を右に折れてまた大通へ出ると、Ｍホテルなのであつたが、人通さへないその道へ足に任せて何氣なく飛び込んで、私は思はず水を浴せられたやうにぞつとした。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その度毎に明｜暗、悲喜こもごも至る二人の顏附たるやお察しに任せる次第だ。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも第二｜次奉直戰爭の時などは自分の方の旗色がよかつたせゐもあつただらうが、戰線のことは部下任せにして置いて、宮苑の奧深くお氣に入りの嬪妾や嬖臣達を相手に日もす夜もす麻雀に耽り樂しんでゐたと言ふ。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来作者は自分自身の中に居る「坊ちゃん」「赤シャツ」「のだ」「狸」「山あらし」を気任せに取出して紙面の舞台で踊らせ歌わせる。",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御屋敷方の内輪のことに、わたくしどもが首を突つ込んぢやあ惡うございますが、いつそこれはわたくしにお任せ下さいませんか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "喬はその醜い女とこの女とを思い比べながら、耳は女のお喋りに任せていた。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら危険を感じていても、滑るに任せ止まるに任せる外はなかったのだった。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃からいつとなく感得したものとみえて、仔細あって、あの白痴に身を任せて山に籠ってからは神変不思議、年を経るに従うて神通自在じゃ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち意欲すべきものといふより、おのづと出来るにまかせるべきものといふことである。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ或る時は僅かな経済学的知識を持出してその裏付けとなし、或る時は自分の感傷にまかせてダダを捏ねるのである。",
              "citation": {
                "source": "非文学的文士",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
