          "literary": [
            {
              "text": "酒井家の主人は気の利いた男だと見えて、円盆に勝栗を盛つて主人の前へ差し出した。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上手紙を読み終ったのと煙草の灰を落したのとは同時でないのだから、二つの間にはさまるぼんやりしたただの時間を認めなければならなかった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
