    "definitions": [
      {
        "index": 1,
        "gloss": "to (an extent)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれども新聞を見る迄もなく、ある本能の異常な直覺が、變事の疑ひ得ないことを斷定させた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "序で乍ら、詩程ではない迄も、小説だとて、まだ一般的にハツキリと位置してはゐない。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "人に対して平静、順応的にしてアクティヴに非ざる限り、我等が民族の文学は何時迄も反復に終るであらう。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして詩の芽生えが、子供の心意する夢の世界と、その幻想的なフエアリイランドに苗づいてることは言ふ迄もない。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "後々迄も影響し、僕の文學的體質を構成するほど、眞に身に沁みて讀んだ本は、ポオとニイチェと、それからドストイェフスキイの三つであつた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（言ふ迄もなく、それは調和ある反映である。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は何處迄も御人好の御坊ちやまの、泣き出し相に、なさけない顏でおろおろして居るまだるつこさ、芳公の啖呵も折角、響が來ないので、聊か之も張合なさの悄氣た體。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ちのびた私たちも、留守の両君も、現在の失業者のなめるのと、同じ悩みを味つたのはいふ迄も無い。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "淺間のが此邊迄も降つたとは思はれない。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其爲に階上階下の部屋といふ部屋は一杯で廊下の籐椅子に迄もはみ出してゐる。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場の燻ぶつた車庫や、ペンキのはげかゝつたタンクや轉轍臺のやうなもの迄も、小春の日光と空氣の魔術にかゝつて名状の出來ない美しい色の配合を見せて居た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯を食ひながら女中の話を聞くと、先達つて何とかいふ博士が此の公園を見に來て、此れは大變にいゝ處だから此の形勝を保存しなければいけないといふ事になり、更に裏手の丘迄も公園の地域を擴張する事になつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何時迄も其處を離れないで見て居るのであつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつきの子供はいつ迄も其處いらを離れずにぶら／＼して居た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして我大東京はだらしなく無設計に横に擴がつて、美しい武藏野を何處迄もと蠶食して行くのである。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の市街が何處迄も／＼續いて居るのにいつもながら驚かされた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "液體力學を持出す迄もなく、かういふ處へ家を建てるのは考へものである。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯れてまでどこ迄もデリカを失わない木の葉のなかへ、スマートな男女｜散策の人形を置いたりしている。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは因縁こそ実に尊くそれを飽迄も大切にすべきものだと信じて居ります。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前も、何時迄もこんな汚ねえ家の二階を借りて居ねえで……」　親爺、睨む。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「実は俺を次郎長親分の身内に加えて貰えねえだろうか」　「お前が……親分の身内になりてえって……」　「俺も、おッ母ァが居なくなって、誰にも遠慮も要らねえし、何時迄もこんな田舎でくすぶってるのは厭だから……やくざになって一生を楽しく暮そうと決心したンだ」　「七五郎、其奴ァよくねえ考えだ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "言われる迄もなく三次の目的はお絹にあるのである。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達でやる筈になつてゐた試演會は校長の禁止で、公演の前日に迄もなつてゐて、それを思ひ切らなければならない破目になつたのである。",
              "citation": {
                "source": "『青空』のことなど",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめてもう一、二年生きていようと思ったのですが、妻は夫と共にどこ迄も歩みとうございますもの。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "堂の書附には故将堂とあり、大さ纔に二間四方許の小堂なり、本尊だに右の如くなれば、此小堂の破損はいふ迄もなし、やう／＼に縁にあがり見るに、内に仏とてもなく、唯婦人の甲胄して長刀を持ちたる木像二つを安置せり。",
              "citation": {
                "source": "甲冑堂",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれ軍人は、あく迄も抗戦をつづけ、最後には皆ひとり残らず自決して、以て大君におわびを申し上げる。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "達二はどこ迄も夢中で追ひかけました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿体ない話じゃ」「断るまでもないがその代りに、お取調の模様は言う迄もない、今日お目付へお眼にかかった事までも、事件が片付かぬうちに他所へ洩らいたなら、アンタの首がないけになあ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れの妹が道ならぬ戀の爲めに死なんとした事や、弟に夫婦約束をした女のある事や、其の他其の友達の上に起つた事迄も大膽に打開いて物語つた。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ程はっきり批判はつかぬ迄も只そんなけはいを感じてか彼女の母からも、みなあなたのお蔭、私よりも厚くお礼を申します。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
