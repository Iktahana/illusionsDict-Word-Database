          "literary": [
            {
              "text": "「まあいいからついておいでなさい。",
              "citation": {
                "source": "さるのこしかけ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあいいから坐ってろ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "沢本　　まあいいから、貴様の計画というものの報告を早くしろ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊代さん、まあいいから、その封筒はそちらへ引込めて下さい。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれらは死んでもあなたのことは忘れませんよ」「そんなことはまあいいから、飲もうじゃないか？",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした天気は決して音楽に適しませんのですもの」「まあいいから御殿へ行って、ただ一声でいいからお弾かせしてくれ。",
              "citation": {
                "source": "源氏物語",
                "author": "末摘花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあいいから、これから気をおつけなさいね」　とだけお言いになって、あとはほかへ話を移しておしまいになった。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ知らない女なんだから、すこぶる躊躇したにはしたが、断然断る勇気も出なかったので、まあいいかげんな生返事をしていた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあいいから一杯｜手繰って行きねえ」　辞退するお鉄を無理に誘って、半七は熱い蕎麦を二杯たのむと、蕎麦屋は六助といって、下谷から神田の方へも毎晩まわって来る男であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、「それもまあいいか」と妙に納得させられる、他に代えようのない不思議さと美しさとが、この作品にはあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾がヤングに欺されているように思うのはソレアあんたの嫉妬よ……まあいいから黙ってお酒を飲みながら聞いていらっしゃい。",
              "citation": {
                "source": "支那米の袋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあいいかげんに辞書を引いては、頁をはぐっていっただけであるが、ともかくそれが僕にとっては、最初に親しんだ仏蘭西小説だった。",
              "citation": {
                "source": "仏蘭西文学と僕",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあいいから、私のすることを見ていなさい」と甚兵衛は答えました。",
              "citation": {
                "source": "人形使い",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあいいから、早く持って来い！",
              "citation": {
                "source": "北国の人",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寿　　そいつはなあ……まあいいか。",
              "citation": {
                "source": "沢氏の二人娘",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　――まあいいから、あの真珠を出してごらん。",
              "citation": {
                "source": "真珠の首飾り",
                "author": "ZHEMCHUZHNOE OZHERELJE",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　――まあいいから、見てごらん。",
              "citation": {
                "source": "真珠の首飾り",
                "author": "ZHEMCHUZHNOE OZHERELJE",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあいいから持ってくさ」　実際問題として『いくらでもかまわねえ』というのはまことに相手にしにくい。",
              "citation": {
                "source": "食べもの",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "『まあいいから、わたしにすっかりその話をしてごらん、そうすれば、わたしが君の力になって上げられるかも知れない。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まあいいからこっちへ来いったら。",
              "citation": {
                "source": "微笑",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあまあいいから帰りたまえ」　たくましい手をグイと延ばし、私の腕をひっ掴んだ。",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いそがしいなら、またあとで」「まあいいから、そこへおかけ」　あたしは掛けながらでたらめをいった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあいいから落ちつきなよ。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあいいからいらっしゃいてえのに」とぐいぐい引っ張る。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "留吉　まあいいから！",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旅館のことをきいているんですが」と云うと、「こんなところに旅館なんてあるもんか」「この辺のこと知らないんでお尋ねしているんですが」「まあいいからふたりともこちらへ来いよ」　ふたりは土手をのぼった。",
              "citation": {
                "source": "野宿",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "良　三　まあいいから、早くあの書斎の机から反射鏡を持って来い。",
              "citation": {
                "source": "宵（一幕）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあいいからお帰り』と彼は乳婆を押しやりながら、真面目な口調になって『お帰り、ビクトワール、別に心配することはない。",
              "citation": {
                "source": "水晶の栓",
                "author": "モウリス・ルブラン",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
