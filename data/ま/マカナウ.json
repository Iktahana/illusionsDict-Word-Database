[
  {
    "uuid": "2a1cc004-66a5-5e09-afb1-0c76160d0f8f",
    "entry": "賄う",
    "reading": {
      "primary": "まかなう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
