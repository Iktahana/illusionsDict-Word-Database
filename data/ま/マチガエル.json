    "definitions": [
      {
        "index": 1,
        "gloss": "to make a mistake (in)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "また同じ人の名が色々な住所と結合してぱらぱらに散在しているので、どれが現住所であるか、当人でさえ時々間違えることがありそうである。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "間違える事なしには研究は進められない。",
              "citation": {
                "source": "雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿江は途中で道を間違えるに違いないしと。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の影を、死神と間違えるんだもの、御覧なさい、生きている瀬はなかったんですよ。",
              "citation": {
                "source": "女客",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから屹度彼女は偶然井深君と見間違える程よく似た恰好の男をその知己にもっていたのであろう。",
              "citation": {
                "source": "嘘",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇　幾度も同じ舞いの順序を間違えると翁はやはり立上って来て、筆者の襟首を捉まえて舞台を引きずりまわしながら、「ソラソラ。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、小太郎さんは、また何かを何かと間違えるんじゃなくって！",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は今もう少しであなたをタイプライターを打ってる人と間違えるところでしたが、もちろんあなたは、音楽家ですな。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一体どうして紳士たちがこいつらを本物の紳士と間違えるのか想像しかねた。",
              "citation": {
                "source": "群集の人",
                "author": "THE MAN OF THE CROWD",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしそのためには、暗号の類としか思えない文字の連なりを、キーボードから綴りを間違えることなく入力することを求められる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで間違えると機械の側は、「違ってるぞ」と言ったきり黙りこくる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＭＳ―ＤＯＳでは、文字による命令を綴りを間違えることなく打ち込むことが必要だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟の時も私の時も、その養育振りは全く同様だつたといふことで、そしてそれ程齢の違ふ弟と兄を稍ともすると感違ひして、呼び間違えるのです。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら慌てても、人間と獣とを間違える程のおれでは無いぞ。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "）五平　なるほど弥三郎どんの云う通り、人間と狼を間違える筈は無さそうだ。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その比露子夫人が、仮令多少の距離があったにしろ、そして又、仮令もう一人の百姓の証人――彼はダンスのイロハも知らない素朴な農夫だ――が、そう言っているにしろ、ダンスをし始めるのと、喧嘩をし始めるのとを、見間違えるなんて事は、そのかみダンスでオマンマを食べていた彼女の申立として、断然信じられない話だ。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今のオルノーコの話だが、君はそそっかしいから間違えるといけないからついでに言うがね」と先生の煙がちょっととぎれた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "セルロイドと間違えるな。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "間違えるな」　と姫草に言ったりしたが、そのたんびにユリ子はキャッキャと笑って立ち働きながら言った。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等上流人士は、自分の財産や権力の魔力を自惚れた結果、神聖な警官を女衒と間違えるようになった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なめくじとつばきのかたまりとを間違えるというような無理な作為にもかかわらず面白い読み物である。",
              "citation": {
                "source": "新人の諸作一括",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物をとり替えて置きさえすれば、それでいいんですよ……だが院長、『トントン』と『怪我人』の屍体を間違えるなんて、えらい失敗をやったもんですね。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「時間を間違えるな。",
              "citation": {
                "source": "人造人間殺害事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお糸が黒船のマドロスと出来合って逃げたらしいな」「それを自分の馴染の女と間違えるというのは、巳之助という奴もよっぽどそそっかしい野郎だ」「野郎もそそっかしいが、女も女だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "妖狐伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十一日は大師の縁日であるから、その日を間違える筈もない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三つの声",
                "note": "青空文庫"
              }
            },
            {
              "text": "――写真の印象だけでまさか見間違えることもなからうが、若しもあの眼の球が青かつたらどんなに薄気味悪いことだらう！",
              "citation": {
                "source": "蔭ひなた",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "女と男と間違える奴があるか。",
              "citation": {
                "source": "稀有の犯罪",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "石膏と本物とを間違えるくらいの泥棒だから、兄さんにもたいてい見当がつくだろう？",
              "citation": {
                "source": "頭蓋骨の秘密",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやらそれは警視総監のことを云っているのだろうが、市長さん狼狽したりと雖も、管轄を間違えるとは何であるかといいたくなる。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日ほどたって、巳之助が草鞋を買ってもらいに行くと、雑貨屋の婆さんはにこにこしながら、こりゃたいへん便利で明かるうて、夜でもお客がよう来てくれるし、釣銭をまちがえることもないので、気に入ったから買いましょう、といった。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
