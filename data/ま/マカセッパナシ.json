        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は仕事を途中で放り出し、部下に任せっぱなしで帰ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は自分の責任を放棄し、全てをチームメンバーに任せっぱなしにしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供がおもちゃを散らかしたまま、親に任せっぱなしにするのは良くない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "わたしは刻々の印象に、身を任せっぱなしにした。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "このまま半導体に任せっぱなしにしておくのか」　とっさに「いえ」と打ち消す言葉が、石井の口をついて出た。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんなの　おねえさんの　みずかきリベカは、　たまごを　あたためるにしても　はじめから　だれかに　まかせっぱなしで　――「わたし　こらえしょうが　ないから、　２８にちも　たまごのうえに　すわりきりだなんて　むり。",
              "citation": {
                "source": "みずかきジェマイマのはなし",
                "author": "THE TALE OF JEMIMA PUDDLE-DUCK",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
