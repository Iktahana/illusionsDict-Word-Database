          "literary": [
            {
              "text": "毎度ありがとう存じます。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――大島屋の大きいお上が、半月と、一月、ずッと御逗留の事も毎度ありましたが、その御逗留中というと、小一の、持病の坐睡がまた激しく起ります。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「毎度ありがとうございます」「時におふくろも兄貴も達者かえ」　お吉の兄は左官で、阿母はもう五十を越しているということを半七は識っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとまてッ」「へえへえ、毎度ありがとうござりやす」「白っぱくれたこと言うな。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大切な髪をこわして、毎度ありがとうござりやすとは何だよ。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "女甲　　毎度ありがたうございます。",
              "citation": {
                "source": "箕輪の心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎度ありがとうございました」　茶代を置いて、長次郎はそこを出た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "小女郎狐",
                "note": "青空文庫"
              }
            },
            {
              "text": "おん歌毎度ありがたく存じます。",
              "citation": {
                "source": "（芥川龍之介の書翰に就いて）",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "筏乗は悪く致すと岩角に衝当り、水中へ陥るような事が毎度ありますが、山田川から前橋まで漕出す賃金は稍く金二円五十銭ぐらいのもので、長い楫を持ち筏の上に乗って、前後に二人ずつ居りまして、中乗りが三人ぐらい居まして、忽ちに前橋まで此の筏が下りて参りますが、中々容易なものでは有りません。",
              "citation": {
                "source": "霧陰伊香保湯煙",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "秘伝秘伝といって隠すのは狭い心、私は何でもないような秘伝を習うために沢山の金を取られた事も毎度あります。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから一々その度ごとに検査しないと同じ印でも以前の品物と変っている事が毎度あります」大原「それは怪しかりません。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの家へは何を持って行っても済むと思うと高い直段を取って悪い品物を売付ける事が毎度あります。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お忘れもののないように、毎度ありがとう御座い」「まア、ここは屋上。",
              "citation": {
                "source": "遊星植民説",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかが、クリームとローションの……」「理窟はさうだけれども、お客に――毎度ありがたうと云ふぢやないか」　彼は、憮然として家に戻り、折から来合せた客の一人に、鏡に映るその無精髭を生やした顔に話しかけた。",
              "citation": {
                "source": "空地利用",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎度ありがとうございますって、人を馬鹿にした空世辞も、満更嬉しくないでもなかった。",
              "citation": {
                "source": "神棚",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はいはい、毎度ありがとうござい。",
              "citation": {
                "source": "時限爆弾奇譚",
                "author": "――金博士シリーズ・８――",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎度ありがとう御ざい。",
              "citation": {
                "source": "渡鳥いつかへる",
                "author": "軽演劇一幕四場",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おやそれはどうも毎度あり難う。",
              "citation": {
                "source": "球突場の一隅",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて買物をした店で、毎度ありがたうつて云ふぢやないか。",
              "citation": {
                "source": "顔",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "八百屋の声　　毎度ありがたう……。",
              "citation": {
                "source": "世帯休業",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎度ありがたう……。",
              "citation": {
                "source": "犬は鎖に繋ぐべからず",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "声　　毎度ありがたうす。",
              "citation": {
                "source": "留守（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所で「お待遠さま、毎度ありがたう……」といふ声。",
              "citation": {
                "source": "留守（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、商店はなれているから、何食わぬ顔、毎度ありがとうございます、と送り返しておいて、月末のツケの中へ、お買い上げ品として万引の品物も書きこんでおく。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その五　万引家族",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、参りましょうか」「荷物を忘れちゃいけないよ」「この通り、シッカリ抱いていまさァ」　毎度ありがとう。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "まいどありがとうございます」「よう。",
              "citation": {
