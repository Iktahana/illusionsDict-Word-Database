[
  {
    "uuid": "7181a5fb-2abb-581c-a6f5-a14c5c4b1381",
    "entry": "真中",
    "reading": {
      "primary": "まなか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
