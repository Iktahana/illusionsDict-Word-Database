      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "middle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たつた一人の客が、部屋の真中にたつた一台の玉台の一方に立留つたきりで、練習突きをしてゐる。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "横道に少し外れたが、　私は大東京の真中で、一人にされた！",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、蟇蛙が一匹、ピクピク／＼しながら何時の間にか、庭の真中に匐ひ出してゐた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母さん、自分がむしやくしやするからつて子供にまで辛く当らなかつたつて……」「またあんたが出て来て事を大きにしてもらつてはお母さんが何時も真中で一番困るから。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "座敷で鼠が物をかじる音がするから見に行ったら、床の真中に鏡が薄くくらがりの中に淋しく光っていた。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の頃、寒月の冴えた夜などに友達の家から帰って来る途中で川沿いの道の真中をすかして見ると土の表面にちょうど飛石を並べたようにかすかに白っぽい色をした斑点が規則正しく一列に並んでいる。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人には遠く離れた広間の真中に、しんとして寝ているような心持である。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道路の真中に大きな樹のあるのを切残してあるのも愉快である。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると池の真中に土手のやうなものが突出してゐて、その端の小屋のやうなものの中で何かしら機械が運転してゐるらしい。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "動物園裏まで来ると道路の真中へ畳を持出してその上に病人をねかせているのがあった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると池の真中に土手のようなものが突出していて、その端の小屋のようなものの中で何かしら機械が運転しているらしい。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "真中で釣手をつけて天井へ釣るか、それとも外に工夫はないだろうか。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "受信機の方ではこれを電話の受話器のごときものに接続する、受話器の薄い鉄の円板の真中に固着した針が一本あってこれが原板の写しを画くペンの役目をするのである。",
              "citation": {
                "source": "写真電送の新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この猫の腹の真中にある穴から糸が出ている。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛唐国の花だとさげすみながら、人は何と争って五月の花壇の真中に何よりも大切にこの宝石の様な花たちを、栽培するようになった事よ。",
              "citation": {
                "source": "五月の朝の花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京市何区何町の真中に尾花が戦ぎ百舌が鳴き、狐や狸が散歩する事になったのは愉快である。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気が付いてみると自分は一番上の字の真中を真黒にしている。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓦斯ストーヴでもあると助かるが、さもなくて、大分しばらく待たされてから、やっと大きな火鉢の真中に小さな火種を入れて持参されたのでは、火のおこるまでに骨の髄まで凍ってしまいそうな気がする。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらと少し種類はちがうが、紙上に水平に一直線を描いて、その真中から上に垂直に同長の直線を立てると、その垂直線の方が長く見える。",
              "citation": {
                "source": "観点と距離",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道の真中は乾いているが、両側の田についている所は、露にしとしとに濡れて、いろいろの草が花を開いてる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑の真中ほどに桐の樹が二本繁っている。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが自分の室内ならとにかく、税関の広い土間の真中で衆人環視のうちにやるのであるからシャツ一つになる訳にも行かない。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代の新聞のジャーナリズムは幾多の猫又を製造しまた帝都の真中に鬼を躍らせる。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツェペリン飛行船が舞台の真中に着陸する、その前でロココ時代の宮庭と現代の世界との混合したような夢幻の光景が渦を巻いたといったような気がするだけである。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上衣の胴着の下端の環が小舟の真中に腰を入れる穴の円枠にぴったり嵌まって海水が舟中へ這入らないようにしてあるのは巧妙である。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "会場の前の道路の真中に大きな天幕張りが出来かかっている。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "炭の活け方には色々あるが、要するに炭を並べて真中に縦穴を作り穴の下の方に横穴を作れば全体が丁度ストーヴの煙突と同じ作用をして空気の流通を促し炭の燃えるのを助ける訳になる。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一列に並べた食卓の真中に二条のレールを据え付け、この上を御馳走を満載した可愛らしい電車が徐々と進行する。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでインド洋の真中から西の方へ向うた不断の潮流がある事が知れる、云々」。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまなか伝説的存在にされてあゝ、この言語玩弄者達の世に、なまなか伝説的存在にされて、（パンを奪はれ花は与へられ）あゝ、小児病者の横行の世に！",
              "citation": {
                "source": "（辛いこつた辛いこつた！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
