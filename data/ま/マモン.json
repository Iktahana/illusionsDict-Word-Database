        "examples": {
          "standard": [
            {
              "text": "古典文学の中で、マモンは物質的な富や金銭を盲目的に追求する悪魔として描かれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は金銭欲に目がくらみ、まるでマモンに取り憑かれたかのように手段を選ばず働いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "強欲の象徴であるマモンという言葉は、現代の格差社会や行き過ぎた資本主義を皮肉る際に使われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "昨夜、此の宿迄送って呉れた奥さんに、僕は如何に先生にホレてゐるか、ホンマモンですと強調した由、それを帰って先生に言はれたら、「テレくさゝうな、嬉しさうなかほして、涙も出てたやうに思ひます」とのこと、何と！",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "或いはまたオボツカクラの君真物（キンマモン）が天神であるに対して、儀来河内すなわちニライカナイの君真物を海神だというのも、しばしば引用せられる箇条であった。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
