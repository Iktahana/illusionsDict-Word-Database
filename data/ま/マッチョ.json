          "literary": [
            {
              "text": "マッチョが「ウンノック」と代って答えた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "クルグックの婆さんも女の子マッチョ、ウンノック、ムンムックたちも赤や黄や藍の更紗の冠りで並んでいた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャベだのアンニャだのシッペタだのゲェルマッチョ（蛙のこと）などという下賤な言葉は禁止される。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "花天狗流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピカ一は余憤おさまらず、「ノートルダムの先生も、カタワのくせに、全然アマッチョロイ頭じゃないか。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
