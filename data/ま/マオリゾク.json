        "examples": {
          "standard": [
            {
              "text": "ラグビーのニュージーランド代表が試合前に行う「ハカ」は、マオリ族の伝統舞踊だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "マオリ族の顔に施されたタトゥーには、一人ひとりの家系や地位を示す重要な意味がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "マオリ族の居住地を訪れ、大地の熱を利用した伝統料理「ハンギ」を堪能した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "政治家嫌いの私が彼に面会を求めたのは、彼が人間であることを――マオリ族に最も博大な人間愛を注いだ人間であることを信じたからだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてヘンリイ・ビドウ氏がいみじくも言つたやうに、『アメリカン・バア、タンゴ、マオリ族の刺青が我々の時代に於けるのは、月光、廢塔、トゥルバドゥル詩人の胡弓がロマンチスムに於けるごときものだ。",
              "citation": {
                "source": "レエモン　ラジィゲ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
