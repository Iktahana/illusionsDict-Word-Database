        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "急流が曲がりくねる深い谷を流れ、大平原では冬に銀色の雪、夏にはアルカリの灰が一面に広がる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "上身も初めよりは多く曲がりくねる。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（湾内の曲がりくねる水は王宮をめぐり、夕日は波に照り映えて橋は弧を描く。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "（河口は曲がりくねること蛇のごとく、市街は浅いなぎさに連なって建つ。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲がりくねる迷路の構造が絶望的なまでに複雑なのか、あるいはいつにない歩行の振動のために天井から岩の屑が落下し、帰り道を塞いでしまったのか。",
              "citation": {
                "source": "千里眼の村",
                "author": "クリスマス・ストーリー",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲がりくねる細い道の両側に商店が建てこむ様子と雰囲気が、彼には楽しかった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "枝はといえば、みんな、ねばねばした長い腕で、まるで、ミミズのようにまがりくねる指を持っていました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
