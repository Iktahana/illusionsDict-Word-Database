    "definitions": [
      {
        "index": 1,
        "gloss": "match (for lighting a fire)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "焚火焚火、人々は手足の関節から、血の循環が一秒一秒止まったように、意識された、今凍えて行くのだということも解る、早くどうかしろと神経が知らせてくれる、誰の顔を見ても、蝋のように白い、マッチ箱は燐寸一本さえ、烟を立てることなしに、空になったほど、何もかも、ビショ濡れになった。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして幾度か燐寸を擦り消しながら、やつと煙草に火を點けると、歩調をとるやうにして狹い甲板を往き來した。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "燐寸の自然発火と、外函の両側に膠着された硝子粉のため、焼き爛らした指頭には、黒い垢じみた繃帯を巻いていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カタイ大ッピラな燐寸工場以外、硬派と軟派を兼ねているからだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして燐寸は、中国の国産品と寸分も異わないものが出来上った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小山は、慌てゝ、自分が燐寸工場の職長であること、逃亡を企てた工人を捕まえに行ったこと、自分の工場にも兵タイを泊めてやっていることなどを説明した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人は煙草を喫まないから燐寸がないのだ。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は燐寸を手に持ちました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "手の燐寸を示すようにして。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "「落し物でしたら燐寸がありますよ」　次にはそう言うつもりだったのです。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は燐寸の箱を袂から取り出そうとした。",
              "citation": {
                "source": "過古",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本の燐寸の火が、焔が消えて炭火になってからでも、闇に対してどれだけの照力を持っていたか、彼ははじめて知った。",
              "citation": {
                "source": "過古",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　説明も形容も何もない――燐寸を摺ると否や、アルコールに火をつけるのであるから、言句もない。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると甲は巻煙草を出して、「オイ君、燐寸を借せ。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "燃えさしの燐寸をト棄てようとして水に翳すと、ちらちらと流れる水面の、他の点燈に色を分けて、雛の松明のごとく、軸白く桃色に、輝いた時、彼はそこに、姉を思った。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　で、袂から卷莨を取つて、燐寸を摺つた。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、今朝もそのままな、野道を挟んだ、飾竹に祭提灯の、稲田ずれに、さらさらちらちらと風に揺れる処で、欣七郎が巻煙草を出すと、燐寸を忘れた。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょいと、燐寸はありませんか。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と車夫の吉造、婦人を一人輪の下に轢かんとせし、ようよう車を踏留め、胆を潰せしむかばらたち、燐寸にあたりて二三本折っぺしょり、ますます苛ち、「命知らずの馬鹿者め、何だって往来に坐ってるんだ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "面疱だらけの女中さんが燐寸を摺つて點けて、插ぼやをさすと、フツと消したばかり、まだ火のついたまゝの燃さしを、ポンと斜つかひに投げた――（まつたく、お互が、所帶を持つて、女中の此には惱まされた、火の用心が惡いから、それだけはよしなよ。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "罐詰どころか、蝋燭も、燐寸もない。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、先ず其正体を見定める為に、袂から燐寸を把出して、慌てて二三本｜擦った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時、敵は血に染みたる洋刃を揮って、更に市郎を目がけて飛び蒐って来たが、其の眼前に恰も燐寸の火が溌と燃ゆるや、彼は電気に打たれたように、猝に刃物をからりと落して、両手で顔を掩ったまま、霎時そこに立縮んで了った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、斯う見えたのも一瞬時で、燐寸の火は忽ち消えた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "市郎は透さず第二の燐寸を擦ると、彼は再び眼を掩った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "市郎は勝つに乗って、続けさまに燐寸を擦ると、敵は既う此方を向く勇気が失せたらしく、頭を回らして一散に逃げ出した。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　重太郎は燐寸を有っていた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "有合う枯枝や落葉を積んで、手早く燐寸の火を摺付けると、溌々云う音と共に、薄暗い煙が渦巻いて※った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "市郎は一度消えた蝋燭に再び燐寸の火を点けて、暗い石室の中を仔細に照して視たが、所々の岩の窪みに氷のような水を宿している他には、矢はり何物も眼に入らなかった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃では神棚の燈明を点すのにマッチは汚れがあるというのでわざわざ燧で火を切り出し、先ずホクチに点火しておいてさらに附け木を燃やしその焔を燈心に移すのであった。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
