    "definitions": [
      {
        "index": 1,
        "gloss": "after (practically) no time",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夫人と結婚して間もない頃、雨でずぶ濡れになった小猫を拾って帰り、その泥だらけのままの猫を懐中に入れて、長い間やさしく暖めていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから間もない或日、学校から帰つてみると、下宿の机の上に例の姪からの手紙が来てゐた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "隙間もない茂りの緑は霜にややさびて得も云われぬ色彩が梢から梢へと柔らかに移り変っている。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ敷いてから間もないと思はれる銀べりの青畳がその光に反射して、しき通るやうな、スガ／＼しい色合を見せて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れて間もない私が竜門の鯉を染め出した縮緬の初着につつまれ、まだ若々しい母の腕に抱かれて山王の祠の石段を登っているところがあるかと思うと、馬丁に手を引かれて名古屋の大須観音の広庭で玩具を買っている場面もある。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が主人に連れられて東海道を始めてみたのは結婚の相談が纏まって間もない頃である。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう出発に間もないのです。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＴＳ君のその話を聞いて間もないある夜のこと、工業倶楽部の近くの辻でバスを待っているとどこからともなく子供を負ぶった中年男が闇の中からひょっくり現われて、浅草までの道を聞くのであった。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が今井とともに家を出てから間もないことであった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、見舞ひに來た友達が歸つて間もない頃の事で、ふと物寂しい氣持になつた私はまた窓際の曲木の椅子に凭りながら、そのすがすがしい病院の庭の暮色を眺めてゐた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "土用が明けてまだ間もない秋の朝日はきらきらと大溝の水に映って、大きい麦藁とんぼが半七の鼻さきを掠めて低い練塀のなかへ流れるようについと飛び込んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が最後に都会にいた頃――それは冬至に間もない頃であったが――私は毎日自分の窓の風景から消えてゆく日影に限りない愛惜を持っていた。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五分と休む間もない位で、夜の目も合わさないで尽力したです。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが実に呼吸をつく間もない短時間に交互｜錯綜してスクリーンの上に現滅するのである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "返事をもらう事ができるかどうかと危ぶんでいる間もないほどに早く返事が来た。",
              "citation": {
                "source": "二十四年前",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大川端にはアーク燈が煌めき、涼み客の往来は絶ゆる間もない。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふん、仰るだの、遊せだのって云うかと思やべいべい、言葉も使い分けるしな、奇妙な婆あだ」　下女のおすめは婆やが来て間もないのにもう斯んな悪まれ口を利いた。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、然う云ふ間もない、彼處に立つてる、貴女とお話をするうちは、實際、胴忘れに手紙のことを忘れて居ました。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は最う、さつきから荷車が唯辷つてあるいて、少しも轣轆の音の聞えなかつたことも念頭に置かないで、早く此の懊惱を洗ひ流さうと、一直線に、夜明に間もないと考へたから、人憚らず足早に進んだ。",
              "citation": {
                "source": "星あかり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくらには一日に三時間の勉強の時間もない。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日がくれて間もない時刻であるから、銘々の家から、明りがさし、人の話声なども、しかとはわからないが、ごそごそと耳にはひる。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏が近く、日暮に間もない空が、ライラック色と薔薇花とのだんだらに染まって見えた。",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "女主は誕生を迎えて間もない乳呑み児を抱いていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀子の行く座敷も、とかく選挙関係の人が多く、それも土地に根を張っていた政友会系の人が七分を占め、あと三分が憲政会という色分けで、出て間もない銀子はある時これも政友系の代議士｜八代と、土地の富豪倉持との座敷へ呼ばれたのが因縁で、倉持のものとなってしまったのだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん家には最近迎えたばかりの新妻はあり、夫婦生活の味もまだ身に染む間もないころのことだったが、銀子にも嫉妬に似た感情の芽出しはありながら、それを引きとめる手もなく、双方物足りぬ感じで別れるのだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その云い伝えとはどんなことで……』　と引っかけて見たが奥さんはまだ鶴原家に来て間もないせいか、詳しいことは知らないらしかった。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "新婚後まもないことであったと思う。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の翁がそう感ずると等しく、自然自体も感ずるのであろうか、翁の指尖が目途の正面を越して反対側へ撫で移るまもないところから地平は隆起し、麓から中腹にさしかかり、ついに聳え立つ峯巒となる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その時はもう、何んの努力をするまもない！",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻脚絆を解くひまもない。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
