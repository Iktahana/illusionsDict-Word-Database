[
  {
    "uuid": "dca170cc-5531-5985-bd04-0e1a84e3176e",
    "entry": "満喫",
    "reading": {
      "primary": "まんきつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
