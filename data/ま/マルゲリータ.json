          "standard": [
            {
              "text": "薪窯で焼かれたばかりのマルゲリータからは、フレッシュなバジルの香りが立ち上っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「やっぱりピザの王道はマルゲリータだよね、モッツァレラが最高に伸びるよ」と彼女は満足げだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ランチメニューに迷ったら、トマトの酸味とチーズのコクが絶妙なマルゲリータを選ぶことにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "プロヴァンスの伯爵ライモンドの女にしてシヤルル一世の初めの妻【マルゲリータ】ボルゴニアの公爵エウデの女。",
              "citation": {
