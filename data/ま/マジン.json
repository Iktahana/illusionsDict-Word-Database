    "definitions": [
      {
        "index": 1,
        "gloss": "devil",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その疑いない証拠として、現に彼らのオクラ（魔神の正体）を見たという人があると。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "いややがて、この鯉を料理して、大胡坐で飲む時の魔神の姿が見せたいな。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしておもしろい事にはその彫刻に現わされたガルダの顔かたちが、わが国の天狗大和尚の顔によほど似たところがあり、また一方ではジャヴァのある魔神によく似ている。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、船に嚴然たる規律のある事は誰も知つて居る、たとへ霹靂天空に碎けやうとも、數萬の魔神が一｜時に海上に現出れやうとも、船員ならぬ者が船員の職權を侵して、之を船長に報告するなどは海上の法則から言つて、到底許す可からざる事である。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎角する程に怪の船はます／＼接近し來つて、白、紅、緑の燈光は闇夜に閃めく魔神の巨眼のごとく、本船の左舷後方約四五百｜米突の所に輝いて居る。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "况んや此海底戰鬪艇は、波威に沈降する事三十｜呎乃至五十｜呎、其潜行を持續し得る時間は無制限であるから、一度此軍艇に睥睨まれたる軍艦は、恰も昔物語の亞剌比亞の沙漠の大魔神に魅られたる綿羊のごとく、遁れんとして遁るゝ能はず、鬪はんか、速射砲もガツトリング砲も到底力及ばぬ海底の此大怪物を奈何せん。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "洞中の秘密造船所の中では、海底戰鬪艇の方でも、私の方でも、鎔鐵爐、冶金爐等から※々と吹き出す熱火の光は魔神の紅舌のごとく、互に打おろす大鐵槌の響は、寂寞たる洞窟を鳴動して、朝日島の海の神樣も、定めて膽を潰した事であらう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いわれも聞きたし、更めて花の礼も言いたいが、――何だか、お前さんは、魔神の眷属……と言って悪ければ、娘か、腰元、ででもあるような気がする。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "大道に腰を抜いたものの、魔神が荒るると見たというは、この入道の事なりけり。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一段高い廊下の端、隣座敷の空室の前に、唐銅で鋳て※の見ゆる、魔神の像のごとく突立った、鎧かと見ゆる厚外套、杖をついて、靴のまま。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "耶蘇教の信者の女房が、主キリストと抱かれて寝た夢を見たと言うのを聞いた時の心地と、回々教の魔神になぐさまれた夢を見たと言うのを聞いた時の心地とは、きっとそれは違いましょう。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、軈て此の鯉を料理して、大胡座で飲む時の魔神の姿を見せたいな。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "魔神を慰め楽しますものゝ、美女に代へて然るべきなら立処に返し得さする。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その青い倦怠の中からわれ知らず罪咎の魔神の力を藉りても生き上ろうとするわが身の内の必死の青春こそ、あなや、危うくあります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うに、前の大斧は則天無私のちょいであったが、これはまた魔神の怪異である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ちその心臓を秤にかけられて罪の軽重を秤られ、罪無き者は神と合し、罪の軽いものは禽獣草木に生れ換り、悪業の深い者は魔神のために喰ってしまわれる事になっておりました。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その又うしろには頭が鰐、身体が獅子、尻は河馬という奇怪な姿の魔神ラマムが、罪の決定し次第に鼻を喰べさせてもらおうと待ち構えております。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダメス王の鼻は、魔神ラマムに与えらるべきものでない。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞いてみると、将軍と呼ばれている魔神の犠牲にせられようとしていた。",
              "citation": {
                "source": "怪譚小説の話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木立草むらを左右に看過して、媼は魔神の如くわれを導き去りぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中には、げに、天の、地の、大海の、――また海と地と高き天とを支配した魔神の、赫々たる歴史がある。",
              "citation": {
                "source": "沈黙",
                "author": "――神話",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の火に照された、二個の魔神の状を見よ。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と山の襞※を霧の包むやうに枯蘆にぬつと立つ、此の大なる魔神の裾に、小さくなつて、屑屋は頭から領伏して手を合せて拝んだ。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お身は神じゃ、われわれの尊崇する魔神の権化じゃ。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大映系は『大魔神』と『ガメラ対バルゴン』で、これも見にいった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "『大魔神』は、ミニチュアがいまひとつだが、まあまあのできだった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "サブマリンサンドというのは、大魔神のホットドッグのようなものだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェックのパンツ一枚に、首からバスタオルを下げ、ゴム草履といういでたちで、風呂上がりの大魔神かなんかに見える。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "パンツいっちょうの大魔神が、ノド渇いたな、と室内に入っていく。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大魔神が、ジョンといっしょに、崖崩れを起こしそうな声で〈レイン〉を歌う。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
