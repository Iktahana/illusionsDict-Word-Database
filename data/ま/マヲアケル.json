          "literary": [
            {
              "text": "そして次の間を開けると酒肴の用意がしてある。",
              "citation": {
                "source": "少年の悲哀",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "武は上がってふすまをあけると、座敷のまん中で叔父叔母さし向かいの囲碁最中！",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大げんかんのうちでは、ふすまをあける音、大戸をあける音がして、やがて、やさしい女たちの話し声が聞えてきました。",
              "citation": {
                "source": "壇ノ浦の鬼火",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "とのさまはおさかずきを一順おまわしになりますと、「だまってさけばかりのんでおっては気がめいるぞ、明日は浮世にひまをあける身があまりじめ／＼していると寄せ手の奴ばらにわらわれる。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
