    "definitions": [
      {
        "index": 1,
        "gloss": "completely honest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「はあ、何、」　真正直な顔をして、「私ですか、」と空とぼける。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　真正直に言訳されて、小次郎法師はちと気の毒。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "真正直な、緊張した表情でバットの灰を弾いた。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「玄洋社一流の真正直に国粋的なイデオロギーでは駄目だ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては今まであの女を真正直に信じていた自分はまんまと詐られていたのだったか。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の眼から見ると、父の性格は非常に真正直な、また細心なある意味の執拗な性質をもっていた。",
              "citation": {
                "source": "私の父と母",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば青野氏が真情をこめて「小説というものは、作家の誠実な生命と結びついたもので、その意味では容易に生み出されるものでなく」と云われる場合、モチーフの健全で真正直な理解なしに、作家はどこから自分の作品への血脈を見出して来ることが出来よう。",
              "citation": {
                "source": "作家に語りかける言葉",
                "author": "――『現代文学論』にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という真正直なろうま人の努力！",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿丘秋郎と云ったのでは、読者は一向興味を覚えないだろうと思うが、これは無論、僕が仮りにつけた変名であって、もしもその本名を此処に真正直に書きたてるならば、それが余りにも有名な人物なので、読者は吁ッと驚いてしまうだろう。",
              "citation": {
                "source": "振動魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、この村はどの村よりも真正直に第一番に立派な完納をして来たため、他の村村よりも米が無くなり大騒動をしている村だ。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "之は一見意地悪るのようであるが、決してそうではなく、全く物事をいい加減にして置く事が出来ない為で、実は真正直な人であった。",
              "citation": {
                "source": "徹底的な浜尾君",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "意地一本、真正直に又右衛門に逢えぱ討取るつもりでいる。",
              "citation": {
                "source": "鍵屋の辻",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "其だけ古いが、何か新鮮な、真正直な感情が今も残つてゐる。",
              "citation": {
                "source": "戞々たり　車上の優人",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "真正直にいって貰うことを歓迎するんです。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何に彼がこくめいと言ふより、更に真正直に、客観描写から、主観に切り入つて行くかを、覚つて頂くことが出来よう。",
              "citation": {
                "source": "鵠が音",
                "author": "追ひ書き",
                "note": "青空文庫"
              }
            },
            {
              "text": "女学生みたいな子供っぽいところもあり、ひどく厳格な怖いところもあり、声高く笑い興ずることもあり、真正直な理屈を主張することもあり、どうも形態の知れないひとのようで、親しみにくかった。",
              "citation": {
                "source": "窓にさす影",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、これを真正直に発音した方で、拍子が抜けて、「ン」の奴に馬鹿にされたやうな、間の抜けた感じなのだ。",
              "citation": {
                "source": "新作いろは加留多",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "恭二は、十七八の青年の様に真正直に心に思った。",
              "citation": {
                "source": "栄蔵の死",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大病が自分を一瞬に引き攫う事も、天災が此の村全体を無に帰させて仕舞えばと云う事も真正直に望まれる事であった。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうこうなったからには真正直に物を云おうじゃないか。",
              "citation": {
                "source": "或る男の手記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、私は昨日からずっと真正直だったわ。",
              "citation": {
                "source": "或る男の手記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「比較的真正直な怜悧な……いや何だかよく分りません。",
              "citation": {
                "source": "或る男の手記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな真正直な番頭が、どこの世界にあるものか。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "特にこゝ六七年間の生活の変転苦難に堪へて、ともかくも、真正直にひとすぢ、己が道を歩みつゞけ得たと信ずることが出来るのは幸せだと思ふ。",
              "citation": {
                "source": "天の狼",
                "author": "富澤赤黄男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こんな先生の大阪でどうして、人間の生きる道が、真正直に教えられるものか？",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が一番魯迅さんに引きずられた一つは、先生の真正直な人柄でしたネー。",
              "citation": {
                "source": "魯迅さん",
                "author": "内山完造",
                "note": "青空文庫"
              }
            },
            {
              "text": "虚飾やヴェールにかくれていい加減にお茶を濁しておくような真似をしないで、裸になって真正直に打つかってゆく、それがいいかわるいかは分らないが、思ったことをとにかく実行してみたい。",
              "citation": {
                "source": "今年の抱負",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "真正直に論理学――概念――から出発すれば、自然哲学――吾々は存在の代表者としてこの場合自然を選ばねばならぬ――は神秘化される。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘーゲル自然哲学に於けるこの神秘的被覆を引き剥ぐためには、その概念からの出発を真正直に受け取ってはならない。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "――であるから吾々は、同一符号を有つからと云って、すぐ様之を同一系統の世界観――存在論――論理学であると真正直に考えることは、実際には許されない。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
