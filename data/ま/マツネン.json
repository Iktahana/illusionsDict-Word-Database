    "definitions": [
      {
        "index": 1,
        "gloss": "the last days",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから年月を経て、万暦の末年頃、淮安に杜九如というものがあった。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治の末年の大洪水に先だつて、忌はしい謡が行はれた。",
              "citation": {
                "source": "震は亨る",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "知って居るところへは旅行をするから年末年始の礼を欠くという葉書を出してあるので客は一人も来ない。",
              "citation": {
                "source": "餅",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　安政の末年、一人の若武士が品川から高輪の海端を通る。",
              "citation": {
                "source": "雨夜の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "また五十も過ぎて身寄りとは悉く仲違ひをしてしまひ、子供一人ない薄倖な身の上を彼女自身潜在意識的に感じて来て、女の末年の愛を何ものかに向つて寄せずにはゐられなくなつた性情の自然の経過が、いくらかこんなことでゝもこゝに現はれたのではないかと、憐れにも感じ、つく／″＼老婢の身体を眺めやつた。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も皆『新しい自己』を造りたい爲に腐心して居るので有るが、其の新しい自己が造れぬので、歳末年頭の嗟歎や祝福を繰返すのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから年月を経て、万暦の末年頃、淮安に杜九如といふものが有つた。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にひそかに此歌を獻じた一友とは、大正末年以後唯二囘遭遇しただけである。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "佛蘭西はブルボン王朝の末年の腐敗がアレ程になりながら、一面ルーソー、ヴォルテール、モンテスキュー等の思想が新生活の準備をした爲めに、滅亡とならずして革命となり、更に新しき佛蘭西が生れ出た。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは脚本風に書くと、時は明治の末年、秋の宵。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれはその兜を形見として明治の末年に世を去った。",
              "citation": {
                "source": "兜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "能楽の如きも老人の閑技、骨董芸術として、忘却されていたものが、明治の末年頃から西洋人の注意を惹いて以来、日本の識者間に再認識され、騒がれ初めた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは至正の末年で、天子は元順帝であったが、杭州の劉万戸が人才であるということを聞いたので、それを用いることにして呼んだ。",
              "citation": {
                "source": "断橋奇聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "画中の人　これも貞元の末年のことである。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この駅の宿舎には昔から凶いことがしばしばあるのですが、その妖怪の正体は今にわかりません」　　　小人　唐の太和の末年である。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "天統の末年に、彼は官命によって、河の堤を築くことになったが、その工事中、幕下のものに昔話をして、彼は涙をながした。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、元和の末年に李夷簡という人が蜀の役人を勤めていたとき、蜀の町に住む趙高という男は喧嘩を商売のようにしている暴れ者で、それがために幾たびか獄屋に入れられたが、彼は背中一面に毘沙門天の像を彫っているので、獄吏もその尊像を憚って杖をあてることが出来ない。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐の元和の末年に、その寺の僧がしばしば同じ夢をみた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐の景龍の末年に、かれは孝廉にあげられて都へゆく途中、渭南の道で一人の女に逢った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "右あらかじめお含み置きください」　　　白猿伝　梁（六朝）の大同の末年、平南将軍｜藺欽をつかわして南方を征討せしめた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "白猿伝・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "天宝の末年に独孤暹という者があって、その舅は范県の県令となっていた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "白猿伝・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "千八百末年の出版本で、若い彼の亡父が誕生日の祝ひか何かに外国での女友達から贈られたらしいサインのあるものだつた。",
              "citation": {
                "source": "好色夢",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそれは知れ切った事で、誰も皆「新しい自分」を造りたい為に腐心しているのであるが、その新しい自分が造れないので、年末年頭の嘆きや祝福を繰返すのだという言葉が其処此処から出るに違いない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等学校の末年から、大学に移る頃には、久野も啓吉も、青木に劣らないような、乱暴な出鱈目な生活を続けたものだった。",
              "citation": {
                "source": "祝盃",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "文政末年の秋の日ももう午に近づいて、広小路の青物市の呼び声がやがて見世物やおででこ芝居の鳴物に変ろうとする頃で、昼ながらどことなく冷たいような秋風が番小屋の軒の柳を軽くなびかせていた。",
              "citation": {
                "source": "放し鰻",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その疵がもとで死んだともいい、あるいは次郎左衛門と八橋との菩提を弔うために出家したともいい、ある町家の入り婿になって七十余歳で明和の末年まで生きていたとも伝えられている。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "天正の末年で酷い盛夏の一日であった。",
              "citation": {
                "source": "三浦右衛門の最後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは明の崇禎の末年のことである。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "閲微草堂筆記（清）",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥を投げる男　雍正の末年である。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "閲微草堂筆記（清）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人が嘉永の末年に御用道中で大阪へゆくことになりました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
