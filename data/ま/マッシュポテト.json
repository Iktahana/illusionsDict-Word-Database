        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "厨房一同入寮晩餐会メニューチキンコンソメ　　アスパラガスのサラダマッシュポテト　　ヒラメのソテコールドミート　　パンデザートはバニラアイスクリーム　慶一は、「厨房」という字を、とりあえず「とうぼう」と読み、コックかなんかの意味だろうと考えた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "マッシュポテトがうまし。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルドヴル、ポタアジュ、ミニツステーキに、マッシュポテトーとスピナッチ、ババロア。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポタアジュ、ポークビーンズ、ハンバクステーキに、フライオニオンとマッシュポテト。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "次、メニュー見て、ブフ・アラ・モドを注文、マッシュポテト添。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "リゾールパイから、タンシチュウ、マッシュポテト、バタライスを食ひ、サントリーハイボールを又二三杯。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "サントリータンサン、チーズトースト、伊藤にお任せの、ビーフ・ミニツステーキ風、バタライス、マッシュポテト添。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
