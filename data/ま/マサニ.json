    "definitions": [
      {
        "index": 1,
        "gloss": "really (ought to)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "響くといふこともないけれども、何かしら本当に仕事してゐるものを却て一時的とはいへ吃驚させたりするのだ。",
              "citation": {
                "source": "文学に関係のない文学者",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "男　（従いて笑ひながら）本当に。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中が二人、書生が一人、老僕が一人、他に抱車夫が一人という大家族であったので、家も相当に広く、間数がいくつもあって廊下続きになっていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当にもうこのごろは、お互い腹のさぐり合いで、十年来の友人でも、あいまいな事をちょっとだけ書いて寄こして、あなたみたいに、長い手紙を書いてはくれません。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「けれども、あいつの画だけは正当に認めなければいけない」　私はぼんやりしていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに暑いのに、わざわざこんな田舎にまでおいで下さって、本当に恐縮に思うのですが、さて、私には何一つ話題が無い。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当に何も話題が無くていけません。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "故にこの俳句を、もし正当に訳さうと思ふならば、「花」は英語の flowers でなくして、日本語「花」といふ語をそのまま原語で用ゐる必要がある。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして結局、レアリズムもナチュラリズムも、その他の如何なる西洋文学も、正当に翻訳し得ないで終つてしまつたのである。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千明とか木暮といふ一流の旅館なら、相当にゆつたりした寝起をすることができる。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然は相当に美しいが、何分近在の百姓が大勢詰めかけるので、伊香保そのものの空気が、まるで田舎の温泉場に変つてしまふ。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを子規がひどく面白がって「しかし本当にそう思ったんだから」ということを繰返し繰返し言い訳のように云うのであった。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鷹を貰ってからのことを色々空中に画いてはエクスタシーに耽ったものと見えて、今でもなんだか本当に一度鷹を飼ったことがあるような気持がすることがある、もちろん事実は鷹などかつて飼った経験はないのである。",
              "citation": {
                "source": "鷹を貰い損なった話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が笑ったら、子規は、いや本当にそう思ったのだから面白いのだと云って虚子のリマークを弁護したのであった。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この丑尾さんは、たしか自分の家がその後一時東京に移っていたその二年の間に病死してしまったので、十歳にも満たない本当に果敢ない存在ではあった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三金時丸は、貪慾な後家の金貸婆が不当に儲けたように、しこたま儲けて、その歩みを続けた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "してみると本当に読んでもらいたいと思うことはやはり何遍か同じことを繰返して色々の場所へ適当に織込むのが著者の立場からはむしろ当然かもしれない。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中で待っていたお客に対して運転手が一々丁寧に、どうも気の毒だが御覧の通り一杯だからと云って、本当に気の毒そうに詫言を云っている。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去というものは本当にどうする事も出来ないものだろうか。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二には船の中に大きな空室を作り、その中に水を満載し、船の動揺に応じて適当に水を動揺させ、その作用で横揺れを防ぐという工夫が今より二十年前、英国の二、三の汽船に応用されたが、あまり面白くなかったと見えてその後は用いられぬ。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当に生活が出来るのかしら――こう疑い始めたのが縁で却ってだんだん唄うたいの仲間と馴染が出来てしまった。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや湿って落ち付いた下層の落葉は朽ちた冷たい気配と共に彼の足踏みを適当に受け止めた。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当の慈悲とは、此処に本当にものを与えるに適当な事情を持つ人がある。",
              "citation": {
                "source": "慈悲",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一概に風を咎め立ても出来ないし、また近年では和装にも丸綴ぢの腰布を下に着け、なほ重々の用意もあつて本当には何でもないのだが、しかし女の身として斯る場合には必ずシヨツクを受ける。",
              "citation": {
                "source": "風と裾",
                "author": "――何人か良案はないか？――",
                "note": "青空文庫"
              }
            },
            {
              "text": "みち子はもう一度同じことを云って見たが、同じような返事だったので、本当に腹を立て「何て不精たらしい返事なんだろう、もう二度と来てやらないから」と云った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そのもしやもだね」　本当に性が合って、心の底から惚れ合うというのなら、それは自分も大賛成なのである。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは藤枝の宿で、熊谷蓮生坊が念仏を抵当に入れたというその相手の長者の邸跡が今は水田になっていて、早苗がやさしく風に吹かれているのを見に寄ったり、島田では作楽井の教えて呉れた川越しの蓮台を蔵している家を尋ねて、それを写生したりして、大井川の堤に出た。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "南京陷落の日に萩原朔太郎歳まさに暮れんとして兵士の銃劍は白く光れり。",
              "citation": {
                "source": "南京陷落の日に",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天寒く日は凍り歳まさに暮れんとして南京ここに陷落す。",
              "citation": {
                "source": "南京陷落の日に",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その反対に今の新人はその基本作因に自信がなく、ぐらついている、というお言葉は、まさに頂門の一針にて、的確なものと思いました。",
              "citation": {
                "source": "自信の無さ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
