[
  {
    "uuid": "62378925-308b-548a-ae09-aaacad9fb073",
    "entry": "正に",
    "reading": {
      "primary": "まさに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "exactly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そしてヘルン夫妻の生活が、正にそうした通りの理想であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『無学で貞淑な女は天才以上である』とニイチェが言っているが、ヘルンの妻のごとき女性は、正にその意味での『天才以上』であったのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし室生君の眼からみれば、禮節身にそなはり、教養と學識に富む文明紳士の芥川君は、正に人徳の至上觀念を現はす英雄であつたらうし、逆に芥川君の眼から見れば、本性粗野にして禮にならはず、直情直行の自然兒たる室生君が、驚嘆すべき英雄として映つたのである。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして芥川君の文學は、正にこの點で自分の敵――しかも最も強力な敵、それへの戰で最大の名譽を感ずるほど、それほど偉大で強力な敵。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼に於て、自分は正にギリシャ人の、ストイック教徒の、ソクラテスの、藝術至上主義の山頂的な哲學を見る。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正にドビュッシイが言ふやうに、ベートーベンはデスクリプションした。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし現代の日本の子供が、果して或る人々の言ふ如く、本來の童話精神を喪失し、老成人の如く常識家化して居るならば、正にそれは日本文化の虚脱である。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし果して今の子供が、さうした眞の童話精神を喪失し、フアンタジイの夢を持たなくなつてしまつたことから、却つてその種の物への冷笑的態度を示すならば、正に大いに憂ふべき教育上の問題である。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて菊池寛氏は某所に於て、今日の如き科學時代には、詩は衰滅の一路をたどるのみだと言つたが、この「科學時代」といふ言葉を、もし菊池氏の主觀に於て、夢を忘れた小常識人や、世渡り上手の小才智人のみが横行する時代、即ち要するに「小常識的俗物時代」といふ意味に解するならば、正にまちがひなく眞理である。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正に今日に於ける僕等の醫療は、その「失はれた耳の健康」を新たに囘復することでなければならぬ。",
              "citation": {
                "source": "ローマ字論者への質疑",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローマ字論者の主張が、言語をその發音通りに正しく書くといふのであつたら、彼等の書法は、正にその主義と自家矛盾をしてゐるのである。",
              "citation": {
                "source": "ローマ字論者への質疑",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代の通用化した日本語が、時代の過渡期混亂によつて、悉く皆音痴的に病疾されたものだとすれば――正にまたその通りであるが――時代の新しい更生教育は、何より先づその醫療に努めねばならないのである。",
              "citation": {
                "source": "ローマ字論者への質疑",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正にその通り、即興詩人は鴎外氏自身の作つた翻案なのだ。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら Real といふ言葉は外国語の意味に於いては、単なる「現実」を指すのでなく、もつと深奥な哲学的の意味、即ち或る「真実のもの」「確実なもの」、架空の幻影や仮象でなくして、正に「実在するもの」といふやうな意味を持つてゐる。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十にしてなお俗吏なりと云うような句があったと思うが、自分の今は正にそれである。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "母がかへつて、私は校正にとりかかり、ひるごろまでに濟まして、晩い朝ごはんをたべ、それから、〆切のせまつてゐる小説を少しづつ書きつづけ、そのうちに、しきりと侘びしくなつて來た。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを外国に見ると、全世界の大山脈を代表するほどに有名なる欧洲アルプスは、前章にも述べた通り、「白き高山」ということで、アルプス山中の最高峰モン・ブラン（Mont Blanc 四八一一米突）は正に白山という義である。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに述べるムーア灯は正にこの注文に応じて出来たもので、室ならばその鴨居の後ろに隠れた長い管が、一面に光を放って天井を照らし、室内は不夜の境となるのである。",
              "citation": {
                "source": "ムーア灯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "正に上司の儀容であるが、勿論職権止むを得まい。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして「いき」は正にこの変位の或る度合に依存するものであって、変位が小に過ぐれば「上品」の感を生じ、大に過ぐれば「下品」の感を生ずる。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "綺麗に刈りならした芝生の中に立って正に打出されようとする白い球を凝視していると芝生全体が自分をのせて空中に泛んでいるような気がしてくる。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "林檎畑の案山子は、樹の頂上からぴょこんと空中へ今正に飛び出した所だと云ったような剽軽な恰好をしている。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "正にその通りである。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物理の理の字は正にかくのごとき総括を意味するとも云える。",
              "citation": {
                "source": "物質とエネルギー",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自分がここまで述べて来た事は正にこの点について疑いを解かんがためである。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "漫画が実物と似ない点において正に実物自身よりも実物に似るというパラドクシカルな言明はそのままに科学上の知識に適用する事が出来る。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "古来の漫画の名家の作品は正にこれを証明する。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業試験は正にこの原則に反するものである。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "南京陷落の日に萩原朔太郎歳まさに暮れんとして兵士の銃劍は白く光れり。",
              "citation": {
                "source": "南京陷落の日に",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天寒く日は凍り歳まさに暮れんとして南京ここに陷落す。",
              "citation": {
                "source": "南京陷落の日に",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
