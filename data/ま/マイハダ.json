        "examples": {
          "standard": [
            {
              "text": "木造船の船底の隙間に槇皮を詰め込み、浸水を防ぐ作業を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "槇皮を使った伝統的な防水技法は、熟練の船大工によって受け継がれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古い蔵の修理で、壁の亀裂を埋めるために槇皮が必要になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "けれどもわれわれは好奇心のある船客のようにわれわれの船の欄干からもっとしばしば眼をはなち、まいはだをむしってばかりいる愚かな水夫のように航海すべきではない。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            }
