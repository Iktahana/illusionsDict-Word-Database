        "examples": {
          "standard": [
            {
              "text": "この伝統が万々年の後まで受け継がれていくことを、心から願っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "壮大な宇宙の歴史に比べれば、人類の歩みなど万々年にも満たない一瞬に過ぎない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地層に刻まれた記憶は、万々年の歳月を経て私たちに地球の歴史を語りかける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "すなわち七言八絶を賦って――銅雀台ハ高ウシテ上天ニ接ス眸ヲ凝セバ遍ス旧山川欄干ハ屈曲シテ明月ヲ留メ窓戸ハ玲瓏トシテ紫烟ヲ圧ス漢祖ノ歌風ハ空シク筑ヲ撃チ定王ノ戯馬謾ニ鞭ヲ加ウ主人ノ盛徳ヤ尭舜ニ斉シ願ワクハ昇平万々年ヲ楽シマン　と、高吟した。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
