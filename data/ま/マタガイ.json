          "literary": [
            {
              "text": "島田へ40、野原へ30、すっかり揃えたら、かえりがのびたので又買い直し。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「荷物だって、何を又買い込んで来たんだね」　それとも知らぬ、お人好しの三次は、ボートをもやって、ノコノコと石段を上って来た。",
              "citation": {
                "source": "魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月にはまたがいに風が吹く。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも二人は、無言のままたがいに近寄っていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "スヴィドリガイロフとアキレスの二人は、しばらく無言のままたがいに相手を見回していた。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "両軍は悪戦苦闘のままたがいに譲らず、はや幾月かを過していた。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
