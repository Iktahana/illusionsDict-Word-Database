    "definitions": [
      {
        "index": 1,
        "gloss": "Patagonian mara (Dolichotis patagonum)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何のことはない妄想家流であつて、ジャズだつてオネガだつてアッターベルヒだつてラヴェルだつてシトラウスだつてマーラーだつて、妄想家流――といつて妥当でなければ幻想家流である。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "この映画を見た前夜にグスタフ・マーラーの第五交響楽を聞いた。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "南方先生｜件の名歌を訳するに苦しみ、かれこれ思い廻らす内、また見付かったから犬寺の話に再追加するは、インドのマーラッタ王サホは五十年という長い間在位して、一七四八年にわれ掛かる処を救うた愛犬を埋めた場所という（バルフォールの『印度事彙』三版三巻四九〇頁）。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "コムソモールカのタマーラが思案にあまったようにして椅子にかけ、コムソモーレツのミーチャに訊いている。",
              "citation": {
                "source": "三月八日は女の日だ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お前、私の前にはタマーラに、タマーラの前にはリョーリャに同じことを云ったじゃないの。",
              "citation": {
                "source": "三月八日は女の日だ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミーチャと別れたお母さんは、急ぎ足で木の門を出たところで、隣りに住んでいるタマーラに会った。",
              "citation": {
                "source": "楽しいソヴェトの子供",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "タマーラと母さんアンナとは、同じ菓子工場で働いている。",
              "citation": {
                "source": "楽しいソヴェトの子供",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若いタマーラは黙って肩をもちあげた。",
              "citation": {
                "source": "楽しいソヴェトの子供",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミーチャの母さんは、労働婦人は、産前産後四ヵ月の給料つき休暇の貰えること、赤坊の仕度金と九ヵ月の特別哺育費が国庫から支出されること、産院が無料であることなどを、その簡単な言葉の中で、タマーラに思い出させたのだ。",
              "citation": {
                "source": "楽しいソヴェトの子供",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "タマーラは何とも云わない。",
              "citation": {
                "source": "楽しいソヴェトの子供",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう引き合わされてタマーラは笑い、すこし顔を赧らめた。",
              "citation": {
                "source": "楽しいソヴェトの子供",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミーチャの母さんは、タマーラと出勤札をとりに事務所へ行った。",
              "citation": {
                "source": "楽しいソヴェトの子供",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の良人はもうタマーラ・イワノヴナの良人ではなかった。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "マーラーのシンフォニーって素的ね。",
              "citation": {
                "source": "彼は誰を殺したか",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕立屋タマーラは、同じ下宿のうちでもこんな具合な食堂にはなんの関係もなかった。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな仕立台に向って、伯母のタマーラが田舎住居にしては白い、丸いおでこをふせて黒絹のユーブカへ飾紐をつけている。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時間に、村端れの仕立屋タマーラの窓からランプの光が夜の村道までさしていた。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○午後黒田礼二氏来、秋田さんのところの連中と話して居るうち、一つ賑やかに年越しをしようではないかということになり、自分達芸術座のマーラヤ・スチェナー〔小舞台〕に呼ばれて居たのをことわりに伝えて、Ｙの発案にて一人前一留十哥ずつ出し、自分達買いものに出た。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "）〔配役表貼付〕「ラマーラ」（女の名）十月十二日　革命座〔入場券貼付〕「第一騎兵隊」十月十八日〔入場券貼付〕「デカブリスト」　ひどい古フィルムだ。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "タマーラ・カルサビーナはロシヤ生れの舞踊家であるが、数年前フランスのルビュウ・エブドマデエルといふ雑誌に連載した「回想記」にスペイン生れの画家ピカソにロシヤ的性情を発見して吃驚したといふことが書いてある。",
              "citation": {
                "source": "北と南",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "タマーラ・カルサビイナのピカソにおける如く、私も屡々私の知人の南国人達に、表現の形式に差はあつても、同じ真実を見出しがちだ。",
              "citation": {
                "source": "北と南",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "タマーラ・カルサビーナはロシヤ生れの舞姫でニジンスキイと踊つた「ペトルシカ」なぞすでに歴史的なものであるが、先年この人が「ルビュウ・エブドマデエル」に思ひ出の記を連載してゐた。",
              "citation": {
                "source": "気候と郷愁",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "トマサンが最後のウイスキーの一本をのみほしてから死んだのを見ても、よく考えてのことで、マーラーの如くだしぬけに女の子のアイクチでやられていないことがわかる。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この屋敷のそばを、どこかの士官候補生か、それとも薄っぺらな詩人先生でも通りかかったら、窓を見あげて、こう考えるでしょうな、――「ここに神秘なタマーラが、住んでいる、夫を愛するあまり、四つの壁のなかにわが身を埋めてしまった女王さまが」とね。",
              "citation": {
                "source": "熊",
                "author": "МЕДВЕДЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ВОКСの建物のあるマーラヤ・ニキーツカヤの通りを数丁先へ行ったところで、この通りは、モスクへ入る一つの門があったものと見えてニキーツキー門とよばれている。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後三時迄の時間であったら、彼はタクシーをやとい、まっすぐ、マーラヤ・ニキーツカヤ通りの対外文化連絡協会へ行けばよい。",
              "citation": {
                "source": "モスクワ印象記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "土語で「山」と云ふ意味の語でありますが、雪山または雪藏と云ふヒマーラヤ 〔Hima_laya〕 とは言語學上何等の關係もありませぬ。",
              "citation": {
                "source": "金剛智三藏と將軍米准那",
                "author": "榊亮三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "825プリアミデース・ヘクトール近く迫りて槍をもて、メノイチオスの勇武の子、衆勢うちし猛將の息の根とめて揚々と誇りて飛揚の言句曰ふ、824　印度マーラッタ地方の諺に『二虎の間に一猪水を飮む』、此獸は時に極めて強暴。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜は新響の定期演奏会でマーラーの第三交響楽でした。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
