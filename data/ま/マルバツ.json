    "definitions": [
      {
        "index": 1,
        "gloss": "circle and cross",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "京セラ自身百も承知だろうが、現在搭載されている二四〇×三二〇ドットの液晶は遅すぎるし解像度が低すぎる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本ＩＢＭの発表によれば、ＤＯＳ／Ｖは六四〇×四八〇ドットのビデオ規格、ＶＧＡ（ビデオ・グラッフィックス・アレイ）に対応したＭＳ―ＤＯＳであるという。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "初代のＰＣに用意されたもののうちカラー対応版は、六四〇×二〇〇ドットで二色を出しＣＧＡ（カラー・グラフィックス・アダプター）と名付けられていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＣ―９８０１が始めから六四〇×四〇〇で八色を出していたことを思い起こせば、「ＰＣ恐るるに足らず」との当時の日本のムードも、むべなるかなである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが日本の標準が六四〇×四〇〇に張り付いたままでいたこの十年間に、ＩＢＭは上位互換のビデオ規格を一歩一歩積み上げていった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＣ　ＡＴの標準規格とされたのが六四〇×三五〇で十六色のＥＧＡ（エンハンスト・グラフィックス・アダプター）。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてここで登場してきたのが、六四〇×四八〇で十六色のＶＧＡだった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "リンカーン研究所がトランジスターの実用性を確認するために実験的に開発したＴＸ―０には、一〇×一〇インチのディスプレイと画面上に絵を描くことのできるライトペンが接続されていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルファベットの大文字と小文字、カナ文字、各種の記号を取り扱えるほか、ＰＣＸ―01は一六〇×一〇〇ドットの解像度で、八色のカラーを表示することができる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "★白黒のＭＤＡは七二〇×三五〇ドットの解像度を備えていたが、カラーのＣＧＡは二色で六四〇×二〇〇、四色では三二〇×二〇〇ドットしか表示できなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方一九七七年に発表されたアップル※は、六色で二八〇×一九二ドットを表示する高解像度モードを持っており、ＰＣの表示機能はむしろ貧弱な印象を与えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしオプションでＲＯＭを追加すれば、白黒の六四〇×四〇〇ドットの画面に八〇〇字の漢字を表示することができた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "斬新なイメージを見事に製品にまとめ上げたＨＣ―20だったが、二〇字×四行（一二〇×三二ドット）を表示できるだけの液晶ディスプレイはいかにも力不足だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日立は四〇字×八行（二四〇×六四ドット）を表示できる液晶の部品供給をアナウンスしていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "画面の解像度に関しても、新一六ビット機はＰＣ―８８０１の六四〇×四〇〇を引き継いだが、あらたにこの解像度で、八色のカラーの表示機能が与えられた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "★高解像度モードではアップルは四〇×四八ドットで一六色を表示したが、メモリーを一二Ｋバイトまで拡張すれば二八〇×一九二ドットで六色まで表示できた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈カラー表示の画面の解像度は、一〇〇〇×一〇〇〇ドットのミリオンピクセル。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時点でＰＣが備えていた六四〇×二〇〇の解像度は明らかに不足していたが、のちにＷｉｎｄｏｗｓと名付けられることになるこのプロジェクトをスタートさせるにあたって、西は隠し玉を仕込んでいた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ディスプレイの解像度は七二〇×五一二ドットと定め、アナログＲＧＢ方式によって五一二色の中から任意の一六色を選べるようにした★。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "★ＰＣ ＡＴ用の新しいビデオ規格として発表されたＥＧＡは、従来のＭＤＡとＣＧＡの機能をカバーするとともに、六四〇×三五〇ドットで一六色を表現できた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "七二〇×五一二ドットの高解像度に加え、オプションにまわされたカラーボードを組み込むことで、五一二色中から任意の一六色を同時に表示できるようにしたグラフィックスの処理能力は、当時の対抗機種の中では傑出していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分自身、ＰＣ―９８０１の基本路線とするべく腹をくくっていたＭＳ―ＤＯＳを前面に押し出し、アナログＲＧＢを採用して六四〇×五〇〇ドットで二五六色中から任意の一六色を表示できる強力なグラフィックス機能を備えたパソピア16に、浜田は強い警戒感を覚えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
