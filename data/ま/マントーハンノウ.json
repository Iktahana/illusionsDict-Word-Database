        "examples": {
          "standard": [
            {
              "text": "結核の診断のために、病院でマントー反応の検査を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "マントー反応は、ツベルクリン液を皮内注射してアレルギー反応を見る検査だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "陽性反応が出たため、医師はさらに詳しい検査のためにマントー反応を再検査した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この前マントー反応をしらべたときは陰性だったが早速又しらべると云っています。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえったら、第二回目のマントー反応をしらべるために、林町から一家がやって来て太郎はギャアギャア泣いたりして。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
