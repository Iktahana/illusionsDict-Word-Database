    "definitions": [
      {
        "index": 1,
        "gloss": "part of the eyebrow closest to the nose",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……」と父はくるっと振向いて私を見たが、その次に細い舌をぺろりと出して眉根を寄せてみせた。",
              "citation": {
                "source": "父を失う話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "アレキサンダー君の女は、頭を美事な男刈にした、眉根の険しい感じのする、十七八にしか見えない小娘であった。",
              "citation": {
                "source": "ああ華族様だよ　と私は嘘を吐くのであった",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "その娘は眉根の※しい悪党みたいな人相だったが、中村はいっそそこが気に入ったと云うのであった。",
              "citation": {
                "source": "シルクハット",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろめきたおれむばかりに娘のところへ駈け込むと、雑誌の続きを読みかけていた娘は眉根を寄せてふり返った。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "をぢさんは、いつもは子供にむだ口なんかきいてくれるいい人ですが、けふは、何かほかのことで腹を立ててゐたと見えて、太い眉根をぴくぴくと動かしながら、「うちの安雄はな、もう今日から、一人前の大人になつたでな、子供とは遊ばんでな、子供は子供と遊ぶがえゝぞや。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は相変らず、眉根一つ動かさず、孤独でかしこまっていた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじさんは、いつもは子どもにむだ口なんかきいてくれるいい人ですが、きょうは、何かほかのことで腹を立てていたとみえて、太い眉根をぴくぴくと動かしながら、「うちの安雄はな、もう今日から、一人前のおとなになったでな、子どもとは遊ばんでな、子どもは子どもと遊ぶがええぞや」と、つっぱなすようにいいました。",
              "citation": {
                "source": "小さい太郎の悲しみ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉根に寄せられた皺も、どうやら彼に似合つて來てゐた。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉根に寄せられた皺も、どうやら彼に似合って来ていた。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御註文の時ずゐ分困るわ……」給仕女は輕く眉根を寄せて答へた。",
              "citation": {
                "source": "霧の夜に",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といいながらも判事は眉根を寄せたのである。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――――」　瘠せてうす汚なくなって、ルオーの描いた基督のように、真面目過ぎるが故に、かすかに剽軽にさえ見える葛岡の顔が顰められかけて、それを張り支えるものがあって、急に刻まれた眉根の皺と鼻唇線の深まりを震源地の断層とするものゝように、そこから四方八方へ筋肉の揺ぎが浪打ちます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから彼は、「ちょっと、ご免下さい」と言って、その両手の掌で彼の狭い額から濃い眉が憂たげに迫った眉根の皺や、豊かに弛んでいる両頬へかけて丹念にマッサージを始めました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "年増づれ、眉根剃りたる、燈さねば、青き鮠らし。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｆ君は眉根をキッと寄せて金縁眼鏡で、声をあげて笑ったが、Ｈさんはこれも眼鏡だが、ややすこしく禿げあがった広い額の、髪は正しく掻いて、鼻の高い、それで眼元で優しく笑った。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち四人に、Ｎ老人にＡ警部、それにわが友若山牧水に似た鼠頭巾の小爺さんにその連れの万世橋はなにがし宿屋の主人公、この二人はお江戸の酒徒だが、さぞ今頃は縮こまって、悲しい無言の憤激をその衰えた眉根の皺に寄せていることであろう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして間もなく私が執っていた触れるか触れないか程度の脈搏が見る見るハッキリとなり、突然に喘鳴が聞こえ初めたと思うと、老先生は如何にも立腹されたらしく、仰臥して眼を閉じたまま眉根を寄せて不快そうに垢だらけの頭を左右に動かされた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　我が友人は今までにないほどきつく顔をしかめ、眉根を寄せた。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ランスはばす織りのソファに腰を下ろすと、何一つ言い落としはしまいとばかりに眉根を寄せた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　フェリアは眉根を寄せて、しばらく黙り込んだのち、口を開いた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "終日わが友は部屋のうちを低回しつつ項垂れては眉根を寄せて、一等きつい黒煙草をパイプに詰め替え詰め替えするばかりで、こちらから何か問いや話をかけても耳を貸さなかった。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「五六杯｜引掛けておきゃ、半分は酒が手伝って暴れてくれます、何しろしらふなんで、」といいかけて、迫った眉根を寄せたのである。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と例の愛くるしい口を結んで眉根を寄せ、吐息をついて歎息した。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "留まると、折屈みのある毛だらけの、彼の恐るべき脚は、一ツ一ツ蠢き始めて、睫毛を数へるが如くにするので、予て優しい姉の手に育てられて、然う為た事のない眉根を寄せた。",
              "citation": {
                "source": "蠅を憎む記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見つめらるる人は、座客のなめなるを厭ひてか、暫し眉根に皺寄せたりしが、とばかり思ひかへししにや、僅に笑を帯びて、一座を見度しぬ。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "文の使い一　京の堀川にある高師直の館では、姫のゆくえが俄かに知れなくなったので、上下一同が不安の眉根をしかめた。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "……すると……」　蜂須賀巡査は眉根に皺を寄せ下唇を噛みながら、道路の長さを追い始めた。",
              "citation": {
                "source": "石塀幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物の前に引き出された見世物小屋の野獣のようないらだたしさを感じて、君は眉根の所に電光のように起こる痙攣を小うるさく思いながら、むずかしい顔をしてさっさとにぎやかな往来を突きぬけて漁師町のほうへ急ぐ。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "美妙な曲線を長く描いてのどかに開いた眉根は痛ましく眉間に集まって、急にやせたかと思うほど細った鼻筋は恐ろしく感傷的な痛々しさをその顔に与えた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し眉根を寄せながら、手紙に読みふける木村の表情には、時々苦痛や疑惑やの色が往ったり来たりした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
