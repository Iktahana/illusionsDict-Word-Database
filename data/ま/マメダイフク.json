        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――ですから、のちに、私がその「魔道伝書」のすき見をした時も炬燵櫓……（下へ行火を入れます）兼帯の机の上に、揚ものの竹の皮包みが転がっていました――　そういった趣で、啖う事は、豆大福から、すしだ、蕎麦だ。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だ、焼芋、蕎麦、ごもく、豆大福、豌豆の入った――うふ、うふ、うふふ。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一口坂の停留場前の三好野では、豆大福が山のようだ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三好野へはいって一皿十銭のおこわと豆大福を二つ買って、たっぷりと二杯も茶をのんで、私は壁の鏡をのぞいている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆大福を売るおばあさんや、焼鳥屋の店が出て、顎紐をかけたお巡りさんが整理にあたっている。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆大福や、スアマなんていう菓子があったっけ。",
              "citation": {
                "source": "甘話休題",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
