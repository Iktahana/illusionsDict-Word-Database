[
  {
    "uuid": "d2f3e7d9-f3fc-56c7-bc75-cf5d4299061d",
    "entry": "紛い",
    "reading": {
      "primary": "まがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
