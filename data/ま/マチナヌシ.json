    "definitions": [
      {
        "index": 1,
        "gloss": "senior town administrator (Edo period)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
