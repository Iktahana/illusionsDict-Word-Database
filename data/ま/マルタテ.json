        "examples": {
          "standard": [
            {
              "text": "「騎士が円盾を構えて、ドラゴンの吐き出す猛烈な炎を防いでいる」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "博物館には、古代ギリシャの兵士が使用していた青銅製の円盾が展示されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "円盾の中央には、敵を威嚇するための恐ろしい怪物の紋章が描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ただし野槌に似た動物が、実際世界にないでなく、例せばウロペルチス（円盾状の尾の義）の一族およそ四十種、南インドとセイロンに産す。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "山林の土中に棲み、眼至って小さく、両齶に歯あり、尾甚だ短く太く、斜めに截り取られたようで、その端円盾のごとく、その表面｜粗し。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを地に押し著けて歩く、その状あたかも古欧州の軍士が円盾を手で使い分けたごとく、わが邦人に解るように言うなら、塚原老翁が鍋蓋を以て宮本武蔵と立ち廻ったごとしだ。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
