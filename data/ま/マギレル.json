[
  {
    "uuid": "48b37bd8-9235-57ab-87ca-2412402aed19",
    "entry": "紛れる",
    "reading": {
      "primary": "まぎれる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
