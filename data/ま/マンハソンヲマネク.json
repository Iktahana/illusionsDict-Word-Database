        "examples": {
          "standard": [
            {
              "text": "「この成功に傲慢になってはいけないよ、満は損を招くというからね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の絶頂期は長く続かなかった。まさに満は損を招くを体現したような人生だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "事業が順調だからといって油断していると、満は損を招くことになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "人事についても満は損を招くとの諺はこれがためである。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "arrogance leads to downfall",
        "register": "standard",
