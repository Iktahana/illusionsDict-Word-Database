        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "信仰とやらも少し薄らいでまいったのでございましょうか、あの口笛も、ひょっとしたら、父の仕業ではなかったろうかと、なんだかそんな疑いを持つこともございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――煙草をあげましょうか、日本のたばこ。",
              "citation": {
                "source": "雪の日",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あしたは、もっとゆっくり、これに就てのお話も出来ましょうから」「わしゃ、偉大なものへ生命を賭けることは大好きなのじゃよ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、まあ、ほんとに久し振りに行ってみましょうか」　と答えた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のような外国人でも二三日続けて行くと「あなたのナプキンを決めましょうか」と聞く。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの子　詩的概念を表現する様になったとでも云いましょうか。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここを海岸と名をつけたってどうしていけないといわれましょうか。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひわを一｜疋あげましょうか。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し休みましょうか」「わたし休まなくとも、ようございますが、早速お母さんの罰があたって、薄の葉でこんなに手を切りました。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民さん、これから二人で歌をやりましょうか」　お互に一つの心配を持つ身となった二人は、内に思うことが多くてかえって話は少ない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "えッ、お静、お前知らねェか」　「さあ、お隣りで借りて来ましょうか」　「いや、俺行ってくらァ、お貸元、すぐ帰ってまいります」　石松、表へ出る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうぞ」　「や、こりゃどうも」　「あら随分破けてんですねえ」　「え」　「縫いましょうか」　「いや、どうも済みません」　お静、糸と針を取りに立つ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お静が、　「お父っつあん、兄さん呼んで来ましょうか？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔註―今迄に書き落して居たが、これは石松のくせで、ひまさえ有れば一文銭を廻したりして居る事〕　酌婦が来て石松に、　「表か裏か当てっこしましょうか」　「よし、俺ァ表だ」　「じゃ、妾は裏ね」　石松、銭を廻す。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなら現代人の要求とでも申しましょうか。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし幾ら手本無しに生活すると申ましても、そういう人でございましても、どうせ生々しいのでございましょうから、何事かに出合まして、五つや六つの調子を覚えましても、それから先は分りませんから、その五つか六つの調子をあらゆるものに当て嵌める事になってしまうのでございましょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう仰ゃれば、わたくしがこのお部屋へ参りまして、心付いた事がございますから、御遠慮なくそれを申して見ましょうか。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠には、盃の一つもさされると「いやどうも、僕は身体を壊していて、酒はすっかりとめられているのですが、折角ですから、じゃ、まあ、頂きましょうかな」といって、細いがっしりとしている手を、何度も振って、さも敬意を表するように鮮かに盃を受取り、気持ちよく飲んでまた盃を返す。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、うなずくのを、踊りながら好色的な上眼づかいに見て、かの女は僕の背中にエピキュリアン同志のする暗号をつたえると、「――お世話しましょうか？",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イヤとてもわかるものか、わたしが言いましょうか、」と加と男。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな浅間しいことが何で出来ましょうか。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ氏は自分にその人の名刺を見せて、このかたがＰ教室の図書室を見たいと言っておられるが、どうしましょうかというのである。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの、失礼でございますが、お店へあがりましてもよろしゅうございましょうか」と、女は忍びやかに云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お作のおふくろを呼んで来ましょうか」「そうさなあ、こっちへ来て貰った方が静かでいいな」と、半七は云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お聴きの通りでございますが、お祷り下さりましょうか」と、式部はあらためて行者に訊くと、彼女はやはり無言でうなずいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "「中隊を止めて、方向転換をやらせましょうか。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁を丸めてつめて置きましょうか？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へえ、……としますと……貸越しになっとる分はどう致しましょうか？",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとお尋ねしますが、この上流に水車がありましょうか。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（姥石まで行けましょうか。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
