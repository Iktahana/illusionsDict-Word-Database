        "examples": {
          "standard": [
            {
              "text": "週末、友人と麻雀荘に行って四人打ちを楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "駅前の麻雀荘は、いつも賑わっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は初めて麻雀荘に入った時、少し緊張したそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "下宿から学校までは、五町あまりのものでありましたが、大変谷村さんには腹具合のいゝ散歩で、その学校までの道筋には、麻雀荘だの、安カフエー、古本屋、魚屋、床屋、玉突場なぞ何か安直な肩の張らない店が、煤けて並んでいました。",
              "citation": {
                "source": "清修館挿話",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "嵐の日などは、よくここが切れて、遠まわりしなければ帰れなかったのだが、この川を半分防岸工事をして、小鳥屋だの西洋洗濯屋だの麻雀荘と、もう次々に出来てしまって、この頃は夜々駅の横に植木市がたった。",
              "citation": {
                "source": "落合町山川記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
