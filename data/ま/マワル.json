    "definitions": [
      {
        "index": 1,
        "gloss": "to turn",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "刈り株ばかりの冬田の中を紅もめんやうこんもめんで頬かぶりをした若い衆が酒の勢いで縦横に駆け回るのはなかなか威勢がいい、近辺のスパルタ人種の子供らはめいめいに小さな凧を揚げてそれを大凧の尾にからみつかせ、その断片を掠奪しようと争うのである。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山登りがじょうずで、城山を駆け回るなどまるで平地を歩くように、道のあるところ無い所、サッサと飛ぶのです。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり空想だと笑われるかも知れませんが、白状しますと、六蔵は鳥のように空をかけ回るつもりで石垣の角から身をおどらしたものと、私には思われるのです。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "病魔のステッキが体内をあばれ回るのである。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一面に陳列された商品がさき盛った野の花のように見え、天井に回るファンの羽ばたきとうなりが蜜蜂を思わせ、行交う人々が鹿のように鳥のようにまたニンフのように思われてくるのである。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは子供を乗せて柵を回る驢馬で、よく馴れていて、子供が乗るとひとりで一周して帰って来るのだといいます。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも親鳥がこんな格好をして水中を泳ぎ回ることは、かつて見たことがない。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自然のあばれ回るのは必ずしも中央アジアだけには限らない。",
              "citation": {
                "source": "ロプ・ノールその他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの普通日常用いる時計の針の回る角度がたまたま時の代用となるのもやはり自然の経験にほかならぬ。",
              "citation": {
                "source": "時の観念とエントロピーならびにプロバビリティ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "堂の前を右へ回ると塔へ上る階段がある。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでさっそく家族に見せて回ると、似ているという者もあり、似ていないというものもあった、無論これはどちらも正しいに相違なかった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、これがちっとも痛くなかったら平気で動き回る。",
              "citation": {
                "source": "鎖骨",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "市場の辻の消防｜屯所夜でも昼でも火の見で見張りぐるぐる見回る　　北は………　　南は………　　西は………　　東は………どっかに煙はさて見えないか。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和六年の元旦のちょうど昼ごろに、麻布の親類から浅草の親類へ回る道順で銀座を通って見たときの事である。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "親熊は突然あと足を折って尻もちをつくような格好をして一度ぐるりと回るかと思うと、急いで駆け出すが、すぐに後ろを振りむいて何かしら自分の腰に食いついている目に見えぬ敵を追い払おうとする様子をする。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ではまた、何事とも知れぬ極度の恐怖に襲われて、氷塊の間の潮水をもぐって泳ぎ回る可憐な子熊もやがて繩の輪に縛られて船につり上げられる。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして懸命の力で反抗しあばれ回る。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば机の上にある紙切りが見えないであたり近所を捜し回ることがある。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニコルを回転すると、それにつれて、この斑点もぐるぐる回る。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に、数人の浪士が、ちょこちょこと駆けずり回る場面がなんべんとなく繰り返される。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬が結局窓の日蔽幕に巻き込まれてくるくる回る、そうなると奇抜ではあるがいっこうにおかしくない。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらはやりっ子のプレジアンでも、相手がいつも同じ相手役では、結局同じ穴のまわりをぐるぐる回ることになるであろう。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばん深刻だと思われた場面は、最大速度で回る電扇と、摂氏四十度を示した寒暖計を映出したあとで、ブランシュの酒場の中の死んだような暑苦しい空気がかなりリアルに映写される。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでステッキをその長軸のまわりに静かに回転させると、とんぼはステッキの回るのとは逆の方向にからだを回して、周囲の空間に対して、常に一定の方向を保とうとする。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは言わば簡単なローラーであって、二つの反対に回る樫材の円筒の間隙に棉実を食い込ませると、綿の繊維の部分が食い込まれ食い取られて向こう側へ落ち、堅くてローラーの空隙を通過し得ない種子だけが裸にされて手前に落ちるのである。",
              "citation": {
                "source": "糸車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもしろいのは、このローラーが全部木製で、その要部となる二つの円筒が直径一センチメートル半ぐらいであったかと思うが、それが片方の端で互いにかみ合って反対に回るようにそこに螺旋溝が深く掘り込まれていた。",
              "citation": {
                "source": "糸車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピクニックよりもダンスよりも、婦人何々会で駆け回るよりもこのほうがはるかに身にしみてほんとうにおもしろいであろうということは、「物を作り出すことの喜び」を解する人には現代でもいくらか想像ができそうである。",
              "citation": {
                "source": "糸車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　さアと促されて吉次も仕方なく連れだって行けば、お絹は先に立ち往来を外れ田の畔をたどり、堤の腰を回るとすぐ海なり。",
              "citation": {
                "source": "置土産",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "みな寝しずまったころ、三十歳くらいのヘロインは、ランタアンさげて腐りかけた廊下の板をぱたぱた歩きまわるのであるが、私は、いまに、また、どこか思わざる重い扉が、ばたあん、と一つ、とてつもない大きい音をたてて閉じるのではなかろうかと、ひやひやしながら、読んでいった。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が予め読者諸氏に、ことわって置く必要があると云うのは、これから、第三金時丸の、乗組員たちが、たといどんな風になって行くにしても、「第一、そんな船に乗りさえしなければよかったんじゃないか、お天陽様と、米の飯はどこにでもついて、まわるじゃないか」と云われるのが、怖しいためなんだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
