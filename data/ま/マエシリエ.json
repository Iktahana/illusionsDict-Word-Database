[
  {
    "uuid": "9a723e1e-6610-50d2-b806-5338367d8dec",
    "entry": "前後",
    "reading": {
      "primary": "まえしりえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
