    "definitions": [
      {
        "index": 1,
        "gloss": "Mars (god)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "どんなものができているかのぞいてみたくてこわごわ近づくと、十二三ぐらいの金髪の子供がやって来て「アマリ、ソバクルト犬クイツキマース」などと言った。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちらに遠く見える一葦の水はマース河。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴァイゴル、ハマースミスの怪異。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "原注一〇　ニューヨーク、『ジャーナル・オブ・コマース紙』。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "その地方の豪農に、ミルトン・ソムマースという老人があった。",
              "citation": {
                "source": "誤った鑑定",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "母のない家庭であったため、父子は非常に親密であって、家政一切は、ミセス・ホーキンスという老婆が司り、近所には、ソムマース所有の田地に働く小作たちの家族が群がり住っていた。",
              "citation": {
                "source": "誤った鑑定",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソムマースの家から一｜哩ばかり隔たったところのスコットという農家に、エドナという娘があった。",
              "citation": {
                "source": "誤った鑑定",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとその頃父のミルトン・ソムマースは、老齢のためか、又は寂しさのためか、にわかに健康が衰え出して来て、遂には二六時中床の上に横わらねばならぬくらいになった。",
              "citation": {
                "source": "誤った鑑定",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソムマース家に、こうした不快な空気が漂っていたある日の午後、エドナは夕食の支度のために牛乳を搾りに牛小舎へ行き、家に帰ってその牛乳を、竈の上にかけてあったフライ鍋の中へ入れた。",
              "citation": {
                "source": "誤った鑑定",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "解剖の結果、死体の胃の内容物に、多量の砒素化合物があるとわかったので、事件は裁判所に廻され、予審判事が出張して、ソムマース家を委しく取調べることになりました」　予審判事の一行は、家人を一々訊問し、家の隅々を捜索した結果、牛小舎の装具置場の高い棚に、パリス・グリーンの入ったボール箱を見つけた。",
              "citation": {
                "source": "誤った鑑定",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、予審裁判の結果、ミルトン・ソムマースは砒素剤によって毒殺され、犯人はエドナであると決定されたのである。",
              "citation": {
                "source": "誤った鑑定",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このソムマース若夫人の弁護士から、私に事件鑑定の依頼があったのです」と、ブライアン氏は語り続けた。",
              "citation": {
                "source": "誤った鑑定",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "陪審官はたった二十分間で決議して、ソムマース夫人の無罪を宣告しましたよ」　こうして、医師の誤まった鑑定のため、無辜の人が危うく殺人罪に問われようとしたのである。",
              "citation": {
                "source": "誤った鑑定",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「看護婦ばかりでなく、ソムマース夫妻の指紋も、ボール箱についていたというのですからね。",
              "citation": {
                "source": "誤った鑑定",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソムマース夫婦は今では楽しい家庭を作って、平和に暮しているそうです。",
              "citation": {
                "source": "誤った鑑定",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番右のがマイスター染料会社のブレーマン、それから、ほら、こちらを向いたでしょう、あれはパーマース・シップのルースさん、その次のはマーカンティル・マリンのバースウィック、その前のは――何んだか忘れた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "梵語で太陰をマース（〔Ma^s〕）というが、これは計量者、計量器（der Messer）の意でラテンの月（mensis）及び計量器（mensura）と関係している。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "フェルスター中佐の名著『シュリーフェンと世界戦争』の第二版にマース川渡河強行のことを挿入した（四一頁）のはこの結果らしい。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "オランダの中立を侵犯しないとせば独軍の主力軍がマース左岸に進出するのにオランダ国境からナムール要塞の約七十キロを通過せねばならず、この間にフイの止阻堡とベルギーの難攻不落と称するリエージュの要塞がある。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "リエージュは欧州大戦で比較的簡単に（それもこの計画の責任者とも云うべきルーデンドルフが偶然この攻撃に参加した事が有力な原因である）陥落したため、世人は軽く考えているが、モルトケとしては国軍主力のマース左岸への進出に、今日我らの考え及ばぬ大煩悶をしたのを充分察してやらねばならぬ。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでモルトケ大将は、敵の攻撃に対しメッツ要塞を利用し、いわゆるニードの「袋」に敵を誘致して一撃を与え、主力はマース右翼の敵の背後に迫るような作戦を希望したものらしい。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある年の参謀旅行で、敵がロートリンゲンに突進して来るのに、作戦計画の如く主力をマース左岸に進めんとする専習員の案に対し、モルトケは「その必要はない。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "マース右岸の地区を敵の側背に迫るべきだ」と講評したとの事である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルギー方面に侵入した独軍また破竹の勢いでマース川の大障害を突破して西進、特にアルデンヌ地方に前進した部隊は仏軍の意表に出でて五月十日既にセダン附近に於てマースを渡河し、マジノの延長線を突破したのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争中詩人たちの多くは、ミューズと一緒に活動するよりもマースと一しょに活動した。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "マースールのカリフは、氏をバグダッドに召して、その説を傾聴し、これに擬するに判官の栄職をもってした。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "※アレース（ラテン名マース）ヂュウスの子、殺戮、鬪爭の神。",
              "citation": {
                "source": "「イーリアス」例言",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
