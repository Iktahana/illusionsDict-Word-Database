        "examples": {
          "standard": [
            {
              "text": "松毛虫の大量発生で、公園の松の葉がほとんど食べられてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「うわ、松毛虫だ！触らない方がいいよ、かゆくなるから。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "松毛虫は、成長すると美しい蛾になるが、幼虫の時は害虫として知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "おい　ファゼロ、しっかりやれ、こんなやつは野原の松毛虫だ。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなやつは野原の松毛虫だ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの立ち枯れのグイ松たちは、いつかの樺太の全山を襲った松毛虫の被害の名残りだということである。",
              "citation": {
                "source": "ツンドラへの旅",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
