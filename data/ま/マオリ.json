        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかしまたチャム語でも「ナイ」は河または河辺の野であり、アイヌやサモア、マオリ語でも「アナ」は穴でもある。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治家嫌いの私が彼に面会を求めたのは、彼が人間であることを――マオリ族に最も博大な人間愛を注いだ人間であることを信じたからだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は真にマオリ人の身になって、彼等のことを考えてやった。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、マオリ人に英人と同等の政治上の権力を与え、土人代議士の選出を認めた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海外にもマオリ人は背に食物を負うを賤民とす（一八七二年パリ板、ワイツとゲルランドの『未開民人類学』六巻三四五頁）。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてヘンリイ・ビドウ氏がいみじくも言つたやうに、『アメリカン・バア、タンゴ、マオリ族の刺青が我々の時代に於けるのは、月光、廢塔、トゥルバドゥル詩人の胡弓がロマンチスムに於けるごときものだ。",
              "citation": {
                "source": "レエモン　ラジィゲ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "希臘神話と「マオリ神話との類似の如きは、人類学派の神話学者の説明を待つに非ざれば之を解すること能わざるなり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「マオリ」神話にも亦た、一個の英雄あり、下界より火を得て、之を人界に伝う。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「マオリ」神話の英雄マウイの神話に於ても、同様なり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "動物と花の切手もローマオリンピックのもインドのも。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            },
            {
              "text": "このホテルのこのダイニング・ルームに出演している、マオリのコーラス・グループのリハーサルだ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "このマオリのグループは彼女が見つけて来た。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
