    "definitions": [
      {
        "index": 1,
        "gloss": "cheating (on one's husband)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
