    "definitions": [
      {
        "index": 1,
        "gloss": "to come to an end",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "最後に幕になる前に、二度目の発作で本当に死ぬる。",
              "citation": {
                "source": "追儺",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕になる少しまえに、隣の男が、そのまた隣の男に、登場人物の声が、六畳敷で、親子差向かいの談話のようだ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローソクは幕になる迄舞台の上で燃えっぱなしでした。",
              "citation": {
                "source": "一つの感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「言はずとも幕になるべきは山藤の花なれど‥‥「其藤を如何にして吾等の力に移すべきか。",
              "citation": {
                "source": "花枕",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の奥さんは、幕になるとすぐ立ったが、間もなく襟巻とコオトなしになって戻って来た。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故つて、父はさきにも申しました通り脅迫状の一件で何事にも恐怖心をもつており、そんな剛情をはる気力もないのに、このことになると、大変な見幕になるのです。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ小山内氏が來て――その時話したのが最後となつたが――「毛剃」（歌舞伎座、左團次所演）を見てくれるなら早く行かないと元船のところが五分位で幕になるからといはれた。",
              "citation": {
                "source": "むぐらの吐息",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてを為さし、思ひさし、なんにも云はぬ女にて、する、する、すると幕になる。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お蝶夫人」は役の性質上、泣いたり、笑ったりしてうたわねばなりませんから、咽喉をころがす技巧を売物にするコロラチウラ・ソプラノには荷が重過ぎて最後の幕になるとうたえなくなってしまうのです。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕になる少し前に、隣りの男が、其又隣りの男に、登場人物の声が、六畳敷で、親子差向ひの談話の様だ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち身のまゝで幕になるきづかひはないのだが、私の記憶は、其できれてゐる。",
              "citation": {
                "source": "春永話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その作品の第一幕の終りに、所謂濡れ場があつて、遂に服のホツクを外すと云ふ所で幕になる。",
              "citation": {
                "source": "仏国議会に於ける脚本検閲問題",
                "author": "――ゴンクウルの『娼婦エリザ』――",
                "note": "青空文庫"
              }
            },
            {
              "text": "圭さんはなにも言わないで、ニヤニヤ笑っているところで幕になるのが、毎度のことであった。",
              "citation": {
                "source": "電気看板の神経",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の場面、ガルモシュカの音につれて若い二人が静かにこの高い橋＝人生の橋をのぼって去るところで幕になる。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに、花四天がからみまして押戻しが出、そして、引っぱりの見得となって、幕になるので御座います。",
              "citation": {
                "source": "京鹿子娘道成寺",
                "author": "酒井嘉七",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本から離れて、あまり遠くないところへ行って、幕になるのを待ってるわ」　カオルは、うっとりとしているサト子の腕に手をかけると、眠りから呼びさまそうとするように、強くゆすぶった。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "逸早く一人前金三円の観覧料を掻集め、ご覧の通り解散を命じられましたから残念ながら「唄う鶴の会」はこれでお終い、とここでツケが入って幕になる寸法だったのである。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あれは園丁長の酒月と幸田社長の合作で、警視庁も間近い日比谷公園で無届不合法の集会をやれば、鶴が鳴くと予告した九時十二分以前に必ず解散させられると決まってるから、それまでに逸早く会費を掻き集め、どうも残念だが、で幕になる最初からの手筈で、尻尾を掴まれるような仕掛は一切しないことになっていた。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕になると――甚だそれは心細い喝采の中に――私より二側ばかり前にゐた三人づれの若い人がすぐに席を立つのでした。",
              "citation": {
                "source": "井上正夫におくる手紙",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
