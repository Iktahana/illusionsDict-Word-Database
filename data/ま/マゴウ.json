[
  {
    "uuid": "fdd8978e-a472-53c7-85ed-80819512a3fd",
    "entry": "紛う",
    "reading": {
      "primary": "まごう",
      "alternatives": [
        "まがう"
      ],
      "is_heteronym": false
    },
    "grammar": {
