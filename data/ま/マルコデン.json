    "definitions": [
      {
        "index": 1,
        "gloss": "Gospel of Mark (book of the Bible)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
