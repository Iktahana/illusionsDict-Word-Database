        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自分が学校で古いフィロソフィカル・マガジンを見ていたらレヴェレンド・ハウトンという人の「首つりの力学」を論じた珍しい論文が見つかったので先生に報告したら、それはおもしろいから見せろというので学校から借りて来て用立てた。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "創刊以来、世話になってきた『ザ・コンピュータ』とコラムを載せてもらった『パソコン・マガジン』も同時に廃刊になった。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九九〇年一月号から一九九二年三月号にかけて、同社の『パソコン・マガジン』に「インサイドウォッチャー」と題して連載していたコラムを、まとめたものだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本書はソフトバンク刊の『パソコン・マガジン』に「インサイドウォッチャー」と題して連載した時評コラムを、まとめ直したものだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『パソコン・マガジン』第一回日米共同セミナーのパネル・ディスカッションの末席に加わることを、発病以前のオレは約束してしまっていたのである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さすが決戦だ、未来だ、新潮流だとあれやこれや思い付くかぎりのネタで大騒ぎしてきた高血圧マガジン！",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来なら引き続いて、両親の離婚騒動に胸を痛める全世界のまるちゃんへのメッセージなども書きたいところだが、今回ベスト１を書かずに終われば『パソコン・マガジン』にオレの席はない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊とこう書いた直後、世話になっていた『パソコン・マガジン』の編集部と大喧嘩して（一方的にオレが怒り狂っていただけだという噂もあったが）、読者への挨拶もなく本書のもとになった連載を打ち切った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "創刊以来、世話になってきた『Ｔｈｅ　ＣＯＭＰＵＴＥＲ』とコラムを載せてもらった『パソコン・マガジン』も同時に休刊になった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『パソコン・マガジン』への連載中は、同誌編集部の宮島淑子さんの励ましと助力を得た。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二学期までは、この寮で漫画雑誌を見かけることはなかったが、最近はあちこちの部屋に、「サンデー」や「マガジン」が転がっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことは昨年の三月二十七日発行の「ゼ・デテクチヴ・マガジン」にボドキン判事によって指摘され、同氏は、この自家撞着があるために、この作品に対する期待を打ち壊されてしまったと言っている。",
              "citation": {
                "source": "「マリー・ロオジェ事件」の研究",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、コミッスィオンヌイ・マガジン〔古道具屋〕に入って何かＹのお祝いにないかさがす。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の発言はマンスリー・マガジン1811年188ページからコピーしたものである。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして時々フィッシュ・ストーリイをマガジンに書いているんだよ」と註をつけてくれた。",
              "citation": {
                "source": "アラスカ通信",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィロソフィカル・マガジンはラザフォードがその論文を大部分出版した雜誌であるから、甚だ了解に苦しむのである。",
              "citation": {
                "source": "原子核探求の思い出",
                "author": "長岡半太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファラデーはノビリ等の論文を英訳して、これに弁明を附し、一八三二年六月のフィロソフィカル・マガジンに出した。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            },
            {
              "text": "この考は友人フィリップスに送った手紙にくわしく書いてあり、またこの手紙を、「光の振動についての考察」という題で、同年五月のフィロソフィカル・マガジンにも出した。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィロソフィカル・マガジン  Philosophical Magazine. 物理学雑誌の名。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの店って人気のないメニューをどんどん削っちゃって、新しいのと取り替える仕組みになってるの」　陽子は一人話題に加わらず、長椅子の側にみつけたマガジンラックから週刊誌を取り出すとパラパラと無作為にページを繰っていく。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽子はマガジンラックに週刊誌を投げ捨てた。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「例えば、馬の足跡とか犬の足跡とかいう様なものです」　私はこの問答を聞いて、ずっと以前にストランド・マガジンか何かで読んだ一つの犯罪物語を想浮べました。",
              "citation": {
                "source": "黒手組",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "オートマティック・ピストルとそのマガジンを二丁ずつ収納することの出来る、特殊な強化プラスティックのケースだ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "16ミリの撮影カメラとフィルム・マガジンそして三脚などを、僕とエマニュエルは居間に運び出した。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "長尺マガジンに収めたカラー・フィルムは、あと何フィートも残っていないはずだ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌は一九六〇年代のなかばあたりから刊行されはじめた、アメリカのアンダーグランド・マガジンや、いくつかのロック雑誌、音楽雑誌が大量にある。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今から四十余年前、一九一三年十二月号の「ストランド・マガジン」に、ジョージ・シムズがそれを書いているのを読み、いまもノートに貼りつけてある。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時に、山水楼へ、ダイヤモンド社の「経済マガジン」誌の僕の独談会だ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉にミダス・マガジン社の表札があり、文字の下に一階と書いてある。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
