        "examples": {
          "standard": [
            {
              "text": "旧約聖書の最後に配置されているマラキ書には、預言者の厳しい警告が記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "聖書勉強会でマラキ書を読み解き、当時の社会状況と信仰のあり方について議論した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "マラキ書は、メシアの到来を予感させる言葉で締めくくられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これはマラキ書三章一節からの引用です（マタイ一一の一〇、ルカ七の二七参照）。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルコはマラキ書の言とイザヤ書の言とを一緒にして、イザヤ書からの引用として掲げました。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            }
          ]
        }
