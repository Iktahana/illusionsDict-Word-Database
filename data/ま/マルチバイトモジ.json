        "examples": {
          "standard": [
            {
              "text": "日本語などの全角文字を扱うプログラムでは、マルチバイト文字のカウント方法に注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "マルチバイト文字に対応していないシステムに漢字を入力すると、文字化けが発生してしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "データベースの設計段階で、マルチバイト文字を考慮したカラムサイズを設定しておく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
