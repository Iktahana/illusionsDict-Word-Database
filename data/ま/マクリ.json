[
  {
    "uuid": "580f6581-2035-5829-98d4-fd5bb3d69030",
    "entry": "捲り",
    "reading": {
      "primary": "まくり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
