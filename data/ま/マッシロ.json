    "definitions": [
      {
        "index": 1,
        "gloss": "pure white",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "富士山を見ると、雪の真っ白なときには、頂上の八朶の芙蓉に譬えられた峰々がよく別る。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕暗に聳える恵那山は真っ白に雪を被っていた。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は気がついてすぐ頭の上を仰ぐと、昼間は真っ白に立ちのぼる噴煙が月の光を受けて灰色に染まって碧瑠璃の大空を衝いているさまが、いかにもすさまじくまた美しかった。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとの座敷へ帰ってくると、いつの間にか其処には寝床が延べられて、雁金を繍った真っ白な蚊帳が涼しそうに吊ってあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて眼界｜頓に開けた所へ出れば、重畳せる群山波浪のごとく起伏して、下瞰すれば鬼怒の清流真っ白く、新しき褌のごとく山裾を迂ぐっている。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここらは取り分けて霜が多いと見えて、高い堤の枯れ草は雪に埋められたように真っ白に伏して、どこやらで狐の啼く声がきこえた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "見台の横に番傘をしばりつけ、それで雪を避けている筈だが、黒いマントはしかし真っ白で、眉毛まで情なく濡れ下っていた。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おたかの髪の毛は真っ白になった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、やっと豊橋の近くまで来た時は、もう一歩も動けず、目の前は真っ白、たまりかねて線路工夫の弁当を盗みました。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅の前が真っ白になる。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "出会いがしらにふっと顔を覗かれる、あっ、老婆の顔は白い粉を吹いたように真っ白で、眼も鼻も口もない……。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「眼の前が真っ白になる」と。",
              "citation": {
                "source": "吉岡芳兼様へ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人には珍らしい、若い時はさぞ秀麗だったろうと思える、禿げ上った頭のそこらに、真っ白い縮れ髪がもじゃもじゃして鼻の太くて高い威風堂々とした朱面の持主である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも生きている、顫えている、わなないている、気死して醒めて、痙攣して、極度に蒼ざめて、また赤く熱して、膨らんで、張って、真っ白に死ちかかってである。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、くわっと明った真っ白い大道のまん中である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "真っ白い長い顎髯は、豆腐屋の爺さんには洒落すぎたものである。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "弐拾壱　時候が次第に寒くなって、お玉の家の流しの前に、下駄で踏む処だけ板が土に填めてある、その板の上には朝霜が真っ白に置く。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう次第で、年ごろの鑑定は付かないが、髪の毛の真っ白であるだけは間違いない。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊佐子さんは死んでから、その髪の毛が白くなったというが、わたしの眼には平生から真っ白に見えていましたよ。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯からだじゅうが真っ白に見えるばかりですから、わたしも最初は雪｜達磨が出来ているのかと思ったくらいでしたが、近寄ってよく見ると、確かに生きている人間で、雪の中に坐ったままで微かに息をついているのです。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしや自分の空目かと思ったのですが、どうもそうばかりではないらしく、一人の婆が真っ白な姿で路ばたに坐っていたのは本当のように思われてならないのです。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「出先によんどころない用が出来て、時刻がすこし遅くなったので、急いで家を出て、鬼ばば横町にさしかかると、横町の中ほどの大溝のきわに、ひとりの真っ白な婆が坐っているのです。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　横町の中ほどの溝のふちには、さっきと同じように真っ白な物が坐っているらしかった。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべから何処に忍んでいて、いつこのところへ立戻って来たのか知らないが、彼はあたかもかの妖婆が坐っていたらしい所をえらんで、おなじように坐って、同じように雪に埋められて、真っ白になって死んでいたのであった。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらから吹いて来る風か知らないが、空も土もただ真っ白な中で、そこにもここにも白い渦が大きい浪のように巻き上がって狂っている。",
              "citation": {
                "source": "雪女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の前が一瞬真っ白になり、倒れそうになった咄嗟に、（誰も出て来ないな）と思った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩をすくめた拍子にぐらぐら目まいがして、道頓堀の灯が急に真っ白にぼやけて、視線になだれこんで来た。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "うなだれていた顔をあげて、ふとその方を見ると、真っ白に白粉をつけて、カフェの入口に立っている女の視線と打っ突かった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが真っ白い洋服を着た彼女の夫だった。",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女を他の部屋へ運び出すと、裸にしてそこの真っ白いベッドの上に革紐で固く縛りつけた。",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            }
          ]
        }
