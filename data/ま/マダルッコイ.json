        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おれには、ただ少しまだるっこいだけである。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちにしても、結局の目的は主観であって、それを描き出すのが主だとすれば、間接のまだるっこい画など描かずに、直接の主観をじかに出して、露骨に訴えたり、叫んだり、主張したりする方が好いじゃないか、と多くの主観主義者は考えるのである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "公子　ああ、まだるっこい。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐縮とか痛みいるなどの言葉もまだるっこい。",
              "citation": {
                "source": "作家の手帖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき丈人が圃に水をやるのに、御苦労さまにも坑道をつけた井のなかに降りて往き、そこから水甕を抱いて出て来るのを見て、子貢がひどく気の毒がって、そんなまだるっこいことをするよりも、いっそこうしたがよかろうと、槹の仕方を伝授したものだ。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親方、俺はそんなもんじゃまだるっこい！",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にその夜張った非常線が、何の効果もなく三日経っても五日経っても犯人の手懸りが、少しも無いのを知ると、私は警察の活動が、愈々まだるっこいように思われて、じっとして居られないようないらいらした心持に、ならずには居られませんでした。",
              "citation": {
                "source": "ある抗議書",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "納得のゆく方向に立って生活の実体とともに歩みすすめられてはいるのだが、その足どりは、まだるっこい、という種類のもの足りなさではない。",
              "citation": {
                "source": "「下じき」の問題",
                "author": "――こんにちの文学への疑い――",
                "note": "青空文庫"
              }
            },
            {
              "text": "十法なんてそんなまだるっこいことでどうするもんですか。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "南風吹かば　――モンテ・カルロの巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも初めに言ったように、文化の力によって生活を豊かにする途をまだるっこいと斥けて、手っ取り早い武力のほうを選ぶ、わが民族の伝統の最後の結果だよ。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると大江戸の夜景色で」「まだるっこいな。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は直覚的に彼の「食を求める」道はこんなまだるっこいことではいけない思ったから、彼は遂に靜修庵の垣根の外へ行った。",
              "citation": {
                "source": "阿Ｑ正伝",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "何てまだるっこいことだろう。",
              "citation": {
                "source": "明日",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "働き者の重吉のまじめさを見こんで、いねの母親はどうでもこうでも娘を貰ってほしいと、まだるっこい形式をとらずに娘をふずくったのである。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はたちになったなんて、へんな心持だな」とさぶがまだるっこい調子で云った、「おら、思うんだが、十六で月代を剃ったときよりもへんな心持だ」「そうだな」と栄二が云った。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとか、若ぼう」と仙之丞がとびこんで来るなり云った、「おめえ、お侍の家へ貰われていくんだって、本当の話か」「親方はそう返辞をしてたよ」と縫之助がまだるっこい調子で云った、「あとからすぐに伴れてまいりますってさ、当人の出世のためですからって、ちゃんと約束していたよ」　若尾は立ちあがった。",
              "citation": {
                "source": "みずぐるま",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正装して、まだるっこい語りでしたね。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
