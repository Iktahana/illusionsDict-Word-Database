        "examples": {
          "standard": [
            {
              "text": "遠くから聞こえてくる笛や太鼓の祭囃子に、思わず心が浮き立って歩みが早くなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この地域の祭囃子は独特のリズムがあって、聞いてるだけで踊り出したくなるね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夏休みが終わる頃、夜風に乗って流れてくる祭囃子はどこか寂しげな響きを帯びている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私が疲れると呉服屋の定ちやんが自慢のお祭囃子の腕にうんとよりを掛けてたゝきました。",
              "citation": {
                "source": "泣き笑ひ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
