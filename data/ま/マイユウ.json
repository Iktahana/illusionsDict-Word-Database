    "definitions": [
      {
        "index": 1,
        "gloss": "every evening",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それにしても毎日毎夕類型的な新聞記事ばかりを読み、不正確な報道ばかりに眼をさらしていたら、人間の頭脳は次第に変質退化して行くのではないかと気づかわれる。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし現代のジャーナリズムは、まだまだ恐ろしいいろいろの怪物を毎朝毎夕製造しては都大路から津々浦々に横行させているのである。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芹川さんの兄さんとは、女学校に通っていたときには、毎朝毎夕挨拶を交して、兄さんは、いつでも、お店で、小僧さんたちと一緒に、くるくると小まめに立ち働いていました。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎夕の風呂には、忙がしがり家のお媼さんは後に廻って、最初に済ますお爺さんの直ぐ次の番に、婆やはかやと一しょにゆっくり這入るのである。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎夕｜納涼台に集る輩は、喋々しく蝦蟇法師の噂をなして、何者にまれ乞食僧の昼間の住家を探り出だして、その来歴を発出さむ者には、賭物として金一円を抛たむと言いあえりき、一夕お通は例の如く野田山に墓参して、家に帰れば日は暮れつ。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼婆という怖ろしい名がどうして起ったかと聞くと、いつの頃のことか知らないが、麹町通りの或る酒屋へ毎夕ひとりの老婆が一合の酒を買いに来る。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　エチオピア事件でほとんど毎日毎夕の新聞に伊国首相や、エ国皇帝、それから国際聯盟の英仏代表イーデン、ラバールの肖像が出る。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "スティーヴンスンは毎夕食後家族のためにこの物語を読み続けていたが、偶々アレグザーンダー・ジャップという人が訪れてその仲間に入り、この話にはなはだ興味を感じて、帰る時に最初の数章の原稿を持ち去り、それを友人である少年新聞「ヤング・フォークス紙」の編輯者ジェームズ・ヘンダスンに送った。",
              "citation": {
                "source": "宝島",
                "author": "序",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎夕の対酌に河村君は予に語った。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "予らは毎朝毎夕浜へ出かける。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "チクオンキ毎夕ですって？",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "みさをはまだ眠っているようなので、起こすのは気の毒だと思って、昨夜眠りがけに読んでいた毎夕と読売の夕刊を床の上でひろげて読んでいましたが、さびしくなったので、彼女をそっと起こしてやりました。",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく毎夕四合壜を一本宛晩酌にとるといふ先の宰相は、この家の「大関」酒を愛好さるゝのであらう――だがたしかに宰相の額であつたか何うかはウロ覚えであるが、私は時々お光さんのゐた酒場へ行くには未だ時間が早いと思はれる明るいうちなどに、杉の葉の目印の格子をあけて此処の土間の飲み場に現はれることがあつた。",
              "citation": {
                "source": "日本橋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは真菰に餅をつつんで来て、毎夕の食い物にしていたが、それがしばしば紛失するので、あるときそっと窺っていると、一匹の大きい蛇が忍び寄って偸み食らうのであった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神後記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、それからは毎夕｜点燈頃になると、何処よりとも知らず大浪の寄せるようなゴウゴウという響と共に、さしもに広き邸がグラグラと動く。",
              "citation": {
                "source": "池袋の怪",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男もほとほと困じ果てていると、ある夜夢に一人の老翁現われて告げていうことには、かの木の伐り屑を毎夕がた焼き捨てれば成就するだろうという。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからは毎夕切り屑を焼き捨ててついに伐り倒したが、その木が倒れて対こうの川向いの山までも枝梢は打ち靡いた。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その娘の煙ったいというのは本当に煙のことで、田舎では毎朝毎夕炉で粗朶をいぶし、煮たきをする、その煙が辛い。",
              "citation": {
                "source": "若き世代への恋愛論",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」毎夕六時になると、有名なトルコ玉のステッキと伊達者ぶりの服装でバルザックは愛人である貴婦人のサロンに現れ、オペラの棧敷に現れ、時には美術骨董店へ立ち現れた。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎朝、毎夕、あの恐しい省線にワーッと押しこまれ、ワーッと押し出されて、お勤めに通う若い女性たちは、昔の躾を守っていたら、電車一つにものれません。",
              "citation": {
                "source": "新しい躾",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "御紀行毎夕読候而御同行仕候様に奉存候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御紀行毎夕読候而御同行仕候様に奉存候」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀の国橋を渡って木挽町の方へしばらく行ったところにこの正さんの古物骨董の店があって、正さんは雨さえふらなければ毎夕車の上に荷をのせて、私の家の前にうすべりを敷いてむずかしい顔をしてだまりこくって座っていた。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎夕私は、父の肩車に乗せられて父の頭に抱きついて銭湯の暖簾をくぐった。",
              "citation": {
                "source": "父",
                "author": "金子ふみ子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「中央毎夕新聞編輯部｜羽束友一」と印刷した最後の一枚を……。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎夕、悪魔の尿溜からくる昆虫群をふせぐために、石鹸石、その他の粉霧を上空から撒くのだという。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎夕、｜悪魔の尿溜からくる昆虫群をふせぐために、石鹸石、その他の粉霧を上空から撒くのだという。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "（自注、此園、露国帝政時代、彼国将軍寳爾和徳所築、当時将校貴女、毎夕競集、開音楽舞踏会於園中、今無復当年盛観也）哈爾賓客中、呈古澤幸吉先生先生白髪未云還。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての樣子は、町かたの貧しい家の娘で、母親の手助をしながら御針でも内職にしてゐさうな風だが、毎朝毎夕同じ時刻に同じとこで逢ふところから考へると、矢張何處かの會社か銀行に勤めてゐるのかもしれない。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
