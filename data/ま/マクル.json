    "definitions": [
      {
        "index": 1,
        "gloss": "to turn up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "颯然と二の腕を捲ると、生白い肌が現出れて酒氣を帶びた頬が薄赤い。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と黄八丈が骨牌を捲ると、黒縮緬の坊さんが、紅い裏を翻然と翻して、「餓鬼め。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　あたかもその時、役者の名の余白に描いた、福面女、瓢箪男の端をばさりと捲ると、月代茶色に、半白のちょん髷仮髪で、眉毛の下った十ばかりの男の児が、渋団扇の柄を引掴んで、ひょこりと登場。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして五六歩あるき階段へ廻る廊下の角の林檎の鉢植の傍まで行くと、老紳士と組んだ腕を解き、右の片手を鉢の縁にかけ、夜会服の裾を膝まで捲る。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は渦巻き吹き捲る恐怖の嵐のために、胸が裂けてしまいそうだった。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しながら彼は極めて不判明な事件に赴くには、直に起る多少の懸念が吹き捲る雪に逆つて、蓑も笠も持たずに走つて行く程慌てさせる譯には行かなかつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく今日半開と呼ばるる回教諸国などなかなかえらい発明も多かり、能くその法を採用したら、上る箱根のお関所でちょと捲るに及ばず、毬一つ投げ受けしただけで、男女を識別し得たはずだ。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一冊づゝ順々に取り上げて、暗いながら二三｜頁、捲る様に眼を通したが何処も彼の注意を惹く様な所はなかつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その心持も厭だし、春は我々こそと云うように、派手な色彩をまとった婦人達が、吹き捲る埃風に髪を乱し、白粉を汚し、支離滅裂な足許で街頭を横切る姿を見るのも楽でないことだ。",
              "citation": {
                "source": "塵埃、空、花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　初めての日曜日、風の烈しく吹き捲る晴れた日であった。",
              "citation": {
                "source": "氷蔵の二階",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一冊ずつ順々に取り上げて、暗いながら二三頁、捲る様に眼を通したが何処も彼の注意を惹く様な所はなかった。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御前達も尻を捲るが好い」「厭な事」　僕は山賊のような毛脛を露出しにした叔父と、静御前の笠に似た恰好の麦藁帽を被った女二人と、黒い兵児帯をこま結びにした弟を、縁の上から見下して、全く都離れのした不思議な団体のごとく眺めた。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故私は旅館の寝床の毛布を引捲る時にはいつも嫌悪の情に身を顫わす。",
              "citation": {
                "source": "夏の町",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "風の強い日であるとよく東側に旋風が起って、粉のような雪を吹き捲る有様が肉眼で認められる。",
              "citation": {
                "source": "望岳都東京",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "却っておかしいわ」「すると、診察台に乗ってから、捲るの。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思うと、癌で見込のない病人の癖に、から景気をつけて、回診の時に医師の顔を見るや否や、すぐ起き直って尻を捲るというのがあった。",
              "citation": {
                "source": "思い出す事など",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛んだお役に立たないとも限りませんから」　庄吉は土手を切つた洪水のやうに、留めどもなくしやべり捲るのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "軍學者の妾",
                "note": "青空文庫"
              }
            },
            {
              "text": "――かなんかで、沓脱の上へ尻を捲ると、いきなりピカリと来た。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "駕籠の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の中を吹き捲るのは、新しい不気味な嵐、あまりの事に、腰を抜かすもの、鮒のように口を動かすもの、一所懸命這い出そうとするもの、しばらくは無言の混乱が続くばかり、新しい死骸に近づこうとする者がないばかりでなく、棺の中に納めたはずの、主人の元の死骸を確かめようとする者もありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二度死んだ男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「間違ひもなく絞め殺したものだが、この通り首に一ヶ所、胸に一ヶ所、背中に一ヶ所、腹に一ヶ所、匕首か何んかで突いた傷がある、その傷に――」　三輪の萬七が死骸の袷を捲ると、成程全身四ヶ所の淺からぬ傷があり、その傷の傍一つ／＼に、墨で女の名前らしいのが、それ／″＼署名してあるではありませんか。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "浮世繪の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "膝をどけてみると敷物の下らしい、捲るとそこに紙入があった、古渡り更紗の高価な品のようである。",
              "citation": {
                "source": "ひやめし物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手洗い口すゝぎなどするうち空ほの／″＼と明けはなれたるが昨夜の雨の名残まだ晴れやらず、蚊帳をまくる風しめっぽきも心悪からず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の家は前のせまくるしい住居とちがって広い庭園に囲まれていたので、そこで初めて自由に接することの出来た自然界の印象も彼の生涯に決して無意味ではなかったに相違ない。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "古顏の生徒が勝手に開封して「シヤンだな」など云つて頁をまくる。",
              "citation": {
                "source": "青空同人印象記（大正十五年六月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本は思いのほかにせまくるしく、エドは虫に食われて、その所在をたしかめることさえできなかった。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄壁でも切りまくる。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後のクライマックスとして、荒野を吹きまくる砂風に乗じていわゆる「アジアのあらし」が襲来する場面がある。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この町にきた、さいしょのころは、ひどくせまくるしい気がして、さびしい思いをしたものです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、せまくるしくってたまりません。",
              "citation": {
                "source": "すずの兵隊さん",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとこめ、と言って、ぱっと裾をさばいて、くるりと尻をまくる。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
