          "literary": [
            {
              "text": "」　しかし待ち時間はそれほど長くはなかった。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人で洒落将棋をさすだけで、わざわざ東京から出かけて行ったが、映画の撮影は、ご存知のとおり、したくや待ち時間が長くかかるわりに撮る時間は短い。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "西行き列車はちょっと待ち時間があったが、やっと来て、シカゴがにぎわうずっと前に、帰り着いた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食の待ち時間には、菊田・穂積も呼んで、配役をしてしまふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ち時間に、「婚約時代」と「明治の演劇」を読み終った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            }
          ]
        }
