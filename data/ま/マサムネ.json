    "definitions": [
      {
        "index": 1,
        "gloss": "famous sword",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "隣の座敷は殿方ばかりにて、ビール又は正宗の空壜を作るによねんなし。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正宗氏と鍋井氏の絵を見ると、かなり熱心に自分の殻を突き破る事に努力しているという事が感ぜられる。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "正宗氏の絵が沢山ある。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "正宗白鳥氏と、川端康成氏と、それから他の二三氏とが、新聞紙上にこれを論じ、そろつてみな僕の主旨に同感を表してくれた。",
              "citation": {
                "source": "悲しき決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "實際、私達はエセ泉鏡花やエセ正宗白鳥などの亞流に幾度顰蹙させられた事であらうか？",
              "citation": {
                "source": "氣質と文章",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」松木が答えないさきに、武石が脚もとから正宗の四合｜罎を出して来た。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、二人の一等卒が、正宗の四合｜壜を立てらして、テーブルに向い合っていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに言うホールとは、銀座何丁目の狭い、窮屈な路地にある正宗ホールの事である。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "正宗ホールでなければ飲めません。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『何故「ビールに正宗……」の其何れかを買ひ入れなかつたらう』といふが一の悔である。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "最早我慢が仕きれなくなつたので、義母が一寸と立て用たしに行つた間に正宗を命じて、コツプであほつた。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "正宗がなまくらになったのは悲惨である。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "正宗を砥ぎにやったのをなまくらにして返して、これでも切れると云って平気でいるのは、少しおかしいと云わなければならない。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作品の出版當時、これに對する文壇の評論の大半は、クローヂヤスのこの新型の惡を見のがし、正宗白鳥氏なども、このクローヂヤスに作者が同情してゐるとさへ解されてゐたやうである。",
              "citation": {
                "source": "『猿面冠者』あとがき",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と湯気の中に、ビール、正宗の瓶の、棚に直と並んだのが、むら／＼と見えたり、消えたりする。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "質の研究のできていない鈍刀はいくら光っていても格好がよくできていてもまさかの場合に正宗の代わりにならない。",
              "citation": {
                "source": "断水の日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝の文芸欄では、正宗白鳥がホザイてゐる。",
              "citation": {
                "source": "散歩生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "はま鍋、あをやぎの時節でなし、鰌汁は可恐しい、せい／″＼門前あたりの蕎麥屋か、境内の團子屋で、雜煮のぬきで罎ごと正宗の燗であらう。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けちに貯へた正宗は臺所へ皆流れた。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……矢張り旅はもの寂しい、酒の銘さへ、孝子正宗。",
              "citation": {
                "source": "大阪まで",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アランや正宗白鳥のエッセイがいつ読んでも飽きないのは、そのステイルのためがあると思っている。",
              "citation": {
                "source": "僕の読書法",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "正宗白鳥氏、内田百間氏。",
              "citation": {
                "source": "わが文学修業",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "島村抱月氏、田山花袋氏、相馬御風氏、正宗白鳥氏、馬場孤蝶氏、森田草平氏。",
              "citation": {
                "source": "夜長ノート",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜番のために正宗の名刀と南蛮鉄の具足とを買うべく余儀なくせられたる家族は、沢庵の尻尾を噛って日夜｜齷齪するにもかかわらず、夜番の方では頻りに刀と具足の不足を訴えている。",
              "citation": {
                "source": "マードック先生の『日本歴史』",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とニヤリとして、半纏の腹を開けると、腹掛へ斜っかいに、正宗の四合罎、ト内証で見せて、「これだ、訳やねえ、退屈をするもんか。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "道中姿の華魁の胸から腰にかけて「正宗」とやつたのは露骨であるが奇拔である。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "屡見るのは福翁、白鶴、金霞、○○正宗、それに波に日の出の朝日ビール。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角の雁汁に正宗、綺麗な白い手でお酌させだら、もつと好がべにナ。",
              "citation": {
                "source": "刑余の叔父",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "老妻を虐めて※を殺さしたり、罎詰の正宗を買はしたり、剰にうんと油を絞られて、お帰りは停車場まで一里の路をお送りだ。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大沼善八は、靴を穿いた、裾からげで、正宗の四合壜を紐からげにして提げていた。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
