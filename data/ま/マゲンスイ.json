        "examples": {
          "standard": [
            {
              "text": "厚木基地に降り立ったマ元帥は、トレードマークのサングラスとパイプを身につけていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "マ元帥が指揮したGHQの占領政策は、日本の戦後民主化に決定的な影響を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歴史資料館で、執務室の机の前に立つマ元帥の大きな写真パネルを見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この草案の発表された三月七日の新聞紙上には、いっせいに「マ元帥、全面的に承認」という記事が、あわせてのせられていた。",
              "citation": {
                "source": "矛盾とその害毒",
                "author": "――憲法改正草案について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に新聞は共産党への弾圧を挑発するためマ元帥暗殺計画を企てた新井輝成という男の記事を発表している。",
              "citation": {
                "source": "信義について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新春のマ元帥の声明は、終戦以来五度目の新年を迎えた統治の安定を謳っていて、占領軍の兵士たちの町を行く姿は、すでに鎖つきの犬よりも目にしたしいものになってしまっていた。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
