[
  {
    "uuid": "6d2db2b9-4e29-5b4f-880a-98888dceae43",
    "entry": "真盛り",
    "reading": {
      "primary": "まさかり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
