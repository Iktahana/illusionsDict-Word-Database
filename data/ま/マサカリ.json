    },
    "definitions": [
      {
        "index": 1,
        "gloss": "height of",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "南国の真夏の暑い真盛りに庭に面した風通しのいい座敷で背中の風をよけて母にすえてもらった日の記憶がある。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「頭の顱じゃあないけれど、額の椀の蓋は所作｜真盛り。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだその古樹がちらほら残って、真盛りの、朧月夜の事でした。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は奥座敷の離れ家の屋根の見える側の雨戸を夏の真盛りの夕刻早々厳重に閉めさした。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔦の茂葉の真盛りの時分に北支事変が始まつて、それが金朱のいろに彩られるころます／＼皇軍の戦勝は報じ越される。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨脚も白く、真盛りの卯の花が波を打って、すぐの田畝があたかも湖のように拡がって、蛙の声が流れていた。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は桜ばかりが真盛りだ。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川中興の名将軍吉宗公の後を受けた天下泰平の真盛り。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "見張りの眼を巧みに潜ってきた銀之丞が、閉め切った本堂の雨戸の隙間からチラチラ洩れる火影を窺いてみると、正しく天下晴れての袁彦道の真盛り。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十三年の四月、桜の真盛りに、福岡市の洲崎お台場の空地（今の女専所在地）で九州沖縄八県聯合の共進会があった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダメス王はその統治する埃及国に於きまして、世界最初の文化の真盛りの時代を作った名王でありました。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくし共は海の静な時を無駄に過してしまつて、渦巻は今真盛りになつてゐる時なのでございます。",
              "citation": {
                "source": "うづしほ",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "卯花や連翹の花が真盛りで、水ばかりでなしに、上から見降すと、水煙りにぼかされた花の姿までが、煙りの渦巻のやうに見えた。",
              "citation": {
                "source": "滝のある村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後二時というに上野を出でて高崎におもむく汽車に便りて熊谷まで行かんとするなれば、夏の日の真盛りの頃を歩むこととて、市中の塵埃の※い、馬車の騒ぎあえるなど、見る眼あつげならざるはなし。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "よそでは盛りの少し過ぎた桜もここばかりは真盛りの美しさがあった。",
              "citation": {
                "source": "源氏物語",
                "author": "胡蝶",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがこの聡明な仕事も、南瓜の花の真盛りのころから、ばつたりと止してしまつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰も昨日今日がその真盛りであるらしく見受けられた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉宿の附近はもうその頃はおおかた散っていたが、少し山を登ってゆくと、まだ真盛りであった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その紅葉も真盛りであった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "初秋の真盛りの陽りが碧い空と、熟れる田畑の上に縞をつくつてゐた。",
              "citation": {
                "source": "ベツコウ蜂",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「斯く詠じ終りて、腹掻き切つてぞ果にけり――といふんだつたかね……」　銀原の声を聞きながら私が、もう一度村の上を振り返ると、桃の花が、今やもう真盛りのやうに陽に映えて、色とりどりの鎧武者がまことに浮きつ沈みつしてゐるやうな光景であつた。",
              "citation": {
                "source": "武者窓日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とまあ自分は気の毒な慌て者だつたことだらう――彼は辛うじて間に合つた汽車の窓に腕をのせて、真盛りの莱畑を眺めながら、あんな手紙位ゐでこんなにも一個の人間が有頂天になるものか！",
              "citation": {
                "source": "陽に酔つた風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭には海棠の花が真盛りに満ちてゐた。",
              "citation": {
                "source": "鶴がゐた家",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "海沿いの公園では夾竹桃が真盛りであった。",
              "citation": {
                "source": "石油の都バクーへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山百合が真盛りだった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャガ芋の花は白く真盛りに咲いている。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅林があり、白梅が真盛りで部屋へ薫香が漲っていたのをよく覚えている。",
              "citation": {
                "source": "宝に食われる",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "キュリー夫人は土用真盛りの、がらんとしたアパートの部屋でブルターニュの娘たちへ手紙を書いた。",
              "citation": {
                "source": "キュリー夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと胡瓜の真盛りになるともう出ないというような儲のとらえかたも、わかりはするが閉口です。",
              "citation": {
                "source": "近頃の商売",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "神社の庭には天狗がおもちゃにするというまさかり、かま、太刀などが、散乱している。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
