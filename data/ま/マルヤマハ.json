      {
        "index": 1,
        "gloss": "Maruyama school of Japanese painting (Edo-Meiji period)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
