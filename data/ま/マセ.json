  {
    "uuid": "35a2745b-78e5-5897-894b-5d618b90457f",
    "entry": "籬",
    "reading": {
      "primary": "ませ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "short roughly woven fence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鶯のあちこちとするや小家がち「籬落」という題がつけてある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三径の十歩に尽きて蓼の花　十歩に足らぬ庭先の小園ながら、小径には秋草が生え茂り、籬に近く隅々には、白い蓼の花が侘しく咲いてる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに泰子、いまこそは暮るる籬や群青の空もしづかに流るころ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋より下の方、東に向つて川の流るゝこと少許にして汽車のための鉄橋の下を過ぎ、右に○塩入村の茅舎竹籬を見、左に蘆葭の茂れるを見ながら一折して、終に南に向つて去る。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ新しくて青き光失せぬ建仁寺籬折りまはしたる小さき坪の中に咲き出でたる、あるはまたよろづ黒みわたりたる古き大寺の書院の椽近く※ひこぼるゝなど、云ひがたき佳きおもむきあり。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "生籬などに籠めらるれど恨む顔もせず、日の光りも疎きあたりに心静けく咲きたる、物のあはれ知る人には、身を潜め世に隠れたるもなか／＼にあはれ深しと見らるべし。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "籬にしたるは、卯の花とおもむき異にして、ゆかしさ同じ。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "山桜桃　にはうめは、いと小さき花の簇れて咲くさま、花の数には入るべくもあらず見ゆるものながら、庭の四つ目籬の外などに、我は顔もせず打潜みたる、譬へば田舎より出でたる小女の都慣れぬによろづ鼻白み勝にて人の背後にのみ隠れたるが、猶其の姿しほらしきところ人の眼を惹くが如し。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを籬にしたるは奢りがましけれど、処子が家にもさばかりの奢りはありてこそ宜かるべけれ。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "広き庭にては池のあなた、籬の隅、あるは小祠の陰などのやゝ高き樹。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧しげなる家の頽れかゝりたる納屋のほとり、荒れたる籬の傍などに咲きたる、春の物としも無く悲し。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "古りたる園の、主変りて顧みられずなり行き、籬は破れ土は瘠せ、草木も人の手の恵に遠ざかりたるより色失せ勢｜萎へて見る眼悲しくなりたるが中に、此花の喬き常盤樹の梢に這ひ上りて、おのが心のまゝに紫の浪織りかけて静けく咲き出でたるなど、特に花の色も身に染みてあはれ深きものにぞ覚ゆる。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "籬などに纏ひつきつ、風車のようなる形して咲き出でたる花の色白く大なるが程よく紫ばみたる、位高く見えて静に幽なるところある美はしきものなり。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳳仙花　前栽の透籬の外などに植ゑたるは、まことによし。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "折から葭籬のもとに、いつのこぼれ種子やら朝顔の二葉土を離れて、我がやどすてぬといへる発句の趣向をあらはす。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "露店中の愛嬌もので、総籬の柳縹さん。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "可懷きは嫁菜の花の籬に細き姿ぞかし。",
              "citation": {
                "source": "五月より",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――就中、南の納戸の濡縁の籬際には、見事な巴旦杏があつて、大きな實と言ひ、色といひ、艷なる波斯の女の爛熟した裸身の如くに薫つて生つた。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　紅葉先生、その時の態度は……采菊東籬下、悠然見南山。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い額、蒼い頬――辛うじて煙を拂つた絲のやうな殘月と、火と炎の雲と、埃のもやと、……其の間を地上に綴つて、住める人もないやうな家々の籬に、朝顏の蕾は露も乾いて萎れつゝ、おしろいの花は、緋は燃え、白きは霧を吐いて咲いて居た。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "両側をきれいな細流が走って、背戸、籬の日向に、若木の藤が、結綿の切をうつむけたように優しく咲き、屋根に蔭つくる樹の下に、山吹が浅く水に笑う……家ごとに申合せたようである。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "籬ほどもない低い石垣を根に、一株、大きな柳があって、幹を斜に磧へ伸びつつ、枝は八方へ、座敷の、どの窓も、廂も、蔽うばかり見事に靡いている。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "槿の花の咲いている竹籬に沿うて左に曲ると、正面に釈迦堂がある。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして遠い曾祖母の過去に於て、かれらの先祖が縁組をした如く、今も同じやうな縁組があり、のどかな村落の籬の中では、昔のやうに、牛や鷄の聲がしてゐる。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして遠い曾祖母の過去に於て、かれらの先祖が縁組をした如く、今も同じやうな縁組があり、のどかな村落の籬の中では、昔のやうに、牛や鶏の声がしてゐる。",
              "citation": {
                "source": "散文詩集『田舎の時計　他十二篇』",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻に深刻な眼で恨まれたこともあったろうが、それは籬の外の蛍ぐらいにしか見えなかったであろう。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜の花畠、麦の畠、そらまめの花、田境の榛の木を籠める遠霞、村の児の小鮒を逐廻している溝川、竹籬、薮椿の落ちはららいでいる、小禽のちらつく、何ということも無い田舎路ではあるが、ある点を見出しては、いいネエ、と先輩がいう。",
              "citation": {
                "source": "野道",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "土耳古帽氏が真鍮刀を鼠股引氏に渡すと、氏は直にそれを予に逓与して、わたしはこれは要らない、と云いながら、見つけたものが有るのか、ちょっと歩きぬけて、百姓家の背戸の雑樹籬のところへ行った。",
              "citation": {
                "source": "野道",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "籬には蔓草が埒無く纏いついていて、それに黄色い花がたくさん咲きかけていた。",
              "citation": {
                "source": "野道",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖書の綱が性慾のコマを廻す原始人の礼儀は外界物に目も呉れないで目前のものだけを見ることでしただがだが現代文明が筆を生みました筆は外界物です現代人は目前のものに対するにその筆を用ひました発明して出来たものが不可なかつたのですだが好いとも言へますから――僕は筆を折りませうか？",
              "citation": {
                "source": "迷つてゐます",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
