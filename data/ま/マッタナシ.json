          "literary": [
            {
              "text": "待ったなしに食い込んでいるのだ。",
              "citation": {
                "source": "那珂川の鱸釣り",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ強いてつけましょうなら、『待ったなし流』とでも申しましょうか。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アッハハハ自己流でござんす」「待ったなし流？",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へい、わっちが待ったなし流で、じっと構えておりますと、相手の野郎はいい気になって、ちょくちょく切り込んで参ります。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうやって充分引きつけて置いて、いよいよ気合いが充ちた時、それこそ待ったなしでございますな、一撃にぶっ潰すのでございます」忠次はここでニヤリとした。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千葉道場へやって来たのも、深い魂胆があったからではなく、自分の我無沙羅な「待ったなし流」を、見て貰いたいがためであった。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ったなしでお願い申さあ。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "賭けの勝負は親子の間だって待ったなしだわよ。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "がんりきを引捕ろうとするような、待ったなしの出足では近寄れない、相手が違う、ということは、近寄る方でも、最初からその勘にあることです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は生れつきするめが嫌いであり、いまなお嫌いで、酒を飲みにいっている店でするめを焼き始めでもすれば、待ったなしに退散するくらいである。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあ」と繁次が訊き返した、「これまではかげんしてたのか」「いいからやんなよ」と参吉がおうように云った、「待ったなしだぜ」　繁次はみじめに負けた。",
              "citation": {
                "source": "落葉の隣り",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "するともう待ったなしで、すぐに支度をし、別れなければならないのであった。",
              "citation": {
                "source": "屏風はたたまれた",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "面目ねえがこの勝負は待ってくれ」「冗戯云っちゃいけねえ、博奕と喧嘩は待ったなしだ。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
