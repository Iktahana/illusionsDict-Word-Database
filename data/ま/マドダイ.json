        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "調べてみるとすぐに血痕が窓台のところに見つかって、転々と落ちた跡が寝室の木の床にも確認できる。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "建物から出る姿は目撃されていないし、窓台の不穏な血痕を考えに入れると、生き延びて泳いでいったとは必ずしも言い切れない。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "グリツプは、窓台の上の籠で陽を浴びてゐた。",
              "citation": {
                "source": "鸚鵡のゐる部屋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――二人は何時になくグリツプの姿を好意を持つて見送りながら学生の部屋に引き返し、そこの窓台に鳥籠を置いた。",
              "citation": {
                "source": "鸚鵡のゐる部屋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "証人のハーカーは窓をあけに行って、わずらわしげに悩みながら窓台に倚りかかっていた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "妖物",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年のまん前の窓台の上には、小さな鏡が一つおいてあります。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、窓台のところに咲いているテンジクアオイやフクシャを眺めました。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
