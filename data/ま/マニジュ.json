        "examples": {
          "standard": [
            {
              "text": "彼は子供の頃から、キラキラと輝く摩尼珠を集めるのが好きだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この物語では、主人公が悪の魔術師から摩尼珠を取り戻す冒険に出る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "摩尼珠は、その美しい輝きから人々に幸運をもたらすと信じられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "女、父の勅を受け、摩尼珠および諸珍宝を持って、これを糞穢に蔵す。",
              "citation": {
                "source": "易の占いして金取り出だしたること",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に梵施王の后｜摩尼珠を失い、我が所は王と長摩納のほか入る者なきにこの珠をなくしたは不審という。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
