[
  {
    "uuid": "53e0e590-b252-5dc8-9ca6-38e44d0c3c2a",
    "entry": "幕切れ",
    "reading": {
      "primary": "まくぎれ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
