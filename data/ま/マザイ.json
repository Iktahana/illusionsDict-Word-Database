    "definitions": [
      {
        "index": 1,
        "gloss": "energy drink (esp. Monster Energy)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
