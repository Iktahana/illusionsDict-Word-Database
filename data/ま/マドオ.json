    "definitions": [
      {
        "index": 1,
        "gloss": "at long distance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "と、喘いでゐたお前の息は丁度臨終の迫つた病人のやうに和いで來、鎭まつて行き、段々に間遠になつて、時々深い吐息がお前の白い咽喉首を脹らました。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、お前の息は殆ど絶えてしまつたかと思はれるやうに幽かに間遠になり、マスクの周圍に見えてゐる頬や額にはほのかな血の赤みが差してゐた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、其處にはお前の間遠な息が靜に聞えてゐるばかりだつた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、程近くのイギリス人の家でいつとなく鳴りはじめたピヤノの音が、その沈默をくすぐるやうに間遠に聞こえてたただ一｜脚のトイスが、いや、あまりにもそれとかけ隔たつたさういふみじめな現実のすべてがうつすりとよみがへつて※た。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "極く丈の詰った影で、街燈が間遠になると鮮かさを増し、片方が幅を利かし出すとひそまってしまう。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に小田原の町を放れ、函嶺の湯本近に一軒、茶店の娘、窶れ姿のいと美しきが、路傍の筧、前なる山凡そ三四百間遠き處に千歳久しき靈水を引いたりといふ、清らかなる樋の口に冷たき其の土を洗ふを見て、山の芋は鰻になる、此の牛蒡恁くて石清水に身を灌がば、あはれ白魚に化しやせんと、そゞろ胸に手を置きしが。",
              "citation": {
                "source": "城の石垣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "間遠に立っている七、八軒の家の前を過ぎた。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも花繁く間遠からではをかしからじ。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼈甲屋や、衣裳屋、指物屋なぞの出入りが間遠になって来たのは、どうも怪訝しいと言う近所界隈の取沙汰じゃ……吾々もドウモそこいらが臭いような……事件の起りはその辺ではないかと言いたいような気持がするが、それから奥の深い事情が一つも判然らんけに困っとる。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護婦が間遠に眞白な印象を殘して廊下に輕やかな草履の音を立てた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は、間遠いので評判な、外濠電車のキリキリ軋んで通るのさえ、池の水に映って消える長廊下の雪洞の行方に擬う。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この声が聞えるのには間遠であった。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "間遠に立つてゐる七八軒の家の前を過ぎた。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三）謙信が幾太刀も斬りつけながら信玄を打ち洩したのはダラシがないようだが、馬上の太刀打で間遠でどうにもならなかったらしい。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし間遠く鳴く波の音ばかりで足音らしいものは聞えなかつた。",
              "citation": {
                "source": "海異志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日の月はほんのりと庭の白沙を照らして、由比ヶ｜浜の方からは穏かな波の音が、ざアーア、ざアーアと云うように間遠に聞こえていた。",
              "citation": {
                "source": "頼朝の最後",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時は極めて間遠に、或時は釣瓶打に烈しく啼く。",
              "citation": {
                "source": "樹木とその葉",
                "author": "若葉の山に啼く鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "間遠に荷車の音が、深夜の寂寞を破ったので、ハッとかくれて、籐椅子に涼んだ私の蔭に立ちました。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の間遠ざかるほど、人数を増して、次第に百騎、三百騎、果は空吹く風にも聞え、沖を大浪の渡るにも紛うて、ど、ど、ど、ど、どツと野末へ引いて、やがて山々へ、木精に響いたと思ふと止んだ。",
              "citation": {
                "source": "二世の契",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十番はどっちへあたるか、二の橋の方は、と思うと、すぐ前を通るらしい豆府屋の声も間遠に聞え、窓の障子に、日が映すともなく、翳るともなく、漠として、妙に内外が寂然する。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまらぬ浜田への意地でそんな手間遠い真似をするより、少しも早く今こゝで浜田へ頼むで蘭丸に会はしてもらはうと思つた。",
              "citation": {
                "source": "蘭丸の絵",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さばかり間遠なりし逢瀬なるか、言はでは裂けぬる胸の内か、かく有らでは慊らぬ恋中か、など思ふに就けて、彼はさすがに我身の今昔に感無き能はず、枕を引入れ、夜着引被ぎて、寐返りたり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "思わず身をすり寄せて、素足のままのフランシスの爪先きに手を触れると、フランシスは静かに足を引きすざらせながら、いたわるように祝福するように、彼女の頭に軽く手を置いて間遠につぶやき始めた。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "間遠に日本橋を渡る鉄道馬車の音が聞こえるばかりで、釘店の人通りは寂しいほどまばらになっていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "苔香園のほうから園丁が間遠に鋏をならす音が聞こえるばかりだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほう、ほう……ほう、ほうほうと間遠に単調に同じ木の枝と思わしい所から聞こえていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くの部屋でディフテリヤにかかっている子供の泣く声が間遠に聞こえるほかには、音という音は絶え果てていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時は極めて間遠に或時は釣瓶打ちに烈しく啼く。",
              "citation": {
                "source": "山寺",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "おりからからりと明けて、雪も間遠にちらりほらり……。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "間遠にちらりほらりと、いまだに降りつづけている淡雪を浴びながら、庭先伝いに歩みよると、うち騒ぐ色も見せずに、烱々とまなこを光らしながら、いま一度三つの窯を見比べました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
