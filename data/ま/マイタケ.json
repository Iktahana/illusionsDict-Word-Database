        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "秋の味覚である舞茸をたっぷり入れた炊き込みご飯の香りが、食欲をそそる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "舞茸を天ぷらにすると、サクサクとした独特の食感と芳醇な風味が楽しめる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "近所のスーパーで、肉厚で立派な株の舞茸がお買い得価格で売られていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "松茸、初茸、木茸、岩茸、占地いろ／＼、千本占地、小倉占地、一本占地、榎茸、針茸、舞茸、毒ありとても紅茸は紅に、黄茸は黄に、白に紫に、坊主茸、饅頭茸、烏茸、鳶茸、灰茸など、本草にも食鑑にも御免蒙りたる恐ろしき茸にも、一つ一つ名をつけて、籠に裝り、籠に狩る。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人夫が採って来た茶盆大の舞茸は、小山の如く莚に積まれて居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞茸の味噌汁が来る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は附近の地名に就て質し、吹切、野脇、湯ノ沢ドウミ（湯沢峠）などいう名を覚えた、干した舞茸の煮つけたのも珍しかった。",
              "citation": {
                "source": "初旅の大菩薩連嶺",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初茸、シメジ、獅子茸の類は初秋のものに属し、椎茸は仲秋（椎茸は総じて秋季に生ずるものにめざましいものは少く、却って春季に生ずるものを尊ぶ）に生じ、松茸、猪の鼻、舞茸、玉茸の類は仲秋から晩秋にかけて多いようである。",
              "citation": {
                "source": "茸をたずねる",
                "author": "飯田蛇笏",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて用意したる米味噌をとりいだし、今朝清水河原村にてもとめたる舞茸にこゝの芋などとりそへて、案内が料理すとて雷盆をといへば、末の娘が棚のすみよりとりいだしたるを見れば、常にはつかはずと見ゆるすゝけたるなり。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の寝床へもぐり込まれてしまって、兵馬は、唖然として舌をまいたけれども、こうなってみると、かえっておかしくもあり、同情心も出て来るので、この上にいっそう荒々しく、夜具を引きめくって、女をつまみ出そう、という気にはなれません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "みちりやの巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
