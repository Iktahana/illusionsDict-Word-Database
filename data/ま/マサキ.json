    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the head",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "同時に食事していた客の誰よりも真先に自分のところへこの菓物鉢が廻って来たので、自分は遠慮なくこのただ一つの柿を取上げた。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "清水で下車して研究所の仲間と一緒になり、新聞で真先に紹介された岸壁破壊の跡を見に行った。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本帝国主義ハ、真先ニ掠奪スルタメニ有利ナル戦略的状勢ヲ利用シテ、諸君ヲコノ地ヘ来ラシメタ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな場合、いつも真先に睨まれる高取は、頭に角のようなコブが出来ていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　防寒帽子をかむり、防寒肌着を着け、手袋をはき、まるまるとした受領の連中が扉を開けて這入ってくると、待っていた者は、真先にこうたずねた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は真先に出会した時は笠を被って竹杖を突いたまま、はッと息を引いて膝を折って坐ったて。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕車を雇って、さして行く従姉の町より、真先に、「あの山は？",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなその、紅立羽だの、小紫だの、高原の佳人、お安くないのにはおよばない、西洋化粧の化紫、ござんなれ、白粉の花ありがたい……早く下界へ遁げたいから、真先に自動車へ。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより下流は川の深処東より移りて漸く西の岸に沿ひ、有名なる○真先稲荷前を過ぐる頃は、東は甚だ浅く西は大に深きに至る。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "石浜神社は小社なれどもその古きをもて知られ、真先稲荷は社前に隅田川を控て、遥に上は水神の森鐘が淵のあたりより下は長堤十里白くして痕なき花の名所の向島を一望の中に収むるをもて名あり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん近づくのを見ると、行列の真先には牛や馬や驢馬や豚や鶏が来る。",
              "citation": {
                "source": "夢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にも総理大臣は騎兵を繰り出して真先に立って馬を躍らせながら、何処までもとあとをつけて行きました。",
              "citation": {
                "source": "犬の王様",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼を覚ますと、もう朝日がいっぱいに射していたが、小恥かしい気分の中で真先に意識に上ってきたのはガンベのあの醜い皮肉な片眼の顔だった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は真先に神田の三崎町にあるトゥヰンビー館に行って円山さんに会った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お末の家で四月から追つかけ／＼死に続いた人達の真先きに立つたのは、長病ひをした父だつた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに真先に貸本に楽書をするのがお客でなくておんつぁん自身だつた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "斉しく俯向いて、莞爾々々と笑ってばかり、黙って、ついて歩行いた、お千世が、衣の気勢にそれと知って、真先に、「今晩は、」「おお、千世ちゃん。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）白寮権現の神職を真先に、禰宜。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（と言うままに、真先に、梟に乗憑られて、目の色あやしく、身ぶるいし、羽搏す。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ジャム、」　真先に駈けて入った猟犬をまず見着けたのは、当｜館の姫様で勇美子という。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸端で水を浴びたり、合長屋の障子を、ト唾で破いて、その穴から舌を出したり、路地の木戸を石※でこつこつやったり、柱を釘で疵をつけたり、階子を担いで駆出すやら、地蹈鞴を蹈んで唱歌を唄うやら、物真似は真先に覚えて来る、喧嘩の対手は泣かせて帰る。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は真先に世間外に、はた世間のあるのを知って、空想をして実現せしめんがために、身を以って直ちに幽冥に趣いたもののようであるが、婦人はまだ半信半疑でいるのは、それとなく胸中の鬱悶を漏らした、未来があるものと定り、霊魂の行末が極ったら、直ぐにあとを追おうと言った、言の端にも顕れていた。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヤッ橋が落ちてるぞッ」と真先に立ちたる未醒君、立留まって、一行を顧みた。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前様方刑事かね」と、ここから真先に逃げているように見える髯将軍は泥棒と間違えられ、吾輩等は刑事と相成った次第。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、どやどやと人の足音がして、真先に黒服の看守が立つて、二組の囚人が門の外へ出て来た。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　黄金の雲なんか真先よ。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "金時｜真先に二の足踏み、「得右衛門もう帰ろうぜ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "朽葉色に垢附きて、見るも忌わしき白木綿の婦人の布を、篠竹の頭に結べる旗に、（厄病神）と書きたるを、北風に煽らせ、意気揚々として真先に歩むは、三十五六の大年増、当歳の児を斜に負うて、衣紋背の半に抜け、帯は毒々しき乳の上に捩上りて膏切ったる煤色の肩露出せり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　呼ぶ時遅し五六人、今の二人の魂消りしに何事ならんと駈附けつ、真先なるは時次郎、「照子様、どうなさいました、幽霊が出ましたかね。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は真先に、戸外へ、鉄砲玉のように飛出しました。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
