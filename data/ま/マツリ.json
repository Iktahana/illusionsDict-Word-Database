      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "festival",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "お祭りのまえの日、というものは、清潔で若々しく、しんと緊張していていいものだ。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伏見人形に思い出す事多く、祭り日の幟立並ぶ景色に松蕈添えて画きし不折の筆など胸に浮びぬ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祭りのまへの日、といふものは、清潔で若々しく、しんと緊張してゐていいものだ。",
              "citation": {
                "source": "春晝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは庭の祭りのかがり火であった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえの居ると同じ屋の棟の下にいれば気が済むのだから、決して祭りの邪魔はしないのだから」「それが、おさせ申上られないことは、お出でにすぐ申上げたではございませんか。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは、暁の祭りにいそしまねばなりません。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると町〔の〕家々ではこんやの銀河の祭りにいちゐの葉の玉をつるしたりひのきの枝にあかりをつけたりいろいろ仕度をしてゐるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野口氏の本質的心境たる熱情を、世間の人は殆んど知らず、皮相なる氏の表皮からして、いたづらに氏をクラシツクの詩匠として所謂「世界的詩人」の無意味な神殿に祭りあげてる。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、私の仕事は、それを私が非常に愛してゐたがために、いつの間にか、稀有な靈感に起因する、大袈裟な行事、お祭り騷ぎになつてしまひました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の秋のお祭りに、太鼓を舁いだり、幟をさしたり、一張羅の着物を着てマチへ出る村の人々は、何等か興味をそゝって話の種になったものだが、東京の街で見るものは彼等にとって全く縁遠いものだった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上田の町を歩いている頃は高原の太陽が町のアスファルトに照り付けて、その余炎で町中はまるで蒸されるように暑く、いかにも夏祭りに相応しい天気であった。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか気になるので、五月の末に無沙汰の詫びながら手紙を出すと、すぐその返事が来て、来月は氷川様のお祭りで強飯でも炊くから遊びに来てくれとのことであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしも急に老人に逢いたくなって、そのお祭りの日に赤坂に出て行くと、途中から霧のような雨が降って来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今年は本祭りだというのに、困ったもんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祭りはどうしても夜のものですよ」　老人に案内されて、わたしは町内の飾り物などを観てあるいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "この情熱によって、彼等は、市街戦で殺された日本人の約十五倍の支那人を血祭りにあげていた、屍体を蹴とばした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に柳は、今はその細長い葉をすっかり落して、冷たい風にほんのすこしゆれ、そのてっぺんの青ぞらには、町のお祭りの晩の電気菓子のやうな白い雲が、静に翔けてゐるのでした。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭日〔一〕谷権現の祭りとて、　　　　　麓に白き幟たち、むらがり続く丘丘に、　　　　鼓の音の数のしどろなる。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると町の家々ではこんやの銀河の祭りにいちいの葉の玉をつるしたりひのきの枝にあかりをつけたりいろいろ仕度をしているのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外界のありさまが遠い祭りのやうに思ひなされる。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて祭りが済めば芻狗は不要だ。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "睛、沁芳の泉、楓露の茗四つのものを捧げ、嘔心の文を念じつ祭りしといへるものがたりいとをかし。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために昔のギリシア人はこの地を人格化して神と祭り上げてしまった。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐘に血を塗るというのは、本来はおそらく犠牲の血によって物を祭り清めるという宗教的の意義しかなかったのであろうが、しかし特に鐘の割れ目に塗るということがあったとすると、それは何かしら割れ目のために生じた鐘の欠点を補正するという意味があったのではないかと疑わせる。",
              "citation": {
                "source": "鐘に釁る",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしか富士吉田町の火祭りの光景を写したものの中に祭礼の太鼓をたたく場面がある。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれの責任であるとか、ないとかいうあとの祭りのとがめ立てを開き直って子細らしくするよりももっともっとだいじなことは、今後いかにしてそういう災難を少なくするかを慎重に攻究することであろうと思われる。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎では鎮守の祭りや市日の売店があった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の政事に祭り事が必要であったと同様に文化国の政治には科学が奥底まで滲透し密接にない交ぜになっていなければ到底国運の正当な進展は望まれず、国防の安全は保たれないであろうと思われる。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "七夕祭りの祭壇に麻や口紅の小皿といっしょにこのおはぐろ筆を添えて織女にささげたという記憶もある。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも、この、紀元二千｜七百年のお祭りの時には、二千｜七百年と言うか、あるいは二千｜七百年と言うか、心配なんだね、非常に気になるんだね。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
