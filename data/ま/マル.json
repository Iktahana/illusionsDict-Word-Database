    "definitions": [
      {
        "index": 1,
        "gloss": "circle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "少し醉の※つて來た連中は、○○や○○等の百貨店を燒打ちして、すべての高層建築を新宿から一掃しろと主張して居る。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "○オクツタ」ユイノウタノム」ケツコンシキノシタクセヨ」アスペキンタツ」オオスミチユウタロウ　同時に電報｜為替で百円送られて来たのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「○オクッタとありますが、この○というのは、百円の事です。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の日｜偶然○○不動の縁日。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の袋町に○印をして「浅井」とあるのは浅井｜忠氏の家であろう。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○○銀行○○課の一團は物靜かでモーニングを着た官吏風の人が多い。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○○百貨店○○支店の一行は和服が多く、此方は藝者を揚げて三絃の音を響かせて居るが、肝心の本職の藝者の歌謠の節※はしが大分危なつかしく、寧ろ御客の中に一人いゝ聲を出すのが居て、それがやゝもすると外れかゝる調子を引戻して居るのは面白い。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも何一つ持出すひまもなく、昨夜上野公園で露宿していたら巡査が来て○○人の放火者が徘徊するから注意しろと云ったそうだ。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○を押さえると△があばれだす。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　夏の初から――六月の半頃から三月以上もかけ續けてやうやく古びた竹の簾。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　今迄かつと照り渡つてゐた初秋の空に僅か飛行船程の暗雲が浮んだ。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　黄色い小菊の花が一つ路上に棄てゝある――。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　震災の年の秋には雨が多かつたやうに覺えてゐる。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○彼女はじっとして居られなくなった。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○「恋など馬鹿らしくて出来なくなりましたわ」と言う。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」○彼女に取ってスピーディで無いものは魅力が無い。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」○チョコレートを食べられる暇さえある職業だったら職業というものは何という好もしいものでしょう。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○繕った靴下でも穿くときは皺の寄らないように。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ近頃の世の中は、――尠くとも知識階級は、まるで肚が坐つてゐない。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭日〔二〕宮沢賢治アナロナビクナビ睡たく桐咲きて峡に瘧のやまひつたはるナビクナビアリナリ赤き幡もちて草の峠を越ゆる母たちナリトナリアナロ御堂のうすあかり毘沙門像に味噌たてまつるアナロナビクナビ踏まるゝ天の邪鬼四方につゝどり鳴きどよむなり",
              "citation": {
                "source": "祭日〔二〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論かういふことは、一々の短歌作品、一々の俳句作品に就いてそつくりそのまま当箝まることではないけれども、夫々の様式を規範的に観た場合そのやうに言ふことは先づ間違ひない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それといふのが、これが都より田舎へ出すのであれば、何音楽会に行きました、何展覧会に行きました等々の、謂はば事件があるわけですが、こちらでは、何を豊富に感じてゐるとも、それが事件の形を採りませんので、書くことがまるでないやうな有様にもなるのだと、今更思ひ知る次第です。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて中の一人が、「云ふことは分らないから、一つ農学士様の話す様子を見てやらう」といふことになり、「なんだい、まるで腰抜みたいぢやないか。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚黙りつゞけるとしても、Ａは兎も角女給なり、従つて酒場の空気なりと交流が始まる。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "開化の段階の低いことが、一朝一夕にして高まることはなく、多くの個人の不撓の努力を要することは勿論でありますが、何れにしろ事態打開の先づ第一歩は、「若い身空でイヤな病気」と感ずる前に、「病気の軽重と処分の軽重」が判明に頭なり良心なりに来ること、それに違ひはないと思ふのであります。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、此処で此の世の、世間の評価、通価といふものは定まるのである。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処の景色を私は好きである、坂は段々勾配を増し、酔つて夕陽に照らされてスタコラゆけば、まるで我が身か、我が身が運ぶ箱か分らず、多分今飲んだビールを運ぶ容器であるに相違なからう。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで計算尺をでも置いたやうに。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから私もも少し具体的に話してみようとしたのだが、彼は「いいかオイ」といつた調子でまるで私の気持にはお構ひないのだ。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "長さ二町ばかりの、その暗い湿つぽい通りに、今挙げたホンの三四軒の店屋が所々にあるのは、まるで蛍でもゐるやうな感じだつた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
