        "examples": {
          "standard": [
            {
              "text": "水族館の巨大な水槽で、翻車魚がのんびりと横向きに泳いでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "漁師の網に偶然かかった翻車魚は、そのあまりの大きさに周囲を驚かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "翻車魚の独特なフォルムを見ていると、自然の造形の不思議さを感じる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "使者二　私共は素早く、馬鹿正直の翻車魚を捕えました。",
              "citation": {
                "source": "対話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
