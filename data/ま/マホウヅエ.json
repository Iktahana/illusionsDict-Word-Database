        "examples": {
          "standard": [
            {
              "text": "魔法杖の先端から、眩いばかりの光線が放たれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は代々伝わる魔法杖を手に、最後の決戦へと向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "魔法杖を正しく扱うには、強い精神力と集中力が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "魔法杖でもちょいと振りゃ、娘ふたりがダンスの沓にもなりそうだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "』そして見てゐるとえぐり出されたとうなすは教母の魔法杖で最上等の馬車に変つた。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分の魔法杖に古糸を付けることを考えだした。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "大量の荷箱がロンドンから、メアリの魔法杖の一振りで、つまり小切手帳によって、運ばれてきた。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
