    "definitions": [
      {
        "index": 1,
        "gloss": "burying in the ground",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "川、章邱等に約十八億トンの石炭が埋蔵されている。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若紳士が言ったのは、例の、おいてけ堀、片葉の蘆、足洗い屋敷、埋蔵の溝、小豆婆、送り提燈とともに、土地の七不思議に数えられた、幻の音曲である。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何百年の間、武蔵相模の土に亙って逞しい埋蔵力を持ちながら、葡い松のように横に延びただけの旧家の一族に付いている家霊が、何一つ世間へ表現されないのをおやじは心魂に徹して歎いていたのだ。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分でも意識し尽せぬ深い天然の力が、白痴であれ、田舎娘であれ、女に埋蔵されてゐて、強い情熱の鈎にかゝるときに等しくそれが牽き出される。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が想像した通り、かれらは何かの埋蔵物を掘出すために、幾たびか忍んで来たらしい。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "金蓮は、伏して念う、某、殺青を骨となし、染素を胎と成し、墳※に埋蔵せらる。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金蓮は、伏して念う、某、殺青を骨となし、染素を胎と成し墳壟に埋蔵せらる、是れ誰か俑を作って用うる。",
              "citation": {
                "source": "牡丹燈籠　牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉱山は特殊な鉱物を埋蔵しているので自然と平々凡々な普通の山とは異なるから、気も自然に各々相異なる理屈である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "埋蔵量六百万｜噸――会社の事業の大半はこの炭坑一本に賭けられて、人も機械も一緒くたに緊張の中に叩ッ込まれ、きびしい仮借のない活動が夜ひるなしに続けられていた。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "またどういう仔細があったか知らぬが、維新の際に七十万両の古金銀を石の蓋匣に入れて地中に埋蔵したそうだ。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が想像した通り、かれらは何かの埋蔵物を掘り出すために、幾たびか忍んで来たらしい。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、支那に埋蔵された原料は同情の故をもって埋蔵を赦すなら、どこに生産の進歩があるか、どこに消費の可能があるか。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本は進歩のために、あらゆる手段を用いて、埋蔵された原料を発掘するのだ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "満州国の鉄の埋蔵量もすばらしい。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄資源としては日本は砂鉄は世界無比豊富であり、満州国の鉄はその埋蔵量莫大である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "地殻の物語は、そこに在る火山、地震、地球の地殻に埋蔵されてある太古の動植物の遺物、その変質したものとしての石炭、石油その他が人間生活にもたらす深刻な影響とともに、近代社会にとって豊富なテーマを含蓄している。",
              "citation": {
                "source": "科学の常識のため",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一条　ロシア社会主義連邦ソヴェト共和国領域内ニオケル土地、地中埋蔵物、水域、森林オヨビ生ケル自然力ニ対スル私有権ハ永久ニ之ヲ廃止ス。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "池田の家の床下に埋蔵せられてゐた火薬は終に爆発した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の立つてゐる地面の真下には、櫃や鍋にいれた金貨だの宝石だのが、うづたかく埋蔵されてゐるのだつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは又、上野介が小細工という説も有るが、勿論地図も出たろうなれど、それには露骨に黄金埋蔵とは書いてなかったので、単に金山脈の書入れとでも見たものか、何の沙汰にも及ばなんだ。",
              "citation": {
                "source": "怪異黒姫おろし",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして子息｜藤十郎以下七人は、同年七月二十日、礫刑に処せられ、召使の者等も死罪やら遠流やら……」「そう承わると、黄金埋蔵は、本当に相違御座りませぬな」「三増峠の老人よりは、勿論印籠を譲られたので、二重底を探って切図は得た。",
              "citation": {
                "source": "怪異黒姫おろし",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "その附近にある諸山の鉱区を合せて埋蔵量二億噸と計上されてゐる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "石炭は半無煙炭で、埋蔵量弐億噸、鉄は磁鉄鉱で総量八千万噸と云はれる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はひとりとなって後、いよいよ巨万の富をひとり占めするつもりで屋敷を後にして水鉛の埋蔵されている場所へ入ったが、それは私の思いちがいで、本当の埋蔵場所ではなかった。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれからもヤリウス様を責め、あるいは自分でいろいろ書類などを調べ、水鉛の埋蔵場所を知ろうとしたが、だめだった。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "水鉛鉛鉱の埋蔵場所はどこだ。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つは、水鉛鉛鉱の埋蔵場所というのは時計屋敷の真下だったことである。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまいぞうまいぞ」などというそれ等の言葉は、本気とも冗談ともとれた。",
              "citation": {
                "source": "一本の花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うまいぞうまいぞ」と喝采するものがある。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「主はだれ、むらさきの覆面二十三騎くつわをならべて……タララララタ、タララララタ、プカプカプカララララララ」「うまいぞうまいぞ」と一同が喝采した。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
