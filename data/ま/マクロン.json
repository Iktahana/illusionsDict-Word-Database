        "examples": {
          "standard": [
            {
              "text": "ローマ字で長音を表すために、母音の上にマクロンを書き加えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ラテン語の教科書では、母音の長短を区別するためにマクロンが多用されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「A」の上に横棒を引く記号はマクロンと呼ばれ、音声学の講義で習った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "飴玉とマクロン　ノラの食べる菓子を予はマクロンと書いた。",
              "citation": {
                "source": "翻譯に就いて",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋の女がマクロンを食ふ場合と、日本の子供が飴玉を食ふ場合との相違はどの位違ふか、少し考へて見るが好い。",
              "citation": {
                "source": "翻譯に就いて",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰やらの小説に、パリイの女學生二人がカルチエエ・ラテンの下宿あたりでマクロンを頬張りながら失戀の話をしてゐる所がある。",
              "citation": {
                "source": "翻譯に就いて",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
