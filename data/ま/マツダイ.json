[
  {
    "uuid": "cb52b7e2-1706-5acd-9a65-80a2c2d69b25",
    "entry": "末代",
    "reading": {
      "primary": "まつだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
