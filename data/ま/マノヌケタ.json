        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いわゆるプロ絵なるものはどうしてああ鈍い色彩の間の抜けた構図ばかりしなければならないか了解が出来ない。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とも云わずに、この間の抜けた「阿呆！",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ村から来ている二三の連中が、暫らくして、狐につまゝれたように、間の抜けた顔をして這入って来た。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白日のもとに見るとあれはいかにも手持ちぶさたな間の抜けたものである。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが遠いので間の抜けた時に鳴った。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（さればさの、頓馬で間の抜けたというのはあのことかい。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は自身のこの不安を、友人に知らせたくなかったので、懸命に佐吉さんの人柄の良さを語り、三島に着いたらしめたものだ、三島に着いたらしめたものだと、自分でもイヤになる程、その間の抜けた無意味な言葉を幾度も幾度も繰返して言うのでした。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日増しのお経みたようなものを大勢で唸っている横で、鼻の詰まったようなイキンだ掛け声をしながら、間の抜けた拍子で鼓や太鼓をタタク。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそうだとすれば、この三人兄弟を張りに来るその芸者を、張りにやって来る男の客ほど世に間の抜けたものはあるまい。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "五六行程の豆記事として新聞に載ったのもありますが、間の抜けたところが、却って都に住む方々の興味を惹くかも知れぬと存じまして、記憶しているだけ書いてみました。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "失敬するぜ」　気まずい場所に、永くとどまっているほど間の抜けた堀木ではありませんでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムカシ　ムカシノオ話ヨ　などと、間の抜けたやうな妙な声で絵本を読んでやりながらも、その胸中には、またおのづから別個の物語が※醸せられてゐるのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は娘の間の抜けたところを悠々と味いながら叱りもし罵りもできた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "間の抜けた事を聞くな。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は間の抜けた顔で答える。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女は困ったような顔をして、妙に間の抜けた笑いを浮べながら、でもとにかく質問の意味は解ったらしかった。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、間の抜けた、困却しきった微笑を浮べて横に首をまげながら、媚びていいものか、どうか、という風に、客の顔色をうかがった。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（然ればさの、頓馬で間の抜けたといふのは那のことかい。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒い銘仙絣の単衣を短かく着て帯の結びばかり少し日本の伝統に添っているけれど、あとは異人女が着物を着たようにぼやけた間の抜けた着かたをして居る。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "影か、骨か、何かが一けた足りなくて、あの徒らに高い北欧の青空の下に何処か間の抜けた調子で立ち並んでいるのであった。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際間の抜けた話ではあるが、上から落ちてくる球をヘッディングしようとして、ちょっと頭をさげた途端に、その同じ球を狙った足に、下から眼のあたりをしたたか蹴られたのである。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄汚ない長い顔には、白く乾いた脣のまわりに疎らな無精髭がしょぼしょぼ生えて、それが間の抜けた表情を与えてはいるが、しかし、又、其の、間の迫った眉のあたりには、何かしら油断の出来ない感じをさせるものがあるようだ。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し、その表現はいつもの通り度を越して間の抜けたものであり、その発声は曖昧で緩慢で、かつ何度も同じ事を繰返すのだから、解りにくいこと夥しい。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小豆と石油缶の音は、実物の汽車よりも間の抜けた音を出す。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドンナ立派な背景や大道具、小道具を使っても、役者がヘボだと、ただそんな物の並んでいるだけの、間の抜けた舞台面になる。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も出て来ないと分ると、豹一は自分の行動が妙に間の抜けたものに思われて来た。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "日頃慎ましくしていても、こんな場合の女はがらりと変ってしまうものかと、間の抜けた観察を下しながら、しかし私は身も世もあらぬ気持で、「結婚しようね、結婚しようね」と浅ましい声を出していた。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ふむふむ……そいつは、妹さんが税関で引っかゝるなんて、まのぬけたことをやったもんだね。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくときの、希望にみちた心持ちにひきかえ、帰りの、なんという、まのぬけた、はぐらかされたような心持ちでしょう。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "まのぬけたことばかりやっていやがって、このとおり抜けめがねえもねえもんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
