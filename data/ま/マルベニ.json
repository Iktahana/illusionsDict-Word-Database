          "literary": [
            {
              "text": "「紅丸紅丸、面白かったなあ」薬草道人の声である。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「紅丸紅丸、大風が吹くぞよ」　不安そうに道人云ったものである。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の部は丸紅商店てのゝ買切で、客はいつもより高級だ、大笑ひはしないがよく分るらしい、「ガラマサ」よく出来た。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「弥次喜多」では、徳山が丸紅小唄をうたった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
        }
