    "definitions": [
      {
        "index": 1,
        "gloss": "to deify",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "後日再び奥州から大軍の将として上洛する途上この宿に立寄り懇ろに母の霊を祭る、という物語を絵巻物十二巻に仕立てたものである。",
              "citation": {
                "source": "山中常盤双紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "他からは多くは※祇尼天を祭るとせられたが、山では勝軍地蔵を本宮とするとしていた。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖先を祭るために生きていなければならないとか、人類の文化を完成させなければならないとか、そんなたいへんな倫理的な義務としてしか僕たちは今まで教えられていないのだ。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう事は知っとるが、趣味と情愛の見聞が少かったためじゃろうか、医学士が生理学教室で、雛を祭る、と云うは信じなかった。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は没分暁漢の一巡査であるが、生理学教室に雛を祭ることにおいて、一石橋の朧月一片の情趣を会得した甲斐に、緋緘の鎧の袖に山桜の意気の羨しさに堪えんで。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの、雪を束ねた白いものの、壇の上にひれ伏した、あわれな状は、月を祭る供物に似て、非ず、旱魃の鬼一口の犠牲である。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりあやしければ、いかなるわけのありてかくはいふ事ぞと委敷尋ね問ふに、当国岩城山の神と云ふは、安寿姫出生の地なればとて安寿姫を祭る。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」などと自信ありげに書き出してゐるが、おしまひのはうに到つて、「岩城と津軽の岩城山とは南北百余里を隔て之を祭るはいぶかし。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "神を祭る鬱鬯の氣は即ち鬯氣である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "神社と云ふものがあり、その内の神を祭ると云ふので目的が神秘に化せられる。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "反対に、お誓さんが故郷へ帰った、その瑞兆が顕われたとして、しかも家の骨に地蔵尊を祭る奇特がある。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "観世音は永久にうらわかい町の処女に依て斎がれ（各の町に一体づつの観世音を祭る、物日にはそれぞれある店の一部を借りて開帳し、これに侍づくわかい娘たちは参詣の人にくろ豆を配り、或は小屋をかけていろいろの催をする。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌天竜の水上清み雪祭る族が鬼はよに遊びける「雪祭」幽けきかも「雪祭」幽けきかも、忠はうれしきかも。",
              "citation": {
                "source": "黒檜",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "風を祭る羽虫蜆花、通草咲き満ち、質素なり、この門の夏、放射線――醸す虫なり。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "風を祭る風を祭る、太陽の光に祭る。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "風を祭る、草と木の緑に祭る。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "風を祭る、蒼空の玻璃宮に祭る。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "風を祭る、新潮のとよみに祭る。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "風を祭る、川と洲の魚鱗に祭る。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "風を祭る、菜園の斜面に祭る。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "風を祭る、海港のブイに祭る。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "風を祭る、浴泉のフラフに祭る。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭日〔二〕宮沢賢治アナロナビクナビ睡たく桐咲きて峡に瘧のやまひつたはるナビクナビアリナリ赤き幡もちて草の峠を越ゆる母たちナリトナリアナロ御堂のうすあかり毘沙門像に味噌たてまつるアナロナビクナビ踏まるゝ天の邪鬼四方につゝどり鳴きどよむなり",
              "citation": {
                "source": "祭日〔二〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "名もない一遊子ではあるけれど、私も幼い時から、富士の影を浴びて、武蔵相模で育った一児童として、永い間の外国生活から、故国へ放還された一旅人として、親友と、子供と、忠実なる案内者とに囲まれて、今富士の膝下へ来て亡き母の顔に見えまつるが如く、しみじみと見ているのだ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲雀料理ささげまつるゆふべの愛餐、燭に魚蝋のうれひを薫じ、いとしがりみどりの窓をひらきなむ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴嬢のご機嫌奉仕をつかまつる。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「修行の淺い我々でござれば、果して奇特の有る無しはお受合ひ申されぬが、兎も角も一心を凝らして得脱の祈祷をつかまつると致しませう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "増鏡巻五に、太政大臣｜藤原公相の頭が大きくて大でこで、げほう好みだったので、「げはふとかやまつるにかゝる生頭のいることにて、某のひじりとかや、東山のほとりなりける人取りてけるとて、後に沙汰がましく聞えき」という事があって、まだしゃれ頭にならない生頭を取られたというのである。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「年ふるみ像のみ前にひれふしノートルダームのみ名によりて祈りまつる、わが神のみ母よ……」というような文句であります。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一ツ差上げましょう」と杯を奉まつる。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
