      {
        "index": 1,
        "gloss": "to have the honour of being present (at a meeting, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
