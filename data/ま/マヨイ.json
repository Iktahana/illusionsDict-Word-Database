    "definitions": [
      {
        "index": 1,
        "gloss": "hesitation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "川は、底を傾けて、水を震うので、森の中まで、吹雨が迷い込んで、満山の樹梢を湿す。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　富士の古道　この前に来たときは、裾野の路という路は、馬力のわだちのあとで、松葉つなぎにこんぐらがり、太く細く、土が掘れたり、盛り上ったりして、行人を迷わせたところに、裾野らしい特色があったが、今は本街道然たる、一筋路が、劃然と引かれて、迷いようもなくなった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "木曾の森林にでも迷いいったようで、焼砂の富士、「ほうろく」を伏せた形の石山とは思われない。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学校で物理学を教える場合に、方則の成立や意義や弱点を暗示するのは却って迷いを生じ誤解を起すという説もある。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもいつも下車する停車場とは、全くちがった方角から、町の中心へ迷い込んだ。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、ばあさんは迷い迷って、人ごみの中をようよう公園の方へぬけて来て云った。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "源叔父の独子幸助海に溺れて失せし同じ年の秋、一人の女乞食｜日向の方より迷いきて佐伯の町に足をとどめぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして「ホーマーのおかげで詩は横道に迷い込んでしまった。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年、犬養内閣が成立したとおなじ日に一羽のローラーカナリヤが迷い込んで来たのを捕えて飼っているうち、ある朝ちょっとの不注意で逃がしてしまった。",
              "citation": {
                "source": "ある探偵事件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中に聞いてみると、この橋の袂へ猫を捨てに来る人が毎日のようにあって、それらの不幸なる孤児等が自然の径路でこの宿屋の台所に迷い込んで来るそうである。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧式な彼には、いろいろな迷いや、苦悩や、逡巡があった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、夕暮れに、迷い児となった遅鈍な鶩を、剣をつけた銃で突き殺そうとした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくてわれ踏迷いたる紅の雪のなかをばのがれつ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この老科学者の世迷い言を読んで不快に感ずる人はきっとうらやむべきすぐれた頭のいい学者であろう。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ陳列台の前を行ったり来たりしている女の顔には、どうかすると迷いや悶えやの気の毒な表情がありあり読まれる事もある。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は一枚、あることはあるのだが、これは私が高等学校の、おしゃれな時代に、こっそり買い入れたもので薄赤い縞が縦横に交錯されていて、おしゃれの迷いの夢から醒めてみると、これは、どうしたって、男子の着るものではなかった。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時は、眼に見えぬ魂か何ぞのように、ズルズルズルと音を立てながら麦打ち場から舞い上って、地続きの廃業した瓦焼場から、これも夜逃げをした紺屋の藍干場へかけて狂いまわり、又は、森の中に立ちあらわれて、見る人も聞く人もない淋しい、悲しい心を、落葉と共に渦巻き鳴らしつつ暗い木立の奥に迷い込んで行く。",
              "citation": {
                "source": "塵",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時自分が東京を去ったか、何処を指して出たか、何人も知らない、母にも手紙一つ出さず、建前が済んで内部の雑作も半ば出来上った新築校舎にすら一｜瞥もくれないで夜｜窃かに迷い出たのである。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時自分が東京を去ったか、何処を指して出たか、何人も知らない、母にも手紙一つ出さず、建前が済んで内部の雑作も半ば出来上った新築校舎にすら一瞥もくれないで夜窃かに迷い出たのである。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠方で打つ大砲の響きを聞くような、路のない森に迷い込んだような心地がして、喉が渇いて来て、それで涙が出そうで出ない。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどこれもまたわが心の迷いなるべきか、われ治子を恋うる心の深きがゆえなるべきか。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "行く末のかれが大望は霧のかなたに立ちておぼろながら確かにかれの心を惹き、恋は霧のごとく大望を包みて静かにかれの眼前に立ちふさがり、かれは迷いつ、怒りつ、悲哀と激昂とにて一夜を明かせり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めから終わりまで道に迷い通しに迷って、無用な労力を浪費するばかりで、結局目的地の見当もつかずに日が暮れてしまうのがおちであろうと思われる。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾年もつづけてジグスとマギーをかいている画家は、おしまいには生きたジグスとマギーの存在を信じて疑わなくなるだろうが、それと似た頭の迷いが起こりはしないか。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればこそ誹諧は栗の本を迷い出て談林の林をさまよい帰するところを知らなかった。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕ははじめこのことをあなただけの所で申しあげようか、おぬいさんだけに聞いていただこうかと迷いました……しかし結局お二人の前で申しあげるのが一番いいとおもいました。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七歳、十八歳、十九歳＝人間が肉体的にも精神的にも葭の葉のような脆くて而も強い生に対する探求の触手を身体中一ぱいに生やし、夢と迷いに向けて小さい眼を光らし、狙いばかりつけて、却って自分は針鼠のように居竦まっている年頃である慧鶴は春、清水へ行き、そこの禅叢の衆寮へ入れて貰って、主に詩文の稽古をした。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "慧鶴青年は詩箋に落す筆を控えて、再び迷い始めた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "無心とは「迷いの心なく、ひたすらに」という意味であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人跡絶えた山道には、人力車の通う術もなかったので、二人の若い男女は、互に助け合いながら、蔦葛の這う細道を、幾時間となくさまよい歩いた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            }
          ]
        }
