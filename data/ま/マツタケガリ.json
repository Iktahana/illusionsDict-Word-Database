          "literary": [
            {
              "text": "ことに松茸狩りにはな。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の者だから松茸狩りなぞ面白がるだらうと思つて、本人もさう云ふもんだから、しかしわしらはとんと根太は知らんし、折角遠くから來たものを失望させてはと思つたので、松茸狩りでは玄人と云はれてゐる親爺に一緒に連れてつてくれと頼んだんだ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る日は婿の一遊が松茸狩りに連れて行こうというので、城下からつい二里半ばかりの平井谷というへ汽車で行って、松茸を取った、尤もこれは、山主が予て囲って置いて、それを勝手に採らせて、採った松茸は秤で量って値を取るのである。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて秋が深くなると、少年の一家は揃つて松茸狩りに出かけた。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "松茸狩りの記憶もすこぶる稀薄だ。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
