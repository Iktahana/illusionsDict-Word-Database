        "examples": {
          "standard": [
            {
              "text": "介護が必要な人のために、着脱しやすい前開きのパジャマを選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このカーディガンは前開きなので、季節の変わり目にさっと羽織れて便利だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "赤ちゃんの肌着は、おむつ替えがしやすいように前開きのデザインが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "恵子は大柄な、女にはめずらしく前開きの歩き方をするので、そんな特徴の女に会うと、そのたびに間違ってギョッとした。",
              "citation": {
                "source": "雪の夜",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に一列にあるボタンをかけながら、「前開きって便利なのよ」　と言った。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
