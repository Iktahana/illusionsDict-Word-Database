    "definitions": [
      {
        "index": 1,
        "gloss": "mawashi",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この忌々しい病気の為に、過去に僕は幾人かの友人を無くしてしまい、愛する人を意外の敵に回してしまった。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "美々しい回しをつけた力士が堂々としてにらみ合っていざ組もうとすると、衛士だか行司だかが飛び出して来て引き分け引き止める。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日露戦争の出征軍歌を、くりかえしくりかえし歌っては、庭を巡回して居ました、その一回の起点が丁度私達の立って見て居る廊下の堅牢な硝子扉の前なのです。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "音が聞こえてから、目でその音源を追究する代わりに、カメラを回してそれを追究する。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おんちゃんごはんおあがんなさいって」「おはんなさいははははは」　父は両手を回し、大きな背にまたふたりをおんぶして立った。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二坪にも足らない小池のまわり、七度も八度も提灯を照らし回って、くまなく見回したけれども、下駄も浮いていず、そのほか亡き人の物らしいもの何一つ見当たらない。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅子も民子もただ見回してはすすり泣きする。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこの結果が熱の器械的等量の電気的測定の結果と器械的測定の結果との齟齬を撤回したので、ジュールはたいそう喜んだ手紙をレーリーに寄せた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、あらゆるものは緩やかに旋回した。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、赤い蝶のようにホールを旋回しながら、僕は粟鼠の毛皮をつけた甘美な女の顔の花園を眺めながら云うのだ。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄海は日本の駆逐艦のマストが見える、夜は外人達によって舞踊会は傾いた部屋を旋回している。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "海峡から飛んできた伝書鳩が香港政庁の上空で旋回した。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "手に太い棒切れを持ってあたりをきょろきょろ見回していましたが、フト石垣の上を見上げた時、思わず二人は顔を見合わしました。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と河田翁は口早に言って、急に声を潜め、あたりをきょろきょろ見回しながら、「実はわたし、このごろある婦人会の集金係をしているのですから、毎日毎日東京じゅうをへめぐらされるので、この年ではとてもやり切れなくなりました、そこでも少し楽な仕事をと頼んで歩きましたら、やっとうまい口が発見ったんです。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、」とあたりを見回した上にさらに延び上がって近所を見回したが、一段声を潜めて「わたしは大変なことをしているんだ、とかく足らん足らんで一円二円とつかい込み、とうとう十五円ほど会の集金をつかい込んでしまったのです。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "河田翁が延び上がって遠くまで見回したのは巡査がこわかったのだ。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベッドの上に掛け回したまっ白な寒冷紗の蚊帳の中にＢ教授の静かな寝顔が見えた。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧羊者の祖先が山地の住民であったためか、それとも羊を追い回しおおかみでも追い払うために使われたものか、ともかくもいわゆるステッキとはだいぶちがったものである。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、黄河を迂回して、側面からここを圧迫する馮玉祥の騎兵部隊と、泰山の南を縫うて、明水平野に出た陳調元の優勢な一部隊に圧迫せられ、又、戦わずに、界首と、黄河の線を抛棄した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつでもそんなことを言って、巡回しないらしいのよ」　大家の主婦に留守を頼んで信子も市中を歩いた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一方からの尽きない生成とともにゆっくり旋回していた。",
              "citation": {
                "source": "蒼穹",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "情のために道を迂回し、あるいは疾走し、緩歩し、立停するは、職務に尽くすべき責任に対して、渠が屑しとせざりしところなり。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしてはあまりに貧弱な露店のような台ではあるが、しかし熱海の間歇泉から噴出する熱湯は方尺にも足りない穴から一昼夜わずかに二回しかも毎回数十分出るだけであれだけの温泉宿の湯槽を満たしている事を考えればこれも不思議ではないかもしれない。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この絵はとうとう二十日余りいじり回したが、結局やはり物にならないで中止してしまわねばならなかった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日同じ顔をいじり回しているうちに時々は要領にうまくぶつかる事もあった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そろそろ回しながらまずこの団塊の重心がちょうど回転軸の上に来るように塩梅するらしい。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊り場でピストルをひねくり回し、それを取り上げられて後にまた第二のピストルをかくしに探るところなどは巧みに観客を掌上に翻弄しているが、ここにも見方によればかなりに忠実な真実の描写があり解剖がありデモンストラチオンがある。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十余年前にワシントン府の青葉の町を遊覧自動車で乗り回したことがあった。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くから母に死なれ、父は頑固一徹の学者気質で、世俗のことには、とんと、うとく、私がいなくなれば、一家の切りまわしが、まるで駄目になることが、わかっていましたので、私も、それまでにいくらも話があったのでございますが、家を捨ててまで、よそへお嫁に行く気が起らなかったのでございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の弱い、情に溺れ易い、好紳士に限って、とかく、太くたくましいステッキを振りまわして歩きたがるのと同断である。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
