    "definitions": [
      {
        "index": 1,
        "gloss": "to mimic",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "特に人間の横っ跳びが馬の伸暢駈歩を真似ると非常にうまく行くことまで実地にやって見せました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは婆やが蔭でおすめの斜視を真似る時、いつも使う眼付きであった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "横紙破りの、ちょっと他人には真似ることの出来ないいたずらだったから、やってみると、快感はあったが、しかし、そのいたずらが結局殺人行為となってみると、いかな豹吉でも、さすがに薄気味悪い後味は心の底に残っていた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "せいぜい真似るだけだねえ。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "文体なども人を真似るのがいやだったから、あんな風にやって見たに過ぎない。",
              "citation": {
                "source": "処女作追懐談",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」麻川氏「そうですとも、何しろ日本の作家達は西洋を真似るのに非常に性急です。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って一部分を概念的に真似るに過ぎないんですね。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ幽霊にもせよ、父の声色を、やたらに真似るのは止し給え。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "派手な京風ばかりを真似るゆゑ、都所別当が御適任といふ御自身をおからかひの意味でおつしやつたのかも知れませぬが、私たちの日常拝しましたところでは、決してそんな事だけではなく、別のもつと厳粛な意味に於いても、その都所別当が首肯できる気持でございました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎者のくせに、都の人の身振りを真似るくらゐ浅間しく滑稽なものは無いのだ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おららが真似るようではないでしゅ。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "君はまだ、やっとお手本を巧みに真似る事が出来ただけです。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人の文学が物語性を持たないからとて、どうしてそれを真似る必要があろう。",
              "citation": {
                "source": "童話における物語性の喪失",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "畠二三枚、つい近い、前畷の夜の雪路を、狸が葬式を真似るように、陰々と火がともれて、人影のざわざわと通り過ぎたのは――真中に戸板を舁いていた。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "四（ああ）と応じた前川の言葉に、人言を真似る鳥のように、美和子も、「ああ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが豹一は真似るべき恋愛のモデルを知らないのである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "境辻三……巡礼が途に惑ったような名の男の口から、直接に聞いた時でさえ、例の鶯の初音などとは沙汰の限りであるから、私が真似ると木菟に化ける。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人形使もまた真似るがごとく、ひとしくともに手まねき、ひとしくともにさしまねく、この光景怪しく凄し。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "パワーブックで読むという想定で、電子本の基本的なあり方を決めて行くにあたって、彼らは先ず、これまでの紙の本の体裁を徹底的に真似ることを目標に置きました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーソナルコンピューターはタイプライターを真似ることで、大成功を収めた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのための最低限の仕掛けは、パーソナルコンピューターの主流であるＭＳ―ＤＯＳの世界では、これにかさ上げしてマッキントッシュを真似るＷｉｎｄｏｗｓが提供する。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "真似るにあたってのプラスとマイナスを差し引きした上で、物事の本質に積極的に貢献する方向で本家を超えたか否か。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡村は又出し抜けに、「君達の様に文芸に遊ぶの人が、時代おくれな考えを持っていてはいけないじゃないか」　鸚鵡が人のいうことを真似るように、こんな事をいうようでは、岡村も愈駄目だなと、予は腹の中で考えながら、「こりゃむずかしくなってきた。",
              "citation": {
                "source": "浜菊",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが一人であるか、五人六人が党を組んでいるのか、あるいはその噂を聞き伝えて面白半分に真似るものが幾人も出来たのか、そんなことも一切判らなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "槍突き",
                "note": "青空文庫"
              }
            },
            {
              "text": "覗機関の口上を真似る。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "などゝ真似るＲのいふことを聞くと、なるほど自分が変な奴！",
              "citation": {
                "source": "岬の春霞",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "努力して、そんな下品な態度を真似るのである。",
              "citation": {
                "source": "作家の手帖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の服装をまねるなどはたやすいことだった。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "おはまはおとよさんを一も二もなく崇拝して、何から何までおとよさんをまねる。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまねるという自覚が、すでに実行の勇気をくじいたうえに、もうはいる席は、いくら詰めても、むずかしかろうという遠慮が手伝って、三四郎の尻は依然として、もとの席を去りえなかった。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
