    "definitions": [
      {
        "index": 1,
        "gloss": "physician in private practice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "樽崎という京の町医者の娘だったが、樽崎の死後路頭に迷っていたのを世話をした人に連れられて風呂敷包みに五合の米入れてやった時、年はときけば、はい十二どすと答えた声がびっくりするほど美しかった。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時は円タクに圧されてしまって、流しの俥夫も商売にならず、町医者に雇われたが、変な上着を脱ごうとしないのがけしからぬと、間もなく暇を出されて、百貨店の雑役夫をしたこともある。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "金光教に凝って、お水をいただいたりしているうちに、衰弱がはげしくて、寝付いた時はもう助からぬ状態だと町医者は診た。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "病院をやめるとたちまち暮しに困つたので、やはり学校の紹介で豊中の町医者へ代診に雇はれた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "のちには、その気の弱い町医者に無理矢理、証明書を書かせて、町の薬屋から直接に薬品を購入した。",
              "citation": {
                "source": "東京八景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者の不養生というほどでもなかったろうが、平生頑健な上に右眼を失ってもさして不自由しなかったので、一つはその頃は碌な町医者がなかったからであろう、碌な手当もしないで棄て置いたらしい。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本橋新乗物町に舟見桂斎という町医者がありましたが、診断も調合も上手だというのでなか／＼流行っていました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者は、允子を嘗て不正な町医者と正義心から闘った女として描いている。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "安田徳太郎氏は内科の博士で山本宣治の従弟であるが、今では気軽で痛快な町医者となっている。",
              "citation": {
                "source": "日本の頭脳調べ",
                "author": "――特に自然科学者に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時浅越の下に附属せられたのが、新に町医者から五人扶持の小普請医者に抱えられた蘭法医｜小山内元洋である。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "信政は町医者であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "京水は分家して町医者となつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "前後の状況より推すに、瑞英は町医者として此に開業したらしい。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一房の鉄扉があけ放され、その外では主任、特高、部長、看守が首をのばして内をのぞいているところへ、入るべき場所でないところへ入ったと云う風な表情と恰好をして中年の町医者が及び腰で出て来るところである。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中のマリイに町医者を喚ばせたが、余り信用の置けない医者で、喉を焼く代りに臀部へ皮下注射をして帰つて行つた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな寝言、云いましたかな」　と総司は俄に赧い顔をしたが、「京都にいた頃、懇意にした娘だが……町医者の娘で……」「ただご懇意に？",
              "citation": {
                "source": "甲州鎮撫隊",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その女は町医者千賀道有の娘で、随分美しい女であった。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "町医者であった道有が、その後恐ろしいような出世をしたのであるから。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は今頃は、腰の低い町医者として、物思ひもない日々を送つてゐるかも知れなかつた。",
              "citation": {
                "source": "古代研究　追ひ書き",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その旅館も人気商売だし、三千子とてもムラサキのマダムとしての人気商売だし、町医者だってまあ言わば同類だし、大事件ならばとにかく、つまらない事件では名声を世に売るわけにはゆかず、高木の希望通りになって、警察の方にも内密に終った。",
              "citation": {
                "source": "好人物",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、町医者などには、催眠術的な説得法を診察にとりいれている例が少くはない。",
              "citation": {
                "source": "安吾巷談",
                "author": "巷談師退場",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、易者的、町医者的な、予期や、牽強附会から絶縁するということは、なかなか人間の為しがたいところである。",
              "citation": {
                "source": "安吾巷談",
                "author": "巷談師退場",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし状況判断ということになると、易者や町医者の鑑定ぶりに近づくことになるから、巷談師が気がかりになるのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "巷談師退場",
                "note": "青空文庫"
              }
            },
            {
              "text": "孤児ではあったけれど今松、生みの親は家柄だったと聞くし、薄情だった育ての親夫婦も、お玉ヶ池界隈では一、二と呼ばれる町医者。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ通油町に住んで、町医者でありながらひと格以上の見識を持っていた。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都の、猥雑な場末町に住みついた町医者の感じでもある。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は京都の町医者の言葉を思い出し、苦笑するより他はなかった。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし連れて行かれた先が、ふつうの町医者などだつたら、恐らく少年は地団太ふんで駄々をこねて、父の計画をみごと水泡に帰させたことだらう。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "半年後に治療費がとどけられた　幌別という駅が、白老から六つほど先にあるのだが、或る時そこの町に急患が出て、町医者を呼びにその家の者が飛んで行ったことがある。",
              "citation": {
                "source": "生きているコタンの銅像",
                "author": "――アイヌの慈父・高橋房次――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日頃、貧しいということで知られていたこの人に、近所の町医者はなんくせをつけ断った。",
              "citation": {
                "source": "生きているコタンの銅像",
                "author": "――アイヌの慈父・高橋房次――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
