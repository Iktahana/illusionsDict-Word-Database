    "definitions": [
      {
        "index": 1,
        "gloss": "boiling something whole (e.g. vegetable, fish)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三、四町行くとまた一軒の汚い旅人宿、幸いここでは、鰌の丸煮か何かで漸く昼飯に有付くことが出来た。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うの暗い棚の上には、章魚の丸煮や、蒲鉾の皿が行列している。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲橋広小路の市は、ちょうど鰌屋の近辺が一番賑やかであった（江戸の名物鰌屋は浅草の駒形、京橋で仲橋、下谷で埋堀、両国で薬研堀この四軒でいずれも鰌専門で汁と丸煮だけである）。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "歳の市のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "……夕方から、澄太君夫妻と共に黙壺居の客となる、みんないつしよに支那料理をよばれる、うまかつた、鶩の丸煮、鯉の丸煮、等、等、等（わざ／＼支那料理人をよんで、家族一同食べたのは嬉しい）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに泥鰌も味噌汁に限ることを言っておこう、駒形の名物泥鰌に浮れ込み、いやに江戸がって骨抜きせぬのをとりよせ、丸煮の鍋に白い腹を出してるのを見て、俄にげんなりしてしまい、嫌々むしって喰べる連中、近来は大分多くなったと、内々嗤ってる手あいがある。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "どじょうといえば本黒の丸煮、玉子の白味でアクを抜いたわりしたでないと食えないという。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "須賀津の溜から胡麻鰻を取って来て、丸煮で先生に差上げて、少しでも根気を附けて上げましょうと、それは私の一心からで、人手にも掛けず選りに行ったのですよ。",
              "citation": {
                "source": "死剣と生縄",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕の巣、鮫の鰭、蒸した卵、燻した鯉、豚の丸煮、海参の羹、――料理はいくら数へても、到底数へ尽されなかつた。",
              "citation": {
                "source": "南京の基督",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソコで御馳走は何かと云うと、豚の子の丸煮が出た。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "張の感想によると、彼は火星人の身体つきを見て、これはスープで丸煮にして喰べたら、さぞうまいだろうと思ったそうである。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "天狗を酔いつぶさせるために爺さんが苦心してこしらえた料理ですから、豚肉の串焼の中にも、雉の肝の揚物の中にも、鯉の丸煮の中にも、その他いろんな見事な料理の中には、みな強い酒がまぜてありましたし、それを食べながら、さらに大きな杯でがぶがぶ飲んだものですから、二人が酔っぱらうのも無理はありません。",
              "citation": {
                "source": "天狗の鼻",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "外にまだ何かあるかね」小山「あるともあるとも、蜜柑の丸煮が出来ている。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は、この丸煮よりも鰍｜膾の淡白を所望したのであるけれど、生憎このごろは漁師が川業を休んでいるために、活き鰍が市場へ現われてこぬとのことであった。",
              "citation": {
                "source": "姫柚子の讃",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰍は素焼きにして、山葵醤油をつけて食べても、焼き枯らして味噌田楽にこしらえても、また丸煮にしても、いずれも結構であるが、頭と脊骨と腸を去って天ぷらに揚げるか、膾に作ればこれに勝った味はない。",
              "citation": {
                "source": "姫柚子の讃",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いよいよいけないとなれば、わしも愚痴は言わんが、家へもどっても夕食をする当のないのは弱った」「それが、愚痴というもんですよ」「こういう霜腹気の日に、泥鰌の丸煮かなんかで、熱燗をキュッとひっかけたら、さぞ美味なことであろう」「贅沢をいっちゃいけませんよ。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "初春狸合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人数にして三十人ばかり、丸煮やら柳川鍋やら大湯呑に鬼菱というのを注がせて、さかんに煽りつけている。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "初春狸合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……おい、姐や、丸煮を二人前に、鬼菱を一升持って来まっせ、急ぎだ急ぎだ、焦がれ死にをしそうなのが、ここに二人いる。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "初春狸合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾もつゞいて入るに、こゝは此度新に建てし長方形の仮屋にて二列にテーブルを据ゑ、菓子の塔柿林檎の山、小豚の丸煮、魚、鳥の丸煮など、かず／＼の珍味を並べ、テーブルの向ふには給仕ありて、客の為に皿を渡し、物を盛る。",
              "citation": {
                "source": "燕尾服着初の記",
                "author": "徳富盧花",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿母さんは儉約家だから、ちっとでも傷のないのは、皆丸煮にするって云うのよ。",
              "citation": {
                "source": "猿",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルマイトの蓋をめくり、いつものとおり細いイカの丸煮が二つと、粟の片手にぎりほどの塊が六つ、コソコソと片寄っている中身を見たとき、ぼくの舌は、ごく自然にぼくを裏切ってしまっていた。",
              "citation": {
                "source": "煙突",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "当然の権利のように、彼はぼくがイカの丸煮をつまむと、ちゃんと残った一つをつまんだ。",
              "citation": {
                "source": "煙突",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "――妙なことを考えるわけは、スノウが旅行して行って御馳走になる、鶏の丸煮、丸ムギのパン、キャベジ、ジャガイモ、粟、それを心からよろこんで食べたが、飲むものは熱い湯しかなく、死にそうにのどが干いたといいながら、それには手もふれられなかったと云っている。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――壇の道教神のまえには、紅蝋燭赤々と燃え、金紙の銭、色紙の馬、お花、線香、羊の丸煮などの供え物が、種々、かざり立てられてある。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また花だの線香だの、さらに神仏の供え物には一番な豪奢とされている丸煮の豚の頭まで買って、持ちきれないほど抱えこんだ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、清国式の大げさな葬式にはぶたの丸煮と共に、ぜひともなくてはならない「泣き女」の職業に。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日一日の疲れか明方やや強い喘息發作、アストオル吸入で鎭まるには鎭まつたが何やら不安なのでエフエドリン一錠半服用、例の陶醉的作用でやがて再び昏昏と眠り入る。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此所なんぞ入場料十圓也と觸れ出せば、紳士淑女は雜鬧し、雜誌は動物園の詩で埋まるに違ひない。",
              "citation": {
                "source": "太郎と街",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら危険を感じていても、滑るに任せ止まるに任せる外はなかったのだった。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな頭を寄せて見ると、針の孔のような小さいまるにコンパスのさきが止っていた。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云いながらまるで兎のようにせ中をまんまるにして走っている列車の下へもぐり込みました。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
