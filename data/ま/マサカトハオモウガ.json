        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まさかとは思うが、行燈か、行燈か？",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "内証のお蔦の事、露顕にでも及んだかと、まさかとは思うが気怯れがして、奥方にもちょいと挨拶をしたばかり。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさかとは思うが、気になるね。",
              "citation": {
                "source": "囚われ人",
                "author": "――寓話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（まさかとは思うが、あるいは……？",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいつ悟ったんじゃあるまいかな」「まさかとは思うが解らないね」「最初に地丸と逢ってからもう今日で十日になる。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔子だけは、まさかとは思うが、それにしても、自分と視線が会うと、すぐ眼をそらしてしまわれるのは、どうしたわけだろう。",
              "citation": {
                "source": "論語物語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "（まさかとは思うが、父さんは悪いと知りつつ、あれをあのままにして置くつもりではなかろうか。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは、中には、――これはまさかとは思うが――組織などなければないでいい、強制がなくてそのほうがかえって気楽だ、と考えているものがあるかもしれない。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさかとは思うが、新聞に掲載されている広告のなかの新人女優、日比谷優子は、矢沢さんの親しかった中原順子と、いわゆる瓜ふたつだ。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
