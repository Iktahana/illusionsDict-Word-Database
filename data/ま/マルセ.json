        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ちぢかんだ丸背にしろ、顔にしろ、口の恰好にしろ、箸の使いわけまでも。",
              "citation": {
                "source": "光の中に",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸背には、大山（強孤形）、中山（緩孤形）それと、角丸（かまぼこ形）とある。",
              "citation": {
                "source": "書籍の風俗",
                "author": "恩地孝四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通見る丸背は前二者であって、角丸は、技術の未熟のために余り日本では少ないが西洋本は多くがこれである。",
              "citation": {
                "source": "書籍の風俗",
                "author": "恩地孝四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又丸背の強いものに対して余り直線的な感じの文様を附するが如きである。",
              "citation": {
                "source": "書籍の風俗",
                "author": "恩地孝四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も日によって――油が煮つまるせいか、胸やけあり。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
