[
  {
    "uuid": "96b9b8ed-20f0-5f5f-9dd5-8be0b7b80e72",
    "entry": "魔王",
    "reading": {
      "primary": "まおう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
