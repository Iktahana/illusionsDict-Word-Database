    "definitions": [
      {
        "index": 1,
        "gloss": "mash",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "マッシュルームの類であろう。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "厨房一同入寮晩餐会メニューチキンコンソメ　　アスパラガスのサラダマッシュポテト　　ヒラメのソテコールドミート　　パンデザートはバニラアイスクリーム　慶一は、「厨房」という字を、とりあえず「とうぼう」と読み、コックかなんかの意味だろうと考えた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」11ゾンビたちも楽しんでいたパーティーは、まだはじまったばかりゲストは狼男とドラキュラ、それにドラキュラの息子〈モンスター・マッシュ〉ボビー・“ボリス”・ピケット　寮の玄関がこれだけ騒々しいのは、めったにあることではない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "サラミとマッシュルームが一五〇〇円」「いらない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏なんて、年をとると、暑いだけで、面白くもなんともない」　山崎はサラミとマッシュルームをとる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にも殊別なものはなく、いつもの、ハンバーグステーキにマッシュドポテトウ、アニオン、おつゆ、おひたしでよろこんで居る。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ナイツブリッジに住んでいる貧しい男がマッシュルームを採るためにハイド・パークを散歩した。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「中年の男は彼がシャンピニオン（＝マッシュルーム）と呼んでいるものを集め、シチューにし、彼自身および妻と食べた。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "パパなるひとは、当時、農大はじまって以来という秀才で、石田の家で書生をしながら苦学をしていたのを、うちのママが、あたしと婚約してくれるなら、かならず洋行させるからと、否応なしにマッシュ（マッシュド・ポテトのマッシュ、力づく、または理詰めで、無理矢理、婚約すること）してしまった。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃では地下室でマッシュルームの養殖もしている。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこし上等の料理には茶色の丸っこい松露のようなマッシュルームをつかい、これはもう世界共通のありふれたものです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローマからこの頃ヴェニスへうつったという日本の人々も、こんなマッシュルームとマカロニたべているのでしょうね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなが野営へ戻りつく頃までには、バックは、「ホー」と云われればとまり、「マッシュ」と云われれば進み、曲り角ではぐるつと遠く廻り、荷のかかつた橇が後から坂落しにすべつてくるときには｜橇際の犬に道をあけてやること、などをおぼえていた。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            },
            {
              "text": "仔うしのヒレ肉と辛いソースをかけたマッシュルーム、炙った膵臓、熱いイセエビ、アンズのタート、中央にはシラバブとジェリーのピラミド。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "マッシュルーム・オムレツ。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒッチハイク、マディスン、フライ、ポニー、ドック、ワツシ、マッシュドポテト、ブーガルー、モンキー、ハリーガリー、リンボ、スイム、フラッグ、シェイク、ボストン・モンキーなど、さまざまにあった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "マッシュポテトがうまし。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "他、ミニツステーキとマッシュド・ポテト。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルドヴル、ポタアジュ、ミニツステーキに、マッシュポテトーとスピナッチ、ババロア。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポタアジュ、ポークビーンズ、ハンバクステーキに、フライオニオンとマッシュポテト。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあと、タンシチュウ、マッシュドポテト、バタライスと行き、雨やんだ中をタクシー帰宅。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、チーズトースト、コールドコンソメ、ピロシキー一、タンシチュウ・マッシュドポテト添。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "タンシチュウ、マッシュドポテト、バターライス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "次、メニュー見て、ブフ・アラ・モドを注文、マッシュポテト添。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "リゾールパイから、タンシチュウ、マッシュポテト、バタライスを食ひ、サントリーハイボールを又二三杯。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "タンシチュウ、マッシュドポテト。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "オムレツ、マッシュドポテト。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
