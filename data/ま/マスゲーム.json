        "examples": {
          "standard": [
            {
              "text": "体育祭の開会式で、全校生徒による壮大なマスゲームが披露された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "北朝鮮のマスゲームは、その規模の大きさで世界的に有名だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "何千人もの人々が息を合わせて演技するマスゲームは、まさに圧巻の一言だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "だが体育さえもそれが本当に社会化されて日常生活に入り込む時は、マスゲームのようなものにならざるを得ない。",
              "citation": {
                "source": "娯楽論",
                "author": "――民衆と娯楽・その積極性と社会性・――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何千人というおばけが、マスゲームでもやっているように、みんなおそろいで動くのです。",
              "citation": {
                "source": "鉄人Ｑ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
