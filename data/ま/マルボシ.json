        "examples": {
          "standard": [
            {
              "text": "朝食に焼いたイワシの丸干しが出てくると、白いご飯がいくらでも進む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "お酒のつまみに、軽く炙ったウルメイワシの丸干しを齧るのが至福の時だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "市場の軒先には、潮風にさらされて旨味が凝縮した丸干しが吊るされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "富山方面の氷見いわしの丸干しなども、いわしとしては優れた美味さを持つものであるが、所詮いわしの味としての美味さにすぎない。",
              "citation": {
                "source": "小ざかな干物の味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "さけの丸干しは一見燻製に似たものであるが、風味に至っては、だんぜんたる相違がある。",
              "citation": {
                "source": "小ざかな干物の味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
