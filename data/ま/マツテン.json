          "standard": [
            {
              "text": "松貂は、ヨーロッパの森林に生息する美しい毛並みの動物だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "図鑑で見た松貂の写真は、その賢そうな瞳が印象的だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夜行性の松貂が、木の上を敏捷に移動する姿を目撃した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "お父さまは　ごこまつてんのうで、お母さまは　いよのつぼね　と　いいました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども　ごこまつてんのうの　おん子として　うまれた　一休さんを　なんとかして、えらくしたいと　おもいました。",
              "citation": {
                "source": "一休さん",
