    "definitions": [
      {
        "index": 1,
        "gloss": "to be mistaken",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「宇平ドンにゃ、今、宇一がそこの小屋へ来とるが、よその豚と間違うせに放すまい、云いよるが……。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まかり間違うと、鼻持ちならぬキザな虚栄の詠歎に似るおそれもあり、または、呆れるばかりに図々しい面の皮千枚張りの詭弁、または、淫祠邪教のお筆先、または、ほら吹き山師の救国政治談にさえ堕する危険無しとしない。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まかり間違うて大公儀の耳にでもそげな事が入ったなら、直ぐさま、黒田五十五万石のお納戸の信用に差響いて来るやら知れぬ話じゃけに、成る限り大切を取って極々の内密に、しかも出来るだけ速よう下手人を探し出せと言う大目付からの御内達で、お係りのお目付、松倉十内｜様も往生、垂れ冠って御座る。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "確かにこの方角に向って行きさえすれば決して間違うはずはない。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――間違うても構わんです。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫の明けた音は細君の耳には必ず夫の明けた音と聞えて、百に一つも間違うことは無い。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "）三人連で、軽井沢、碓氷のもみじを見た汽車の中に、まさしく間違うまい、これに就いた事実があって、私は、不束ながら、はじめ、淑女画報に、「革鞄の怪。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから「頭は間違うことがあっても、血は間違わないものであること。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ程の評判じゃったかのう」「間違えば間違うもので御座いまする……何でもその友川という若いお武家が、返り討に会うた会うた。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "キット仇を取って進ぜまするという手紙を添えて、大枚の金子を病身の兄御にことづけた……という事が又、もっぱらの大評判になりましたそうで……まことに早や、どこまで間違うて参りまするやら解からぬお話で御座いますが……」「ハハハ。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "間違うても今死ぬ事はなりませぬぞ」　今度は少年連がシクシク泣出した。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「演説はともかく、板垣という男の至誠には動かされたよ、この男の云う事なら間違うてもよい。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本は国体が立派じゃけに、よほど豪い奴でないと光らん」「そんなもんですかねえ」「そうとも……日本の基督教は皆間違うとる。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも呼込まれる先々が大抵レコが留守だすケニ間違いの起り放題で、又、間違うてやりますと片身の約束の鯖が一本で売れたりします。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "謡が実に立派で、蔭で聞いていると只圓翁と間違う位であった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "シテはたしか故大野徳太郎君であったと思うが、お互に受持の言葉を暗記するかしないかに二人向き合って申合わせをさせられたので、間違うたんびに笑っては叱られた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "間違うても囃子方の尻に付いてはならぬ」　と翁は度々山本氏等に云っていた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな亭主を持ち、細君は死ぬまで将棋を呪うて来たが、けれど十年前いよいよ息を引き取るといふ時「あんたは将棋がいのちやさかい、まかり間違うても阿呆な将棋は指しなはんなや。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "信用ある商館の上の方の事務員、すなわち「世慣れたしっかり者」といった方も、間違うはずはなかった。",
              "citation": {
                "source": "群集の人",
                "author": "THE MAN OF THE CROWD",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そちが話を聞けば、甚五郎の申し分や所行も一応道理らしく聞こえるが、所詮は間違うておるぞよ。",
              "citation": {
                "source": "佐橋甚五郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "古藤は思わず笑いをもらしながら、「間違うとたいへんですから」という言葉を、時おり葉子の口から聞くチャームに満ちた子供らしい言葉の一つとでも思っているらしかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四階級をいうならば、ブルジョアジーとの私生児でない第四階級に重心をおいて考えなければ間違うと僕は考えるものだ。",
              "citation": {
                "source": "片信",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで土の中から石を掘り出すようなものだからけっして間違うはずはない」と云った。",
              "citation": {
                "source": "夢十夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "指紋は間違うとも、水晶の印だけは間違わぬ。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常な速さで、誰も掛声ひとつ発するものとてもなく、唯不気味な息づかいの荒々しさが一塊となって、丁度機関車の煙突の音と間違うばかりの壮烈なる促音調を響かせながら、一陣の突風と共に私の眼の先をかすめた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "間違えば間違うもので、金蔵が藤吉となり、藤吉が半七となって、わたくしが先ず第一にお縄頂戴……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "わっしの又聞きで何か間違うといけねえから、その本人を引っ張って来ました」「そうか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三河万歳",
                "note": "青空文庫"
              }
            },
            {
              "text": "村人たち　（口々に）それや、嘘じゃ……なんぼ奉行様の仰せでも、それは間違うとる。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとにかすかで、よく見なくては鴎とまちがうくらい小さいけれど。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まちがうといけないから、他の書類は引出へでもしまって頂いて、机の上はこの餌だけをおくことにしたいですね」　と、蜂矢はどしどしと説明をすすめた。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
