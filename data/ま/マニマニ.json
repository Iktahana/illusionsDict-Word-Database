[
  {
    "uuid": "3e219332-ab7b-54bf-b6ca-926400f860e0",
    "entry": "随に",
    "reading": {
      "primary": "まにまに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
