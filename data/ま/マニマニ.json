    },
    "definitions": [
      {
        "index": 1,
        "gloss": "at the mercy of (e.g. the waves)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "不幸にして露西亜はレーニンの奇蹟的な偉業とアンナ・スラビナの半身不随によって、過去タレルキンの饒舌、私に遺伝してしまった。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "家屋の建築は設計者の気随になる。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父はおぬいの十二の時に脊髄結核にかかって、しまいには半身｜不随になったので、床にばかりついていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年半も半身不随になつて、どつと臥つたなりであつたから、小さな床屋の世帯としては、手にあまる重荷だつた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我に諂い我に媚ぶる夥多の男女を客として、貴き身を戯に謙り、商業を玩弄びて、気随に一日を遊び暮らす。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうとっくに死んでいたおきみ婆さんと同じようにお歯黒に染めていたその婆さんは、もと髪結いをしていて、その家の軒には「おめかし処」と父の筆で書いた行灯が掛っていたのだが、二三年前から婆さんの右の手が不随になってしまったので、髪結いもよしてしまったらしい。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時勢であったから椿岳は二軒｜懸持の旦那で頤を撫でていたが、淡島屋の妻たるおくみは男｜勝りの利かぬ気であったから椿岳の放縦気随に慊らないで自然段々と疎々しくなり、勢い椿岳は小林の新らしい妻にヨリ深く親むようになった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "父にておはせし人はその頃年三十を越え給はず、また母にておはせし人もなほ若かりしかば、さのみは愛し給ひしとも聞かざれど、祖母なる人のいとめでいつくしみ給ひて、父の叱り給ふ時は機嫌よろしからぬほどなれば、おのづから気随におひたてり。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "……気随になさるもよいけれど、それにしても、そちらからせがんだのぢやないか……。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる年早々、Ｉ総監が半身不随に罹った旨が報ぜられた。",
              "citation": {
                "source": "外務大臣の死",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "当座四五日は例の老人の顔を見る毎に嘆息｜而已していたが、それも向う境界に移る習いとかで、日を経る随に苦にもならなく成る。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "その癖お勢が帰塾した当坐両三日は、百年の相識に別れた如く何となく心｜淋しかッたが……それも日数を経る随に忘れてしまッたのに、今また思い懸けなく一ッ家に起臥して、折節は狎々しく物など言いかけられて見れば、嬉しくもないが一｜月が復た来たようで、何にとなく賑かな心地がした。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "歳の暮頃から全身が不随になって、口もきかなかった。",
              "citation": {
                "source": "私の子供時分",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "モチーフを整理の必要として感じているとき、作家は、「在るものへの追随によって世界像を求める傾向へ」と発展せざるを得ず、今日の生活のなかで、それが文学にどのような結果をもたらすかということは、察するに余りある。",
              "citation": {
                "source": "作家に語りかける言葉",
                "author": "――『現代文学論』にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故あらゆる分野で婦人を封建的、奴隷的文化に封じこめて置くことに成功しさえすれば、それはとりもなおさず解放に向って闘うプロレタリアート・農民を半身不随に陥らせたと全く同じことだという事実を、彼らは狡猾に知りぬいているのである。",
              "citation": {
                "source": "婦人雑誌の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊藤整のように、ジェームズ・ジョイスの文学を深く理解した作家が、より若い世代のヨーロッパ文学の手法追随に対してむしろ警告的であるのも注目される。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代作家の何人かは、一人の女の一生にうつし出された変転のまざまざとした形象に目をひかれて、その道行きを辿って再現するが、それがただの映し直し、現象の追随に止まっている原因は、「くれない」の批評に見られたと同じに、今日の文学世代の歴史と社会性とに対する把握の貧寒さから来ているのである。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "読書よりはおのが気まゝ気随に遊びて暮すを好ましく思へども、何分貧家に生れ一文の金も贅沢には消費し得ざる身分なれば思ふ様に遊ぶこと能はず、併し乍ら多情（多慾といふも同じ事なり）の生れとて此ままに朽ち果てんは我本意にあらず。",
              "citation": {
                "source": "読書弁",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "栲窓は抽斎の歿した頃奥医師を罷めて大塚村に住んでいたが、明治七年十二月に卒中し、右半身不随になり、此に※って終った。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは脳卒中で右半身不随になっています。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "文政十年、は中風のために右半身不随になり、且一目失明した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "不随になったその体がはげしく引きつり、そして眼には或る恐怖の色をうかべながら、「大違いですよ、ムッシュウ。",
              "citation": {
                "source": "十時五十分の急行",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "八十歳近く、半身不随になって、妹の陋屋でみまかった。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "父母寵愛して恣に育ぬれば、夫の家に行て心ず気随にて夫に疏れ、又は舅の誨へ正ければ堪がたく思ひ舅を恨誹り、中悪敷成て終には追出され恥をさらす。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "大瀧氏来訪、彼のおばあさんが脳溢血で半身不随になって居ると云う。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからの俳優は、職業的関節不随に陥ることを避けなければなりません。",
              "citation": {
                "source": "俳優志望者メンタルテスト",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷は既に当時の人には天空にある神であるが、天皇は雷神のその上に神随にましますというのである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "謂はゞその膝と膕とが、一つの頭のまはりであつて、其から下の脛や足頸が、胴体や脚でゞもあるやうに、其処だけが、気随にはたらいて居るのである。",
              "citation": {
                "source": "鏡花との一夕",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、もうそのときは口は利けず、右半身が殆んど不随になっていた。",
              "citation": {
                "source": "花を持てる女",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどき神経痛のために半身不随になるということを聞いていたが、そんな時は一人でどうするのだろうと、その老衰した様子を見ながら彼は思った。",
              "citation": {
                "source": "恢復期",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
