        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まんじりともしないで東の空がぼうっとうすむらさきになったころ見ますと屋根の上には一面に白いきらきらしたものがしいてあります。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、ウト／＼する心持から引戻されたのを口惜しがつて、「起きたつてつたつて、昨夜からまんじりともしないんだもの……堪まりやアしない。",
              "citation": {
                "source": "眠い一日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜も一昨夜もその前の晩も俺は、まんじりともしないで二つの未定稿を繰り返し／＼読んだが、あゝ、駄目だ！",
              "citation": {
                "source": "蔭ひなた",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "心配することは無い」　しかし、その夜彼は、一晩中まんじりともしないで、溜息と一緒に考えこんでいた様子だ。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほとんど一晩中、まんじりともしないであらゆる物音に耳をすましていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで探偵はその夜一夜まんじりともしないで脳細胞を酷使した揚句、夜の明けるのを待って、稀代の怪賊烏啼天駆の隠家へ乗込んだ。",
              "citation": {
                "source": "心臓盗難",
                "author": "烏啼天駆シリーズ・２",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は暗い所にたった独り寝るのが淋しかったのだろう、翌る朝までまんじりともしない様子であった。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその晩まんじりともしないで、幼い時からのことを考えなおしてみた。",
              "citation": {
                "source": "椎の木",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達はそうしたまままんじりともしないでその夜を明かした。",
              "citation": {
                "source": "風立ちぬ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、冬の夜など、御前の近くに、知らない女房たちの中に伏しながら、殆どまんじりともしないでいる事が多かった。",
              "citation": {
                "source": "姨捨",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその夜は殆どまんじりともしないで妻のことを考え通していた。",
              "citation": {
                "source": "菜穂子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一晩中、まんじりともしないで、あたし、待つてたわ。",
              "citation": {
                "source": "驟雨（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもその行方が今以てわからぬというのは、今宵もまんじりともしないほどお松の心を苦しめていました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "……やがてその晩、ドロシーダ・ペトローヴナが言うには、　――ねえ、それじゃいけないよ……まんじりともしないで、まるで石みたいにコチコチになって臥ているなんてさ。",
              "citation": {
                "source": "かもじの美術家",
                "author": "TUPEJNYJ HUDOZHNIK",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜はほとんど、そこでまんじりともしないでいたが、明けがたになって、どうやらほんのちょっとばかり眠ったらしく、人の足音で眼がさめた。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの夜、サト子は海からあがると、どの部屋よりも海からへだたった、山側の叔母の寝室で寝たが、頭の下でたえず熱いまくらをまわしながら、朝まで、まんじりともしないという夜を経験した。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、行子は頭の下でたえず熱い枕を廻しながら、朝までまんじりともしないという辛い夜を、生れてはじめて経験した。",
              "citation": {
                "source": "うすゆき抄",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "一夜まんじりともしないで踊りつづけ暁方近くには疲れきって舞台に俯伏したまま前後不覚に寝入ってしまった。",
              "citation": {
                "source": "鷺娘",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四日の夜は、行雄とひろ子とがまんじりともしないで番をした。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　その夜、おくめは、明方までまんじりともしないで床の上に眼を醒していた。",
              "citation": {
                "source": "黄昏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は殆どまんじりともしないで一と夜を明かし、明くる日の午後六時頃まで待ちましたけれど、それでも何の沙汰もないので、もうたまりかねて家を飛び出し、急いで浅草へ駈け付けました。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "輾転反側、明方までまんじりともしない。",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一晩中まんじりともしないで、東の空がしらむのといっしょに、二人はもう洞窟を飛び出し、出発の用意をはじめました。",
              "citation": {
                "source": "新宝島",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜は、まんじりともしないで、夜の明けるのを待って、彼は江川蘭子の自宅へ出かけていった。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
