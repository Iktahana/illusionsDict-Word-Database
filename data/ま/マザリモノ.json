        "examples": {
          "standard": [
            {
              "text": "この宝石は、混ざり物が一切ない純粋な輝きを放っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "購入した米に、小さな石の混ざり物があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "不純物の混ざり物がない、高品質な材料を求めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "も少し混ざり物の少ない酒を民衆に注いでやったほうが、はるかによいのだ。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが実際は大概まざりものなのであります。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛を表現する精神の働きばかりでなく、それと全く等しく愛を表現し、生命の調和をつかさどる肉体の機能も、そのまままざりものなしに卑屈なはずかしがりなどない見かたと、扱いかたがされるべきである、と。",
              "citation": {
                "source": "傷だらけの足",
                "author": "――ふたたび純潔について――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
