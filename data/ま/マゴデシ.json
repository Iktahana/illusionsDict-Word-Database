    "definitions": [
      {
        "index": 1,
        "gloss": "disciples of one's disciples",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
