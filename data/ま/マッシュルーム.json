          "literary": [
            {
              "text": "マッシュルームの類であろう。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "サラミとマッシュルームが一五〇〇円」「いらない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏なんて、年をとると、暑いだけで、面白くもなんともない」　山崎はサラミとマッシュルームをとる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ナイツブリッジに住んでいる貧しい男がマッシュルームを採るためにハイド・パークを散歩した。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「中年の男は彼がシャンピニオン（＝マッシュルーム）と呼んでいるものを集め、シチューにし、彼自身および妻と食べた。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃では地下室でマッシュルームの養殖もしている。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこし上等の料理には茶色の丸っこい松露のようなマッシュルームをつかい、これはもう世界共通のありふれたものです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローマからこの頃ヴェニスへうつったという日本の人々も、こんなマッシュルームとマカロニたべているのでしょうね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "仔うしのヒレ肉と辛いソースをかけたマッシュルーム、炙った膵臓、熱いイセエビ、アンズのタート、中央にはシラバブとジェリーのピラミド。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "マッシュルーム・オムレツ。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピラフは（芝海老とチキン、マッシュルーム）クリームソース掛け。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
