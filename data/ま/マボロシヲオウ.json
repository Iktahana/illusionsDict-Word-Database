          "literary": [
            {
              "text": "自殺とのことを聞いて、全身を震わして泣いたが、中途で泣きやんで、幻を追うような様子に変った。",
              "citation": {
                "source": "父の形見",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "病室に行くと、啓介は逃げてゆく幻を追うように、天井の隅を見つめていた。",
              "citation": {
                "source": "二つの途",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だのにあなたは、幻を追うのがご商売なのね。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤三は夢幻を追う思いで、今、彼の視野から消えた女体を、もう一度、網膜に描いた。",
              "citation": {
                "source": "刺青",
                "author": "富田常雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ、あなた、何とかそれを確める手だてはないものでございましょうか」　夫人はなき愛嬢の幻を追う様な目をして、夫の智恵に縋るのであった。",
              "citation": {
                "source": "恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
