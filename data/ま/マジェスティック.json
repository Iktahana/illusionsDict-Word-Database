        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なかに、ホテルについて、マジェスティックが東洋第一といいながら、ボルト酒のよいのを持たない、「長崎のジャパン・ホテルにだって一九一一年のブルガンディー酒があるくらいだのに」云々とある。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山のうえには黄昏の色が漂っているが、シャモニーの谷はもう夜で、はるか目の下、眼路の終るあたり、宮殿のようなマジェスティック・パレスの窓々が、あかあかと電灯の光をあふらせている。",
              "citation": {
                "source": "白雪姫",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうでしょう、ロンドンのマジェスティック劇場は。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いつきでマジェスティック劇場と契約を結ぼうなんて、時間の無駄ですし、絶対だめですよ。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "マジェスティック劇場の営業は暇なしだ。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "マジェスティック劇場の観客は大いに満足した。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "サンフランシスコ新聞の記事は単なるでっち上げで、マジェスティック劇場に出演するために考え出されたものだった。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあとマジェスティック劇場は数週間、床から天井まで満席になった。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "次にマジェスティック劇場でローラ嬢の公演が決まった後、詳細を詰めた。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしてマジェスティック劇場の支配人は大儲けさ。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
