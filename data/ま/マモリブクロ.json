    "definitions": [
      {
        "index": 1,
        "gloss": "small pouch containing a paper charm or talisman",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は、お母がこしらえてくれた守り袋を肌につけていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど、今は親しくお目にもかかれぬ身、お礼のかわりにこの守り袋お届け候まま、わが身と思うて、たいせつにご所持なさるべく、はよう年季勤めあげて、ご立身なさるよう、陰ながら祈りあげ候。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、こっちの弥吉どんだが、おまえさんこっそり次郎松にお会いなすって、あの金襴織りの守り袋を見せてもらったんじゃござんせんかい」「…………」「いいえ、なにもそんなにこわがらなくともいいですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの青梅と眼がついたな、あの金襴織りの守り袋からだよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "成田山のお守り袋のなかに、森永ミルクキャラメルの箱が入っているすがたが浮かんでくる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹は弾丸除けのお守り袋を縫ってくれた。",
              "citation": {
                "source": "出発",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　内藤氏はこの三箇条を守り袋に入れた積りで記者生活に入つて往つた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのは、なんとそのお岩が後向きであって、ただ守り袋をさしつける人形の作り手のみが、ひょいと不器用な、動きかたをしたにすぎなかった。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "房枝は、スミ枝に目くばせをすると、手つだってもらって、黒川の胸にかけてあったお守り袋の紐を切り、そっとはずした。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "財布はすつかり、守り袋に変つてしまひました。",
              "citation": {
                "source": "鵠が音",
                "author": "島の消息",
                "note": "青空文庫"
              }
            },
            {
              "text": "うない拝みをして、其頂の髪の毛を乞うて、守り袋に入れて旅立つ。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "懐中へ片腕を差し込むと、守り袋を引きずり出し、その中から紙片を取りいだし、それを頭上に高くかざし、「方々見られよこの紙片を！",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "リ　まむり　守り袋の大きな物を、鐘楼の撞木の様に吊る。",
              "citation": {
                "source": "だいがくの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよその日も近づいて、継母のおまんは半蔵のために青地の錦の守り袋を縫い、妻のお民は晒木綿の胴巻きなぞを縫ったが、それを見る半蔵の胸にはなんとなく前途の思いがおごそかに迫って来た。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "手回しのいいこの和尚はすでに旅の守り袋を用意したと言って、青地の錦の切地で造ったものをそこへ取り出して見せた。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえの帯にはお守り袋がついていて、それに名まえが書いてあるから、迷ったならだれか連れてきてくれるだろうと思ったが、それぎりついに帰ってこなかった。",
              "citation": {
                "source": "けしの圃",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "かきおきはまたしちのまもりぶくろにあり「あツ、讀めますね、こいつは」「――書き置きは又七の守り袋にあり――と讀むんだらう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "櫛の文字",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとその後から一人の中間者が來て、赤ん坊をすつかり剥いだ上、自分の赤合羽一枚だけ着せて雪の上に投り出し、紋服も守り袋も持つて行かうとするから、橋番をして居た親父がびつくりしてとがめると、小判で二十兩入つてゐた財布をくれて――これが口止料だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "二つの刺青",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八、向うを見ろ、あれは何んだ」「へエ」　八五郎が垣根の方を向いた瞬間、平次は守り袋の中味をそつと拔いて、自分の懷ろ紙を二枚ばかり、小さく疊んで詰めました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "旅に病む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「子供が死に際に言つたのは、六十三の今日ではなくて、六十三番の凶だつたのさ」「えツ」「守り袋にこれがあつたんだ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "黒い巾着",
                "note": "青空文庫"
              }
            },
            {
              "text": "――財布から机の抽斗まで捜し抜いた揚句あげく、守り袋の中に、亡くなった母親が形見のつもりでいるようにと言ってくれた、二分金のあることを思い出し、それを一銭銅貨の代りに、娘の納豆籠に入れてやったことがあります。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "食魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは気の毒だ、――が、もう少し『疾風』のやり口が判っていないと、手のつけようがない」「これなどは良い証拠じゃございませんか」　お島はそう言いながら、後ろへ手を伸すと、針箱の中から贋物ながら蜀紅の錦で作った、守り袋を取出して、平次の前へ押しやりました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "八人芸の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや、神田皆川町たから屋太兵衛倅和太郎、甲辰歳潤五月生――」　守り袋の中の臍の緒書を読んだ、平次の方が驚きました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "八人芸の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "お島さん、この守り袋の出よう一つで、お前はどんな事になるか解らなかった」「まア」「これは俺が借りて行く。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "八人芸の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「相変らず気楽だぜ、八」「まだ腑に落ちない事があるんだが――お島が隠しておけばいいのを、わざわざ針箱の中から和太郎の守り袋を出して見せたのは、どうしたわけでしょう、親分」「そこがお島の賢いところさ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "八人芸の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「子供が死に際に言ったのは、六十三の今日ではなくて、六十三番の凶だったのさ」「えッ」「守り袋にこれがあったんだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "黒い巾着",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「母親の形見でございます、――御殿奉公をしてゐた母親と違つて、藝子や踊り子に身を落した私には、品が良過ぎると申しませうか、――正直に申上げると野暮つたくて氣が引けるのですが、一生の大事と思ふ時は、守り袋の代りに、それを持ち歩きます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美少年國",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、それは俺の守り袋だ、いつの間に――」「ホ、ホホ、麓の茶屋で、これを抜かれたのを御存じなかったのでしょう」「お前か」「まア、まア、私が泥棒や巾着切に見えます？",
              "citation": {
                "source": "大江戸黄金狂",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「外に誰も居なかった筈だが――」「厄介の貝六という、日本一の厄介な男が、あなたの側でドブ六を呑んで、絡みついて居た筈ではありませんか」「フーム」「この守り袋の中に、命と釣替の大事なものが入っていることを御存じでしょう」「いや、その中には臍の緒書が入って居るだけだ。",
              "citation": {
                "source": "大江戸黄金狂",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ねてもさめても銭一文費ふ手だてのない今日このごろ、財布はすつかり守り袋に変つてしまひました。",
              "citation": {
                "source": "島の便り",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
