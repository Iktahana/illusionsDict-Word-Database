[
  {
    "uuid": "d8af0d6c-8dff-5cf5-a101-3012ecc9a143",
    "entry": "松飾り",
    "reading": {
      "primary": "まつかざり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
