    "definitions": [
      {
        "index": 1,
        "gloss": "New Year's pine decorations",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "わたしの暗い故郷の都會ならべる町家の家竝のうへにかの火見櫓をのぞめるごとくはや松飾りせる軒をこえて才川町こえて赤城をみる。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "町内で松飾りを立てたものは一軒もない。",
              "citation": {
                "source": "元日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "背中合せの松飾りはまだ見えなかったが、家々の籬のうちには炉を切って、新造や禿が庭釜の火を焚いていた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "松飾りも例年よりは張り込んだのが多く、緑のアーチに「祝戦捷」などの文字も見えた。",
              "citation": {
                "source": "正月の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁師共の着て居るその「どてら」みたいなものと、船じるし、松飾りをした船とが、しっくりとつり合って、絵にでも書いて置きたい様に見える。",
              "citation": {
                "source": "冬の海",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅梅が咲けば折って前髪に挿し、お正月の松飾りの、小さい松ぼっくりさえ、松の葉にさして根がけにした。",
              "citation": {
                "source": "大門通り界隈一束",
                "author": "続旧聞日本橋・その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "閉め忘れた裏木戸が、風のためにバタンバタンと鳴りつづけ、大道を吹き荒ぶ風は、松飾りに浪のような音を立てさせている。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そうしているうちに、ふと松飾りのざわめきに触れると、彼の神経はふたたび鋭くなってきた。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中井から家へ来るまでの、ほんの一二丁の町並も、もう松飾りをしたりして、福引をやっている。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三四年（昭和九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "平常でさえ賑やかな人形町通りの年の市はことのほか景気だって、軒から軒にかけ渡した紅提燈の火光はイルミネーションの明りと一緒に真昼のように街路の空を照らして、火鉢や茶箪笥のような懐かしみのある所帯道具を置き並べた道具屋の夜店につづく松飾りや羽子板の店頭には通りきれぬばかりに人集りがしていた。",
              "citation": {
                "source": "うつり香",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮廷及び皇族では、正月松飾りをせられない。",
              "citation": {
                "source": "雪の島",
                "author": "熊本利平氏に寄す",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって、度々転居ぐせのある私の現住所へ届くには日数がかかって、松飾りをとってから連日舞いこんでくるのである。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "水茶屋の葭簀は幾軒となく見渡すかぎり半円形をなしたる海岸に連り、その沖合遥なる波の上には正月の松飾りしたる親船、巍然として晴れたる空の富士と共にその檣を聳かしたり。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "「松飾りーい、松飾り、」の所へ来て手を忘れた。",
              "citation": {
                "source": "理想の女",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹の葉の汚らしく枯れた松飾りの間からは、家の軒ごとに各自勝手の幟や旗が出してあるのが、いずれも紫とか赤とかいう極めて単純な色ばかりを択んでいる。",
              "citation": {
                "source": "深川の唄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "菖蒲河岸より大川の面を望むに、暖なる冬日照りわたり、徃来の荷舩には舵のあたりに松飾り立てしものもあり。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "松飾りも取払われて、街には正月気分が見られなくなったが、ここ市川の田舎道を着かざった人々の群が三々五々つづいて通る。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十五　赤罠",
                "note": "青空文庫"
              }
            },
            {
              "text": "松飾りの影が眼先に散らつくほど暮が押しつまった頃、余は始めてこの珍らしい経験を目前に控えた自分を異様に考え出した。",
              "citation": {
                "source": "思い出す事など",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "市民は御重態の発表を知るや、一刻も早く御悩の去らんことを祈りつつ、街々は迎春の用意に商店の軒先も注連繩を張り、吉例の松飾りを立てつつ安き心はなかったのです。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "平次の話が次第に重大さを加へるので、そつと後を振り返りましたが、此處へ來るともう元日の街も思ひの外淋しく、廻禮の麻裃や、供の萠黄の風呂敷が、チラリホラリと通るだけ、兩側の店も全く締めて、松飾りだけが、青々と町の風情を添へて居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "平次屠蘇機嫌",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月もあと一週間で行き詰つて、松飾りがもうあちこちの軒下に樹てられるころだ。",
              "citation": {
                "source": "蒼白き巣窟",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は立つて窓からすぐ汚ない通りを見てゐたが、もう狹苦しい長屋つづきの裏町にも、釘打にされた松飾りが初初しい新しい年を迎へるために、そこここに青青としてゐた。",
              "citation": {
                "source": "蒼白き巣窟",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は原稿の速達を出したかえり、目白の角の果物やの半町ほど先の右側に出ているお飾りやで、小さい松飾りとそこに下げる小飾りとを買って、自分の椅子の座蒲団の布をすこし買って、お恭ちゃんの御飯茶わんかって、そしてかえって来たら、向島の江井が来ていて、お雑煮用の鶏肉をくれました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚れた松飾りのついた町名の書かれた柱が幾本も窓をすぎる。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その若い男は、店の前に立ててある松飾りの、松の葉を弄っていた。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東蔵は松飾りのところに立って、こちらに横顔を向けていたが、明らかに眼の隅で、こっちのようすを見ているようであった。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　　年宿年を迎える家のしるしとして、棚と注連飾り松飾り以外にどういう支度をするか。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　　注連と松飾り注連繩の種類名称と飾り方。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを神々と松飾りに供えるのは、いうまでも無く年男の任務で、そのために度々水を使ってこの寒いのに身を潔めなければならぬ。",
              "citation": {
                "source": "歳棚に祭る神",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
