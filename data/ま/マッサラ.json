        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "机の上などをかたづけ、お風呂にもはいり、まっさらの下着を身につけて寐ました。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の上などをかたづけ、お風呂にもはいり、まっさらの下着を身につけて寝ました。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "フーミ　まっさらな本は素本というもんで。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まっさらな本は素本と言うだろ。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなると何度茶を点てようが、いつどこで茶を点てようが、まっさらな想いの茶になる。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜田は先日も「柳が物を持つと、どんな骨董でも、たちどころに骨董でなくなり、まっさらなものになる。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほれ見せえま」と老人は云った、「まっさらとは云えねえが、造ってからまだ七年にしかなんねえ、大事にしろばまだ十五年や二十年はたっぷり使えるだ」　私は自分の考えを述べようとした。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハッタリと取られると困るが、紹介状を用意しといた」　ポケットから、白い、まっさらの封筒を出してきた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとの対比で、照子のまっさらのヨコビラ（足袋）が俺の眼をひいた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕日がメアリの顔にかかるのをじっと見て、誇り高い顔の下に、純粋でまっさらな心があるのを見抜いた。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカではまっさらな経歴で出直しされると思ったら間違いです。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "風がもろに当たる大通りは吹きさらしになり、まっさらな畑のようで、その他の積雪は約一メートル。",
              "citation": {
                "source": "四日白魔",
                "author": "THE FOUR WHITE DAYS",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、彼が今度移ったうちは、東栄館という、新築したばかりの、まだ壁に湿り気のある様な、まっさらの下宿屋でしたが、ここで、彼は一つのすばらしい楽みを発見しました。",
              "citation": {
                "source": "屋根裏の散歩者",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
