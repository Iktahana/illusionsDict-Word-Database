    "definitions": [
      {
        "index": 1,
        "gloss": "(thick) scarf",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
