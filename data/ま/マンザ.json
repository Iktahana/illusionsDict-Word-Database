[
  {
    "uuid": "b0464d7b-88a8-5b77-9c8a-03667388ad8f",
    "entry": "満座",
    "reading": {
      "primary": "まんざ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
