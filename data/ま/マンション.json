        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "政府にあったリー・シー・ツワンは今暁香港に飛行機で来り、直にホテル・マンションに入ったことが記事になっていた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテル・マンションには、青銅色の秋が訪れていた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "表参道を折れたところにあったマンションの小さな事務所を訪ね、萩野さんに加えて、北村礼明さんと鎌田純子さんにも会うことができました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "学年が進むに連れて大学には顔を出さなくなり、マンション設計ではかなり力を持っている会社への就職も、自分で決めました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "頃日僕の書く物の総ては、神聖なる評論壇が、「上手な落語のようだ」と云う紋切形の一言で褒めてくれることになっているが、若し今度も同じマンション・オノレエルを頂戴したら、それをそっくりお金にお祝儀に遣れば好いことになる。",
              "citation": {
                "source": "心中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "編集作業は新宿の西のマンションで行われたが、編集長は北大出身で西より九歳上の星正明が担当した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌作りの根城は、西が新しく代々木に借りたマンションの一室に置かれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "確かに広くはないものの、下宿でもアパートでもない、まぎれもないマンションの一室に西は住んでいた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラグを抜き差しして回路を調整しながら音を変えていくパッチボード式のこのシステムに塚本は目を輝かせ、以来西のマンションに入りびたりとなった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "港区の南青山に借りたワンルームマンションが、新しいオフィスとなった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが大半がマンションの一室にマシンを並べただけの開発元は、フロッピーディスクやカセットへのコピーを大量にこなす設備など持っておらず、こうした作業を専門にこなす業者も存在していなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マンションの一室でのたこ部屋作業に明け暮れる若者たちを励まし、製品の出荷にこぎ着けるために、ほとんどが一世代下の社長たちにあれこれと手を貸した成果は、春が過ぎてからようやく実りはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "加えて裏方として会社を支えるまとめ役が一人、つごう三人の核となる人材がそろっていれば、借りているマンションの部屋がいかに狭かろうと、会社らしい体裁を欠いていようと、ソフトハウスには勢いがあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その西は今、青山のマンションにアスキー出版の事務所を構えているという。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が滞在していたのはブロードウェー・マンションの十五階の一室で、目の下に街衢の屋並から、遙か、黄浦江の流れや村落が展望された。",
              "citation": {
                "source": "秦の憂愁",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の宿ブロードウェー・マンションまではかなり遠く、自動車で送って貰った。",
              "citation": {
                "source": "秦の出発",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "米国映画と日本映画　帝劇を出て、私は有楽町駅前に新装し得たマンションクラブに、一夜の宿を借りるべく暗い大路小路をぞろぞろと、人群れの裡を押されながら歩いて行った。",
              "citation": {
                "source": "アーニイ・パイルの前に立ちて",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "マンションクラブは、我々同人の集まる、袖すり合えば多生の縁ありという、その緑の下の力持ちをする同人達の息抜きクラブである。",
              "citation": {
                "source": "アーニイ・パイルの前に立ちて",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "マンションクラブの一夜は、お隣から急雨のごとく響ききたる変電所の騒音に明けて、八時半の急行列車に乗る。",
              "citation": {
                "source": "アーニイ・パイルの前に立ちて",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "行列を見ようとしてマンションハウスの前に立ってたところが、日本と違って向うのものがあんまり君より背丈が高過ぎるもんだから、苦し紛れにいっしょに行った下宿の亭主に頼んで、肩車に乗せて貰ったって云うじゃないか」「馬鹿を云っちゃいけない。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "大仏がなくなった代わりに、それより遥かに大きい高層マンションが、街のあちらこちらに建っている。",
              "citation": {
                "source": "湯けむり",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "塗り固めたような湯けむりの太い柱が、マンションよりもはるかに天高くまで伸びている。",
              "citation": {
                "source": "湯けむり",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ブロマンの前で今夜……八時」　ブロードウェイ・マンションのことである。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは海に近いところにあるマンションなんだよ。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "余計な荷物はトランク・ルームに預けて、ふたりでどこかのマンションの２ＤＫに半年もいれば、それでいいのですから」「いまのうちかもしれませんね」「建物は限界を越えてます。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来たばかりのときにこの建物をいまの日本の人が見たなら、結構なマンションではないか、と思うだろう。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
