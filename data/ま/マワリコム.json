        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その谷が途中からだらだらと向こうへ回り込む所に、右にも左にも、大きな葭簀掛けの小屋を、狭い両側から高く構えたので、空さえ存外窮屈にみえる。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐるっと山のふもとをまわりこむと、目の前に洞門があらわれた。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘と丘とのあいだを北にまわりこむと、眼下に河が見えた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "島の南へまわりこむと、灰色の曇天となった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "南側にまわりこむと陸地がとぎれ、リーフの内側に飛び石のようにまっ白い砂地が点々とつながっている部分がある。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな砂丘の下へ降り、裾をまわりこむようにして、その隣りの砂丘へ歩いた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
