    "definitions": [
      {
        "index": 1,
        "gloss": "the whole mountain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "川は、底を傾けて、水を震うので、森の中まで、吹雨が迷い込んで、満山の樹梢を湿す。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "初冬の風が吹いて満山の木が鳴った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "満山の風がまた亙る。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒るときは、山腹にかみなり稲妻を起し満山は暗くなった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "落葉を踏んで頂に達し、例の天主台の下までゆくと、寂々として満山声なきうちに、何者か優しい声で歌うのが聞こえます、見ると天主台の石垣の角に、六蔵が馬乗りにまたがって、両足をふらふら動かしながら、目を遠く放って俗歌を歌っているのでした。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "高嶽の絶頂は噴火口から吐き出す水蒸気が凝って白くなっていたがそのほかは満山ほとんど雪を見ないで、ただ枯れ草白く風にそよぎ、焼け土のあるいは赤きあるいは黒きが旧噴火口の名残をかしこここに止めて断崖をなし、その荒涼たる、光景は、筆も口もかなわない、これを描くのはまず君の領分だと思う。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "渦いて寄する風の音、遠き方より呻り来て、どっと満山に打あたる。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "競り上るように鮮かさを見せる満山の新緑。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "熟して満山にしたれあふれた蜜柑の黄金！",
              "citation": {
                "source": "動かぬ女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "渦いて寄する風の音、遠き方より呻り来て、どつと満山に打あたる。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……満山のもみじの中に、もくりと一つ、道も白く乾いて、枯草がぽかぽかする。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "若くして禅学に達し、聖福寺の東瀛禅師、建仁寺の黙雷和尚に参し、お土産に宝満山の石羅漢の包みを提げて行って京都の俥屋と、建仁寺内を驚かした。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう雪の山路に行き暮れて満山の雪折れの音を聞くということは、想像するだけでも寒いようである。",
              "citation": {
                "source": "軽井沢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の火は朝露に晃々と、霧を払つて、満山の木の葉に映つた、松明は竜田姫が、恁くて錦を染むる、燃ゆるが如き絵の具であらう。",
              "citation": {
                "source": "貴婦人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那にも千疋猴あった例、程伯淳、山に遊んで猴一疋も見えず、山僧より〈晏元献南に来て猴性すこぶる霊し、相車来ればすなわち満山に迎う、騾に鞭ちてここに到れば何ぞかつて見ん、始めて覚る毛虫にもまた世情〉。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "宋の州の五峯に至りし人、〈馬上遥かに山中の草木｜蠕々とし動くを見る、疑いて地震と為す、馭者いう、満山皆猴なり、数千万を以て計る、行人独り過ぐれば、常に戯虐に遭う、毎に群呼跳浪して至り、頭目胸項手足に攀縁す、袞して毛毬を成す、兵刃ありといえども、また施す所なし、往々死を致す〉。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ側面観なるが、正面より、即ち山麓の臼井村より見れば、男体女体の双峯天を刺して満山鬱蒼たり。",
              "citation": {
                "source": "秋の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、どういふわけで斯んなに沁々と、秋風が身に沁むのかと思ふと、愚かな自分に二の句も吐げなかつたが、度胸を決め直してあたりの山々を見直すと、まさに満山の紅葉が吹雪を浴びて、火の粉の如く舞ひあがり、その華麗さは夢かと思ふばかりの光景であつた。",
              "citation": {
                "source": "風流旅行",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏通寺（許山一宿）・あけはなつや満山のみどり　水音の若竹のそよがず・山のみどりのふか／″＼雲がながれつゝ・塔をかすめてながるゝ雲のちぎれては・ほんにお山はしづかなふくろう四月三日　曇――晴れさうな、尾ノ道にて。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "満山に紫黄相｜雑りて奇麗繁華限なし。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "満山あせび、ぶな、うつ木にて大木はなし。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "惟聽青龍長廣舌　　惟だ聴く青竜の長広舌、滿山松籟和溪聲　　満山の松籟渓声に和す。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時は初夏で満山潮の湧くやうであつたが、今は秋やうやく深く木の葉が散つて来る。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "違うよ」と私は説明しきれないもどかしさに苛々したが、ひょいと眼を挙げれば、宿場はすでに出て、満山の常緑が眼に明るい。",
              "citation": {
                "source": "箱根の山",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "見渡す限りの満山の錦、嵐が一度颯と渡るや、それが一度に起き上がり億万の小判でも振るうかのように閃々燦々と揺れ立つ様はなんとも云われない風情である。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで満山の落葉を見おろしてゐる気持は、あはれな留学生の身の上でも、やはり感ずるに堪へたるものであつた。",
              "citation": {
                "source": "接吻",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時にはもういつのまにか大きな月が出て、高野の満山を照らして居り、空気が澄んでゐるので光が如何にも美しく、悪どく忙しくせつぱつまつた現世でも、やはり身に沁みるところがあつた。",
              "citation": {
                "source": "仏法僧鳥",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一首の意は、満山の光るまでに咲き盛っていた花が一時に散ったごとく、皇子は逝きたもうた、というのである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時にはもういつのまにか大きな月が出て、高野の満山を照らして居り、空気が澄んでいるので光が如何にも美しく、悪どく忙しくせっぱつまった現世でも、やはり身に沁みるところがあった。",
              "citation": {
                "source": "仏法僧鳥",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "出発前に軍記をあさつて関ヶ原の地形だけは心に控えた甚兵衛だつたが、似た山ばかりで、どれが主家の陣地を構へた天満山やら、それすらもしかと分らない。",
              "citation": {
                "source": "わが血を追ふ人々",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
