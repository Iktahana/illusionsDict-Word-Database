        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "名工の手によって仕上げられた工芸品は、細部までまいゆ細工が施されており溜息が出る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女のまいゆ琴の音色に、会場を埋め尽くした観客は静かに聞き入っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "庭師のまいゆ手つきによって、乱れていた松の枝が見事な造形へと整えられていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
