    "definitions": [
      {
        "index": 1,
        "gloss": "last day (of a month)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "広小路の松坂屋へはいって見ると歳末日曜の人出で言葉通り身動きの出来ない混雑である。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――田螺公）五首ずつ集　　　　　　　　　最近作二月末日〆切　五首　　　　　　　　　（題□□□）佐波郡三田尻駅前浴永不泣子宛（椋鳥会『初凪』　大正二年一月）",
              "citation": {
                "source": "雑信（二）",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは四月末日までの、私たちの生活費の全部である。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧紙幣の通用するうちに、式をあげた方がいいだろうと説き伏せると、彼も漸く納得して、二月の末日、やっと式ということになった。",
              "citation": {
                "source": "鬼",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月の暖かい朝のこと、末日教徒は自らが紋章にしていた蜂の巣にたがわず、蜂のように忙しかった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "被害者は両名とも若年の頃末日教徒の一員であり、このたび死んだ被疑者ホープはソルト・レイク・シティ出身であるそうだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月の末日が、段々近づいて来るに従って、父は毎日のように金策に奔走した。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月の末日が、段々近づいて来るに従つて、父は毎日のやうに金策に奔走した。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、一九四五年一月末日神田と本郷の一部が真先に空襲をうけた。",
              "citation": {
                "source": "田端の汽車そのほか",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月の末日に、殆ど例年の如く、この連嶺は、一日か二日か全く雲に包まれて姿を見せず、温度は俄に降下して、外套を求めたいほどのことがある。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月末日の晝頃、北海道實業雜誌社に行つて見た。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その月の末日になつて、加集がまたやつて來たが、今度は、いよ／＼鶴田から借りる金が出來たと云ふ報告をしに來たのであつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月末日のことであった。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月末日のことであつた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤陰は六月発兌の二編を、早くも五月末日に贖ひ得たのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月の末日に乳母は家を出るはずであったから、その日に宇治から恋人を移そうと計画をしておいでになるのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはもう大分巴里の事情に通じた気がするので、四月の末日限り此陰気な食卓から逃れて仕舞つた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし法典延期の期限は明治二十九年の末日で尽きるのであるから、同年の帝国議会でなお一箇年半の再延期法案を議定し、十二月二十九日に法律第九十四号としてこれを公布された。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪役者二代目実川延若が若し今のまゝ、又は今の病状に一歩を進めるやうなことがあつたら、其こそ、幸四郎の場合よりも、更にまざ／＼と、寂しい歌舞妓の末日の姿を見つゝ耐へねばならなくなるだらう。",
              "citation": {
                "source": "実川延若讃",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "之を読み了へて下さつた大方の人々、延若の才能、或点では天才的でもあつた彼の素質を、此歌舞妓及び彼自身の末日の今において、思ふ限り伸べさせる望みをお起しにならないだらうか。",
              "citation": {
                "source": "実川延若讃",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月末日までに品物の納入完了という契約であるが、早いほど良いからというペルメルのサイソクであった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日といえば八月末日にほぼギリギリというところ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "久五郎は泣きほろめいて多門を詰問しカケ合ったがダメの物は仕方がないから、ギリギリの八月末日に自分の買い集めた五万五千斤だけ横浜へ届けて、契約の期限は今日だが、あと十日だけ待ってくれ、残りの四万五千斤はそれまでに必ず納入するから、と懇願した。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本を離れたのが前の年の七月末日であるから、約半年かゝつて目的地に足を踏み入れたわけだが、その時、懐中わづかに十六フランしか残つてゐなかつたことを覚えてゐる。",
              "citation": {
                "source": "外遊熱",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "致斎の方は、昔は絶対な物忌みであつたらうが、令の規定以来、少しく軽くなり、十月の末日と定められて、山城の京都では、加茂川の某地点で、御禊を行はせられた。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "書きかけの長篇小説の原稿をふところに入れて、僕が京都へ行つたのは、去年の一月末日だつた。",
              "citation": {
                "source": "囲碁修業",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月末日、修善寺へ。",
              "citation": {
                "source": "小説　圓朝　あとがき",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて他の大陸からの通信が絶えてしまった、もう一切の通信機関が絶滅したのだ、米国の人はこれが世界の最終の審判日だと知り、いよいよ末日の来たるを待つのみである。",
              "citation": {
                "source": "暗黒星",
                "author": "シモン・ニューコム",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとは、この六月末日と、さうしませう。",
              "citation": {
                "source": "椎茸と雄弁",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
