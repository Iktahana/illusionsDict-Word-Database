    "definitions": [
      {
        "index": 1,
        "gloss": "deep blue",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "湖畔亭のあたり、真青な湖水の上に、白鳥のやうな白いボートが浮んで居たのを夢のやうにおぼえてゐる。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちらこちらに切り倒された大木の下から、真青な羊歯の鋸葉が覗いている。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "興津を過ぐる頃は雨となりたれば富士も三保も見えず、真青なる海に白浪風に騒ぎ漁る船の影も見えず、磯辺の砂雨にぬれてうるわしく、先手の隧道もまた画中のものなり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの夢の景色の中では、すべての色彩が鮮やかな原色をして、海も、空も、硝子のように透明な真青だった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "西の山｜懐より真直に立ちのぼる煙の末の夕日に輝きて真青なるをみつめしようなり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "セルロイドの窓から見える空は実に真青で美しかった。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "星の光っている空は真青であった。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……扉浅うして、然も暗き奥に、一｜個人面蛇体の神の、躯を三｜畝り、尾と共に一｜口の剣を絡うたのが陰影に立つて、面は剣とゝもに真青なのを見た時よ。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此日、本線に合して仙台をすぐる頃から、町はもとより、野の末の一｜軒家、麓の孤屋の軒に背戸に、垣に今年竹の真青なのに、五｜色の短冊、七｜彩の糸を結んで掛けたのを沁々と床しく見た、前刻の今で、桔梗は星の紫の由縁であらう。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藍色の空には、白く光る雲が、糸のように流れているばかり…………崖の下には、真青く、真白く渦捲きどよめく波の間を、遊び戯れているフカの尻尾やヒレが、時々ヒラヒラと見えているだけです。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "緞子の椅子の肱に白い、ふくよかな両腕を投げかけて、そういう青年の顔を真正面から見上げていた眉香子は、非常に感動したらしく真青になっていた。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ウーム」　縛られたまま敷布団の上に起き直った青年は、ポマードだらけの毛髪を振り乱したまま真青になって自分の周囲を見まわした。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに釣込まれるように半三郎も、両手を突いたまま真青になった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までの貴方様のお許嫁、蔵元屋のお熊さんと生写しで御座いましょうが」　半三郎の真青な顔が、見る見る火のように赤くなった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "通りの海添いに立って見ると、真青な海の上に軍艦だの商船だのが一ぱいならんでいて、煙突から煙の出ているのや、檣から檣へ万国旗をかけわたしたのやがあって、眼がいたいように綺麗でした。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にケルソン市の岸に立ち竝んだ例のセミオン船渠や、其の外雑多な工場のこちたい赤青白等の色と、眩るしい対照を為して、突っ立った煙突から、白い細い煙が喘ぐ様に真青な空に昇るのを見て居ると、遠くが霞んで居るのか、眼が霞み始めたのかわからなくなる。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "札幌の貧民窟と云はれるその界隈で流行り出した赤痢と云ふ恐ろしい病気の事を薄々気味悪くは思ひながら、お末は力三の手から真青な胡瓜を受取つた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勃凸は真青に震へて怒つてゐた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の外の樹々の若葉が、二人の顔や体に真青に反映した。",
              "citation": {
                "source": "窓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……夜の蓮華の白いのの、いま真青な、麓の川波を綾に渡って、鼓の緒を捌くように響いて。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、気勢がしたか、ふいに真青な顔して見ると、寂しい微笑を投げて、すっと下りたのである。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "月代が真青で、鬢の膨れた色身な手代、うんざり鬢の侠が一人、これが前へ立って、コトン、コトンと棒を突く。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　青月代が、例の色身に白い、膨りした童顔を真正面に舞台に出て、猫が耳を撫でる……トいった風で、手を挙げて、見物を制しながら、おでんと書いた角行燈をひょいと廻して、ト立直して裏を見せると、かねて用意がしてあった……その一小間が藍を濃く真青に塗ってあった。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし小郷の真青な顔を見たくてたまらないの」　弓子はそれが癖らしい早口で言った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小郷が真青になるって、一体そりゃどういう意味……？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、小郷虎吉、真青になるだろうね」　鶴雄は弓子と顔を見合わせて愉快そうに笑った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "君勇の顔はふと真青になり、唇の両脇がふるえた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「小郷のやつ真青になったわ」「掏られて……？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "声はすぐ人ごみの隙間を伝わり、「掏摸だ、掏摸だ」　真青な唇と、不安な唇と、好奇的な唇が、右へ向き、左へ向いた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、真青になった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
