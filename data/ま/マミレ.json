        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しやうふを塗れるガラス戸を、　　学童らこもごもにのぞきたり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みづから塗れる伯林青の、　　むらをさびしく苦笑ひ、胡桃覆へる石屋根に、　　　　いまぞねむれと入り行きぬ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田植で泥塗れになった動物がピカピカに光って街道を帰ってゆく。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方山から土に塗れて帰って来る彼らを見るがよい。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥に塗れたまままた危い一歩を踏み出そうとした。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ドッテテドッテテ、ドッテテド、　タールを塗れるなが靴の　歩はばは三百六十尺。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドツテテドツテテ、ドツテテド、タールを塗れるなが靴の歩はばは三｜百六｜十尺。",
              "citation": {
                "source": "月夜のでんしんばしらの軍歌",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れた日には庭一面におしめやシャツのような物を干す、軒下には缶詰の殻やら横緒の切れた泥塗れの女下駄などがころがっている。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（隣の部屋から画箱を持ち出して捜しながら歌う）「一本ガランスをつくせよ空もガランスに塗れ木もガランスに描け草もガランスに描け天皇もガランスにて描き奉れ神をもガランスにて描き奉れためらうな、恥じるなまっすぐにゆけ汝の貧乏を一本のガランスにて塗りかくせ」村山｜槐多も貧乏して死んだんだ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてが埃に塗れて汚らしく、肉慾で人を繋ぐグロテスクで残忍な獄屋の正体をありありと見せ付けられる感じがした。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、砂がついて、あれ、こんなに、」と可怨しそうに、袖についた埃を払おうとしたが、ふと気を着けると、袂は冷々と湿りを持って、塗れた砂も落尽くさず、またその漆黒な髪もしっとりと濡れている。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ドツテテドツテテ、ドツテテド、　タールを塗れるなが靴の　歩はばは三百六十尺。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と見れば美人は仰様に転び、緑髪は砂に塗れて白き踵は天に朝せり。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と辻便所より女乞食、膚の色の真白きに、海松のごとき袷を纏えば、泥に塗れし残の雪。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎧飴を以て釜を塗れば、崇は蝋を以て薪とす。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右に一體、牛頭、馬頭の、あの、誰方も御存じの――誰が御存じなものですか――牛頭の鬼の像があつたが、砂埃に塗れた上へ、顏を半分、べたりとしやぼんを流したやうに、したゝかな蜘蛛の巣であつた。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とかくは馬蹄の塵に塗れて鞭を揚ぐるの輩にあらざるなり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "松明をそなたへ向けて窺うと、岩を枕に唸っているのは、半面｜血塗れの怪しい者であった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上また彼が犯した血塗れの罪悪は暗い部屋の隅から絶えず彼に呼びかけ、彼を嘲笑い、そして氷のような指で彼の眠りを揺り起した。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、真中の哀れな一本は、雪に塗れ寒く小さかった。",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "……こんな工合では、やがてのことも我々は、雨降りの映画を見ればビショ塗れになるだろうし戦争の映画を見れば多数の見物が悶絶してしまう程に、効果的なフィルムが市場に出現するに違いありますまい……検閲制度ですか？",
              "citation": {
                "source": "十年後の映画界",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "井深君は、みるみる雪のために、帽子もかぶらないお河童の頭とオレンジ色のジャケツが白く塗れて行くのを眺めているうちに、少々変な気持がし出した。",
              "citation": {
                "source": "嘘",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人とも傘がなかったので、再び雪に塗れ乍ら電車道まで歩いた。",
              "citation": {
                "source": "嘘",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "で何事に依らず氣疎くなツて、頭髪も埃に塗れたまゝにそゝけ立ツて、一段と瘻が甚く見える。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "前通には皿や鉢や土瓶やドンブリや、何れも疵物の瀬戸類が埃に塗れて白くなつてゐた。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀子の父親はちょうどそのころ、田舎に婚礼があり帰っていたが、またしても利根の河原で馬を駆り、石に躓いて馬が前骨から頬へかけて、肉が爛れ血塗れになっていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして伊奈子を血塗れにして、七転八倒させつつ冷笑していようという私の計画は、私の頭の中でいくつもいくつもシャボン玉のように完成しては、片っ端から、何の他愛もなく瓦解幻滅して行った。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生の言によると、それはタムシ草と云って、その葉や茎から出る汁を塗れば疥癬の虫さえ死んでしまうという毒草だそうで、食べるどころのものでは無い危いものだということであって、自分も全く驚いてしまった。",
              "citation": {
                "source": "野道",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには笹竹や芹などの雑草が生え、塵芥にまみれて捨てられてる、我楽多の瀬戸物などの破片の上に、晩春の日だまりが力なく漂っているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅員の不機嫌顔甚だしきも官線はやはり官線だけの権力とか云うものあるべしと、かしこみて願い奉りようよう切符を頂戴して立ちいずれば吹き上ぐる朝嵐に藁帽飛んでぬかるみを走る事｜数間、ようやく追い付きて取止めたれど泥にまみれてあまり立派ならぬ帽の更に見ばえを落したる重ね／＼の失敗なり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
