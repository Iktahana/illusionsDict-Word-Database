    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to lose one's way",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "戸袋のすぐ横に、便所の窓の磨硝子から朧な光のさすのに眼をうつすと、痩せたやもりが一疋、雨に迷う蚊を吸うとてか、窓の片側に黒いくの字を画いていた。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓前花堆うして香煙空しく迷う塔婆の影、木の間もる日光をあびて骨あらわなる白張燈籠目に立つなどさま／″＼哀れなりける。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝは稍静かなれど紅塵ようやく深く鉄道構内の煤煙風に迷うもうるさし。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白剥山の入口などは、解らなくて、森の中を一行が、離れ離れに迷うばかり、滝上りまでもやった、一時は絶望に近かった、しかし山腹に辿りついてからは、去年の路が、微かに見分けが出来た、頂は存外変りがなかった。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも私自身も郵便を投函する必要のあるとき自動車の運転手に「郵便函があったら留めてくれ」といおうか「ポストがあったらストップしてくれ」といおうか、どっちがよくわかるだろうかと咄嗟に迷うことがある。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内人なしにいい加減な道を歩いていると道に迷うてとんでもない災難に会わなければならない。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし問題の分析をせずに研究すればいつまでたっても要領を得ないで五里霧中に迷うような事になってしまう。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその二つの世界の限界を定めようとする時にドーミエーやゴヤやロートレークの或る作物をいずれの領分に配していいかを決定するのに迷うのである。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに迷うことは、嘗てなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無断で借りて帰った分のことをどうしようかと心で迷う。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめは体を押つけたのが、足ばかりとなり、手さきとなり、果は間を隔てていても、道を迷うた旅人は嬢様が思うままはッという呼吸で変ずるわ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その面貌の無邪気なる、その謂うことの淡泊なる、要するに看護員は、他の誘惑に動かされて、胸中その是非に迷うがごとき、さる心弱きものにはあらず、何等か固き信仰ありて、たといその信仰の迷えるにもせよ、断々｜乎一種他の力のいかんともし難きものありて存せるならむ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "草原に花をたずねて迷う蜂の唸りが聞える。",
              "citation": {
                "source": "ある幻想曲の序",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その自殺致しました△△には妻と男の子が三人ありまして、今申上げましたような事情で路頭に迷うておりますのを、微力ながら吾々友人が寄り集まりまして、どうにかこうにか喰えるように処置いたしましたが、ここに困りますのはその三人の子供に父の死因が知らせられない事で御座います。",
              "citation": {
                "source": "恐ろしい東京",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "深夜の十字街頭に音もなく立ち迷うて、何かの亡霊に取り憑かれたかのように、くるくるくると闇黒の中に渦巻き込む塵の幾群れが見える。",
              "citation": {
                "source": "塵",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵野に散歩する人は、道に迷うことを苦にしてはならない。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年はしばし四辺を見渡して停止みつおりおり野路を過る人影いつしか霧深き林の奥に消えゆくなどみつめたる、もしなみなみの人ならば鬱陶しとのみ思わんも、かれは然らず、かれが今の心のさまとこの朝の景色とは似通う節あり、霧立ち迷うておぼろにかすむ森のさまは哀れに物悲し、これ恋なり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内記が詳密で正確であればあるほど、これに対する信頼の念が厚ければ厚いほど、われわれは安心して岐路に迷う事なしに最少限の時間と労力を費やして安全に目的地に到着することができる。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "血迷うばかりの、清葉を遮って、突戻すためであった。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　この辺に蛍は珍らしいものであった、一つ一つ市中へ出て来るのは皆石滝から迷うて来るのだといい習わす。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがためにこそ餓えたり、傷付いたれ、物怪ある山に迷うたれ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧のある日ならミーロだって迷うよ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……薄き海の光の末に、烏の立迷う風情であった。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人は訝り、「これこれ、其方は血迷うていやるようじゃ、落着いて申すが可い、死んだといやる、何がどうしたのじゃ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉱蔵　（ふわふわと軽く詰め寄り、コツコツと杖を叩いて）血迷うな！",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　大通りは一筋だが、道に迷うのも一興で、そこともなく、裏小路へ紛れ込んで、低い土塀から瓜、茄子の畠の覗かれる、荒れ寂れた邸町を一人で通って、まるっきり人に行合わず。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「血迷うな、誤解はどうでも構わないが、君は卑劣だよ。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これえ消したが最後、立処に六道の辻に迷うだて。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その雪烟の中に迷うが如き火の光が一点、見えつ隠れつ近寄って来たので、忠一は思わず声をあげて呼んだ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝の田町の方から人魂のやうな火が宙を迷うて来る。",
              "citation": {
                "source": "雨夜の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
