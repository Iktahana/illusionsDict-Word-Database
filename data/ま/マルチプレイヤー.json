        "examples": {
          "standard": [
            {
              "text": "彼はギタリストであり、ピアニストでもあるマルチプレイヤーとして知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "バンドでは、ボーカル、ギター、キーボードをこなすマルチプレイヤーのメンバーが重宝される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "舞台俳優としては珍しく、歌、ダンス、演技全てをこなすマルチプレイヤーだ。",
              "citation": {
                "source": "幻辭AI",
