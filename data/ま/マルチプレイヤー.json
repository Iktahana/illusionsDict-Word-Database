        "examples": {
          "standard": [
            {
              "text": "オンラインゲームのコミュニティでは、熱心なマルチプレイヤーが多く活動している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "eスポーツの世界では、高度なスキルを持つマルチプレイヤーが競い合っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このゲームは、一人でじっくり遊ぶモードと、大人数で競うマルチプレイヤーモードの両方が楽しめる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
