        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "末の見込みのない土地であったが野菜や蕎麦も蒔き付けた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のツァーランに着いたのはちょうど五月中頃でございましたからようやく麦を蒔き付けた位でした。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "みれば、ですくの上に突つ伏した大人の額を、いつのまにか蛇がぎりぎりとまきつけてゐた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お前は、腹のまわりに袋に入れたあの粉をまきつけて、――おや、妊娠三カ月にも見えやしなくって？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、ボロ切れをまきつけた脚でいざりながら、鑿岩機を使ったり、槌を振り上げたりした。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ふたりのにいさんがブランコにのって、腕を綱にまきつけて、からだをささえているわ。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊り子はこの着物を着て、サフラン色の布を首にまきつけます。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな山賊の娘は、ゲルダの首のまわりに腕をまきつけて、片手にナイフを持ったまま、いびきをかいて、眠りこんでしまいました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居小屋はしまってしまうし、菓子屋のおかみさんたちは、砂糖菓子の子ブタに、黒い喪章をまきつけました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしのからだに、まきつけるんだ」と、家来に言いつけました。",
              "citation": {
                "source": "わるい王さま（伝説）",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしは、天使のような、小さな腕を、わたしの首にまきつけて、『アン・リス』とおっしゃったものだわ。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "『芸術博士』に応募して落ちた時など帯を首にまきつけました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、松の木にまきつけた綱をさがすつもりで、牛の腹をいつまでもなでまわしたりします。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ま、ちょっと一服するくらい、いいだろう」と和太郎さんは、手綱を松の太いみきにまきつけながら、いいました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だらんとはだけた浴衣の裾は立てた膝にまきつけていても、すぐみだれ勝ちになるのだが、それが案外だらしなく見えなかったのは、白粉気のない皮膚の清潔さと、青み勝ちに澄んだ眼の、怜悧そうな光のせいであろう。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお部屋に、長い／＼青いひげの生えた王さまが、緑色のびろうどの着物を着て、帯のかはりに、銀色の蛇をまきつけて、椅子にかけてゐます。",
              "citation": {
                "source": "湖水の鐘",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそこの床の上には、上衣やチョッキがぬぎすててあって、そしてドアの背後についている鉤金に、フランス中部鉄器株式会社の専務取締役が、自分の首の廻りに自分のズボンツリをまきつけてブラさがっていた。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、いくらかの看護婦と、二人の顔と胸に繃帯をまきつけた少年が椅子にかけて居た。",
              "citation": {
                "source": "青白き夢",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひいさまは、そこでまず、うるさくまつわるながい髪の毛を、しっかりあたまにまきつけて、さんご虫につかまらないようにしました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の子は、かた手にちいさなお皿をもってるし、かた手には土製のパイプをにぎっているので、からだをささえるために、つなにうでをまきつけています。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりとて自分の秘密を知っているたったひとりの彼を、江戸に残して置くのはどうも不安に堪えないので、お定は不意に自分の手拭を相手の首にまきつけて、お駒とおなじように押し片付けてしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は本能的に毛布を足でもちあげ、歯でくわえて短衣の上にまきつけた。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後で、皆は手拭を首にまきつけて、つッ立ったり、白い角の浮石鹸を手玉にしたり、待っていた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁人形には小さい蛇をまきつけて、その蛇のからだを太い竹釘で人形に打ちつけてある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "柳原堤の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋構鉄塔にはいのぼると、彼は胴にまきつけてきた用意の白いズボンの水を絞ってはいた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "カワカミはいずれも後手に縛られ、頸のまわりに番号を書いた赤い巾をまきつけてあった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "たったいまそこを出て来たばかりの小料理屋での記憶が――ぐったりとしなだれかかって来て、腕を首にまきつけたりする若い女の白くぼやけた顔や、やけにかん高い音を立てるこわれかかった蓄音機の音などが、遠い昔のことででもあるかのようにおもい出されて来た。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで運動にも出てゐたものがバツタリと出なくなり、ずつと寢込んでしまふやうになると、その監房には看病夫が割箸に水飴をまきつけたのを持つて入る姿が見られた。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "盲縞の仕事着に繩を帶がはりにまきつけ膝までしかない股引をはき、脛はまるだしで足は草履も足袋もはかぬ跣足だつた。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
