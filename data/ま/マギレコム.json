[
  {
    "uuid": "9888b3b5-e6c5-5204-abe7-34620b4d866f",
    "entry": "紛れ込む",
    "reading": {
      "primary": "まぎれこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to disappear into",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それとも江戸、大阪へ紛れ込む積りで御座いましっろうか……その当てがガラリと外れた昨晩の蔵元屋のお召捕騒動。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "時にはまたとんだいかものが紛れ込む。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "香椎なぞでは泊っている宿へイキナリ踏込まれたので、すぐに脇差を取って懐中に突込み、裏口に在った笊を拾って海岸に出て、汐干狩の連中に紛れ込むなぞという際どい落付を見せて、とうとう大分まで逃げ延びた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "送って出たお孝が紛れ込むように、降り来る雨に、一騒ぎ。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく、夜はいっそう警戒が厳重だろうから――だが、それだけまたこっちにしてみれば、昼よりは紛れ込むに都合がいいわけだからねえ。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "安重根　（急き込む）ポグラニチナヤへ引っ返すか、さもなければチタあたりの、朝鮮人の多いところへ紛れ込むんだ。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "天つ神を喚び降す依代の空高く揚げられてある処へ、横合からふと紛れ込む神も無いとは言はれぬ。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の沈黙にゐて思ひ出す雑踏の慈愛と同様に、雑踏にゐてふと紛れ込む山脈の映像は、恰も目に見え、耳に冴え、皮膚に泌みる高い香気を持つものであつた。",
              "citation": {
                "source": "黒谷村",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "石の崩れなども二ヶ所ほどあって、道の形は次第に怪しくなるが、他に紛れ込むような恐れは無い。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらを避けて横を廻ろうとすると外へ紛れ込むので、いやでも其中を通らなければならない。",
              "citation": {
                "source": "思い出す儘に",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから竈のそばへ移り、流しの下へ移り、皿の中へ紛れ込む。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、騷ぎになつた時、その人數の中に翁屋の店の者でない顏がゐなかつたのかな、――孫六を殺して、土藏の庇合ひとか、井戸の後ろとか、戸袋の蔭とかに隱れて、大勢人が出たところへ、そつと紛れ込む手はあるぜ」　平次はさすがに細かいところに氣がつきます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "月の隈",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども例の穴裏のうすくらがりに紛れ込むと、もう自分の姿がごちやごちやと入り亂れた群衆のなかに揉み消されて、自分ながらも安心するほど其處をうろつく人人が、薄暗く溝闇ににじんで見えるのであつた。",
              "citation": {
                "source": "蒼白き巣窟",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、騒ぎになった時、その人数の中に翁屋の店の者でない顔がいなかったのかな、――孫六を殺して、土蔵の庇合いとか、井戸の後ろとか、戸袋の蔭とかに隠れて、大勢人が出たところへ、そっと紛れ込む手はあるぜ」　平次はさすがに細かいところに気がつきます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "月の隈",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　お菊の死骸の首に捲きついていたのは、同じ「鎌、輪、ぬ」の模様ですが、それは死骸の首から外して、別に証拠の一つとして、町役人に預けてあるので、それが沓脱の下に紛れ込む筈もなく、此処で明かに不思議な柄の手拭が二本現われ、その一筋は間違いもなく昨夜小三郎が忘れて行ったものとなるわけです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "夕立の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はロードス・オン・ザ・ポートゥックストの岸やカヌー小屋をうろついているように見え、後にウィレット医師が現地に行って質問したところ、彼の目的はむしろ土手の方に紛れ込むことで、河に沿って北上し、再び戻って来るまで通常大変に長い時間がかかった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "良くわからない形がどんどん暗くなっていく闇の中に紛れ込むのがわかるだけだ！",
              "citation": {
                "source": "千里眼の村",
                "author": "クリスマス・ストーリー",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の中に紛れ込むのが一番安全だ。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから川岸を西行越え、増野、切久保、福士と行くうちに、何かひっかかりが出て来るから見ていてごらんなさい、無事に身延まで伸せたら、この七兵衛が兜を脱いでしまいます」「しかし、間道から身延へ出ないで、信濃路へ紛れ込むようなことはなかろうか」「どうしてどうして。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白根山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三　お菊の死骸の首に捲きついてゐたのは、同じ『鎌、輪、ぬ』の模樣ですが、それは死骸の首から外して、別に證據の一つとして、町役人に預けてあるので、それが沓脱の下に紛れ込む筈もなく、此處で明かに不思議な柄の手拭が二本現はれ、その一筋は間違ひもなく昨夜小三郎が忘れて行つたものとなるわけです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "夕立の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞいかにして敵の陣地へ紛れ込むかゞ問題である。",
              "citation": {
                "source": "武州公秘話",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "門を暗くして紛れ込む両伯のたぐひ。",
              "citation": {
                "source": "雪",
                "author": "高祖保",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日は地方から参集した信者も多いので、まぎれこむには便利に相違ないのです。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その三　魔教の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二人づれが小屋の中へまぎれこむと、狂言作者の小山田新作が、どういうワケだか分らないが、美しい方の女に向って乱暴しようとした。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その四　ああ無情",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごみごみした通りや、広い誰もいないような街をぬけて、頭上にたたきこわしをやっているような高架線の通りへ出て、すこし歩くと、またがらんとした大通りへまぎれこむ。",
              "citation": {
                "source": "ニュー・ヨーク　『青春の自画像』より",
                "author": "前田河広一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日、あの研究所の池の水溜りに、一羽の雄の家鴨がまぎれこむのではないだろうか。",
              "citation": {
                "source": "博士の目",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "『さては、きみは、そんな日本人の変装をして、東京の町へ、まぎれこむつもりだな。",
              "citation": {
                "source": "宇宙怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ただいま、取り調べているところでござります」「うむ、お城のご普請中をつけこんで、雑多なやつがまぎれこむようすじゃ。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから御覧なさい、おどおどして落着いていませんや、無論、私たちが市へまぎれこむとすぐに、おやじは今戸焼の竈を打ちこわして、江戸の外へ逃げ出す寸法なんで……、なぜかって旦那、まごまごしていれば、すぐ仲間がその仕返しに命を助けてはおきませんからね。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ着くまでの間は、たえず、日本左衛門におびやかされている気持でしたが、繁昌な甲府の城下にまぎれこむと、何か気強い気がして、いつかその恐怖も忘れています。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
