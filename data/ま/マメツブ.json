        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まるで自分の體が針にでもなつたやうに、豆粒にでもなつたやうにちぢまるのだ。",
              "citation": {
                "source": "自分の變態心理的經驗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸されるような暑苦しい谷間の坂道の空気の中へ、ちょうど味噌汁の中に入れた蓴菜のように、寒天の中に入れた小豆粒のように、冷たい空気の大小の粒が交じって、それが適当な速度でわれわれの皮膚を撫でて通るときにわれわれは正真正銘の涼しさを感じるらしい。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小豆粒くらいの大きさの花火が、両耳の奥底でぱちぱち爆ぜているような気がして、思わず左右の耳を両手で覆った。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六｜疋めの鹿は、やっと豆粒のくらいをたべただけです。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆粒程の大さの生々しい血汐である。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "また鼻から出たにしたところで、鼻先から一尺四、五寸も前へ突出した食指の上へ、豆粒程の大さだけポタリと落ちる道理はないのだ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "六｜疋めの鹿は、やつと豆粒のくらゐをたべただけです。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雫ひた／＼と滴りて、時の間に消え失する雪は、はや豆粒のやゝ大なるばかりとなりしが、水晶の如く透きとほりて、一点の汚もあらずなれり。",
              "citation": {
                "source": "紫陽花",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき焼けたゞれたる傷にて、目は豆粒ばかりに明きて物見え、口は五分ほどあれど食ふに事足り、今年はや七十歳ばかりと聞けりといへるに、いと有難き人とおもひて、後も折ふしは人に語りいでぬ。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだじゅう、トマトがつぶれたみたいで、頸にも胸にも、おなかにも、ぶつぶつ醜怪を極めて豆粒ほども大きい吹出物が、まるで全身に角が生えたように、きのこが生えたように、すきまなく、一面に噴き出て、ふふふふ笑いたくなりました。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "莢の中の豆　莢の中には豆粒が五つありました。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "かわいらしい、豆粒のような小鬼どもは、ずきんに鬼火をつけて、広間のなかをおどりまわりました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑の次手に、目の覚めるような真紅な蓼の花と、かやつり草と、豆粒ほどな青い桔梗とを摘んで帰って、硝子杯を借りて卓子台に活けた。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹿が此芝をくひに來ることがあると見えて豆粒のやうな鹿の糞がころ／＼と轉がつて居る。",
              "citation": {
                "source": "鉛筆日抄",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆粒程にも小さい黒い点が、腰のあたりで、にぶく白く光ることで剣を吊してゐることがはつきり判る。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾尖に大きな小豆粒ほどの、全く舎利玉通りなる物、自ずから出来いた由見ゆ。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度小豆粒ほどの大きさで幾重かの萼見たやうな薄皮で包まれてゐる。",
              "citation": {
                "source": "樹木とその葉",
                "author": "自然の息自然の聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分を局外に置いて見る時は群小作家皆豆粒よりも小さかったが、自分をその中の一人として比較する時は豆粒よりも小さく思う人よりも更に一層自分が小さく思われて堪えられなかったようだ。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、空港へいったって、豆粒が手ェふってんのが見えるだけだろうし、オマワリと女どもがうるさいだけだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その豆粒ほどの家畜をイギリスに持つて帰つて飼つたなどといふところは、まだ軽い気分で読めます。",
              "citation": {
                "source": "ガリヴア旅行記",
                "author": "Ｋ・Ｃに",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は豆粒でも拾うように、ボツリ、ボツリ、然しむさぼるように、それを読んでしまうと、嫌なものを見てしまったという風に頭をふって、次ぎに渡してやった。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "丹念に、一枚の新聞を何日もかかって、一字一字豆粒でも拾うように読んでいた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗がりから、ワア――ンと飛び上った金蠅の群が、いきなり令嬢の顔に豆粒のように、打ツかった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はがゆくてもよ、豆粒みたいによ、俺達のどこさよ、一人一人よ、殖やして来るんだな。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――つまりこれから先の行手では、まことに春日遅々たるの想ひで豆粒ほどの土に藹々たる無辺の念を凝らしながら、阿吽の呼吸をはかつて、やがては個性を吹き込み、風格を注ぎ込まうといふ妙境なのである……。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蕗の灸はおそらくありふれた豆粒大のそれとは趣きを異にして銅貨大の艾を急所に貼り重ねて、火を点じながら団扇をもつてほいほいと煽ぎたてるといふ凄まじさだつた。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼうえんきやうからみえたぞうさんは、まめつぶほどちひさくて、一ちやうもむかふのほうにゐるやうでした。",
              "citation": {
                "source": "ゾウ　ト　ネズミ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、松村の姿が、肉眼では見えなくなり、それから、巨ゾウのすがたさえも、まめつぶのように小さくなってしまいました。",
              "citation": {
                "source": "灰色の巨人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "空中のまめつぶのような点が、りんごほどの大きさになり、それから、おもちゃのようなかわいらしいゾウの形になり、そのゾウが、みるみる大きくなって、いまは、ヘリコプターから百メートルほどの空を、ユラユラゆれながら飛んでいました。",
              "citation": {
                "source": "灰色の巨人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
