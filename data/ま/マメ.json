      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "legume (esp. edible legumes or their seeds, e.g. beans, peas, pulses)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "街道を折れて、少し下り坂になる道をスタコラと歩いてゆくと、街道でしてゐた豆腐屋の喇叭の音は急に聞えなくなり、道の傍の、森の葉擦の音に私は淋しくなるのであつた。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "14　この會見の後、私は直ちに伊豆の温泉へ旅行した。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、豆腐屋の硝子戸に寫る私の姿も、なんと、維新の志士のやうに見えた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな太平楽を言ふといで、今にＭさんは偉いもの、あんたは豆腐売になる。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　祖母が私を噛むやうに何時もの豆腐売と湯屋の亭主を並べた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫が仰向いて長火鉢の上の柱時計をみながら飛び出した喉豆に掛けた声で「七時かあ」と云つた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆腐売りのラッパが聞こえる、今夜は豆腐が要るのだからラッパが近づくのを待つて呼びとめる――それならば文句はない。",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆腐売りのラッパに酔ふとしてまことに随一だが、それを呼びとめるとしていとも間抜野郎である。",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月雨や御豆の小家の寝覚がち「五月雨や大河を前に家二軒」という句は、蕪村の名句として一般に定評されているけれども、この句はそれと類想して、もっとちがった情趣が深い。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪入の夢や小豆の煮えるうち　藪入で休暇をもらった小僧が、田舎の実家へ帰り、久しぶりで両親に逢ったのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供に御馳走しようと思って、母は台所で小豆を煮ている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に夏の部で評釈した句「五月雨や御豆の小家の寝醒めがち」も、どこか色っぽい人情を帯びてはいるが、詩情の本質においてやはりこれらの句と共通している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪入りの寝るや小豆の煮える中　という句を作り、さらに春風馬堤曲を作る蕪村は、他人の藪入りを歌うのでなく、いつも彼自身の「心の藪入り」を歌っているのだ。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊豆の伊東のやうな、海岸の温泉も嫌ひのものの一つである。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "森のはずれから近景へかけて石ころの多い小径がうねって出る処を橙色の服を着た豆大の人が長い棒を杖にし、前に五、六頭の牛羊を追うてトボトボ出て来る。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず裏の畑の茄子｜冬瓜小豆人参里芋を始め、井戸脇の葡萄塀の上の棗、隣から貰うた梨。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺碧のナポリの湾から山腹を逆様に撫で上げる風は小豆大の砂粒を交えてわれわれの頬に吹き付けたが、ともかくも火口を俯瞰するところまでは登る事が出来た。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小豆色のセーターを着た助手が、水道のホーズから村山貯水池の水を惜気もなく注いで、寝台自動車に冷たい行水を使わせている。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "本郷区役所がコンクリートの豆腐に変った。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "凌雲閣上人豆のごとしと思う我を上より見下ろして蛆のごとしと嘲りし者ありしや否や。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男バナナと隠元豆を入れたる提籠を携えたるが領しるしの水雷亭とは珍しきと見ておればやがてベンチの隅に倒れてねてしまいける。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "磁石とコンパスでこれらの雲のおおよその方角と高度を測って、そして雲の高さを仮定して算出したその位置を地図の上に当たってみると、西は甲武信岳から富士箱根や伊豆の連山の上にかかった雲を一つ一つ指摘する事ができた。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正四、五年頃、今は故人となった佐野静雄博士から伊豆伊東の別荘に試植するからと云って土佐の楊梅の苗を取寄せることを依頼された。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三日　豆腐屋が来た。",
              "citation": {
                "source": "窮理日記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから神田の宝亭で、先生の好きな青豆のスープと小鳥のロースか何か食ってそして一、二杯の酒に顔を赤くして、例の蛙の鳴声の真似をして笑っていた。",
              "citation": {
                "source": "蛙の鳴声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのお家の庭先に私が時々あそびに行つて、さうして、おいしいやはらかな豆なんかごちそうになつたのを、あなただつて知つてたぢやないの。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手にこんなに豆が出來た。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生垣には隱元豆の蔓がからみついてゐる。",
              "citation": {
                "source": "金錢の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お豆腐屋の笛が方々で聞えてゐたわ、あの電信柱が、夕空にクッキリしてて、――僕、つてあの人あたしの方を振向くのよ、昨日三十貫くらゐある石をコジ起しちやつた、つてのよ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "殘る一人席なくて困じけるを、かの醉ひしれたるまめ男、自らは千鳥足の危きをも顧みず、數ならぬ妾に席を讓り賜はりしは、さきのにくさ、恐しさも忘れさりていとど嬉しかりき、この人なからましかば、わが足は棒になりてそれより石に化りなまし。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
