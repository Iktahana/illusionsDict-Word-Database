    "definitions": [
      {
        "index": 1,
        "gloss": "Malta fever (variety of brucellosis caused by the bacteria Brucella melitensis)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
