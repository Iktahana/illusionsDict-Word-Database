    "definitions": [
      {
        "index": 1,
        "gloss": "to be conceited",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は少し成功しただけで、すぐに慢じてしまう癖がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "若いうちに慢じると、その後の成長が止まってしまうだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "どんなに才能があっても、慢じることなく努力を続けることが大切だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "すこしも智を慢じるふうは見えない。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいつまでも手工業にあまんじるべきではないと、ドイツから巻取り段ボール機械の輸入を計画し始めた。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな無意義な殺刀にあまんじる理由があろうか。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翻弄にあまんじる用意は顔にできていた。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
