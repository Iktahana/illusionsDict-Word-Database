    "definitions": [
      {
        "index": 1,
        "gloss": "gypsy rose (Scabiosa japonica)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
