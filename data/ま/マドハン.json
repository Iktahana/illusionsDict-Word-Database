        "examples": {
          "standard": [
            {
              "text": "その投資信託は、ネット販売ではなく窓販でしか購入できない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "窓販でしか手に入らない限定品は、ファンにとって魅力的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最近は、金融商品の窓販も多様化している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "宰相は出て行く気がしないで、飽かなくに雁の常世を立ち別れ花の都に道やまどはん　と言って悲しんでいた。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "なき人を慕ふ心にまかせてもかげ見ぬ水の瀬にやまどはん　と思うと悲しかったそうである。",
              "citation": {
                "source": "源氏物語",
                "author": "朝顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなかに折りやまどはん藤の花たそがれ時のたどたどしくば　というのである。",
              "citation": {
                "source": "源氏物語",
                "author": "藤のうら葉",
                "note": "青空文庫"
              }
            }
          ]
        }
