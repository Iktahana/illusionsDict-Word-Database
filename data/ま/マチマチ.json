[
  {
    "uuid": "77b527b4-1d13-5907-8d52-65e375e7a8b8",
    "entry": "区々",
    "reading": {
      "primary": "まちまち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
