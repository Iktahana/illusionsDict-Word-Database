        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "するとすぐ私の足もとから引いて行った潮水はまた巻き返して波になってさっとしぶきをあげながらまた叫びました。",
              "citation": {
                "source": "サガレンと八月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "地平線に近く夕立雲が渦を巻き返して、驟雨の前に鈍った静かさに、海面は煮つめた様にどろりとなって居る。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎は手紙を巻き返して、封に入れて、枕元へ置いたまま目を眠った。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "井泉村の助役の手紙を読んで、巻き返して、「私は視学からも助役からもそういう話は聞かなかったが……」と頭を傾けた時は、清三は不思議な思いにうたれた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは弾動する激流のように、巻き返しながら、関門めがけて襲いかかった。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "代助は叮嚀に手紙を巻き返して、三千代に渡した。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は最初、これを丸髷の若奥さまとして描写してみたのですが、若夫人では、すでに袖の丈がつまっていますからあの袖を、腕の上に巻き返した格好、あれが出来ませんから、あらためて、袖の長い令嬢にしたのでした。",
              "citation": {
                "source": "謡曲仕舞など",
                "author": "――文展に出品する仕舞図について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕舞で、袖を上に巻き返したあの格好、あれはとてもいい姿だと思います。",
              "citation": {
                "source": "謡曲仕舞など",
                "author": "――文展に出品する仕舞図について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "転属となった計画部でアストラの巻き返しにあたった早水の目の前で、ビジカルクが爆発的なヒットを遂げ、ＣＰ／Ｍに対応したワードスターが人気を集めていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカの家具の傾向に合わせて、木目のキャビネットに入れるなどの巻き返し策をこうじてみた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人を亡くした東野の針路も、定めしその題の示すところに苦心の光鋩を集めたものだろうと察せられたが、東野のみならず、今は人人の念じるところ、それぞれ違った角度からとはいえ、新アジヤに対い沸沸と湧くもののようやく底から逆巻き返して来ている物音が、公園の長蛇の列からも感じられた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番悲しみの深い菅井和尚が一番暢気な笑いを立てて、適当な話を出しているが、地平より高く巻き返して来ている災厄の津浪を望んで、目下の方寸誰が何を云えようか。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから四五尺の長さにメッキリと書き詰めた漢文の上を形式ばかり眼を通して、その結末にある、大倭朝天平宝字三｜年癸亥五｜月於西海火国末羅潟法麻殺几駅大唐翰林学士芳九連二｜女芬　識　という文字を二三度繰り返して読んで、いくらか気を落付けてから、もとの通りに巻き返して箱の横に置いた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃霧は馬の背越の頂で、ふっと切れて巻き返している。",
              "citation": {
                "source": "高千穂に思う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎は手紙を巻き返して、封に入れて、枕元へ置いた儘｜眼を眠つた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（手紙を巻き返しつつ）終わりのほうを読むのはあまりに恐ろしゅうございます。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻き上り巻き上り、高い火先は、逆に後ろへ巻き返しました。",
              "citation": {
                "source": "古木",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "突風が表面を掠めてるらしく、砂塵をでも挙げるように灰色の煙が千切れ飛び、更に内部にも突風が荒れてるらしく、真黒な塊りが巻き返していた。",
              "citation": {
                "source": "波多野邸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小川が、酒匂川と狩川の合流点へ注ぐ角に木床工があって、深さ一尺五寸ばかりの巻き返しになっていた。",
              "citation": {
                "source": "想い出",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、そちらの大人のご希望もあったことだから、未熟な節廻しではあるが、一齣ご披露しよう、といって、くり返し巻き返し同じような唄を歌い、蹣跚たる足どりで帰っていった。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "タラノ音頭　――コルシカ島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――鍾巻流の小手返し、柳生流では「車返し」太刀をグルリと巻き返し、切っ先のぶかに切り込んだ。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十五　父は長い手紙を裾の方から巻き返しながら、「何か用かね、また金じゃないか。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれを読んでしまって、また封筒へ収めるために巻き返した時には、彼の手がただ器械的に動くだけであった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて手紙を巻き返して封筒へ入れると、「ようこそ」と云って、叮嚀に会釈したなり、先に立って宗助を導いた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、終りから巻き返して、再び状袋のなかへ収めた。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸との間には大きい白い磯波が巻き返している。",
              "citation": {
                "source": "生きること作ること",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく煙にむせ返って咳は巻き返して、のた打ち廻った。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の反省は何時もその場限りでほろびたが、今夜の一服は次の一服につなぎ合しても、咳は猛烈に巻き返してはこなかった。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝霞のほうはおなじ繰言のまきかえしにうんざりし、ある日、たまりかねて素ッ気ないことをいうと、白女は朝霞の冷たい態度から、急に曲ったほうへ解釈した。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
