        "examples": {
          "standard": [
            {
              "text": "アパートの管理人は、すべての部屋を開けるマスターキーを持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "防災のため、各フロアのマスターキーは非常口の近くに保管されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "金庫のマスターキーは厳重に保管され、限られた人物しかアクセスできない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "マスターキーをもっていないかぎり、舎監や当直教師も、いきなり四〇七に踏むこむことはできない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「名金」「マスターキー」「拳骨」「ハートの３」「護る影」等、等、連続探偵大活劇が競映され、例の「天国と地獄」の音楽が、必らず追駈のとき演奏された。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
