    "definitions": [
      {
        "index": 1,
        "gloss": "bed(side) screen",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
