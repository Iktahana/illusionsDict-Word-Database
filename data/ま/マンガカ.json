    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cartoonist",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "漫画家自身でもおそらく人によってこれに関する所見を異にするに相違ない。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "優れた観察力をもった漫画家が街路や電車の中で十人十色の世相を見る時には、複雑な箇体が分析されて、その中のある型の普遍的要素が自ずから見出される。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一方において漫画家の抽象は必ずしも直感のみによるとは考えられない。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して漫画家の対象は人間に関係したものであるために、このような分離が困難になり、表現は十人十種になって作者の個性の香が高くなるのは止むを得ない。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしあらゆる可能な漫画家を一団として見る時には、各画家を微分とした無限項の和としての積分は渾然たる一つの定まった極限値を有する「真の」一面と考えるに不都合があるだろうか。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "漫画家の言語たる線や点や色はこれに反して多次的な無限の「連続」を形成するものである。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで漫画家は言語では到底表わす事の出来ない観念の表現をするための利器を持っている。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろあまりに悪達者な漫画家の技巧がその内容と反比例を示す場合も少なくないように見える。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはむしろ漫画家のかいた鳥羽絵がいちばん有効かもしれない。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は、わずかに、粗悪な雑誌の、無名の下手な漫画家になる事が出来ただけでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、しかし、自分は、大きな歓楽も、また、大きな悲哀もない無名の漫画家。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではね、もう一つおたずねするが、漫画家は？",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "流行漫画家上司幾太」「堀木正雄は？",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その点になると、今の日本の漫画家にあなたのようなものは一人もないと云っても誇張ではありますまい。",
              "citation": {
                "source": "岡本一平著並画『探訪画趣』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本画家、洋画家、彫刻家、戯曲家、舞踏家、評論家、流行歌手、作曲家、漫画家、すべて一流の人物らしい貫禄を以て、自己の名前を、こだわりなく涼しげに述べ、軽い冗談なども言い添える。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕にとっては、その屋台に行くのは、その夜がはじめてでしたが、しかし、その店はあの辺の新聞記者や雑誌記者、また作家、漫画家などの社交場みたいになっていて、焼酎を飲み、煙草を吸い、所謂その日その日の「ホットニュウス」を交換し合い、笑い興じている場所だったのです。",
              "citation": {
                "source": "女類",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これじゃ僕は、漫画家になるより他は無い。",
              "citation": {
                "source": "リイズ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の有名な漫画家の描いた文豪の似顔画はあまり出来のいいものではなかった。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "芋銭氏はたゞの漫画家ではない。",
              "citation": {
                "source": "小川芋銭",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "漫画家でもないだろうし、イラストレーターにもおさまらない。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一一月、詩人と漫画家による諷刺誌『太鼓』の同人となる。",
              "citation": {
                "source": "小熊秀雄全集-1",
                "author": "短歌集",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本では往時から文塚、筆塚、針塚といつたやうなものもあるが、東京新聞の漫画家が寄集まつて、島田三郎氏の漫画葬式をやつたのは面白い企てであつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩庸三は、小夜子の家で遅くまで花を遊んだが、遊びに来ていたジャアナリストや漫画家も一緒だった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "この洋画の部では、去年「老婆」を出品して一般の注意をひいた漫画家の池部鈞氏が今年は「落花」という小さい絵を出し、二列に並べたところの上の方に一寸かけられている。",
              "citation": {
                "source": "帝展を観ての感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと後の時代でも、例えばドイツの漫画家グロッスの仕事を見ると、彼の諷刺家としての階級性がよく分る。",
              "citation": {
                "source": "新たなプロレタリア文学",
                "author": "――アレゴリーと諷刺――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これには漫画家の近藤日出造氏もあきれています。",
              "citation": {
                "source": "求め得られる幸福",
                "author": "――今こそ婦人の統一を――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルジョア漫画家も失業でやけになって酔っ払った労働者の酔態を描くだろう。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルジョア漫画家は丁度ブルジョア政治家がそうである通り、それをそれとして現象的に描写する。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロレタリア漫画家だけが、それをやるのだ。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェト同盟の漫画家たちの苦心はここにある。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
