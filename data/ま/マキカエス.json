        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "試合の最終回、強打で一気に点差を巻き返す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "一度は落ち込んだ業績も、新しい戦略で巻き返すことができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は苦しい状況から、最後まで諦めずに巻き返した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
