[
  {
    "uuid": "16edc767-188d-5234-849a-e6ac196b1fee",
    "entry": "的射",
    "reading": {
      "primary": "まとい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "target shooting (with bow and arrow)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "修學の四標的射を學ぶには的が無くてはならぬ、舟を行るにも的が無くてはならぬ。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうなると、大乘佛教の面影も見えて、世界は神聖な夢であつて、その夢の中にあらはれて居る自然は、心靈が百尺竿頭一歩を進めて、下方へ權化したので、心靈から云へば、その無意識的射影であるのだ。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "十発のうち、二発でも一発でも命中すれば、しめたものです」「そういう公算的射撃作戦は、どうも感心できないねえ。",
              "citation": {
                "source": "のろのろ砲弾の驚異",
                "author": "――金博士シリーズ・１――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、一言にしていえば、函数的等値的射影をもって、あらゆる領域への関連をはたす数的構造を存在の内面的構造として考える考えかたと歩を同じくしている。",
              "citation": {
                "source": "リズムの構造",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "物理的説明が光の現象と等値的射影をもつではあろうけれども、まったく異なれる面の中にひろがっていると考えなければならない。",
              "citation": {
                "source": "芸術の人間学的考察",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘言にうずまった人間が、レンズと、フィルムのもつ現象との物質的射影関係にとりすがったこころもちはわかるのである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきの場合、うつすことは等値的射影であるということを意味する。",
              "citation": {
                "source": "「見ること」の意味",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "映すことの構造はうつすが示すように移す、映す、覆すなどの等値的射影を意味している。",
              "citation": {
                "source": "うつす",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その意味するすべての内面には型と原存在との間の等値的射影が指示されている。",
              "citation": {
                "source": "うつす",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本語でうつすことがそのまま移動的意味を構成するごとく、それは芸術の移入的等値的射影性を意味すると考えたい。",
              "citation": {
                "source": "うつす",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる意識の働きの原型もが、生命のすべての現象の等値的射影的関連にありとも考えられよう。",
              "citation": {
                "source": "うつす",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビシャは正しくいえばブシャすなわち歩射で村の社の春祭に的射を行い、終って酒食を共にする風は今もまだ残っている。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "有馬郡｜有野の唐櫃神社に伝わっているネングイというものなどは、正月二日の鬼打神事の一部で、はじめに的射の式があってそれの終った後、弓を地上においてその弓弦の前と後とに、櫨の木で作った杭を六本ずつ二度、合せて二十四本打ちこむ。",
              "citation": {
                "source": "こども風土記",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういった変化は他の土地の、的射の式などにもおりおりに見られる。",
              "citation": {
                "source": "こども風土記",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "四国や九州で百手祭、または御的射の神事といっているのは、的も大きく距離も近くしてあるようだが、射手はたいていの場合には少年であって、みな前々から精進をして練習する。",
              "citation": {
                "source": "こども風土記",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "的射に出る少年選手は弓太郎などと呼ばれ、それを出す家には親類から祝い物を贈ってくるような土地もある。",
              "citation": {
                "source": "こども風土記",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この中で、我が奥常念は一と際高い、殊に蝶ヶ岳に向って低く下っているところは、波の如き山を躍らすこと七、八峰、峰は皆磐石を畳んだもので、石は皆裂け、偃松と、岩ぶすまという地衣が布いているばかり、この方面から常念を望むと、前の婉容はなくなって、見上げるように急峻に尖っている。",
              "citation": {
                "source": "奥常念岳の絶巓に立つ記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その音はかくも無性な激しい怒りとまといつく怖れのもつれあがるのをぶち切ったのだ。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "断然殺してしまわねば死ぬまでまといつくような蛇にも思われる。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "七味唐辛子を売り歩く男で、頭には高くとがった円錐形の帽子をかぶり、身にはまっかな唐人服をまとい、そうしてほとんど等身大の唐辛子の形をした張り抜きをひもで肩につるして小わきにかかえ、そうして「トーン、トーオン、トンガシノコ」と四拍子の簡単な旋律を少しぼやけた中空なバリトンで歌い歩くのがいた。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、前線から手足まといとなってついてきた他の負傷者達も、そこで、急ぐ退却の犠牲となって、片ッぱしから生埋めにされてしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにいろいろの太さの蔓がくしゃくしゃにその木をまといみちも大へんに暗かったのです。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして背嚢から小さな敷布をとり出してからだにまとい、寒さにぶるぶるしながら階段にこしかげ、手を膝に組み眼をつむりました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男女の話声が水口の水の音だとわかっていながら、不可抗的に実体をまとい出す。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おさえたるわが手には血の色つかぬに、燈にすかす指のなかの紅なるは、人の血の染みたる色にはあらず、訝しく撫で試むる掌のその血汐にはぬれもこそせね、こころづきて見定むれば、かいやりし夜のものあらわになりて、すずしの絹をすきて見ゆるその膚にまといたまいし紅の色なりける。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹斎だか何だったか徳川初期の草子にも外法あたまというはあり、「外法の下り坂」という奇抜な諺もあるが、福禄寿のような頭では下り坂は妙に早かろう。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅薄、軽率、不正確、無責任というようなものがおのずから付きまといやすい。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、全く文字どおりの着のみ着のままという罹災者は一人も無く、まずたいていは荷物の四個や五個はどこかに疎開させていて、当分の衣料その他に不自由は無いものの如くに見受けられる。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は高等学校一年生の時に、早くもお洒落の無常を察して、以後は、やぶれかぶれで、あり合せのものを選択せずに身にまとい、普通の服装のつもりで歩いていたのであるが、何かと友人たちの批評の対象になり、それ故、臆して次第にまた、ひそかに服装にこだわるように、なってしまったようである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「其処で田園の中央に家がある、構造は極めて粗末だが一見米国風に出来ている、新英洲殖民地時代そのままという風に出来ている、屋根がこう急勾配になって物々しい煙突が横の方に一ツ。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
