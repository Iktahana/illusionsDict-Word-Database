        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「まあね……」と彼女は三和土の上で靴を脱いでる夫の肩に手を置いて声だけを難儀らしくして云つた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房子に足をとられたり、ガツガツした胃袋に足をとられたり、そう云う、俺だって、ざまあねえや、今まで足をとられていたじゃねえか。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は「まあね」と答えるより仕方がなかった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……まあね、……遺言と云った訳なんですとさ、私も姉が亡くなったんです。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……此のお夥間です……人の賣買をする連中は……まあね、槍は給仕が、此も慌てて受取つたつて。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その小袖を年一度、七夕様だわね、鼓の調を渡して、小袖の土用干をなさる時ばかり、花ももみじも一時に、城も御殿も羨しくないとお思いなすった、その記念まで……箪笥はもうない、古葛籠の底から、……お墓の黒髪に枕させた、まあね……御経でも取出すように、頂いて、古着屋の手に渡りましたッて、お可哀相に。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "……城下でも評判だったと言いますし、師匠の家だし、近常さんも、時々仕事中に、まあね、見学といった形で、閣へ行きなすったものですから、鶏の工合は分っています。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあね、……まるでお見えなさらないと言うじゃあないの。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さぞかし、ぐあいがいいんだね」「ええ、まあねえ」と、アンネ・リスベットは、言いました。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だけどあなたは随分読書家なんでしょう」「まあね」　規矩男はにやにや笑って、「それだけに堪らなく嫌になって、幾日も密閉して、書物の面見るのも嫌になるんですよ。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやあえて怪しい御仁とも見受けはせんが、まあね、この陽気だから落着くが可うござす。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあね、……旦那は寝たろう。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」十吉「えゝ、まあね、おかしいでしょう？",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "……此のお夥間です……人の売買をする連中は……まあね、槍は給仕が、此も慌てて受取つたつて。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "尼様のお計らいだ、どうにか形のつくことでござんしょうと、そうまあねえ、千ちゃん、そう思って帰ります。",
              "citation": {
                "source": "清心庵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "我ながら頼母しく、「何、まあね、何うぞこれを打つことのないやうにと、内々祈つて居るんだよ。",
              "citation": {
                "source": "二世の契",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあね物の譬えがですわ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあね、あそこの押入れの中に、竹の皮や反古や古手拭なんかゞ、かうやつて抱へる程、突つゝき込んであつたのですのい。",
              "citation": {
                "source": "胡瓜の種",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえ、大学の帰りか」「うん、まあね。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これから何をしようというんだ、人々の目から隠れて……」「むずかしい使命だ、ワーナー博士からの切なる懇請によって……」「ワーナー博士も無事なのか」「まあねぇ」「で、何をするって」「潜水艦を手に入れなければならない」「潜水艦？",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａ　まあねえ、Ｂ　それだのに、一日だって学校はお休みにならないし、遅刻一つなすった事はないでしょう。",
              "citation": {
                "source": "大きな手",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だかちょこちょことやって、もうそれでいいの」「まあね」「まだ何か食べたいものはないんですか」「もう食べあきた。",
              "citation": {
                "source": "挿話",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とか便りをしてくれなくちや、全くたよりなかつたよ」「うん、失敬、失敬、時に留守中かわりはなかつたかい」「ああ、まあね。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まあね、さぞ、およろしかろうね。",
              "citation": {
                "source": "鬼眼鏡と鉄屑ぶとり",
                "author": "続旧聞日本橋・その三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ家でも持って、ちゃんと一所帯構えねえことにゃ女房の話も真剣事になれねえじゃねえか」「そりゃ、まあね」とお光は意を得たもののように頷いて見せる。",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まあね、いって見れば、あたしは、女団洲と呼ばれたくらいだし、自分でも、団十郎のすることの方が好きだから――わかりもしないくせに、高尚ぶってるといわれたりしたけれど、もともとお狂言師は、生世話物をやらなかったからねえ。",
              "citation": {
                "source": "市川九女八",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　視力も失したとでもいったのか、まあね、という嘆息もまじってきこえた。",
              "citation": {
                "source": "遠藤（岩野）清子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "『Ｙさんが大変なお金持に見られるつて、まあね。",
              "citation": {
                "source": "女が来て",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まあね、そうだよ、間接にはね」「どんなことをすれば可いのかい？",
              "citation": {
                "source": "天主閣の音",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
