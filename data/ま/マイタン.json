        "examples": {
          "standard": [
            {
              "text": "昧旦の寒さに震えながら、初日の出を拝むために山頂でじっと待機した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昧旦の時刻になると、寺の鐘がゴーンと鳴り響き、朝の訪れを告げる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昧旦から作業を開始し、日が高くなる前に全ての農作業を終わらせるのが彼の習慣だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「小杉さん、あんたが種をまいたんじゃないの。",
              "citation": {
                "source": "小さき花にも",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「実は一平さん、昨夜十二時ごろから、山下のおでん屋の屋台に噛りついて、徳利を十何本とか倒して、くだをまいたんだそうです。",
              "citation": {
                "source": "ネオン横丁殺人事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなにたくさん、ばらまいたんだもの」　ポケット小僧は、井上君をはげますように、いうのでした。",
              "citation": {
                "source": "怪人と少年探偵",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
