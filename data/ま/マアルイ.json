        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かっと逆上ったままあるいた。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "・ころ／＼ころげてまあるい虫・つながれて吠えるばかりの仔犬の暑さ・朝からはだかで蝉よとんぼよ・夕立つや蝉のなきしきる　夕立つや逃げまどふ蝶が草のなか　七月十八日朝ぐもり、蝉しぐれ、身心なごやかなり。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあるいおしりが下って、おぶい紐が肩に食いこんで、重ったるい。",
              "citation": {
                "source": "鴻ノ巣女房",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何度も、まあるいおなかに湯をかけている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしておもしろいことには、大きい鼻の穴にまあるいかんをつけて太い紐がついていました。",
              "citation": {
                "source": "狐物語",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "帽子もない、靴もない、靴下と膝頭を泥だらけにし、頬と手から血を流し、まあるい瞳を見張っていたが、私の顔が眼に這入るなり、無言でぼろぼろ大粒の涙を零し始めた。",
              "citation": {
                "source": "箱根の山",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "泉に咲いた花のよなまあるい、まるい、花子の目。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "躍るこころを現はしたまあるい、まるい、花子の目。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃や桜のさく前で、真赤な風の吹く中で、小鳥の歌を聞きながら、まあるい、まるい、花子の目。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "太い首から、山國産らしい肩の形、づんぐりした胴、豐かにまあるいお尻などは、病的な浮世繪や草艸紙の美人の弱々しさを嫌ふ現代の油繪畫家も喜ぶ姿態かもしれない。",
              "citation": {
                "source": "貝殼追放",
                "author": "向不見の強味",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘も京の川水に産湯をつかっただけ有って牡丹のようなはでやかな姿とまあるいなめらかな声をもって育った人で理くつもこねず女学校にも上らず御かざりのようにしてある箱入娘だと云うことである。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなに私をいじめるもんじゃないよ」と低い声で云う男の口元を見た時、女の心の中には今までの後向になった気持にこっちを向かせるほど力のある一種のうるんだうれしさと悲しさとがこみあげて、のどのところでホッカリとあったかいまあるいかたまりになった。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はもう十五にもなって居て……昔なら御手玉もって御嫁に行った年だのに、まだ大人の着物を引きずって着るのと戸棚の中に入って下を見下して居るのとが妙にすきで、鉛筆の先のまあるいのが大きらいでいそがしい時鉛筆がふとくなると涙がこぼれそうになる。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "神聖観に護られて、固定のままあるいは拗曲したままに、伝った語句もある。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "美馬の郡名は、みぬまあるいはみつま・みるめと音価の動揺していたらしい地名である。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあるいおばちゃんの胸のところへちょいと抱かれて、面白いわねえ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあるい、きれいな卵が四つある。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
