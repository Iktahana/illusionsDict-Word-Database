        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「アラ、来週はメーベルノーマンドの写真なのね、あたし今度は一人で来るわ」　予告のビラが横手の壁にあつたのをみて、Ｓ子はさういつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "粗末なカフェーへはいって休んでいると、奥のほうの卓を囲んで四五人の男女がマンドリンをひいて歌っています。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年始めて西洋の土地を踏んだ晩ゲノアの宿屋で夜ふけに窓の下でマンドリンをひきながら歌う者があった、その歌の調子がいかにも感傷的と言うのか卑俗と言うのか妙な感じがしましたがきょうのもやはり同じ感じがしました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして先生がマンドリンを持って出て来て、みんなはいままでに習ったのを先生のマンドリンについて五つもうたいました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "マンドリンみたいな音が。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その「うーう」のなかに、マンドリンの音がまじってやしないかと、一心ふらんにきいていると、なるほどかすかに、ピンピンペンペンというような音がきこえるような気がする。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "曇日の色なき街は清水さす石油の噎、轢かれ泣く停車場の鈴、溝の毒、昼の三味、鑢磨る歌、茴香酒の青み泡だつ火の叫、絶えず眩めく白楊、遂に疲れてマンドリン奏でわづらふ風の群、あなあはれ、そのかげに乞食ゆきかふ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "米領「プリビロフ」露領「コンマンドルスキー」そうしてこの日本領の海豹島（露名、チュレニ島、ロッペン島）。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月十四日　夜甲板の椅子によりかかってマンドリンを忍び音に鳴らしている女があった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一人ねずみ色の地味な服を着た色の白い鼻の高い若い女は沈鬱な顔をしてマンドリンをかき鳴らしている。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "2020（令和2）年1月19日〜29日翻訳　　　2020（令和2）年10月7日青空文庫公開※挿絵は、エドマンド・デュラック（1882-1953）によるものです。",
              "citation": {
                "source": "ポオ異界詩集",
                "author": "エドガー・Ａ・ポオ　Edger A. Poe",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて艶子さんはマンドリンを持つて来て、では今度は先程のお礼に、と云つてそれを弾いて私に聞かせました。",
              "citation": {
                "source": "嘆きの孔雀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "△藤岡一氏――『マンドリン』『花甘藍』と題をつけるのはあまりにシャバ気がある、無題とまで徹底できなかつたら、かうしたコラージュ的な仕事を廃した方がいい。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには未だ懸けない大きな油絵などが、窓ぎわに立てかけてあつたりして、大入道のＲ国人が、この作者について、絵の意味について説明してくれたりしたが、間もなくピアノの伴奏でマンドリン演奏がはじまつた。",
              "citation": {
                "source": "微笑の渦",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "コマンドを確認し、リターン・キーを叩き、プリンターに処理をわたす。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙な洋食や支那料理、凝ったアイスクリームを求め、カフェー女の本名を探り、ヤゾーを作って大向うから怒鳴る代りに、亜米利加ものや新派の甘い筋に手をたたき、歌沢の心意気よりも、マンドリンに合わせた「籠の鳥」のレコードを買う。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくきいて見ると、ハーモニカやシロフォネンなどは子供のオモチャで、マンドリン、ギタ、ヴァイオリン、洋琴やピアノなぞが本当の文化的価値があるものだそうだ。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほの青きほの青き幻燈の雪の夜景にわれはまた春をぞ思ふ、マンドリン音をひそめしそのあとの深き恐怖に、ふりつもる雪、ふりつもる雪、…………ゆゑわかぬ性の芽生は青猫の耳の顫へをわが膝に美くしみつつ。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓枠に腰を掛けてマンドリンを弄んでゐるのは一番｜年長の池部だつた。",
              "citation": {
                "source": "夜の奇蹟",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハーモニカの巧みな正吉やマンドリンの嗜みのある細君等も打ち交つて世にも不思議の大合奏が夜毎に樽野の部屋で演奏され続けたのであつた。",
              "citation": {
                "source": "村のストア派",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたゞつてもう学生ではないぢやありませんか、隣りのマンドリンが煩いなんてよくも図々しく云へたものだ、何処にお酒を飲みに行つたつて屹度鼻つまみに違ひない、几帳面の唄となつたら春雨ひとつ知らないでせう。",
              "citation": {
                "source": "蝉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る晩は、窓辺に近い椅子に凭つて月を仰ぎながら、マンドリンの弾奏に余念がなかつた。",
              "citation": {
                "source": "西瓜喰ふ人",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "マンドラゴラは英語でマンドレークと称する。",
              "citation": {
                "source": "毒と迷信",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "この植物は馬鈴薯類に属するもので其の有効成分マンドラゴリンは、わが国に産する「きちがひなすび」の毒成分「アトロピン」と同じ作用を有するのであつて、往時人々は麻酔剤として用ひ、ことに屡々外科手術の際に応用した。",
              "citation": {
                "source": "毒と迷信",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくてマンドレークが抜き出されて後に、その犬はマンドレークの唸り声を聞いて死んで了ふ。",
              "citation": {
                "source": "毒と迷信",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "希臘神話の中に出て来る魔法使ひの女サーシーはこのマンドレークを最も屡々使用したといはれて居る。",
              "citation": {
                "source": "毒と迷信",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
