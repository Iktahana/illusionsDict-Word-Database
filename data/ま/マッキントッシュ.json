    "definitions": [
      {
        "index": 1,
        "gloss": "Macintosh (brand of personal computer manufactured by Apple)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一九八三年にアップルコンピュータが発表したリサや、翌年のマッキントッシュの斬新さに驚いた私は、これらに盛り込まれた設計思想がケイの研究成果を汲んでいることを、後になって知りました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マッキントッシュ用に作られたハイパーカードは、「なにか自分でも作ってみたい」という気持ちを使う側から上手に引き出してくれる、実にこのコンピューターらしいソフトウエアです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙から画面への橋渡しとしてのＤＴＰ　一九九二（平成四）年七月号の『マックワールド』誌に載った原稿は、「マッキントッシュで書き、ハイパーカードのページにテキストを流し込み、一冊の本を作る。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "信念の統合処理としてのエキスパンドブック「マッキントッシュで書き、ハイパーカードのページにテキストを流し込み、一冊の本を作る。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マッキントッシュを実験場としてマルチメディア作品の開発にあたっているボイジャー社は、「そんなことはない」と主張する。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやくツールキットの原稿を仕上げて一か月ほどで、マッキントッシュのフェアーが、例年通り幕張で開かれました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "御大のアラン・ケイやダグラス・エンゲルバートに加え、開発に携わった人たちを訪ねてまとめた『マッキントッシュ伝説』というＣＤ―ＲＯＭのインタビュー集には、資料映像や取材時の場景がたくさん組み込まれていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "今多くの人たちが、マッキントッシュやウインドウズを使ってインターネットを利用していることを、リックライダーは自分の見た夢の実現として受けとめるはずです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マッキントッシュとウインドウズ95に対応しているから、たいていの機種で読めるだろう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウインドウズでもマッキントッシュでもかかるＣＤ―ＲＯＭに仕立てるところでは、ボイジャーの野口英司さんから、また大きな力を借りた。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者はマッキントッシュでしか読めないが、後者はウインドウズでも大丈夫だ。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アップルコンピュータのマッキントッシュのユーザーには、カラー版のハイパーカードと言えばイメージが掴みやすいだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつてアップルコンピュータを起こしてパーソナルコンピューターの第一段ロケットに火を付けたジョブズは、マッキントッシュと名付けた製品の開発の先頭に立って、個人用マシンの歴史の第二幕を開いた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方マッキントッシュは、基本ソフトに使いこなしの仕掛けを組み込み、すべてのアプリケーションにこれを利用することを求めた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして新しい会社を起こし、マッキントッシュにもう一段磨きをかけたかっこうのＮｅＸＴと名付けられたマシンの開発に取り組んだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "デビュー間もないＦＭ　ＴＯＷＮＳをいじくり回し、ＴＯＷＮＳ　ＧＥＡＲの目指すものに納得したオレは、となりで電源を入れっぱなしにしておいたマッキントッシュに目をやったとたん、富士通の新しいマシンが使いこなしの流儀を決めるウインドウ環境を持っていないことに気づいた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＭＳ―ＤＯＳをサポートするＦＭ　ＴＯＷＮＳは、ＭＳ―ＤＯＳにかさ上げしてマッキントッシュ型のウインドウ環境を提供する試みは採用するだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつてマッキントッシュを見てぶっとんだマイクロソフトは、ＭＳ―Ｗｉｎｄｏｗｓ（以下、省スペースのためにＷｉｎｄｏｗｓと書く）と呼ばれるかさ上げ分を開発し、その改良を進めている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この項で強調している「表現する」という領域は、少なくとも今のところマッキントッシュの独壇場だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにＷｉｎｄｏｗｓ用の表計算、マッキントッシュ用のワープロなども出していくという。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "行ないうる作業をメニューに表示してそこから「選ぶ」ことを基本とする操作や絵文字の利用といったアラン・ケイ自らが開発し、後にマッキントッシュで大衆化されたインターフェイスこそが、ここから生まれたボール型の握りであるとのご主張なのである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて、ケイがマッキントッシュを評価したように、ケイ本人に日本の“ダイナブック”の評価を直接聞いてみたが、ここでは書くまい。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のところダイナブックに一番近いマシンは、マッキントッシュのノートブック版であるパワーブックだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダイナブックの環境をソフトの側から育て、大衆化する作業は、まちがいなくマッキントッシュがリードした。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "確かにＰＣがのさばってマッキントッシュが苦労した数年は、回り道と言えば回り道だろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャープの電子手帳はアメリカではウイザード（魔法使いね）という名前で出張っているが、こいつにマッキントッシュの爪の垢を飲ませて洗練させようということだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一のルートは、一般消費者をターゲットとして、マルチメディア機能を持たせたマッキントッシュを開発していく道だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "カラーのマッキントッシュを可愛らしく、できるだけ安く仕上げて、ＣＤ―ＲＯＭでもくっつけるのだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "確かにマイクロコンピューターは裏側に組み込まれており、あれこれと機械に指示する際はマッキントッシュで見慣れた形の表示が出てくる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに家電製品の中で賢くして意味のあると思われるものを、マッキントッシュの開いた人との対話の流儀に沿って電脳化しようとする腹だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
