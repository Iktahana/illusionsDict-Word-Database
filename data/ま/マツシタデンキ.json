          "literary": [
            {
              "text": "ハードウエアは、８０２８６搭載の松下電器のＰａｎａｃｏｍ　Ｍ５３０である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "松下電器のマシンが富士通のＦＭＲ互換であることを考えれば、健全な好奇心を持つものはこっちでも動くのではないかと考える。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＢＴＲＯＮのＯＳ開発に取り組んだ、松下電器。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "現実にＢＴＲＯＮ１の開発に取り組んだのは、松下電器の情報システム研究所だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハードウエアは、松下電器のノートブック・マシンＰＲＯＮＯＴＥそのまま。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
