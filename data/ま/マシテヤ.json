    "definitions": [
      {
        "index": 1,
        "gloss": "much less",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "況してやモルトナス島のあの兇惡な慘劇とストックホルムの富の王者とを結びつけるなどは？",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "況してや平生激昂しやすき厭世家の想像は、この誠実なる恋愛に遭ひて脆くも咄嗟の間に、奇異なる魔力に打ち勝たれ、根もなき希望を醸し来り、全心を挙げて情の奴とするは見易き道理なり。",
              "citation": {
                "source": "厭世詩家と女性",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "況してやその表現の根底が仮りの本心、仮りの性格であるに於てをやであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "況してや其處に田があり畑があり、野あり大海がある。",
              "citation": {
                "source": "樹木とその葉",
                "author": "自然の息自然の聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "況してや七十四年間の外国雑誌は長い間に何度も繰返して重複したものを買集めなければ揃えられないので、恐らく此雑誌も全部揃ったは日本に幾何も無いであろう。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "況してや女わらべは草双紙を読むぐらゐで、此の草双紙や戯作本は堅木の家では遠ざけてゐたから、四民の上に位する堂々たる武士の家に書物が一冊も無いのは少しも珍らしく無かつた。",
              "citation": {
                "source": "家庭の読書室",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "況してや瀧口殿は何思ひ立ちてや、世を捨て給ひしと專ら評判高きをば、御身は未だ聞き給はずや。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "況してや舞台好みの文金高島田、化粧をした顔の美艶、竜次郎は恍惚たらざるを得なかった。",
              "citation": {
                "source": "死剣と生縄",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "況してや他の国の事である。",
              "citation": {
                "source": "女子教育の目的",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は踊りの事は何も知らないし、ましてやこんな西洋の足踏み踊りなどいったいなんのことだかちっともわけがわからない。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてや少しでも自己觸媒作用のある所には、ものの片寄るのが寧ろ普遍な現象だからである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてや論文が独創的なものであればあるほど、疵やひびが多いのは当然であるから、そういうものが大勢の合議にかかれば無事に通過する気遣いはまず無いと云ってもいい。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてや議員席から時々突発する短い捨て言葉などは一つも聞き取れなかった。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてやアフリカ大陸の自然の棲所で撮った河馬の映画となれば猶更のことである。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてや雪の山で遭難して世間を騒がす心配などは絶対になくてすんでいるわけである。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、この個人的な経験はおそらく一般的には応用が利かないであろうし、ましてや、科学の神殿を守る祭祀の司になろうと志す人、また科学の階段を登って栄達と権勢の花の山に遊ぼうと望む人達にはあまり参考になりそうに思われないのである。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「後の台詞はあちらの方が御存じだ」　と言って、Ｔ「現場を押さえて臭えおまんまを噛ましてやると仰しゃるんでしょう？",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつを噛ましてやって呉れ。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてや内部生活の疎隔した他人はなおさらの事である。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてや、古典的物理学の基礎をなしていた決定的因果律に根本的な修正が問題になり、統計物理学の領域にも全く新しい進出の曙光が見られる今日において、特にここで問題とするような諸現象を列挙して読者の注意を促すのも決して無益のわざではあるまいと思われるのである。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてや「恋愛至上主義」など、まあなんという破天荒、なんというグロテスク。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに少年の方から附き纏って離れなくなってしまうもんですから困ってしまってカルモチンを服ましてやったのです……そうして地下室の古井戸の中から、いい処へ旅立たしてやったんです。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは大喜びで連れて帰って、寄ってたかって介抱をして、もとの通りにふくらましてやりました。",
              "citation": {
                "source": "キューピー",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が高慢な老人をへこましたのか、老人から自分の高慢をへこまされたのかわからなくなったが、ともかく、少しはへこましてやったつもりで宅に帰り、この事を父に語った。",
              "citation": {
                "source": "初恋",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい近頃になって「Ｂ教授の追憶」を書くときにふとそのＢ教授の手紙を想い出すと同時にこの抽出しとＳ先生の手紙を想い出したのであったが、今ではもう昔の教室の建物はすっかり取毀されてしまって、昔の机などどうなったか行衛も分らず、ましてやその抽出しの中の古手紙など尋ねるよすがもなくなってしまった訳である。",
              "citation": {
                "source": "埋もれた漱石伝記資料",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが必要でないという事になれば、ましてや不完全不真実な記事を毎日あわただしく読む事の価値ははたしてどうなるであろう。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてや連句の場合にこの音程に相当する付け味の数は言わば高次元の無限大である。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてや世の営みの職業なら、何なりとも尊い事に存じて居ります。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてや五六十年の長い生涯、愛し合った始めの熱情に少しの弛みを与えずそれを持ち通す時間というものは、いくらあるで御座いましょう。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と私御挨拶をしました処で、爺の口から旦那様が嬉しい、飲ましてやろう、と姉さんが申されたのでござりましたよ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
