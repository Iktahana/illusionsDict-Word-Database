        "examples": {
          "standard": [
            {
              "text": "「このプレゼン、大丈夫かな？」「心配ないって！俺に任せとけ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「初めての場所で迷子になったらどうしよう…」「大丈夫、地図もあるし、俺がなんとかするよ。任せとけ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この重い荷物、一人で運べるかな？」「僕が手伝うよ。ほとんど僕に任せとけ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "俺に任せとけ」「折角だがお任かせ出来ねえね。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お巡りになつたのが、わるいというのか、やいこら」「よくもあるめえ、糞面白くもねえ、罪人をふん縛る商売なんぞ、人に任せとけ」「誰かがやらにやなるめえ」「おい、おい、やりたい奴にやらしたらどうだ。",
              "citation": {
                "source": "この握りめし",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "川口松太郎来り、梅田コマ一月の「蛇姫様」は任せとけ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
