          "literary": [
            {
              "text": "荷車の柄は舗石の上におろされてい、田舎者の頭は荷車の前板の上にたれていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体はその斜めの前板の上に長くなって、足は地面に触れていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "水金のたれはちっと甘口でぞっとしねえが、中くしのほどよいところを二、三人まえいただくのも、いかさま悪くねえ寸法だ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（尤もこの怪物は脚下に二人の人間を踏まえいたり。",
              "citation": {
                "source": "北京日記抄",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
