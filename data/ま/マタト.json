    "definitions": [
      {
        "index": 1,
        "gloss": "(never) again",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼はその蘭人の恩を忘れぬ美しい心が又となく嬉しく思はれた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は飯田から二里ばかりある、時又といふ船の出るところまで、車を走らせた。",
              "citation": {
                "source": "天竜川",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの奴等に、又とない、ええ薬となりますぞ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間ばかり前に、飛ぶように這入って飛ぶように出てきた石畳の小路を、又とぶように歩いて行った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "サル又と襦袢だけの者。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな旅人とこんな見送り人とは、東京駅の長い歩廊にも恐らく又とはゐまい。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ世の中に、これだけの機能の備わっている道具は、又とあるでしょうか。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばけもの奇術師が、よく十二三位までの女の子を、変身術だと申して、ええこんどは犬の形、ええ今度は兎の形などと、ばけものをしんこ細工のように延ばしたり円めたり、耳を附けたり又とったり致すのをよく見受けます。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見張りの人が眠げに片方に腰をかけて居る丈で、外に人はない、もし彼に逃亡を企つる勇気があつたなら、こんないゝ機会は又とないのであつたが、彼にはそんな呑気な――今の彼として実際それが呑気な事であつた――計画を考へてる遑がなかつた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして又と役に立たんように打ち潰して下さらんか。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "又と見られぬ世界一の珍らしい夫婦です。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "入らっしゃい入らっしゃい」　これをきくと、何しろ大評判な上に又と見られないというので、われもわれもと一円出して、見る見るうちに中は一パイになってしまいました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　思切つて坂道に取つて懸つた、侠気があつたのではござらぬ、血気に逸つたでは固よりない、今申したやうではずつと最う悟つたやうぢやが、いやなか／＼の憶病者、川の水を飲むのさへ気が怯けたほど生命が大事で、何故又と謂はつしやるか。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから段々話しているうちに老人は死後のことに就き色々と拙者に依托せられた、その様子が死期の遠からぬを知っておらるるようで拙者も思わず涙を呑んだ位であった、其処で貴所の一条を持出すに又とない機会と思い既に口を切ろうとすると、意外も意外、老人の方から梅子｜嬢のことを言い出した。",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かね又という牛めし屋へ「芋ぬき」というシュチューを食べに行く。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の男は近江から蚊帳を為入れて、それを上州から野州方面に売っていたが、某時沼田へ往ったところで、領主の土岐家へ出入してる者があって、其の者から土岐家から出たと云う蚊帳を買って帰り、それを橘町の佐野又と云う質屋へ持って往った。",
              "citation": {
                "source": "沼田の蚊帳",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生が世界に又とない彫物師で、人の体を彫る人だということは、お前も知っているだろう。",
              "citation": {
                "source": "花子",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一體おれの妻のやうな女が又と一人あるだらうか。",
              "citation": {
                "source": "半日",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな不祥な女が又とあるものではない。",
              "citation": {
                "source": "妖氛録",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭山満曰く、「杉山みたような頭の人間が又と二人居るものでない。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻の表現法の真意義の研究に入るには、先ずその邪道なるものを飽く迄も知り抜いていなければ、その真意義なるものがはっきりとわかりにくいのみならず、却ってこの邪道に陥って又と再び本通りに帰る事が出来ないようになる恐れがあるのであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今北信の諸豪が泣きついて来たのこそ、又とない機会である。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私「又とない君には適当な仕事だと、君も僕もその時は悦んだのだつたがね。",
              "citation": {
                "source": "雑談抄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん又と崑崙茶を飲みに行く資力なんか無いのですが、しかしその味だけはトコトンまで腹に沁み込んでいてトテモトテモ諦められない。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "四つ又と共に上り框へ腰をかける。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の生涯に取って、報酬を予期しない看護婦になると云うこと、しかもその看護を自己の生活の唯一の内容としていると云うこと程、大いなる犠牲は又とあるまい。",
              "citation": {
                "source": "百物語",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ程、崇厳な、これ程崇大なこれ程崇美な、然もこれ程微妙な……静かな音楽が、私達の住むこの世界に又と見出すことが出来るでありませうか。",
              "citation": {
                "source": "嘆きの孔雀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらば又と来ざらんやうに逐払ふべき手立のありやと責むるに、害を為すにもあらねば、宿無犬の寝たると想ひて意に介るなとのみ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうこれぎりで、貴方も……私も……土に成つて了へば、又とお目には掛れ、ないんだから、せめては、今改めて、狭山さん、私はお礼を申します」　男は身をも搾らるるばかりに怺へかねたる涙を出せり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸男、さらば又と氣張りしが、一句も浮かばずして、そのまゝ眠る。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
