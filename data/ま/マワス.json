[
  {
    "uuid": "fd3f98eb-dd35-563d-8948-cc30446e491e",
    "entry": "回す",
    "reading": {
      "primary": "まわす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
