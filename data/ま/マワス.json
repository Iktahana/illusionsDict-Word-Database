    "definitions": [
      {
        "index": 1,
        "gloss": "to turn",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "短歌・俳句は、一詩心の一度の指示、或ひは一度の暗示に終始するが、詩では（根本的にはやはり一篇に就き一度のものだらうとも）それの旋回の可能性を、其処で、事実上旋回すると否とに拘らず用意してゐるものである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはほんとうにバッカスの酒宴で、酒は泉とあふれ、肉は林とうずたかく、その間をパンの群れがニンフの群れを追い回すのである。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか「棒使い」と言って、神前で紅白の布を巻いた棒を振り回す儀式もあったが、詳しい事はもうよくは覚えていない。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふところ手をして縁へ腰かけてさびしい小庭を見回す。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこへ行ったかと見回すと、はるか向こうの東屋のベンチへ力なさそうにもたれたまま、こっちを見て笑っていた。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの子供らがあひるを慣らしているのを見て、今まではいっこうにあひるに対する興味がないか、あるいは追い回す以外の可能性を考えなかった近所の子供たちも、とんぼをつかまえて来たりあき鑵にいっぱいいなごを取ってはあひるに食わせることを覚えて来た。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "座席に腰かけた人の右手にハンドルがあってそれをぐるぐる回すとチェーンギアーで車台の下のほうの仕掛けがどうにかなるようにできているらしい。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間が人間を追っ駆け回す場面、人と人とが切り合う場面が全映画の長さの少なくも五割以上を占めているような気持ちがした。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "スクリーンの面で船や橋や起重機が空中に舞踊し旋回する。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その先端の綿の繊維を少しばかり引き出してそれを糸車の紡錘の針の先端に巻きつけておいて、右手で車の取っ手を適当な速度で回すと、つむの針が急速度で回転して綿の繊維の束に撚りをかける。",
              "citation": {
                "source": "糸車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで取っ手を回すと同じリズムでキュル／＼／＼と一種特別な轢音を立てるのであった。",
              "citation": {
                "source": "糸車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "』母親がきょろきょろと見回すと、『なに。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざわざ旅費を出して幾日も汽車を乗り回す必要などはないように思われる。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな宿屋などの三助ででもあれば、あたりまえなら接近する事も困難なような貴顕のかたがたを丸裸にしてその肢体を大根かすりこぎででもあるように自由に取り扱って、そうしておしまいには肩や背中をなぐりつけ、ひねくり回すのである。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして彼女の心の態度はこのライトモチーフの現われるたびごとに急角度で転回する。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがもうその言葉を、弟から撤回する術はない……私は何といつてよいか分らなかつた。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれ一まず安心と、今度は双眼鏡で前の洞の附近を見回すと、「難有い。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "またがちっととってを回すと、模型はこんどは大きなむかでのような形に変わりました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十過ぎての蹉跌を挽回することは、事実そうたやすいことでもなかったし、双鬢に白いものがちかちかするこの年になっては、どこへ行っても使ってくれ手はなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に統一が成立し、帝国が成立し、侵略の虞なくして独乙が優に存在し得た暁には撤回すべき性質のものではないか。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は大家の若旦那に生れついて、家の跡取りとなり、何の苦労もないうちに、郷党の銀行にただ名前を貸しといただけで、その銀行の破綻の責を一家に引受け、預金者に対して蔵屋敷まで投げ出したが、郷党の同情が集まり、それほどまでにしなくともということになり、息子の医者の代にはほぼ家運を挽回するようになった。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "這般の実例をつまびらかに叙せんとせば、我は実にこの『閑天地』を百千回するも猶且つ足らざる者あらむ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「乱杭、歯くそ隠の鉄漿をつけて、どうだい、その状で、全国の女子の服装を改良しようの、音楽を古代に回すの、美術をどうのと、鼻の尖で議論をして、舌で世間を嘗めやがる。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "智子が必死の思案の果てに思極めたことは――智子がなまじ自分の智能を過信して夫を眼開きの世界へ連れて来ようとした無理を撤回することだった。",
              "citation": {
                "source": "明暗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな身体になれば良いと佐伯は羨ましく眺め、心に灯をともしながらバスが迂回するのを待った。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "但、文芸通信誌上で私は「探偵小説が文芸であるかどうかは責任を負う限りでない」と明言しているが、これは謹んでこの項の中から撤回する。",
              "citation": {
                "source": "甲賀三郎氏に答う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸村茶臼山に陣し、毛利勝永は天王寺南門に備え、大野治長の先鋒銃隊東に在り、左方岡山口は大野治房を配し、迂回すべき遊軍は明石｜全登が精兵三百を率いた。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "迂回するためかと思ったが、車はそのまま真っ直ぐ天王寺の方へ走って行った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は腕を動かして自分の肉体の凸所を撫でまわす。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し演壇をあちこち歩き廻ったり、拳固を振りまわす労力はこの外であるのは勿論の事だ。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
