        "examples": {
          "standard": [
            {
              "text": "駅前の廃ビルは、いつの間にか麻薬中毒者たちの溜まり場になっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "麻薬中毒者の更生を支援するボランティア団体が、募金活動を行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は自分が麻薬中毒者であることを認め、ようやく治療を受ける気になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "もがきあがいて、作家たる栄光得て、ざまを見ろ、麻薬中毒者という一匹の虫。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "麻薬中毒者が、麻薬が切れて薬を求める時の気持だって、これほどつらくはないでしょう。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "麻薬中毒者なのであった。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし取調べの途中で、彼が麻薬中毒者であることも分り、それから糸がほぐれていって、遂に彼が白状したところによると、問題の軽い缶詰は、旗田亀之介に頼まれて、彼井東が缶詰仕上げをやったに相違ないことが明白となった。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
