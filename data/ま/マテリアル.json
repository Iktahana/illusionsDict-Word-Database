          "literary": [
            {
              "text": "彼等はマテリアルも失っている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしマテリアルがよく手がこんで居る丈でインスピレーションが一寸もないから美の感なし。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その色が、マテリアルの重みを加えて、古び、かっちりと建っているから何か日本人の胸に迫る美、懐しさがあるのが面白い。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "全線のマテリアルを小さい部屋で見せてくれる。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○マテリアルのとりかたが、なかなか用意周到だ。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "マテリアルの蓄積はなくなつたかも知れないが、血液の中にある蓄積は、われわれ日本人が生きている以上は、なくなるものではない。",
              "citation": {
                "source": "革命を待つ心",
                "author": "――今の實業家、昔の實業家――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
