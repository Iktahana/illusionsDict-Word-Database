[
  {
    "uuid": "89d7e951-7d0d-5853-958e-2e682eba4239",
    "entry": "毎夜",
    "reading": {
      "primary": "まいよ",
      "alternatives": [
        "まいや"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
