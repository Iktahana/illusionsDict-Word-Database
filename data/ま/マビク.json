    "definitions": [
      {
        "index": 1,
        "gloss": "to thin out (plants, seedlings, crops, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "折角伸びて來た苗を間引くことが、彼には惜しいことのやうに思はれた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大根を間引く、間引いたのはそのまゝお汁の実。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――菜を間引く、雑草がはびこるには閉口する（神仏の前には菜も雑草もおなじものだらう）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜をこめてこっそり官木を間引くなんてこともありそうだが、いくらはずみがついたからといって、のんきらしく歌拍子をいれる抜作もあるまい。",
              "citation": {
                "source": "生霊",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれは通常あまりに密にそだつ傾きのあるこれらの樹を間引くために必要なことでもあろう。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶんあとで間引くでしょうね。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "国で、御手許不如意になった時、わしは、子供をまびく外に方法はないと思うた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやな語だが、「まびく」などということも行なわれた。",
              "citation": {
                "source": "石の信仰とさえの神と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "福井　※伊豆の山々月あはくあかりにむせぶ湯のけむりあゝ初恋の君をたづねて今宵またギターつまびく旅の鳥トおでんやの店先に立寄り、福井　おじさん。",
              "citation": {
                "source": "渡鳥いつかへる",
                "author": "軽演劇一幕四場",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は顔をひきつらせて、倒れたままびくとも動かない人形、その表情のない顔を、もう一度まじまじとみつめた。",
              "citation": {
                "source": "菊",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "――生れた子を殺して「まびく」という、どこでもおこなわれているし、北国などでは藩で布令を出した例もある。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "氷の下の芽",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう場合には「まびく」ことが黙認されている。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "氷の下の芽",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
