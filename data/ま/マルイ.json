    "definitions": [
      {
        "index": 1,
        "gloss": "round",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "つばきの葉を見るような、厚い革質のくすんだ光沢があって、先端の丸い、細長い楕円形の葉を群がらしている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "七重の瀧の茶店で「燒饅頭」と貼札したものを試みに注文したら、丸いパンのやうなものに味噌※を塗つたものであつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが尽きるとぱっと明るくなって、丸い丘が幾つも在る間の開けた田畑の中の道を俥は速力を出した。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "痩せぎすであったけれども顔は丸い方で、透き徹るほど白い皮膚に紅味をおんだ、誠に光沢の好い児であった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の氷屋などでは、板に丸い穴をあけて、そこに幾つとなく、ラムネを逆さにして立てて居る。",
              "citation": {
                "source": "ラムネ・他四編",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "理髪店の軒先には、紅白の丸い棒が突き出してあり、ペンキの看板に Barbershop と書いてあった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや左手の眼の前に落ちかかる日輪は爛れたような日中のごみを風に吹き払われ、ただ肉桃色の盆のように空虚に丸い。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、その刹那に私の眼にまざまざと映つたのは、ほの白んだ女の顏に、欲情に燃えながら輝いてゐた、まん丸い二つの眼であつた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は、机のはしに、丸い爪を持った指の太い手をついて、急に座ると腰掛が毀れるかのように、腕に力を入れて、恐る／＼静かに坐った。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」お富は眼※を袖で摩って丸い眼を大きくして言った。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヘロが一本三千円、……ヘロが一本三千円……」　乳棒は、丸い乳鉢の中をがじ／＼まわりながら、こう呟いている。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄条網は、工場の周囲から、遠くの街路に添い、街路を横切ってのびて行く、Ｓ銀行には、丸い、瓦斯タンクのような歩哨の土嚢塁が築かれた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある時花壇の金蓮花の葉を見ているうちに、曇った空が破れて急に強い日光がさすと、たくさんな丸い葉は見るまにすくすくと向きを変え、間隔と配置を変えて、我れ勝ちに少しでも多く日光をむさぼろうとするように見えた。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "土用の日ざしが狭い土堤いっぱいに涼しい松の影をこしらえて飽き足らず、下の蕃藷畑に這いかかろうとする処に大きな丸い捨石があって、熊さんのためには好い安楽椅子になっている。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｈ温泉旅館の前庭の丸い芝生の植え込みをめぐって電燈入りの地口行燈がともり、それを取り巻いて踊りの輪がめぐるのである。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今に秋風が音ずれて、われわれのみならず、このへんの人たちがみんな引き上げて帰ってしまったあとでも、このあひるはやはりだれもいない明き家のヴェランダの前へ来て、首を左右にかしげて、小さな丸い目でのぞき込みながらガーガーと鳴いているであろうと想像するのはちょっとおかしくもあればあわれでもある。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことを無意識に考えたためでもあろうか、この水準点ベンチマークの鋲の丸いあたまに不思議な愛着のようなものを感じてちょっとさわってみないではいられなかったのである。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日ほどまえから、黄昏どきになると一束の花を持ってここへ電車でやって来て、東京市の丸い紋章にじゃれついている青銅の唐獅子の下で、三四時間ぐらい黙って立っているのである。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は、その大学生の怒った肩に、おのれの丸いやわらかな肩をこすりつけるようにしながら男の後を追った。",
              "citation": {
                "source": "あさましきもの",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　飛騨は、炭火のほてりでてらてら油びかりしだした丸い顏を、けはしくしかめた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧の中に丸い広場のように見えたのです。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言いながら白い丸い石をひろいました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのマン丸い、うるうるした瞳と新鮮な頬の輝やきを曇らせて、はかなくも白け渡った投影を仄めかす。",
              "citation": {
                "source": "塵",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「百日紅の根に丸い石があるでしょう。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ容貌はあまり立派ではございません、鼻の丸い額の狭いなどはことに目につきました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "生まれてほどもない仔牛は始終驚き通しているような丸い眼で人を見やりながら、柵から首を長く延ばして、さし出す二本の指を、ざらざらした舌で器用に巻いてちゅうちゅう吸った。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「肩まで、肩まで」と手で押えられて、かやは婆やの丸いすべすべした膝の上へ、ひったりお尻を据えてしまった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "古典的で若々しいローマの丘のように盛上った浦子の掌の肉の中に丸い銀貨の面はなかば曇りを吹き消しつつある。",
              "citation": {
                "source": "汗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "門札の傍へ、白で丸い輪を書いたのは。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "典型的なもくもくと盛り上がったまるい頭を並べてすきまもなく並び立っていた。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
