        "examples": {
          "standard": [
            {
              "text": "彼は自らの信仰を守り抜くために、マルチリヨの道を選んだと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歴史の教科書には、迫害に屈せずマルチリヨを遂げた人々の記録が残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その聖堂は、かつてこの地でマルチリヨとなった聖人を祀るために建てられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "長崎の感情は激発し、日と共に亢奮の坩堝に落込み、信徒達はマルチリヨの覚悟をかため、それに処する心得を胸にたたみ、日夜に会合をひらいた。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            }
          ]
        }
