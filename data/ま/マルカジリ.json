          "literary": [
            {
              "text": "白い粉の吹いたまゝな皮を衣物で押し拭って、丸かじりにしたその味は忘れられない。",
              "citation": {
                "source": "北海道に就いての印象",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎからつぎへと、手をのばして、林檎を、丸かじりして、腹の中におさめた。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かけてもいいですか」「どうぞ」　長椅子にかけて、ナターシャは前かけのポケットからリンゴをとり出し、いい音をたててそれを丸かじりし、五分ばかり休んで出て行く。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
