        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "とは言え、私自身でも、これを書きながら、さすがに、自分を世界一の醜悪な卑怯な人間だということははっきり意識しているのだから、私がそれを意識していないかと思って、読者から色々愚にもつかぬ批評を私の行為に加えて貰うことは真っ平ごめん蒙りたい。",
              "citation": {
                "source": "秘密",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は死ぬのは平気なんだけど、怪我をして出血してそうして不具者などになるのは、まっぴらごめんのほうですので、ヨシちゃんに腕の傷の手当をしてもらいながら、酒も、もういい加減によそうかしら、と思ったのです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後打首が廃され、絞首になる時その器具を造るのを調べさせられて用いた夜、どうしても寝具合がわるく、三晩もうなったので、役人なんざまっぴらごめんだと、噛りつきたがるはずの椅子を投りだしてしまった。",
              "citation": {
                "source": "牢屋の原",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなきゅうくつな政冶なんてまっぴらごめんだ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しみったれて、けちけちした恋愛はまっぴらごめんだ。",
              "citation": {
                "source": "恋愛の微醺",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャックなどはまっぴらごめんだ。",
              "citation": {
                "source": "河童",
                "author": "どうか Kappa と発音してください。",
                "note": "青空文庫"
              }
            },
            {
              "text": "しからば、まっぴらごめんと、中へ入ってみるか」　佐々刑事は、およそ世の中に、恐しいというものを知らない人間だった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "オオオオ、足へ水をかけてしまったが、まっぴらごめんなヨ」　石金さんはそう言いながら、片手にさげた柄杓のしずくを切って、お美夜ちゃんのそばへ寄っていった。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ここへ土下座をしてお飲ませくださいと頼んだって、まっぴらごめんと突っぱねやす。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "かごやの客",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、あんなに心持ちの悪い、恐ろしかった経験などは、もうまっぴらごめんだ。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "上床",
                "note": "青空文庫"
              }
            },
            {
              "text": "……間）仙太　（荷物の側にピタッと坐って、折れ刀をカラリと土に置き、まだ姿は見せぬ追手に向ってかなり大きな声で）……まっぴらごめんねえ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（と箱を抱え込んで）じゃ、お二人さん、まっぴらごめんねえ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『まっぴらごめんなさっておくんなさい。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙太　（荷物の側にピタッと坐って、折れ刀をカラリと土に置き、まだ姿は見せぬ追手に向ってかなり大きな声で）……まっぴらごめんねえ。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いますぐいくなんて、おれはまっぴらごめんだ。",
              "citation": {
                "source": "漁師とそのおかみさんの話",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえ喰べたのか」「犬じゃあないんでね」弟は振向きもしなかった、「アメちゃんの食い残しなんかまっぴらごめんさ」　もう米軍の残飯を食うなどということはなかった。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうえ、このうちには、あのおそろしい鉄人Ｑが住んでいるのですから、こんなうちにいるなんて、まっぴらごめんです。",
              "citation": {
                "source": "鉄人Ｑ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっぴらごめんだと」　最後は金切り声だ。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
