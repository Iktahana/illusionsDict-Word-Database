        "examples": {
          "standard": [
            {
              "text": "「麻」という漢字の部首は、麻冠（まかんむり）と呼ばれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "漢字の部首を覚えるとき、麻冠の形をイメージすると覚えやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この文字の部首は、筆順を気にせず麻冠と書くことができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "マカロンが先ず第一の贅沢なもの、これは後年「人形の家」のノラが、しきりに食べることを知り、イプセンも、マカロンの愛用者ではなかったかと思った。",
              "citation": {
                "source": "甘話休題",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "マカロンの、いささか濃厚な味は、然しフランスの乾菓（キャンディーではない。",
              "citation": {
                "source": "甘話休題",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "マカロンの他にデセール、サブレー、ウーブリ、ビスクイなどという種類があり、乾葡萄の枝ごとのもあった。",
              "citation": {
                "source": "甘話休題",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "店の名の通り、アーモンドをうんと使った、クレセントマカロンが一。",
              "citation": {
                "source": "甘話休題",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
