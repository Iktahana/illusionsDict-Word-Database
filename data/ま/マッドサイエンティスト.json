        "examples": {
          "standard": [
            {
              "text": "その映画に登場するマッドサイエンティストは、奇抜な発明で世界を騒がせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、マッドサイエンティストのような研究者になりたいと夢見ていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の実験は、まるでマッドサイエンティストが行うような常識外れのものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「東洋の」秘密教団と、デコボコ二人組のマッドサイエンティストに狙われ、バッキンガム宮殿や、アルプスや、バハマを逃げまわるビートルズの物語のなかに――。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
