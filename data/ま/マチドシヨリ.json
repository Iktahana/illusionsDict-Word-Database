    "definitions": [
      {
        "index": 1,
        "gloss": "town elder (Edo period)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
