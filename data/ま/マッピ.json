        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "マッピラと云う音が面白いと云うので、しきりに真平と云う事を申しました。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私ゃあのガキと同居するのはマッピラですよ。",
              "citation": {
                "source": "町内の二天才",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫ケラだと思っているから、死に首も、生き首もマッピラでさア」　ヒメはニッコリうなずいた。",
              "citation": {
                "source": "夜長姫と耳男",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "戻って京子に言ったら、マッピラ御免だと言う。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
