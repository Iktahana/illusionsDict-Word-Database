[
  {
    "uuid": "6ea5cf33-9c0f-572c-aa69-f12eb418e5f4",
    "entry": "股旅",
    "reading": {
      "primary": "またたび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wandering life of a gambler",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この勝太郎節と同時に、並行して流行したものは所謂「股旅小唄」であつた。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この股旅小唄の主旋律は、概して皆尺八的、浪花節的哀傷を帯びてるもので、日本人の民族的リリシズムとも言ふべき、旅への放浪情操をよく表現して居た。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "剣劇の股旅ものや、幕末ものでも、全部がまだ在来の歌舞伎芝居の因習の繩にしばられたままである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう関係から劇に志したのには無論違いないだろうけれど、しかし、中学校の三年生の時の作文に、股旅物の戯曲を書いて叱られたところを見ると、もともと好きだったのだろう。",
              "citation": {
                "source": "わが文学修業",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お次は大連の貿易商で満鉄の大株主｜股旅由高。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう言へば、長谷川伸さんの侘しい股旅渡世人の幾種かを演じた。",
              "citation": {
                "source": "市村羽左衛門論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「股旅もの」が流行し、「剣もの」が「ピストルもの」にかわっていても、彼らが求めているのは、もっとほんとうの奥のもの、しみじみと語ってくれるものなのではないだろうか。",
              "citation": {
                "source": "大衆の知恵",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "脚絆に草鞋がけという実誼な装で一年の半分は山旅ばかりしているので、画壇では「股旅の三十郎」という綽名をつけている。",
              "citation": {
                "source": "生霊",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "股旅物、三尺物の主人公が何で食っているかはいかにもはっきりしているが一歩すすんで、彼らの生活の物質的な地盤となっている社会経済――いわゆる旦那衆を構成する特定社会層の本質となると描かれていることがもう稀だ。",
              "citation": {
                "source": "志士と経済",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう一人の男は、鐵之助といふ遊び人で、松前鐵之助と違つて、股旅の鐵之助といふちよいと苦み走つた、好い男の小｜博奕打で」「それを當つて見たか」「昨夜のうちに突きとめて、見張らせて置きました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "掏られた遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻までの俺だったら、一緒にまた高飛びの、股旅かけた草鞋を穿けと、いうところだが左様はいわねえ、お袋さん、何とか法がござんすか。",
              "citation": {
                "source": "瞼の母　二幕六場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "身の置きどころは六十余州の、どこといって決まりのねえ空の下を飛んで歩く旅にんに逆戻り、股旅草鞋を直ぐにも穿こうか。",
              "citation": {
                "source": "瞼の母　二幕六場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠太郎　（素早く斬り仆し、血を拭い鞘に納め、斜めの径を歩き、母子の去れる方を振り返りかけてやめる）朝の真赤な光が映す、忠太郎、その光に背いて、股旅の路に踏み出す。",
              "citation": {
                "source": "瞼の母　二幕六場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "或いは又股旅物やチャンバラは大衆文学だと云われる。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそ股旅者の旅鴉といいたい位だ。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのような行末の有望なお方を、わたしのような股旅者が引留めようのなんのと、そんなだいそれた心はありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、女というものが別な女になって、海千山千の股旅者ではない、純な処女の人情として扱うことの、何となしの魅力を、兵馬が改めて感得したものと見えて、気持よく言いました、「よろしい、最後の一夜を明かしましょう、出立は一日延ばしてあげます」「まあ嬉しい、嬉しい」　女は飛び立って悦びました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "股旅映画みたい……」　真剣な俺の言葉を、冗談でも言ったみたいに波子はからかって、「あたしもついて行こうかしら。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、特に今日の文化的民衆の間には殺伐だといはれたり、餘りに復古的だといはれたり、また退歩的だと見られたりするやうな封建的な人物、道徳、時代相などを書くうちに、人物には宮本武藏のやうな劍客とか、股旅的人物とか、また戰國の鬪將連が登場する。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……ははあ、兇状持ちの股旅者ンだな。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はアて、こんな股旅者が」「なんともはや、面目もありません。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "真新しい衣服頭巾をめぐまれ、朝飯もたべて、すっかり元気を取り戻したかの股旅者は、晁蓋を前にしてその素姓を明らかに語っていた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪にも色気狂いのような釵子やら簪やら挿して、亭主はおろか、股旅でも、呑み助の暴れン坊でも、まちがえばちょいと抓んで抛り出すなどお茶の子だといわれているこのおばさんにしてさえ、しんそこは、やはり女であったらしい。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまもなくある日縁側で倒れて気息の絶え絶えになっているのを発見して水やまたたびを飲ませたら一時は回復した。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十七　夫人はわずかに語るうちも、あまたたび息を継ぎ、「小児と申しても継しい中で、それでも姉弟とも、真の児とも、賢之助は可愛くッてなりません。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて座敷で介抱して、ようよう正気づくと、仁右衛門は四辺を※し、あまたたび口籠りながら、相済みましねえ、お客様、御出家、宰八｜此方にはなおの事、四十年来の知己が、余り気心を知らんようで、面目もない次第じゃ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、あまたたび額の汗を拭った。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――たちまち鉄砲の音、あまたたび――薄　それ、皆さん。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと足遅れてのぼり来る姫の息｜促りて苦しげなれば、あまたたび休みて、漸う上にいたりて見るに、ここはおもひの外に広く、めぐりに低き鉄欄干をつくり、中央に大なる切石一つ据ゑたり。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと足遅れてのぼり来る姫の息せまりて苦しげなれば、あまたたび休みて、ようよう上にいたりて見るに、ここはおもいのほかに広く、めぐりに低き鉄欄干をつくり、中央に大なる切り石一つすえたり。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
