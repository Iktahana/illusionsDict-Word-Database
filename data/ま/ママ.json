        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "小サイ可愛イママサマ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ママサマ、少シモアブナイ事ハアリマセン。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "小泉八雲　小サイ可愛イママサマ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "（中略）　ママニ願ウ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "サヨナラ、可愛イママサマ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻を愛称して『小サイ可愛イママサマ』と呼んでるヘルンは、同時にいかにまた子煩悩であったかが解る。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『内のパパとママとは、だれにも解らない不思議な言葉でだれにも解らない神秘のことを話している』と、学校へ行ってる男の子が、自慢らしく仲間の子供に語ったほど、それは奇妙な別世界の会話であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ママさん私この寺に坐る。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『家のパパとママとは、だれにも解らない不思議な言葉で、だれにも解らない神秘なことを話している』と子供が無邪気に言った言葉は、実際にもっと神秘な意味をもっていたのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンにとっての夫人は、この世にただ一人の愛人であり、永久に『可愛い小さいママさま』であったと共に、またその仕事の忠実な助手でもあり秘書でもあった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰かあたしのパパとママンになる人は無いかい。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼女はあらためてパパとママンになりそうな人が欲しいと希望を持ち出した。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、ママンにはあたしがなってやる。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "パパの鋸楽師と、ママンのマギイ婆さんが珍らしそうに英語名前の食ものを食っている間に入り代り立ち代り獲ものは罠の座についた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「パパ、ママ」排撃を事新しく持ち出すわけではないが、外来語の横行もこんなになってくると深く考えさせられる。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾はいいママだわねえ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あの娘にとって、お前はいいママかも知れないよ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ママが泣いちゃう！",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "農民をママ子扱いにしていた。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルジョア文学になると、もっと農民を、ママ子扱いにしている。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんなにキママを云うてどうするんぞいや！",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども僕はなんだか臆病になってパパにもママにも買って下さいと願う気になれないので、毎日々々その絵具のことを心の中で思いつづけるばかりで幾日か日がたちました。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事にも几帳面で、怒らない時には柔順な敏夫は、私の父の塑像の前に行つて、「おぢいちやま御機嫌よう、おばあちやま御機嫌よう、ママ御機嫌よう」　一々頭を下げて誰にともなく云つてから、私の所に來て、「パパ御機嫌よう」と挨拶した。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」青年「これ、僕のママです。",
              "citation": {
                "source": "オペラの帰途",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ママこっちへ来るんですよ」　紳士は二人を制して微笑した。",
              "citation": {
                "source": "オペラの帰途",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショッファーと僕こっちに乗るから君ママを側へ乗せて操縦したまえ」　婦人を傍へ坐らせて操縦しながら青年は後の紳士に話しかける。",
              "citation": {
                "source": "オペラの帰途",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお嬢さんは……いや、ママさんはあっさりしている。",
              "citation": {
                "source": "オペラの帰途",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえのあの時の雑煮はすっかりおまえがつくったというんじゃないのか、でも、おれが食って居る傍でおまえのママがそう説明したんだよ」　――そうなの、ママの説明のとおりなの。",
              "citation": {
                "source": "餅",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの日ママがね、今日は慎一さんが来られるからおもてなしに出すものはみなおまえがするがいい。",
              "citation": {
                "source": "餅",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
