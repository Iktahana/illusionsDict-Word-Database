        "examples": {
          "standard": [
            {
              "text": "最近流行っているこの前割れのスカート、歩きやすくてデザインも素敵だね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "伝統的な前割れの衣装を身に纏い、祭りの行列がゆっくりと進んでいく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "前割れのパンプスは、足元をすっきりと見せてくれるのでオフィスでも重宝する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それを機に、私は立ち上り、浴衣を脱いで、例の前割れシャツと、ステテコ姿になる。",
              "citation": {
                "source": "日を愛しむ",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただその恋情を、世の義理のためにまげているお艶と、男の意地、刀の手まえわれとわが胸底をいつわりおさえなければならぬ栄三郎と、世にかなしきはかかる恋であろう――。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
