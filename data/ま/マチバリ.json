          "literary": [
            {
              "text": "「そうですよ」　おゆきは、縫っていた糸を歯できって、つぎのしるしにまち針をうちながら、「あっさんは赤門。",
              "citation": {
                "source": "菊人形",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　てふが、まち針を打ちながらわざと無雑作に云った。",
              "citation": {
                "source": "縫子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "電流計の針がブルッと震えたかと思うと、弾かれたようにピーンと右の方へ一｜閃、たちまち針が飛んでしまった。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
