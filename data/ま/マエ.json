        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供たちは、着替えの際に体の前を隠すように教わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "医者は診察の前に、患者に体の前を出すように促した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "公衆の面前で体の前をさらすのは、社会的に許されない行為だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 10,
        "gloss": "criminal record",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は昔、小さな犯罪を犯して「前」があることを告白した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "警察は容疑者の「前」を調べ、過去の類似事件との関連性を探った。",
