    "definitions": [
      {
        "index": 1,
        "gloss": "round collar (of Western clothing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "幼稚園の制服は、可愛らしい丸襟のブラウスに指定されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は丸襟のワンピースを着て、清楚な雰囲気でパーティーに現れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "このシャツは丸襟なので、ネクタイを締めるよりもカジュアルに着こなしたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "白衫に銀紗模様という洒落た丸襟の上着に、紅絞りの腰当をあて、うしろ髪には獅子頭の金具止め、黄皮の靴。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "びろうどの黒い丸襟の服を着、羊脂の珠のかがやく帯には細身な短剣を佩いているのみでなく、金鶏の羽ネで飾られた貴人の冠といい珍珠の履、どう見ても、王侯の香いがする。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
