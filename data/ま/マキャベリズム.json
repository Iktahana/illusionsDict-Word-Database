        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あの政治家はマキャベリズムを信奉しており、目的のためには手段を選ばないことで知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "企業買収において、彼の冷徹なマキャベリズムが成功の鍵となったと評価された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史書を読み進めるうちに、権力闘争におけるマキャベリズムの側面がより深く理解できた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "軍国主義とファシズムに対する人民のしんからの嫌悪を逆用して、その名を戦争挑発反対者に冠らせ、内外の戦争挑発に対する抵抗分子を除去しようとする試みは、近代マキャベリズムの一つの着想として考えられないことではない。",
              "citation": {
                "source": "世紀の「分別」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "全欧洲が、獅子のように恐れ憚る大皇帝と、マキャベリズムの実行者のような三十三歳の大外交官とは、そこで、しばらく沈黙した。",
              "citation": {
                "source": "今昔茶話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "逆説というよりむしろ一種のマキャベリズムだね、そいつを身近に引きつけて監視している間だけは、少なくとも安全だといえるからね。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの三十年戦争の惨禍は実に莫大なるもので、歴史家のいうところに依れば、ハイデルベルグ大学の学生はただ二人となり、他の学生は「マキャベリズム」に感染せる残酷なる兵隊の群に入りて掠奪を事としたのである。",
              "citation": {
                "source": "大戦乱後の国際平和",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
