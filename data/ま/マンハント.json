        "examples": {
          "standard": [
            {
              "text": "脱獄犯を捕らえるため、警察は大規模なマンハントを開始した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「マンハント」は、逃走者と追跡者の心理戦を描いたスリリングな映画だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "犯人の特徴が公開され、街全体でマンハントが行われているような緊張感があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私はホルマンハントが贖罪の羊を描いた死海の画を想ひ出さずにゐられなかつた。",
              "citation": {
                "source": "トラピスト天使園の童貞",
                "author": "三木露風",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから「マンハント」八月創刊号。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘミングウェイ「老人と海」と、「マンハント」九月号と交互に読むうち眠くなる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
