      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "many words",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自分の意志や感情やを、真によく対手に呑み込んでもらうためには、対手が自分の親友｜知己であり、自分の心持ちや性格やを、充分によく知っているものでない限り百万言を費して無駄になる場合が多い。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "云うまでもなく、朝顔を見たことのないエスキモー土人に朝顔を説明するに百万言を費やすよりも写真か映画で一分間を費やした方が早分りである。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みにたったひとこまの皮膜に写った形像を精細に言葉で記載しようとしてもおそらく千万言を費やしてもなおすべてを尽くすことは不可能であろう。",
              "citation": {
                "source": "ニュース映画と新聞記事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一こと理窟を言いだしたら最後、あとからあとから、まだまだと前言を追いかけていって、とうとう千万言の註釈。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですからこの制度を改めるに非ずんば、千万言を費しても文化の普及と云ふことは駄目であります。",
              "citation": {
                "source": "農民文化といふこと",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「諸君、祭司長は、只今既に、無言を以て百千万言を披瀝した。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "某々四五人のものは、既に一身の運命の窮極を悟り、且つは共同の被告に累の及ばんことを慮りて、なるべく詞短に問に対する答をなした丈であつたが、之等は千万言を費しても動かすことの出来ない犯罪事実を自認して居たからである。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分には、女の千万言の身の上噺よりも、その一言の呟きのほうに、共感をそそられるに違いないと期待していても、この世の中の女から、ついにいちども自分は、その言葉を聞いた事がないのを、奇怪とも不思議とも感じております。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの沈黙は千万言にも尚ほ勝るほどの感動を二人に与へた。",
              "citation": {
                "source": "時子",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々鈍漢が千言万言｜列べても要領を尽せない事を緑雨はただ一言で窮処に命中するような警句を吐いた。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "井侯が陛下の行幸を鳥居坂の私邸に仰いで団十郎一座の劇を御覧に供したのは劇を賤視する従来の陋見を破って千万言の論文よりも芸術の位置を高める数倍の効果があった。",
              "citation": {
                "source": "四十年前",
                "author": "――新文学の曙光――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は已むを得ない事情のために私を裏切ったことを、千万言にもまさる雄弁な美しい涙によって私に告白して、許しを乞うているのだ。",
              "citation": {
                "source": "秘密",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "その事実のうちに、千万言にまさる道義が存在することを今にして会得するであろうと信じる。",
              "citation": {
                "source": "婦人の一票",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "千万言を聴いて悲しむ場合もあり、唯の一言を聴いて悲しむ場合もあり、甚しい場合には云はぬ言葉さへ聴いて悲しむのである。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "私信の一部を公にしては悪いが、わたしの筆に幾万言を費して現わそうとするよりも、この書簡の断片の方がどれだけ雄弁に語っているか知れない。",
              "citation": {
                "source": "柳原※子（白蓮）",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際校長の心持ちは千万言を費やすよりもありがとうの一語につきているのであった、かれはいま九百の青少年から人間としてもっとも美しい精霊を感受することができたのであった。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "この至誠殉法の一語は、民会に諭す百万言よりも彼らの叛意を翻すに殊効があったろうと思う。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "その女の叫ぶ百万言もみんな彼には判っていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "持つて生れた雄弁で、中国の情勢、地理風俗にまでわたつて数万言、信長の大軍に出陣を乞ひ自ら手引して中国に攻め入るなら平定容易であると言つて快弁を弄する。",
              "citation": {
                "source": "黒田如水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が縷々万言を費したことはたかが表情に就てですが、然しながら私は実は女占師の敵意の視線を前にしてその表情がどうならうとその方のことは意にしたくないつもりでゐました。",
              "citation": {
                "source": "女占師の前にて",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、僕も開き直って、徳川公の書の能書なることをあれこれと様々に説明したが、遂に彼等を承服させ得ず、百万言の説法も徒労に終ったばかりか、遂には、君の見方も当てにならないね、という風で、そのためこちらまで不信任になった。",
              "citation": {
                "source": "現代能書批評",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "偉人の片言というものは、くだらねえ奴らの百万言より、どんなに身に沁むか解らない。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "元田｜永孚先生の如きはこの一節を説明するにも幾万言を費し、古今の大真理としたそうだが、「酔うて唄う亦楽しからずや。",
              "citation": {
                "source": "論語とバイブル",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は特に、Ｐ・Ｓの書方が極めてうまく、僅か二、三行のＰ・Ｓ中に、千万言の思いを巧みに託した。",
              "citation": {
                "source": "彼が殺したか",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "百万言をついやしても同じこと。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩賢避疫臥孤村、一夢結成千万言、追慕遺風尋古屋、老婆為我説民敦。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "（詩賢の人は疫病を避けてこの片田舎に臥し、ひとたびの夢むすびて千万言の書をなす。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "世に能弁利口、人に取入ることの巧妙な者があって、それが千万言を費そうとも、陶の一言ほどには俺の心霊を振蘯させ得なかッたろう。",
              "citation": {
                "source": "湖畔",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
