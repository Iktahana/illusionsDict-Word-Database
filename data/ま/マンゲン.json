[
  {
    "uuid": "316a8c20-2537-5a58-89dc-9b854acded67",
    "entry": "万言",
    "reading": {
      "primary": "まんげん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
