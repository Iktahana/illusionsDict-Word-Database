        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "わしの書いたものも、棚一段、満杯になろうとしていたんですよ。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "記憶装置の容量の想定は、一日に五〇〇〇ページ分の情報を入力したとしても満杯になるまでに数百年はかかろうという規模である。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほぼ満杯で、特許栓が差してある。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々がやるべきことは大きな旅行カバンを夜っ引き満杯にして、翌朝、廷臣に駅へ運ばせることだ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "この部屋は様子からして、小さな黄蛾で満杯になり、不運な男が素手ではたき落とし、粉々になったサフランの花弁が男の足元に輪っか状になっている。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "リンゴは丸くて赤く熟れており、３個もあれば帽子に満杯になるけど、玄人の口には不満足な代物だ。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからトリガーセン島向けの船が満杯で数隻到着し、海を渡って大切な品物を届けてくれた。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんと些細なことで、貧民は幸せになり、喜びの盃は満杯になることだろう。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "金属容器が満杯になるとゴム管に一滴流れ、増えた科酸の重みで、管を開く。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラリに知らせて蒸留器に継ぎ足させると、ちょっと前に満杯にしたと言う。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "コップが屈辱で満杯になり、一滴残らず飲み干す羽目になった。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "失望と絶望の苦しみが満杯になって垂れ落ちるのが分かった。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨大なタンクは石油が満杯、燃えるに任せるしかないだろう。",
              "citation": {
                "source": "四日闇夜",
                "author": "THE FOUR DAYS' NIGHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くの四軒の病院も満杯だ」　ヒューバート医師が叫んだ。",
              "citation": {
                "source": "死の土壌",
                "author": "THE DUST OF DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなぽこが　まんぱいになると、　こんどは　きの　たかいところに　ある　うろあなへと　ふくろを　あけはじめました。",
              "citation": {
                "source": "つまさきチミーのはなし",
                "author": "THE TALE OF TIMMY TIPTOES",
                "note": "青空文庫"
              }
            },
            {
              "text": "へやも　まんぱいで、　ろうかにまで　ごろごろ　ころがってる。",
              "citation": {
                "source": "つまさきチミーのはなし",
                "author": "THE TALE OF TIMMY TIPTOES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
