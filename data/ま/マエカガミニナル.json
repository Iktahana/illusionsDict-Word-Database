          "standard": [
            {
              "text": "読書に集中するあまり、彼は知らず知らずのうちに前かがみになっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "重い荷物を持つとき、腰に負担がかからないように前かがみになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "電車の揺れでバランスを崩さないよう、多くの乗客が手すりを掴んで前かがみになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "よくお湯を流して、滑に温められた流し場の板敷の上へ行儀よく坐って、後ろ首に白粉をのばす婆やの手の重みに少し前かがみになると、かやの眼の前には向き合って居る婆やの細長く垂れた、二つの乳房がふらふらとゆれて居た。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうか私にそのわけを話してください」　ウェッシントン夫人は前かがみになると、いつもの癖で、妙に早く首を傾げてから口をひらいた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            }
          ]
