          "literary": [
            {
              "text": "それどころかこの殺人は作為が様々見られ、部屋中に痕跡が残してあるため、そのあいだずっと加害者がいたことが丸わかりだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえ友が黙りながらもじっと考えを巡らせているその中身のことは、私にも丸わかりだった。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファーガソンが首ったけなのはまるわかりだ。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "マグレガーおじさんには　まるわかりでした。",
              "citation": {
                "source": "あなうさピーターのはなし",
                "author": "THE TALE OF PETER RABBIT",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつの　行き先なんて　ぼくには　まるわかりだ。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
