    "definitions": [
      {
        "index": 1,
        "gloss": "competitive spirit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「オヤ、負けん気だよ」、「怒つてるよ」と女給は思ふ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その愛別離苦の悲しみや壮烈な想いで、わしの腸はこんなに螺の貝のように捻じ巻いたのじゃないか」と山の祖神の翁は負けん気の声を振り立てていった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この界隈の人の間には共通の負けん気があった。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、あそこの、羽に、ゆがんだ点々のある、まだらさんはね、ものすごいりくつやで、おまけに負けん気なのよ。",
              "citation": {
                "source": "アヒルの庭で",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇　筆者の祖父は馬鹿正直者で、見栄坊で、負けん気で、誰にも頭を下げなかったが、しかし只圓翁にだけはそれこそ生命がけで心服していた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と僕も負けん気で、俺！",
              "citation": {
                "source": "大音寺君！",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "『さう、わたしもそんな気がするわ』　おきいちやんも負けん気になつて云ひました。",
              "citation": {
                "source": "虹の橋",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "「妾だつて、それつ位ゐ……」　ふと負けん気な照子は、石を拾ひ、私に真似て、でも女らしく腕だけで「ヨツ！",
              "citation": {
                "source": "晩春の健康",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "世俗な勝気や負けん気の女のひとは相当あるのだけれども、勝気とか負けん気とかいうものは、いつも相手があってそれとの張り合いの上でのことで、その女らしい脆さで裏づけされたつよさは、女のひとのよさよりもわるさを助長しているのがこれまでのありようであった。",
              "citation": {
                "source": "新しい船出",
                "author": "――女らしさの昨日、今日、明日――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夕暮」の絵の下図も出来ていたことだし自分としても気分のいい構図だったので何とかして招待日までに間に合わせたかったので、無理だと思ったが一年一度の制作を年のせいで間に合わせなかったなどと思われるのが残念さから、負けん気を起こして、これもまる一週間徹夜をつづけた。",
              "citation": {
                "source": "健康と仕事",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "忘れもしねえが、何でもあれは清元の師匠の花見の時だっけ、飛鳥山の茶店で多勢芸者や落語家を連れた一巻と落ち合って、向うがからかい半分に無理｜強いした酒に、お前は恐ろしく酔ってしまって、それでも負けん気で『江戸桜』か何か唄って皆をアッと言わせた、ね、覚えてるだろう」「そうそう、そんなことがあったっけね。",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は泣き顔で戻って行くが、負けん気の参右衛門も、このようなときは、さすがに声は低く娘に詫びを云うように悄気ている。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アレは負けん気が強いし、小さい時から世の中のウラばかり見て来とるから、あんな風になったんだよ。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "母ちゃんが、姉ちゃんに負けん気だして、辛えの無理しんなって、よ。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺や腹の底の方に途方もなく強情な、負けん気の、勇ましい奴がゐやがるな」と尊厳な弁護士は頼もしさうに呟いたほどだつた。",
              "citation": {
                "source": "金談にからまる詩的要素の神秘性に就て",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人とも負けん気より衝突しとかく咬み合う。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "やらせてみると、どんな仕事でも素晴しく器用だし、書物は驚くほど読んでゐて、ただ知らん顔をしてゐるだけだし、そのうへ、兄に似て、兄が手古摺るほどの負けん気と来てゐる。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、キーシュは今ではもう十三歳になり、お父さんゆずりのがんじょうさと負けん気とを持つようになりました。",
              "citation": {
                "source": "負けない少年",
                "author": "吉田甲子太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "負けん気の照子は、大晦日までの疲れをけろりと忘れた顔で、ふだんの女学生気分にかへつた。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "また例のおどしだと思ったものだから、負けん気の千太、ふふんと鼻で笑って、なにをしゃらくせえ、と言うつもりなのが、ただ、「ウワ、ウワ」　としか言えない。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "野伏大名",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、負けん気のつよい諭吉は、「なあに、いまにみろ、みんなにおいついてやるから。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "もと彼には、不運だつた父親を持つた息子に特有な、自分の未知の生涯に対する負けん気が潜んでゐた。",
              "citation": {
                "source": "朧夜",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "『和歌山は居らんと見えるな、居つたら大分大事ぢやが……あの男も負けん気ぢやから、負けて居らんわな』　その中に刑事らしい男が這入つて来て、『まア静かにせ、静かにせ』となだめて居る。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり車夫が猿股をつけて天下の大道を我物顔に横行｜濶歩するのを憎らしいと思って負けん気の化物が六年間工夫して羽織と云う無用の長物を発明した。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、梨枝子と菊子とが見てゐる前で嶺太郎が、颯爽と抜手を切るのをみて、彼もはじめは敵はぬと思つたが、つい、負けん気を出し、一つ変つたところをと、こつちはうろ覚えの背泳をやつてみせた。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠矢幸造の勉強ぶりは、思つたより真剣で、記憶のわるさを補う子供のような素直さと野心家独特の負けん気とで、教える方でも、わりに張合いがあつた。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "一座と言ってもあと四人だけ、一人は梅谷｜哲と言う貴族らしい青年、少し病弱そうですが、これは如何にも上品な人柄、もう一人は金井半四郎という、富豪の若主人と言った負けん気らしい、精悍そうな二十五、六の青年、打ち見たところはニコニコした、まことに人付きの良い男です。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第七夜　歓楽の夢魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう気風のあった家に、私の母のような負けん気の強い女の血筋が入ったのだから、半ばは運命のようなものを感じて、私らもあまりそれに抵抗しない方がいいとまで考えるようになった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
