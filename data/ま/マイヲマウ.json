    "definitions": [
      {
        "index": 1,
        "gloss": "to dance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「何、その舞を舞うのかい。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "九十に近い老僧が瘠せ枯びた病躯に古泥障を懸けて翼として胡蝶の舞を舞うたのであった。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「未熟な芸を御所望とならば、今宵は朝まで御覧に入れましょう」　八郎は其の夜終夜病人の前で幸若舞を舞うて見せた。",
              "citation": {
                "source": "人面瘡物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "思い出せば、古いことじゃが、そなたが十六で、われらが二十の秋じゃったが、祇園祭の折に、河原の掛小屋で二人一緒に、連舞を舞うたことを、よもや忘れはしやるまいなあ。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを今日はぜひにも聴いてもらいたいのじゃ、思い出せば古いことじゃ、そなたが十六で、われらが二十の歳の秋じゃったが、祇園祭の折に、河原の掛小屋で、二人一緒に連舞を舞うたことがあるのを、よもや忘れはしやるまいなあ。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀と黄金と私の心と――　一つの大きなかたまりとなって偉大な宙に最善の舞を舞う。",
              "citation": {
                "source": "旅へ出て",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "能楽は楽器を伴った朗読につれてそれぞれの性格を現す「能の面」（マスク）をつけた二人三人の登場人物が、動作のきわめて圧縮されたシムボリックな舞を舞う。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞を舞うのが好きと見えて、始終、何やら舞うていると聞きましたので、私が、謡をうたってみますと本当に舞いはじめました。",
              "citation": {
                "source": "画筆に生きる五十年",
                "author": "――皇太后陛下御下命画に二十一年間の精進をこめて上納――",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕舞を舞うこともございます。",
              "citation": {
                "source": "画筆に生きる五十年",
                "author": "――皇太后陛下御下命画に二十一年間の精進をこめて上納――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてこの山人は、同時に薪を立て、庭燎を焚き、倭舞を舞うたことが梅宮に関する江家次第などの記述を中心として考へると訣ります。",
              "citation": {
                "source": "神楽（その二）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此舞を舞うたのは弘計王で、度々言うて来た縮見の室ほぎの時であつたのも、家の精霊を小人と考へて居た平安朝頃の観念を、溯らして見る事が出来れば、説明はうまくつく。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それも、もう一枚めくって見れば、難なく解決されたことで、そこには前に首だけ写生しておいた美人の全身が、妙な旋律を起しながら、胸に物を抱いて、舞を舞うているところが描かれてありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "神楽と云っても、神子が鈴を振り、笛に合せて、神前で舞を舞うばかりではない。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「千島返還促進同盟」を彼が首唱して、道民が少しも踊らず、お蔵になってしまったが、「ハボマイ返還促進同盟」の二の舞を舞う道化役者に、なるかならぬか、するかしないか、彼の意志の彼方にあろう。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "天女十六人は左右に分かれて舞を舞う。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなくては、勤めかねます」「すりゃ、その面と装束は、舞を舞うためのものか」「さようでございます」　伝内はまじまじと主水の顔を見ていたが、大きな声で、「たわけ」　と一喝すると、荒々しく座から立って行った。",
              "citation": {
                "source": "鈴木主水",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本などはそれに比べると、ずっと優しいよい方法で、特別の場合でもせいぜい五節の舞を舞うくらいのものである。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その熱と、その水とに潤されて、地の濃やかな肌からは湿っぽい、なごやかな薫りが立ちのぼり、老木の切株から、なよなよと萌え出した優雅な蘖の葉は、微かな微かな空気の流動と自分の鼓動とのしおらしい合奏につれて、目にもとまらぬ舞を舞う。",
              "citation": {
                "source": "地は饒なり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲惨な人生を描いたものであっても、その悲惨に終った主人公が必ず（多く）舞を舞う。",
              "citation": {
                "source": "俳句への道",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故舞を舞うのかというと、これに依って救われた事を意味するのである。",
              "citation": {
                "source": "俳句への道",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大概｜成仏して舞を舞うという事に終る。",
              "citation": {
                "source": "俳句への道",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『腹が減っては戦が出来ぬ』云うことは聞いてるけど、舞を舞うのんにお腹張ってたら苦しいことないやろか」「そうかて、この人、お昼御飯もあんじょう食べてえへんのんで、ふらふらで舞うたら引っくり覆る云いますねん」「文楽の太夫は語ってしまうまで何も食べん云うやないか。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ルクレティウス）　（a）万物はお前たちの舞を舞うではないか。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその調子の変化につれて、もろもろの星は種々様々の舞を舞うのである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その御歌は、椅子にいる神樣が御手ずから彈かれる琴に舞を舞う女は永久にいてほしいことだな。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを渡るは何者じゃ」　と、呼びかけると、「これは」　と、驚いて振向いた良人は、小舞を舞うような恰好して、狼狽をかくしながら、「ここは小橋か大橋か、道にまようた者でおざる」　と、よろめいて来て、妻の背中につかまった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体に色が灰白なので老人に見立てたものと、長くつやつやとしているので少年に擬した名と二通りあり、なお『本草啓蒙』や、『増補｜俚言集覧』によれば舞を舞う人の姿にたとえたものも元は多かった。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野草雑記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
