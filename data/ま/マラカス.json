        "examples": {
          "standard": [
            {
              "text": "ラテン音楽のリズムに合わせて、彼はマラカスを軽快に振り鳴らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「幼稚園の発表会で、息子が一生懸命マラカスを振っている姿に感動したよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "マラカスの中には小さな種や玉が入っており、振るとシャカシャカと独特の音がする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "道頓堀筋、そこのキャバレエ赤玉の前を通ると、アジャーアジャーと訳の分らぬ唄声、そして途端に流れる打楽器とマラカスのチャイナルンバ。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きなキャバレエーの前を通ると、いきなり、アジャーアジャーとわけのわからぬ唄歌、とたんに打楽器とマラカスがチャイナルンバを奏しだしたのが腹立たしく耳にはいった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
