        "examples": {
          "standard": [
            {
              "text": "作業着に巻きゲートルを着用し、準備を整えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔の兵隊は、足元を保護するために巻きゲートルを巻いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "山歩きには、ズボンの裾が邪魔にならないよう巻きゲートルが便利だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さしこのはっぴに、さしこの頭巾、下は巻きゲートルに靴をはいている。",
              "citation": {
                "source": "一坪館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻きゲートルをして、地下足袋をはいて、黒い帽子を被っていました。",
              "citation": {
                "source": "生きぬく力",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "主任のボタンはすべて取れ10万人もの兵士を回って巻きゲートルが合わなくなったことを知っている私はこの哀れな男を可哀想に思った。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、見物人をかきわけて、まきゲートルをした若者が前へ出てきました。",
              "citation": {
                "source": "道の上で見た話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
