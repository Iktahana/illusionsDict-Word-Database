    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese timber bamboo (Phyllostachys bambusoides)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは真竹の根の地上に三寸ばかり現はれた処に発してゐた。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "食物には、筍は孟宗のシユンは過ぎて淡竹｜真竹の歯切れのよい品種が私たちを迎へる。",
              "citation": {
                "source": "初夏に座す",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（これがうつくしい伯母さんのために出家した甥だと、墨染の袖に、その杜若の花ともあるべき処を）茗荷を掴み添えた、真竹の子の長い奴を、五六本ぶら下げていましたが、（じゃあ、米一升でどうじゃい。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "塙代与九郎宅の奥庭、落葉を一パイに沈めた泉水に近く、樫と赤松に囲まれた離れ座敷は、広島風の能古萱葺、網代の杉天井、真竹瓦の四方縁、茶室好みの水口を揃えて、青銅の釣燈籠、高取焼大手水鉢の配りなぞ、数寄者を驚かす凝った一構え……如何にも三百五十石の馬廻格には過ぎた風情であった。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、これは真竹に限る。",
              "citation": {
                "source": "天主閣の音",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "真竹、孟宗の類は、この地方には十分に成長しません。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "礫が飛び土煙りが上がり、真竹が十本束になって切られ、婆裟と地上へ仆れて来た。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――真竹の藪がさやさやと鳴った。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一むら、真竹の竹藪があるばかりだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "おねえさまたちが、浅瀬に乗りあげた船からひろってきた、めずらしいものをかざってあそんでいるようなときでも、このお姫さまだけはちがいました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは、お城の中でにぎやかにうたったり、踊ったりしているというのに、お姫さまだけは、たったひとりで、自分の小さな花壇の中に、悲しみに沈んですわっていました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、神さまだけが、われわれにおあたえくださることができるのだ。",
              "citation": {
                "source": "家じゅうの人たちの言ったこと",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、お姫さまだけは、ソファに横になったきり、口をきこうともしませんでした。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今は、神さまだけがごぞんじの、深い海の底に、横たわっている、あの子の夢を見たのです。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたまだけ　じょうずに　こぞうに　ばけたかと　おもうと、くろい　手が　二ほん　にょきっと　でて　いました。",
              "citation": {
                "source": "ひよりげた",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがしょうこに、それから五、六｜日のち、海蔵さんは、椿の木に向かいあった崖の上にはらばいになって、えにしだの下から首ったまだけ出し、人々の喜捨のしようを見ていました。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "御重臣たちは色を失ひ、こそこそ御退出なさいましたが、相州さまだけは御退出の際もにこにこ笑つて、さうして舌をお出しなさいました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお母さまだけは、嫁の手がさはつたところには、きつとしめり気がのこるのを見て、一人でへんだ／″＼と思ひました。",
              "citation": {
                "source": "湖水の鐘",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればこの頃よりは思いしよりも忙わしくして、多くもあらぬ蔵書をひもとき、旧業をたずぬることもかたく、大学の籍はまだけずられねど、謝金を収むることのかたければ、ただ一つにしたる講筵だに往きて聴くことは稀なりき。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから東京は暑くなるのに、新子姉さまだけが別天地にいられるわけね。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、どんどん先へ立って行こうとするので、「あの、奥さまに、ご挨拶したいのですが……」というと、「奥さまは、来週の水曜まで、東京にいらっしゃいますので……」「まあ……じゃ、こちらは……」と訊くと、「旦那さまと、お子さまだけでございます。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那さまと、お子さまだけをこちらへよこして、奥さまは、まだ東京にいらっしゃいますの。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、お父さまだけが、わたしが決して悪い子供ではなかったことを思っていてください）　その日の昼食後の休み時間に、わたしは頭が痛むので教室の中で一人で休んでおりました。",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、お父さまだけがわたしがとったのではないことを思っていてください。",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ返ってくるのは、周囲の断崖に反響する自分の声のこだまだけであった。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかのおねえさまたちが、難船した船からとって来ためずらしい品物をならべたててよろこんでいるとき、このひいさまだけは、うつくしい大理石の像をひとつとって来て、大空のお日さまの色に似た、ばら色の花の下に、それをおいただけでした。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうだいたちが、こうして手をつないで、夕方、水の上へあがっていくとき、いちばん下のひいさまだけは、いつもひとりぼっちあとにのこっていました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "お月さまだけが、うつくしくさえていました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそのなかでひとり、いちばん年下のおにいさまだけが、あとにのこっていました。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどいちばん末のおにいさまだけは片手なくって、そのかわりにはくちょうの羽根をつけていました。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
