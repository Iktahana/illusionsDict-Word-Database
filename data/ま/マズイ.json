    "definitions": [
      {
        "index": 1,
        "gloss": "bad(-tasting)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
