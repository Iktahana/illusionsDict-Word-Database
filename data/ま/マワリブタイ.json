        "examples": {
          "standard": [
            {
              "text": "劇場の回り舞台で、次々と場面が転換していく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歌舞伎の回り舞台は、日本の伝統的な舞台技術の粋だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの役者は回り舞台の上で、見事な立ち回りを演じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「所が杉江さん、人の世の回り舞台なんてものは、全く一寸先が判らないものでね。",
              "citation": {
                "source": "絶景万国博覧会",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "月が落ちてゆき、回り舞台が回る。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "旗一兵「喜劇人回り舞台」を読み出し、眠りしは、三時すぎ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "床が回り舞台のように消え、反対側から全く同じ模様の絨毯を敷いた床が現れた。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
