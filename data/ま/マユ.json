  {
    "uuid": "91bd762f-6175-5100-bc35-211b2e349d0b",
    "entry": "繭",
    "reading": {
      "primary": "まゆ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cocoon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（「山繭」一九二六年十一月号）",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "否、小雨にぬれた山まゆの繭。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は歌垣に加わって歌舞する手並も人並以上に優れたが、それよりも、繭を口に含んで糸を紡ぎ出し、機糸の上を真櫛でもって掻き捌く伎倆の方が遥に群を抜いていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "廂を長く突出した低いがっしりした二階家では窓から座敷に積まれているらしい繭の山の尖が白く覗かれた。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒板を見てわらっていました、それから繭を売るのが済んだら自分も行こうと云うのでした。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は前庭の日なたで繭を※ながら、実際グレートヘンのように糸繰車を廻していることがある。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　文藝城、新思潮、眞晝、葡萄園、山繭、驢馬等、目星しい同人雜誌の十二月號の出ないのはどうしたことか。",
              "citation": {
                "source": "「青空語」に寄せて（昭和二年一月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒板を見てわらってゐました、それから繭を売るのが済んだら自分も行かうと云ふのでした。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、しかし――この清らかな繭のような餅を見るとき、捨て難きあのおん方――思い断ち難きわが心――。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿難　――わたしは清らかな繭と見る、また峯を連ねた雪の山だ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿難　――いいや繭だ、雪の山だ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまもなく、虫は大きな黄いろな繭を、網の目ごとにかけはじめました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとてぐす飼いの男は、狂気のようになって、ブドリたちをしかりとばして、その繭を籠に集めさせました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしてこしらえた黄いろな糸が小屋に半分ばかりたまったころ、外に置いた繭からは、大きな白い蛾がぽろぽろぽろぽろ飛びだしはじめました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝と晩に膿を吸い取るために当ててある山繭とガアゼを、自分でピンセットで剥がしちゃ取り替えていましたけれど、見ちゃいられませんでしたわ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "真綿は繭を曹達でくたくた煮て緒を撈り、水に晒して蛹を取り棄てたものを、板に熨して拡げるのだったが、彼女は唄一つ歌わず青春の甘い夢もなく、脇目もふらず働いているうちに、野山に幾度かの春が来たり秋がおとずれて、やがて二十三にもなった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中に蠶はずん／＼大きくなつて最早二三日ばかりすると繭をかけると云ふ一番大切な時になりました、お母様はいつもの通り金持ちの家の裏の畠に桑を盗みに行きますと其の夜は美しい月の夜で今まで毎晩葉を千切られた桑の樹が皆枝ばかりになつて白い光りの下にズラリと並んで居りました。",
              "citation": {
                "source": "金銀の衣裳",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "又｜其中の一人は同じ村外れの一軒の廃ら屋から金色の光りが輝き出て居るのを見て不思議に思つて覗つて見ますと何様でせう、蠶は皆お玉の母親の心に感じたものか眼も眩い金銀の糸を吐いて大きな繭を家中にかけて居りましたから今まで真暗なみじめなお玉の家の中はまるで王様のお住居の様に光り輝いて居りました。",
              "citation": {
                "source": "金銀の衣裳",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親に逢つたお玉の喜び娘の出世を喜ぶ母親の喜び此様な美しいお后を見つけた皇太子の喜び、王様御夫婦の喜び、取り分けても世にも珍らしい金銀の繭を見た人々の驚きそれやこれやで世界は喜びと驚きに満ち／＼たかと思はれました。",
              "citation": {
                "source": "金銀の衣裳",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして飽満の極に達した時、繭を作って蛹となり、仮死の状態に入って昏睡する。",
              "citation": {
                "source": "老年と人生",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩十四章、其二に曰く、念ふ　子が　初めて来りし時、才思　繭糸の若し。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "と内力少し気に至る、其費且つ巨千万、其住｜纔に二三年、古人の造る者居らずと云える、誠なるかな斯言、と嘲り、自分の暮歯に及んで小宅を起せるを、老蚕の繭を成すが如しと笑い、其の住むこと幾時ぞや、と自ら笑って居る。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "老蚕の繭を成せる如し、とは流石に好かった。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "保胤が池亭を造った時は、自ら記して、老蚕の繭を成せるがごとしと云ったが、老蚕は永く繭中に在り得無かった。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "保胤は遂に寛和二年を以て、自分が折角こしらえた繭を咬破って出て、落髪出家の身となって終った。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
