        "examples": {
          "standard": [
            {
              "text": "地主から借りた農地を勝手に他人に貸し出す又小作は、小作権を失う原因になりかねない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔の農村では、貧しい農民が生活のためにやむを得ず又小作という形で土地を貸し借りしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "又小作の小作料が不当に高く設定されていたため、耕作者たちの生活は極めて困窮していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "――「又小作いじめだ！",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            }
          ]
        }
