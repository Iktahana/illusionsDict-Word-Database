    "definitions": [
      {
        "index": 1,
        "gloss": "see you tomorrow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
