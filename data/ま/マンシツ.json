        "examples": {
          "standard": [
            {
              "text": "ホテルは観光客でいっぱいで、どこも満室だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "人気の旅館は、週末は常に満室になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "年末年始は、多くの宿泊施設が満室になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "また日高郡丹生川大字大谷に、蚯蚓小屋ちゅうは昔ここの杣小屋へ大蚯蚓一疋現われしを火に投ずると、暫くの間に満室蚯蚓で満たされその建物倒れそう故逃げ帰った、その小屋｜址という。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "其度に老爺が満室の客に注意を与へて演じる人を紹介する。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋はほぼ満室、おかみの持ち宿です。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいにく満室だったが、亡父チャールズ卿の居間と化粧室に居座り、そこにベッドを造れるだろう。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
