        "examples": {
          "standard": [
            {
              "text": "無理な戦いは避けるのが賢明だ。時には「負けるが勝ち」ということもある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "議論で言い負かされるのは悔しいが、相手の主張にも一理ある。今回は「負けるが勝ち」としよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "戦わずして撤退するのも一つの戦略だ。そう、まさに「負けるが勝ち」というわけだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "負けるが勝ちよ、私わざと負けたのよ。",
              "citation": {
                "source": "青白き公園",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
