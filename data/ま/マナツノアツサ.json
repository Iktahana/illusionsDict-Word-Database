        "examples": {
          "standard": [
            {
              "text": "真夏の暑さに体力を奪われ、食欲もなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "真夏の暑さ対策として、日中は外出を控えるようにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "真夏の暑さの中でのスポーツは、熱中症に注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "焼けるような真夏の暑さにむかって青い蛇は生き生きした鱗の色をよみがえらせたが、蛇つかいの顔には暗い影が始終まつわっていた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "真夏の暑さに閉めきっているのが変だと思ったのも道理。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれが、かなくそ山です」　つき当りの巍峨たる一峰を指して、案内僧がひたいの汗を押し拭った頃、陽もちょうど中天、真夏の暑さは昇りつめていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
