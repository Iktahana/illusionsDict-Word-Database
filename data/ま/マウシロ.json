    "definitions": [
      {
        "index": 1,
        "gloss": "right behind",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ちょうど観音堂の真後ろに向って田圃を距てて六郷という大名の邸宅があった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大火以前の雷門附近",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が明けたら、また何んとかなろうなぞ師匠は私たちにも話しておられたが、ふと、上野で戦争ということで気が附いて困ったことは、ちょうど、そのいくさのあるという上野の山下の雁鍋の真後ろの処（今の上野町）に裏屋住まいをしている師匠の知人のことに思い当ったのであります。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "上野戦争当時のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "『えーとこっちが北で、こっちが西と、この隅です』と机の置いてある真後ろの隅を指したの。",
              "citation": {
                "source": "ニッケルの文鎮",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅毛人の船長はこう云う彼の真後ろに立ち、不相変冷笑を浮べた顔を丁度半分だけ覗かせている。",
              "citation": {
                "source": "誘惑",
                "author": "――或シナリオ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "天狗の宮の真後ろまでこの崖道は続いている。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのは夜だからで、しかも所は八ヶ嶽の天狗の宮の真後ろの崖で、早春のことであったから氷雪が厚く積もっている。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "真後ろの小川山だけが黒木を鎧うた尨大な山容を紺碧の空に悠然と横たえているのが、振返える毎に目を楽しませたが、夫も押し寄せる雲の波を幾度か切り抜けた後、終に姿を没してしまった。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんはいつのまにか、しやがんでゐる少年の真後ろに立つてゐたのである。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "このさるは『権力が代表せられる令名高き閣下』の真後ろに座をかまえてこっけいなしかめっ面をして見せていた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "長老の真後ろにあつた「非常口」の扉が突然カタリと音がして一寸程開いた。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハッと驚いて飛んで行くと、お勝手の真後ろにある風呂場はもう人間一パイ。",
              "citation": {
                "source": "死の予告",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大文字山、志賀山、瓜生山、一乗寺山――と三十六峰の中腹を横に這って叡山の方へすすめば、ここからそう時を費やさずに、目的の一乗寺下り松のちょうど真後ろへ、山の上から望むこともできるのだった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "まうしろにあかりをつけておきました。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、そのうしろの柱に結びつけてある品物をとっくり見ろよ」　指さしたのは、二三春の死骸のちょうどまうしろになっている柱の下のほうに、しっかり結わいつけてあるその名もなまめかしい江戸紫のしごきです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んでいくのに、祝賀なんかされたら、ヘッケルとジャッケルが浮かばれない」　慶一は気持ちを引き立てるために、まうしろの令子に目をやる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "焦立ったか門弟のひとり、松をへだてて左膳のまうしろへまわり、草に刀を伏せて……ヒタヒタと慕い寄ったと見るまに、「えいッ！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにいたのは　ドードー（まんまえに　いる　おおきな　とりで、　つえに　よっかかってるね）、　それと　アヒルに　インコ（アヒルの　まうしろで　あたまごしに　みてる　やつね）、　あと　こどもワシ（インコの　ひだりがわに　いる　やつ）とか　そのほか　いろいろ。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男のまうしろまで接近したので、呼吸する息でその男の髪の毛がゆらぐのを防ぐために、顔を横にむけなければならぬほどだった。",
              "citation": {
                "source": "オスカー・ブロズキー事件",
                "author": "THE CASE OF OSCAR BRODSKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子たちにまうしろを見せてテーブルに向っていた一人の男が、ふいと人の気配を感じたように首をねじって振向いた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからわたし自身は、あなた方がおいでになつたときはいつていた部屋のまうしろの部屋で、本をかきまわしていました。",
              "citation": {
                "source": "とけない問題",
                "author": "THE INSOLUBLE PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄三郎は支えようとしたが、全身でとびつかれて支えきれずおつるを抱きとめたままうしろへ倒れた。",
              "citation": {
                "source": "扇野",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまうしろにいたかと思えば、たちまち右へまわり、右へまわったかと思えば、つぎの瞬間には高い樹上におどりあがり、樹上にいるかと思えば、前から切りおろす、ヒラリヒラリと足音ひとつたてず、しかもおどろいたことには、このやみのなかに曲者は目が見えるとみえて、そのねらいの正確さ！",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜそうかんじましたものか分りませぬがすぐまうしろにいたのだそうにござりますから女中どもにものをいうときの口のききかた、そのほかの態度やものごしなどがいかにも大家の御寮人らしくおうようだったのかも知れませぬ。",
              "citation": {
                "source": "蘆刈",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は四枚ある舞姿の中で、「心も遠き夜半の鐘」のあとの合の手のところ、―――傘を開いたままうしろに置き、中腰に両｜膝を衝いて、上体を斜め左の方に浮かせ、両｜袖を合わせ小首をかしげて、遠く雪空に消えて行く鐘の音に聴き入っているところ、―――を撮ったものが一番好きであった。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "直衛は着替えた袴の紐を緊めながら出てゆき、活けている佳奈の姿を、立ったままうしろから眺めていた。",
              "citation": {
                "source": "改訂御定法",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ万三郎さま、もういちどさっきのように抱いて下さいましな、ぎゅうっと、息の止るくらいきつく、ねえ」七　女は身もだえをしながら、両手で万三郎を抱き、そのままうしろへ倒れようとした。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――騒ぐな、おれは乱暴はしない、騒ぐと斬るぞ、じっとしていろ」　相手の男はけもののように喘ぎ、刀を持ったままうしろへさがった。",
              "citation": {
                "source": "雪と泥",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは彼女のほうに顔をむけると、棚に面して立っている彼女のうしろ姿を、ほぼまうしろからぼくは見ることができた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、その窓は、ちょうど明智探偵のまうしろにあったものですから、探偵はそんな奇妙な人の顔があらわれたことなど少しも知りませんでした。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その音が、ちょうど、ふたりのまうしろにきたとき、ぱったり聞こえなくなってしまいました。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
