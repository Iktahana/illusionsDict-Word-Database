    "definitions": [
      {
        "index": 1,
        "gloss": "front side",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "乗合いは随分｜立籠んだが、どこかに、空席は、と思う目が、まず何より前に映ったのは、まだ前側から下りないで、横顔も襟も、すっきりと硝子戸越に透通る、運転手台の婀娜姿。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の前側の窓は曾つて開きありたることなし。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓は前側のものも後側のものも鎖して内より鑰を卸しありたり。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "仰向けにすると、寝衣の前側と敷布は真っ赤に染まっていた。",
              "citation": {
                "source": "現場の写真",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "小夜子が紹介してくれというので、ちょいと紹介してから、二階へあがって行ったが、そうやって、前側にすわって扇子をつかっている小夜子の風貌は、広い場内でも際立つ方であった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "前側の椅子にかけると、彼女はヒステリックな表情で、「ここでは話もできないの。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "一葉の家は京町の非常門に近く、おはぐろ溝の手前側であったという。",
              "citation": {
                "source": "樋口一葉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは私たちをとても可愛がった酒屋が、利久そばやの前側にあって、隣家の家一軒買って通りぬけの広い納屋にした空地があるので、いい私たちの遊び場だった。",
              "citation": {
                "source": "勝川花菊の一生",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "前側の階段にはキラキラと日が当っていた。",
              "citation": {
                "source": "贋紙幣事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "観音堂裏には、江崎写真館の前側に、二、三軒あった。",
              "citation": {
                "source": "田沢稲船",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前側が大きな弓型の道路で岸の中央に、海に突出して八角の建物のカジノ・ド・フォリーが夢の竜宮のように青ばむ夜を、赤々と灯を水に照りかえしている。",
              "citation": {
                "source": "モルガンお雪",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛が跳び越して来ても、板囲いと見物席の前側の間は狭い通路になっていて、見物席は石の塀で遮られてあるからそれより内へは容易に侵入することはできない。",
              "citation": {
                "source": "闘牛",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前側の見物席はバレラスとかコントラバレスとか、デランテラスとか、位置に依ってそういう風に呼ばれ、アフィシオナドス（通人たち）の争って獲得しようとする座席である。",
              "citation": {
                "source": "闘牛",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前側は黒く続いた中村家の納屋で、あの向うが屋根より高く穂を上げた黍の畑になつて居ます。",
              "citation": {
                "source": "月夜",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょう、ちょいと婦人傍聴席を見ると、あのときの記憶の奥さんに似た細面の眼鏡の婦人が一番前側にいた。",
              "citation": {
                "source": "議会見物",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "前側の若い女、私と同じ位の年であろうか。",
              "citation": {
                "source": "四年のあいだのこと",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたまの前側だった貌。",
              "citation": {
                "source": "原爆詩集",
                "author": "峠三吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は鍛冶橋を渡って丸の内へ這入る時、いつでも東京府庁の前側にひろがっている閑地を眺めやるのである。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            },
            {
              "text": "門のところで、自転車を降りると、前側の板べいへ寄せかけて、ポケットから、焼き芋を出して、自分は食わずに、それを犬にやりました。",
              "citation": {
                "source": "生きぬく力",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "前側の商店の小僧さんが、往来をはいていました。",
              "citation": {
                "source": "ねずみの冒険",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "後の隅々についてゐる瓦斯の裸火の光は一ぱいに詰つてゐる見物人の頭に遮られて非常に暗く、狭苦しいので、猿のやうに人のつかまつてゐる前側の鉄棒から、向うに見える劇場の内部は天井ばかりがいかにも広々と見え、舞台は色づき濁つた空気の為に却て小さく甚遠く見えた。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "後の隅々についている瓦斯の裸火の光は一ぱいに詰っている見物人の頭に遮られて非常に暗く、狭苦しいので、猿のように人のつかまっている前側の鉄棒から、向うに見える劇場の内部は天井ばかりがいかにも広々と見え、舞台は色づき濁った空気のためにかえって小さく甚遠く見えた。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "影のように黒く立つ石川島の前側に、いつも幾艘となく碇泊している帆前船の横腹は、赤々と日の光に彩られた。",
              "citation": {
                "source": "深川の唄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉柄の前側には狭長な縦溝路があり、葉は質が鈍厚で表面は緑色を呈するが、裏面は淡緑色で常に或る菌類が寄生し、諦視すると細微な黒点を散布している。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本舞台向ふ黒幕、通しの波手摺、下手に葭簀張りの出茶屋、畳みたる道具、床几二脚程重ねあり、前側葭簀立廻しあり、此の側に永代両国乗合船の立札、側に船板の崩れ、櫂の折れなど積みあり、上の方松の立木、同じく釣枝、総て八つ山下、夜の模様」が黙阿弥の「因果小僧」八つ山下の道具立てで文久元年の作。",
              "citation": {
                "source": "山の手歳事記",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "前側にいるのを、とっては投げ、とっては投げしているうちに、川端にかがみこんでいた二百人ばかりの一団が、「お願い、お願い」　と連呼しながら、道幅いっぱいになって押しだしてきた。",
              "citation": {
                "source": "奥の海",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "前側に線のように見えるのは駆逐艦だろう。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が東京を立つ前に、母の持っていた、ある場末の地面が、新たに電車の布設される通り路に当るとかでその前側を幾坪か買い上げられると聞いたとき、自分は母に「じゃその金でこの夏みんなを連て旅行なさい」と勧めて、「また二郎さんのお株が始まった」と笑われた事がある。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも、「おまえがわるいんだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝶子よ、おまえがわたしの上に平気で呼び慣れて来たおじさんというものは、そういう果敢無くも似非義人的なものなのだ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
