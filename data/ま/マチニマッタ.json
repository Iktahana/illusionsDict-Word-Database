        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "待ちに待った朝は来た、朝がいかなる方面から、いかに忍び足に寄って来て、一秒ずつ額を白くしたかは徹夜凝視しても解らない、夜と朝の筋目が判然と目立つほどなら、地球の緯度線が草鞋の爪先に引っかかるわけである、しかも争う可らざるは朝の神秘なり、一たび臨むとき、木偶には魂を、大理石には血を与る。",
              "citation": {
                "source": "奥常念岳の絶巓に立つ記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ちに待った過越の祭、エルサレム宮に乗り込む、これが、あのダビデの御子の姿であったのか。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "神山甚兵衛も、出陣以来、待ちに待った日にあうことを喜んだ。",
              "citation": {
                "source": "恩を返す話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ちに待った名人のすっと胸がすくような伝法句調が、はじめてズバリと言い放たれました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんのために、そう厳重にしてあるのだろうかと怪しみながら、二重三重の包紙をやぶって、やっと待ちに待った品物が、杉田二等水兵の眼の前に出てきた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼の焦躁がどうにも待ちきれなくなり、遂に一大爆発をしようとした午後九時になって、廊下に跫音も荒々しく、待ちに待った牧山大佐がひどく興奮した面持をして這入ってきた。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ちに待った敵機をついにとらえたからだ。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の暮れ方、税関の門がもう閉まろうという前、待ちに待ったレッド老人の声がやっと門の方から聞えた。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして待ちに待った第五番目のノートは、うまくとれた。",
              "citation": {
                "source": "暗号数字",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ちに待った其日ではあるけれど、今となっては如何やら一日位は延ばしても好いような心持になっている中に、支度はズンズン出来て、さて改まって父母と別れの杯の真似事をした時には、何だか急に胸が一杯になって不覚ホロリとした。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "この会話をきいた時、自分は待ちに待った機会が愈よ到来したことを知った。",
              "citation": {
                "source": "鼻に基く殺人",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをくぐって劇場の前へかたまった三十人ばかりの婦人たちは、何とかしてこの待ちに待ったわたしら「働く婦人の夕べ」を闘いとろう、警察へデモをやろう、と代表を選んで提議して来たほどです。",
              "citation": {
                "source": "日本プロレタリア文化連盟『働く婦人』を守れ！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ちに待った日がやって来て見ると、彼の足はその薔薇園の方へ向かないで、矢張長く住慣れた下宿のある町の方角へ向いた。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとは機会を待つだけのことだったが、いよいよ今夜は、待ちに待ったその夜だった。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく、待ちに待った調べ室の会話が、低音ながら聞えてきた。",
              "citation": {
                "source": "人間灰",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今に女から電話ぐらいかかるだろうと心待ちに待ったけれど、それもかからないで早くも一ヶ月経った。",
              "citation": {
                "source": "ふみたば",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、どんなことにも終りはあるもので、ようやく待ちに待った時が来た。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角お友達から来る手紙を待ちに待った様子で有りました。",
              "citation": {
                "source": "臨終まで",
                "author": "梶井久",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ちに待った大晦日が来た。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ちに待った日は来た。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "到頭母は、誰かの、待ちに待った外からのことづけを持って、わざわざこんな日に面会に来てくれたのか。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ちに待ったアメリカ地学協会のものらしい。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、彼女を見ている瞳は確かに待ちに待った瞳だった。",
              "citation": {
                "source": "馬の脚",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　待ちに待った幼年組は、日をつかむように両手をかざして、とびまわった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これがトウベツ」「そう、これがあの、待ちに待ったトウベツ」　そして、その奥ふかく――およそこの原野の中央と思われるオンコ樹のあたりに――彼女らの男たちは控えていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで行こうや」「えっ、そうするか」「こうなったら心臓だ、さあ、早く修理道具を集めて車にのっけてしまおう」　遂に待ちに待った小屋の扉が左右にひらかれた。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ちに待った報告であった。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　と決心し、わざと今度はソロソロと歩み、寄って来るのを心待ちに待った。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十五　此方は例の早四郎が待ちに待った今宵と、人の寝静るを窺うてお竹の座敷へやって参り、早「眠ったかね／＼、お客さん眠ったかえ……居ねえか……約束だから来ただ、※の中へ入っても宜いかえ入るよ、入っても宜いかえ」　と理不尽に※を捲って中へ入り。",
              "citation": {
                "source": "菊模様皿山奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕虜の高言　諸君、われ等のまちにまった潜水艦『富士』が、とうとうその姿を戦場へあらわした。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
