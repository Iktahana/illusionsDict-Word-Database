        "examples": {
          "standard": [
            {
              "text": "アクション映画の主人公が、巨大な44マグナムを構えて敵を威嚇した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "マグナム弾の威力は凄まじく、標的となった防弾ガラスは粉々に砕けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "射撃場で初めてマグナムを撃ったが、想像以上の反動に腕が痺れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "煙草は、マイミクスチユアか、スリーキヤツスルのマグナムに限る。",
              "citation": {
                "source": "著者小傳",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウエイター、リカビー氏に席を作れ、もう一本もってこい、いや、それじゃなくマグナム瓶を持ってこい。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
