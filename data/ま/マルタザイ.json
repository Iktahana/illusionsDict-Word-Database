        "examples": {
          "standard": [
            {
              "text": "「ログハウスの建築現場に、北欧から輸入された立派な丸太材が届いた」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この家具は丸太材の質感を活かしており、表面の凸凹が手に馴染む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "製材される前の丸太材が、貯木場の水面にいくつも浮かんでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "三四郎の住居は、丸太材を適度に配したヒュッテ風の小粋な住居で、同じように三軒並んだ右端の家であった。",
              "citation": {
                "source": "寒の夜晴れ",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸太材をならべた床に腰かけて湿った弁当をつかった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖になったその岸のうえに捲きあげられ、丸太材は横にならんで陽に照らされた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
