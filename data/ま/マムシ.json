[
  {
    "uuid": "244f6f6b-c9df-5cb3-8269-4e402f8e48c8",
    "entry": "蝮",
    "reading": {
      "primary": "マムシ",
      "alternatives": [
        "まむし",
        "はみ",
        "くちばみ",
        "たじひ"
      ],
      "is_heteronym": false
    },
    "grammar": {
