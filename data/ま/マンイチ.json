    "definitions": [
      {
        "index": 1,
        "gloss": "(unlikely event of) emergency",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "万一受けた親切の償却も簡易な方法で行なわれる。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨嫌いな私は、鰍沢で、万一の用心にと、買って置いた饅頭笠を冠り、紐の結び方で苦心をしているうちに、意地の悪い雨は、ひとまず切り上げてしまって、下界を覗く空の瞳がいまいましいまでに冷たい。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこの甚だ杜撰な比較が万一この方面の専門家の真面目な研究のヒントにでもならばと思って、思い付いたままを誌してみた次第である。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに万一にも眼界の狭い偏執的な学者でも出て来て、自分に興味のないような事項の観測の無用論を唱えたりするような場合には事柄はますます心細くなる。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何よりも先ず事実の方から確かめてかかる事が肝心であるから、万一読者の中でそういう現象を目撃した方があったらその観察についての示教を願いたいと思う次第である。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野方面の火事がこの辺まで焼けて来ようとは思われなかったが万一の場合の避難の心構えだけはした。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "万一わしが卒倒したら、天下は何と視るだらう、わしは単なる破〔廉恥〕のみか卑懦の称さへ受けねばならぬ〔。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "万一殺されないにしてももう縛られると私どもは覚悟しました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くかえらないと、万一誰かの右傾した球が落ちかかって来れば、この可愛い五つ生命の卵子は同時につぶされそうである。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "万一の誤りを教えてならないとなれば世界中の学校教員は悉皆辞職しなければならない。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "万一の危険を恐れれば地震国の日本などには住まわぬがよいというと一般なものである。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし万一将来の実験や観測の結果が、彼の現在の理論に多少でも不利なような事があったとしても、彼の物理学者としてのえらさにはそのために少しの疵もつかないだろうという事は、彼の仕事の筋道を一通りでも見て通った人の等しく承認しなければならない事であろう。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀕死を自覚した病人が万一なおったらという楽しみほど深刻な強烈な楽しみがこの世にまたとあろうとは思われない。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "古来数知れぬ刑死者の中にもおそらくは万一の助命の急使を夢想してこの激烈な楽しみの一瞬間を味わった人が少なくないであろう。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし万一の自然の災害か、あるいは人間の故障、例えば同盟罷業やなにかのために、電流の供給が中絶するような場合が起ったらどうだろうという気もした。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが万一｜僥倖に助かって孵化しても、親に似て性の悪い杜鵑の雛鳥に鋭い嘴で啄き出されてしまうという。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○万一余りましたら、協会と前進座で分けて下さい。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　なりひらが、Ｔ「その半分は俺の相棒に渡してな」　と言って、Ｔ「俺ァ八ッ時迄には帰るつもりだが」　と尚も、Ｔ「若し万一帰れ無かったその時は」Ｔ「その連判状を老中へ差し出せと」　えッ、とおどろく左衛門顔色なし。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一人｜留守番のときの用心に、いつものように入口に鍵をかけ、電燈を消して、蚊帳の中に這入り、万一｜忍び込むものがあるときの脅しに使う薄荷入りの水ピストルを枕元へ置いた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじような論理の錯誤から実際の刑事事件について無実の罪が成立する恐れが万一ありはしないか。",
              "citation": {
                "source": "ある探偵事件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてそれが万一不正でなくて何かの誤謬か過失から起った事であったら果してどうであろう。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし一日の善行で百日の悪行を償ってまだその上に釣銭をとるような心持が万一でもあってはかえって困る。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しいおもちゃを貰った子供が古い方を掃溜に投込んでしまうように、新しい学説の前にはすべての古いものがみんな駄目になったように思う人が万一あるとしたら、それはもちろん間違いである。",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは市ヶ谷の質屋に奉公している時から、近所のおみよと不図云い交すようになったが、女は武家の持ち物になっているので、万一それが露顕したらどんな祟りを受けるかも知れないという懸念から、二人は用心して、月に二、三度位ずつ雑司ヶ谷の茶屋でこっそり出逢っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "万一あの中間が口惜しまぎれに舌でも食い切ったらどうするか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "万一取り押さえられた場合に狂女を粧って巧みに逃がれようとする用心のためでもあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫れから第三次の侠客は、諸大名の中に何か一つ事が起ると人夫が必要になる、二本指の人間は使つて居ても之を雑役には使へぬし、又た俸禄の関係から云つても、平時用の無い時に万一を慮つて沢山の雇人を使つて置くといふことが出来ぬ。",
              "citation": {
                "source": "侠客の種類",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくも東欧の一部と極東日本との間に万一存在したかもしれないなんらかの古い関係の可能性という事までも、なんの考察もなしに否定せんとする人のあまりに多いのに驚いた。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも万一ことによると、これはアラビアの halq その他同系の語を通じて結局は西欧の gorge, throat, Hals などにもつながり、また一方たとえばベンガリの 〔gala_〕 などを通してかなり東洋にも広がっているのかもしれないと想像される。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう呪われた身の上の女が、あのような上品な奥様におつきあいすることは、奥様をけがし、そして奥様に、まんいち危難をかけるようなことがあってはたいへんである。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
