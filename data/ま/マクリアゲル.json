        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　親分は浴衣の裾をまくり上げると源吉を蹴った。",
              "citation": {
                "source": "人を殺す犬",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて大きく息をついて、静かに腕組みを解き、腕に垂れた衣をまくり上げる。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この玄関のなかでさえ、風が上衣のすそをそんなにもまくり上げるのだった。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "靴と弁当を振り分けにして肩にかけ、ズボンをまくり上げる。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人がくっつき合っている部面は、かれこれ四本の指をならべた位の広さに過ぎなかったから、この不完全な方の子供をまくり上げると、その下にもう一方の子供のおへそが見られた。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では、御免を蒙って、ちょっとのぞかせて頂きます」　再び丁寧にことわって、半七は桐油紙を着せてある駕籠の垂簾を少しまくりあげると、中には白い着物を着ている僧が乗っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "狐と僧",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたが、そうおっしゃるんでしたら、そうしますわ」　カバード・コートを脱いで、袖をまくりあげると、酢酸をたらし込んだ冷たい水で、せっせと黒江氏の咽喉を湿布しはじめた。",
              "citation": {
                "source": "キャラコさん",
                "author": "女の手",
                "note": "青空文庫"
              }
            },
            {
              "text": "和服の女が突然キモノを尻までまくりあげる踊りなど色々とあって、一番おしまいに猫八が現れる。",
              "citation": {
                "source": "日本文化私観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
