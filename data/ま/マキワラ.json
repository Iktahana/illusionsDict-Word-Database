    "definitions": [
      {
        "index": 1,
        "gloss": "straw post for training sword strikes, karate punches and arrow hits",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
