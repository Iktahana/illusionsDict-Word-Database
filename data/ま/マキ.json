[
  {
    "uuid": "c7ad9cb2-7e41-5a80-ae38-dae1a19047f6",
    "entry": "巻",
    "reading": {
      "primary": "まき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
