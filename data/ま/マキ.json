    },
    "definitions": [
      {
        "index": 1,
        "gloss": "roll (e.g. of cloth)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "此の我々の感性に近いもの、寧ろ民謡でさへある殉情詩が、此の殉情的な国で、今迄読まれなかつたなぞといふことは不思議だと、今度此の全集の第一巻が出た後では、諸君も必ずやさうお思ひになることと思ひます。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "稍々あつて男――もう今では夫、入口より葉巻を銜へ、長きマントの儘、如何にも寒い中を歩いて帰つて来た風である。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒヨツト葉巻を手に取り、マークをみてゐる）女の声　（ドアの辺りより）お帰りなつてるのね。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ポケットから葉巻を一握り出す）新輸入の葉巻を目ッけて来たのさ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "男、コーヒーを啜つて天井の隅を凝視したまゝ――右手の指に挟まれた葉巻から、冷い空気の中を薄紫の煙が細く細く立ちのぼる。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "所詮は、十一月の曇つた午後に、風が往来の砂塵を巻きあげてゐるやうなもんだと、僕の、心はともかく肉体は、左様に今はや観念してゐるやうな具合だ。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば安宅の関で弁慶が勧進帳とて読み上げる巻物の正体を、覗かれかゝると笑ふ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一巻の創作集の中から、作者の意図を、あやまたず摘出してくれる。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日劇を、ぐるりと取り巻いている入場者の長蛇の列を見ると、私は、ひどく重い気持になるのである。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "数十人の智慧ある先賢に手をとられ、ほとんど、いろはから教えたたかれて、そうして、どうやら一巻、わななくわななく取りまとめた。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "書房主山崎剛平氏は、私でさえ、ひそかに舌を巻いて驚いたほどの、ずぶの夢想家でありました。",
              "citation": {
                "source": "砂子屋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――恰度百姓娘の、赤いネルの腰巻を思はせるやうな夏の日の夕飯仕度の頃の中でされるには余りに相応しいそれらの話声や物音であつた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ン坊の泣声や、おひきずりの靴の音や、昆布や烏賊や洟紙や首巻や、みんなみんな、街頭沿ひの電線の方へ荷馬車の音も耳に入らずに、舞ひり吁！",
              "citation": {
                "source": "暗い天候",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおこの「侘び」について、巻尾に詳しく説くであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "主婦は時々鉢巻をして髪を乱して、いかにも苦しそうに洗濯などしている事がある。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいていの店は早く仕舞って、寂れた町に渦巻き立つ砂ほこりの中を小きざみに行く後姿が非常に心細げに見えた。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高く釣った蚊屋の中にしょんぼり坐っているのは年とった主婦で、乱れた髪に鉢巻をして重い病苦に悩むらしい。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい新聞紙の包を大事そうにかかえて電車を下りると立止って何かまごまごしていたが、薄汚い襟巻で丁寧に頸から顋を包んでしまうと歩き出した。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹村君は前屈みになって硝子箱の中に並べたまじょりか皿をあれかこれかと物色しているが、頭の上の瓦斯の光は薄汚い鼠色の襟巻を隠す所もなく照らしている。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "木枯しが森川町の方から大学の前を渦巻いて来る度に、店ごとの瓦斯燈が寒そうに溜息をする。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも背広の片腕に黒い喪章を巻いていたような気がする。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "若くて禿頭の大坊主で、いつも大きな葉巻を銜えて呑気そうに反りかえって黙っていたのはプリングスハイムであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人雑誌の巻頭挿画らしい色刷の絵が一枚貼ってある。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室津の宿屋の主人はかなりのお婆さんであったが、われわれ二人の中学生の初旅を珍しがって大変にもてなしてくれた上に「珍しいものを見せて上げよう」と云って持出して来たのが一巻の絵巻物であった。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この鯨絵巻の写しや、硯石で昔から知られた行当岬のスケッチや、祖先の出身だという一世一海和尚の墓の絵などが郷里の家に保存してあったはずであるが、いつの前にかもう無くなってしまったか、それともまだ倉の中のどこかに隠れているか不明である。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この鯨の絵巻物はおそらく昔の御鯨方に伝わった最貴重な伝書のようなものではなかったかと思う。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "重兵衛さんの晩酌の膳を取巻いて、その巧妙なお伽噺を傾聴する聴衆の中には時々幼い自分も交じっていた。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の日がかんかん照りつけるので柿の葉が乾燥してじりじりと巻き上がるのでいつの間にかそっくりと雀を包んで動けないように縛ってしまう。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにか知らねど萩原朔太郎なにか知らねど泣きたさにわれはゆくゆく汽車の窓はるばるときやべつ畑に日は光り風見ぐるまきりやきりりとめぐる日にわれはゆくゆく汽車の窓なにか知らねど泣きたさに",
              "citation": {
                "source": "なにか知らねど",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "厳かな入学宣誓式が行われて、自分も大勢の新入生の中にまき込まれて大講堂へ這入ったが、様子が分らないのでまごまごしていると、中に一人物馴れた日本人が居ていろいろ注意してくれて助かった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
