    "definitions": [
      {
        "index": 1,
        "gloss": "official price",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――富田の丸公」「へえ」「へえとはなんじゃい。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "えりにえって小次と丸公とが生き残るとはなんのことじゃい。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸公、手伝え」　おもちゃをでも、いじくり廻すように足を引き出して、こびりついている血と泥を、ごしごしとむしりとった。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いけっ、いけっ、丸公、別室があろう。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸公が値上げになったために一般家計が窮迫しはじめたのも昨年中のことです。",
              "citation": {
                "source": "“生れた権利”をうばうな",
                "author": "――寿産院事件について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが十一月には、あがった丸公につれてヤミまであがって、ヤミ買を拒絶した山口判事の死がつたえられた。",
              "citation": {
                "source": "ほうき一本",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家計の苦しさは、千八百円ベースがあるのに丸公がずっと上昇したところにある。",
              "citation": {
                "source": "ほうき一本",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸公の配給を円滑にして千八百円ベースでやってゆけば十一月には黒字が出る、という理論数字が政府からあんなにくりかえし示された。",
              "citation": {
                "source": "ほうき一本",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、配給はそれで食べてゆかれないことはこれまでどおりで、丸公があがった。",
              "citation": {
                "source": "ほうき一本",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸公があがったから一般の生活は益々窮地においこまれているのに、和田氏の家庭では、家計が二〇％改善しでもしたのだろうか。",
              "citation": {
                "source": "ほうき一本",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸公値上げについては、都留副長官が、女性改造という婦人雑誌の対談会で、民報の森沢氏からつっこまれて大汗に陳弁している。",
              "citation": {
                "source": "ほうき一本",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "和田長官はこのメモの中では、まるでそういう事実は勤労者家計に関係ないことででもあるように丸公値上げのことはよけて通ってしまっている。",
              "citation": {
                "source": "ほうき一本",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸公でこれらは買えない。",
              "citation": {
                "source": "ほうき一本",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ、十五年前なら八十五円に当る千八百円ベースというもので、とどめをさされた収入なのに、物価は丸公の値上りで、あがる一方の一年でした。",
              "citation": {
                "source": "今年こそは",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "市ケ谷から飯田橋へと続く堀端、靖国神社、そして武道館を取り巻く北の丸公園と、あたりは桜の名所である。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "工賃を米でくれというので、それじゃ、どっちも丸公にしょうというたばかりじゃ。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
