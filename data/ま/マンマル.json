        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "十四日の大きい月はなかぞらに真ん丸く浮き上がって、その影をひたしている大川の波は銀を溶かしたように白くかがやきながら流れていた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ふと見ると彼の真ん丸に視張って僕の顔を眼ばたきもしないで見詰めている眼眥から、忽ちコロコロと球のような涙が滾び出て、と突然彼はワッと声を挙げて僕を抱き締めた。",
              "citation": {
                "source": "吊籠と月光と",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」頼宣の下知に五十人、頼宣とお京を真ん丸に包み、たいまつで道を振り照らし、頂上さして押しのぼった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "曽根下野守の屋敷の方から、真ん丸に塊った一団が、柳町通りの方へ押し出して来た。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "真ん丸なお月さまが、野にも山にも一｜面に照っていました。",
              "citation": {
                "source": "姨捨山",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その背中が真ん丸いので、あたしは拳骨でコツコツ叩いた。",
              "citation": {
                "source": "朝散太夫の末裔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "チンチリチンテン、チリリンチンテンと響くこの真ん丸い楽器がひどく面白かったが、練習にゆくところが勝川のおばさんであろうとは随分長くしらなかった。",
              "citation": {
                "source": "勝川花菊の一生",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏森の辻まで行った時だ、真ん丸に塊まった一団の人数が、むこうからこっちへ走って来た。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ははあ」と感付いた小一郎は、いそいで家へ帰って見ると、家内は乱暴狼藉を極め、君江がその眼を真ん丸にし、こんな事を云って説明した。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウオーッという群衆の吠え声が、その瞬間ひときわ高くなり、ムラムラと三人の犠牲者を、おっとり囲んだと見る間もなく、その一団は真ん丸となり、中へ三人の犠牲者を囲み、真ん丸のままで雑草の原を、一軒の廃屋の背後の方へ、一直線に縦断し出した。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見れば盆地の一所に、弓、鉄砲を持った十五、六人の武士が、冬次郎他五人のものを、中へ取りこめ真ん丸に包み、鏃を向け銃口を差しつけていた。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそれ旗本にかかろうなら、すわやと全軍真ん丸になり、揉みに揉んで揉みつぶす、島津の兵法｜猗廈の懸かり、新納武蔵が発明し、豊臣殿下を驚ろかせた、死中活ある戦術じゃ！",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二挺のトヤ駕籠を真ん丸に包み、伊集院の一団走り出したが、この頃七ツ寺の火事場を遁がれ、浅間の社地の方角へ、走って行く三人の女があった。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポンと上がった駕籠二挺、そいつを真ん丸に引っ包み、烏組の連中走って行く。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨大ポスターは形が真ん丸、色は真っ黒で、白い縁取りがある。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの月の影法師は、まんまるより少し缺けてゐますから、けふは十三夜かな？",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とそのお人形さんみたいな可愛い女の子が、お爺さんの前にお行儀よく坐り、まんまるい眼をぱちくりさせて答へる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むくむくした毛皮の外套を豪猪のようにまんまるくなるまで着こまなければならない。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "園子のおなかは、ぶんまわしで画いたようにまんまるで、ゴム鞠のように白く柔く、この中に小さい胃だの腸だのが、本当にちゃんとそなわっているのかしらと不思議な気さえする。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニのうしろには、いつから乗っていたのか、せいの高い、黒いかつぎをしたカトリックふうの尼さんが、まんまるな緑の瞳を、じっとまっすぐに落として、まだ何かことばか声かが、そっちから伝わって来るのを、虔んで聞いているというように見えました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云いながらまるで兎のようにせ中をまんまるにして走っている列車の下へもぐり込みました。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山男はまんまるになって一生けん命｜遁げました。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつきさんおつきさん　まんまるまるるるん　おほしさんおほしさん　ぴかりぴりるるん　かしわはかんかの　　　かんからからららん　ふくろはのろづき　　　おっほほほほほほん。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、まんまる大将のお日さんと一しょに、パチンと割られるよ。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでベゴ石も、しづかに、まんまる大将の、お日さまと青ぞらとを見あげました。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはからだの中に泥や水がたまって、無暗にふくれる病気で、しまいには中に野原や山ができて狸のからだは地球儀のようにまんまるになりました。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでベゴ石も、しずかに、まんまる大将の、お日さまと青ぞらとを見あげました。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山男はまんまるになつて一生けん命｜遁げました。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつきさんおつきさん　まんまるまるゝゝん　おほしさんおほしさん　ぴかりぴりるゝん　かしははかんかの　　　かんからからゝゝん　ふくろはのろづき　　　おつほゝゝゝゝゝん。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとちの実ぐらいあるまんまるの玉で、中では赤い火がちらちら燃えているのです。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
