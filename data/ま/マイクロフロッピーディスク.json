        "examples": {
          "standard": [
            {
              "text": "古いソフトウェアは、まだマイクロフロッピーディスクで配布されていた時代があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "データのバックアップのために、いくつかのマイクロフロッピーディスクを用意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このソフト、インストールにマイクロフロッピーディスクが3枚必要だよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "これに対しソニーは、サイズを三・五インチといっそう小型化したうえで、プラスチックのケースに収めたマイクロフロッピーディスクを開発し、これを新しい標準に押し上げようと狙っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "最終的に採用されることになったソニー製の三・五インチ、マイクロフロッピーディスクの代わりに、五インチのドライブを一体型の筺体に内蔵したマッキントッシュの試作機に、西自身もこの時点で触っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
