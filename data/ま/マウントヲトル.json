        "examples": {
          "standard": [
            {
              "text": "ドッグランで、うちの犬が他の犬にマウントを取ろうとして、慌てて止めに入った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "発情期の猫は、時にぬいぐるみに対してマウントを取る行動を見せることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "獣医さんは、犬がマウントを取る行動は支配欲だけでなく、ストレスが原因である場合もあると説明してくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
