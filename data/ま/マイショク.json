  {
    "uuid": "f525f455-742f-52af-8f68-d85ffb2ca3d1",
    "entry": "毎食",
    "reading": {
      "primary": "まいしょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
