        "examples": {
          "standard": [
            {
              "text": "上り坂を自転車で進むには、地面からの摩擦力が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "摩擦力が強すぎると、動きが鈍くなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "科学の授業で、様々な物体間の摩擦力を測定する実験を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "これは星と地球の海水との間のすごい摩擦力でそうなったものであろう。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、「その子供の種類にも依るし、彼女の電気性に摩擦力を与えるもののみが危険であるようだ。",
              "citation": {
                "source": "幻影の都市",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
