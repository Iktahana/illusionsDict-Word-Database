    "definitions": [
      {
        "index": 1,
        "gloss": "Mary (mother of Jesus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "後年、伊太利フローレンスで「花のサンタマリア寺」を見た。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人としての自分にはベラスケズのインファンタ、マリア、マルゲリタよりもこの方がいい。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こん度｜私共の方で出すようになりました、あの家常茶飯の作者のライネル・マリア・リルケというのは、あれは余り評判を聞かない人のようですが、一体どんな人ですか。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "「或る夜、ライネル・マリア・リルケは若いころ――たしか十九か二十のころ――書いた『旗手』の話を私にしてくれました。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ごらんなさい、公爵夫人』とライネル・マリア・リルケは、開いた窓のはうへ私と一しよに近づきながら、言ひつづけました。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "……』　そしてそのとき、とライネル・マリア・リルケは、彼の顏ぢゆうを明るくさせる子供らしい微笑をうかべながら、言ひをへました。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はライネル・マリア・リルケが、この微妙な作品を何遍も朗讀するのを聞きました。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "――」「マリア樣があなたをお護りになるやうに。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "頓首貴方のライネル　マリア　リルケ＊　「La Plume」（美術雜誌）は一九〇〇年にロダン號を出した。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはライナア・マリア・リルケがモオリス・ド・ゲランの「サントオル」を譯したとき（一九一一年）その卷末に附せられた註（Anmerkung）である。",
              "citation": {
                "source": "モオリス・ド・ゲラン",
                "author": "「そしてこの稀有で、偉大で、しかも果敢ないもの、一個の詩人」",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方のライネル・マリア・リルケ",
              "citation": {
                "source": "リルケ書翰（ロダン宛）",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アオイ・ホテル」のお六の亭主が東京郊外で令嬢殺しの疑いで拘引され、娼家街のマリアとしてお六のコケットな写真が新聞の三面を賑した事件。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄關の廣間にはマリアの像が立つてゐた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば日本の「アソ」、「ウス」、「オソレ」、「エサン」、「ウンセン」等に対してカムチャツカの「ウソン」、マリアナ群島の「アソンソン」、スマトラの「オサール」などがあり、またわが国の「ツルミ岳」、「タルマイ山」、「ダルマ山」に対しジャヴァの「ティエリマイ」、「デラメン」などがあるという類である。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私と並んで、マリアナ・ミハイロウナが歩いている。",
              "citation": {
                "source": "秋の歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がＧの絃で話せば、マリアナはＥの絃で答える。",
              "citation": {
                "source": "秋の歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マリアナの姿はもう見えない。",
              "citation": {
                "source": "秋の歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "サンタマリア」と斯うひとりごとしたそうだ。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩、象は象小屋で、七｜把の藁をたべながら、空の五日の月を見て「ああ、つかれたな、うれしいな、サンタマリア」と斯う言った。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある晩、象は象小屋で、ふらふら倒れて地べたに座り、藁もたべずに、十一日の月を見て、「もう、さようなら、サンタマリア。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでその次に出て来たユダヤでも第一等の美男子のイエスという男優と、ユダヤ第一の美しい女優のマリアというのを取組ませて、この宣伝を街頭でやらせてみたらコイツが大々的に大当りを取ることになった。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは「アンヴィルコーラス」をやれとか、カルソーの「アヴェマリア」をやれとかいろいろの注文を持ち出すようになった。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき英国の美術館にある名画の写真をいろいろ見せられて、その中ですきなのを二三枚取れと言われたので、レイノルズの女の子の絵やムリリョのマグダレナのマリアなどをもらった。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マリーの母、澳太利の名皇后、マリア・テレザは心配した。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度あの切支丹等が、彼等のマリア観音を壁に隠して、秘密に信仰をつづけたように、我々の虐たげられた詩人たちも、同じくその芸術を守るために、秘密な信仰をつづけねばならなかった。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「聖母マリアがもし現代に生れていたら」とカジノ・ド・パリの興行主は言った。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中背の撫で肩の上にラファエルのマリア像のような線の首筋をたて、首から続く浄らかな顎の線を細い唇が締めくくり、その唇が少し前へ突き出している。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
