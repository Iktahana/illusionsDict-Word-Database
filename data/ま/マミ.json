  {
    "uuid": "83b9a211-ace4-54f0-94f1-5994c0fe01ef",
    "entry": "目見",
    "reading": {
      "primary": "まみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "look",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "梅津の君も今は物もいはで彳めるを、玉枝の君と妾とは目見合せてをり、さすがに恐しからぬにもあらず。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "横山先生のところへ連れて行くと、先生は一目見ただけで、これはじきに直る、毎日上白米を何合ずつ焚いて喰わせろと云った。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、山には一目見ただけでも傲慢であったり、独りよがりのお人好しであったりしそうな性格に見立てられるものがある。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は、さうした女の気持ちの反映を直ぐに直覚しました、と同時に三年前の自分の記憶に残つて居た女とは似もつかぬ、やつれて老いた女の俤を一目見て、あらゆる歓喜と期待の心が打ち破られました。",
              "citation": {
                "source": "恋愛といふもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一目見ただけで妙な気がした。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お富はお秀の様子を一目見て、もう殆ど怪しい疑惑は晴れたが、更らに其室のうちの有様を見てすっかり解かった。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はしばし目と目見あわして立ちぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "（おらにもああいう若ぃづぎあったんだがな、ああいう面白い目見る暇なぃがったもな。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さあ先生なら一目見て、何百目まで云うんだが、おれたちじゃちょっとわからない。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死体を一目見て、　「アッ」　と叫んだ。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　汽車が通じてから、はじめて帰ったので、停車場を出た所の、故郷は、と一目見ると、石を置いた屋根より、赤く塗った柱より、先ずその山を見て、暫時茫然として彳んだのは、つい二、三日前の事であった。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何為か、その上、幼い記憶に怨恨があるような心持が、一目見ると直ぐにむらむらと起ったから――この時黄色い、でっぷりした眉のない顔を上げて、じろりと額で見上げたのを、織次は屹と唯一目。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一目見て、幼い織次はこの現世にない姿を見ながら、驚きもせず、しかし、とぼんとして小さく立った。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "李花は猛獣に手を取られ、毒蛇に膚を絡われて、恐怖の念もあらざるまで、遊魂半ば天に朝して、夢現の境にさまよいながらも、神崎を一目見るより、やせたる頬をさとあかめつ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "海野と軍夫と、軍夫と、軍夫と、軍夫と、軍夫の隙より、真白く細き手の指の、のびつ、屈みつ、洩れたるを、わずかに一目見たるのみ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一目見れば満足して次の店に移って行かれる。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の使ういろいろな器具器械でも一目見てなんとなくいい格好をしたものはたいてい使ってぐあいがよい。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一目見て死ぬほど惚れて、二度目には顔を見るさえいやになる、そんな情熱こそはほんとうに高雅な情熱だって書かれていたわねえ。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一目見て、「蛇だ。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にせいお初のお目見得じゃけに松倉どんがドレ位の御人物やらコッチもさっぱり見当が付かぬ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンと申すと……」「たとえば名人のお医者が、小便の色を見て病人の寿命を言い当てるようなもので、私どもは掃溜の色をタッタ一目見ますると、その家の奥の奥の暮し向きまで包み隠しのないところが、ハッキリとわかりまする」「うむ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直者の父は一目見るなり、ただもう震え上ってしまいまして……」　半三郎は無類の親思いらしく、父親と同じ程度に震え上がっているらしかった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その犬は狸のようなつまらない汚い犬でしたが、いよいよお祝いの当日になりますと、金襴の着物を着て王様のお椅子に着いて、大勢の家来や人民にお目見得をさせる事になりました。",
              "citation": {
                "source": "犬の王様",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お目見得に来た人民の中に一人の婆さんがいて、一匹の三毛猫を抱いて犬の王様の前に出てお辞儀をしました。",
              "citation": {
                "source": "犬の王様",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は三十五六の若紳士、女は庇髪の二十二三としか見えざる若づくり、大友は一目見て非常に驚いた。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と叔父さんは鹿を一目見て叫んだ。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "否、君のみにあらず、われは一目見しかの旗亭の娘の君によく肖たると、老い先なき水車場の翁とまた牛乳屋の童と問わず、みなわれに永久の別れあるものぞとは思い忍ぶあたわず。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくたちはポチを一目見ておどろいてしまった。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには笹竹や芹などの雑草が生え、塵芥にまみれて捨てられてる、我楽多の瀬戸物などの破片の上に、晩春の日だまりが力なく漂っているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅員の不機嫌顔甚だしきも官線はやはり官線だけの権力とか云うものあるべしと、かしこみて願い奉りようよう切符を頂戴して立ちいずれば吹き上ぐる朝嵐に藁帽飛んでぬかるみを走る事｜数間、ようやく追い付きて取止めたれど泥にまみれてあまり立派ならぬ帽の更に見ばえを落したる重ね／＼の失敗なり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
