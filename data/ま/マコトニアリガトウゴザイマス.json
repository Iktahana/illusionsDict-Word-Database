        "examples": {
          "standard": [
            {
              "text": "「多大なるご支援をいただき、誠にありがとうございます。心より感謝いたします」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「本日はお忙しい中、私たちの結婚披露宴にご出席賜り誠にありがとうございます」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「皆様から貴重なご意見を多数頂戴し、誠にありがとうございます」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「誠にありがとうございます。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝石を返却して戴いて、誠にありがとうございます。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日はかめのいのちをお助けくださいまして、まことにありがとうございます。",
              "citation": {
                "source": "浦島太郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことにありがとうございます。",
              "citation": {
                "source": "海からきた使い",
