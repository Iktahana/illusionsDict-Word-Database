          "literary": [
            {
              "text": "図395は真鯵と鰓蓋と鰭とを示し、図396は別の魚の切りようで、串をさし込んで切口を引きはなす。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあじゃないじゃありませんか。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあだいじょうぶだろうよ」　「まあじゃ困るわ。",
              "citation": {
                "source": "手紙",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあだいじょうぶだろうよ」「まあじゃ困るわ。",
              "citation": {
                "source": "手紙",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあじっと辛抱して待つより他はないねえ」　私はこう言って慰めるより他はありませんでした。",
              "citation": {
                "source": "塵埃は語る",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、まあじやありません。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ云って見て下さい」「まあじゃいけません。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さア……」「つや子さんの気がすむ方にしましょうよ、ね」「……………」「こんどは、御苦労でも、ひろ子はんに行んで貰おう、いくらかしゃんとした話もせまあじゃ、のう、つや子はん」「はア、それがよろしうあります」　相談がきまった。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こりゃ早う避難せまあじゃ、家がこけよる」「そんなこともなかろうけれど……」　上から何か大きいものが流れて来たら、この家はもつまい。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあじゅんとうに申しますれば三法師ぎみが御嫡流でいらっしゃいますけれども、御幼少のことでござりますから、いまのばあいは北畠どのをおあとへすえようと仰っしゃる方々もござりますし、そんなことで何や彼やとむずかしくなったのでござりましょう。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
