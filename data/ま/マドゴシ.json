    "definitions": [
      {
        "index": 1,
        "gloss": "viewing through a window",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "廊下から中央階段を降りようとする途中で窓越しに東を見ると、地下鉄ビルの照明が見える。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西日が窓越しに看護婦の白衣と車の上のニッケルに直射する。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "食堂のガラス窓越しに見える水辺の芝生に大名行列の一団が弁当をつかっているのが見える。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車の窓越しに人の頸筋を撫でる小春の日光のようにうららかであったのである。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルの一室で人が対話していると、窓越しに見える遠見の屋上でアラビア人のアルラーにささげる祈りの歌が聞こえる。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓越しに見えるエスカレーターには、下から下からといろいろの人形がせり上がっては天井のほうに消えて行った。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「烏賊」ホテルの酒場のガラス窓越しに、話す男女の口の動きだけを見せるところは、「パリの屋根の下」の一場面を思いだす。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途中で、車の前面の幌にはまったセルロイドの窓越しに見る街路の灯が、妙にぼやけた星形に見え、それが不思議に物狂わしくおどり狂うように思われたのであった。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな硝子窓越しには遠くに雨雲のよどんだ夏の無月の空が、潤みを持つた紺碧の色に果てもなく擴がつてゐた。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまには、人に縋りつきたい切ない限りの様子も窓越しに見えました。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに一かたげ眠ったお米はクサメを二ツ三ツして眼を醒ましたが、高い天窓越しに、薄暗く曇って来た空を見ると、慌てて子守のお千代を揺り起した。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓越しにマロニエの街路樹の影が、銀灰色の暁の街の空気から徐々に浮き出して来た。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の多少当が外れた気持ちが、私がこの家へ出入のときに眼に映る店先での娘の姿や、窓越しに見る艀板の上の娘の姿にだんだん凝って行くのであった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、息を入れながら、明滅する京都の町の燈灯を窓越しにぼんやり眺めてゐた。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねるまへに、部屋のカーテンをそつとあけて硝子窓越しに富士を見る。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご婦人方がこの男と別れたあとも距離をとって尾けられていたのは明白であるし、そしてその男は窓越しに夫妻の口論を見たこと、なかへ飛び込み、さらに箱で運んできた生き物が逃げ出たこと、これはみな確かも確か、それでいてその部屋で起こったことを正確に教えられるのは、世界でこの男だたひとり。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "わかっております、あなたはそのあと彼女を家までおつけになって、窓越しに夫妻の口論をご覧に。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓越しに見ると、老婆は向かいの通りをとろとろと歩いている。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓越しにうかがうと、齢は中年、砂色の髪をした体格のよい男がこっちに向かっていたので、心臓が飛び出そうになった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "その先を追いかけると、どうも窓越しに雫落ちるわびしい庭を見ているとしか思えない。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝子窓越しにチラチラ光る綿雪を見遣りながら……。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "真っ蒼に澄み切った、まだ秋らしい空の色がヴェランダの硝子戸を青玉のように染めたのが、窓越しに少し翳んで見えている。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さうですね、それはさうですけれど……」　と、苦もなく言つて、茫然窓越しに向うの空を眺めて居る。",
              "citation": {
                "source": "一家",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "倒れると窓越しの大空が廣々と眺めらるる。",
              "citation": {
                "source": "一家",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　今日訪ねて来た医者のＭ氏は、応接室の窓越しに菜園の高棚にぶら下っている糸瓜を見つけて、さも感心したようにいった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "開け放った応接室の窓越しに、ちらと畑の方へ眼をやりながら言った。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが私の談話に対するうけ答えでないのはいうまでもないこと、どうかすると、私の存在をも忘れさせるような、眼に見えない第三者が窓越しに立っていて、それに対する挨拶とも見えるようで、何だかちょっと不気味だった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　Ｂ夫人はこう言って、ふと窓越しに外へ眼をやったが、糸瓜棚にだらりとぶら下った長糸瓜を見ると、思わず声を高めた。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、皿のなかの油揚が急に立ちあがり、窓越しに外へ飛び出して、そのまま姿を隠してしまいました。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "バルコニーから窓越しに教室内をねらっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
