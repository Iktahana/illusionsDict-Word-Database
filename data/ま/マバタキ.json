    "definitions": [
      {
        "index": 1,
        "gloss": "blink (of eyes)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
