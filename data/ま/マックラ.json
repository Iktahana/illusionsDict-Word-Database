        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "真っ暗いところに、こっそり坐って、誰にも顔を見られない。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よっぽど大きいらしいから跳ねられねえように気をつけねえよと、おれも傍から声をかけたが、なにしろ真っ暗だから見当が付かねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょせん手の着けようもねえので、おれも途方に暮れてしまったが、それでも川下の方へ流されて行くうちには、どこかの岸へ泳ぎ付くことがあるかも知れねえと、暗い堤下を探るようにして、どんどんの堰の落ち口まで行ってみたが、真っ暗な中で水の音がどんどときこえるばかりで、為さんの上がって来る様子はねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "案の通り、娘は先に帰っているものと思って、格子をあけてはいると内は昼でも真っ暗であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "月のない夜で、真っ暗な木立のあいだに螢のかげが二つ三つ流れていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "銭湯へ行く時には、道も明るかったのに、帰る時には、もう真っ暗だった。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お角さんも余一郎さんもそれぞれ帰って来ないので、他の人達も不思議に思って、二、三人がばらばらと起って表と裏へ出てみると、外は一寸さきも見えないような真っ暗闇で、そこらに人のいるような気配もないのです。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいてい見当は付いたかね」「おさき真っ暗で眼も鼻も利きません」と、半七は笑った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ真っ暗闇ですからね」「井戸へ飛び込んだのは誰なんです」「飛び込んだのじゃあない、投げ込んだのですよ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと家並みは続いていたが、停電のせいだろう、門燈は消えて、洩れて来る一筋の灯りもなく、真っ暗闇だった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼間の場所は夜になると、真っ暗になるので商売も出来ない。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそろしく泡立っている真っ暗な海面。",
              "citation": {
                "source": "氷れる花嫁",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソウスルトネ……電燈が消えて真っ暗になっているの。",
              "citation": {
                "source": "人の顔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "春夫さんは、この支那人が美代子さんを誘拐しているのじゃないのか知らんと思って、あたりを見まわしましたが、念のため横にある黒い箱にのぼって、その上にある小窓からガラス越しに中をのぞいて見ると、中は真っ暗で何も見えません。",
              "citation": {
                "source": "クチマネ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくれんぼのとき、押入れの真っ暗い中に、じっと、しゃがんで隠れていて、突然、でこちゃんに、がらっと襖をあけられ、日の光がどっと来て、でこちゃんに、「見つけた！",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "真っ暗がりの田舎道を、提灯つけて岸和田までひいて行った。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼先が真っ暗になったような気持の中で、ただ一筋、交番へ届けるという希望があった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "真っ暗になった気持の中で、たった一筋、「あッ、凄いデマを飛ばしたな」　という想いが私を救った。",
              "citation": {
                "source": "四月馬鹿",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛙が真っ暗な鳴声を立てている。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何で周囲に当り散らすのかわからぬ立腹が、たちまち私の眼先を真っ暗にしてしまう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲板さん出て見たっちゃ、真っ暗闇で、歩けもせん。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓からさしているかと思って、窓を見れば、窓は真っ暗だ。",
              "citation": {
                "source": "鼠坂",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて提灯だけはうまく保護して行こうと思ったのであるが、それも五、六間あるくうちに吹き消されてしまったので、彼は真っ暗な風雨のなかを北へ北へと急いで行った。",
              "citation": {
                "source": "異妖編",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は真っ暗で星ひとつ見えないと言った。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして明治十九年、僕がまだ十五六の少年時代は、山の手も場末のさびしい町で、人家の九分通りは江戸の遺物というありさまだから、昼でもなんだか薄暗いような、まして日が暮れるとどこもかしこも真っ暗で、女子供の往来はすこし気味が悪いくらいであった。",
              "citation": {
                "source": "月の夜がたり",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっくらな草や、いろいろな形に見えるやぶのしげみの間を、その小さなみちが、一すじ白く星あかりに照らしだされてあったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまっくらな島のまん中に高い高いやぐらが一つ組まれてその上に一人の寛い服を着て赤い帽子をかぶった男が立ってゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると空中にざあっと雨のやうな音がして何かまっくらなものがいくかたまりもいくかたまりも鉄砲丸のやうに川の向ふの方へ飛んで行くのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の川の一とこに大きなまっくらな孔がどほんとあいてゐるのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうそこらが一ぺんにまっくらになったやうに思ひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
