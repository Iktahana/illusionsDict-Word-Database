    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gusset",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その高い襠で擦れた内股にひびが切れて、風呂に入るとこれにひどくしみて痛むのもつらかった。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おらあ別に人の褌襠で相撲を取るにもあたらねえが、これが若いものでもあることか、かわいそうによぼよぼの爺さんだ。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　客は火鉢に手を翳し、「どの店にも大きな人形を飾ってあるじゃないか、赤い裲襠を着た姐様もあれば、向う顱巻をした道化もあるし、牛若もあれば、弥次郎兵衛もある。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……黒の絽縮緬の裾に、不知火のちら／＼と燃えるのに……水淺葱の麻の葉の襟の掛つた裲襠だとさ。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だつけ、その裲襠を屏風へ掛けて、白い切の潰島田なのが……いや、大丈夫――惜しいかな、これが心中をしたのでも、殺されたのでも、斬られたのでもない。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯人の頭も、顔も、黒く塗りて、肩より胸、背、下腹のあたりまで、墨もていやが上に濃く塗りこくり、赤褌襠着けたる臀、脛、足、踵、これをば朱を以て真赤に色染めたるおなじ扮装の壮佼たち、幾百人か。",
              "citation": {
                "source": "凱旋祭",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議にこゝで逢ひました――面影は、黒髮に笄して、雪の裲襠した貴夫人のやうに遙に思つたのとは全然違ひました。",
              "citation": {
                "source": "雪靈記事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀姫、振袖、裲襠、文金の高髷、扇子を手にす。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "惟れば嘴の尖った白面の狐が、古蓑を裲襠で、尻尾の褄を取って顕れそう。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議にここで逢いました――面影は、黒髪に笄して、雪の裲襠した貴夫人のように遥に思ったのとは全然違いました。",
              "citation": {
                "source": "雪霊記事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "金襴、刺繍の帯、裲襠、眼も眩ゆく、白く小さき素足痛々しげに荒莚を踏みて、真鍮の木履に似たる踏絵の一列に近付き来りしが、小さき唇をそと噛みしめて其の前に立佇まり、四方より輝やき集まる人々の眼を見まはし、恐ろし気に身を震はして心を取直し居る体なり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そを懸命に踏み堪へて、左褄高々と紮げ、脛白き右足を擡げて、踏絵の面に乗せむとせし一刹那、「エイツ……」　と一声、足軽の棒に遮り止められ、瞬く間に裲襠を剥ぎ取られて高手小手に縄をかけられつ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "綴錦の裲襠に銀の六花の摺箔。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "見返りもせずに、裲襠の背中をクルリと見せながら、シャナリシャナリと人垣の間を遠ざかって行った。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同年の男は急いで南村の寇家へ往って、祝が水莽草を飲まされたわけを話して、三娘の襠をもらいたいと言ったが、寇の方ではそれによって女が生れ代ることができると思ったのでくれなかった。",
              "citation": {
                "source": "水莽草",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの、幻の道具屋の、綺麗な婦のようでもあったし、裲襠姿振袖の額の押絵の一体のようにも思う。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "面小手で竹刀を引担いでお前、稽古着に、小倉の襠高か何かで、朴の木歯を引摺って、ここの内へ通っちゃ、引けると仲之町を縦横十文字に鳴して歩いた。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬は、ふらふらとなって切戸口から引入れられると、もう奥庭で、階段のついた高縁の、そこが書院で、向った襖がするすると左右へ開くと、下げ髪にして裲襠を捌いた、年三十ばかりの奥方らしいのに、腰元大勢、ずらりとついて、「待ちかねました。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その裲襠、帯、小袖の綾、錦。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "太夫が客の前へ坐つて裲襠をすつと脱ぐ處は風情のあるものだと河井さんはいつた。",
              "citation": {
                "source": "菜の花",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "前で結んで兩方へ張つた錦襴の大きな帶と、刺繍の裲襠とが目を射る。",
              "citation": {
                "source": "菜の花",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "帶も裲襠も眩きばかりの錦襴である。",
              "citation": {
                "source": "菜の花",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺にはまた高尾の襠裲の殘片と稱するものをも藏す。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おお、渋川様の御乗物か」　喧嘩のまん中へ邪魔な物を投げ出されて、町奴の群れも少し躊躇していると、乗物の引戸はするりと明いて、五十を越えたらしい裲襠姿の老女があらわれた。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "所詮頭はあがらぬものと諦めているらしく彼は伯母の前におとなしく降伏していると、真弓の裲襠姿はやがて再び乗物に隠されて、生肝でも取られたようにぼんやりしている奴どもを後に、麹町の方へしずかにその乗物を舁せて行った。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "金糸で大きい鰕を刺繍にした縹色繻子の厚い裲襠は、痩せてすらりとした彼女の身体にうつりがよかった。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は前と違って、吉原の花魁の裲襠を見るような派手なけばけばしい扮装で、真っ紅な友禅模様の長い裾が暑苦しそうに彼女の白い脛にからみついた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が、いま考えている事を、そのまま率直に述べたら、人は、たちまち私を狂人あつかいにするだろう。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて、妹さえ丈夫でございましたならば、私も、少し気楽だったのですけれども、妹は、私に似ないで、たいへん美しく、髪も長く、とてもよくできる、可愛い子でございましたが、からだが弱く、その城下まちへ赴任して、二年目の春、私二十、妹十八で、妹は、死にました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの海岸の城下まちにも、大砲の音が、おどろおどろ聞えて来て、まちの人たちも、生きたそらが無かったのでございましょうが、私は、そんなこととは知らず、ただもう妹のことで一ぱいで、半気違いの有様だったので、何か不吉な地獄の太鼓のような気がして、ながいこと草原で、顔もあげずに泣きつづけて居りました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
