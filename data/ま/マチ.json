  {
    "uuid": "ef86f48f-92e1-5470-abde-2f34204791ad",
    "entry": "襠",
    "reading": {
      "primary": "まち",
      "alternatives": [
        "マチ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
