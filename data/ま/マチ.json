    "definitions": [
      {
        "index": 1,
        "gloss": "town",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今日も彼は紺の背広を着て熊のやうにしづ／＼と南国の夏の町を歩いてゐるのであらう。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔洪積の台のはてなる〕宮沢賢治洪積の台のはてなる一ひらの赤き粘土地桐の群白くひかれど枝しげくたけ低ければ鍛冶町の米屋五助は今日も来て灰を与へぬ。",
              "citation": {
                "source": "〔洪積の台のはてなる〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔青びかる天弧のはてに〕宮沢賢治青びかる天弧のはてにきらゝかに町はうかびて六月のたつきのみちはいまやはた尽きはてにけりいさゝかの書籍とセロを思ふまゝ〔以下空白〕",
              "citation": {
                "source": "〔青びかる天弧のはてに〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長さ二町ばかりの、その暗い湿つぽい通りに、今挙げたホンの三四軒の店屋が所々にあるのは、まるで蛍でもゐるやうな感じだつた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎晩アパート三階の便所に行くと、新宿の百貨店や何かの電燈広告が五六町ばかりの向ふに灯つてゐて、まるでほんとかと云ひたくなる。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンは常に散歩を好み、学校の帰途などには、まだ知らない町の隅々を徘徊したが、新しい興味の対象を見出すごとに、必ず妻を連れてそこへ再度案内した。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に東京の富久町に居た時には、近所の瘤寺へ毎日のように出かけて行った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのビルヂングの林立する新宿の町々に、かうした多くの人物が生棲してゐることを考へ、都會の隅々に吹きめぐる秋風の蕭條といふ響を聞いた。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場のガードをくぐつて坂を登ると、暗い煤ぼけた古道具や、安物の足袋など店に竝べた、昔の宿場そつくりの町がある。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、共に府下｜三鷹町｜下連雀の住人なのである。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いはば、すりばちの底の町である。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺町の呉服屋の、豊田様であります。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が中学の二年生の頃、寺町の小さい花屋に洋画が五、六枚かざられてゐて、私は子供心にも、その画に少し感心しました。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前は、甲府の町はずれに家を借りて住んでいたのである。",
              "citation": {
                "source": "無趣味",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "更にその前は、千葉県、船橋の町はずれに、二十四円の家を借りて住んでいたのである。",
              "citation": {
                "source": "無趣味",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が中学の二年生の頃、寺町の小さい花屋に洋画が五、六枚かざられていて、私は子供心にも、その画に少し感心しました。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れて始めて両親を離れ、飛び立つ思ひなり、その秋の暮、寒い夜に丸太町橋際の古本屋で「ダダイスト新吉の詩」を読む。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "住んでゐたのは野田寺町の照月寺（字は違つてゐるかも知れない）の真前、犀川に臨む庭に、大きい松の樹のある家であつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅から旅館までの俥の上で自分の息が見知らぬ町の暗闇の中に、白く立昇つたことを夢のやうに覚えてゐる。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日は父と母と弟と祖母とで、金沢の町を見て廻つた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが野田寺町の先刻云つた家であつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺ばかりといつてもいゝやうな町に住んでゐたので、葬式は実に沢山見た。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今以てそれは不思議といへば、一度町内の子供が全部揃つて、忠臣蔵の真似をして練り歩いたことがある。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダ・ヴィンチは、入れられぬ故郷の町を後に、自作の画数枚を背負つて雪のアルプスを越え………「今に………！",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」………ダヴィンチの顔――故郷の町の嘲笑――アルプス山の雪………と、まるで今彼が掻き混ぜてゐる石綿の灰の中から出て来るやうに、先達読んだ本の一節が浮んだ。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それは私に変な癖があるのだが、一度私が矢張広島の頃、父が東京に出張するといつて出る時、私はそれまでは何でもなかつたが、父の俥がいよいよ玄関を出る時急に人生の大切な岐路にでも立たせられたやうな気がして来て、泣く泣く父の俥の後を二三町ばかり泣きながら夢中に追つ駆けたことがあつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今は余つぽど好くなつた方だが、まだあんたの生れない頃Ｆ町にゐる時なんかは、それはそれはお母さんのお友達といふお友達が、とても貴方は体が続くまいから出て行け出て行けつてさへ言つたものですよ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君も知つてるだらうが、Ｓ子はデカタンのやうでピューリタニックなところを持つた女だし、それにあんな処で遊廓町で歌ふやうな歌を歌つちやあ困るぢやないか。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（金の酒……）　もう人通りの少い町を、電車がゴーゴーとやつて来た。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が、いま考えている事を、そのまま率直に述べたら、人は、たちまち私を狂人あつかいにするだろう。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
