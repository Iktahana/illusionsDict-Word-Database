        "examples": {
          "standard": [
            {
              "text": "彼女が手紙に書く丸文字は、いかにも女の子らしくて可愛らしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "80年代に流行した丸文字は、当時の若者文化を象徴するスタイルだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "テストの解答を丸文字で書いたら、先生に「もっと丁寧に」と注意された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「これ二反借って来たんは、丸文字屋にも知らんのじゃけど……」　もう行ったことに思っていたお里が、また枕頭へやって来た。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "想像は、いつのまにか、彼を丸文字屋の店へ引っぱって行っていた。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸文字屋へは、金持ちの客が沢山行っている。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸文字屋の内儀は邪推深い、剛慾な女だ。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の顔色によって、丸文字屋でどんなことが起ったか分るからだった。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
