          "literary": [
            {
              "text": "町火消し、弥次馬、役人達が、四方八方から駈けつけて来た。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、纏屋次郎左衛門から、六十四組の町火消しに供給した的と謂はゞ言はるべき、形の上の要素を多く具へた、馬簾つき、白塗り多面体の印をつけた、新しい物を考へに置いてかゝる事だけは、控へねばならぬ。",
              "citation": {
                "source": "まといの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大声を上げて飛び込んで来たのは、町火消しに組の頭常吉だった。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "宙に浮く屍骸",
                "note": "青空文庫"
              }
            }
          ]
        }
