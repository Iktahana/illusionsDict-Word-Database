        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし雛妓にはそんな様子もなくて、頻りに家の中を見廻して、くくみ笑いをしながら、「洒落てるけど、案外小っちゃなお家ね」　と言って、天井の板の柾目を仰いだり、裏小路に向く欄干に手をかけて、直ぐ向い側の小学校の夏季休暇で生徒のいない窓を眺めたりした。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの草履の代りに、柾目の正しく通った下駄を預けることができるが、預ける人はやっぱり同じ大男の爺だ。",
              "citation": {
                "source": "出世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネルの単衣に涼しさうな生絹の兵子帯、紺キヤラコの夏足袋から、細い柾目の下駄まで、去年の信吾とは大分違つてゐる。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネルの單衣に涼しさうな生絹の兵子帶、紺キャラコの夏足袋から、細い柾目の下駄まで、去年の信吾とは大分違つてゐる。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は中へ這入ってから、杉の板壁に背をよせかけても、それからはもう、杉の柾目が神殿の木目に顕われた歳月の厳しさや、和らぎに見えるのだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてどの部屋にも壁がなく、柾目の通った杉戸でしきり、全体の感じは鎌倉時代そのままといって良い。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鍛えは柾目、忠の先細く、鋩子詰まって錵おだやか、少し尖った乱れの先、切れそうだな、切れてくれなくては困る」　ソロリと納めると膝元へ置いた。",
              "citation": {
                "source": "首頂戴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ自分が今坐つてゐる疊の色や、天井の柾目や、床の置物や、襖の模樣などの中に、此屏風を立てて見て、夫に、召使が二人がゝりで、藏の中から大事さうに取り出して來たと云ふ所作を付け加へて考へると、自分が持つてゐた時よりは慥に十｜倍以上貴とい品の樣に眺められた丈であつた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "拭き込んだ細かい柾目の板が、雲斎底の影を写すほどに、軽く足音を受けた時に、藤尾の背中に背負った黒い髪はさらりと動いた。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと顔を挙げて見ると、其処には何にもなくて、障子の上の鴨居よりは一尺ばかり高く、床の間の落掛が、白々とした柾目を見せてるばかりだった。",
              "citation": {
                "source": "都会の幽気",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "見廻すと、覆いをした電燈の薄暗い光に照されてる室は、いつもの室と何の変りもなく、床の間にはやはり呉竹の軸が掛っており、上の落掛は白々と柾目を見せていた。",
              "citation": {
                "source": "都会の幽気",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから床の間が檜の一枚板であるとか、柱が柾目の杉であるとかいうようなことは、教授にとってなんの価値もなかったのです。",
              "citation": {
                "source": "アインシュタイン教授をわが国に迎えて",
                "author": "石原純",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の相槌をもって火気を去り、打ち返して肌に柾目をつけ、ほどよいころから沸かし延べの手順にかかる。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ自分が今坐っている畳の色や、天井の柾目や、床の置物や、襖の模様などの中に、この屏風を立てて見て、それに、召使が二人がかりで、蔵の中から大事そうに取り出して来たと云う所作を付け加えて考えると、自分が持っていた時よりは、たしかに十倍以上｜貴とい品のように眺められただけであった。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "天秤棒は細手の、飴色に磨きこんだ、特別製のようであり、手桶は杉の柾目で、銅の箍がかかっていた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄色い桑や黒い黒柿、斑のある楓や柾目の檜。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "柾目だとか木目だとか、好みは細かく分れます。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「秋田春慶」とも呼ばれていて檜の柾目を素地にし、幾回かこれに漆を塗って、なおかつ柾目の見えるのを誇りとします。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲物はいずれも柾目を用いねばなりません。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "主に杉の柾目を使って曲物を作ります。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十畳位の広さで、内部には柾目の通った檜の板を張り、保温のためその間には、木屑がつめられてあった。",
              "citation": {
                "source": "雪",
                "author": "楠田匡介",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり、折目正しい、サーヴィスで、柾目の通ったものを食わせる。",
              "citation": {
                "source": "神戸",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "パチ……　パチリ　榧の柾目の盤が三面、行儀よく並んでいた。",
              "citation": {
                "source": "魚紋",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "板屋根を葺くのは枌板といって、もとは杉だの檜だのの柾目のよくとおったふとい材木を、鉈のような刃物でそぎわったうすい板であった。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　もうそのころは、ひとかどのりっぱな職人になっていたマタンは、さっそくふしのない、まさめのよい木をえらんで、新しい木ぐつをつくりはじめました。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "水手はまたいふ、『人魚とはげにそれならめ、まさめにて見しはひとたび、また遇はず。",
              "citation": {
                "source": "有明集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "水手の翁はその日より海には出でず、『まさめにて三度人魚を見き』とのみ。",
              "citation": {
                "source": "有明集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、ふと、鉄網を張つた柵の隙間から、庭に面したテラスの上をみると、どこをどうして越えたのか、梨枝子がそこで、膝をついて、ホールの硝子戸に顔を押しあてたままさめざめと泣いてゐる様子であつた。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢が本当のようにまざまざとそこに坐っていらっしゃる絣の膝だの、そのわきに仰向いて高く二つの手をのばして、重い頭をその手の間に感じ、響きのような訴えを心に感じているままさめて行って、そうでない朝の中に出てゆく心持は、何と独特でしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
