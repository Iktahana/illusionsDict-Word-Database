    "definitions": [
      {
        "index": 1,
        "gloss": "revilement",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もちろん僕は、雜誌の六號記事がゴシツプ的に書く漫罵なので、神經質に抗議する男ではない。",
              "citation": {
                "source": "常識家の非常識",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学に対して理解を欠き、科学の功の大ならざるを見る時は、忽ちに軽侮漫罵の念を生ずるのは、口惜しい悪風である。",
              "citation": {
                "source": "震は亨る",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども貴様、それは漫罵だ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん僕は、雑誌の六号記事がゴシツプ的に書く漫罵なので、神経質に抗議する男ではない。",
              "citation": {
                "source": "常識家の非常識",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは出て行つた人と予とに對する漫罵であつた。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "群集はまた思い出したように漫罵を放って笑いどよめいた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "段々激しい漫罵になつて行く自分の言葉に、その時はじめて氣づいたのかも知れない。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず、右翼日和見主義者とその眷族調停派たちは、自身の誤謬を固執し、作家同盟の一部の同志は、同志小林の指導的批判に対していささかも科学的根拠のないデマゴギー的漫罵をわめきたてさえしたのである。",
              "citation": {
                "source": "同志小林の業績の評価に寄せて",
                "author": "――誤れる評価との闘争を通じて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "漫罵の代りに、真面目な、本質的な反駁をやる訳にはゆかんのか？",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ここでまことに面白いことは、この夜プレハーノフの論文を朗読し、漫罵の代りに本質的な反駁をやることは出来ないかと特に注意した一人の青年フェドセーエフが、喧々囂々の中で苦しそうにしているゴーリキイに目をとめた。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "話題の大部分は文壇人の悪口であつたとはいふものゝ、さすがに批評家を本領とする彼れのそれは漫罵ではなかつた。",
              "citation": {
                "source": "斎藤緑雨と内田不知菴",
                "author": "坪内逍遙",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭は素漫罵の癖がある。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "また無能にして漫罵詆笑を事とする徒の頻りに投機者流を以て父及び父の同志者を呼ぶあり。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "作品は默殺されるのがおきまりで、たまたま批評するものがあると、當の作品の批評よりも、仲間外れに對する漫罵に類するものが多かつた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（その席で先生一流の漫罵やまぜっ返しがあったけれどこれを略す。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "誠に森先生が性慾の事を題材とせられた「ヰタ、セクスアリス」または妓女の情事を寫された「心中」の如き短篇小説を一讀して、これを當代作家の作品に比較して見たなら、わたしの言ふ處はあながち漫罵でない事を知る事が出來るであらう。",
              "citation": {
                "source": "森先生の事",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "滑稽なる日本全一冊　　彩色表紙定価郵税共金二十銭著者は「滑稽」の二字、我社会の総べてを形容し得可しとなし、而して其標本はハイカラーなりとし、漫罵冷嘲、縦横翻弄して滔々たる高襟者流をして顔色無からしむ。",
              "citation": {
                "source": "ハイカラ考",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論そのやりとりの中には、国際的通有性の濃い性器に関する漫罵の言葉も多分に含まれてゐたことだらうが、やがて双方が次第に興奮して来て、応酬の内容が次第に一そう深く民族的｜矜持にふれる主題にまで発展して行つたらしいことは、まだ台湾語をほとんど解するに至らない少年の耳にも、はつきり推測がついた。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも平生吾輩が彼の背中へ乗る時に少しは好い顔でもするならこの漫罵も甘んじて受けるが、こっちの便利になる事は何一つ快くしてくれた事もないのに、小便に立ったのを馬鹿野郎とは酷い。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "精一杯手短かな言葉に代表さしていえば、「お目出度き人」という小説か脚本かを書いた武者小路氏のごとく、皮肉でも反語でもなく、勿論何らの漫罵でもなく、思切って「オメデタイ」ことである。",
              "citation": {
                "source": "文壇昔ばなし",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり相手に腹を立てさせるのを目的にして漫罵を連ねているのである。",
              "citation": {
                "source": "文壇昔ばなし",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んの女の子の二の腕くらい、力づくでねじ伏せたって、畜生ッ」　平次に漫罵を浴びせられて、八五郎は面喰って飛び出してしまいました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私の姉を殺し、父親を牢に入れ、家を潰した上、私を騙して、水野様を殺させようとした大悪人は其奴だ」　お豊の声は礫と漫罵の中に甲走ります。",
              "citation": {
                "source": "礫心中",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "街の悪童の漫罵の中に、泥酔した父親を背負って帰る屈辱感が、ベートーヴェンの負けじ魂を一層｜頑なものにし、荊の道を渋面作って踏み破る最初のスタートになったのであろう。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、或る感情を持つてゐる純文學と稱する人たちが、歪んだ尺度と、狹義な文學至上をもつて、徒らに漫罵する。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その漫罵と人々の意地悪さには、さすがの武大も耐えかねた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "曹仁が漫罵の計を逆用して、急に血を吐いた真似をして見せたのだ。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "白帝城一　敵を誘うに、漫罵愚弄して彼の怒りを駆ろうとするのは、もう兵法として古すぎる。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そこで彼らは、この機とばかり、まわりに見える弥次馬へも、演舌するような口調で、足利若御料の周囲を漫罵したあげくに、「不服か」　と、相手の若い真額をにらみつけ、「だから歩けというのだ。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば、きっと幾何か包まっしゃるけに……非人の分際で、お役人を追い使うて済まんばってん……」「何の何の。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
