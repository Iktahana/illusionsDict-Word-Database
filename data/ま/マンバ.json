    },
    "definitions": [
      {
        "index": 1,
        "gloss": "mamba (snake of the genus Dendroaspis)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おびゆる人々　一九一四年、ドイツでは、ヘルマンバールは、次のように叫んでいる。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "クマンバチの巣に頭を突っ込んでいます。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "出雲の大原郡にはヤマンババというのがある。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野草雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京近くではアヒダキモノ、またアハヒノキモノ（富士郡）、信州越後ではマンバとも謂う。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "マンバもアヒダも同じことで、働かぬ時という意味だ。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "信州の松本などでは、現在は稲扱器をマンバと呼ぶ語がある。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来｜万能だの万力だのという農具は、みなこのマンバと同様の宣伝名で、すなわちそれがすでに商品として彼らに供給せられたことを語るものである。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
