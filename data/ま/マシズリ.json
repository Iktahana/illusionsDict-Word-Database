          "literary": [
            {
              "text": "最初に刷った分が売り切れ、今後もある程度売れ続ける見通しが立つと、増し刷りになります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般に出版社では、単価が高く部数の読みにくい書籍はそこそこの部数を刷って売り出し、市場動向を見て必要とあらば増し刷りする。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは15世紀と16世紀にしばしば増し刷りされた。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            }
          ]
        }
