[
  {
    "uuid": "5cfb0cdd-a90a-5385-aac2-1631dba66119",
    "entry": "満点",
    "reading": {
      "primary": "まんてん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
