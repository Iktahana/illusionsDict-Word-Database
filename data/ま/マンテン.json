    },
    "definitions": [
      {
        "index": 1,
        "gloss": "perfect score",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今日はどうでもかうでも行乞しなければならないので、午前中近在を歩いた、行乞相は満点に近かつた（現在の私としては）。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし満点というわけには行かず、妻の生きた面影は地上では再び見る術もなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなら、楽だ、しかし、人間というものは、皆そんなもので、またそれで満点なのではないかしら、わからない、……夜はぐっすり眠り、朝は爽快なのかしら、どんな夢を見ているのだろう、道を歩きながら何を考えているのだろう、金？",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "サービスは満点である。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "横沢さんは満点をつけても、僕は、君には零点をつけます。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「赤い部屋」では、その前置きの材料を集められたハタラキと、その配列と、トリック、脚色を、あそこまで洗練し、有機化しつつ、最後に茶化してしまわれた大器量に対して、思わず「満点」を叫ばせられました。",
              "citation": {
                "source": "江戸川乱歩氏に対する私の感想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語の科目は凡て、終始満点であつたが、それは当然のはなしで寧ろ済まなく考へてゐた。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、たつた一遍予科の二度目の一年の時、ケイト先生の自由英作文といふので満点を貰ひお前は外国の中学を出たのか？",
              "citation": {
                "source": "文学的自叙伝",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "由って思案の末課目が十あるうち作文と講義は得手物で満点と極まっており、総点数の五分一得れば落第せぬ定め故、他の八課の答えは直ちに白紙を差し出し件の二課は速くやって退け十分安心して遊び廻った。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではお菊どの、御造作ながら御手伝い下さりませ」　打揃いながら別室へ退いていったかと思われましたが、程経てそこに再び立ち現れた京弥の女装姿は、まこと、女子にしても満点と言った折紙すらもが今は愚かな位です。",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうじゃな、そなたとて二人して、ふた夜三夜しっぽりと参籠致しますかな」「いいえ、そんなこと、――わたしあの、知りませぬ」　くねりと初い初いしげに身をくねらして、パッと首筋迄も赤らめたあたり、三十年増が化けたものなら正に満点。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなら、百点満点ではないが、零点というわけでもない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "――煽動効果満点よ！",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「失念致しましてございます」「よろしい、満点、その方がいい。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "満点ついでにもう一つ聞こう。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "動かなければ、確に彼女は満点だ。",
              "citation": {
                "source": "火の点いた煙草",
                "author": "一名――煙草蒐集家の奇禍",
                "note": "青空文庫"
              }
            },
            {
              "text": "和田垣博士と試験問題２・21（夕）　法学博士和田垣謙三氏といへば、学生の試験答案を爪先で一つ一つ跳ね飛ばしてみて一番遠くへけし飛んだのへ満点をつけたといふ、立派な採点法を発明したので名高い先生である。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、そうだからといって、一つ一つの絵がみんな満点といえないのは明かだ。",
              "citation": {
                "source": "プロレタリア美術展を観る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると翌日の試験には満点百のものをようよう十四点だけもらった。",
              "citation": {
                "source": "酒",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の行乞相はすこし弱々しかつたが上々だつた、私としては満点に近かつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説の父親の考は、では、賑やかなところと云えば、どこを指したら満点なのだろうかというところまではふれられていない。",
              "citation": {
                "source": "新入生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夏僕は、訓育（実科）では未曽有の十九点何分（二十点満点）で一番、学科では十八点何分で二番、操行ではこれまた未曽有の十四点何分で下から一番、平均して三十五番か六番かという成績表を持って、今までの僕にはなかった陰欝な少年となって新発田へ帰った。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の行乞相は、現在の私としては、まあ満点に近い方だつた、我といふものがなかつたとはいへないが、ないに近い方だつた、そして泊つて食べる（その上に酒一本代）だけは頂戴することが出来た。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "道を訊ねる、答へる人の人間的価値がよく解る、今日も度々道を訊ねたが、中年の馬車挽さんは落第、若い行商人は満点だつた、教へるならば、深切に、人情味のある答を望むのは無理かな。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝てばかりもゐられないので三時間ばかり町を行乞する、行乞相は満点に近かつた、それはしぼり腹のおかげだ、不健康の賜物だ、春秋の筆法でいへば、シヨウチユウ、サントウカヲタヾシウスだ。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "富田町行乞（そこは農平老の故郷だ）そして富田よいとこと思つた、行乞相は満点、いつもこんなだと申分ない。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
