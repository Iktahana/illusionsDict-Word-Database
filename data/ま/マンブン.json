        "examples": {
          "standard": [
            {
              "text": "休日の午後に、喫茶店で漫文を読みふけるのが好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼のブログには、日々の雑感を綴った漫文が投稿されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "気軽に読める漫文は、忙しい現代人に癒しを与えてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "キザの見本だというので漫文漫画に諷刺され世間の笑いものになっているから、自粛するかと思うとそうじゃない、伯爵夫人でも重役夫人でもない熊さん八さんのオカミサンが、とたんにザアマスをやりだして、人に笑われて得々としている。",
              "citation": {
                "source": "敬語論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕刊各紙の「短針」「三角點」「よみうり寸評」を初め、漫畫漫文、ウソシンブンの類まで、君が云はんとする所は、人間も云つてゐる。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
