          "literary": [
            {
              "text": "キザの見本だというので漫文漫画に諷刺され世間の笑いものになっているから、自粛するかと思うとそうじゃない、伯爵夫人でも重役夫人でもない熊さん八さんのオカミサンが、とたんにザアマスをやりだして、人に笑われて得々としている。",
              "citation": {
                "source": "敬語論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕刊各紙の「短針」「三角點」「よみうり寸評」を初め、漫畫漫文、ウソシンブンの類まで、君が云はんとする所は、人間も云つてゐる。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
