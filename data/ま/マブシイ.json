        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あなたはそんなにパラソルを振る　　僕にはあんまり眩しいのです　　あなたはそんなにパラソルを振るさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "眩しいような瓦斯燈の下に所狭く並べた絵具や手帳や封筒が美しい。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞は眩しいほど、それ等の事を並べたてた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "酸素と水素あるいは灯用瓦斯と混じた焔を石灰の塊に吹き付けると眩しいような光を出す。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして球技場の眩しい日照の下に、人知れず悩む思いを秘めた白衣のヒロインの姿が描出されるのである。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして強い眩しい日光の中にキラキラして飛んでいる蜂の幻影が妙に淋しいものに思われて仕方がなかった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供部屋の裏の縁先にある花壇には、強烈な正午過ぎの日光が眩しいように輝いて、草木の葉もうなだれているようであった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからたちまち闇が戻されて眩しい花の姿は消えましたので、ガドルフはせっかく一｜枚ぬれずに残ったフラン［※５］のシャツも、つめたい雨にあらわせながら、窓からそとにからだを出して、ほのかに揺らぐ花の影を、じっとみつめて次の電光を待っていました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眩しいような真昼の光の下に相角逐し、駈けり狂うて汀をめぐる。",
              "citation": {
                "source": "ある幻想曲の序",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、楢夫は、眩しいひるまの草原の中に飛び出しました。",
              "citation": {
                "source": "さるのこしかけ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はアンマリ眩しいので二三度瞬きをした。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は鏡の中の自分の姿を、眩しいシャンデリヤ越しに振り返ってみた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "眩しい刺繍の丸帯の前に束ねた、肉づきのいい両手の間から、巨大なダイヤの指環がギラギラと虹を吐いた。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "眩しい白昼の光の中で受けた、強い大きな屈辱と、それに対する深い悔恨……。",
              "citation": {
                "source": "線路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "相島は大急ぎで中の口から上つて、自分の書齋を通り拔けて玄關に出ると、書生が既に戸を開けて、暗い家の中から明るい雪の庭が眩しい樣に見える。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時の間にか世の中は眩しいやうな朝の光になつてゐた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝子戸越の早春の朝の陽差しを眩しい眼ざしで防ぎながら海を眺めていました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　私は目下京都にいて、この原稿を書いているが、焼けた大阪にくらべて、焼けなかった京都の美しさは悲しいばかりに眩しいような気がしてならない。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "四条通りはまるで絵具箱をひっくり返したような、眩しい色彩の洪水だった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "流れと白さと、堤の桜の若葉の緑が眩しい。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽の眩しい光に憧がれる人達が姿を消し、夜光虫の青白い光に憧がれる人間共が大阪の盛り場に蠢く時が来たのだ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論それにしてもあの様な最初から最後まで奇妙だった出会いの後ではあるし、又眩しいほどの彼女の美しさであるから、一応は逃げたくもなるだろうけれど。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "……蓬々と延びた髪の毛……無性ヒゲ……ボロボロの浴衣……結び目をブラ下げた縄の帯……瘠せ枯れた腕……灰色のホコリにまみれた素跣足……そんなものの黒い影が、一寸法師のように、眩しい地面に這いついていた。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、それとほとんど同時に、眼の前の暗い横路地から眩しい、美しい色彩の一カタマリが音もなく辷り出て、眩しくユラユラと立ち止った。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るとそれはこの別荘の若大将夫婦で、たった今ボート乗りから帰って来たものらしく、二人とも眩しいほど白い洋服を着て、濡れ草履を穿いて、ニコニコしながら突立っていた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそのドキドキした予感を中心にして、深良屋敷の惨劇を裏書きしているらしい色々な過去の前兆が、眩しいくらい明るい、又はジメジメと薄暗い木立の中を押分けて行く草川巡査の、勉強に疲れた記憶力の中に、今更のようにマザマザと浮み上って来るのであった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそれから後、小高い深良屋敷を囲む木立の間から眩しい窓明りと共に、朗らかなラジオの金属音が、国道添いの村の方へ流れ落ち初めたのであった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……眩しい太陽……。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなかやると思っていますよ」私はむっとして、佐竹のまぶしいほど白い顔をもいちど見直した。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜を見るとまぶしい。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
