[
  {
    "uuid": "90f7de92-7f42-588d-b2bd-d05f5de89b2a",
    "entry": "紛らす",
    "reading": {
      "primary": "まぎらす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
