        "examples": {
          "standard": [
            {
              "text": "彼女はルネサンス音楽、特にマドリガルが好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "合唱団が美しいマドリガルを披露した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "16世紀のマドリガルは、多声の世俗音楽として発展した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "マドリガルやエピグラムのきらめきに、昼の間を遊び暮して、草臥れた跡で、それとは様子の変つた、彼の青年との交際を楽む事にしてゐる。",
              "citation": {
                "source": "クサンチス",
                "author": "XANTHIS",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間がキカイに食われる時代、私は煙草屋のウインドウの前で白と赤のマントを拡げたマドリガルと云う煙草が買いたかったのだ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すばらしい享楽、すばらしい溺酔、マドリガルの甘いエクスタシイ、嘘でも言わなければこの世の中は馬鹿らしくって歩けないじゃありませんか――。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
