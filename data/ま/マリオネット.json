        "examples": {
          "standard": [
            {
              "text": "巧みな手つきで糸を操ると、木製のマリオネットが舞台の上で軽やかにワルツを踊り始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "人形師は、まるでマリオネットに魂が宿ったかのように、豊かな表情を指先だけで作り出す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「自分の人生は誰かに操られるマリオネットじゃない」と、彼は強い口調で言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そうして、結城孫三郎やダークのマリオネット、ないしはギニョールのパンチとジュデーなどに対する独特の地位を全然喪失してしまうことは明白である。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある父はマリオネットの人形を指して、「それお化けや、買うたろか」といったら子供は「いや！",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　六、飛んだり跳ねたりマリオネットの兎小僧。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "合乗り乳母車　――仏蘭西縦断の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "マリオネットだってこうまで手ひどく翻弄されはしまい。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "──　あそこのマリオネットで、わたしは欠伸の滂沱たるなみだにかきくれた。",
              "citation": {
                "source": "希臘十字",
                "author": "高祖保",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　あそこのマリオネットで、わたしは欠伸の滂沱たるなみだにかきくれた。",
              "citation": {
                "source": "希臘十字",
                "author": "高祖保",
                "note": "青空文庫"
              }
            },
            {
              "text": "色塗り指人形、糸｜操り人形、麦わら髪のマリオネット、そんな女王を想像します。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "グリーンに操られた魂のないマリオネットだ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
