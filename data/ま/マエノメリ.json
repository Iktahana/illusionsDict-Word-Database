[
  {
    "uuid": "34463ee0-7574-545b-a250-5d6d6f739337",
    "entry": "前のめり",
    "reading": {
      "primary": "まえのめり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pitching forward (as if to fall)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だが、この場合は窪んだ腹に緊く締めつけてある帯の間に両手を無理にさし込み、体は前のめりのまま首だけ仰のいて「お母さあん」　と呼ぶ。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、肩を持たれたまゝ、右の跛の黒どのは、夫人の白魚の細い指に、ぶらりと掛つて、一ツ、ト前のめりに泳いだつけ、臀を搖つた珍な形で、けろりとしたもの、西瓜をがぶり。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "息杖で背後へ反っくり返るのと、楫棒を握って前のめりに屈むんじゃ、から、見た処から役割が違いやさ。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "縞がらは分らないが、くすんだ装で、青磁色の中折帽を前のめりにした小造な、痩せた、形の粘々とした男であった。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "名古屋の客は、前のめりに、近く、第一の銅鍋の沸上った中へ面を捺して突伏した。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "縫えると、帯をしめると、私は胸を折るようにして、前のめりに木戸口へ駈出した。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑所は前のめりに俯向いて、一服吸った後を、口でふっふっと吹落して、雁首を取って返して、吸殻を丁寧に灰に突込み、「閉込んでおいても風が揺って、吸殻一つも吹飛ばしそうでならん。",
              "citation": {
                "source": "朱日記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一座の者はおやと思って記者の顔へ眼をやる間もなく、その記者は前のめりになって高座の下へ落ちたので、怪談会はしらけてしまって、未明までやるはずのものが、一人帰り二人帰りして、十二時頃には何人もいなくなった。",
              "citation": {
                "source": "怪談会の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふさふさの簪を前のめりに挿して、それは人柄な、目の涼しい、眉の優しい、口許の柔順な、まだ肩揚げをした、十六七の娘が、一人入っていたろう。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二条で追いつき、あわや襟首をつかもうとした時、盗賊はぶらついていた首をいきなり千切ってふところへ入れたので、すかされて前のめりになった。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "安来｜千軒、名の出たところ、　コラサッと、この時、笊を前のめりに、ひょろひょろと、横っ飛びに蹌けかかった黒んぼがある。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "車の前が高くなって体がのけ反るようになるので、それを要心していると今度は前が低まってきて、前のめりになりそうになる処があった。",
              "citation": {
                "source": "賈后と小吏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が躓いて前のめりに倒れた。",
              "citation": {
                "source": "藍瓶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は落ちながら前のめりになろうとする体をやっと支えて立ちなおった。",
              "citation": {
                "source": "馬の顔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と私が前のめりに聞くと、「一〇ほど、いや一二か。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　この男の様子がずいぶん前のめりなので女中も怖くなり、すり抜けるようにいつも食事を渡す手はずの厩舎の窓のところへ駆けていった。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "内の医師が手にかけたという、嬰児の酒精に浸けたのが、茶色に紫がかって、黄色い膚に褐斑の汚点が着いて、ぐたりとなって、狗の児か鼠の児かちょいとは分らぬ、天窓のひしゃげた、鼻と口と一所に突き出た不状なのが、前のめりにぶくりと浮いて、膝を抱いて、呀！",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、肩を持たれたまゝ、右の跛の黒どのは、夫人の白魚の細い指に、ぶらりと掛つて、一ツ、ト前のめりに泳いだつけ、臀を揺つた珍な形で、けろりとしたもの、西瓜をがぶり。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こけ勘はお里が知れまさ、ト楫棒へ掴った形、腰をふらふらさせながら前のめりに背後から、（愛吉さん、危え、危え。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五　赤大名のずたずた袷が、廂合を先へ出ると、あとから前のめりに泳ぎ出した、白の仕事着の胸倉を掴んだまま、小路の中で、「ええ、」　と小突いて、入交って、向の生垣に押つけたが、蒼ざめた奴の顔が、赫と燃えて見えたのは、咽喉を絞められたものである。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の踵は宙の風を切つて、身体は前のめりに案山子のやうに引きずり込まれたかと思ふと、銑太郎は内側から慌てゝ扉を圧し、えいツ！",
              "citation": {
                "source": "冬物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "（五）　足を女の足のしろさとならべてつま先のところをじつと男がみつめてゐると幾分地面が傾斜になつてゐることに気がついた、そして背中にすく／＼と暗の中に新鮮な青い樹木のやうなかたちが大きな掌をひろげて男をどんと突いたので、危くがつくりと前のめりに娘さんの膝の上に頭を落してしまふところであつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "極度の疲労で痩せた両足は痲痺状態になり前のめりに前進し、奇怪なことには、ステッキが足より先に疲れたやうに思へたので、珍太はステッキを手にもつ苦痛から、これを投げ捨てた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "だらしがないと云つて屡々周囲の者に嫌はれたが、紳士風に浅く前のめりに軽く被つて見ると、今時、烏帽子でも被つてゐるかのやうな浮ついた、妙な気分になつて決して堪えられないのである。",
              "citation": {
                "source": "小川の流れ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉蜀黍殻といたどりの茎で囲いをした二間半四方ほどの小屋が、前のめりにかしいで、海月のような低い勾配の小山の半腹に立っていた。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の子はひざをまげて、地びたへつけようとして、ころりと前のめりにたふれました。",
              "citation": {
                "source": "乞食の子",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――シュッと血しぶきを噴きあげ飛ばして、若く美しかったその妻は一言の言葉を交わし放つひまもなく、どったりと前のめりにうっ伏した。",
              "citation": {
                "source": "十万石の怪談",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "傷は、背中をぐさりとやられた突き傷が一カ所、凶器は匕首、手慣れの三味にひと語りかたっているところをでも不意にうしろから襲われたらしく、二三春は撥もろともに太棹をしっかりとかかえたまま、前のめりにのめっているのでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが時々、くぼみに足を落して、身體を前のめりにのめらせたとき、亂れるだけだつた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "案の定敵は、ドスを頭上に晃らせつつまえのめりにおっかぶさってきた。",
              "citation": {
                "source": "放浪作家の冒険",
                "author": "西尾正",
                "note": "青空文庫"
              }
            }
          ]
        }
