[
  {
    "uuid": "4050d685-3c04-5f02-b41f-0fe34e18a2b9",
    "entry": "招き",
    "reading": {
      "primary": "まねき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
