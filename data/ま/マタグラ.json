        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "高やかに組んでいる両腕の太さは普通人の股ぐらいに見える。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の口臭も我慢ならない程臭いけれど、何より一晩中股ぐらをごしごしかいて明かすのである。",
              "citation": {
                "source": "光の中に",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "来て見りやおれの股ぐらから、あの野郎がもう片息になつて、面妖な面を出してゐやがる始末よ。",
              "citation": {
                "source": "鼠小僧次郎吉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつが出刃包丁を啣えた女の生首の刺青の上に、俺達の太股ぐらいある真黒な腕を組んで、俺の寝台にドッカリと腰を卸して出ッ歯をグッと剥き出したもんだ。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "靴屋の前を通るのは心がひけたが、運惡く今朝の女の子が、二三人の友達と、大きな毬を股ぐらをくぐらせくぐらせ突いてゐるところだつた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又役者が意気揚々と、房のついた韃を振りまわしていたら、その役者の股ぐらの下には、驕って行かざる紫子の下から、ちらりと小さな靴の底を見せた。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "河合はマートン技師の股ぐらへ首をつっこんでしまった。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "テメエのコタツを蹴とばしてお舟の股ぐら焦すんじゃねえや。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十六　家族は六人・目一ツ半",
                "note": "青空文庫"
              }
            },
            {
              "text": "帽子を股ぐらに挾んでいる。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷やかされて、ナネットは、股ぐらへ棒を投げつけられたように、ぎっくりとする。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな瞬間には新宿のいんちき酒場の亡霊共がものすごく彼を招くのだ、彼の乱酔の渦中に女どもが叫んで彼の帽子を脱がせ、上着から財布をもぎ取り、髪をむしり脇の下をくすぐったりする女どもが、白ねずみのように股ぐらを駈け廻るのである。",
              "citation": {
                "source": "わが愛する詩人の伝記（三）",
                "author": "――萩原朔太郎――",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒い時分には、掛け布団の襟をくゞつて、枕の方からもぐり込んで来るのであつたが、寝勝手のよい隙間を見付け出す迄は、懐の中へ這入つてみたり、股ぐらの方へ行つてみたり、背中の方へ廻つてみたりして、やう／＼或る場所に落ち着いても、工合が悪いと又直ぐ姿勢や位置を変へた。",
              "citation": {
                "source": "猫と庄造と二人のをんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒い時分には、掛け布団の襟をくぐって、枕の方からもぐり込んで来るのであったが、寝勝手のよい隙間を見付け出す迄は、懐の中へ這入ってみたり、股ぐらの方へ行ってみたり、背中の方へ廻ってみたりして、ようよう或る場所に落ち着いても、工合が悪いと又｜直ぐ姿勢や位置を変えた。",
              "citation": {
                "source": "猫と庄造と二人のおんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "股ぐらを潜らせた丈けだ」「見ろ。",
              "citation": {
                "source": "ある温泉の由来",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "股ぐらを潜って行け」「仕方がない」　と西の若い者も東の領分へ入っていると考える。",
              "citation": {
                "source": "ある温泉の由来",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その瞬間には新宿のいんちき酒場の亡霊共がものすごく彼を招くのだ、彼の乱酔の渦中に女どもが叫んで彼の帽子を脱がせ、上着から財布をもぎ取り、髪をむしり脇の下をくすぐったりする女どもが、白ねずみのように股ぐらを駈け廻るのである。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "脇差を引っこ抜いて、武士と渡り合うのを不穏当と思ったか、右手に掴んだ振り分けの荷、――それを入口を塞いだ大男の股ぐらへパッと投ったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お局お六",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に私は体の処々方々がむず痒くなって、着物の裾のはだけた処から冷めたい風がすう／＼と股ぐらに吹き込み、一方へ伸ばした右の手の中指の先が微かに仙吉の髪の毛に触れて居るのを感じた。",
              "citation": {
                "source": "少年",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は失望しながら、（その辺の土砂も相当に危険で、一歩々々に股ぐらいまで漬かるのであった）校舎の南の、以前は花壇や芝生などのある庭になっていた所を横切り、玉置女史の住宅のある方へ行った。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "股ぐらの下にエンジンがある。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "……だが、てめえの首はおれがスゲ替えてやるから心配するな」　無造作に、大蔵は股ぐらのうえに、中の物をひろげだした。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽がまたぐらぐらおどりだしたなあ。",
              "citation": {
                "source": "ペンネンノルデはいまはいないよ　太陽にできた黒い棘をとりに行ったよ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂利を積んだ車がまたぐらぐらと橋を揺ったので、砂塵濛々、水も空も、日が暮れて月が冴えねば、お夏が彳んだ時のように澄みはしない。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "きさまのまたぐらにゃ、人並みに度胸袋がぶらさがっていねえのか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはいけないと思ひながらも、辰子さんにまたひきとめられるとまたぐらぐらと氣持ちが搖れた。",
              "citation": {
                "source": "悲しみの代價",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやと思ってその次のやつへ足をかけるとまたぐらりとくる。",
              "citation": {
                "source": "槍が岳に登った記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きみは強いんだね」「いやぼくは弱いよ」「そうじゃない、あの場合きみがライオンのまたぐらへ飛びこんでくれなかったら、ぼくはあの小刀で一つきにされるところだったんだ」と生蕃がいった。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手はまたぐらりと揺れて、重ねて、「君は誰だ」と繰りかえした。",
              "citation": {
                "source": "石ころ路",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、またぐらぐらつとした。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "左膳がしゃがみこみ、「ごめん……」　と源三郎は、その左膳の首へまたぐらを入れた。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
