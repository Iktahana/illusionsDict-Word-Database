    "definitions": [
      {
        "index": 1,
        "gloss": "marathon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "千米、五千米、いやいや、もっとながい大マラソンであった。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "競争は、マラソンである。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻孔から、喉頭が、マラソン競走をしたあとのように、乾燥し、硬ばりついている。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、将来大マラソン家になろうという野心も無く、どうせ田舎の駈けっくらで、タイムも何も問題にならん事は、よく知っているでしょうし、家へ帰っても、その家族の者たちに手柄話などする気もなく、かえってお父さんに叱られはせぬかと心配して、けれども、それでも走りたいのです。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼児の危い木登りには、まだ柿の実を取って食おうという慾がありましたが、このいのちがけのマラソンには、それさえありません。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「マラソンの練習でございます。",
              "citation": {
                "source": "月夜のけだもの",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかにマラソンの方でございます。",
              "citation": {
                "source": "月夜のけだもの",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに第一おまへらにマラソンなどは要らん。",
              "citation": {
                "source": "月夜のけだもの",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからマラソンの方と両方でございます。",
              "citation": {
                "source": "月夜のけだもの",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは地獄行きのマラソンをやったのだ。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　なるほどそうしてみると三人とも地獄行きのマラソン競争をしていたのです。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばド・ヴァレーズ伯爵がけしからぬ犯行の現場から下着のままで街頭に飛び出し、おりから通りかかったマラソン競走の中に紛れ込み、店先の値段札を胸におっつけて選手の番号に擬するような、卑猥であくどい茶番はヤンキー王国の顧客にはぜひとも必要なものであろう。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼のたちの悪い人が刺繍で成功しようとしたり、足の短い人がマラソンの選手を志したりする無謀は避けなくてはならないでしょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）大将「これはなアフガニスタンでマラソン競争をやってとったのじゃ。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "山上通信太宰治　けさ、新聞にて、マラソン優勝と、芥川賞と、二つの記事、読んで、涙が出ました。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな不仕鱈な女をひとり放って置いて、比律賓へ行ってしまえば、どうなっていたことかと、他吉はひやっとしたが、間もなく行われた町内のマラソン競争で桶屋の新太郎は一等をとった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "マラソン競争のあった翌日、他吉はれいの上着のポケットに、季節はずれの扇子を入れて、桶屋の主人を訪れ、「早速やが……」　と、新太郎を初枝の婿にする話を交渉した。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "マニラてねっから聴いたことのない土地やが、何県やねん」「阿呆なこと言いなはんな」　ポロポロ涙を落しながら、マニラは比律賓の首府だと説明すると、「さよか、しかし、なんとまた遠いとこイ行ったもんやなあ」「マラソンの選手でしたが……」「ほんまかいな、しかし、可哀相に……。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "見てみイ、お前のお父つぁんとお母んの写真が出てるぜ」　新太郎が町内のマラソン競争で優勝した時の十八年前の記念写真が、変装写真や俳優の写真にまじって、三枚四十銭の見本の札をつけて、陳列してあったのだ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、誰も親なし子や言うて虐めたら、あけへんし」　その日から、君枝はだんだん明るい子になり、間もなく行われた運動会の尋二徒歩競争では、眼をむき、顎をあげて、ぱっと駈けだし、わてのお父ちゃんはマラソンの選手やった、曲り角の弾みでみるみる抜いて一着になった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとあった変装写真や歌舞伎役者の写真がすっかり姿を消して、出征の記念写真が目立って多くなっているなかに、どうした奇蹟であろうか、二十年前のマラソン競争の記念写真が、色あせたまま、三枚一円八十銭の見本だと、値だけ高くなって陳列されているのを見ると、気が遠くなるほどなつかしかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにがうちが嘘いうもんかいな」　君枝は昨日次郎ぼんにあったいきさつを話して、「――これ、次郎ぼんが引伸してくれはってん」　マラソン競争の写真を見せると、他吉もその写真のことは知っていて、「こらまた、えらい大きに伸びたもんやなあ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕元の壁の額に入れられたマラソン競争の記念写真の中から、半分顔を出して、初枝がそれを覗いていた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "清はマラソンの稽古をしてゐるな、と思つた。",
              "citation": {
                "source": "白いシヤツの群",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初枝「……次は、飛び入りマラソン競争であります、来賓の有志、青年学校、在郷軍人会、壮年団の有志の方は特にふるって御参加願います」放送の途中で、庄平が、のそっと入って来て、一般観覧席で、きょろ／＼している。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」係の先生のＢ「何秒ってマラソンはありませんよ、半時間で行けたら早い方です」八人の選手は出発線へ並ぶ。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "初枝「マラソン競争の選手が帰って参りました」拍手。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "初枝（放送する）「只今のマラソン競争の成績を申し上げます。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴三「やあ、待ってました、マラソンは……？",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄平「蜂谷君じゃないか」十吉「じゃ、やっぱし中瀬古君か」庄平「うん、イノシシだよ」十吉「あわて者の」鶴三「お知り合いでしたか」庄平「中学時代一緒だったんですよ、もう十年も会わぬが、面影はあるね」十吉「実は、先刻君を見たんだよ、学校で」庄平「マラソンをやってる処を」十吉「うん」庄平「どうして声を……？",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
