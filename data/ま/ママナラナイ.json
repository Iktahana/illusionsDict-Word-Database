    "definitions": [
      {
        "index": 1,
        "gloss": "unable to do (as one wishes)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
