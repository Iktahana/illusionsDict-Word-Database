        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "地下鐵道にてひとり來りて地下鐵道の青き歩廊をさまよひつ君待ちかねて悲しめど君が夢には無きものをなに幻影の後尾燈空洞に暗きトンネルの壁に映りて消え行けり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日はいよいよ鷹が貰えると思ってさんざんに待ちかねて、やっとその日になってみると鷹は今ちょうどトヤに入っているからもう二、三日待ってくれというのである。",
              "citation": {
                "source": "鷹を貰い損なった話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの、内の人は来ていますかえ」と、お徳は待ちかねて訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は、工場が引けて帰る幹太郎を待ちかねていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車で待ちかねていた連中がどやどやと押しよせてきた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カムパネルラは、その紙切れが何だったか待ちかねたというように急いでのぞきこみました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……リンリン、リンリンリンリンリンリンリン……　眉香子はその音の切れるのを待ちかねて受話機を取り上げた。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後になるのを待ちかねて、野球を見に行ったが、そのうちにやっと落着いて家に帰れた。",
              "citation": {
                "source": "道成寺不見記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "品物の届く時刻を待ちかねて門の外へ幾度か見に出たりした。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんがお待ちかねよ」　といった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「若様もお待ちかねよ」　ともう一人のがいった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お待ちかねでした」といつて案内する女中に導かれて三階の一室にはいつて行つた時には、おんつぁんも、勃凸も、Ｉも最上の元気で食卓を囲んでゐた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大膳職はさっきからそのご命を待ちかねてうろうろうろうろ廚の中を歩きまわっております」　「ふう。",
              "citation": {
                "source": "四又の百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまで待っても出て来ないので、その一人が待ちかねて戸を開けようとすると、やはり開かない。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、母のお由は待ちかねてまた訊いた。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻木君の言葉の続きを待ちかねた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は妻木君が出てゆくのを待ちかねて違い棚の上に露出しに並んでいる四ツの鼓を見た。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして夜のあけるのを待ちかねて電車で九段に向った。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ちかねた豚吉は慌ててその間から出ようとしましたが、まだ出られませんので、又一本外しましたが、まだ出られません。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして日曜日を待ちかねて、母親を慰めに行くことが聯隊中の評判になったので、遂に聯隊長から表彰された。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それにしても様子がおかしいというので、評議が区々になっていたが、あくる朝を待ちかねて人々が、荒物屋に集まってみると、果して、事件の真相が詳しく新聞に出ていた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆も待ちかねている事でしょう。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "入道さまは法名を蓮胤と申して居られましたが、その蓮胤さまが、けふ御ところにおいでになるといふので私たちも緊張し、また将軍家に於いても、その日は朝からお待ちかねの御様子でございました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "裁縫師は不思議でたまらないので、朝になるのを待ちかねて相場師の家へ往って見た。",
              "citation": {
                "source": "娘の生霊",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄造は待ちかねていて座敷へ呼び入れた。",
              "citation": {
                "source": "狸と俳人",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「待ちかねたよ、お袖さん」「え」　お袖は其処ではお紋と云うことにしていたので驚いた。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔦芳は夜の明けるのを待ちかねて、菊五郎の許へ駆けつけた。",
              "citation": {
                "source": "幽霊の衣裳",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "許宣の往く時間を知って待ちかねていたかのように小婢が出て来た。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の暮れるのを待ちかねて、わたくしは堤の芒をかきわけて行くと、あなたが先に来て釣りをしておいでなさる。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを待ちかねて町から続々上京する者がある。",
              "citation": {
                "source": "指輪一つ",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
