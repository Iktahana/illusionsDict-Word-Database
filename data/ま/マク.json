[
  {
    "uuid": "8341d784-0e2e-5009-8828-e4ffec0ea718",
    "entry": "巻く",
    "reading": {
      "primary": "まく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-カ行",
        "動詞-他動詞"
      ],
