      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to wind",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "次第に、谷が蹙って来る、水は、大石の下に渦を巻く。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧はフツ、フツと渦巻く、偃松に白く絡んで、火事場の烟でも立つように、虚空を迷っている、天幕の屋根の筋目から仰ぐと、暗灰色の虚空が壁のように狭くなって、鼻の先に突っ立っている、雨と知りながらも、手を天幕の外へ出すと、壁から浸染み出る小雨に、五本の指が冷やりとする、眼がやっと醒める。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち送ろうと思うものが写真ならば、これを薄い金属板に焼付けこれを前のコルン式同様に円筒に巻く。",
              "citation": {
                "source": "写真電送の新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体卵が産み出さるる前にどんな道筋を経て来るかというに、始め卵黄だけが輸卵管へ出て来ると、そこで白味が来て取り巻く、これに膜が出来てその上に殻が分泌され管から押し出されるうちに固まってしまう。",
              "citation": {
                "source": "卵の形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもし一室の内をぐるりと取り巻く大きな硝子管の中が一体に光るようなものが出来れば、この不便をよほどなくする事が出来るだろう。",
              "citation": {
                "source": "ムーア灯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはひそかに無性な触覚の気安さから一たび風が吹き出すと、吹雪のように中空に、地上に舞い立ち渦巻くあわただしさと変った。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界的百貨店、ウェルトハイムの大飾窓に煌めく満天の星、神木の木の下の女神を取巻く小鳥、獣類、人間の小児、それらを囲る幽邃な背景が、エンジンの回転仕掛けで、めぐる、めぐる。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "越知　「オチ」は水の渦を巻く義。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫色の衣服をつけたお六が、私の肩に手を巻くとそっぽを向いて煙草の黄色いけむりを吐きだした。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻脚絆を巻くのがおそく、整列におくれて、たび／＼一緒に聯隊本部一週の早駈けをやらされたものだ。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い繃帯は、巻くそばから紅く染った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "取ると、……むら／＼と一巻、渦を巻くやうに成つて、湯気が、鍋の中から、朦と立つ。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌々夜の秋田市では、博士を蝶の取巻くこと、大略斯の通りであつた。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この綿打ち作業は一度も見たことはないが、話に聞いたところでは、鯨の筋を張った弓の弦で綿の小団塊を根気よくたたいてたたきほごしてその繊維を一度空中に飛散させ、それを沈積させて薄膜状としたのを、巻き紙を巻くように巻いて円筒状とするのだそうである。",
              "citation": {
                "source": "糸車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓦焼場の煙渦巻く瓦町を抜けて太宰府へ通う田圃の中の一本道の東側。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その巨石を取巻く大小の墓の前には、それぞれに紅と白の桃の花が美しく挿し並べて在ったが、その墓の間々へ物見高い近隣の町の者や、通りかかりの肥汲みの百姓や柴売り、又は近道伝の太宰府参りらしい町人なんどが真黒く、犇々と押しかけて、中央の白い花崗岩の石甃の上を、折重なるように凝視している。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "千両箱の山を積んでもこの楽しみばっかりは、お譲りする訳に参りませんので……ヘエ……」　松倉十内は又しても余計な事を言ったために、非人風情に吹き巻くられた形になったので、スッカリ苦り切ってしまった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの少年らも驚いて、豊吉を怪しそうに見て、急に糸を巻くやら籠を上げるやら、こそこそと逃げていってしまった。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローマを取巻く丘のように程のよい高さで盛り上る肉付きのまん中に一円銀貨の片面が少し曇って濡れていた。",
              "citation": {
                "source": "汗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "取巻く、人数が、「退いた、退いた、退いた。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "団々として渦巻く煤烟は、右舷を掠めて、陸の方に頽れつつ、長く水面に横わりて、遠く暮色に雑わりつ。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は縁下より、ばらばらとその行く方を取巻く。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲霧深くして、遠く那須野の茫々たる平原を一眸に収める事の出来ぬのは遺憾であったが、脚下に渦巻く雲の海の間から、さながら大洋中の群島のように、緑深き山々の頭を突出している有様は、実になんともいう事の出来ぬ雄大なる光景であった。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "風上にいる者は雨の飛沫を受けるだけで我慢もなるが、風下にいる連中は渦巻く煙に咽び返って眼玉を真赤にし、クンクン狸のように鼻ばかり鳴らしている。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし雲巌寺を出発してから行く途々、渓流に沿うて断岸の上から眼下を見れば、この渓流には瀑布もあれば、泡立ち流るる早瀬もあり、また物凄く渦巻く深淵などもあって、好奇に盥に乗って下ろうものなら、二人や三人土左衛門と改名したかも知れぬのだ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」車夫は輪軸を検せんとて梶棒を下すを暗号に、おでん燗酒、茄小豆、大福餅の屋台｜店に、先刻より埋伏して待懸けたる、車夫、日雇取、立ン坊、七八人、礫のごとくばらりと出で、腕車の周囲を押取巻く。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ崖の客の盲いたるは、紫鉛筆の粉のためといい伝えて、いずれも意外の毒に舌を巻くばかり。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "博徒、衆ともに下より取巻く。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわり、牛が三頭、犢を一頭連れて、雌雄の、どれもずずんと大く真黒なのが、前途の細道を巴形に塞いで、悠々と遊んでいた、渦が巻くようである。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と紫玉はもう褄を巻くように、爪尖を揃えながら、「でも何だか。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
