        "examples": {
          "standard": [
            {
              "text": "今年の夏休みは、家族で馬来西亜のクアラルンプールへ行く予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "馬来西亜は多民族国家であり、食文化も非常に豊かだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "日本のメーカーが馬来西亜に新しい工場を建設した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "マレーシア、タイワン、スマトラ、ベトナム、そうして多分日本で恙虫病原体はラットおよびマウスを通過しているだろう。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "マレーシアでも脚気は根深い問題であった。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "マレーシア医学研究所の研究員たちはオランダの研究を学び、ニワトリを使って独自の研究を始めた。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "この会議には日本、ジャワ、マレーシア、タイ、スリランカおよび現在ベトナムと呼ばれている地域からフランス代表が出席した。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            }
          ]
        }
