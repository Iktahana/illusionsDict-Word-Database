    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Manchukuo (Japanese Manchurian puppet state; 1932-1945)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "満州国がどうして日本帝国がどうかしたといったような事を言って相手を捜している。",
              "citation": {
                "source": "軽井沢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "北方教育と呼ばれるこうした教育実践が、東北の教師たちに広がっていくその一方で、一九三一（昭和六）年、日本は満州事変を引き起こし、翌年、傀儡政権を立てて満州国の建国を宣言します。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮半島もずっと北の方で、満州国にちかいところの、さびしい港町でありました。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし女や子供まで全部が満州国やシベリヤ、または南洋に行って戦争をやるのではありません。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "満州国の鉄の埋蔵量もすばらしい。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "石炭は日本内にも相当にあるが、満州国の東半分は、どこを掘っても豊富な石炭が出て来る。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　満州国の東亜連盟防衛上に於ける責務真に重大なり。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和七年夏、私は満州国を去り、暮には国際連盟の総会に派遣されてジュネーブに赴いた。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮、満州国、支那に於ける日本の困難は皆この道義心｜微かなる結果である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は昭和七年八月満州国を去りこの協和会の声明は知らないでいたが、昭和八年六月某参謀本部部員から「石原は海軍論者なりという上官多し、意見を書いてくれ」と要求せられた。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに同年九月十五日の満州国承認記念日に、陸相板垣中将がその講演に東亜連盟の名称を用いられた。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "国家主義の時代から国家連合の時代を迎えた今日、民族問題は世界の大問題であり、日本民族も明治以来朝鮮、台湾、満州国に於て他民族との協同に於て殆んど例外なく失敗して来たった事を深く考え、皇道に基づき正しき道義観を確立せねばならぬ。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "満州国内に於ける民族協和運動は今日まで遺憾ながらまだ成功してはいない。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、東ソ連の航空基地は満州国境から何れも（西方は別として）余り遠くなく、しかも極東には有利なる空爆目標に乏しいのであるから、対ソ陸軍航空部隊は軽快で特に速度の大なるものが有利と考えられる。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄資源としては日本は砂鉄は世界無比豊富であり、満州国の鉄はその埋蔵量莫大である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三節　満州国の責務　ソ連が東亜連盟を侵す径路は三つある。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一は満州国であり、第二は外蒙方面より蒙疆地方への侵入、第三は新疆方面である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "満州国の喪失は東亜連盟のためほとんど致命的と言える。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "満州国は東亜連盟対ソ国防の根拠地である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "東亜連盟が直接新疆を防衛する事は至難であるが、満州国のソ領沿海州に対する有利な位置は在満州国の兵備が充実しておれば間接に新疆方面をも防衛することとなる。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大切な満州国の国防は、日満議定書に依り日満両国軍隊共同これに当るのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "満州軍の不安は実に満州国の不安を示しているのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "満州国内に於て民族協和の実が漸次現われ、民心比較的安定した支那事変勃発頃の満州軍は、恐らく最良の状態にあったものと思う。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "満州軍は要は満州国の鏡とも見る事が出来る。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那事変に於ける漢民族の勇敢さを見ても、満州国が真にその建国精神を守り、正しく発展するならば満州軍は最も有力なる我らの友軍である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し満州軍に不信ならば満州国人の心理に深く注意すべく、自ら満州国の民心を把握していない事を覚らねばならぬ。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "満州国の民心安定を欠く時は共産党の工作が進展して来る。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "満州国防衛の第一主義は民心の把握であり、建国精神、即ち民族協和の実践である事を銘心せねばならぬ。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
