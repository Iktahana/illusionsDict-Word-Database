        "examples": {
          "standard": [
            {
              "text": "春の庭で、丸っこい体をしたマルハナバチがラベンダーの蜜を吸っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "マルハナバチは温厚な性格で、こちらから刺激しない限り刺してくることはない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子供たちが、モコモコしたマルハナバチが飛ぶ様子を不思議そうに眺めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "おかの　てっぺんぺんにある　まるはなばちの　すから　かっぱらってきた　ものでした。",
              "citation": {
                "source": "きたりすナトキンのはなし",
                "author": "THE TALE OF SQUIRREL NUTKIN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と　まるはなばちの　おんなのこが　しゃべります。",
              "citation": {
