    "definitions": [
      {
        "index": 1,
        "gloss": "Matsuzakaya (major Japanese department store chain)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――銀座松坂屋の屋上にて――無用の書物蒼白の人路上に書物を賣れるを見たり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩崎の森の梢に松坂屋の照明が見える。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "広小路の松坂屋へはいって見ると歳末日曜の人出で言葉通り身動きの出来ない混雑である。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またことしの初夏には松坂屋の展覧会で昔の手織り縞のコレクションを見て同じようななつかしさを感じた。",
              "citation": {
                "source": "糸車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか上野の松坂屋の七階の食堂の北側の窓のそばに席を占めて山下の公園前停留場をながめていた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、松坂屋の前を越して、あすこは、黒門町を曲ろうとする処だ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――貴族鼠の※高縮緬の五紋なる單衣を曳きて、帶は海松地に裝束切模の色紙散の七絲……淡紅色紋絽の長襦袢――　とあれば、かくの如く、お出入の松坂屋へあつらへる。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辺まで付き合ってくれないかと言うから、お金はいけないから、靴足袋の一足も買ってやりましょうと思って、上野の松坂屋まで行って、靴足袋とワイシャツを買って、坊やと三人で食堂で幕の内を食べて別れたけれど、男もああなると駄目ね。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "一通はお母さんへ、松坂屋から夏物売出しのご案内。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "散財さえしてくれなんだら、わてだけの力であんたを養生させられた筈や」　柳吉と一緒に湯崎から大阪へ帰ると、蝶子は松坂屋の裏に二階借りした。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和四年十一月、渋柿）　　　　　　　＊　上野｜松坂屋七階食堂の食卓に空席を捜しあてて腰を下ろした。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕車に乗った時は私一人雪の降る中をよろけて来たから、ちょうど伊藤松坂屋の前の処で、旦那召しまし、と言ったら、ああ遣ってくれ、といって乗ったそうだ。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お聞き申しますと悪いことばかり、お宅から召したお腕車は破れたでしょう、松坂屋の前からのは、間違えて飛んだ処へお連れ申しますし、お時計はなくなります。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、自動車が松坂屋の前にさしかゝった時、信一郎は、やっと――と言っても、たゞ一分間ばかり黙っていたのに過ぎないが――会話の緒を見付けた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "松坂屋の前へ参りましたが、恋しきあなたのお姿が見えません。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び松坂屋のところへ引返してお捜ししたのですけれど、遂に懐しいあなたのお姿は見当りませんでした。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（余談だが、彼女は人眼をひくような綺麗な顔をしているので、黙っていても男工たちが工場からの帰りに、彼女を誘って白木屋の分店や松坂屋へ連れて行って、色々のものを買ってくれた。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そら、そこに三越とか松坂屋の包紙が沢山あるだろう。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　工場で一寸眼につく綺麗な女工だと、大抵監督のオヤジから、係の責任者から、仲間の男工から買物をしてもらったり、松坂屋に連れて行ってもらったり、一緒に「しるこ屋」に行っておごってもらったりする。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、小銃は雁鍋の二階から、大砲は松坂屋から打ち込んだが、別して湯島切通し、榊原の下屋敷、今の岩崎の別荘の高台から、上野の山の横ッ腹へ、中堂を目標に打ち込んだ大砲が彰義隊の致命傷となったのだといいます。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "上野戦争当時のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこし前に、東京上野の松坂屋で、１９９９年の科学時代の展覧会があって、そこに人造人間が舞台に立ち、みなさんと交歓した。",
              "citation": {
                "source": "人造物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年上野の松坂屋の１９９９年展覧会で出演したロボットは、どんなことを、どんな言葉できいても、即座に返事をした。",
              "citation": {
                "source": "人造物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、自動車が松坂屋の前にさしかゝつた時、信一郎は、やつと――と言つても、たゞ一分間ばかり黙つてゐたのに過ぎないが――会話の緒を見付けた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、大津町筋を南にさがると、松坂屋デパートがあり、昨今はどうやら、そちらへ中心点が移動しさうであるが、広小路をはなれて中心点をつくることは当分はどうもむづかしさうである。",
              "citation": {
                "source": "名古屋スケツチ",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "松坂屋は感じのよい百貨店、賑うて居た、食料品部を通りぬけるとき、人間の胃袋の大きく強いことを考へさせられた！",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "行進が上野の山へ集合した頃、私たちは群集におされながら、松坂屋の先の、時計屋の大きい飾窓の下におしつけられていた。",
              "citation": {
                "source": "メーデーに歌う",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は新規に誂えるまでもなく、松坂屋あたりの店で見つけた出来で間に合わせて、唯寸法だけを少し詰めて貰ったとも言った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日の晩松坂屋がやけ始め　四日の朝六時に不忍池の彼方側ですっかり火がしずまった。",
              "citation": {
                "source": "大正十二年九月一日よりの東京・横浜間大震火災についての記録",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の老婆をどうして逃そうかと、松坂屋に火のついたとき、心配此上なかった。",
              "citation": {
                "source": "大正十二年九月一日よりの東京・横浜間大震火災についての記録",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
