        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "最近の外交文書もワルマ卿が書いたマル秘だ。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "このマル秘資料のほかにも証拠を持っています。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "次つぎ止まるひまなしにつくつく法師が鳴いた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄砲で打たれたり、波に呑まれたり、飢えたり、病んだり、巣のあたたまるひまもない悲しさ。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、ご婚礼のおいわいは、まるひと月もつづきました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "東の南の背の高い、よく雀が来てとまるひば、一杯の引かぶった松、あすなろう。",
              "citation": {
                "source": "一九二三年冬",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあざっとこんな風で、体の休まるひまはまるっきりないと言ってもいいのである。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかるさわぎがあろうとは夢にも思わなかった久保井校長は、五人の子と夫人と、女中とそれから八十にあまるひとりの老母と共にあらわれた。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "柄にもなく真剣に女中を口説いて、案の定口説きそこねて、その一日の酒肴費からこんな宿屋へ泊つたことも、こんな土地へ来たことも、眺めた景色も、くそ忌々しいまるまるひとつの大損だつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも、しょっちゅうこんなふうで、われとわが身に責め立てられて、心のやすまるひまもない。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に、あなたがご亭主といっしょにここへ見えると、それまでせっせと働いて、その辺をごそごそやって、何かこう仕事らしいことをしていた連中が、忽ちみんな仕事をうっちゃらかして、まるひと夏というもの、ご主人の痛風だの、あなたのことだので、無我夢中になってしまうんだからなあ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "金が庄内を出たと聞くと、屋敷の南どなりの金魚屋を居ぬきで買っちまい、金蔵のましたを通して池を神田川まで掘りぬき、まるひと月のあいだ、池のほうから金蔵の土台へせっせと水を流していたんです。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "両国の大鯨",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに集まるひとびとは、いわゆる、大東京の通人たちである。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "きらいでない、という線からはじまるひろくぼんやりしたこころもちの、どの地点に蜂谷良作はおかれるのだろう。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "殆どいちように、このベンチに集まるひとびとは、みな疲れ込んで、なりも汚れていたし、顔という顔には当然現われるべき疲労と倦怠、つぎには悲しげな苛苛した貧しさをたたえていたのである。",
              "citation": {
                "source": "幻影の都市",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、おれはまるひと月……』　けれど、彼はことばでも叫びでも、自分の興奮を現わすことができなかった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはりまるひと月も、人と話をしなかったようなあんばいだった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "『わたしはまるひと月、歯痛に悩んだことがあるから、確かに快感のあることを知っていますよ。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなければ、二週間待ったって、三週間待ったって、まるひと月待ったって……　けれど、わたしがどんなに意地を張ってみても、結局はやはり彼の勝利だった。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は、すこしはじぶんの勉強にもなるつもりで、ほんの数人の患者でもきてくれればけっこうだと、思っていられたのかもしれませんが、こんな田舎に、めずらしい名医がおいでになったといううわさが、人から人へつたわって、朝から晩まで患者がたえず、今では博士も、ろくろくからだのやすまるひまとてもないのです。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――うちのにお燗番をさせちゃだめですよ、燗のつくまえに飲んじまいますからね」　すると脇にいた女が、それではおまえさんの燗鍋はいつも温まるひまがないだろう、など云い、きゃあと笑い罵りあった。",
              "citation": {
                "source": "雨あがる",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後醍醐以下、侍者の公卿や典侍らの身をあずかってから、すでに早や一年ちかくにはなるが、隠岐ノ判官清高の立場は、一日も心のやすまるひまはなかった。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊氏はいぜん心の安まるひまはなかった。",
              "citation": {
                "source": "私本太平記",
                "author": "黒白帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
