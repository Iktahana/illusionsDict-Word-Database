    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to excel",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "でこれを云い換えて見ると、情調的の歌は味いをもって勝り、思想的材料的の歌は要素をもって勝ると云えるのである。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ今日のような世の中でも、場合によってはかえってこの頃のいろいろの人聞きのいいデーに勝る事がないとも限らない。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は千の新を合わせて、なおかつ勝ること千の新なるべき異常の面魂なりき。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "七歳の童児なりとも、我に勝るものには我れ即ち彼に問はん、百歳の老翁なりとも我に及ばざる者には我れ即ち侘を教へんと云つて、南泉といふ禅坊さんの所へ行つて二十年間｜倦まずに修業を継続したのだから、卒業した時にはもう八十になつてしまつたのである。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「体は衣に勝るならずや」とあるを未だ読まぬか。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ其の三者の佳致を併有して、一編の奇話を構成するところは、女仙外史の西遊水滸三国諸書に勝る所以にして、其の大体の風度は平妖伝に似たりというべし。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "○参分｜勝る有つて、而して誅せず。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "参分勝る有るは天下を三分して其二を保有するを言ふ。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄弟にのみ挨拶すとも何の勝ることかある、異邦人も然するにあらずや。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いのちは糧にまさり、からだは衣に勝るならずや。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども去て吉野の物さびたる造化の深き峰のあたりに見るに、其美、其妙、塵垢に近き墨※の外に勝る事幾倍なるを知るべし。",
              "citation": {
                "source": "「伽羅枕」及び「新葉末集」",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬なく導くもの曰く、澁の山道高拔の態之に勝るものをみずと。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ、かく思ひて其の夜すがら三坂峠を越え行くに、九十九折なる山道は、聞きしに勝る難所なり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「梅津只圓という者は聞きしに勝る立派な人物である。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "真柄と忠勝とが、三十余合撃ち合ったとすれば、戦国時代の一騎討として、これに勝るメイン・エヴェントはないわけだが、本当は矢張り、匂坂兄弟に撃たれたのであろう。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "信長の弟勘十郎信行の折目正しい肩衣袴で慇懃に礼拝したのとひき比べて人々は、なる程信長公は聞きしに勝る大馬鹿者だと嘲り合った。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「第一発見者に勝る者はない。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "媼は我に向ひて、カムパニアの馬に勝るべき足どりの駒なり、幸運の門出は今ぞとさゝやきぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば、この書を著すは、素よりこの苦悶を忘れんとての業には非ず、否筆を執るその事もなかなか苦悶の種たるなり、一字は一字より、一行は一行より、苦悶は弥※勝るのみ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦悶はいよいよ勝るのみ、されど、妾強ちにこれを忘れんことを願わず、否昔｜懐かしの想いは、その一字に一行に苦悩と共に弥増すなり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この深遠なる疑問に対し答うる所二個あるのみ、すなわち神なるものは存在せざるなり、この地球に勝る世界の義人のために備えらるるあり。",
              "citation": {
                "source": "基督信徒のなぐさめ",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "不治の病怖るるに足らず、快復の望なお存するあり、これに耐ゆるの慰と快楽あり、生命に勝る宝と希望とを汝の有するあり、また病中の天職あるあり、汝は絶望すべきにあらざるなり。",
              "citation": {
                "source": "基督信徒のなぐさめ",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に二十章のゾパルのヨブ攻撃は実に辛辣非礼を極めたもので、十八章のビルダデの攻撃に勝るも劣らぬものであるが、これに対してヨブは甚だ平静であって決して激語を以て酬いず、遂には進で自己を罪人となし神を赦し得るに至るのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩いた後の一盞は正しく百薬に勝るものを沁々と覚えさせられ、近くは半島を出でゝ遥かなる旅路の彼方に恍忽の夢を結ばうと画策してゐる次第である。",
              "citation": {
                "source": "或るハイカーの記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎もあれ百薬に勝る一盞は、ハイキングの賜物であつた。",
              "citation": {
                "source": "或るハイカーの記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が幸福を得ようと思って他人に福恵を与えるのは、善美を尽したものではないけれども、福は植えなくてはならないと覚悟して植福の事に従うのは、福を植えないことに勝ること万々である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし道を同じくし信じるものを等しくする者が相得て喜ぶことはこれに勝る。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮はその身の上の日毎輝き勝るままに、いよいよ意中の人と私すべき陰無くなりゆくを見て、愈よ楽まざる心は、夫の愛を承くるに慵くて、唯機械の如く事ふるに過ぎざりしも、唯継は彼の言ふ花の姿、温き玉の容を一向に愛で悦ぶ余に、冷かに空き器を抱くに異らざる妻を擁して、殆ど憎むべきまでに得意の頤を撫づるなりき。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "『華厳経』に一切宝中如意宝珠最も勝るとあり。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "――郷土望景詩――昨日にまさる戀しさの昨日にまさる戀しさの湧きくる如く高まるを忍びてこらへ何時までか惱みに生くるものならむ。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
