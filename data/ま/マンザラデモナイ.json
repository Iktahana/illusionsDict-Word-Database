        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "満更でもないと思った。",
              "citation": {
                "source": "わが文学修業",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「莫迦――」男爵は、満更でもない様子で、ニヤリと笑って、真弓の逃げてゆくあとを、見送った。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "写真屋がうまくこしらえたところもあろうけれど、これなら満更でもないと私は眺め入った。",
              "citation": {
                "source": "縁談",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そいつは良い事に気が付いてくれた、甥の八五郎より、立派な御用聞になれるぜ叔母さん」「まア、それ程でも無いでしょうよ」　などと、叔母さんは満更でもない様子です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "群盗",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オペラの怪人」という綽名を友人達から貰って、顔をしかめ、けれども内心まんざらでもないのでした。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五箇年間に千五百部といえば、一箇月間に十万部も売れる評判小説にくらべて、いかにも見すぼらしく貧寒の感じがするけれど、一日に一冊ずつ売れたというと、まんざらでもない。",
              "citation": {
                "source": "「晩年」と「女生徒」",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女を自分｜許りのものだと引っ張り寄せるように右腕で女の左腕を抱き寄せて居るが、女はそれがまんざらでもないらしくあしらい乍ら強いて彼に引き寄せられまいとしてジョーンの左腕にすがって居るようにも見える。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十吉はずいぶん派手なところを見せ、椙の機嫌とるための芝居見物にも思いきった使い方するのを、椙はさすがに女でまんざらでもないらしかった。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫌なこと続きで疎ましく感じ始めていたこの町を、オレはまんざらでもないではないかと思った。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "年は二十二だといいますから、甚吉や伊兵衛と同い年で、容貌はまんざらでもない女でした。",
              "citation": {
                "source": "真鬼偽鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「母親さんは自分が清元が出来るもんだからそんな事をお言いだけれども、長唄の方が好サ」「長唄も岡安ならまんざらでもないけれども、松永は唯つッこむばかりで面白くもなんとも有りゃアしない。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ほう、わかるか、それならまんざらでもないな。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "うん、これあまんざらでもないぞ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸奥出の三才駒だっていうから、まんざらでもないわね。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどまんざらでもないようであるというので、そのお婆さんの言う通りにやって見ると、初めて見事にそれが成功した。",
              "citation": {
                "source": "自力更生より自然力更生へ",
                "author": "三澤勝衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "……とするとまんざらでもない年じゃ」　ここで兵庫は菊女の方を見た。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――まんざらでもない顔してやがる――　彼は、私の顔みて、そう云ったのです。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まんざらでもないって、どんなこと、私ききました。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そういわれて、まんざらでもない表情が顔色にあらわれる。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "吸えばまんざらでもない気がした。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「丁が余る、丁が余る……いかがです、旦那、負けときますぜ、やすめを一つお買いになっては……」「へ、へ、へ」　前のよりはいっそう人のよかりそうな、純乎たる素人が、ワナを眼の前につきつけられて、まんざらでもない心持。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫くしている間に、最初にしたり面をして出た半黒人も、まんざらでもない心持の純素人も、グルグルとグループの中へ捲き込まれてしまうと、中盆が得意になって、「運賦天賦のものですから、本職だって勝つときまったものではなし、ドコへ福がぶっつかるかわかりませんや」　いざやと壺振りが、勢い込んで身構えをする。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったん、やめて見た酒も、口あたりのよいやつを鼻の先へ持って来ると、まんざらでもない。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間を曲る横町で、一寸人の知らない寂しいところだが、しもた屋つゞきの二階には簾がさげてあつたり植木鉢が置いてあつたり、三味線の音が聞えたりして、まんざらでもない処だ。",
              "citation": {
                "source": "来訪者",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "まんざらでもない証拠だ。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙管ならそっちにあるじゃねえか」「お前さんの煙管でのみたいのさ」「へん、安手な殺し文句だ」「でも、まんざらでもないでしょうよ」「こんどは押し売りと来やがったな。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こう云ったのは鬼火の姥で、いくらか荒んでいるけれど、なかなか美貌の大弥太に対し、まんざらでもない心から、その歓心を迎えるように、こう追従らしく云ったのであった。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右衛門の勝利に見えていたが、俄然近頃は手の裏返すように、あったら遊君とは云われる島君、当世流に襟元に着いてあの悪者の紋十郎めに、まんざらでもない素振りを見せ、へばり付いているという事じゃ」「どうじゃな気の毒な右衛門は、さぞ悲しんでいるであろうの？",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかが巷談師に向って、人民の怨嗟は大きすぎると思うが、こう言われてみると、私の筆力にヒットラーの妖怪味がはらまれているようにも幻想し、まんざらでもない気持にさせられたのである。",
              "citation": {
                "source": "巷談師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中はよくしたもので、まんざらでもないとみえますよ」「だッ……だまされたのだッ！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
