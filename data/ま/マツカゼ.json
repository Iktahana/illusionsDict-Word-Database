[
  {
    "uuid": "11ddb739-a8c2-5868-a4fa-45d460b2f3d0",
    "entry": "松風",
    "reading": {
      "primary": "まつかぜ",
      "alternatives": [
        "しょうふう"
      ],
      "is_heteronym": false
    },
    "grammar": {
