      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Buddhist lantern festival",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "妾達の小屋はセエヌ左岸のアルマの橋を渡ったところに、日本画の万灯に飾られて、富士山や田園の書割にかこまれて、賑かにメリンスの友禅の魅力を場末の巴里人に挨拶していたのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時田町の方から小供の群が万灯をかついで、景気よく押寄せて来ましたが、手風琴の仲間を見るや『万歳！",
              "citation": {
                "source": "夜の赤坂",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "万灯は動く、手風琴は出たらめに鳴りだす。",
              "citation": {
                "source": "夜の赤坂",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "加えて波上の炎々たる水雷火、その魚鱗火、連弾光、鵜舟の篝、遊覧船の万灯、提灯、手投げの白金光、五彩の変々たる点々光、流出柳箭、けだし参と信との花火芸術の最高を極め精を尽くし神を凝らしたものであった。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜とともに眼ざめる万灯の巷。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡そ江戸ッ児として、大若小若の万灯、樽天王を見て気勢わぬものは一人もなく、ワッショイ！",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "向こうの藁葺屋根の暗い軒端に、祭礼と書いた赤い万灯が立て掛けてあって、それが雨に濡れて字が滲み、ぽたぽたと赤い雫を落としていた。",
              "citation": {
                "source": "雨の回想",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "万灯の列の中を過ぎ行くように明るい。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "春日風の朱塗門を入ると、日本画に漢詩や狂歌の賛のある万灯が客を中央の池へ導く。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその時、堯の姿が、万灯を持って飛びはねてる堯の姿が、はっきり私の頭に映じた。",
              "citation": {
                "source": "生と死との記録",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホンコンの夜景は海上より一見するに、全市万灯中にうずめらるるの趣あり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "峰巒繞海海如湖、船与船連舳抱艫、入夜港頭更添趣、万灯光裏泛全都。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "一水二条貫市流、岸頭茶店幾層楼、夜深猶聴電車走、人在万灯光底遊。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は万灯の光のもとに遊歩しているのである。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "遼湾風浪晩来恬、涼月印天形似鎌、入夜港頭却多趣、万灯影裏一峰尖。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚、本堂にて厄除の万灯を奉納し、厄除の守を受け、又、寺務所に於て、厄除祈祷を申込まるべし”　この祈願、年に一度かと思つたらさうでなく、旧の正月、旧の五月、旧の九月、旧の十二月と、しば／＼行はれるらしい。",
              "citation": {
                "source": "にはかへんろ記",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また二十六日、すなわち大地震の前夜には八時ごろから十時ごろまで、赤神山に幾千万の光り物が、万灯のように赤く輝いたと、「乾坤相克記」に記してある。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思えば、貧者の一灯、長者の万灯、太平洋横断飛行に、東京、無名氏より、金一万円寄附の記事が、同じ新聞に掲げられる。",
              "citation": {
                "source": "青バスの女",
                "author": "辰野九紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一尺の提灯独楽、心棒を引き上げると二尺余りの長提灯になったり、正面に四方開きの花万灯、独楽が欄干づたいにその中へことりと消える。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "万灯はパッと開いて真白な鶏に変ったり、まずこの種の華やかな芸当、その間にちょいちょい得意の早変り、水芸には女の弟子が二人左右に並んで、独楽を使いながら扇子の先や独楽の心棒から盛んに噴水、私は見ないが水中飛込みの早変りも藤治の十八番。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "とちゅう、にぎやかな町の上を通りましたが、キラキラひかる町の灯が、まるで万灯流しのようで、じつにきれいでした。",
              "citation": {
                "source": "宇宙怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アキハバラ」「タカダノババ」の今日では、今夏、あるところへ書いた私の小説など、校正注意と欄外へ朱書までしておいたのに、「駒形堂」を「こまんどう」とはルビしてくれず、むざんや、標準語で「コマカタドウ」でアリマシタ。",
              "citation": {
                "source": "寄席行燈",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
