  {
    "uuid": "92a5ef33-ad4d-518b-981f-277c8c6a1fbc",
    "entry": "マナ",
    "reading": {
      "primary": "マナ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "manna",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "谷が狭くなって、崖側を行くと、緩いながらも雪の傾斜で辷るから、ミヤマナナカマドの枝を捉えながら上る、前にも増した雪の断裂で、草鞋に踏み蹂った雪片は、山桜の葩弁のように、白く光ってあたりに飛び散る。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "虎杖や去年の実を結んだままのハマナシ（コケモモ）が、砂の上にしがみついている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲ハ経紙ノ紺ニ暮レ、　　　　　樹ハカグロナル山山ニ、梢螺鈿ノサマナシテ、　　　　　コトトフコロトナリニケリ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガイ・マナリングやロブ・ロイやアンドルウ・フェアサーヴィスなどを。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汀から二間と隔たらない所、大きなタマナ樹の茂みの下、濃い茄子色の影の中で私は晝寢をしてゐたのである。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸のタマナ竝木の蔭のはづれ迄來た時、向ふから陽に灼けた砂の上を素裸の小さい男の子が駈けて來た。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年について一歩日向の砂の上に踏出した時、タマナ樹の梢から眞白な一羽のソホーソホ鳥（島民が斯う呼ぶのは鳴き聲からであるが、内地人は其の形から飛行機鳥と名付けてゐる）が、バタ／＼と舞上つて、忽ち、高く眩しい碧空に消えて行つた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し、ギラ・コシサンがキッパリとあのモゴルの女と切れた上で、自ら遥々カヤンガル島に渡り、其の地の名産たるタマナ樹で豪勢な舞踊台を作らせ、それを持帰った上で、其の披露｜旁々二人の夫婦固めの式を行うという条件つきである。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰好なタマナ材は直ぐに切出されたが、舞踊台の製作には大変暇がかかった。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は手を取り合って、鬱蒼たるタマナ樹の茂みの下に歩み去った。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五日すると、エビルと共に白昼タマナの茂みに姿を消した中年男の家に、エビルが公然と入り込んだことを村人は知った。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汀から二間と隔たらない所、大きなタマナ樹の茂みの下、濃い茄子色の影の中で私は昼寝をしていたのである。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸のタマナ並木の蔭のはずれまで来た時、向うから陽に灼けた砂の上を素裸の小さい男の子が駈けて来た。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年について一歩日向の砂の上に踏出した時、タマナ樹の梢から真白な一羽のソホーソホ鳥（島民がこう呼ぶのは鳴き声からであるが、内地人はその形から飛行機鳥と名付けている）が、バタバタと舞上って、たちまち、高く眩しい碧空に消えて行った。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝等の国は近々にも訪れたいのだが予は、いつか生れて初めてマナヅルからアタミまで船に乗つた時に悶絶せんばかりに苦悶した経験を持つて以来、汝の国はガリバーの訪れた国よりも遥かになつてしまつた。",
              "citation": {
                "source": "消息抄（近頃書いた或る私の手紙から。）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "このネタには伏し目がちに笑いを押し殺し気味で臨むのが、聞く側のマナーというものだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アナタノ小説、友人ヨリ雑誌借リテ読ミマシタガ、アレハ、ツマリ、一言モッテ覆エバ、ドンナコトニナルカ、ト詰問サレルコト再三、ソノタビゴトニ悲シク、一言デ言エルコトナラ、一言デ言イマス、アレハアレダケノモノデ、ホカニ言イ様ゴザイマセヌ、以後、ボクノ文章読マナイデ下サイ。",
              "citation": {
                "source": "走ラヌ名馬",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（小熊夫人書き写し）------------------------------------------------------------------マナイタの化けた話　海の水平線に、小さな帆前船が現はれました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタダニといふのはアイヌ達がお台所で使ふマナイタのことです。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると酋長の夢枕に、赤い着物をきた、『マナイタの神様』の姿があらはれました、そしてマナイタの神様は酋長にむかつて、語り出しました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから夕飯の仕度をするのです、魚の乾かしたのを、トン／＼と叩いて柔らかにしたり、獣の肉を切つたりするのに、イタダニ（マナイタ）を使ひました、このマナイタはかんたんなもので、木を一尺程の長さに切つてそれをまたたてに割つたカマボコ型をしたマナイタでした。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて神様は、辺りの獣も狩りつくして少なくなつたので、山小屋をひきあげて、遠くの山奥に移り住むことになりました、そこでそのマナイタもいらなくなつたので、小屋の中に捨てたまゝ出発してしまひました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋の中に残されたマナイタは、主人をうしなつて、さびしい悲しい思ひをしながら誰一人やつて来ない、谷間の小屋にとり残されて何十年となく暮らしてゐました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "マナイタは今にも神様がひよつこりと山小屋にかへつて来るやうに思はれてなりませんでした、毎日毎日主人のかへりを待ちこがれてゐました、しかし神様はこの捨てたマナイタのことなどは考へてはゐなかつたのです。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "その海を流れるマナイタの生活も、それはそれは永い間で、何十年、何百年といふ年月をもう忘れてしまふほど、浮いたり、沈んだり、潮にもまれる、つらい／＼生活をつゞけました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は若者であつたマナイタも今はまつたく腐つてしまつて、見るかげもなく醜い老人となつてしまひました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
