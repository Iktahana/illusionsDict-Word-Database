    "definitions": [
      {
        "index": 1,
        "gloss": "to create (a sensation)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
