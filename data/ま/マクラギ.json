        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たゞ、パルチザンは、枕木の下へ油のついた火種を入れておくだけだった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、枕木は炭焼竈の生木のように、雪の中で点火されぷす／＼燻りながら炭になってしまうのだった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の中で燻る枕木は外へは火も煙も立てなかった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕木はいつの間にか引きぬかれていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全身の力をこめて、うんと枕木を踏んばり、それで前へ押さなきゃならない。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、端から端まで、――女達のいるところから、ケージのおりて来るところまで、――枕木を踏んばり通さなきゃならなかった。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "市三は、枕木を踏んばりだした。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "市三は、大人にまじって土と汗にまみれて、うしろの鉱車に追われながら、枕木を踏んばっていた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕木はうすい灰色曲ったり間隔もずゐぶん不同だ。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡れ渡れ、一体これではあんまり枕木の間隔がせますぎるのだ。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼いた枕木でこさえた小さな家がある。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車のように枕木の上にレールが並べてあって、踏切などをつけた、電車だけの道なのであった。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕木も何もでこぼこだ。",
              "citation": {
                "source": "化物丁場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾燥した枕木の上に、今吐いた唾が黒く泌みこんでいるだけであった。",
              "citation": {
                "source": "線路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずうっと積まれた黒い枕木の向こうに、あの立派な本線のシグナル柱が、今はるかの南から、かがやく白けむりをあげてやって来る列車を迎えるために、その上の硬い腕を下げたところでした。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬がれの木や、つみ重ねられた黒い枕木はもちろんのこと、電信柱までみんな眠ってしまいました。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕木の向こうに青白くしょんぼり立って、赤い火をかかげている軽便鉄道のシグナル、すなわちシグナレスとても全くそのとおりでした。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い枕木はみな眠り、赤の三角や黄色の点々、さまざまの夢を見ている時、若いあわれなシグナルはほっと小さなため息をつきました。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その霧を徹して、月のあかりが水色にしずかに降り、電信柱も枕木も、みんな寝しずまりました。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱車を押す半裸体の馬来人は檳榔子の実を噛んでいて、血の色の唾をちゅっちゅと枕木に吐いた。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "軌道の枕木の間隔が、一歩には狭く、半歩には広く、ひどく意地悪く出来てゐて、甚だ歩きにくかつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっくりと枕木も小砂利も濡れて、右も左も椴松の林が遠い、遠い、遠い。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さわりさわりとその肩の長い棹を弧に、その先きを線路につけて、その鉄橋の枕木の上を拾い拾い渡る男も見えた。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕木は昔ながらに埋設されていた。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "その拍子に右手で軌条を掴んで起き上りかけたが、何故か又グッタリとなって、軌条のすぐ横の枕木の上に突伏した。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は松丸太の枕木の上に腰を下して、スパイクを抜いてゐた。",
              "citation": {
                "source": "万福追想",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "線路脇や、線路の枕木の上を歩るいて、彼が此処までやつてくる途中で何回となく線路工夫に叱り飛ばされたことだらう。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故、枕木にぶら下るつもりが、間違ひてレールにぶら下りしなり。",
              "citation": {
                "source": "多摩川冒險記",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して、前より來たることなれば、枕木にぶら下るの餘裕は十分にあるべしと云へば、友諾す。",
              "citation": {
                "source": "多摩川冒險記",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車が見えたら、枕木にぶら下り給へ。",
              "citation": {
                "source": "多摩川冒險記",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
