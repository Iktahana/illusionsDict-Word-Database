        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "石抱きは十露盤板と称する三角形の板をならべた台のうえに罪人を坐らせて、その膝のうえに石の板を積むので、石は伊豆石にかぎられ、長さ三尺、厚さ三寸、目方は一枚十三貫である。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "奧の方の二階から眺ると、伊豆石で建てた土藏、ナマコ壁、古風な瓦屋根などが見渡される。",
              "citation": {
                "source": "伊豆の旅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "手釣りの黒鯛を沖で叩いて締めた刺身、つづいて丸い伊豆石を敷いた大鉢の中には鮎が見えた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "引きめぐらした伊豆石の塀の上に幾株かの夾竹桃が被さって、その梢を茂らせていた。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊豆石を積重ねた物揚場を隔てて、初夏の水が流れていた。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "石垣の下に見える物揚場の伊豆石、家々の屋根、対岸の道路などは、その度に白く掩われた。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊豆石の御手洗で洗った手を、拭くのを忘れた橘屋の若旦那徳太郎が、お稲荷様への参詣は二の次ぎに、連れの隠居の台詞通り、土へつかない足を浮かせて、飛び込んで来たおせんの見世先。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹹水にも溶けるとか云って大連でくれた豆石鹸でも、行李の底から出せばよかったと思った。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "材木や伊豆石や、城普請の用材をつんだ船が、誇張していえば、舳艫をつらねてといえるほど、江戸湾に、それぞれの藩旗を並べていた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "青銅の大きな燈籠やら、巨きな伊豆石やらが、泉水をかこんでいる。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
