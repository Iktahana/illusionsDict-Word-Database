[
  {
    "uuid": "5dc20d54-14d2-5350-9efe-5a06f020db60",
    "entry": "また木",
    "reading": {
      "primary": "またぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
