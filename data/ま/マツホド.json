        "examples": {
          "standard": [
            {
              "text": "松の根元に生える松塊は、漢方薬の原料として珍重される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "専門家が、松塊の薬効について詳しく説明してくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "松塊は、近年では健康食品としても注目されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "息をこらしてまつほどに、爆音はいよいよ大きくいよいよ近づき、天幕はびりびりと振動をはじめた。",
              "citation": {
                "source": "大空魔艦",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まつほどもなく、明智探偵の自動車が、拘置所の玄関に、着いたので、所長は明智を、ていねいに、自分の部屋へあんないさせました。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
