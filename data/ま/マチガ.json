        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれども、それは、僕のまちがい。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場にはこのまちが始めてのようであったが、べつだん驚きもせずゆったりした歩調で私と少しはなれて歩きながら、両側の小窓小窓の女の顔をひとつひとつ熟察していた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座通りといふ賑やかな美しいまちがある。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて菊池寛氏は某所に於て、今日の如き科學時代には、詩は衰滅の一路をたどるのみだと言つたが、この「科學時代」といふ言葉を、もし菊池氏の主觀に於て、夢を忘れた小常識人や、世渡り上手の小才智人のみが横行する時代、即ち要するに「小常識的俗物時代」といふ意味に解するならば、正にまちがひなく眞理である。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし私が何かまちがったことを云ったらそのむすこらの一人でもすぐに私を外のくらやみに連れ出すだらう。",
              "citation": {
                "source": "丹藤川〔「家長制度」先駆形〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはまちがひのないことである。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてすっかり道をまちがえ、方角を解らなくしてしまった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ、部屋をまちがえた花嫁のようにてれているじゃないか。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボーアをまちがえてポーア／＼と云っているのが気になるので、それだけは訂正しておいた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まちが代りに来て枕元に控えていた。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まかりまちがえば、落っこちて死んじまうんだからね。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺れらだって、ひとつまちがえば、やられていたかもしれないんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「種子をまちがへたんでせう。",
              "citation": {
                "source": "花椰菜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてＫ君の死体が浜辺に打ちあげられてあった、その前日は、まちがいもなく満月ではありませんか。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "身を捨ててこそ浮ぶ瀬あるものでして、と苦労人の忠告、その忠告は、まちがっています。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まちがえたんだ。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下女が風邪でも引いてまちがえて入れたんだ。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にも雀ややまがらやみそさざい、めじろ、ほゝじろ、ひたき、うぐひすなんといふ、いつまでたっても誰にも見まちがはれるてあひなどは、きゃっきゃっ叫んだり、手をつないだりしてはねまはり、さっそくとんびの染屋へ出掛けて行きました。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは君のまちがひだよ。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なぜって第一わたしは花にそんな数字が書いてあるのでなくて、それはこっちの目のまちがいだろうと思うんだ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたらどういう加減か小十郎の柄にもなく登り口をまちがってしまった。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかりみちをまちがったな。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもさっきまちがえて異教徒席に座りそのためにあんな反対演説をしたらしいのです。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の計算にまちがいがあるとはどうもそう思えんね。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれが信じわれわれの行かうとするみちがもしまちがひであったなら究竟の幸福にいたらないならいままっすぐにやって来て私にそれを知らせて呉れ。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝ヒームキャの向こう岸でご説法のをハムラの二人の商人が拝んで参ったと申します」　「そうか、それではまちがいあるまい。",
              "citation": {
                "source": "四又の百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「や、道をまちがえたかな。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして新聞で、あのときの出来事は、肥料の入れようをまちがって教えた農業技師が、オリザの倒れたのをみんな火山局のせいにして、ごまかしていたためだということを読んで、大きな声で一人で笑いました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まちがへたんだ。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下女が風邪でも引いてまちがへて入れたんだ。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
