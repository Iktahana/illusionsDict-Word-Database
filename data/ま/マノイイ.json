        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「そんなものに関係なぞして、あなたは世間のいい笑いものになっていることを知らないんですか。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間のいい顔とはどんな顔つきをさすだろう。",
              "citation": {
                "source": "顔を語る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前夜投げこんで置いて、翌朝縄を引きあげると、間のいい時には二、三匹も鈎に食いついている。",
              "citation": {
                "source": "すっぽん",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いがけないところで出遭った、こんな間のいいことは、願ってもありゃァしないからひとつどこぞで、御飯でもつき合ってもらおうと思ってさ」「おや、それは御親切に、有難うはござんすが、あたしゃいまも申します通り、風邪を引いたお母さんと、お見世へおいでのお客様がござんすから。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこが人間のいいところだ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "王妃さまだって、ハムレットさまのいいところは、ちゃんとご存じの癖に。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もし、わたしがからすでなかったなら、いまのいいなずけをすてても、王女さまとけっこんしたかもしれません。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもいいから、お金を下さる御主人さまのいいつけ通りにしていれば間違いはないんだ」「うむ、やっぱりそうか。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちも、わがままのいい合いをして来たんだからね。",
              "citation": {
                "source": "花園の思想",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "義父は……お祖母さまのいいつけではないという。",
              "citation": {
                "source": "方子と末起",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日ごろ、あたまのいい君にも似合わないぜ」「一体どうしたというんです。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "三浦須美吉といえば、あたまのいい読者諸君は、きっとおぼえているであろう。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それははつきりいつとく」「そんなら、どうでもお父さまのいいやうに……あたしはいいわ」四「あたしは、いいわ」　と、いつてしまふと加寿子は激しく瞬きをした。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日たったところで、王さまのいいつけどおり、お百姓さんは王さまのまえにでました。",
              "citation": {
                "source": "うまい商売",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩の仕度をしかけていた十八ばかりになる女中は、奥さまのいいつけに従って、さっそく汚れた前かけをはずして、出かける用意にとりかかりました。",
              "citation": {
                "source": "おきくと弟",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに、人のいうことを、まっすぐにしか解しなかったお竹も、底意地のわるい、奥さまのいい方がわかって、もうなにもいうことができませんでした。",
              "citation": {
                "source": "だまされた娘とちょうの話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたまのいいひとにとっては、しらべるものだし、あのしごとにんげんにとっては、お金のもと。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎮子姉さまのいい方を借りますと、やはり、機縁とでもいうのでしょうか。",
              "citation": {
                "source": "キャラコさん",
                "author": "月光曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂現地報告が昨秋の流行となって、さまざまのいい加減なものを見せた。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとはそこにも、さまざまのいい伝えが、茂り栄えていたことがありました。",
              "citation": {
                "source": "日本の伝説",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
