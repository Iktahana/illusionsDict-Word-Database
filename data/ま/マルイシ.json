        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "常住｜湿り気の乾ききらないような黒土と混って、大小の丸石が歩む人の足を妨げるようにおびただしく転がっていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小林久兵衛前駆奮撃して重昌を護るが、丸石落ち来って指物の旗を裂き竿を折った。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と旅人はつぶやき、丸石の陰に腰を下ろそうとする。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "祈りが終わると、二人は丸石の陰に再び腰を下ろした。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "不毛の岩山の上に、平坦なところが少しあり、そこに大きな丸石が乗っていた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れが気がついた時には、何方をどう歩いたのか、昆布岳の下を流れるシリベシ河の河岸の丸石に腰かけてぼんやり河面を眺めていた。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸中遠野郷青笹村字｜中館という所の里道の傍らに一の丸石あり、ちょうど通行人の腰掛けて憩いたそうなあんばいの石なので、村の誰彼はなにげなく腰を掛けると、たちまちに気分がへんになり家に帰り病むことちょうど傷寒のような容体であった。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "地曳きのときの丸石を曳き合うのなども地固めという実利のほかに理があるかもしれぬ。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "轍の音が急に高くなり、車体がひどく跳りだしたので、いよいよ馬車が丸石の鋪道へ乗りこんだことが分った。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "高さ十尺ばかり、のっぺりした丸みをなしていて、下部を地中に埋め、茶釜大の丸石で囲んであった。",
              "citation": {
                "source": "狸石",
                "author": "――寓話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "人工を経たのでない自然石でも、ただの丸石でも、拝まれる事がある。",
              "citation": {
                "source": "石を積む",
                "author": "別所梅之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の感心した事は、村の道路から庭内の隅隅までが歐洲の田舍のやうに丸石を敷き詰めてある事と、島中の植物の手入が行屆いて、何處の土地も掃いたやうに清潔な事です。",
              "citation": {
                "source": "初島紀行",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そばを見れば目印においた丸石が放りだしてある。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸石を敷きつめた狭い通りを下りて、湖水のふちに出る、対岸はモンテ・サン・サルヴァトーレ Monte San Salvatore, 915m. が水にせまって、少し風立った山の湖には、シャヴァンヌの「貧しき漁夫」に見るような、覆のかかった小舟がいくつも波に揺られている。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸石旅館に手荷物を下ろし、茶一ぱい飲んで、直ぐ例の見物に出かける。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこの近傍において地質の急に変革したところもある、すなわちその北方｜犀川筋の地方はおもに破砕した翠増岩石から成り立っていて、そしてその南方木曾川の谷は数マイルの間おもに大口火性石の谷側に連なるのを見るし、また、河底は一面に大きな塊の丸石でおおわれていると言ってある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "雄山神社の社前に敷き詰められた丸石は、辻本君に拠ると「立山が白山よりも馬の沓一束だけ低い」という口碑に基づいて、登拝者が一寸でも本山を高めたい真心からわざわざ麓から持参したものだそうである。",
              "citation": {
                "source": "二、三の山名について",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに何等かの因縁話が添わって、死んでからこの丸石を祠にまつり込めることになったものと想像することはできたが、それ以上を聴く機会はついに来なかった。",
              "citation": {
                "source": "幻覚の実験",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "低く垂れさがった灰色の空から、絶え間なく霧のような氷雨が落ち、丸石の舗石をしっとりと濡らしていた。",
              "citation": {
                "source": "墓地展望亭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "住み荒して、見るかげもない破家だが」　玄関のつづきは大きな広間で、天井に栂の太い梁がむきだしになり、正面に丸石を畳んだ壁煖炉がある。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "街上の敷石に小なる丸石を用うること。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本舞台正面小高き丸石の石垣四つ目垣樹木の植込、後一面座敷の書割、障子灯入り、下の方二間の屋体、伊予簾を下し、平舞台上下に柳の立木、日覆より同じく釣枝、総て下谷広小路松源裏手の体。",
              "citation": {
                "source": "上野界隈",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮川に沿う岸の家々は京都風に近き建築にて、板の屋根に丸石を置く。",
              "citation": {
                "source": "中山七里　二幕五場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸石旅館に手荷物を下ろし、茶一ぱい飮んで、直ぐ例の見物に出かける。",
              "citation": {
                "source": "熊の足跡",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "五、六貫は確かと言った、泥と糠に塗れた真っ黒な丸石です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "腰抜け彌八",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥だらけの市場通りと深い轍がついてしまったタウン街を舗装するための籤を数多く購入し、そのおかげで道には大きな丸石が敷き詰められ、中央に煉瓦敷の歩道ないし「コージー」を持つようになった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "今彼が立っているのは吹きさらしのスクエアで、丸石が古風に敷き詰められ、向こう側は高い盛土の壁になっていた。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "煤竹の濡縁の前に、朴訥な丸石の手洗鉢があり、美男かつらがからんで、そこにも艶々した新しい葉がふいている。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（之を錘り石と呼ぶ）（第四）質の粗き丸石にして凹所を有する者。",
              "citation": {
                "source": "コロボックル風俗考",
                "author": "坪井正五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは三々五々転がっている丸石の上に腰を降ろして一息入れた。",
              "citation": {
                "source": "千里眼の村",
                "author": "クリスマス・ストーリー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
