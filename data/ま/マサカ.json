    "definitions": [
      {
        "index": 1,
        "gloss": "by no means",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "真逆に墓表とは見えずまた墓地でもないのを見るとなんでもこれは其処で情夫に殺された女か何かの供養に立てたのではあるまいかなど凄涼な感に打たれて其処を去り、館の裏手へ廻ると坂の上に三十くらいの女と十歳くらいの女の子とが枯枝を拾うていたからこれに上根岸までの道を聞いたら丁寧に教えてくれた。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、あいつが真逆やったんじゃあありますまい」「むむ」と、半七は考えていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも真逆、母は知ってはいないだろう、と気強く思い返して、夢のなかの喬は「ね！",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はやその谷川の音を聞くと我身で持余す蛭の吸殻を真逆に投込んで、水に浸したらさぞいい心地であろうと思うくらい、何の渡りかけて壊れたらそれなりけり。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は耐らず真逆に滝の中へ飛込んで、女滝をしかと抱いたとまで思った。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "山中に朽木の独木橋を渡り、アワヤ谷底へ真逆様にならんとせしは某君。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "先頭に立った吾輩は振り顧見ると、三番目に乗って来た未醒画伯、馬から真逆様に落ちて、大地へ四ツん這いになっておる。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "天地も崩るるがごとき音して、船はたちまち天空に舞い上り、たちまち奈落に沈むがごとく、それと同時に、余は梯子の中段より真逆様に船底に落ち込み、失敗たと叫びしまでは記憶すれど、その後は前後正体もなくなったり。",
              "citation": {
                "source": "南極の怪事",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "淵に臨んで、崕の上に瞰下ろして踏留まる胆玉のないものは、いっその思い、真逆に飛込みます。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）おつや　真逆これに毒が這入っているわけでもあるまい。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、其の御総領の若様が五歳になった時、ある日アノ窓の側で遊んでいる中、どうした機会か其の窓の口から真逆さまに転げ墜ちて、敷石で頸の骨を強く撲ったから堪りません、其のまま二言といわず即死して了ったのです。",
              "citation": {
                "source": "画工と幽霊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "空を撃ったお杉は力余って、思わず一足前へ蹌踉く機会に、恐く岩角に蹉いたのであろう、身を翻えして穴の底へ真逆さまに転げ墜ちた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、真逆にそんな事もあるまい。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に乗せられたお杉の亡骸は、既に頂上まで達いたと思う頃、何うした機会か其畚は斜めに傾いて、亡骸は再び遠い底へ真逆様に転げ落ちた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛唐は真逆日本のお婆ちゃんがと油断してかかったのだろうけど、四月一日であってみれば、怒るに怒れず頭を掻いて逃げて行ったわ。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしでも生まなけりゃ、真逆、ブン大将が生む訳はないでしょう。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ちる途中、その突起に衝突して、そこで一度バウンドしてから、真逆様に墜落したものらしい。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はパジャマの片袖を松の枝に残したまま、真逆様に白い波の砕け散っている岩の上に落ちて行った。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚吉は困りましたが、放っておけば女の児が死にそうですから、すぐに上衣を脱いで、ズボンを脱いで、シャツ一枚になって井戸の中へ真逆様に飛び込みました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の身体はそのまま一直線に地平線の端から、辷り出して無限の空間に真逆様に落込んだ。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞ひすましたる男の、真只中をひやうつと射て、舟底へ真逆様に射倒す。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで内証で涙を払うのかと偲うと、肩に一揺り、ゆすぶりをくれるや否や、切立の崖の下は、剣を植えた巌の底へ、真逆様。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋台根こそぎ波を打って、下土間へ真逆に落ちようとしました……と云った楼で。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はや其の谷川の音を聞くと我身で持余す蛭の吸殻を真逆に投込んで、水に浸したら嘸可心地であらうと思ふ位、何の渡りかけて壊れたら夫なりけり。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は耐らず真逆に瀧の中へ飛込んで、女瀧を確と抱いたとまで思つた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "城ヶ島の娘むすめ、むすめ、城ヶ島の娘、おまへは裸で海のそこ、朝も早うから海のそこ、素足ちらちら、真逆様に波を潜れば、青波ばかり。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アッ……」　と又野は前へのめったが、振返る間もなく中野学士を掴んだままギリギリと一廻転して、真逆様に落ちて行った。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……真逆に街道の狐でもあるまいが……。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "真逆……と思いながら打ち忘れておったところへ平馬殿の話を承ったものじゃから、実はビックリさせられてのう。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "真逆祖母の記憶力がここまで消耗していようとは夢にも思わなかったが、併し謡わないよりは増しだと思って又一番｜相勤めた。",
              "citation": {
                "source": "謡曲黒白談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
