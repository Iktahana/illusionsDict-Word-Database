        "index": 1,
        "gloss": "must (juice of grapes or other fruit prior to fermentation into wine)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
