      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "mast (of ship)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その沖の可なり此方と思はれるあたりに、海の中からマストがのぞいてゐる。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのマストは黒い、それも煤煙のやうに黒い、――黒い、黒い、黒い……それこそはあの有名な旅順閉塞隊が、沈めた船のマストなのである。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その時はまだ、閉塞隊の沈めた船のマストが、海の上にのぞいてをつた」と、貧血した母の顔が、遠くの物でも見てゐるやうに、それでもそんな時にはなにか生々と、後年私の生後七ヶ月の頃のことを語つて呉れるたびに、私は何時も決つて右のやうな風景を心に思ひ浮べるのである。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の此の眼も、慥かに一度は、そのマストを映したことであつたらうが、もとより記臆してゐる由もない。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護衣のまゝで抱かれるのは少しいやでもあつたけれど、心底可愛さうに抱いてるのにそんなことも云へなかつた……」と、母の話はマストの次には岡宮さんである。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝそこにはクリスマストリイのやうにまっ青な唐檜かもみの木がたってその中にはたくさんのたくさんの豆電燈がまるで千の蛍でも集ったやうについてゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "マストの上には銀河がぎらぎらと凄いように冴えて、立体的な光の帯が船をはすかいに流れている。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "埠頭に碇泊している船舶のマストにセイラーが双眼鏡をもってよじ登っていた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄海は日本の駆逐艦のマストが見える、夜は外人達によって舞踊会は傾いた部屋を旋回している。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああそこにはクリスマストリイのようにまっ青な唐檜かもみの木がたってその中にはたくさんのたくさんの豆電燈がまるで千の蛍でも集ったようについていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学校で教わったナショナルリーダーの「マッチ売りの娘」の幻覚のように、大きなクリスマストリーが、神秘的に光り輝く霧の中に高く浮かみ上がる。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マストにのぼつた　ふなのりが。",
              "citation": {
                "source": "お月さまを",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああそこにはクリスマストリイのようにまっ青な唐檜かもみの木がたって、その中にはたくさんのたくさんの豆電燈がまるで千の蛍でも集まったようについていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああそこにはクリスマストリイのやうにまつ青な唐檜かもみの木がたつて、その中にはたくさんのたくさんの豆電燈がまるで千の螢でも集つたやうについてゐました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むこうのほうに、三本マストの大きな船が浮んでいました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "波は、大きな山のように、黒々ともりあがって、今にもマストをつきたおそうとします。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "マストは、アシかなにかのように、まんなかから、ポキッと折れてしまいました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばんの本家は、船のメインマストになりました。",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "マストのある風景と、浪を蹴つて走る蒸汽船と。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ト、ウシロノ　ハウガ　イヒマスト、マヘノ　ハウガ、「モウ　スコシ　サキノ　ガケノ　上カラ　タニ川ヘ　ホリコンデ　ヤラウ。",
              "citation": {
                "source": "カゴカキ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヲトコハ　トシヨリト　ワカレテ　ナホモ　アルイテ　イキマスト、ナルホド　アノ　トシヨリガ　イツタトホリ、ハタケハ　タイハウノ　ワヤ　ウマノ　アシデ　スツカリ　アラサレテ　アリマシタ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナニカト　マウシマスト、ホカデモ　アリマセン、オホキナ　ハゲシイ　オナラヲ　スル　コトデ　アリマス。",
              "citation": {
                "source": "ガチヨウノ　タンジヨウビ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵の砲弾は、わがマストに命中し、たちまち帆がめらめら燃え上った。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おーい敬礼して行けとマストやデツキで失敬した。",
              "citation": {
                "source": "島",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、マストにかゝる亥中の月の、淋しくも凍れるが如き光にも我と共に浴びぬ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤマキチ　ハ　イタクテ　オイオイ　ナイテ　イマスト、タカ　ガ　ムカイ　ニ　キマシタノデ、イソイデ　ヤマ　ヘ　ツレテ　カエッテ　モライマシタ。",
              "citation": {
                "source": "山のコドモ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとまた高いマストだろう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その向うを、黄色いマストをした、黒い蒸汽船が、長い烟をはいて、横向きにとほつていきました。",
              "citation": {
                "source": "ぽつぽのお手帳",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
