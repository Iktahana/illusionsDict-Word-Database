        "examples": {
          "standard": [
            {
              "text": "失恋の痛手から、彼女は毎晩枕を濡らしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "悔しくて、誰にも見られないように布団の中で一人、枕を濡らした夜もあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "不安な気持ちでいっぱいになり、彼は気づけば枕を濡らしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "文字通り枕を濡らす想いで夜が明けた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "目から落ちる涙が、まくらをぬらすのでした。",
              "citation": {
                "source": "さか立ち小僧さん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
