        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……あなたは、名声だの幸福だの、何かこう明るい面白い生活だのと仰しゃるが、わたしにとっては、そんなありがたそうな言葉はみんな、失礼ながら、わたしが食わず嫌いで通しているマーマレードと同じですよ。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたかけと　よそ行きの　ぼうしを　みにつけ、　リービは　かごを　手に　また　おでかけ、　村のお店で　お茶っ葉　ひとつつみと　角ざとうを　５００グラム、　あと　マーマレードを　ひとびん　買うのです。",
              "citation": {
                "source": "パイとやきがたのはなし",
                "author": "THE TALE OF THE PIE AND THE PATTY-PAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは　マフィンに　マーマレードつけて　食べるつもりですから。",
              "citation": {
                "source": "パイとやきがたのはなし",
                "author": "THE TALE OF THE PIE AND THE PATTY-PAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「な、　なかみ、　これ　マーマレード？",
              "citation": {
                "source": "パイとやきがたのはなし",
                "author": "THE TALE OF THE PIE AND THE PATTY-PAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってこの種の陶器のジャーやつぼは果物ジェリー、マーマレード、その他の同様な砂糖煮を入れるには全く適していない。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "――好きといえば、僕はマーマレードが好きですね。",
              "citation": {
                "source": "チェーホフ序説",
                "author": "――一つの反措定として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そこで話は俄然活気を帯びて、やがて頗る満足した婦人連は、そのうちおいしいマーマレードをお届けしましょうと約束して、いそいそと帰って行く。",
              "citation": {
                "source": "チェーホフ序説",
                "author": "――一つの反措定として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで餌は勿論マーマレードに限ったことはないはずだ。",
              "citation": {
                "source": "チェーホフ序説",
                "author": "――一つの反措定として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "現にこの婦人訪問客の逸話を伝えている当のゴーリキイにしろ、或いはブーニンにしろクープリンにしろ、おなじマーマレードを振舞われたことがなかったと誰に保証ができるだろうか。",
              "citation": {
                "source": "チェーホフ序説",
                "author": "――一つの反措定として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがこれは実のところ、又しても例のマーマレードにほかならないのではないか。",
              "citation": {
                "source": "チェーホフ序説",
                "author": "――一つの反措定として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この序説の冒頭に引いた「自伝」で、殆ど五分の三に近い行数を占めていた医学の礼讃にしたところで、案外ドクトル・ロッソリモの口に合せたマーマレードだったかも知れないのだ。",
              "citation": {
                "source": "チェーホフ序説",
                "author": "――一つの反措定として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "マーマレードは事実チェーホフの好物だったろうし、同様にして医学効用論にしろ現代文化論にしろ、彼としてはあくまで正論だったに違いない。",
              "citation": {
                "source": "チェーホフ序説",
                "author": "――一つの反措定として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "全地球だの全自然だのという景気のいい宣言は、またしても例のマーマレードを思い出させないでもないが、その辺は大丈夫か。",
              "citation": {
                "source": "チェーホフ序説",
                "author": "――一つの反措定として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "通りがかりにたなのひとつからびんを取ってみると、〈オレンジ・マーマレード〉とはられてあるのに、とてもがっかり、中身はから。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "通りがかりにたなのひとつからびんを取り下ろすと、〈オレンジ・マーマレード〉とはられてあるのに、とてもがっかり、中身はから。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミルクと砂糖が七ペンス、パンが六ペンス、バターが八ペンス、マーマレードが六ペンス、卵が一シリング八ペンス、洗濯女に二シリング九ペンス、油が六ペンス、世話代に五シリング、〆て十二シリング二ペンス。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "「玄米とコーヒーとマーマレード。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワインを入れて熱く煮つめたマーマレードを、少しずつスプーンですくっては食べながら、コーヒーを飲む。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のしていることが単調になりすぎると、僕たちはキチンに集まって玄米を食べ、コーヒーを飲み、マーマレードをなめて話をした。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェニファーが持って来てくれている、マーマレード入りの熱いコーヒーをすすり、砂浜を飛び跳ねるように走っては、冷えた全身に体温をとり戻した。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
