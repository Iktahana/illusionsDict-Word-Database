    "definitions": [
      {
        "index": 1,
        "gloss": "McDonald's (fast food restaurant)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
