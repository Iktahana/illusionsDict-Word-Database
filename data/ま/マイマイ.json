[
  {
    "uuid": "68d89369-1dd6-5a0f-a779-fc34b428d053",
    "entry": "毎々",
    "reading": {
      "primary": "まいまい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "each time",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "婦人はものに拗ねたよう、今の悪戯、いや、毎々、蟇と蝙蝠と、お猿で三度じゃ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "正行が鼻血を出したり、陳平が泣面をしたりするという騒ぎが毎々でした。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　などは毎々の事。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……当時は電車で、毎々の事だが。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "とて、年月を經る夜毎々々、殿は美しき夢見ておはしぬ。",
              "citation": {
                "source": "妙齡",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と雙方同音に云つたが＝＝毎々お世話に＝＝と云ふべき處を、同時に兩方でのみ込みの一寸默然。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それについて毎々議論の出ることは、ここに一定の場所を定め、竹矢来などを結いまわして仇討の勝負をさせる。",
              "citation": {
                "source": "かたき討雑感",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも私は書物を買うことが好で、「お前は役にも立たぬ書物を無闇に買うので困る」と、毎々両親から叱られている矢先である。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "此故に古より奸雄の如きは毎々此の氣の共鳴作用を利して事を做す位である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "――小母さんは寺子屋時代から、小僧の父親とは手習傍輩で、そう毎々でもないが、時々は往来をする。",
              "citation": {
                "source": "絵本の春",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてその夢は、予の腹の漸く膨れ出して以來、その壓迫を蒙る内臟の不平が夜毎々々に釀した無數の不思議な夢の一つであつた。",
              "citation": {
                "source": "郁雨に與ふ",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間体にも、容体にも、痩せても袴とある処を、毎々薄汚れた縞の前垂を〆めていたのは食溢しが激しいからで――この頃は人も死に、邸も他のものになった。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人はものに拗ねたやう、今の悪戯、いや、毎々、蟇と蝙蝠とお猿で三｜度ぢや。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞は毎々難有う、續々面白い議論が出ますなア』と先生は僕の顏を見るや口を開きました。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その父も毎々の失敗にすこし呆れたんでしょう。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "又藩公へお客様の時には、翁は囃子、仕舞、一調等を毎々つとめた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども夜毎々々に、それが泳げる場所は狭くなる一方でした。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、迂遠千万にも毎々旅費日当を費やし官公吏を派し、その人々の、あるいは脅迫し、あるいは甘言して請願書に調印を求むること、怪しむに堪えたり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い古いと自国を自慢するが常なる日本人ほど旧物を破壊する民なしとは、建国わずか百三十余年の米国人の口よりすら毎々嗤笑の態度をもって言わるるを聞くなり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる境涯に毎々到り得なば、その人三十一字を綴り得ずとも、その趣きは歌人なり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "また猫や犬が時に葉や土を掻き戯れ、あるいは何か考うる体で尾を異様に動かすごとく、注意して観察せば、虎も時々異様な振舞いをなす事あるべく、毎々これをみた人々が、虎方術を能くし、まず卜うて後に食を取ると信じたなるべし。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "前から、その縁はあるのですけれども、他家のお嬢さん、毎々往来をしたという中ではありません。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎々のことでしょう、気をつけると毎月さ、はて変だわえ、とそれからいつでも寝際にゃあちゃんと、ちゅう、ちゅう、たこ、かいなのちゅ、と遣ります。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "地蔵尊の参詣人もこの頃はだんだんに遠ざかって、賽銭その他も昔とは大きな相違であるから、毎々の無心は肯かれないと申し聞かせますと、それならばいい工夫がある……と云うのが地蔵の踊りで、コロリ除けと云い触らせば、きっと繁昌すると云うのでござります。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それ位の事は、許してやらなければ、坂田は生きて行く空はあるまい」　と、仲間たちは、皆心の底から深い同情を以て聞いていたし、毎々の者は聞く振りをして、外の事を考えていてやったのである。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ故に昔から奸雄（大悪党）などは毎々この気の共鳴作用を利用して事を起こすくらいである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して今にして知りぬ、古人が自家見証につきて語る所の、毎々徒らに人をして五里霧中に彷徨せしむるの感ある所以を。",
              "citation": {
                "source": "予が見神の実験",
                "author": "綱島梁川",
                "note": "青空文庫"
              }
            },
            {
              "text": "情に脆く人なつこい性質とその半面の孤獨――時として彼はまいまいつぶらの樣に蓋を閉ぢてしまふ。",
              "citation": {
                "source": "青空同人印象記（大正十五年六月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボースン、何だ、まいまいつぶろ見たいに、グルグル回ってやがって、グルグル回ったって、ボイラーは上がりゃしないぞ、どこへ行くんだ、そら、ばか！",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "上水道水源地散歩、蛇が落ちこんで泳ぎまはつてゐる、多分這ひあがることは出来まい、まいまいはいういうと泳いでゐる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
