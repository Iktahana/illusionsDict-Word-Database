[
  {
    "uuid": "42626a04-5fa0-56d5-97b7-1f56c157ec75",
    "entry": "満了",
    "reading": {
      "primary": "まんりょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
