    "definitions": [
      {
        "index": 1,
        "gloss": "rendezvous",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人来り人去っていつまでも待合の隅に居残るは吾等のみなるぞつまらなき。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場の待合室のベンチに腰をおろして、その新聞をひらいて見た。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "フー、だが、全く暑いよ」　彼は、待合室から、駅前の広場を眺めた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "下り、下の関行うううき」　駅手が朗かな声で、三等待合室を鳴り渡らせた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "待合室はざわめき始めた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、立ち上って、三つばかり先のベンチへ行って、横目で、一渡り待合室を見廻した。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "カバンをぶら下げて、悄々ともとのバスの待合所へ歸つて來たら、どういふものか急に東京へそのまゝ引き返したくなつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、歸ることは歸るとしても兎も角も其處らを少し歩いてから歸つても遲くはないだらうとＳがいふので、厄介な荷物を一時バスの待合所へ預けておいてぶら／＼と坂道を上つて行つた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の有樣を見て居たら急に胃の工合が變になつて來て待合室の腰掛に一時の避難所を求めなければならなかつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "函館の連絡船待合所に憐れな妙齢の狂女が居て、はじめはボーイに白葡萄酒を命じたりしていたが、だんだんに暴れ出して窓枠の盆栽の蘭の葉を引っぱったりして附添いの親爺を困らせた。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮の下で下りて少時待っているうちに、次の箱根町行が来たが、これも満員で座席がないらしいので躊躇していたら、待合所の乗客係が気を利かして居合わせたハイヤーを別に仕立ててバス代用に提供してくれた。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから廊下や待合室を駆け廻つて捜した。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅夫がどこかの待合室を覗いて、なんとか地名を呼んだ。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "口不精な役人が二等の待合室に連れて行ってくれた。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィンクは肘で扉を押し開けて閾の上に立って待合室の中を見た。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二人だけは帰って行く者の仲間から除外されて、待合室の隅の方で小さくなっていた。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日偶然上野の精養軒の待合室で初めてＪＯＡＫの放送を聞いたが、その拡声器の発する音は実に恐るべき辟易すべきものであった。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時時しも岩手軽鉄の、　　待合室の古時計、つまづきながら四時うてば、　　助役たばこを吸ひやめぬ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "待合室は大きくてたくさんの人が顔を洗ったり物を食べたりしている。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "待合室で白い服を着た車掌みたいな人が蕎麦も売っているのはおかしい。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "待合のある小路へ入つた。",
              "citation": {
                "source": "太郎と街",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "相州小田原の町に電車鐵道待合の、茶店の亭主が言に因れば、土地の鹽辛、蒲鉾、外郎、及び萬年町の竹屋の藤、金格子の東海棲、料理店の天利、城の石垣、及び外廓の梅林は、凡そ日本一也。",
              "citation": {
                "source": "城の石垣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三隅さんのお袋とおぬいさんとは、妹を連れてきたおたけさんと一かたまりになって、混雑を避けるように待合室の外壁に身をよせて立っていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい凸勃、今夜こそ、お前待合に行け、俺達と一緒に。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「駄目、おんつぁん」をきつかけに勃凸は急に待合の事をいひ出した。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "方々、お茶屋さんだの、待合さんへ、そう云っておいでって云うんでしょう。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と待合の女中に囁く。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "片側は角から取廻した三階建の大構な待合の羽目で、その切れ目の稲葉家の格子向うに、小さな稲荷の堂がある。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ここで、一度待合になった処、開店の晩に、酔って裏二階から庇合へ落ちて、黒塀の忍返しにぶら下って、半死半生に大怪我をした客があって、すぐに寂れて、間もなく行方知れずそれは引越す。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "片側の待合のその羽目に、薄墨でぼかしたように、ふらふらと、一所に歩行いて附いて来る影法師。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
