        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ああ、いづこぞ夢の序樂のぽろねえず、會社は河岸に涙をひたし、花店の飾窓つゆにぬれたり、しばしまたつりがね鳴らむ、あさまだきにほふ葉影に、しろじろとかざし泳がせ、この列をなす少女らあゆむ。",
              "citation": {
                "source": "若き尼たちの歩む路",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北の屋蔭の苔むしたる井筒に、新調の洋服涼しげなる若人二人、巴里形の麥藁帽子見よげにかぶりて、細き櫻のステツキを手すさびに振り上げ、花もまだきなる紫陽花の葉を叩きつ、あやめを隔ててこなた、うちまもり給へるなりけり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅館の主人、馬を勧め、剛力を勧め、蓆を勧め、編笠を勤む、皆之を卻く、この極楽の山、只一本の金剛杖にて足れりと広舌して、朝まだき裾野を往く。",
              "citation": {
                "source": "霧の不二、月の不二",
                "author": "――明治三十六年八月七日御殿場口にて観察――",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿一日朝まだきに起き出でて見るに有明の月東の空に残りて雨はなごりなく晴れたり。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その古代の発音については色々の説があって、まだきまりません。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）翌朝――猿若町に櫓の太鼓鳴り響けば　鳴り響く櫓太鼓――　＝（Ｆ・Ｉ）お光の茶店（朝まだき）　駕籠が一丁待っている。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝まだき、東の空ようやく白みしころ、人々皆起きいでて合羽を着、灯燈つけ舷燈｜携えなどして波止場に集まりぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋の燈も顫ひ落ちよと、　　　　まだき吹くみなみ風かな。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "物質的宇宙の限界、その進化の諸問題について、われわれが知り得たと思っている事は今日でも実はまだきわめてわずかである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそういう場合の問題の解析に必要な利器はまだきわめて不備であって、まさにこれから始めて製造に取りかかるべきである。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "裂罅、あるいは「われめ」の生成は皺襞と対立さるべきものでやはり一種の不安定によって定まるものであろうが、このほうの研究はまだきわめて進捗していない。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝まだき霧の晴れぬ間に家を出で野を歩み林を訪う」同二十六日――「午後林を訪う。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後有色写真のいろいろな方法が案出されて、「テクニカラー」式有色映画の示す程度までは進歩したが、その色彩はまだきわめて単調でなまなましくて、かろうじて安物の三色版の水準にしか達していない。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、」　温泉の口なる、花室の露を掻潜って、山の裾へ出ると前後になり、藪について曲る時、透かすと、花屋が裏庭に、お雪がまだ色も見え分かぬ、朝まだき、草花の中に、折取るべき一個の籠を抱いて、しょんぼりとして立っていた。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "俥夫が朝まだき提灯で道案内に立つた。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "全市街はその日朝まだきより、七色を以て彩られ候と申すより他はこれなく候。",
              "citation": {
                "source": "凱旋祭",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤児の啼く声はまだきこえた。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼくは、なんて言うか、まだきめてないんです」と、ヨハンネスは言いました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑蔭倶樂部都のみどりば瞳にいたく緑蔭倶樂部の行樂はちまたに銀をはしらしむ五月はじめの朝まだき街樹の下に竝びたるわがともがらの一列ははまきたばこの魔醉より襟脚きよき娘らをいだきしむ。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母　　　ああ、これだね、まだきられるかしら。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三男　　まだきこえるね、ねえちゃん。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "長女　　ええ、まだきこえるわ。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三男　　まだきこえるよ。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばばさまは、まだきっとあの茶壺のからっぽな事にはお気附きなさらず、相変らず日に四度ずつ見廻りに行っている事でありましょうが、お気附きなさらぬままで頓死でもなさったならば、ばばさまも仕合せ、また私の罪も永遠にうやむやになって、大手を振って家へ帰れるというわけになるのです。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の家は、東京のどこにあるのだ」「罹災してね、どこへ行ったらいいか、まだきまっていないよ」「そうか、罹災したのか。",
              "citation": {
                "source": "親友交歓",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝まだきは納豆売、近所の小学に通ふ幼きが、近路なれば五ツ六ツ袂を連ねて通る。",
              "citation": {
                "source": "草あやめ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月一日の朝まだき、神々の御父ジュピタア様の宮殿へおまいりの途中で逢った三人目の男のひとを私の生涯の夫ときめよう。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本の題はまだきまつて居なかつたやうであるから、それとこの図案との附が好く行くかどうかは知らぬ。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
