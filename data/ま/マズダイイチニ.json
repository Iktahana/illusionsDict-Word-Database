[
  {
    "uuid": "149dcf68-05de-5d96-9b29-cd7a543311ae",
    "entry": "まず第一に",
    "reading": {
      "primary": "まずだいいちに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
