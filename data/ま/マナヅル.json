    "definitions": [
      {
        "index": 1,
        "gloss": "white-naped crane (Grus vipio)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
