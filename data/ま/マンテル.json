        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "頭に鳥毛飾りの帽子をかぶり、錦のマンテルを着た人は、王様の使者でなくて誰でしょう。",
              "citation": {
                "source": "ようか月の晩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大理石のマンテルピース、一つの壁には大きな裸体画、もう一つの壁には印度｜更紗が貼ってあった。",
              "citation": {
                "source": "鞄らしくない鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな人物の口からこんな文句が出るかというに、にわか散切りの西洋ごしらえ、フランスじこみのマンテルにイギリスのチョッキを着け、しかもそれは柳原あたりの朝市で買い集めた洋服であり、時計はくさりばかりぶらさげて、外見をつくろおうとする男とある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃膝取マンテルなぞと呼びたる由なり。",
              "citation": {
                "source": "洋服論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "マンテルを着た役人や、帽子を冠った人も珍しがられなくなり、やがて新聞がこの高原の村々にも配られだした。",
              "citation": {
                "source": "春いくたび",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九〇五年二十二歳七、八月に単独でシュレージェンのツックマンテルのサナトリウムに滞在。",
              "citation": {
                "source": "「世界文学大系58　カフカ」年譜",
                "author": "原田義人",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏期休暇中、ふたたび単独でツックマンテルに滞在。",
              "citation": {
                "source": "「世界文学大系58　カフカ」年譜",
                "author": "原田義人",
                "note": "青空文庫"
              }
            },
            {
              "text": "より低い場所は雪のマンテルを失って、而もまだ緑色ではなく、褐色の芝土の背地の上に、よごれた白色の筋と綴布とを見せるだけである。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
