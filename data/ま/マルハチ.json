    "definitions": [
      {
        "index": 1,
        "gloss": "Cyathea mertensiana (species of tree fern)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
