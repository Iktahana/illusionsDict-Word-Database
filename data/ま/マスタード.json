        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "マスタードを塗らなかったほうを、「ガキ用」といって慶一にわたし、「いくぞ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "マスタードを慶一にわたそうとして、そのバンズが閉じられているのを見た高志は、「おまえ、マスタードつけろよ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "マスタード抜きで」　と、レンジのまえに立っている女の子にいった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ワラはどこへいったんだ」「あいつは朝まで大いそがしだ」　高志が、ケチャップとマスタードを慶一にまわす。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "粉芥子を溶くかマスタードを落とすかする。",
              "citation": {
                "source": "鉄道模型の夜",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "マスタードとマヨネーズを混ぜ合わせる。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていっさいがっさいを、マスタード・マヨネーズがつなぎ合わせる。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
