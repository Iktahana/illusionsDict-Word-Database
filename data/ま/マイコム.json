[
  {
    "uuid": "aa030710-4b2b-55fa-8e24-4eaf63041f03",
    "entry": "舞い込む",
    "reading": {
      "primary": "まいこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
