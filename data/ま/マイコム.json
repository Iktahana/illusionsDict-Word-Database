    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to come fluttering in (e.g. leaves, snow, flowers, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ことしの春遊んだ吉野山中の宿坊に似た庭景色だと思うが、あの色つやのいい青苔と、座敷一杯に舞い込む霧のわびしさは、およぶべくもない。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが思想も遠方より理解せられ、そうして上酒一升、鴨一羽が、よき夕に舞い込むというのが、僕の理想であるが、それではあまりに慾が深すぎるかも知れない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸者から貰った一銭を首にかけた袋の中に大事そうに仕舞い込むのに気を取られていた女乞食は、咄嗟の勢で引き倒されました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日の午後も聖ジェイムズ・ホールで私は音楽に心酔しているホームズを見て、冒険の果てに捕らえられるべき犯人達にはやがて、凶事が舞い込むであろうと感じた。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し君の計算に讓歩するとしても、二千三百四十五萬六千七百八十九｜枚が舞い込むんだ。",
              "citation": {
                "source": "ハガキ運動",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろばかに耳たぶがあったけえと思っていたら、必定こういう福の神が舞い込むんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙は風呂場の下から逆に勘次の眼を攻めて、内庭へ舞い込むと、上り框から表の方を眺めている勘次の母におそいかかった。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "お島が庭口へ下りて戸を開けた時は、広岡学士と体操教師の二人が暗い屋外から舞い込むようにやって来た。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会主義者は舞い込む。",
              "citation": {
                "source": "放浪の宿",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "単行本が理工学書の売り上げランキングの上位につけると、『トランジスタ技術』以外の雑誌からも執筆依頼が舞い込むようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人の実家へ舞い込む頻々たる脅迫状に、当時奉公中の下女が顫え上って暇を乞うて逃げ出したと云う事もあった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵野固有の文言通り吹けば飛ぶ軽い土が、それ吹くと云えば直ぐ茶褐色の雲を立てゝ舞い込む。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は前年｜蘇士運河の船中で、船房の中まで舞い込む砂あらしに駭いたことがある。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "螢が此処からふらりと出て来て、田面に乱れ、墓地を飛んでは人魂を真似て、時々は彼が家の蚊帳の天井まで舞い込む。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日あたり風あたりが暴く、水も荒く、軽い土が耳の中鼻の中まで舞い込む余の住む武蔵野の百姓女なぞは中々、斯う美しくはして居られぬ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手をはなれた土皿は、ヒラ／＼／＼と宙返りして手もとに舞い込む様に此方の崖に落ち、中々｜谷底へは届かぬ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄道省旅客課あたりから登山者の感想、註文を求めると、千差万別な投書が舞い込むのである。",
              "citation": {
                "source": "案内人風景",
                "author": "百瀬慎太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、写真機を革の箱に仕舞い込むと、「さあ、杖をこう持って、グンと押して御覧！",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとしたら舞い込むのかもしれない幸運の期待で、自分の心を苛立たせ焦らすのは、何とまあわくわくして面白いんだろう！",
              "citation": {
                "source": "富籤",
                "author": "ВЫИГРЫШНЫЙ　БИЛЕТ",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸運が舞い込むかもしれないという考えで、二人ともすっかりまごついてしまった。",
              "citation": {
                "source": "富籤",
                "author": "ВЫИГРЫШНЫЙ　БИЛЕТ",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなり建てつけがよくなっていると思われるような硝子戸の隙からもこの種の粉雪は平気で舞い込むのである。",
              "citation": {
                "source": "雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなり建て付けがよくなっていると思われるような硝子戸の隙からも、この種の粉雪は平気で舞い込むのである。",
              "citation": {
                "source": "粉雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "迷亭は人の家も自分の家も同じものと心得ているのか案内も乞わず、ずかずか上ってくる、のみならず時には勝手口から飄然と舞い込む事もある、心配、遠慮、気兼、苦労、を生れる時どこかへ振り落した男である。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし普通の家庭へ舞い込む電報には好い消息よりも悪い消息の方が多い。",
              "citation": {
                "source": "或良人の惨敗",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はネお品さん、一と月ばかり前からちょいちょい私のところへ変な手紙が舞い込むんだ」「…………」　お品は言い出しそびれて、平次の顔を眺めました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "富籤政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうした八、たいがい大変が舞い込む時分だと思って、その辺を片付けさしたところだ」　平次はさして驚く色もありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "懐ろ鏡",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち例のパンドラの手箱に仕舞い込むことが本当の止揚だというのである。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰にも文句は言わせない」　そう言い乍ら千代之助は、半紙を四つに畳むと、そのまま押し戴くように、少しなまめく襦袢の袖の中、内懐深く仕舞い込むのでした。",
              "citation": {
                "source": "百唇の譜",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも幸運が舞い込むのは資金があり、体力があり、労をいとわぬ男のようだ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会部へは種々の団体から宣伝的集会の招待状が部長宛で舞い込む。",
              "citation": {
                "source": "負けない男",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
