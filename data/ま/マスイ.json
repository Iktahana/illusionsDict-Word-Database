[
  {
    "uuid": "bee5a54c-156e-56d2-844e-4dedbd802bdb",
    "entry": "麻酔",
    "reading": {
      "primary": "ますい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
