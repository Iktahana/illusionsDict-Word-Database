        "examples": {
          "standard": [
            {
              "text": "「この薬草茶には、体に良いものだけでなく、少し珍しい「混じり物」も入っているよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この香辛料のブレンドは、多くの「混じり物」が絶妙なバランスで配合されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "最終的な製品は、複数の化学物質の「混じり物」からできている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "荷風のロマンティックな、芸術至上主義風なリアクションは、ヨーロッパ文化の伝統はそのまじりもののない味いにおいて、日本の文化の伝統はまたヨーロッパとは別個なるものとして、あくまでペンキで塗られざる以前の姿において耽美したいという執着によっている。",
              "citation": {
                "source": "歴史の落穂",
                "author": "――鴎外・漱石・荷風の婦人観にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、栄さんのかくものが、栄さんの人となりのままで、その程度なりにまじりもの、こしらえものでないから本人予想以上の好評であるということになります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
