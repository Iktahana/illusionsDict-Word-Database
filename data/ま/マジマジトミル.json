        "examples": {
          "standard": [
            {
              "text": "刑事は、証拠写真を「まじまじと見た」。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この古い地図、何か秘密が隠されているのかも…」と、彼は書物を「まじまじと見た」。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "夕日が沈む絶景に、彼女は息を呑み、「まじまじと見た」。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ことに、一夜眠った明方の湖水の静けさ、恐らく深々とあたりの山腹に動いているであろう朝靄の真白さ、その中を啼いて渡る杜鵑の声、若葉の輝き、すべて身近にまじまじと見る様な気がして、なかなかに寝附かれないほどであった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　譜面台を受けとりながら、慶一は先生の顔をまじまじと見る。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
