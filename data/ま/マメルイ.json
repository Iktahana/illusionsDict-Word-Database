        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "花椰菜、千日大根、萵苣、白菜、パセリ、人蔘、穀物、豆類。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘達は、その出來たものや豆類などを背負つて停車場のある町に出掛けて行つた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁が澤山積まさつてゐる甘酸つぱい匂ひや、馬鈴薯や、豆類の匂ひや、澤庵漬や鰊漬の腐つたやうな便所くさい臭ひが、ごつちやになつて、お芳にはハキ氣がしてきた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜種も、豆類も、粟もすっかり駄目だった。",
              "citation": {
                "source": "トコヨゴヨミ",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の弁当に大豆類を多くせよ、などの警報にひかれている。",
              "citation": {
                "source": "祭日ならざる日々",
                "author": "――日本女性の覚悟――",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜葉二銭、半分は煮て食べ、半分は塩漬にした（私はあまり芋類豆類を好かない）。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "高粱（稷）にも幾つかの種類があり、豆類に至つては四十種以上に分れてゐる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "芋や野菜や豆類が、相当の闇価を負って河を渡りました。",
              "citation": {
                "source": "渡舟場",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "四方とも広々とした焼け跡で、処々に小さな家が建ってはいるものの、大体は小さく区切られて耕作され、麦の葉が風にそよぎ、豆類の花が咲き、雑草が伸びていました。",
              "citation": {
                "source": "白蛾",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その細い道の一方（最上川の流と反対側）は畑になつてゐて、豆類の収穫はもう了つて居る。",
              "citation": {
                "source": "支流",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "○牛蒡、蕪根、豆類の如きは醗酵性食物にして胃の悪き物は醗酵を促す。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体刺撃物や香料の配合は衛生上から割出してあって玉子に唐辛、豆類に薄荷、無花果に丁子、牛肉に芥子、梨や芋類に肉桂という風な合い物という事が出来ています。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆類が一番いゝのです。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年は豆類其他で千円も収入があろうと云うことであった。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦や豆類とはちがって、もう少し大振りな種である。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のオジヤでは、肉、ジャガイモ、人参、キャベツ、豆類などを入れて、野菜の原形がとけてなくなる程度のスープストックを使用する。",
              "citation": {
                "source": "わが工夫せるオジヤ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "図は皆着色画で、その第一面が植物学的の事柄で、葉形やら根やら花やらなどの事が出て、その第二面には種々の果実ならびに瓜の類が出ており、その第三面には穀類、豆類、根塊類が出て、その第四面には野菜の類、海藻類、菌類が出ていた。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第二部　混混録",
                "note": "青空文庫"
              }
            },
            {
              "text": "米ばかりではなく、豆類も皆無に近い所が沢山あり、馬鈴薯も大分悪かった。",
              "citation": {
                "source": "農業物理学夜話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明暦大火のすぐ後、浅草金竜山で、茶飯、豆腐汁、煮締、豆類などを一人前五分ずつで売り出した者があったが、これを奈良茶と言っておおいに重宝し、間もなく江戸中に広まってそのなかでも、駒形の檜物屋、目黒の柏屋、堺町の祇園屋などがことに有名であった。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "巷説蒲鉾供養",
                "note": "青空文庫"
              }
            },
            {
              "text": "日張博士は、この地方の豆類は、なにによらず味がよいと言へば、菊井博士は、これで収量をふやすことができれば、申分はないのだが、と、その方法について、いろいろ、研究の結果を述べ立てた。",
              "citation": {
                "source": "秋の雲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "依ては年中絶えず第一には馬鈴薯を多く常喰する事にて、第二は諸種の豆類をも多く喰するを以て、馬鈴薯と豆類には足りて忌むべきを覚ゆるあり。",
              "citation": {
                "source": "関牧塲創業記事",
                "author": "関寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に僻地に於て隣家も遠くして平生他の人を見る事なく、亦語る事少く、他に心を慰むるもの無きにより、殊に傭人等は日々馬鈴薯と豆類のみを多く喰するを楽とするのみなるを以て、折には異る喰物を大に楽とするのみなり。",
              "citation": {
                "source": "関牧塲創業記事",
                "author": "関寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "此際には豆類｜甘藍等に兎と鼠と日中にても群を為して来り食するや実に驚くのみ。",
              "citation": {
                "source": "関牧塲創業記事",
                "author": "関寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "老妻は渡道後は大に健康なりとて自ら畑に出で鍬を取り、蔬菜豆類を作り喰用の助けとして、一日に一銭たりとも多く貯えて又一が手許に送り、牧塲の資本を増加せん事をとて熱心に働き、自らも大快楽なりとて喜び居れり。",
              "citation": {
                "source": "関牧塲創業記事",
                "author": "関寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏じゅう、これがわたしの奇妙な仕事であった――それは地球の表面のこの部分、そこにはただ五弁草、キイチゴ、オトギリ草、その他の香ぐわしい野生の果実やうつくしい花が生えていたところに、その代りにこの豆類を産み出させることであった。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "その字の暗示するごとくやや高燥な草原であって水利の土木工業が大いに進まぬ限りこれを田にする見込みはほとんとなくわずかに多雨の年を頼りにして麦豆類を作るか、さもなければいつまでも草原として草でも刈っているの他はなかった。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっちはお米一日に二合七勺で、豆類は一切輸出禁止です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "麓の村々では代掻きもおおかたすんで、早くも植付けが始まり、か細い緑の列が、涼しげに戦ぐ山田もあれば、傾斜の豆類はたくましい茎の上に幾枚かのほん葉を、強い日光に捧げているのだから。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
