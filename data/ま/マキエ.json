    },
    "definitions": [
      {
        "index": 1,
        "gloss": "scattered animal feed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "無論金糸雀同志の事だ、精々｜撒き餌の粟粒か卵の事でも話し合つてゐるらしかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "年中品川へ網打ちにばかり出て、金を撒き餌に、雑魚をすくって、欣しがっているかと思うと、神田祭に、巨額な奉納金をして、花車の上で馬鹿踊りをやって、大得意な奴がある。",
              "citation": {
                "source": "田崎草雲とその子",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "横浜｜本牧あたりで獲れたまきえびを、生醤油に酒を三割ばかり割った汁で、弱火にかけ、二時間ほど焦げのつかないように煮つめる。",
              "citation": {
                "source": "車蝦の茶漬け",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
