        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "はなはだまとまらないこの一編の映画漫筆フィルムにこのへんでひとまず鋏を入れることとする。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このはなはだ杜撰な空想的色彩の濃厚な漫筆が読者の中の元気で自由で有為な若い自然研究者になんらかの新題目を示唆することができれば大幸である。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーヒー漫筆がついついコーヒー哲学序説のようなものになってしまった。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて支那の例は、『松亭漫筆』二に引きあるごとく、明の謝在杭の『五雑組』六にいわく、「人一目して数行｜倶に下る者あり。",
              "citation": {
                "source": "失うた帳面を記憶力で書き復した人",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中漫筆其中一人として、漫然として考へ、漫然として書き流したものである。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "・をさない瞳がぢつと見てゐる虫のうごかない・くもりつめたく山の鴉の出てきてさわぐ・てふてふひらひらとんできて萩の咲いてゐる・いちにち雨ふる土に種子を抱かせる　　　其中漫筆行乞と魚釣、鉄鉢を魚籃として。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中漫筆芸術は熟してくると、さびが出てくる、冴えが出てくる、凄さも出てくる、そこまでゆかなければウソだ、日本の芸術では、殊に私たちの文芸では。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中漫筆　　　必然性（歴史的）現実　　　　　　　　　　　　文学　　　可能性（社会科学的）　九月廿一日　雨、彼岸。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中漫筆何をたべてもおいしく、何を為てもおもしろく、何を見てもたのしく、何を聞いてもたのしく。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中漫筆□こんにやくといふもの　　　　　（豆腐に対比して）□物事をアテにすることは、あんまりよくないが、アテがなくては生活は出来ないが、アテが外れても困らない心がまへは持つてゐなければなるまい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中漫筆……おもひわずらふところさらになし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "（其中漫筆）　　　　　続酔心泥酔の世界から微酔の境地へ┌個性　┌特殊的　┌芸術│　　　│　　　　│文芸│　　　│　　　　│短歌└社会性└普遍的　└俳句日本詩　　　　　　┌音声　┌定型言語の成分　│意想　│季題　　　　　　└文字　└切字　十月四日　秋晴。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中漫筆　　酔中戯作一首あなた　ドウテイわたくし　シヨヂヨよ月があかるい虫のこゑ　　　其中漫筆□私俳句とは――□リアリズム精神　　自由、流動、気魂。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　　　其中漫筆┌自己の生活認識└社会の現実認識　　　　　　　　　　┌知識　　　　　　　　　　└意識┌生活印象└時代感覚　十月十日　曇、やつぱり雨だつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚痴をこぼしたってどうにもならないし、それに、この置き忘れ・紛失物の一件を並べ出すと、それだけで優に、生活の角度から見た全般にわたる旅行漫筆が出来上るくらいで、その土地々々に関する多少の描写の説明も必要だし、何よりも、いまここにその紙数もなければ場合でもない。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "逍遙子の諸評語小説三派（小羊漫言七一面より）及梓神子（春廼舍漫筆一五一面より）　さきにわれ忍月、不知庵、謫天の三人を目して新文界の批評家とせしことあり。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ややこしき漫筆　近頃あの銀行はややこしいといえば、よほど内容が危険でいつ休業するかわからないから、今のうちに預けてあるものなら早く取り出しなさいということまでも含まれているところの複雑な言葉である。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "街頭漫筆　私はあらゆる交通機関が持つ形の上の美しさを常に愛している。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、漫のつくものは漫歩、漫談、漫画、漫遊、漫筆等、肩のこらない気安さはあっていい。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "「冷灰博士――そっちの方のお名には、そぐわないことはないけれど」　友達が言うとおりだった『冷灰漫筆』の筆は、風流にことよせて、サッと斬りおろす、この家の主人の該博な、鋭い斬れ味を示すものだった。",
              "citation": {
                "source": "江木欣々女史",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "太田錦城が、日本では神武開闢以來、人が人を食ふこと見當らざるは、我が國の風俗の淳厚、遠く支那に勝る所以と自慢して居るが（『梧窓漫筆』後編上）、この自慢は支那人と雖ども承認せねばなるまい。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学者の随筆は何所かに術語が混つてどつしりした重味がつくし、文献家の漫筆は御手の物の博引旁証で読者に予期しない稗益を与へる。",
              "citation": {
                "source": "『全輯百間隨筆』内容見本「推薦文」",
                "author": "桑木厳翼",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は漫然とその次の「鎌倉漫筆」へ目を移した。",
              "citation": {
                "source": "大久保湖州",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここらでこの漫筆をおしまいにしたら、誠に天下は太平であるが、さて物事はそうは行かない。",
              "citation": {
                "source": "勝太郎",
                "author": "兼常清佐",
                "note": "青空文庫"
              }
            },
            {
              "text": "細かい事は漫筆に適しないが、早い話が『佐渡おけさ』『追分節』のレコードでは三味線はスタカートで終る。",
              "citation": {
                "source": "勝太郎",
                "author": "兼常清佐",
                "note": "青空文庫"
              }
            },
            {
              "text": "大田南畝が壮時劉龍門に従って詩を学んだことも、既にわたくしは葷斎漫筆なる鄙稿の中に記述した。",
              "citation": {
                "source": "上野",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "子の著『猿論語』、『酒行脚』、『裏店列伝』、『烏牙庵漫筆』、皆酔中に筆を駆ったものである。",
              "citation": {
                "source": "梅雨晴",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しわたくしなる一人物の何者たるかを知りたいと云うような酔興な人があったなら、わたくしが中年のころにつくった対話「昼すぎ」漫筆「妾宅」小説「見果てぬ夢」の如き悪文を一読せられたなら思い半に過るものがあろう。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後市中大晦日の景况を見むとて漫歩神田仏蘭西書院に赴き、フロオベル全集中尺牘漫筆の類数巻を購ふ。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
