        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ファッションショーで華麗な衣装をまとうマネキンガールたちの姿は、観客を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "百貨店のイベントで、新商品の香水をPRするマネキンガールが笑顔で対応していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は将来の夢を尋ねられ、「いつかマネキンガールとして舞台に立ちたい」と答えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "冬に這入ると、伊代はホールを辞めて、マネキンガールになった。",
              "citation": {
                "source": "帯広まで",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの文字の代りに、一人でいいから、天女のようなマネキンガールをくっつけたら……。",
              "citation": {
                "source": "慾",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽衣をつけたマネキンガールをあらゆる人が驚異の眼で見上げる。",
              "citation": {
                "source": "慾",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、スチームの暖気でむうっとしてる密閉した屋内に、爽かな冷い外気を吹入れるような調子で、マネキンガール――或はロボット――のことを話してやったものだ。",
              "citation": {
                "source": "慾",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初は女記者、それから女優、近頃ではデパートで、万人に生き身をさらすマネキンガールまでやって居るという噂でした。",
              "citation": {
                "source": "悪魔の顔",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄色い洋装と不思議な化粧はこのマネキンガールの様子を、埃及の昔語りの女王のように妖艶なものに見せました。",
              "citation": {
                "source": "悪魔の顔",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
