        "index": 1,
        "gloss": "evergreen (esp. one planted or used at a shrine)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
