        "examples": {
          "standard": [
            {
              "text": "彼女はいつまでも若々しく、まるで万年娘のようだと言われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「私もあんな万年娘になりたいわ」と、友人はため息をついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "年齢を重ねても変わらぬ美貌を保つ彼女は、まさに万年娘だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "いや親の眼からは年頃と思ふが、世間では万年娘といふかも知れぬてや。",
              "citation": {
                "source": "当世二人娘",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「相変らず騒々しいな、横町の万年娘が、駆落したって話なら知っているよ」　銭形の平次は、恋女房のお静に顔を当らせながら、満身に秋の陽を浴びて、うつらうつらとやっているところだったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "血潮と糠",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
