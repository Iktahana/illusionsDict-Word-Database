    "definitions": [
      {
        "index": 1,
        "gloss": "deep blue",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私はしびれを切らせて、彼が降りる筈の駅まで迎えに行くと、半時間ほどして、真っ青な顔でやって来た。",
              "citation": {
                "source": "鬼",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "真っ青な顔をして木の葉のように顫えていた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正勝は真っ青な顔で紀久子を覗き込んだ。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀久子は真っ青な顔をして婆やに付き添われながら、そのストーブの前に腰を下ろしていた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "４　敬二郎と松吉とは真っ青になりながら、顔を見合わせた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀久子は真っ青になってわなわなと顫えていた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、紀久子は真っ青な顔をして、微かにわななきながら腰を上げた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "真っ青な死の手に握られているピストル。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「頭が痛いんです」　房枝は真っ青な顔を上げて言った。",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "房枝は静かに起き上がって、真っ青な顔をしておどおどした目で鈴木女教員の顔を見詰めた。",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、妻の顔は気絶しそうなほどに真っ青で、手紙を読むと、それをそのまま火の中に投げ込んでしまいました。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "真っ青で息を切らし、寝台の方をこっそり窺いながら、外套を押さえて、僕が物音で起きてしまったのかを確かめました。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔は真っ青で、目は怯えて、でもちぐはぐに、口元は微笑んでるんです。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂色の頬髯をたくわえた男が、その細長い顔を真っ青にして暖炉わきの椅子から立ち上がったのは、我々が入ると同時だった。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴は真っ青な顔をして、「覚えてろよ」とでも言うみたいに目をぎらつかせて、向こうへ行ってしまった。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙っていたならすべて流れたのに、その医者は臆病者で、驚いて声を上げて、顔を真っ青にしてしまったため、その囚人も何が起こったのか感づいて、その医者を捕らえてしまったのだ。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下のランプの光を浴びて、姉が戸口に現れたのですが、恐怖で真っ青になった顔、すがるような手つき、千鳥足でふらふらと進み出てくるのです。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストーナ嬢は終わりまで聞かぬうちに唇まで真っ青になった。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とウィンディバンク氏は叫び、唇を真っ青にして、罠にかかった鼠のように身の回りを見まわしている。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "」バークリの奥さまは死んだみたいに真っ青になり、もしその恐ろしいなりの男が抱きとめなければ、倒れてしまっていたかもしれません。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」はっきりしゃべろうとなさいましたが、顔はまだ真っ青で、言葉もふるえた唇からかろうじて出るという有様で。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その顔は真っ青で、目に見えて疲れ切っている。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その漆黒の顎鬚は真っ青な顔から妙に目立っており、目は熱病にかかったごとくぎらついている。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただその青い目は不安げに我々ひとりひとりへ向けられ、奥隅にバニスタを見つけるや、とうとう顔色も真っ青となる。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と夫人は唇まで真っ青にしました。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女の顔は真っ青になっていたが、健康そうな腕と脚を見ると、連れの旅人ほどはつらくなさそうだった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルーシィが顔を真っ青にしておびえているのを見て、一部始終を聞いていたことがはっきりとわかった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "」スタンガスンは怒りで顔を真っ青にしながら、声を張り上げた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、シャーロック・ホームズはまだ帰宅せず、ようやく一〇時近くになって戻ってきたが、見えるは真っ青で疲れた顔色。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは風のないうららかに晴れた日で、ゆくさきに見える山々が真っ青な大空の下にくっきりと浮き出していた。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
