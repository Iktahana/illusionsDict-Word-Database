          "standard": [
            {
              "text": "切れ味の落ちた包丁を研ぐために、倉庫から大きな丸砥石を持ち出してきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "工場の隅で、職人が火花を散らしながら丸砥石で金属の部品を加工している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "丸砥石を回転させて、鎌の刃こぼれを丁寧に修正していく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "近ごろフランス人で刃物を丸砥石でとぐ時に出る火花を研究して、その火花の形状からその刃物の鋼鉄の種類を見分ける事を考えたものがある。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
