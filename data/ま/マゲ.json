[
  {
    "uuid": "f8a91c5b-d91f-5402-a330-950f6e63d5af",
    "entry": "髷",
    "reading": {
      "primary": "まげ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
