    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bun (hairstyle)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "若い丸髷の下町式マダムが弁慶縞の上っぱりで、和装令嬢式近代娘を相手に、あでやかにつややかに活躍している。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その傍に立った丸髷の新婦が甲斐甲斐しく襷掛けをして新郎のために鬚を剃ってやっている光景がちらと眼前に展開した。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "船にのるのだか見送りだか二十前後の蝶々髷が大勢居る。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲板へ上がってボーイに上等はあいているかと問うとあいているとの事、荷物と帽を投げ込んで浜を見ると、今端艇にのり移ったマントの一行五、六人、さきの蝶々髷の連中とサヨーナラといっているのが聞える。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃は「成功」なぞという言葉が特に取出されて流行し、娘たちはハイカラ髷という洋髪を結っている時代で虫食いの図書遺品を漁るというのはよくよく向きの変った青年に違いなかった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化文政には正式な髪は丸髷と島田髷とであった。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつ島田髷としてはほとんど文金高髷に限られた。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して、「いき」と見られた結振りは銀杏髷、楽屋結など略式の髪か、さもなくば島田でも潰し島田、投げ島田など正形の崩れたものであった。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が振返ってすっかり青葉になってしまった桜を眺めている間に、羽織姿の桃割と赤前垂の丸髷とが交って踊り出した。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国人達は彼女達の日本｜髷を珍らしがって嬉しそうにはしゃいでいた。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょん髷をつけたわれらの祖父母｜曾祖父母とはどうしても思われない。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七がいつもより早く家へ帰って、これから夕飯をすませて、近所の無尽へちょいと顔出しをしようと思っていると、小さい丸髷に結った四十ばかりの女が苦労ありそうな顔を見せた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "額の出た、頭の大きい、鼻のしゃくんだ、黄色い顔が、その長さ、大人の二倍、やがて一尺、飯櫃形の天窓にチョン髷を載せた、身の丈というほどのものはない。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この女房の母親で、年紀の相違が五十の上、余り間があり過ぎるようだけれども、これは女房が大勢の娘の中に一番｜末子である所為で、それ、黒のけんちゅうの羽織を着て、小さな髷に鼈甲の耳こじりをちょこんと極めて、手首に輪数珠を掛けた五十格好の婆が背後向に坐ったのが、その総領の娘である。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お聞き、」と涙声で、枕も上らぬ寝床の上の露草の、がッくりとして仰向けの淋い素顔に紅を含んだ、白い頬に、蒼みのさした、うつくしい、妹の、ばさばさした天神髷の崩れたのに、浅黄の手絡が解けかかって、透通るように真白で細い頸を、膝の上に抱いて、抱占めながら、頬摺していった。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「衣絵さん……」　品のいゝ、藤紫の鹿子切の、円髷つやゝかな顔を見た時。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "言わば白粉ははげ付け髷はとれた世にもあさましい老女の化粧を白昼烈日のもとにさらしたようなものであったのである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "水鬢の細髷つつましやかに女のように白い襟足のういういしさ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "でつかい建物や、ごてごてした裝飾には口をあけておつたまげても、こんな幽邃の美には一向に感心しない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」青年はほんたうにびっくりしたらしく燈台看守の両手にかゝへられた一もりの苹果を眼を細くしたり首をまげたりしながらわれを忘れてながめてゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まげて御承知くださるように重ねておねがい申します」「娘はゆうべ帰りまして、それからなんだか気分が悪いとか申して、きょうも一日｜臥って居りますので、まだ碌々に相談いたす暇もございませんで……」　お亀は一寸｜遁れの口上で、なんとか此の場を切り抜けるつもりらしかったが、相手はなかなか承知しなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「張大人は野蛮だからよ……さぞ、内地の人間が見たら、おったまげるこったろうな。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、彼等は、たまげちゃったような中隊長の散解の号令をきいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊さんが、どこへ持って行っても相手にしない、山根の、松林のかげで日当りの悪い痩地を、うまげにすゝめてくると、また、口車にのって、そんな土地まで、買ってしまった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その彼が、たまげた話し方をした。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の邪鬼の小便ぁたまげだ永ぃな。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人のように指をまげて唇にあてたりまっすぐに床を見たりしました。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中で大臣の子のタルラが少し顔を赤くして口をまげてわらいました。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　老人はわずかに腰をまげて道と並行にそのまま谷をさがった。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　二人はわらじを解いてそれからほこりでいっぱいになった巻脚絆をたたいて巻き俄かに痛む膝をまげるようにして下駄をもって泉に行った。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
