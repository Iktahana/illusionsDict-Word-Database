        "examples": {
          "standard": [
            {
              "text": "マリーセレスト号の失踪事件は、今もなお多くの海洋歴史家を悩ませる最大の謎だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "無人のまま漂流していたマリーセレストの船内には、争った形跡が一切なかったという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "幽霊船の代名詞として、マリーセレストにまつわる数々のエピソードは有名である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 2,
