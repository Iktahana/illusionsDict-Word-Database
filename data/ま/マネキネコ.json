        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "柿江は本当に恐ろしがって招き猫のような恰好をした）乱暴はよせよ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろんなものの載っている神棚があり、そこに招き猫があった。",
              "citation": {
                "source": "一太と母",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」少し女にも申しわけのない、恥かしい樣な氣になつたが、それを隱す爲めにわざと笑ひながら、火鉢のふちへ兩肱をついて、招き猫の樣にして寄せ合はせた兩手の上へ顎を置き、女の顏を見つめて、「どうだ、仙臺へ歸りたくないか？",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕元を見ると箱の上に一寸ばかりの人形が沢山並んでゐる、その中にはお多福も大黒も恵比寿も福助も裸子も招き猫もあつて皆笑顔をつくつてゐる。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "白猫黒猫三毛猫山猫招き猫。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "手首の辺から下へ曲り、あの陶器の招き猫の、あの手首そっくりであった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　まあお聴きといったふうに、招き猫の手つきをする。",
              "citation": {
                "source": "朝散太夫の末裔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "金花糖やも人形町に店があって、招き猫は大小となく出来ていた。",
              "citation": {
                "source": "流れた唾き",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間からお酒に胸焼けのしている皮がはみだすのを、招き猫のような手附きで話をしながら、時々その手で、衣紋を押上げるのだった。",
              "citation": {
                "source": "鬼眼鏡と鉄屑ぶとり",
                "author": "続旧聞日本橋・その三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が吃驚していると、その手でひとつ、招き猫のような格好をしておいて、鼻の下へもっていって差恥んだように首を縮めて笑う。",
              "citation": {
                "source": "木魚の配偶",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "一四　イタリーの招き猫名マネージャー・ルサルディ　ルサルディという人はイタリーのマネージャーで、ニューヨークのメトロポリタンのマネージャーのカザッツァと共に欧米の二大マネージャーとして有名な人で、カルーゾーもこのルサルディにマネージされて世界一のテナーになったのでした。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれを見て、日本の招き猫を思い出して、くすくす笑ったら、マダム三浦は何が可笑しいのか、ときかれたので、日本のゲイシャガールのお家では商売が繁昌するようにと、招き猫といって猫を飼ったり、猫が人を招いている人形を飾ったりするのを思い出して可笑しくなった、と説明したら、さようか、それでわかった。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "招き猫の招く手は、注意して見ていると、右の場合もある。",
              "citation": {
                "source": "落日の光景",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の家の近くの蕎麦屋には、右と、左の二匹の招き猫が並んでいる。",
              "citation": {
                "source": "落日の光景",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私は片手だけを挙げた招き猫の恰好が、気にかかってならない。",
              "citation": {
                "source": "落日の光景",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど招き猫に魅せられるように、舟三はその死人の招きを避けること出来ない。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は此話を聴いたとき、日本の客商売の家に、招き猫と称して座蒲団の上などに、猫の土偶を置く風習を考え出しておかしかった。",
              "citation": {
                "source": "どら猫観察記",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分、ちょいとお顔を」「何だい、八」　ガラッ八が招き猫のような手付きをしているのを見ると、平次はお勝手から水下駄を突っかけて、裏口の方へ出ました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死相の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "又招き猫という、縁起の猫の本尊（由来不明）があって、花柳界などこの頃大層な儲りかたにつれ、お猫様繁昌で紫のまくがはってあったりするのを見ました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時間に可哀そうですね」「四人ともお泊りをつけてやる」「それにしたって……」「いや、四人ともひきうけてやる」「あら、まあ、精力絶倫……」　招き猫みたいな手つきをして、「お一人で二人ずつ――妙な遊びがお好きなんですね」　小肥りの仲居は笑った。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでおのずと俺の手つきも、招き猫の手みたいと言うか、猫がじゃれるみたいなふざけた手つきになって、それが矢萩を一層怒らせた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "すみのかべ板に背中をこすりつけて、立ったくまは、まるでまねきねこみたいなかっこうだった。",
              "citation": {
                "source": "くまと車掌",
                "author": "木内高音",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
