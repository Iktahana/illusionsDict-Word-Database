        "examples": {
          "standard": [
            {
              "text": "暇な時間には、お気に入りの漫画本を読み返すのが好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "図書館で借りた漫画本が面白くて、あっという間に読み終えてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古本屋で、懐かしい漫画本を大量に見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "次は英泉、北斎、其他の漫画本。",
              "citation": {
                "source": "十歳以前に読んだ本",
                "author": "――明治四十五年六月『少年世界』の為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "漫画本を読ませって下さい」　五郎は理髪台に乗った。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪を刈っている間、少年は背を曲げるようにして、漫画本に見入っている。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
