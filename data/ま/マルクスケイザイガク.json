        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は西道頓堀の縁切路地の附近にある、古典書にまじって、横文字のマルクス経済学書もあろうと思われる、古本大学の淫書の書架の前に立っていた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は所謂「同志」に紹介せられ、パンフレットを一部買わされ、そうして上座のひどい醜い顔の青年から、マルクス経済学の講義を受けました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばマルクス経済学とブルジョア経済学とがその二つである。",
              "citation": {
                "source": "再び「科学の歴史的社会的制約」に就いて",
                "author": "――岡邦雄氏に答える――",
                "note": "青空文庫"
              }
            }
          ]
        }
