        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "絵葉書屋へはいったら一面に散らした新年のカードの中には売れ残りのクリスマスカードもあった。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆者が〔以下原稿数枚なし〕　それから「アナタ、タヾノオキャクサンゴザイマスカ。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アナタコノヘンノオテラ、ボンゾサン　シッテヰルゴザイマスカ。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コノヘンノボンゾサン、シャカブツ五カイ、マモルゴザイマスカ。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「サケノミゴザイマスカ。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ニクルイタベルゴザイマスカ。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「オクサンアリマスカ。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私、あまりお世話になっていると……」新子は、そこまでいって、食後のマスカットの一粒を、そっととり上げた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリスマスカードをよこすくらいで、たいしたことは、いってこないんだ」「メッセージは、『元気かい、いけなくてゴメン。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　あの年の八月に絵はがき、十二月にクリスマスカード、それからたしか翌年と、令子は慶一に三枚のハガキを送ってきた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度工場外ニ足ヲフミ出シテ見レバ分ル通リ、当工場ハマサニ「Ｙノフォード」タル名ニ恥シクナイ充分ノ待遇ヲ、ソノ時間ノ点カラ云ッテモ、ソノ賃銀ノ上カラ云ッテモ、皆サンニ与エテ居ルノデアリマスカラ、コノ際決シテ、カヽル宣伝ニ附和雷同セザル様、呉々モ申述ベテ置ク次第デアリマス。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "隅っこの方に小さな教会のついて居るクリスマスカードが見える。",
              "citation": {
                "source": "少年・春",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コレモ　ユリコサン　ニアケマス　オトウサマカ　ナニヲシテ　イマスカ　オカアサマニ　オキキナサイ　オカシイデショウ　　　〇六・三・二六」　ロンドンから母宛に来た手紙の中に封じこめられたものであったのでしょう。",
              "citation": {
                "source": "写真に添えて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "コノ、リョカンノ、名ハ、何トイイマスカ？",
              "citation": {
                "source": "夏の日の夢",
                "author": "THE DREAM OF A SUMMER DAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋ニハ電気ガツイテ居マスカラハッキリワカリマス。",
              "citation": {
                "source": "夢の殺人",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "オカネハ、イツモノヨウニ、ハンヲ、オシテ、アリマスカラ、コノママキョクヘ、トリニユキナサイ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "オトウサンノ、タヨリアリマスカ、ナニゴトモ、トキノクルマデ、ノンキニシテイナサイ、ワタシモ、コトシハ、アクネンユエ、タダジットシテイマス。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "オカネハ、イツモノヤウニ、ハンヲ、オシテ、アリマスカラ、コノマヽキヨクエ、トリニユキナサイ。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "オトウサンノ、タヨリアリマスカ、ナニゴトモ、トキノクルマデ、ノンキニシテイナサイ、ワタシモ、コトシワ、アクネンユエ、ジツトシテイマス。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちかごろ、七郎はどうしちまったのよ」　話があると、マスカの実が地上に垂れさがっている陰へ、マヌエラが座間を呼びこんだ。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリスマスカロルなど、スエ子がきのうよんで、何だかいやな気がしたと、ひどく気分的に表現していたが主人公がここでも、全くあり得ぬようにセンチメンタルに架空的にとらえられているのです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三四年（昭和九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、青年会館へクリスマスカロルの活動を見に行く。",
              "citation": {
                "source": "日記",
                "author": "一九二〇年（大正九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼等も同じやうにダマスカスへ向ふ途の上に必ず彼等の敵の中に聖霊を見ずにはゐられなかつた。",
              "citation": {
                "source": "西方の人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ツウジガアリマスカ」などと少しの日本語が出来る。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでオペラの作曲家マスカーニが同情して、ラザロのために「ピソコロ・マラー」というオペラを作曲して、ローマの王室劇場でラザロがうたって大変評判をとったことがございました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "マスカーニの名前が出ましたからつけ加えますが、この作曲家はシシリー島に題材をとった処女作「カヴァレリア・ルスチカーナ」で一躍有名になりました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからマスカーニは日本の吉原に題材をとった「イリス」というオペラを作りました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十四年の十二月興行に、私とサルコリィとで、マスカーニの傑作オペラ「カヴァレリア・ルスチカーナ」を原語イタリー語で上演いたしました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りはマスカルチア、グラヴィナなどの村を過ぎた。",
              "citation": {
                "source": "エトナ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
