    "definitions": [
      {
        "index": 1,
        "gloss": "the curtain opens (for the start of a play, act, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "幕が開くと、「ああ好いですわねえ」とその一人が云つた、「先代萩の序幕……あの舟はしつかり出来てますわねえ、かかりますでせうねえ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次「アー幕が開く」Ｔ「先生、早く来ねえかな」　と大吉を物色して辺りを見廻す。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "平土間の客も幕が開くので落ちつく。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう幕が開く処、見物は残らず場所へ坐直している、ここらは大阪は行儀が可いよ。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人公の Edgar といふ男は、幕が開くといきなり心臓病の発作で死んだやうになる。",
              "citation": {
                "source": "追儺",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕が開くと、才助と浅太郎とが出てくる。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕が開くと、若衆形の美少年が鼓を打ちながら、五人声を揃えて、左の小唄を隆達節で歌う。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕が開くと、藤十郎は右の廊下を、腕組みをしながら歩いて来る。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちらの舞台にては幕が開く前と見え、鼓と太鼓と笛の音が継続して聞える。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕が開くと、狂言方や下回りの役者たちが、五、六人左右に忙しく行き交う。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤十郎　さあ、もう幕が開くに程もあるまい。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――観劇に疲れた見物が、次の幕が開くのを待ちながら夜空の運動場へ出て深呼吸をする類ひでゝもあつた。",
              "citation": {
                "source": "籔のほとり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今中幕が開くところだ。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "木山はその一幕のあひだ到頭入つて来なかつたが、さうなると晴代も探してあるくのも厭で、知らん振りして次の幕が開くまで座席で筋書を読んで寂しさを紛らしてゐた。",
              "citation": {
                "source": "のらもの",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の門口の幕が開く。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "二番目の幕が開くと成つてから、初めて今更の如く思案の大頭を驚嘆しても、どうにも追ひつき様が無いので有つた。",
              "citation": {
                "source": "硯友社と文士劇",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "モウ直、次の幕が開くんですよ」「この次の幕は……ですね。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕が開くから……オヤア……これあ西洋｜室だ……おれア日本｜室にしといた筈だが……」「……シッシッ……」　第二幕の第一場は大森の天川呉羽嬢邸内、轟九蔵氏自室の場面であった。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて幕が開くと、忠臣蔵で、序から九段目までした。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一幕の幕が開くと周旋人のゴローが、ピンカートンに木と紙で出来た二人の愛の家の説明を諂いながらしてきかせ、女中や下男を呼び出して紹介します。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "（片手を下し、後方に静かに退場しつつ）如何にＦなる魔法使いが、銀の竪琴に魔を呼ぶか、如何にレモンの花の咲く南方の国の人々が、燃え狂う恋路を辿り行くか、諸君はこの幕が開くと共に、残る方なく知ることが出来ましょう。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤星ジュリアは喜歌劇に出演中だったが、彼女の持ち役である南海の女神はその途中で演技が済み、あとは終幕が開くので彼女を除く一座は総出の形となって、ひとりジュリアは楽屋に帰ることができるのであった。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど幕が開く前には彼女らはもう、一張羅と着替へて、ちやんと舞台の真正面に陣取つてゐるのである。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おやもう幕が開くんだよ。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の宅から黙つて姉様の着物を取り出すやら、化粧の間から、鏡やおしろいを持ち出して、与力窓の暗い暗い下で自分がお化粧をして、兎に角、女に化ける積りで涼み台の舞台へ現はれ蓆の幕の開くのを待つて居ると軈て幕が開く。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて小さな管絃団が、颯々たる序曲を奏する、幕が開く――と、どうだろう、そこには、けばけばしい衣裳と、血のように赤い唇の、醜怪な黒人どもがおおぜい立っていて、歯をむき出しながら、野蛮な咆哮を始めたのである。",
              "citation": {
                "source": "ルイスヒェン",
                "author": "LUISCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽曲が鳴り幕が開くと、華麗に装飾の施された屋形船が仕掛けによって上手から動いてきて、右手の松から舳先を突き出してくるが、音楽が鳴り止むと同時に波打ち際で止まる。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
