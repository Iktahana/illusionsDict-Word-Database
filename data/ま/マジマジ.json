        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "梟が撞木に止まってまじまじ尤もらしい顔をしていたこともあった。",
              "citation": {
                "source": "鷹を貰い損なった話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と頬杖をついたまま、にこりともせずお婆さんの顏を、まじまじと見つめながら、こんどはやや明瞭に言ふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "月寒の牧場へ行ったら、羊がみんな此方を向いて珍しそうにまじまじと人の顔を見た。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まくら辺に子を坐らせて、まじまじとその顔を見れば、逃げてゆきしかな。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男が皆の前でその夢の話をして聞かせると、皆はそれに耳を傾け、そしてそれを疑はうともせずに、本當にそんな大膽な眞似が出來たのかどうかを知らうとし、その男をまじまじと見つめたほど、それほど皆は氣が立ち、亢奮してゐたのであつた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然の思掛ない誘ひの詞に驚いて、私はまじまじと婦人の顏を見詰め返した。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇にも歓びあり、光にも悲あり、麦藁帽の廂を傾けて、彼方の丘、此方の林を望めば、まじまじと照る日に輝いて眩ゆきばかりの景色。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田がその市場で用事を足して帰って来ると往来に一人の女が立っていて、その女がまじまじと吉田の顔を見ながら近付いて来て、「もしもし、あなた失礼ですが……」　と吉田に呼びかけたのだった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たいてい推量もなさるであろうが、いかに草臥れておっても申上げたような深山の孤家で、眠られるものではない、それに少し気になって、はじめの内｜私を寝かさなかった事もあるし、目は冴えて、まじまじしていたが、さすがに、疲が酷いから、心は少しぼんやりして来た、何しろ夜の白むのが待遠でならぬ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと少年の方を見ると、少年はまじまじと予の方を見ていた。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "連れの男は何遍となく「コロッサアル」を繰返しては湯気の立つ馬をまじまじ眺めていた。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく生まれて始めて汽船というものに出会って、そうしてその上にうごめく人影を奇妙な鳥類だとでも思ってまじまじとながめているのであろう。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、いま眼のまえに少女の美しい裸体を、まじまじと見て、志賀氏のそんな言葉は、ちっともいやらしいものでは無く、純粋な観賞の対象としても、これは崇高なほど立派なものだと思った。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "できるだけ器用に忍びあしを使ひ、葉藏の枕元まで近寄つていつたが、硝子戸のそとの雨脚をまじまじ眺めてゐるだけであつた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふつうの人間は臨終ちかくなると、おのれの兩のてのひらをまじまじと眺めたり、近親の瞳をぼんやり見あげてゐるものであるが、この老人は、たいてい眼をつぶつてゐた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふつうの人間は臨終ちかくなると、おのれの両のてのひらをまじまじと眺めたり、近親の瞳をぼんやり見あげているものであるが、この老人は、たいてい眼をつぶっていた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "嗚咽びかえっているのです、それを見た武の顔はほんとうに例えようがありません、額に青筋を立てて歯を喰いしばるかと思うと、泣き出しそうな顔をして眼をまじまじさせます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治三十三年五月四日の午前十一時、――その時間は永劫の前にもなければ永劫の後にもない――が現われながら消えていく……園は時間というものをこれほどまじまじと見つめたことはなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隅の方で、西山が図書館から借りてきたカアライルの仏蘭西革命史をめくっていた園が、ふと顔を上げて、まじまじと西山の方を見続けていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奇体だなあ」　彼は思わず鉛筆を心もち紙の表面からもち上げて、自分に対して必死の抵抗を試みようとする項式をまじまじと眺めた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関に時計をおくとは変な贅沢をしたもんだなあと思いながら、渡瀬はまじまじと大ぎょうな金色に輝くその懸時計を見守って値ぶみをしていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡瀬は少し憚りながらも、まじまじとおぬいさんを眺めなおさずにはいられなくなった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟はとみると、私に秘してゐたことがすまなかつたといふ気持もまじへて、まじまじとうるんだ眼をして私を見てゐた。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姉さま旅行すきでしたわね」　すると慶四郎は、一寸たちどまってまじまじ千歳の顔を見たが、「仲子嬢の話は、きょうはこれ以上、して貰い度くないな」　と言って、またむっつり慶四郎は歩き出した。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭を釘六十　赤熊は、まじまじとして、頽然と俯向いたが、太く恥じたらしく毛皮の袖を引捜すと、何か探り当てた体で、むしゃりと噛む。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまじまじと女の様子を見つめて、その冷静な態度に比して自分の見苦しさを恥かしいと思つた。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまじまじと女の樣子を見つめて、その冷靜な態度に比して自分の見苦しさを恥かしいと思つた。",
              "citation": {
                "source": "計畫",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "余りの事に、これは一分別ある処と、三日｜二夜、口も利かずにまじまじと勘考した。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そう云われてみれば成る程ひどく剽悍そうな体つきをしている、その見知らぬ男の顔をまじまじと眺めたのであった。",
              "citation": {
                "source": "薔薇の女",
                "author": "渡邊温",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と頬杖をついたまま、にこりともせずお婆さんの顔を、まじまじと見つめながら、こんどはやや明瞭に言ふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
