          "standard": [
            {
              "text": "大規模なインフラ整備では、又請負の業者がさらに下請けを雇うことも珍しくない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "又請負に関する契約条件を明確にしておかないと、事故が起きた際の責任の所在が曖昧になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地方の小規模な工務店が、大手ゼネコンから又請負の形でリフォーム工事を引き受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "米屋の米つき、炭坑で雑役として働いたり、又請負師のところで、土方の手伝ひをやり、材木運び、使ひ走り、帳簿つけなどをしました。",
              "citation": {
                "source": "「地熱」について",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
