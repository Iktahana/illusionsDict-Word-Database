[
  {
    "uuid": "d940e7d4-1aed-5cf1-9626-6bd0b880d013",
    "entry": "真っ当",
    "reading": {
      "primary": "まっとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
