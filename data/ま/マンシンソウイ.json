    "definitions": [
      {
        "index": 1,
        "gloss": "having wounds all over one's body",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
