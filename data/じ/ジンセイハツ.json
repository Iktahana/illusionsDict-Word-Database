          "literary": [
            {
              "text": "しかるに意識の分化発展するに従い、物我相背き、主客相対立し、人生初めて要求あり、苦悩あり、人は神より離れ、楽園はアダムの子孫よりとこしえに閉ざされた。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは人間生活のうちで最も古くそして最も新らしく、時に従って更生を繰返している、その人生初期の観念に破れた、その反動のためであった。",
              "citation": {
                "source": "あめんちあ",
                "author": "富ノ沢麟太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
