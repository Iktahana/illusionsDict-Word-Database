    "definitions": [
      {
        "index": 1,
        "gloss": "ascetic practices (esp. celibacy)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
