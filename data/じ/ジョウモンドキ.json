    "definitions": [
      {
        "index": 1,
        "gloss": "straw rope-patterned ancient Japanese pottery",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
