          "standard": [
            {
              "text": "母乳が出ない場合や、母親の健康状態によっては、人工ミルクで赤ちゃんを育てます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "人工ミルクは、母乳の栄養バランスに近づけるように調製されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「人工ミルク」で育てる場合、調乳方法や衛生管理には十分注意が必要です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
