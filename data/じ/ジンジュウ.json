[
  {
    "uuid": "92af684c-8b42-5005-8be8-52effec77d81",
    "entry": "人獣",
    "reading": {
      "primary": "じんじゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "humans and animals",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は、｜一ツ目小僧と手に手をとつて踊り狂つたり、類人獣と組打ちをしたりする夢を見てゐたのだつたが、そんな夢の続きが目の前の「デイライト・スクリーン」に未だに怖ろしく映つてゐた。",
              "citation": {
                "source": "村のストア派",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンドレ・ジイドは「ワルテルの手記」によって後者の庶民的生活力には結びつかず、象徴派のマラルメやアンリ・ド・レニエなどと相識り、爾後四五年間はその温室の中にあって、間接に『法螺貝』、『半人獣』などという雑誌編輯に当り、グループの「最も光彩陸離たる聖職者の一人」となった。",
              "citation": {
                "source": "ジイドとそのソヴェト旅行記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾ら斯かる人獣でも、当局としては、一応自分を弁護する機会をも与え、その上で法律に拠って適宜に裁断する義務のあることは、尠くとも文明国である以上言うまでもなかろう。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その中央で王座のように蟠って君臨しているのが、黄銅製の台座の柱身にはオスマン風の檣楼、羽目には海人獣が象嵌されていて、その上に、コートレイ式の塔形をなした人形時計が載せられている――一つがそれだった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "でまず、ドドを人獣の児として考えてみよう。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それによって、ドドが原人か人獣児であるか、その点がはっきりと分るはずだった。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも、ドドを人獣の児として――その場合を君はどう考える？",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するにそこは、人獣ともに害さぬ仏典どおりの世界でしょう。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "その網の真ん中で、人獣「斬裂人のジャック」は級数的に活躍し、またまたこのハンベリイ街のアニイ・チャプマン殺しによって、もう一つその生血の満足を重ねたのである。",
              "citation": {
                "source": "女肉を料理する男",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "人獣争闘の大修羅場がこうして、邸内に展開された。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは人獣の格闘であった。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜘蛛手に造られてある廊下の諸所で、人獣争闘が行われた。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたたび人獣争闘が、焔の中で行われた。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其演奏種目が殖えて行つて、ほかひ・ことほぎよりも、くづれとも言ふべき物語や狂言・人獣の物まね・奇術・ふりごとなどがもてはやされた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "我ながら――人獣に備える心は不断に怠ったとは言えないが、まだ、ここで弓矢に覘われようとは、さすがの七兵衛も予想していなかったことです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵外国人獣肉を屠るに慣る。",
              "citation": {
                "source": "エタ源流考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "後世仏教の盛に行はるゝや、人獣肉を食ふを忌み、遂に屠戸を見る事人類に非ざるものゝ如くす。",
              "citation": {
                "source": "エタ源流考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下田より檻輿江戸に赴き、途三島を経るや、警護の穢多に向い、大義を説き、人獣相距る遠からざる彼らをして憤励の気、色に見われしめたり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆があまりに忙しくて、ヒマラヤの人獣のことなどに、かかわり合っていられなかったからであろう。",
              "citation": {
                "source": "雪男",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀内より十日町へ越える七里の山中で、竹助という人夫が、この人獣に遭っている。",
              "citation": {
                "source": "雪男",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年の暮、英国のエヴェレスト遠征隊が、ヒマラヤで奇怪な人獣の足跡を発見したという記事が、一時新聞紙上を賑わしたことがあった。",
              "citation": {
                "source": "イグアノドンの唄",
                "author": "――大人のための童話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒマラヤの人獣の足跡　もっともすべての大人にも、多かれ少かれ、この童心は残っている。",
              "citation": {
                "source": "イグアノドンの唄",
                "author": "――大人のための童話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、進化論によりて考うれば、人獣動物は同一の先祖より分派したりと申すから、精神のおおもとは動物初発のときにさかのぼらなければなりませぬ。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、人の死して鬼あらば、衣服に鬼あるということか』論者、ここに服す」と）韓退之曰、有形而無声者物有之矣、土石是也、有声而無形者物有之矣、風霆是也、有声与形者物有之矣、人獣是也、無声与形者物有之矣、鬼神是也。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "声、形とあるものは、物にこれあり、人獣これなり。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "人獣の差別を超えた純粋な精神の交流に心をうたれ、私は涙を流さんばかりだったが、追々ひく息ばかりになり、とうとうシャックリをするようになった。",
              "citation": {
                "source": "海豹島",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
