        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして、面會の上熟談したいから、都合を知らして呉れろと云つてやつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "今般全安様御事、伊沢家へ御養子御熟談相整重畳愛度奉存候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "大将はこの中将のいる右近衛のほうの長官であったから、始終この人を呼んで玉鬘との縁組みについて熟談していた。",
              "citation": {
                "source": "源氏物語",
                "author": "藤袴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、今晩は、そういうことの取引を熟談するために、この船をよそおうて湖へ出たのではないらしい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "尼子勝久にも会い、鹿之介幸盛とも熟談した。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度表むきでなく対面して熟談したいと考えていた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "周、――この儀については伊達一門、一家宿老ども熟談し、入札のうえ決定したものでございます。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴僧もよく御承知のある黒田官兵衛どのともう一応、じっくりと、はなし合うてみるおつもりはないか」「だれとでも熟談いたそう。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして高氏と酒くみ交わしながら、いよいよ、機密な熟談に入っていた。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
