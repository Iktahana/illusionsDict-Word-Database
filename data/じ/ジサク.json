    },
    "definitions": [
      {
        "index": 1,
        "gloss": "next work (book, film, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "枯木のようにひょろ長い、無表情な若者が吉太郎、そのほか次作、久助、富五郎などという名を、登は覚えた。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "狂女の話",
                "note": "青空文庫"
              }
            },
            {
              "text": "次作を期待しています。",
              "citation": {
                "source": "風貌",
                "author": "――太宰治のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月の映画は、もう間に合はないが、その次作品からは、今迄のやうにアチラ任せでなく、大いにこっちも註文を出し、映画のロッパも、一俳優に甘んずることなく、プロデューサーとしても、責任を持ちたいと思ふのである。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝村和男と次作品の打ち合せ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「青春」のピアノ曲は国定忠次作曲「のしいかのアクビ」と来て、大詰では男になり大あばれ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "成政は、寒さ防ぎに、酒をあたためさせ、一族、旗本たちと、鳥越城を攻め奪ったあとの――二次作戦を、しきりに協議していた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "魏はさらに、後続軍の新鋭を加えて、呉の脆弱面を徹底的に破砕すべく二次作戦を計っていたところだったのである。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じさくらという日本名をもっていても、この娘たちにくらべると光子とその友達のさくらは、まるで別の雰囲気の若い娘たちだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
