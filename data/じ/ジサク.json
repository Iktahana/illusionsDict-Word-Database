    "definitions": [
      {
        "index": 1,
        "gloss": "one's own work",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自作を説明するという事は、既に作者の敗北であると思っている。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、その少数の友人にも、自作の註釈をした事は無い。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自作を語れ、と言われると、どうして私は、こんなに怒るのだろう。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも、自作を語るのは、いやだ。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自作を語るなんてことは、老大家になってからする事だ。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダ・ヴィンチは、入れられぬ故郷の町を後に、自作の画数枚を背負つて雪のアルプスを越え………「今に………！",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は芭蕉の俳句中でひらひらと上る扇や雲の峯　を第一等の名作として推賞してゐたが、上例の如き自作の句を観照すると、芥川氏の芭蕉観がどのやうなものであつたかが、およそ想像がつくであらう。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで堀口君の訳詩を通して、ヱルレーヌを愛読し、ヱルレーヌに私淑してゐるといふ一青年が、かつて私に自作の詩を示して言つた。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時は、各々自作の作品を朗読するのであるが二つの素晴らしい作品が、朗読された。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の彼の悪戯の傑作は、Milton の sonnets をそのまま自作のような顔をして田舎新聞に投書したことである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八七九年から翌年へかけては小作人がだんだん土地を返上して来たので、地主は自作するより外途がなくなった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、往々にしてその作者が、自作の映画化を企図して書いていると思いなされる場合があるからだ。",
              "citation": {
                "source": "気まま者の日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "が昔から自作農であったことに変りはない。",
              "citation": {
                "source": "小豆島",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自作農は、直接地主から搾取されることはない。",
              "citation": {
                "source": "小豆島",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、五段歩ほど田を持っている自作農もいる。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで「吾々貧乏人は……」と云われても、五反歩の自作農は、自分にはあまり関係していないことを喋っているように思ったりするのである。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者だつて、自作に就いて的確な説明は、容易に出來るものでない。",
              "citation": {
                "source": "『東京八景』あとがき",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自作農で小作農も兼ねている。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "地主の娘と、小作兼自作農の伜との結婚は、家と家とが、つり合わなかった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "七年間に、彼は、全然の小作人でもない、又、全然の自作農でもない、その二つをつきまぜたような存在となった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見通しのきく自作農の竹さんは、土地をすっかり売ッぱらって都会へ出た。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小作人から、自作農に成り上って行こうと、あがいている者も僕の親爺一人に止まらなかった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自作農で破産をする人間、誰れもかれも街へ出て作り手がなく売りに出す人間、伊三郎が、又、息子の学資に畠の一部を売る場合――秋に入ると一と雨ごとに涼しくなる、そんな風に、地価は、一つの売出し毎に、相場がだん／＼さがった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "地主も、自作農も、麦が踏まれたことは、金が這入ることを意味する。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田と畠を頼母子講の抵当に書きこみ、或は借金のかわりに差押えられようとしていた自作農は、親爺だけじゃなかった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄兵衛も作右衛門も、藤太郎も、村の自作農の半分はそういう、つらいやりくりであえいでいた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな地主や自作農もあった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "地主も、自作農も、――土地を持っている人間は、悲喜｜交々だった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "源作は、村の貧しい、等級割一戸前も持っていない自作農だった。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "西原氏は、嫌味のないさつぱりした調子で、あの坂でつくつた自作の童謠を口ずさみ、しみじみと愉快氣に童男型でありながらまた大人風をも備へた大兵の體を振つた。",
              "citation": {
                "source": "狂童女の戀",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
