    "definitions": [
      {
        "index": 1,
        "gloss": "Shangdi (creator deity in Chinese folk religion)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「正行なかりせばいと口惜しからましに、よくこそ計ひつれ」と後村上帝が賞讃し、内侍を正行に賜らんとした。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「上帝の命を受けて、大華卿となって、遠くへ往くから、事務が煩わしいうえに途も遠いので、もうくることができない」　母子のものがとりすがって泣いた。",
              "citation": {
                "source": "陸判",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「上帝が、わしが人世に功があると言われて、わしを四｜涜牧龍君にしてくれたので、これから出かける」　児が何か言おうとしていると、庭のさきに四頭の馬をつけた黄※車が来たが、その馬の股には皆｜鱗があった。",
              "citation": {
                "source": "水莽草",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋に上帝を引いて誓い、また皇帝を引いて誓うこと多し。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "由って虎を霊視するの極、本来動物崇拝を峻拒する回教徒中にあっても、かつて上帝が虎と現じて回祖と談じたと信ずる輩すらある（『太平広記』二九二。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "死人の後家彼僧主を頼み、僧主官許を得て、今は回教僧だが昔取つた杵柄と丹誠を凝し、上帝に祈る事僅かに數分、爾時尸肉忽ち落ち失せ白骨のみ存つた。",
              "citation": {
                "source": "詛言に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "上帝鬼神は天子より庶民の上に存してゐるものとする。",
              "citation": {
                "source": "墨子",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此點は儒家にも通じ、支那上代より存してゐる上帝の思想にも淵源してゐる。",
              "citation": {
                "source": "墨子",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "南正重が天を司どり、火正黎が地を司どり、共工氏の子の句龍が死して社祠と爲り、烈山氏の柱が死して稷祠と爲り、舜の時には上帝・六宗の思想が發達し、高山大川をも祭り、羣神をも認むるに及んだ。",
              "citation": {
                "source": "道教に就いて",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "當時の上帝が後の元始天尊に進化したのか、門神が神荼欝壘（これは又蓋し雷の表象である）となつたか、井が井君となり、竈が竈神となつたか、それは別に考證を待つて定めらるべきだが、いづれにせよ早くからいろ／＼のものが祭られた。",
              "citation": {
                "source": "道教に就いて",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく穆公が夢に上帝に見えて、上帝が穆公に命じて晋の亂を平げよと云つたといふ傳説がある。",
              "citation": {
                "source": "道教に就いて",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "上帝はハッキリと擬人せられたのは穆公の夢がはじまりかと考へられるが、これより前既に長い／＼間に上帝の思想は凝結されて人の如き形及び作用を有するものとなつてゐたのであらう。",
              "citation": {
                "source": "道教に就いて",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "始皇は儒生を喜ばず、泰山に封じ、梁父に禪するに及んでも、其禮は雍に於て上帝を祀るの儀を用ゐた、と云はれてゐる。",
              "citation": {
                "source": "道教に就いて",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰一の思想は多神教より一神教へと進んで行く道程の一驛站のやうなものであるから、當時に迎へられたのに無理も無いが、泰一其物は云はゞ周初に於ける上帝の思想と異なつたものでは無いやうだ。",
              "citation": {
                "source": "道教に就いて",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "程子（中国・北宋時代の儒学者、兄が程祀燔柴の様な、「浄め祭る（※祀）をもって儒教における宇宙の最高神（昊天上帝）を祀る」『周礼（春官・大宗伯）』と云うのもある。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリスト教は古宗教の善悪の諸竜を混同して、一斉にこれを邪物とせり、かくて上世の伝説外相を変えて、ミカエル尊者、ジョージ尊者等、上帝に祈りて竜を誅した譚となり、以前ローマの大廟に窟居して大地神女を輔け人に益した神蛇も、法王シルヴェストル一世のために迹を絶つに及べり。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "上帝その禍を予防せんため、竜の身を極めて重くし居る故、みな楽土より流れ出る一河に陥ちて死す、近処の人その死を覗い、七十日の後その尸の頭頂に根生た紅玉を採って国の帝に献ると。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "英領ギヤナのアラワク人の談に、往時上帝地に降って人を視察した、しかるに人ことごとく悪くて上帝を殺そうとし、上帝怒って不死性質を人より奪い蛇蜥蜴甲虫などに与えてよりこれらいずれも皮脱で若返ると。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛇を見付けた処から、少しも身動きせざらしむる呪言は「汝を造れる上帝を援いてわれ汝に、汝の機嫌が向おうが向くまいが、今汝が居る処に永く留まれと命じ、兼ねて上帝が汝を詛いしところのものを以て汝を詛う」というのだ（チャムバースの『ブック・オブ・デイス』一巻一二九頁）。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "回教学有数の大著、タバリの『編年史』にいわく、上帝アダムを造り諸天使をしてこれを敬せしめしに、エブリスわれは火より造られたるにアダムは土で作られたから、劣等の者を敬するに及ばぬといい、帝｜瞋りてエを天より逐い堕す。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "上帝蛇を悪むの余りその四脚を去り、永えに地上を跂い行かしむと。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわく、太古ノア巨船に乗って洪水を免るるを、何がな災を好む天魔、錐を創製して船側を穿ち水浸りとなる、船中の輩急いで汲み出せども及ばず、上帝これを救わんとて、蛇に黠智を授けたから、『聖書』に蛇のごとく慧しといったのじゃ。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "洪水息んでノア牲を献って上帝に謝恩し、一同大いに悦ぶ最中に蛇来って約束通り人を求めて食わんという。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノアこの人少なに毎日一人ずつ取られては、たちまち人種が尽きると怒って、蛇を火に投じ悪臭大いに起ちて上帝を不快ならしめた。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
