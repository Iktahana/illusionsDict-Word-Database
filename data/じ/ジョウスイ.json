[
  {
    "uuid": "1fe68d17-60b3-5546-a7f2-c0351837250d",
    "entry": "上水",
    "reading": {
      "primary": "じょうすい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
