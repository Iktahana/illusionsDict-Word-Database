[
  {
    "uuid": "30630e1a-11ef-5677-9178-2bac28c303f8",
    "entry": "地割れ",
    "reading": {
      "primary": "じわれ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
