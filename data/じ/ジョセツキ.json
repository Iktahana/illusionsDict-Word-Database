        "examples": {
          "standard": [
            {
              "text": "大雪が降ったので、早速その最新型の除雪機を庭で動かしてみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "隣のおじいさんが、ごっつい除雪機でうちの前の雪も綺麗にしてくれたよ、本当に助かる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この除雪機は操作が簡単で、女性でも楽に扱えるのが良い点だね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "わたしはブエナ・ヴィスタ〔一八四九年のメキシコ戦争中の一激戦地〕の前線に半時間踏みとまった人々の勇気よりは、除雪機関車を冬の根城とする人々の長つづきのする快活な勇敢さに打たれる。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "エディンバラからこっち側には除雪機と呼べるようなものが一つもないんだから」　次長がブツブツ。",
              "citation": {
                "source": "四日白魔",
                "author": "THE FOUR WHITE DAYS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
