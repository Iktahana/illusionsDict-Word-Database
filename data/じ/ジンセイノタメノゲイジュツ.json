        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "わたしは、かれの、見得易からざる才分の、恰もゑんゑんたる春の波にもてあそばれて、恢々と、即ち、人生のための芸術の扉を開かれるのであります。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "□人生のための芸術――芸術のための芸術。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊池なぞは勿論、前者に属すべき芸術家で、その意味では人生のための芸術という主張に縁が近いようである。",
              "citation": {
                "source": "合理的、同時に多量の人間味",
                "author": "――相互印象・菊池氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術のための芸術と云う人と、人生のための芸術と云う人。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこの霊魂をもって書かれた大芸術こそ、人生のための芸術であり、我等の高遠な目的に向って進むに当って、鼓舞して止まない真の芸術ではあるのです。",
              "citation": {
                "source": "民衆芸術の精神",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、人生のための芸術でなくて、事実虚名のためであり、虚栄のためであるからです。",
              "citation": {
                "source": "自分を鞭打つ感激より",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベートーヴェンは「｜人生のための芸術」の最初のスタートを開いた音楽人である。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
