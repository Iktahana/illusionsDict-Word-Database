      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "castle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いかめしい城郭のようなライブラリーも柔らかで憂鬱な霧の薄絹に包まれている。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなる場合にもアインシュタインの相対性原理は、波打ちぎわに子供の築いた砂の城郭のような物ではない。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "滅びた主家の家臣らが思い思いに離散して行く感傷的な終末に「荒城の月」の伴奏を入れたのは大衆向きで結構であるが、城郭や帆船のカットバックが少しくど過ぎてかえって効果をそぐ恐れがありはしないか。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、西洋の芸術理論家は、こういうものの存在を拒絶した城郭にたてこもって、その城郭の中だけに通用する芸術論を構成し祖述し、それが東洋に舶来し、しかも誤訳されたりして宣伝されることもあるであろう。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "實驗室――彼れの庵室とも、城郭とも、宮殿とも昨日まで思つて、この六年間｜立籠つてゐた實驗室を彼れはいま／＼しげに見まはした。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一種の虚無思想、彼等の心性上に広大なる城郭を造りて、彼等をして己れの霊活なる高尚の趣味を自殺せしめ、希望なく生命なき理想境に陥歿し入らしめたり。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "城郭もなければ田畑もない国。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝夕の霧の中から浮び上る丘々や、その上に屹然として聳える古城郭から、遥か聖ジャイルス教会の鐘楼へかけての崎嶇たるシルウェットが、ありありと眼の前に浮かんで来た。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "島を案内しようといふのを斷つて公學校を退却すると、私は獨りで、島民に道を聞きながら、「レロの遺跡」といふ名で知られてゐる古代城郭の址を見に行つた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "島を案内しようというのを断って公学校を退却すると、私は独りで、島民に道を聞きながら、「レロの遺跡」という名で知られている古代城郭の址を見に行った。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀吉が、諸大名に命じて築かせた大坂城は、周囲三里に余る大城郭で、八層の天守閣を中心に、華美を極めた建物が立並んだ。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に、伊達正宗の最初の居城、臥牛の城閣がこの丘の上に組まれ、当時の城閣を偲ばせる本丸の地形や城郭の跡が今でも残っている。",
              "citation": {
                "source": "荒雄川のほとり",
                "author": "――私の郷土を語る――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その半腹なる村落の白壁は、鼠いろなる岩石の間に亂點して、城郭かとあやまたる。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、君も知っておられるだろうが」と彼は考えこみながら言い続けて、「スパルタに（それは今のパレオコリのことだが）、そのスパルタに、城郭の西の方に当って、渾沌たるほとんど見分けられない廃墟の間に、台石のようなものが一つあって、その上に今でも ΛΑΣΜ という文字が読まれる。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪人であるから、賢くもあり、又利害の念に明るいけれども、又一面大阪人の持つた暗い城郭的の狭い自己を持つてゐて、ぱつと花の開いたやうな処がなかつた。",
              "citation": {
                "source": "西鶴小論",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "東西南北は、思想の側のみ、思想の城郭にあらざるなり、思想の最極は円環なり。",
              "citation": {
                "source": "国民と思想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "広大な城郭の縄張り絵図が、半分だけかかれてあるのであった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "随分大きな城郭だが。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……だがそれにしてもこの図面、どこの城郭の縄張りなんだろう？",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……だがそれにしてもこの城郭、恐ろしいほどに宏大だが、こんな宏大な城郭が、いったいどこにあるのだろう？",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれとて城郭は、こうも大きくない筈だ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻軸のおもてに描かれているのは、宏大な城郭の縄張り図面、ただし半分しか描いてない。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "城郭故の如く、人民非なり。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　忠志君の頭の上には、昔物語にある巨人の城郭の樣に、函館山がガッシリした諸肩に灰色の天を支へて、いと嚴そかに聳えて居る。",
              "citation": {
                "source": "漂泊",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "千五百尺の深さまで掘ってようやく水を得た井戸が城郭の中に一つあるきりだ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は思想がこの人間の夢の間に間に、ひとり勝手に人間の頭の中で、体系の美しさをとどめているのが、奇怪な城郭に見えて来る。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "小高い位置にある城郭の名残から濠を越して向うに見える樹木の多い市ヶ｜谷の地勢の眺望は一層その通路を楽しくした。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "城郭のような巨船の処女航海だ。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
