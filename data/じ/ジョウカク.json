[
  {
    "uuid": "835ebfc8-4f21-51e8-a05b-c745b91e2be3",
    "entry": "城郭",
    "reading": {
      "primary": "じょうかく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
