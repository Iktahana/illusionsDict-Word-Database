        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『いったいあの鳥をどうしたのさ、ジェム？",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェムズバードって名付けてね。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "『問屋に出したけど、ジェム。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "『いたねぇ、ジェム。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、私の耳に倫敦のうなりがひびき、眼のうらに白屋敷の、メイフェアの、聖ジェムスの、南ケンシントンの、ハムステッドの、ブリクストンの、そしてライムハウスの――一くちに言えば大ろんどんの生活種々相が走り過ぎる。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一人はジェムス・ジョイスだ。",
              "citation": {
                "source": "詩人も計算する",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからモストルグへＹが目をつけたという石を見に行って、これは買わず、小さいＹのピンと紫ジェムを買う。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェムリャノイブール〔地名〕の先で、建物は古いが、内部での生活はまるで他の国に於ける監獄と全然違う。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェムシイ・デンプシイが死んでから欲しいと思っていたあの十エーカアの田地も手に入れて牧場にすることが出来る。",
              "citation": {
                "source": "カスリイン・ニ・フウリハン（一幕）",
                "author": "CATHLEEN NI HOOLIHAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "この地域から移された105人はミドルセックス病院、ユニヴァーシティ・カレッジ病院その他で死亡し、206人は聖ジェムズ教区の費用で埋められた。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はジェムか何かを五六粒手の平へ載せて口のなかへ投げ込んだ。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばあさんとむすこひとりのおばあさんと三人のむすこ、ジェリイ、ジェムス、それにまたジョンよ。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェムスはおぼれた。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェリイ、ジェムス、それにまたジョンよ。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君ももう、いよいよだな、ジェム」とうとう、一人が言った。",
              "citation": {
                "source": "井戸",
                "author": "Ｗ・Ｗ・ジェイコブズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今度は六週間あくびしながら蜜月をすごして、客を招いた男を――いや、女をというつもりだったが――さぞかし呪うだろうな」　ジェム・ベンスンは椅子に腰かけたまま長い手足をのばして、なにやらぶつぶつ異議をとなえた。",
              "citation": {
                "source": "井戸",
                "author": "Ｗ・Ｗ・ジェイコブズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は僕なりに、自分のカヌーに乗って“時”の流れを漕ぎくだりながら、友だちの家の側柱にカヌーをつないでは、中へはいって食事の御相伴にあずかって暮しているよ」「まったくヴェネチヤふうだね」まだ窓の外を眺めながら、ジェム・ベンスンは言った。",
              "citation": {
                "source": "井戸",
                "author": "Ｗ・Ｗ・ジェイコブズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし真面目に言ってだよ、ジェム」彼は、ゆっくり言った。",
              "citation": {
                "source": "井戸",
                "author": "Ｗ・Ｗ・ジェイコブズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "真剣なんだ、ジェム、千五百ポンド貸してくれないか？",
              "citation": {
                "source": "井戸",
                "author": "Ｗ・Ｗ・ジェイコブズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、いらっしゃいよ」　彼女はジェムをおいて駈けだし、駈けながら蕨をぱりぱり踏みくだいて、松林の中へ姿を消した。",
              "citation": {
                "source": "井戸",
                "author": "Ｗ・Ｗ・ジェイコブズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ、あたし一人だけでも、ここに腰かけていられると思うわ、ジェム。",
              "citation": {
                "source": "井戸",
                "author": "Ｗ・Ｗ・ジェイコブズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『親愛なるジェムよ、僕を救い出してくれたまえ』って」　ジェム・ベンスンは香ばしい煙を空中にふうっと吐き出してから、葉巻を歯にくわえたまま、上着の袖に落ちた灰をはらいのけた。",
              "citation": {
                "source": "井戸",
                "author": "Ｗ・Ｗ・ジェイコブズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしたち結婚したらね、ジェム、あたしはいとこ同志の関係を利用して、あの人にうんとお説教したげるわ。",
              "citation": {
                "source": "井戸",
                "author": "Ｗ・Ｗ・ジェイコブズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど、あたしたちの後ろで、誰かが『ジェム、救い出しておくれよ』って、ささやいたような気がしたんですもの」「そんな気がしただけさ」ベンスンはくりかえしたが、声が顫えていた。",
              "citation": {
                "source": "井戸",
                "author": "Ｗ・Ｗ・ジェイコブズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたが一緒にいてくださったら、どんなことにも、ほんとに怯えやしないわよ、ジェム。",
              "citation": {
                "source": "井戸",
                "author": "Ｗ・Ｗ・ジェイコブズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ジェム」彼女は怯えた口調で言った。",
              "citation": {
                "source": "井戸",
                "author": "Ｗ・Ｗ・ジェイコブズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「優しいジェム、どうなさったの？",
              "citation": {
                "source": "井戸",
                "author": "Ｗ・Ｗ・ジェイコブズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「井戸は、ほんとに埋めてしまわなければなりませんよ、ジェム」「ほんとにそうですね」ゆっくりと、息子が言った。",
              "citation": {
                "source": "井戸",
                "author": "Ｗ・Ｗ・ジェイコブズ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
