        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ワラが考えたジョークだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いいの、いいの、こっちのジョーク。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、日本にいて銀座をブラつくモダンボーイになるよりはパリのモンマルトルでアパッシュになった方がまだしも気が利いているかも知れない、これはジョークだが、私はまったく駒の出ないことを心から祈っているのだ。",
              "citation": {
                "source": "え゛りと・え゛りたす",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは＊１トルジョークの市などで盛んに売り出している、あの色とりどりの縫附飾のしてある上靴なんで。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊１　トルジョーク　トゥヴェリ県下の小都会で、手細工ものの産地として有名なところ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夜ひまなとき、わたし、クラブのクルジョークで勉強したいと思ったのです。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョークを解さぬわけではないけれども、先方の軽い言葉が、ヤス子にとって軽視できない意味があると、本当のことしか言えないという気質であった。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月十九日　月　夜、八時から｜クラブのリトクルジョーク〔文学サークル〕へ出かけた。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "セルプ・イ・モロト〔「鎌と槌」工場のこと〕へ出かけたら丁度ゆき違ってクルジョーク〔サークル〕だめだった。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜ソコーリスキーのリトクルジョークへ出かけた。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜八時から、オソアビアヒム〔国防飛行化学建設後援会〕のクラブのリトクルジョーク、今日はカラが創作的会話をするという日なり。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――つまりリトクルジョークに来てる人間の鋭くしたがってるところ、みがきたがってるところを磨く役には立たぬ。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、ライオンヌイ・リトクルジョーク〔地区文学サークル〕へ行った。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "オクチャーブリの編輯をして居る男が来て居ていろんな質問や、クルジョークの組織に関する話をやった。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日リテラツールナヤ・ガゼートにレーニングラードのクルジョークは非常にアクティブで、却ってモスク※の方がそうでないことが出て居たばかりだ。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "このクルジョークがわるいことは、指導者しっかりして居ないので子供にはびこられて秩序立った研究もしてない。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえりずっと歩いてバンクによって、かえって来たらリトクルジョークの「グラ※ー」〔指導者〕ПОЧТА〔郵便局〕のところから出て来て室へあがり喋った。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "燈がまばらについた片明りのザール〔ホール〕にソコールニクのライオンヌイ・リトクルジョークの連中が来て居た。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば市中各区の工場、クラブのクルジョーク員を大衆的につかって、（デモンストラーションで）生産のインダストリアリゼーション、集団化、第二「СССРの護り」を演出したような。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブック・オフ・ジョークス。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからこそ英国文化も、英国社会も、階級もジョークも、より強く（批判的に）現れ出るのです。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に過去何十年間かこの宮殿にない図書室、科学、芸術、工業の知識普及のためのクルジョーク（組）。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここはここでいろんなクルジョークがあって、この壁新聞もそこで出してます。",
              "citation": {
                "source": "子供・子供・子供のモスクワ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今のはジョークなの。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョークにしてはちっとも面白くないわ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "手の込んだジョークだってことは認めるけど……」「そんなんじゃないさ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親からの今年のクリスマス・プレゼントは、『あらゆる機会に利用出来る傑作ジョーク５０００篇』という分厚い本だった。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すぐれたジョークによって、さまざまな難局を切り抜けることが出来るのは、歴史が証明するところだよ」　大統領のような英語の口調で、父親は言った。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、まえに立っている店主を見上げ、「面白いジョークをひとつ、いかがですか」　と、言った。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
