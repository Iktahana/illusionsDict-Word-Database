    "definitions": [
      {
        "index": 1,
        "gloss": "to recite",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "女車掌が蟋蟀のような声で左右の勝景を紹介し、盗人厩の昔話を暗誦する。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂は一度西国立志編の美味を知って以後は、何度この書を読んだかしれない、ほとんど暗誦するほど熟読したらしい、そして今日といえどもつねにこれを座右に置いている。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "要品を読誦する程度の智識では、説教も済度も覚束ない。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "八歳になるまでは一銭の小使いも与えられず、支那の君子人の言葉を暗誦することだけを強いられた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "又｜嘗て貴州金竺長官｜司羅永菴の壁に題したまえる七律二章の如き、皆｜誦す可し。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、丁晋公臨終前半月、已に食はず、但香を焚いて危坐し、黙して仏経を誦す、沈香の煎湯を以て時々少許を呷る、神識乱れず、衣冠を正し、奄然として化し去ると。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、スワンソン夫人に命令された給仕男は鸚鵡返しにその通り復誦する。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "給仕は姿勢を取り直してまた夫人の命令を復誦する。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さはれ、なほ爺は真面目に諳誦す、業の輪廻を。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "参　岡田は虞初新誌が好きで、中にも大鉄椎伝は全文を諳誦することが出来る程であった。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "余常に誦する所の俗謠一首あり。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉の如く庫裡に入りて笈を卸し、草鞋を脱ぎて板の間に座を占め、寺男の給仕する粟飯を湯漬にして、したたかに喰ひ終り、さて本堂に入りて持参の蝋燭を奉り、香を焚きて般若心経、観音経を誦する事各一遍。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この声を出すには、先ずこんな風に正座して身心を整斉虚名ならしめ、気海｜丹田に力をこう籠めて全身に及ぼし、心広く体胖かに、即ち至誠神明に通ずる底の神気を以て朗々と吟誦するのです。",
              "citation": {
                "source": "謡曲黒白談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧どもは皆經を誦するに、我は火伴の童二人と共に、髑髏の贄卓の前に立ちて、提香爐を振り動したり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "卷を開いて高く誦すれば、聽衆手を拍ちて賞讚す。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは創作すと感ぜず、われは復誦すと感ず。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はかの観音経を読誦するに、「彼の観音力を念ずれば」という訓読法を用いないで、「念彼観音力」という音読法を用いる。",
              "citation": {
                "source": "おばけずきのいわれ少々と処女作",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この故に観音経を誦するもあえて箇中の真意を闡明しようというようなことは、いまだかつて考え企てたことがない。",
              "citation": {
                "source": "おばけずきのいわれ少々と処女作",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "文章も三誦すべく、高き声にて、面白いぞ――は、遠野の声を東都に聞いて、転寝の夢を驚かさる。",
              "citation": {
                "source": "遠野の奇聞",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と誦するのが、いうべからざる一種の福音を川面に伝えて渡った、七兵衛の船は七兵衛が乗って漂々然。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "七兵衛は空を仰いで、「曇って来た、雨返しがありそうだな、自我得仏来所経、」となだらかにまた頓着しない、すべてのものを忘れたという音調で誦するのである。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "美人は其の横に、机を控へて、行燈を傍に、背を細く、裳をすらりと、なよやかに薄い絹の掻巻を肩から羽織つて、両袖を下へ忘れた、双の手を包んだ友染で、清らかな頸から頬杖支いて、繰拡げたペイジを凝と読入つたのが、態度で経文を誦するとは思へぬけれども、神々しく、媚めかしく、然も婀娜めいて見えたのである。",
              "citation": {
                "source": "貴婦人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「巳の年巳の月巳の日巳の刻生」と口中に復誦するに及びて、村沢浅次郎の名は忽ち脳裡に浮びぬ。",
              "citation": {
                "source": "黒壁",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして貴下が、仏像の前で、その言行録を誦する経文だといった、悉い話を聞きましょう。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて支那にも僧など暇多い故か、観察の精しい人もあって、後唐の可止てふ僧托鉢して老母を養い行きながら、青竜疏を誦する事｜三載、たちまち巨蟒あって房に見る。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボスエルの『ジョンソン伝』に、ジョンソンわれ能くデンマーク語でホレボウの『氷州博物誌』の一章を暗誦すと誇るので試せて見ると、「第五十二章蛇の事、全島に蛇なし」とあるばかりだそうな。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "経を誦するごとに座に登って聴く。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕨の茎葉で蝮に咬まれた創口を撫でてかの歌を誦すと越後でいう由なるが、陸中の俚伝を佐々木喜善氏が筆したのには、蛇に逢いて蛇がにげぬ時「天竺の茅萱畑に昼寝して、蕨の恩を忘れたか、あぶらうんけんそわか」と三遍称うべし。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉村の――お菓子屋の――お島ちゃんは面長な美女で、好んで黄八丈の着物に黒じゅすと鹿の子の帯をしめ、鹿の子や金紗を、結綿島田の上にかけているので、白木屋お駒という仇名だった。",
              "citation": {
                "source": "明治座今昔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は半外套を着込み、恐ろしく油じみた黒じゅすのチョッキにネクタイなしでいたが、その顔全体が、油でてらてらしている鉄の錠前みたいであった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
