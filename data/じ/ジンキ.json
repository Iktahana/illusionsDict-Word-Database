      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "mysterious turtle (an omen of good luck)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「このお蔭に因りまして、わたくし一人の命ばかりでなく、南方ぜんたいの人間が永く毒類の禍いを逃がれることになりましたのは、一に聖徳、二に神亀の力でございます」　　　異洞　乾符年中の事、天台の僧が台山の東、臨海県のさかいに一つの洞穴を発見したので、同志の僧と二人連れで、その奥を探りにはいった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "録異記",
                "note": "青空文庫"
              }
            },
            {
              "text": "神亀五年の古鈔跋文中に長王の二字あり。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「上州長尾春斎（草屋の弟子）世話にて、神亀之古碑共一覧、其後｜多胡碑も観申候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二は※斎に神亀の古碑を見せた上野の人長尾春斎である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "神亀元年二月四日（聖武即位の日）の詔を例に見て頂きたい。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "万葉集巻五にある憶良の「令反惑情歌」（神亀五年作か）の如きも、聖武天皇の詔詞を飜訳したものなることは明らかだ。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人は六十二、三歳頃（神亀三、四年）太宰帥に任ぜられ、天平二年大納言になって兼官の儘上京し、天平三年六十七歳で薨じている。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは吉野宮行幸の時で、聖武天皇の神亀元年だとせば、「わが命も」の歌よりも以前で、未だ太宰府に行かなかった頃の作ということになる。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "憶良は、大宝元年遣唐使に従い少録として渡海、慶雲元年帰朝、霊亀二年｜伯耆守、神亀三年頃筑前守、天平五年の沈痾自哀文（巻五・八九七）には年七十四と書いてある。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻第五　　　　　　　　　　　○世の中は空しきものと知る時しいよよますます悲しかりけり　〔巻五・七九三〕　大伴旅人　大伴旅人は、太宰府に於て、妻｜大伴郎女を亡くした（神亀五年）。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "○悔しかも斯く知らませばあをによし国内ことごと見せましものを　〔巻五・七九七〕　山上憶良　大伴旅人の妻が死んだ時、山上憶良が、「日本挽歌」（長歌一首反歌五首）を作って、「神亀五年七月二十一日、筑前国守山上憶良上」として旅人に贈った。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "○奥つ島荒磯の玉藻潮干満ちい隠れゆかば思ほえむかも　〔巻六・九一八〕　山部赤人　聖武天皇、神亀元年冬十月紀伊国に行幸せられた時、従駕の山部赤人の歌った長歌の反歌である。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "○み芳野の象山の際の木末には幾許も騒ぐ鳥のこゑかも　〔巻六・九二四〕　山部赤人　聖武天皇神亀二年夏五月、芳野離宮に行幸の時、山部赤人の作ったものである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇后は藤原｜不比等の女、神亀元年二月聖武天皇夫人。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "神亀五年の格に、外五位の資人は十年を選となす。",
              "citation": {
                "source": "武士を夷ということの考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには、「神亀四年の編戸による、天平の里」ということが書いてある。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "神亀というのは奈良の朝、聖武天皇の御代の初めの年号です。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に新たに戸籍に編入せられたもので、それを、神亀の次の天平年間に「里」ということにした。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにその後神亀四年に新たに戸籍に編入せられ、雑戸を平民とした天平年間に里と立てたものが、所謂｜余戸の里だというのであります。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「出雲風土記」には、出雲の余戸を解して、「神亀四年の編戸に依る」とあって、天智天皇八年庚午の戸籍にも漏れていたものが、この年新たに戸に編せられ、戸籍に登録せられて国家からその存在を認められたのであった。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがってかつては公民の待遇を受けなかった筈であるが、しかしすでに神亀四年に編戸せられたとある以上、国家の公民として認められたものであったに相違なく、社会の進歩とともに、農民以外の雑戸の徒も、段々とその地位が向上したものらしい。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「浄行僧」に対して「智行僧」というのもあって、神亀五年十一月に、智行僧九人を選び山房に住せしむと『続日本紀』にある。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "曇の字は安曇のズミであるため、ついにエズミになったのを、町村制施行の際に故称に復したのであるが、『出雲風土記』によれば、神亀三年までは文字を恵伴と書き、神がこの地形を見て絵鞆のごとくなるかもと仰せられたための地名とあれば、本当はエドモである。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "神亀元年三月御年十六歳のとき光明子として聖武天皇の妃となられ、天平元年八月に皇后として立たれた。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『延喜式』のころまでは如何かと思いますが、現に神亀三年には、召出されたという記録が残っているのであります。",
              "citation": {
                "source": "山の人生",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉の二階住で、じんきょやみのくせに妾があった。",
              "citation": {
                "source": "大門通り界隈一束",
                "author": "続旧聞日本橋・その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺の午休みに駈け戻つて來た文吾は、母の手元にあるじんきの束を取つて、竊と物蔭へ身を忍ばせつゝ、樣子を窺つてゐると、自分のしたが、じんきはそこいらに一本もなかつた。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "いぶかしさうに小首を傾けた母は、立つて行つて戸棚から一束のじんきを持ち出し、またビイビイビイと紡ぎ始めた。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "文吾は再び拔き足して、母の傍に忍び寄ると、其の新らしいじんきの束を攫つて、更に物蔭へ隱れた。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "今持つて來たばかりのじんきの束が、また見えなくなつたのに呆れた母は、暫らく考へてゐる風であつたが、やがて絲車を片付け、膝の上の綿埃りを拂つてから、臺所へ行つて火打箱を取り出し、燧石をカチ／＼やつて、神棚に燈明を上げた。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
