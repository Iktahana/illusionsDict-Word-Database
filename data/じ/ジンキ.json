[
  {
    "uuid": "3ec05f96-c3d6-5c30-b0e8-3100ee0804b0",
    "entry": "神亀",
    "reading": {
      "primary": "じんき",
      "alternatives": [
        "しんき"
      ],
      "is_heteronym": false
    },
    "grammar": {
