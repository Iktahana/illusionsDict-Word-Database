    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese Industrial Standards",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そんな同年の五月、新しいＪＩＳ漢字コードの策定作業にあたっていた芝野耕司さんから、「青空文庫の作業の中で見つかった外字の情報を、まとめて提供してくれないか」と連絡をもらった。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般のパソコンで使える漢字は、ＪＩＳ X ０２０８という規格で決められた、第一水準第二水準の範囲のものだ。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "後にＪＩＳ X ０２１３と名付けられる規格の第三水準第四水準漢字原案は、一九九八年一二月に示され、翌一九九九年二月末を締め切りとして公開レビューが行われることになっていた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三水準第四水準の漢字を定めたＪＩＳ X ０２１３は、二〇〇〇年一月に制定された。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "この反省を踏まえ、新しい規格にもない文字の使用状況に関する調査が先々必要になった場合に備えて、作品中にＪＩＳ X ０２１３外字が使われていた際は、底本の何頁何行目に現れるかの情報を添え、外字情報だけを簡単に切り出せるように、ＸＨＴＭＬファイルの末尾に集約しておくことにした。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに漢字の字形を記憶させた漢字ＲＯＭに、ＪＩＳ第一水準に区分される基本的な文字を持たせておき、オプションでこれを使えるように準備する。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦横一六ドットの文字のパターンを収めたＪＩＳ第一水準の漢字ＲＯＭに関しては、標準で持たせるべきか、オプションにまわしていいか判断が分かれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "新機種のＰＣ―９８０１Ｆには、ＪＩＳ第一水準の漢字ＲＯＭが標準で組み込まれ、ベーシックやＭＳ―ＤＯＳの日本語機能が強化されることになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでＪＩＳ第一水準の漢字ＲＯＭを標準で組み込み、オプションで第二水準のＲＯＭも用意された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来のベーシックでも、オプションの漢字ＲＯＭを組み込めば、それぞれの漢字に割り振られているＪＩＳコードを十六進数で入力して、漢字を表示することができた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "研究テーマは、新しく定める「ＪＩＳ漢字コード」にかかる調査。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "４　青空文庫のネットワーク――深まりと広がりは、電子テキストを介してＪＩＳ漢字コードの取り組み　紙媒体にある表現物を電子媒体に移す際に問題が生じることは、青空文庫を始めるときから予想はされていた。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな壁となったのが、ＪＩＳ漢字コードにおける限界だった。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごく大雑把に言うと、パソコンにない漢字をＪＩＳ外字と呼ぶ。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる正字も、パソコンに用意されていなければＪＩＳ外字となってしまう。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのＪＩＳ外字を、青空文庫のテキストではどのように表記したらよいだろうか。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＪＩＳ漢字規格改正原案委員会のメンバーから、青空文庫作品中にある外字について情報提供の依頼があったのだ。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＪＩＳ漢字水準を第三水準、第四水準に拡張する、その漢字選定の資料にしたいということだった。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちなみにＪＩＳ漢字とは、パソコンや携帯電話などの情報機器で用いられる漢字を、その入力・処理・蓄積・交換・出力において、統一したコードとして規格標準化させた漢字のことを指す。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＪＩＳ＝日本工業規格が定める規格である。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼びかけ人たちは、新ＪＩＳ漢字策定チームへ提出する資料をまとめるなかで、インターネット上に電子図書館を構築していくには、ＪＩＳ漢字水準の整備が必要不可欠であることを再認識した。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "二〇〇〇年一月、新ＪＩＳ漢字コード（ＪＩＳ Ｘ ０２１３）は公表された。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その新ＪＩＳ漢字を使うためには、ＯＳ、フォント、アプリケーションなど、そのすべての対応が必要となってしまうため、まだ一般化している状況にはない。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "青空文庫では、新ＪＩＳ漢字が表示できるフォント、アプリケーションの情報提供や、新ＪＩＳ漢字コードを使用したテキストファイル作成などを通して、ＪＩＳ漢字水準の整備に向けた作業を継続している。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "著作権、ＪＩＳ漢字コード、テキストにおける表記方法。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "印象的イマジストであった蕪村は、その表現にもまた印象的イマジスチックな工夫を用いた。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり蕪村の場合では、言葉の聴覚的な音韻要素も、対象をイマジスチックに描写するための手段として、絵画的用途に使用されているのであって、本質上の意味でのリリシズムとして――即ち音楽として――使用されているのではない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし実景であるとすれば、少女の心情に似た優美の可憐さを、イマジスチックに心象しているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　リルケが晩年、ラアガツのホテルで、この小時の作品の思ひ出をトゥルン・ウント・タクジス公爵夫人に語つた一夜のことが、夫人の囘想記には興深く敍せられてゐる。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、ああ、ガンジス河、幅一｜里にも近い大きな水の流れは、みんなの目の前で、たちまちたけりくるってさかさまにながれました。",
              "citation": {
                "source": "手紙　二",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
