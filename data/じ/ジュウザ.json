          "literary": [
            {
              "text": "ラスキン大尉は双眼鏡をすばやくしまって、機関銃座にしがみついた。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピート一等兵は、後方機銃座へつけ。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くやれ」「はい」　機関銃座へつけといっても、飛行機のうえの射撃には経験のないピート一等兵だった。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピート一等兵は、銃座へのぼった。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ、かわってください」　ピート一等兵は、そういうと機銃座をからにして、のこのこ下へ下ってきた。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいから、機銃座はあけておけ。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "機銃座にだれもついていないなんて、眼にたちますよ」「なあに、お前が戦死したことにしておけばいい」「なるほど。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "暁闇に　銃座を掘るも。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "艤装いかめしく、大鉄砲の銃座もすえてあるし、長柄や、鈎槍なども、舷に立てならべてあった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "槍隊は、槍と槍をつなぎ持ちにして渉り、鉄砲隊は銃座と筒口を持ち合って越えた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、村じゅうざわめいて、眠っていた人々が右往左往した。",
              "citation": {
                "source": "性に関するアイヌの習俗",
                "author": "知里真志保",
                "note": "青空文庫"
              }
            },
            {
              "text": "左膳の一眼、萩乃と源三郎をかたみに見ながら、「おれは今朝、源三にだまってブラリとここを出たが、あの足ですぐ妻恋坂の道場へ行ってみると、何やら今夜儀式があるとかで、屋敷じゅうざわめいているじゃねえか。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
