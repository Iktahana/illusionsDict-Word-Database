  {
    "uuid": "95dd4ec7-24eb-5ece-8863-2222d3b27ab6",
    "entry": "時文",
    "reading": {
      "primary": "じぶん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
