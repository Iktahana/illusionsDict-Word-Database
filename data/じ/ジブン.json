      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "modern literature",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
