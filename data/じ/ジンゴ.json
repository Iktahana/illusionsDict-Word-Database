[
  {
    "uuid": "f0f5030b-293a-5005-a7b3-b90d09771e21",
    "entry": "人後",
    "reading": {
      "primary": "じんご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "behind others",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれども、小生と雖も、貴兄の幸福な結婚を望んでいる事に於いては人後に落ちないつもりだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は一人後ろになって歩いていた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しつかりした、さかり場の女中らしいのが、もう一人後についてゐる。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴雄もジュリアン・ソレルを自分に擬し、ジュリアンのような生き方に憧れることにかけては、人後に落ちなかった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕だって、マルクスやレーニンに関心を持つことは敢て人後に落ちないつもりですからな。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより自分は孫先生を尊敬し、その三民五憲の説に共感している事においてもあえて人後に落ちぬつもりであるが、しかし、その三民主義の民族、民権、民生の説の中で、自分には民生の箇条が最も理解が容易であった。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人中に出ることをひどく恥ずかしがるくせに、自らを高しとする点では決して人後に落ちない彼の性癖が、才能の不足を他人の前にも自らの前にも曝し出すかも知れない第一の生き方を自然に拒んだのでもあろう。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん無理な註文も多いに違いないが、それでも自分の註文に嵌まった本格探偵小説を憧憬れ望んでいる事は決して人後に落ちないつもりである。",
              "citation": {
                "source": "探偵小説漫想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "学問は大したものではないが、当時の剣客としては、人後に落ちない位の素養はあつたのであらう。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、歴史を愛し、歴史上の諸人物に親しみを持つ点に於ては、多く人後に落ちないつもりである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "雛遊は本と女子に、成人後、人の妻たり、母たる道を學ばしめた戯れ（骨董集上編下前。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪筆では人後に落ちない私には、「悪戦苦闘の末勇気をふるい」原稿用紙への書き写しを終えたという祖母の気持ちが、良く分かります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕には詩というものがちっともわからぬけれども、君も御存じのとおり、天才の詩人というものを尊敬する事に於いては、敢えて人後に落ちないつもりだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学的認識の限界を認めることに於ても人後に落ちるものではない。",
              "citation": {
                "source": "文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "御老体もちと変り種でござりまするな」　変り者たる点に於ては決して人後に落ちる退屈男でないが、これはいかにも大変りでした。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "女、酒、口どき上手、人後におちる隊長じゃごわせんが、その御病体では、身体がききますまいからな。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "マッサージをやる美人後家の下宿をねらって這入ったら、奥の間に脊髄病の入れ墨男が居て、その後家を女衒の手先に使っていた……。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "其※時は、孝子は用もない帳簿などを弄つて、人後まで残つた。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "其※時は、孝子は用もない帳簿などを弄つて、人後まで殘つた。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本がその現実の歴史に即して周密に探求されることを望むことでは、私も決して人後におちない誠意をもつものの一人である。",
              "citation": {
                "source": "近頃の話題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寄席がはねて木戸を出る時、待ち合せて電車に乗る時、人込みに切符を買う時、何でも多人数競争の折には大抵最後に取り残される、この場合にも先例に洩れず首尾よく人後に落ちた。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "遥かこなたの人後だから心細い。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "人後に落ちた仕合せには邪魔になるほど近くに人もおらぬ。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし腕力とか暴力とか、またはそれにもとづく勢力とかの上では最初から決して人後に落ちなかった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎは亜米利加人だが、これあまあ大概の事物には興味を持つんだし、ことに金を出すことにかけちゃあ何にだって人後に落ちない気でいるんだから、この今夜の一隊も、例によってほとんど、英米両国の旅行者だけだったと言っていい。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢學は主として頼山陽の門人後藤松陰に學んだのである。",
              "citation": {
                "source": "「西周哲學著作集」序",
                "author": "井上哲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の歌界に於ける諸氏は愚蒙の群中に一頭地を拔きたるために先鞭者の名をこそ負へれ他日歌界一般に進歩したる時、空しく人後に落ちて陳腐好きの俗輩と伍せられざらん事を祈るなり。",
              "citation": {
                "source": "萬葉集を讀む",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "内田百間氏の作品は多少俳味を交へたれども、その夢幻的なる特色は人後に落つるものにあらず。",
              "citation": {
                "source": "内田百間氏",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「決して」　弦之丞は鴻山の言葉を否定して、「不平などはみじんござりませぬ。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "鳴門の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
