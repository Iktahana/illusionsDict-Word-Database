[
  {
    "uuid": "3d5a3337-208b-58e7-a39c-5c9dd362ab09",
    "entry": "字体",
    "reading": {
      "primary": "じたい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
