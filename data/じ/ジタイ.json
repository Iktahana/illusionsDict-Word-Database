      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "form of a character (e.g. simplified, traditional)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "またなんという画家の手に成ったものか、角のないその字体と感じのまるで似た、子供といえば円顔の優等生のような顔をしているといったふうの、挿画のこと。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と一通の書を取出して、「なかなか字体がうまいです。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "間抜な字体で何の語かが書いてある。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私が川端さんから戴いているお手紙の字体と、それから思い出の中の、夢川利一様、著者、という字体とは、少し違うようにも思われるのです。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』それから一寸置いて、ちがつた字体で、『やつぱり迷はず和漢の療法を守つてゐればいいのだね。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙包には、写本の字体で、ごぶつぜんと書いてあり、ひらくと、お君が呉れてやった金がそっくりそのまゝはいっていた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その遺書は、巡査が私に見せてくれたが、昔風の曲りくねった字体で丸ッキリ読めなかった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらは筆のあとの柔かく温かな文字で書かれてあつて、声に出して読むと、ちやうどその字体のやうに、素直であたたかであはれ深い言葉である。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらか習わされた良家的の字には違いないが、生来の強い我が躾の外へはみ出していて、それが却って清新な怜悧さを表わしているといった字体で、それ以後五六本の手紙がかの女に来た。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士はマッチの火で、とろとろ辻占の紙を焙り、酔眼をかっと見ひらいて、注視しますと、はじめは、なんだか模様のようで、心もとなく思われましたが、そのうちに、だんだん明確に、古風な字体の、ひら仮名が、ありありと紙に現われました。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "われらの国の文字で書くと「夢」と「妻」は、この如くに字体が似通つてゐるのであるが――。",
              "citation": {
                "source": "消息抄（近頃書いた或る私の手紙から。）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、写本の字体で、ごぶつぜんとあり、お君が呉れてやったお金がそっくりそのままはいっていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのＡ、君も見たように、ドイツ活字体風に書かれていた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "字体や内容から見ても自分は金子の正気を疑はざるを得なかつた。",
              "citation": {
                "source": "悪魔の舌",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼のいちばんの喜びは、四折判ゴシック字体の非常な珍本――ある忘れられた教会の祈祷書――“Vigilioe Mortuorum secundum Chorum Ecclesioe Maguntinoe（21）”を熟読することであった。",
              "citation": {
                "source": "アッシャー家の崩壊",
                "author": "THE FALL OF HOUSE OF USHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠に、中国ではもう二十年もまえに明朝体を捨てて、より手書き文字にちかいなだらかな書体や字体（草書体や略字体）を本文印刷にもちいるようになっている。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙な字体で書いてある。",
              "citation": {
                "source": "杯",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹気は吹いて冷やかにする気、呼気はダン気、嘘気は出気、呵・熙・師三気は『科解』にも全くこの字体無しとしてあり、全く字の態を以って義としないとあるから、ただその帯びる声を取るので、呵気は「かー」という声を帯びた気、熙気は「きー」という声、師気は「し」という声を帯びた気をいうのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "懐紙に、別人のような字体で書いた。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "孰もインキでノート筆記やうの無造作な字体で、最初の一｜通が一｜番長く、細字で三｜頁半にも亘つてゐる。",
              "citation": {
                "source": "背負揚",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも人柄に不似合いな下手な字体で、葉子がひょっとすると上陸を見合わせてそのまま帰るという事を聞いたが、もしそうなったら自分も断然帰朝する。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「相模屋」と古めかしい字体で書いた置き行燈の紙までがその時のままですすけていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "可なり興奮して書いたと見え、字体が荒んでいる上に、字の書き違などが、彼処にも此処にもあった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が半｜頁ばかり飛んでから、前よりももっと乱暴な字体で始まっている。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠に、中国ではもう二十年もまえに明朝体を加えて、より手書き文字にちかいなだらかな書体（草書体や略字体）を本文印刷にもちいるようになっている。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れ「明治・大正詩人論」といふ書が近々出るわけですから、その中で宮沢賢治のことは、詳しく論じたいと思つてゐます。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は科学というものの方法や価値や限界などを多少でも暗示する事が却って百千の事実方則を暗記させるより有益だと信じたい。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十二月二十九日『東京朝日新聞』）　　　　　　　　　五十七　　　　　　婦人と動物学者　テキサス大学のモントゴメリー教授は、衣服その他の粧飾に鳥類の羽毛を使用する事を絶対的に禁じたいと論じている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには、この実験によって生じたいろいろの効果を正確に観察し、それを忠実に記録し、そうしてその結果を分析し帰納し、それから、もしできるなら、市民交通を支配する方則のようなものを抽出し、それから演繹される各種の命題を将来の市電経営法の改善に応用したいように思う。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにその後、竹村書房に對して、讀者からの直接の註文が、かなりあるので、竹村書房主はその註文を受ける度毎に憂鬱、なんとかして讀者の求めに應じたいと煩悶、あげくの果は一日、著者の陋屋をおとづれ、名案なきかと相談に及ぶ始末であつた。",
              "citation": {
                "source": "『老ハイデルベルヒ』序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
