    "definitions": [
      {
        "index": 1,
        "gloss": "ground (color, colour)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
