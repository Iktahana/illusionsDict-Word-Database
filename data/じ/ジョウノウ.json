[
  {
    "uuid": "ad957a05-0c1b-588e-894e-50ce419220ba",
    "entry": "上納",
    "reading": {
      "primary": "じょうのう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
