        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鉄の腰の十手の大写。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "見送る三次がお絹に、Ｔ「そーれ見なせえお絹さん」　と言って、Ｔ「俺と一緒に居るとお前迄があの通りやくざ者にされちまう」　と言うのを、　始終無言で聞いていたお絹が、　袂で隠して居た十手を三次に示す。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹が、Ｔ「今の旦那のお腰の物」　三次「馬鹿」と叱って、その十手をひったくって捨てる。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次を見て傍へ寄り、Ｔ「俺の十手を知ら無えか？",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次空とぼけて「御冗談でしょう旦那」Ｔ「それは十手じゃ御座んせんよ旦那」　言われて鉄が「何んだって？",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と訊き返して、　「これが十手でなくて何が十手でえ」と言うのを三次がへへへへへと笑って、Ｔ「それァ、あっし等二人の縁結びの神様でサァ」　と言ってお絹と共に去る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "序番自分よく、中盤惡手から駒損となり玉再再ならず窮地に陷つて、梅原さん意氣大に上つてゐたが、自分屈せず腹を据ゑて長考幾度、やがて百二三十手頃の終番に近く、隙を見て奮然逆襲、敵の應酬の失を捉へて過に勝名乘を擧げてしまつた。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く出ろ、早く立て」と、半七もふところの十手を探った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "用心深い半七は彼が必死の切っ先に空を突かせて、刃物を十手でたたき落した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝六十手を示して、Ｔ「少しお訊ねしたい事があるんですがね」　和尚が、Ｔ「寺社奉行様への手続を踏んで参られたか」　伝六返答に困った。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝六が此の間の奴は、Ｔ「あの侍ですよ旦那」　右門お内儀を呼びとめて、　十手を示して、Ｔ「明日の晩どうかしたんですか」　お内儀「いいえ」Ｔ「其処のお寺で結構なお説教が御座います」　と言ってお内儀は家の中へ――　伝六、右門に、Ｔ「あのお寺ですよ旦那」　と言う。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず万一、この一件が片付き兼ねる……下手人がわからぬとなると吾々は元よりの事、御主人の松倉様まで、十手捕縄を返上せにゃならぬかも知れぬと言うので、松倉十内様は今のところ青息吐息、青菜に塩の弱りよう……」「ちょっと良助さん。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "右胴へ来た奴をチャリンと鉄砲の砲口で弾いたが、その切尖の欠けた刀を持ち直さぬうちに、十手を鍔元に引っかけて巻き落いた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし子供達は、縄切れや、おもちゃの十手をふりまわしながら、あちらへ走っていきました。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚紙もて烏帽子を作りて被り、払を腰に挿したるもの、顱巻をしたるもの、十手を携えたるもの、物干棹を荷えるものなど、五三人左右に引着けて、渠は常に宮の階の正面に身構えつ、稲葉太郎｜荒象園の鬼門なりと名告りたり。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十手持ちたるが引添いて眼を配り、顱巻したるが肩をあげて睨め着くる。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "八年前、英ヘンリー・ダイヤー、『大日本』という書を著わし、欧米で巡査の十手を振らねば治まらぬ群集も、日本では藁の七五三繩一つで禁を犯さず、と賞賛せり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "これじゃあどうも、あなたの方が十手を持っているようですね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "十手に対しても申し訳がねえ」と、半七はすこし驚かされた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "十手とお縄をあずかっている商売でも、年をとると後生気が出る。",
              "citation": {
                "source": "半七捕物帳",
                "author": "槍突き",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは葺屋町の七兵衛と云って、十手をあずかっている者だが、すこしお前に訊きてえことがある」「へえ」と、勘次は女房と顔を見あわせた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "槍突き",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は自分が手をくだす番になって、藤四郎はふところの十手の服紗を払った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御用と叫んで打ち込んで来る十手の下をくぐって、松蔵は店を駈け出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "短刀と十手がたがいに空を打って、二、三度入れ違ったときに、藤四郎の雪駄は店先の打ち水にすべって、踏みこらえる間もなしに小膝を突いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ちすくむ途端に、かれの足は藤四郎の十手に強く打たれた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは朝帰りの客を送り出して、自分の部屋を片付けていると、表に捕物があるという騒ぎに、ほかの朋輩たちと一緒に表二階の欄干に出てみると、あたかもここの店さきで十手と短刀がひらめいている最中であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "林檎の皮ごとぼりぼり※り歩いている女学生も交じっていた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地球物理談話会もほんの五、六人の仲間であったが、その中にまだ若いコールシュッター氏も交じっていた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか海洋博物館での通俗講演会でペンクが青島の話をしたとき、かの地がいかに地の利に富むかということを力説し、ここを占有しているドイツは東洋の咽喉を扼しているようなものだという意味を婉曲に匂わせながら聴衆の中に交じっている日本留学生の自分の顔を見てにこにこした。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "松魚の刺身のつまに生のにんにくをかりかり齧じっているのを見て驚歎した自分は、自宅や親類の人達がどうしてにんにくを喰わないかと思って母に聞いたら、あれを食うと便所が臭くなるからいけないと云うことであった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
