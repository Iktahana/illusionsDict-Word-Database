    "definitions": [
      {
        "index": 1,
        "gloss": "as a matter of fact",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
