          "standard": [
            {
              "text": "手術後、一時的に人工肛門（じんこうこうもん）を造設する必要が生じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "人工肛門のケアには、専用の装具の使用と丁寧な衛生管理が求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ご家族のサポートを受けながら、人工肛門（じんこうこうもん）のある生活に慣れていくことが大切です。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ただ久島の肝臓癌は末期には大腸にも転移していて最後は人工肛門を使っていたと聞いたとき、記憶の底に埋もれていた光景を思い出した。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            }
          ]
        }
