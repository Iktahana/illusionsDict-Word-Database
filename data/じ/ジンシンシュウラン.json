    "definitions": [
      {
        "index": 1,
        "gloss": "winning the hearts of the people",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
