        "index": 1,
        "gloss": "walk (horse gait)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は平常歩いていた往来から教えられたはじめての路へ足を踏み入れたとき、いったいこんなところが自分の家の近所にあったのかと不思議な気がした。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とんだり、かけたり、あるいは、「帰りがくたびれるぞ」などと、かしこそうにおたがいを制しあって、しばらくは、正常歩で歩いたりして、進んでいった。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっとのことでおき上がって、かいちゅうでんとうをてらしてみますと、そこは十じょうほどの、ひろいちかしつでした。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "にいさんの丈吉君の寝室とならんでいて、六じょうほどの小さい部屋に、小さいベッドがおいてあるのです。",
              "citation": {
                "source": "塔上の奇術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "園田君の勉強べやは、六じょうほどの洋室で、窓ぎわに机がおいてあり、そのガラス窓の外は、立木の多い広い庭になっているのです。",
              "citation": {
                "source": "黄金豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
