    "definitions": [
      {
        "index": 1,
        "gloss": "being readily aware of rumors and gossip",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "法螺丸は又、そいつを地獄耳の中に細大洩らさずレコードしておいて、ほかの医学博士に応用する。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うっかりと口をすべらせた以上、どうであなたの地獄耳が聞き逃す筈はありません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる地獄耳で聞き逃がすわけには行きません」と、半七老人は云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "少年少女の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だれにきいたんだよ」「へっへ、地獄耳」　ワラはプレイ・ボタンを押すと、鉛筆をもってテーブルのまえの折り畳みイスに腰掛けた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、地獄耳というか、よく知ってるね」「ご注意しますが、絶対あんなものには係わらねえほうが、いい。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしが極秘にしている人造人間戦車の発明を、どうして、どこで知ったか」「それはもう、地獄耳でございます。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪事千里を走るとはこのことだ」「与力大寺他巳吉の地獄耳ですかね。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ウム、彼なれば早耳地獄耳、江戸の屋根の下の出来ごとは、一から十まで心得ているにふしぎはない。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "長屋の夫婦喧嘩から老中機密の策動にいたるまで、この奉行の地獄耳に入らんということはない。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "よいこと探ったの」「地獄耳でさあ。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠密の総帥で、みずから称して地獄耳、いながらにしてなんでも知っている。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "道は二つしかないな、一方は三河屋の裏へ出るのか」「離室の前から、母屋へ出られますよ」「離室には誰がゐるんだ」「七平と言つて、――足の惡い男で、何でも、三河屋の遠縁の者だとか言ひましたが」　地獄耳のガラツ八は、此邊の消息なら何でも知つて居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "十七の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "道は二つしかないな、一方は三河屋の裏へ出るのか」「離室の前から、母屋へ出られますよ」「離室には誰が居るんだ」「七平と言って、――足の悪い男で、何でも、三河屋の遠縁の者だとか言いましたが」　地獄耳のガラッ八は、この辺の消息なら何でも知っております。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "十七の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "――八」「ヘエ」「聴いていたろうな」「お復習して聞かせましょうか」　人間は少し間が抜けておりますが、記憶力は抜群で、いわゆる地獄耳と言われた八五郎です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "血潮の浴槽",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前に教へる分には差支へあるまいが、間違へても人に言ふな」「へエ、それはもう大丈夫で、名題の地獄耳で」　八五郎は大｜袈裟に、自分の耳などをほじつて見せるのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美少年國",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘン、こう見えても七之助は地獄耳だよ」「おまえは、きょうはどうかしているんでしょう。",
              "citation": {
                "source": "銀河まつり",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな仕打ちを受けたので、大人気になったとき、地獄耳たちに真相を打ち明けた。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "八方眼で、地獄耳の辻木夫婦も、そこまでは気づかない。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "召使い連中は地獄耳だからな」「いや、実はイズミは召使いじゃない。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度聞いたことは、けっしてわすれないという、地獄耳です。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの耳は、地獄耳だぞ。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――と今までいかにも神妙らしく畏まっていた矢倉伝内は、ジロリと凄い上目づかいをしながら、玄関の応答に地獄耳を欹てていた。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういううまいかくれ場所に道中師の伊兵衛様が、地獄耳をそばだてていることは、相手方の日本左衛門でも、夢、気がつくまいと内心得意でありましたところが、あにはからんや、この縁の下には自分のほかにも、ヘンな黒衣の人間がジッと竦んでおりましたのに、「おっ……」　と、しりごみをした伊兵衛。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
