          "standard": [],
          "literary": [
            {
              "text": "一八七五年から七六年にわたる冬の数箇月間ビーチャム・タワー（Beauchamp Tower）というエンジニアーを助手として水力学の実験をした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと近年になってこの現象が電気動力線の瞬時的高圧の測定に利用されそうだというので若干のエンジニアーによって応用の方面の見地から取り扱われはしたが、それも本質的に物理的な意味ではなんらの果実を結ぶこともなしに終わっているように見える。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "老いたるカトンは、サルジニア総督時代には、徒歩で巡視をした。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この出来事はヴァージニア州のリッチモンドの付近で起ったのである。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八四七年の一月に愛妻ヴァージニアが亡くなりまして、これ以後ポウの不幸は急湍の如くに彼をおし流し、ポウ自身の言葉を借用しますと「或る不思議な切迫した宿命感」のために遂に自ら死を招くに至つたのであります。",
              "citation": {
                "source": "『ユリイカ』挿話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "サツカレーの『虚栄市』『ニウカムス』ヂツケンスの『ヒツクウイク』『二市物語』などを読んだり、ウイルキー・コリンスの『白衣婦人』『イビル、ジニアス』を読んだりした。",
              "citation": {
                "source": "紅葉山人訪問記",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈トゥマロウ・ネヴァー・ノウズ〉にはじまる『リヴォルヴァー』セッションから、ビートルズのチーフ・エンジニアをつとめて、スタジオ・テクニックに革命を起こしたジェフ・エメリクが、きょうもチーフだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、チーフ・エンジニアはテープにさわったりはしない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "テープ操作は、きょうのセカンド・エンジニア、リチャード・ラッシュの仕事だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "エドガーは三歳の時父母を亡ったので、ジョン・アランというヴァージニアの煙草商に養われた。",
              "citation": {
                "source": "ポウの本質",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからアランに連れられて英国に渡り、向こうで小学校をすませて、一八二〇年に帰米してヴァージニア大学に学んだ。",
              "citation": {
                "source": "ポウの本質",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ちジニアスを要するのである。",
              "citation": {
                "source": "「二銭銅貨」を読む",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "右にコルシカ島、左にサルジニア。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙義山を連ねたようなサルジニアには波が荒い。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑談のうち、南米から廻って来た貿易商人で、兼エンジニアだと判明する。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男が先日ヴアージニアのヴアノンが岡に住むでゐる一人の友達を訪ねようとして、馬車旅行を企てた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "レオナルドは非常に優れたエンジニアであって、特に治水工事に長じていた。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍前面の敵はサルジニアのコッリーが約一万をもってケバ要塞からモントヴィの間に位置し墺軍の主力はなおポー河左岸に冬営中であった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナポレオンはかねての計画に基づき、両軍の分離に乗じ速やかに主力をもってサボナからケバ方向に前進し、サルジニア軍の左側を攻撃、これを撃破する決心であった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸からサルジニアに進入するためにはサボナから西北方アルタールを越える道路（峠の標高約五百メートル）が最良で、少し修理すれば車を通し得る状態であった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋しナポレオンは墺軍の前進を知り、なるべくこれを東方に牽制してサルジニア軍との中央に突進し、各個撃破を決心したのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に右翼の部隊をもってサボナ北方のモンテノット附近を占領せしめ、サルジニア軍と連絡して要線の占領を確実ならしむる事とした。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナポレオンはこの戦闘の成果を過信して墺軍の主力を撃破したものと考え、予定に基づき主力をもってサルジニア軍に向い前進するに決し、その部署をした。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏軍はケバ要塞を単にこれを監視するに止めて前進、十九日敵陣地を攻撃したが増水のため成功せず、二十一日攻撃を敢行した時はサルジニア軍は既に退却していたが、これを追撃してモントヴィ附近の戦闘となり遂にコッリー軍を撃破した。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "サルジニアは震駭して屈伏し二十八日午前二時休戦条約が成立した。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二週間の間に墺軍に一打撃を与えサルジニア国を全く屈伏した作戦は今日の軍人の眼で見れば余りに当然であると考え、ナポレオンの偉大を発見するに苦しむであろうが、フリードリヒ大王以来の戦争に対比すれば始めてその大変化を発見し得るのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "サルジニアを屈したナポレオンは再び墺国に向い前進、ポー川左岸に退却せる敵に対しポー川南岸を東進して五月八日ピアツェンツァ附近に於てポー川を渡り、敵をしてロンバルデーを放棄の止むなきに至らしめ、敵を追撃して十日有名なるロジの敵前渡河を強行、十五日ミラノに入城した。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に現代の引例として、やはりイギリスの国際的地位にある婦人作家ヴァージニア・ウルフの書いたものの一節を引用してあった。",
              "citation": {
                "source": "夫婦が作家である場合",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでその後、ヴァージニア・ウルフの作品を一寸読む機会があり、つづいて伝記を読み、私は千葉氏にもそれに注意をよび起された自分に対しても全く別な内容で或る感銘を覚えた。",
              "citation": {
                "source": "夫婦が作家である場合",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程バルザックは、沢山旅行をし、サルジニアや南部ロシアへまで出かけたこともあった。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
