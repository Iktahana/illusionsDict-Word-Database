    "definitions": [
      {
        "index": 1,
        "gloss": "guardhouse (Edo-period city)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "家主だって自身番だって、なんとも思っていやあしませんよ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "左様でございます」「こいつと一緒に番屋まで来てくれ」　二人を引っ張って、半七は近所の自身番へ行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅蜊の殻を店の前の泥に敷いていた自身番の老爺は、かかえていた笊をほうり出して、半七らを内へ入れた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると近所迷惑で、長屋中のものはみな自身番の取り調べをうけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのことは取りあえず自身番の方へもお届け申して置きましたが、けさも長五郎親分が見えましたから詳しく申し上げました」「そりゃあ案外な事になったね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "自身番まで引き摺って行って、わざわざ引っぱたくのも忌だから、ここでみんな聞いてやろうぜ」「恐れ入れました」と、千次郎はもう生きているような顔色はなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜすぐ自身番へでも連れて行かないんですえ」　かれらは半七の顔を識らなかったが、それでも庄太の連れであるので、薄々はその身分を覚ったらしく、余計な世話を焼くなというような反抗の顔色も見せなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "自身番へ引っ立てられた時、かれは狂女を粧ってその場を逃がれる積りであるらしかったが、あとから彼の男と庄太とが大きい黒犬の死骸を引き摺って来たので、かれの狂言は結局不成功に終った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　近所の自身番へ連れ込まれて、宇吉は素直に申し立てた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は少しく思案して、自身番の男に云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "縛って置くにゃあ及ばねえが、逃がさねえように気をつけて……」　宇吉をそこに預けて、半七は自身番を出た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七を蕎麦屋に待たせて置いて、徳次は自身番へ出て行ったが、やがて帰って来て笑いながら云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等ふたりは自身番へ引っ立てられて、徳次の下調べを受けたが、まず新次郎の申し立てによると、お節の縁談について鍋久のおきぬが山谷へしばしば尋ねて来る時、彼は幾たびかその供をして来て、お節の美貌にこころを奪われた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで助けて置いたのはお上のお慈悲だと云って、すぐに近所の自身番へ連れて行って、徳次がきびしく責めました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "大方そこらの番屋へ引き挙げたのであろうと、半七はその足で近所の自身番へ行ってみると、そこには幸次郎の姿も見えなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも念のために店へはいって訊くと、自身番の親方は面目ないような顔をして答えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき幸次郎が観世物小屋から河童を引っ張って来て、この自身番へあずけて行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "自身番には店の側に一種の留置場ともいうべき六畳ほどの板の間があって、その太い柱に罪人を縄でつないで置くのが例であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "自身番の者共もおどろいて其処らを片付けた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は柳橋へ半七を迎えに出たのであるが、途中で夕立にふり籠められて、そこらの軒下に雨宿りをして、小降りになるのを待ってお照の家へゆくと、どこで行き違ったか半七はもう出てしまった後であったので、また引っ返して自身番へくると、この始末である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでぐずぐず云っているよりも、幸次郎に加勢して河童のゆくえを早く探し出す方がましだと思ったので、半七は草履を自身番にぬいで置いて、跣足になって駈け出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "いけねえか」「自身番の疝気野郎、飛んでもねえどじを組みやがって、お話にもならねえ」と、幸次郎は忌々しそうに云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもよほど弱っているらしいのを常吉はいたわりながら、町内の自身番へ連れて行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の死骸は辻番から更に近所の自身番に運ばれて、町奉行所から出張した与力同心の検視をうけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雪達磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを発見した者はすぐに辻番か自身番へ届けいづべきである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雪達磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旦那がた、御苦労さまでございます」　ひとりの男が自身番のまえに浅黒い顔を出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雪達磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそれから少時そこらを猟っていたが、ほかにはなんにも新らしい発見もなかったらしく、泥によごれた手先をふところの手拭で拭きながら、もとの自身番へ引っ返してゆくと、与力はもう引き揚げて、当番の同心三浦だけが残っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雪達磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "なに、決して迷惑はかけねえから」　迷惑そうな顔をしている番頭を引っ張り出して、半七は彼を神田の自身番へ連れて行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雪達磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所の娘子供が落としたものか、あるいは死人の所持品かと、半七は自身番へ引っ返して死人の袂を丁寧にあらためると、袂の底からたった一と粒の南京玉が発見されたので、かれが南京玉の持主であったことは確かめられた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雪達磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "葱鮪の鍋の引っくり返った灰神楽のなかで豊吉はもろくも縄にかかって、町内の自身番へ引っ立てられた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雪達磨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
