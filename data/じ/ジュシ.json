  {
    "uuid": "5f672098-2c36-5f1b-bf4f-771e6e32d964",
    "entry": "孺子",
    "reading": {
      "primary": "じゅし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "child",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "女は隅へ蹙められたやうに成つて居たが軈て毛孺子の黒い笠の紐を締め直して、輕くなつた籃を擔いて去つてしまつた。",
              "citation": {
                "source": "佐渡が島",
                "author": "波の上",
                "note": "青空文庫"
              }
            },
            {
              "text": "里見の防禦使となって堂々対敵しても逃路に待ち伏せする野武士のような役目を振られて、シカモ首尾よく取り逃がして小水門目輩｜孺子をして名を成さしめてる。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が弱き者のしいたげらるるを見る時は、必ず常に、孺子をとらえて井中に投ぜんとするを目撃するがごときの感をなすも、ひっきょうこれがためである。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども孺子の為に辱めらるること此に至る。",
              "citation": {
                "source": "八宝飯",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "又孺子を廢して皇帝となるに及び、劉といひ、周にありては陳、齊にありては田、濟南にあつては王といふ、尚書にも「惇序九族」といふ事あれば、この五姓を以て宗室となすべしといひて、自ら堯の禪をうけた虞舜の氣取をした。",
              "citation": {
                "source": "楊雄と法言",
                "author": "狩野直喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "張飛はくわっと口をあいて、「孺子っ。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、曹仁自身も先に立ち、「周瑜孺子。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたたび、われの忠言を聞け」　こう城へ向っていうと、やがて※昭は、櫓の上に姿をあらわして、「孺子。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "東蔵赤面閉口していると、磐次磐三郎はまたいわく、真の狩人はかくのごときことのみにあらず、なおかくあるべきにとて、さらにまた気を吐けば前の尾嶺に忽然として出現ましませしは南無ありがたや三十三観音、金色燦爛、微妙清音、まんじゅしゃげを雨と降らせたまいてダンスをしたもう。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉たちと山で私ははじめて珠数花（まんじゅしゃげ）を手折った。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今でも真紅なまんじゅしゃげを手に持って、川の見える崖道を、華やかに笑いながら、ハンカチを手にして少し婀娜っぽく、その花にまけず美しく見えた豊子姉の姿が忘れられない。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
