    },
    "definitions": [
      {
        "index": 1,
        "gloss": "resin",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "薄曇りの空が針葉の間から隙いて見える、根を張り樹脂の多い、男松の印象を此の顔は与へた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹脂の香に　朝は悩まし　　うしなひし　さまざまのゆめ、森竝は　風に鳴るかなひろごりて　たひらかの空、　　土手づたひ　きえてゆくかなうつくしき　さまざまの夢。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "木乃伊を作るには始め塩水に死体を漬け種々の樹脂の類を塗って固めたものらしい。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小松のみどりが強烈な日光に照らされて樹脂中の揮発成分を放散するのであろう。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから街道は日によってはその樹脂臭い匂いや、また日によっては馬力の通った昼間の匂いを残していたりするのだった。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳者、予てより御通達の、潮流研究用と覚しき、赤｜封蝋附きの麦酒瓶、拾得次第｜届告仕る様、島民一般に申渡置候処、此程、本島南岸に、別小包の如き、樹脂封蝋附きの麦酒瓶が三個漂着致し居るを発見、届出申候。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは、それから、お父様とお母様にお手紙を書いて大切なビール瓶の中の一本に入れて、シッカリと樹脂で封じて、二人で何遍も何遍も接吻をしてから海の中に投げ込みました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（飛行機に残つたのは僕、　　バットの空箱を蹴つてみる）三歳の記憶縁側に陽があたつてて、樹脂が五彩に眠る時、柿の木いつぽんある中庭は、土は枇杷いろ　蝿が唸く。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に樹脂――つまり涙です。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまゝ佇んで、しめやかな松の初花の樹脂｜臭い匂ひを吸ひ入れながら、門外のいさかひを聞くとも聞かぬともなく聞く。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹脂色の蝗の吐血が掌についていました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいて庭の面には黄ろい光線が重圧され、ビール壜を陽に透して覗くように池も中ノ島も築山も、この世のものならず松樹脂色に光り輝いております。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "誤字の訂正には、樹脂をアルコールに溶かした修正液を使います。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の度に杉は針葉樹の特色を現して樹脂多い葉がばり／＼と凄じく鳴つて燒けた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙は水ではない、心の幹をしぼつた樹脂である、油である。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "松太郎は、何がなしに生甲斐がある様な気がして、深く深く、杉の樹脂の香る空気を吸つた。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "松太郎は何がなしに生き甲斐がある樣な氣がして、深く深く、杉の樹脂の香る空氣を吸つた。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "オゾーンに充ちた、松｜樹脂の匂う冬の日向は、東京での生活を暗く思い浮ばせた。",
              "citation": {
                "source": "明るい海浜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "己の背は木の皮でこすられて、肌には樹脂が黏り附いた。",
              "citation": {
                "source": "復讐",
                "author": "BALTHASAR ALDRAMIN. KURZE LEBENSGESCHICHTE AUS DEM ALTEN VENEDIG.",
                "note": "青空文庫"
              }
            },
            {
              "text": "材料に樹脂をひいた綱を用ひ、木油も少しはまぜるので、地球全體におそろしく惡臭が漂ひ、鼻の孔に栓をする必要が起る。",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "車輪に硝子に樹脂に煙草、帯革、玉葱、そのほか百姓道具が一式……これでは財布に三十両あつても、市の品ひと通り買ふことは出来まい。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と何処か小さな町からでもやつて来たらしい、風来の町人といつた容子の、樹脂で汚れて脂じんだ縞の寛袴を穿いた男が、もう一人の、ところどころに補布の当つた青い長上衣を著た、お額に大きな瘤のある男に向つて言つた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし現に今、絹張りの長椅子の上に、樹脂を塗つた長靴ばきで胡坐をかいて、俗にコレシュキといふ最も強烈な煙草をスパスパ喫つてゐるのが、ディカーニカを通つた件んのザポロージェ人たちに違ひないのを見て、ほつと安心した。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹きぬけの向うで、杉の巨木の肌に流れた樹脂の艶が自然の潤いに見え、万事ここではこうして仏から放れた清潔さを保っているのが、自然に僧侶の心さえ変形させているのだろうか、神官に似たあんなに無表情な沈黙に僧を還らせるのも、ふとこぼれた人間の情かもしれない。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨ふりだと、しっとり濡れた前の杉苗畑から、若々しい杉の樹脂の香いが微かに漂って来て戸棚にアヤの骨壺がしまってある二間の家の縁ばたに匂った。",
              "citation": {
                "source": "小祝の一家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼近い陽にぬくもった松の樹脂の匂い、芝生から立ちのぼる見えない陽炎のようないきれ、それらが海近くの濃い純粋な空気の中でとけあっていて、目をつぶってころがっている桃子はただ日光がふり注ぐばかりでなく、ふんだんな光りと空気の微粒がぴちぴちと快く粒だって皮膚や髪の根にまでしみて来るような感じである。",
              "citation": {
                "source": "夜の若葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう暗澹たる空模様の中で、黒死館の巨大な二層楼は――わけても中央にある礼拝堂の尖塔や左右の塔櫓が、一｜刷毛刷いた薄墨色の中に塗抹されていて、全体が樹脂っぽい単色画を作っていた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "でまず、最初の一つから、硝子粉、浸剤、硫黄、単寧、水銀、醋、溶和剤、黄斑粉、紅殻、樹脂――と読んでいって結局その頭文字を連ねるのです。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東蔵赤面閉口していると、磐次磐三郎はまたいわく、真の狩人はかくのごときことのみにあらず、なおかくあるべきにとて、さらにまた気を吐けば前の尾嶺に忽然として出現ましませしは南無ありがたや三十三観音、金色燦爛、微妙清音、まんじゅしゃげを雨と降らせたまいてダンスをしたもう。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉たちと山で私ははじめて珠数花（まんじゅしゃげ）を手折った。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
