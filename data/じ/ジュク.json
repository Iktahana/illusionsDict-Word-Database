    },
    "definitions": [
      {
        "index": 1,
        "gloss": "suffering pain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "また受苦週（耶蘇復活祭の前週）の間、鼠、蛇等有害動物の名を言わず、これを言わば年中その家にそんな物が群集すると伝う（一八七〇年板ロイドの『瑞典小農生活』二三〇頁、二五一頁）。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、芭蕉の一生は享楽の一生であると共に、誰の目にも受苦の一生である。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし棘のない薔薇はあつても、受苦を伴はない享楽はない。",
              "citation": {
                "source": "僻見",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "又曰、輪廻六道、受苦楽二報、生死無窮。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえに死してまた生ず」と）往生要集曰、如是展転作悪受苦、徒生徒死、輪転無際、如経偈云、一人一劫中所受諸身骨、常積不腐敗、如毘布羅山、一劫尚爾況無量劫。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "外廓の内側に沿える巷石垣の中に作り込めたる龕に、受苦聖母の祈願像あり。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂受苦聖母という像で、双手をあわせながら眼を天へ向けて祈っている姿である。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "百済観音を眺めながら、私はふとこの受苦聖母を想い出した。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは受苦観音ではない。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "基督教徒は、受苦聖母の前でどんな祈りを捧げるのであろうか。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "受苦聖母はその運命のゆえに、人間を懺悔と悲哀に誘うのだろうか。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにわれわれが物語ろうと試みる人々〔訳注――ベートーヴェン、ミケランジェロ、トルストイ、画家ミレーらの伝記が書かれた〕の生涯は、ほとんど常に永い受苦の歴史であった。",
              "citation": {
                "source": "ベートーヴェンの生涯",
                "author": "VIE DE BEETHOVEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "対岸の原の中でよしきりがじゅく／＼呟きます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見る眼に今や鷺町の家も路面も真夏の午前の陽の光りにじゅく／＼と油で揚げられかけております。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たくさんの花が、にじのように咲きみだれて、じゅくした果物が、おいしそうにふさになって、なっていました。",
              "citation": {
                "source": "アラビヤンナイト",
