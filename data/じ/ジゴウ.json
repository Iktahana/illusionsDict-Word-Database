    "definitions": [
      {
        "index": 1,
        "gloss": "type size",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "分家伊沢の伝ふる所に従へば、榛軒は厚朴を愛したので、名字号皆義を此木に取つたのだと云ふ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "従之の氏名字号通称は相似たることも亦甚だしいではないか。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此に於てか門人後藤世張を随へ手抄杜韓蘇古詩三巻、詩韻含英一部と外史の草稿とを携へて京を発し淀川を下り、大阪より篠崎承弼に送られて尼崎に至り、雨には即ち淹留し晴には即ち行き広島に至りて父の墓に謁し赤間関に淹留すること半月、年々摂酒附商舟、磊落万罌堆岸頭、清※尤推鶴字号、駕人酔夢上楊州の詩あり。",
              "citation": {
                "source": "頼襄を論ず",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "『上毛の民俗』の最近の活字号に、列挙せられた記事などは好い例であった。",
              "citation": {
                "source": "垣内の話",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "じごうじとくと、あきらめるんだね」　人形の顔の怪人は、ニヤニヤわらいながら、きみのわるいことをいうのです。",
              "citation": {
                "source": "怪人と少年探偵",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
