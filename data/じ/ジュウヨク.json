        "gloss": "Ten Wings (set of commentaries to I Ching traditionally ascribed to Confucius)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
