  {
    "uuid": "ab4d6cb4-f14f-5afa-b18a-e56d17929f2c",
    "entry": "獣欲",
    "reading": {
      "primary": "じゅうよく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
