    "definitions": [
      {
        "index": 1,
        "gloss": "reception (telephone)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
