[
  {
    "uuid": "6ee22aad-6286-5207-bfe8-577789b654ed",
    "entry": "準ずる",
    "reading": {
      "primary": "じゅんずる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-ずる変",
