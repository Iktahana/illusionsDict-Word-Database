    },
    "definitions": [
      {
        "index": 1,
        "gloss": "time",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これは、注文者がもし素人の数寄者とでもいうのであれば、あるいはそうすることも時宣に依ってかまわぬことでもあろうが、若井氏は商売人である。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "矮鶏の作が計らず展覧会に出品されたいきさつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはある時宣宗が一句を得て対を挙人中に求めると、温は宣宗の「金歩揺」に対するに「玉条脱」を以てして、帝に激賞せられたのである。",
              "citation": {
                "source": "魚玄機",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
