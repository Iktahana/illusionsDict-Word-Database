        "index": 1,
        "gloss": "earplug (traditional jewellery worn in the earlobe, popular in Jomon-period Japan)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あたしたちがウルティムス号に乗り込んだら、まず綿を使って耳栓をします。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーネギー・ホールのコンサートでは、場内警備にあたった警官は、ガン・ベルトからピストルの弾を抜いて耳にさしこみ、「騒音」に対する耳栓にした。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
