      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "removing a name",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『われひとりを悪者として勘当除籍、家郷追放の現在、いよいよわれのみをあしざまにののしり、それがために四方八方うまく治まり居る様子』などのお言葉、おうらめしく存じあげ候。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八年前、除籍された。",
              "citation": {
                "source": "悶悶日記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『われひとりを悪者として勘当除籍、家郷追放の現在、いよいよわれのみをあしざまにののしり、それがために四方八方うまく治まり居る様子、』などのお言葉、おうらめしく存じあげ候。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、些とも不思議はないが、同時に両方に夢中になってる中に、学校を除籍された。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも形勢が既に定って動かすべからずなって、其形勢に制せられて始て決心するのだから、学校を除籍せられたばかりでは、未だ決心が出来なかった。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "甞て私が学校を除籍せられた時、父が学資の仕送りを絶ったのは、斯もしたら或は帰って来るかと思ったからだ。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして結果は伯爵家を除籍して別家させなければなるまいという事になった。",
              "citation": {
                "source": "芳川鎌子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "除籍された家へ、離別した夫の住む家へと運ばれていった。",
              "citation": {
                "source": "芳川鎌子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "刺客およそ十七人、脱藩除籍の願書を藩邸に投げ込んで永の暇を告げたというから、浪人ではあるが、それらの水戸の侍たちが井伊大老の登城を待ち受けて、その首級を挙げた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は罪あって除籍せられ、「非人」と称せられた。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "郡会事務局にては、該農民らはすでに郡会より除籍せられトムスク県下に籍を置くものなるを楯に給与を拒み、かつまた資金も無いのであります。",
              "citation": {
                "source": "妻",
                "author": "ЖЕНА",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして八月十六日、前内大臣宗盛以下平家一門百六十余人の官職をすべて剥奪、殿上の間から除籍された。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第八巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "除籍を免れたのは、平大納言時忠、内蔵頭信基、讃岐中将｜時実の父子三人である。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第八巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "国は寿の知らないうち、除籍する方法はないかと云った人だから、（この上迷惑を蒙らないための由、寿がどんな迷惑をかけたでしょう、それほどの）うっかりすると、帰って来ようとするとき手紙が来て、姉さんはとりあえず国府津へ転出しておいたから、などということになりかねませんでした。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘当と同時に領内をたちのけと命じ、細貝家から除籍したことを、正式に係りへ届け出た。",
              "citation": {
                "source": "やぶからし",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ除籍してあっても、細貝家の一人息子だったことに変りはない。",
              "citation": {
                "source": "やぶからし",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたは弁護士名簿から除籍してやる。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
