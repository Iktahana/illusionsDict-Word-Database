          "standard": [
            {
              "text": "女権主義は、男女平等を基本理念としています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "現代社会において、女権主義の重要性は増しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、女権主義の観点から現代社会の問題を分析しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "が、生得上品な性質である上に、外国に長くいたために、女権主義者であり、平和主義者であり、煩わしいことが、嫌いであるので年々悪妻の強さを発揮している綾子夫人を、当らずさわらず、取り扱うことに馴れてしまったのである。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく口汚く罵るものの先生は何も新しい女権主義を根本から否定しているためではない。",
              "citation": {
                "source": "妾宅",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
