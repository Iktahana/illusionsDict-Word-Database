        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして朝になつて見ると、自分が熟睡しなかつたのやら何やらも、殆ど知らない位でした。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "親父も弁公も昼間の激しい労働で熟睡したが文公は熱と咳とで終夜苦しめられ、明け方近くなってやっと寝入った。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうして今時分こんなところにねえ」　渠は跫音を忍びて、再び男に寄り添いつつ、「ほんとに罪のない顔をして寝ているよ」　恍惚として瞳を凝らしたりしが、にわかにおのれが絡いし毛布を脱ぎて被せ懸けたれども、馭者は夢にも知らで熟睡せり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一座の連中は早くも荷物を取｜纏めて、いざ引き払わんと、太夫の夢を喚びたりしに、渠は快眠を惜しみて、一足先に行けと現に言い放ちて、再び熟睡せり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "熟睡した快さ、雨の音のうれしさ。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明来、お土産は例の如し、鰺はうまいし焼酎もわるくない、酔ひつぶれて宵から熟睡。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "追加・おべんとうをひらく雀も何やら食べてゐる・昼寝覚の夕立の水音が鳴りだした　八月十八日昨夜は二人共安眠熟睡だつた。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は天満宮参詣をやめて旧友Ｍ君を訪ねる、涙ぐましいほど歓待してくれた、奥さんもお嬢さんも、おばあさんまで出てきて、私の与多話を聞いて下さつた、十時近く、帰宿して熟睡。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔うて戻つて熟睡、大鼾であたりをなやましたらしい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "疑いもない強盗殺人で、新夫婦が熟睡して気付かぬ間に演ぜられた兇行に相違ない。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "熟睡していた鶴木老検事は、ようようの事で起上った。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、火消したちは次郎兵衛の新居にぎっしりつまって祝い酒を呑み、ひとりずつ順々に隠し芸をして夜を更しいよいよ翌朝になってやっとおしまいのひとりが二枚の皿の手品をやって皆の泥酔と熟睡の眼をごまかし或る一隅からのぱちぱちという喝采でもって報いられ、祝賀の宴はおわった。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "低く小さい、鼻よりも、上唇一、二センチ高く腫れあがり、別段、お岩様を気にかけず、昨夜と同じに熟睡うまそう、寝顔つくづく見れば、まごうかたなき善人、ひるやかましき、これも仏性の愚妻の一人であった。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あさましいまでに、私は、熟睡を渇望する。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "熟睡していないせいかしら。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の瞼は最早それを閉ぢるべき筋肉の使用法を忘れ果て、夜、熟睡してゐる時でも、紀昌の目はクワッと大きく見開かれた儘である。",
              "citation": {
                "source": "名人傳",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の瞼はもはやそれを閉じるべき筋肉の使用法を忘れ果て、夜、熟睡している時でも、紀昌の目はカッと大きく見開かれたままである。",
              "citation": {
                "source": "名人伝",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夜、翁の請に応じて即吟、白扇に題したる我句は、越えて来て又｜一峰や月のあと　暁天の白むまで眠り得ず、翌朝日｜闌けて起き出でたるは、いつの間にか明方の熟睡に入りたりしと覚ゆ。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "外に出て一応各部署を点検し終わると、ふたたび幕営に入り、雷のごとき鼾声を立てて熟睡した。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二時頃、狂人は熟睡に陥った。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "悟浄は、熟睡のあとのさっぱりした気持で起上がった。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家人は階下で熟睡しているらしい。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "両人とも熟睡していて夜中に何も聞かなかったという。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "気性の荒い動物は刃物をちくりと感じただけでも、熟睡した者をたたき起こすくらい騒ぐはず。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの善良なる質屋さんが熟睡するまでは、やつらも身動きがとれない。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "身の疲に酒の醉さへ加はりたれば、程なく熟睡して前後を知らず。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二時間の熟睡は好き保養なるべし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間も無事だ、牛も無事だ、よしといったような、爽快な気分で朝まで熟睡した。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゅくすいコンテストが　あれば　ほんと　いっとうしょう　まちがいなし！",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
