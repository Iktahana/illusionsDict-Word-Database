    "definitions": [
      {
        "index": 1,
        "gloss": "under ... circumstances",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
