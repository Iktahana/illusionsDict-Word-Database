    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the foregoing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "外史氏山陽が後に詠んだのに、｜将士銜枚｜馬結舌｜桶狭如桶雷擘裂｜驕竜喪元敗鱗飛｜撲面腥風雨耶血一戦始開撥乱機万古海道戦氛滅唯見血痕紅紋纈笠寺の山路ゆすりしゆふたちの　　あめの下にもかゝりけるかな　これは幕末の井上文雄の歌である。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "上文に據ば金剛嬉戯は和合出生之義だそうな。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから井上文雄と云ふ先生があります。",
              "citation": {
                "source": "假名遣意見",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "言ひ換ふれば、我が国民に普遍なる特質（而して此かる特質は要求するまでもなく作家が日本人なる限り、其の描写の方面を異にせるに拘らず、之れに触れざる作家なかるべき所以は普遍といふ語にも著くまた上文既に論じたる所にも著し）とは果して如何なるものなるかと。",
              "citation": {
                "source": "国民性と文学",
                "author": "綱島梁川",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから『荊楚歳時記』から引いた元旦の式を述べた上文、〈以て山※悪鬼を辟く〉の次に、〈長幼ことごとく衣冠を正し、次を以て拝賀し、椒柏酒を進め、桃湯を飲み屠蘇を進む云々、各一鶏子を進む〉とあって、註に『周処風土記』に曰く、正旦まさに生ながら鶏子一枚を呑むべし、これを錬形というとある。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそも産児制限なるものは、法律上文化的の生活が許されたる智識階級の……」云々。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ以上文藝時代ともあらうものが、背競べをさせられて、しかも平氣で背くらべをして大家を持ち上げて默つてゐると云ふその顏つきは見てゐられないではないか。",
              "citation": {
                "source": "書翰",
                "author": "大正十三年十一月四日　川端康成宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に井上文雄の『調鶴集』を見てまた失望す。",
              "citation": {
                "source": "曙覧の歌",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればといってこの二派が先天的に哲理上こう違うから微塵も一致するものでないという理窟も書いてなし、また理論上文芸の流派は是非こう分化するものだとも教えてくれない。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "其上文句が気に喰はない。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学・文学（芸術）・などを総括する言葉を便宜上文化とするなら、文化は認識の総括となる。",
              "citation": {
                "source": "哲学の現代的意義",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　美的生活の事例　上文を説けるが如く、價値の絶對なるもの、是を美的と爲し、美的價値の最も醇粹なるもの、是を本能の滿足と爲す。",
              "citation": {
                "source": "美的生活を論ず",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を見せられようとも、また見せられた現象を皮相的にレンズにうつしたとしても、それが人道上文学上、恥ずべきことであると考えられるだろうか。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」わたくしは榛軒の父蘭軒と同じく本草に通じてゐたことを示さむがために、多く上文を刪らなかつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此数者中岡西氏は既に渋江抽斎伝に見え、又上文にも見えてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "上文は己巳六月十四日に棠軒が藩の医官を拝するに終つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この姉妹が盛りのころは、深川の芸者で姉は小川屋の小三といい、または八丁堀｜櫓下の芸者となり、そのほかさまざまの生活をして、好き自由な日を暮しながら歌人としても相当に認められ、井上文雄から松の門の名を許され、文人墨客の間を縫うて、彼女の名は喧伝されたのであった。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして八丁堀｜茅場町の国文の大家、井上文雄の内弟子になった。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "女流歌人｜松の門三艸子は長命であったが、その前身は井上文雄の内弟子兼｜妾で、その後、深川松井町の芸妓｜小川小三である。",
              "citation": {
                "source": "明治大正美女追憶",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上文體の考察を約言すれば、此文は文法も知らず典故も知らずして書いたもので、且つ全體の調子より察して比較的近頃の人の作と思はせられる。",
              "citation": {
                "source": "天津教古文書の批判",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上文體の考察を約言すれば、此文は假名違ひがあり、假名の多過ぎたるも時代の下れることを示し、口寄せ風の口調も如何はしいことであり、之を長慶天皇の宸翰など稱するは實に以ての外のことである。",
              "citation": {
                "source": "天津教古文書の批判",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上文體の考察を約言すれば、此文は長慶天皇御眞筆の文と同じく全く甚しい僞作である。",
              "citation": {
                "source": "天津教古文書の批判",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上文體の考察を約言すれば、教養ある人の手に成るものと取ることの出來ない俗惡の文章であり、殊に發音上シスの區別を爲すことの出來ない疑も加はり、此點地方的色彩濃厚となり、中央政府の重要なる地位にある平群眞鳥の筆になるなどとは、凡そ信ずべからざることである。",
              "citation": {
                "source": "天津教古文書の批判",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上文體の考察を約言すれば、此文書は神代文字で記してゐるが、他の文書と同じく近頃のもので、其作製は第五文書より後るるものと推斷される。",
              "citation": {
                "source": "天津教古文書の批判",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三艸子は日本橋茅場町の井上文雄といふ國學者の妾となつて、豐かでない臺所仕事をしながら學んだ女だつた。",
              "citation": {
                "source": "河風",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユックは一面識もない學生が、いかにして君の代作が出來るかと尋ねると、支那人の教師はさも不思議相な顏付をして、私は彼の學生に一年以上文章の作製法を教へた。",
              "citation": {
                "source": "支那人の文弱と保守",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴峯戊申は其著『襲國僞僭考』に於いて、『魏志』上文の百里を不彌國より投馬國に至る里程と誤解して曰く投馬は和名鈔筑後郡名上妻｜加牟豆萬、下妻郡准上、とある妻なるべし。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればこそ上文に見ゆる如く「復有國、皆倭種」とのみ云ひて、其國名を擧げざりしなれ。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "石上文麻呂から、今の世の大学生の思想演説のやうなものを聞かうとするのが本望だらうか。",
              "citation": {
                "source": "「なよたけ」の解釈",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三幕目までなよたけ物語の現実で、四幕目から石上文麻呂の育てた「なよたけ」として出発するのだから、もつと原本の竹取より美しくしてもよい。",
              "citation": {
                "source": "「なよたけ」の解釈",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
