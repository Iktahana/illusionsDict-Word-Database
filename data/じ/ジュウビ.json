    "definitions": [
      {
        "index": 1,
        "gloss": "completion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかるにこれに続きてやや充備したる民権論派の萌芽は生じたり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "之より先、陸軍は第二次国防充備の五カ年計画のために、明年度以降五カ年総額六億の要求を大蔵省に提出している。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると一人の脊の高い、青い顔をした乞食が、「俺は、一｜日じゅうびっこのまねをして町じゅうを歩きまわったが、やっと、こればかりしかもらわなかった。",
              "citation": {
                "source": "石をのせた車",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか永久におどしつけられたような顔をした女房も、年じゅうびっくりしているので化石したような顔をし、口をぽかんとあけたいくたりかの子供たちもやって来た。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
