    "definitions": [
      {
        "index": 1,
        "gloss": "one's predestined length of life",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
