    },
    "definitions": [
      {
        "index": 1,
        "gloss": "circulation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "このような変化がどうして起こるかはわからないが、いちばん直接な原因はやはり血液の循環の模様が変わったために脳の物質にどうにか反応する点にあると素人考えに考えている。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "焚火焚火、人々は手足の関節から、血の循環が一秒一秒止まったように、意識された、今凍えて行くのだということも解る、早くどうかしろと神経が知らせてくれる、誰の顔を見ても、蝋のように白い、マッチ箱は燐寸一本さえ、烟を立てることなしに、空になったほど、何もかも、ビショ濡れになった。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし負け惜しみの強い彼の説によると「世界は循環する。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局循環論理のようなものに陥ってしまう恐れがある。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう芸術上のグロテスクな傾向が、循環的に吾々の倫理思想や人生観に与える反応はどんなものであろうか。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……人生の本當の姿はその二つの領域に相亙つてをり、又、もつとも大きく循環する血はその兩方を流れてゐるのです。",
              "citation": {
                "source": "ドゥイノ悲歌",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "南洋では年じゅう夏の島がある、インドなどの季節風交代による雨期乾期のごときものも温帯における春夏秋冬の循環とはかなりかけ離れたむしろ「規則正しい長期の天気変化」とでも名づけたいものである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともこの点では英国諸島はきわめて類似の位置にあるが、しかし大陸の西側と東側とでは大気ならびに海流の循環の影響でいろいろな相違のあることが気候学者によってとうに注意されている。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような理由から、日本の気候には大陸的な要素と海洋的な要素が複雑に交錯しており、また時間的にも、週期的季節的循環のほかに不規則で急激活発な交代が見られる。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳諧歳時記を繰ってみてもわかるように季節に応ずる食用の野菜魚貝の年週期的循環がそれだけでも日本人の日常生活を多彩にしている。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人とも、その体内には、健康で清純な血液の循環を妨げる一つの病菌も、一ツの傷もないように見えた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その反対に、茶わんのまん中のほうでは逆に上のほうへのぼって、表面からは外側に向かって流れる、だいたいそういうふうな循環が起こります。",
              "citation": {
                "source": "茶わんの湯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと同じような気流の循環が、もっと大仕掛けに陸地と海との間に行なわれております。",
              "citation": {
                "source": "茶わんの湯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば安政元年の大震のような大規模のものが襲来すれば、東京から福岡に至るまでのあらゆる大小都市の重要な文化設備が一時に脅かされ、西半日本の神経系統と循環系統に相当ひどい故障が起こって有機体としての一国の生活機能に著しい麻痺症状を惹起する恐れがある。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "性が主なのか、愛が主なのか、卵が親か、鶏が親か、いつまでも循環するあいまい極まる概念である。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六七台も待つ間には、必ず満員の各種の変化の相の循環するのを認める事ができる。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果はさらに循環的に、その次の停留所に着く時刻を遅らせる、and so on で、この乙電車の混雑はだんだんに増すばかりである。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のからだじゅうの血液ははじめてどこにも停滞する事なしに毛細管の末梢までも自由に循環する。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "循環小数みたいですね」　もとよりそこに盃洗などはなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤道から北極まで大循環さえやるんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大循環の話なら面白いけれどむずかしいよ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は大循環のことを話すのはほんとうはすきなんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は大循環は二｜遍やったよ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も一遍は途中からやめて下りたけれど、僕たちは五遍大循環をやって来ると、もうそれぁ幅が利くんだからね、だからみんなでかけるんだよ、けれども仲々うまく行かないからねえ、ギルバート群島からのぼって発ったときはうまくいったけれどねえ、ボルネオから発ったときはすっかりしくじっちゃったんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大循環志願者出発線、これより北極に至る八千九百ベェスター南極に至る八千七百ベェスターと書いてあるんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先頃僕行って挨拶して来たおじさんはもう十六回目の大循環なんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大循環でいちばんこわいのはこの時なんだよ、この僕たちのまわるもっと中の方に極渦といって大きな環があるんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもなんにも卑怯をしないものは割合平気だねえ、大循環の途中でわざとつかれた隣りの人の手をはなしたものだの早くみんなやめるといいと考えてきろきろみんなの足なみを見たりしたものはどれもすっかり入れられちまうんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときあちこちの氷山に、大循環｜到着者はこの附近に於て数日間休養すべし、帰路は各人の任意なるも障碍は来路に倍するを以て充分の覚悟を要す。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいや、行くように云われて来たんだ、さあ通してお呉れ、いいや僕たちこそ大循環なんだ、よくマークを見てごらん、大循環と云われると大抵誰でも一寸顔いろを和らげてマークをよく見るねえ、はじめから、ああ大循環だ通してやれなんて云うものもそれぁあるよ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
