          "literary": [
            {
              "text": "」家内は一枚一枚きたながらずに調べて、「これなどは、純毛ですよ。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来の賊なれば、この青年の心臓を抜いて、残りの身体はそのまま溝の中へでも叩きこんでおいたであろうが、わが烏啼――いや、かの烏啼めに至っては、下に藁蒲団を敷き、被害者の身体は純毛五枚で包んだ上で、ここへ捨てていった。",
              "citation": {
                "source": "心臓盗難",
                "author": "烏啼天駆シリーズ・２",
                "note": "青空文庫"
              }
            },
            {
              "text": "背広服は少し古いが、純毛のもので、丹念にブラシがかけられていた。",
              "citation": {
                "source": "塩花",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "純毛品はＳ・Ｆ時代には貴重品でねがあがるものなり。",
              "citation": {
                "source": "日記",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "（×月×日、スカパフロー発）　余は今、純毛純綿のベッドに横わりながら、昨日に引続き、スカパフロー発の第二報の原稿を書いているところである。",
              "citation": {
                "source": "沈没男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "服はララから贈られた純綿・純毛、生意気なと思わせるほどのモダンな仕立て。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "居心地のよい家にも、純毛の洋服も、ライスカレーにも未練を残さず、孤児が収容所を飛び出すのは、そこに「真実」が見いだせなかったからである。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし二人は濡れない上着を持っており、自分は純毛のシャツだったのでかなり助かった。",
              "citation": {
                "source": "一ノ倉沢正面の登攀",
                "author": "小川登喜男",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀子は黒い純毛の厚地外套の前をいくらか引上げるような身ごなしで立ったまま、室の様子を机から壁へと眺めまわしながら、「素晴らしいわねえ！",
              "citation": {
                "source": "今朝の雪",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛糸でこしらえた下着類も、もう純毛なんかないし。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "各※に純毛の手袋一組ずつがついています。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "純毛は大人用は本年はないでしょうね、折角のおくりものでも。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンポン式足袋はいかがでしょうか、あれでも純毛よ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "デンが半ば窒息しかけてひれ伏した羽毛は、体にまとわりつくほど快適で、純毛のように柔らかく、泡のように透けていた。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            }
          ]
        }
