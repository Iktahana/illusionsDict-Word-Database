    "definitions": [
      {
        "index": 1,
        "gloss": "dweller",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すなわち、共に府下｜三鷹町｜下連雀の住人なのである。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四は、山の不幸は、住人の不幸になって、シャスタ山と、切っても切れぬ歴史中の人を、埋没しようとしている。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大学士の吸ふ巻煙草がポツンと赤く見えるだけ、「斯う納まって見ると、我輩もさながら、洞熊か、洞窟住人だ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大学士の吸う巻煙草がポツンと赤く見えるだけ、「斯う納まって見ると、我輩もさながら、洞熊か、洞窟住人だ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾度も住人が變つて、今度のは久しく住んで居るさうである。",
              "citation": {
                "source": "怪談女の輪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の泣いた被告は三村保三郎と云つて大阪の住人であつた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ皆顏色が眞つ蒼です」――此時、選手第一の賞を得たのは、池をめぐること三十幾囘、翌日發表されて、年は六十に餘る、此の老神行太保戴宗は、加州小松の住人、もとの加賀藩の飛脚であつた。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六日、丁亥、天晴、安念法師の白状に依りて、謀叛の輩を、所々に於て生虜らる、凡そ張本百三十余人、伴類二百人に及ぶと云々、此事、濫觴を尋ぬれば、信濃国の住人泉小次郎親平、去々年以後謀逆を企て、輩を相語らひ、故左衛門督殿の若君を以て大将軍と為し、相州を度り奉らんと欲すと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとしの二月にも信濃国の住人、泉小次郎親平といふ人が、相州さまを憎んで亡きものにしようと内々謀逆を企ててゐたのが、未然に露顕して鎌倉中が大騒動になつたといふ事件がございました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小生は第一號に現はれたる如き、小世界の住人のみの雜誌の如き、時代と何も關係のない樣な編輯法は嫌ひなり。",
              "citation": {
                "source": "消息",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを通って、両方の塀の間を、鈍い稲妻形に畝って、狭い四角から坂の上へ、にょい、と皺面を出した……　坂下の下界の住人は驚いたろう。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛騨国の住人日本の刻彫師、尾ヶ｜瀬菊之丞孫の菊松、行年積つて七十一歳。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」としめやかに朱唇が動く、と花が囁くやうなのに、恍惚して我を忘れる雪枝より、飛騨の国の住人以つての外畏縮に及んで、「南無三宝、あやまり果てた。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右は今出川住人富田無敵の訴出に依れば、盗賊の逐電致せし者にきっとまぎれなき由、依って高札を掲げる事如件」　とあり、何となく面映ゆく赤面していると、意外な囁きが耳に入った。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "長屋の住人の筈のお前は、その時既にどこやら姿をくらましていた。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "水城、博多は多多良が浜の防塁、別しては箱崎の宮の大前、一歩も上げじ許すなと、獅子奮迅に射放ち落せば、波を潜つて軽舸の面々、漕ぎ寄せ、漕ぎ寄せ、日本国は四国の住人河野ノ通有、いで物見せん、夷原、月は弓張る幸先に、倒す檣渡りに船と乗りかけ、つけ入り、斬り込んだり。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は山荘の住人で、平生竹や草や昆虫ばかりの中に立ち交っているので、身のまわりなぞは清潔にはしているが、少くとも野趣そのままにちがいなかった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのやうな面が將軍家のおん手に渡りて、これぞ伊豆の住人夜叉王が作と寶物帳にも記されて、百千年の後までも笑ひをのこさば、一生の名折れ、末代の恥辱、所詮夜叉王の名は廢つた。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "小舎の住人が珍しい人声に驚かされて、弓矢を手に表へ出て来た、頭から毛皮を被った鬚ぼうぼうの熊のような山男の顔の中に、李陵がかつての移中厩監蘇子卿の俤を見出してからも、先方がこの胡服の大官を前の騎都尉李少卿と認めるまでにはなおしばらくの時間が必要であった。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "九州の住人、須々木四郎と名乗って雨の如く射かけたから堪らない。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おらあレヴュー小屋の住人だぜ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから廃院の住人たちを調べて来てくれること、――これだけをやって来てもらえば、大に助かるんだがね。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "不安のあまり、僕はその小屋の新しい住人をちょっと見てやろうと心に決めました。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその反対に、そうであってほしいのですが、その住人があなたが来ると知らされ、昨日は踏み込む前に出て行ったのだとすれば、今はもう戻っているので、解決も楽になるでしょう。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして会っているあいだにお手伝いが飛び込んできて、今の夫が帰宅してきたとつげ、女もこの小屋にまっすぐ今の夫がやってくると分かったので、住人を裏口から急いで出して、おそらく、すぐそばにあるとかいう赤松の林に隠れさせた。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから館の住人についても調べた上で、帰って僕に報告を。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒野の孤独な住人たちだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりオドリ屋敷なりハーヴィ屋敷なりキャリトン屋敷なり――まあ名前以外忘れられたかつての住人たちというわけだ。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが照れることなく一から筋道を追って熱をもって表現する能力は、オレを含むこの国の住人にもともと欠けていた資質である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーソナルコンピューターの初心がコンピューター技術の個人への解放にあったことを忘れ、コンピューター村の住人としての実感にこだわっているのではないか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
