[
  {
    "uuid": "5a70545d-0895-5e20-9fa3-b2e73c3acfee",
    "entry": "城門",
    "reading": {
      "primary": "じょうもん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
