    "definitions": [
      {
        "index": 1,
        "gloss": "gene",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこで、手前商いまするのは、ラジーンと申して、金山鉱山におきまして金を溶かしまする処の、炉壺にいたしまするのを使って製造いたしました、口金の保助器は内務省お届済みの専売特許品、御使用の方法は唯今お目に懸けまするが、安全口金、一名火事知らずと申しまして、」「何だ、何だ。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "外からの音も聞こえず、魚類もまれにしか来ない所で、悟浄もしかたなしに、坐忘先生の前に坐って眼を瞑ってみたら、何かジーンと耳が遠くなりそうな感じだった。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀蠅の飛びまわる四｜畳の部屋は風も通らず、ジーンと音がするように蒸し暑かった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝉時雨が、ただ一つになって聞えて、清水の上に、ジーンと響く。",
              "citation": {
                "source": "瓜の涙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドンのウェストミンスター・アッベイは、熊楠知人で詩名兼ねて濫行の聞え高かったジーン・ハーフッドその坊に棲み、毎度飲ませてもらいに往った。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の耳の底には、ジーンといふ微音が残る。",
              "citation": {
                "source": "眠い一日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジーンといふ音のやうな感じが、頬を透して口のなかへ沁み渡りました。",
              "citation": {
                "source": "美智子と歯痛",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも私は丁度同時にバージーンの修辞学を或る外国人から授かって、始終講義を聞いていた故、確かにその一部をバージーンから得たらしき（坪内君には聞いて見ないが、）『小説神髄』を余りに驚かなかったが、シカシ例証として日本の作物を挙げて論じられた処は面白くも読みかつまたお庇で蒙を啓いた処もある。",
              "citation": {
                "source": "明治の文学の開拓者",
                "author": "――坪内逍遥――",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈ヒピー・ヒピー・シェイク〉スウィンギング・ブルー・ジーンズ　二カ月後、起床音楽はがらりと変わった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "スウィンギング・ブルー・ジーンズは、声が気に入らない、という高志の主張で、消滅。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志が身につけているのは、ブルージーンズだけだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "上半身裸なのに、下はちゃんと長いジーンズを穿いている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志のジーンズは短くて、裾がくるぶしの上にきている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志がブルージーンズだけ穿いて、慶一のとなりに黙って腰をおろした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志はジーンズのポケットをさぐって、カギをとりだした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "裾幅が十六センチしかないホワイトジーンズを脱ごうとして、高志は片足で立ち、二、三歩バックステップを踏んで、飛び板に背中をぶつけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一は、Ｔシャツ、ジーンズ、バスタオルと、ていねいにたたんだ上に、靴底を上にむけてスニーカーをおいた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ディス・ソング・イズ・デディケイティド・トゥ・ザ・レイト・グレイト・ジーン・クラーク。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "故ジーン・クラークに捧ぐだと？",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ザ・レイト・グレイト・ジーン・クラークってのは？",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほうが、ジーンにふさわしい」「わかった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳がジーンとなっていた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪を含んだ暗い空の下で、街は地の底からジーンと靜まりかへつてゐた。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "深夜らしくジイン、ジーン、ジーンと耳のなる音がする。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジーン――鋭く響いて、スコップは私達の前へ弾き落された。",
              "citation": {
                "source": "気狂い機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちの車の硝子が、護謨毬をたたきつけたかのようにジジーンと音を立てた。",
              "citation": {
                "source": "人造人間殺害事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の芯がジーンと痛む。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
