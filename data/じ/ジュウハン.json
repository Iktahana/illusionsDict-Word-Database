[
  {
    "uuid": "d33af195-45fc-5317-8e03-a3b23ed99158",
    "entry": "従犯",
    "reading": {
      "primary": "じゅうはん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "accomplice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "インド人の船乗りは、経歴こそ大悪党として知られた男だが、ことシンクレア氏の件については、夫が窓際に姿を見せた数秒後には階段の下にいたことがわかっているから、この犯罪においては従犯程度の役割しかないだろう。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に夫のロスコー氏はその従犯で、夫人の命令のまにまに与えられた地形図を図案化して刺青する技術師に過ぎなかった。",
              "citation": {
                "source": "Ｓ岬西洋婦人絞殺事件",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者は押収され、後者はその後従犯人として、軍法会議で多少の審問を受けた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "重罪裁判廷はふたりの従犯人で満足しなければならなかった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "……従犯の白日鼠夫婦は、すぐ召捕りました。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
