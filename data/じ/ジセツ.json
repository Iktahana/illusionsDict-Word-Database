    },
    "definitions": [
      {
        "index": 1,
        "gloss": "season",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "斯かる場合に稀薄にされた直観に気付くことなく、何とか直観濃厚の時節に於けるが如く活々としたいものだと思つて、新しい方法を講じようとして何かと議論すればする程、直観層は荒れるばかりである。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが少しひどくなって来ると、自分が何かしらもっと積極的な悪事を犯していて、今にもその応報を受けるべき時節が到来しそうな心持ちになる。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その言質をいよ／＼受け出さなければならない時節が到来した。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "永い間宅にばかりくすぶつて居て、適※此の好い時節に外の風に吹かれると氣持はいゝやうなものゝ、餘りに美しい自然と其處にも附き纏ふ世の中の刺戟が病餘の神經には少し利き過ぎるやうでもある。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その言質をいよいよ受け出さなければならない時節が到来した。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで時節柄天体の運動に関する最新の大発見をちょっとここで読者に御紹介しておきたい。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里にも三十年、まあ三十年もまめに働けばもう、楽に穴にもぐって行く時節が来たというものですよ。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思うと、また今の時節には少しどうかと心配されるような非戦論を滔々と述べ聞かすのであった。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大詰はこちらに案あり）　時節柄大河内で西郷さんか、乃木さんの一代記八千ぐらいにまとめてやればどうやろか。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の初の旅、僕は何よりも是が好で、今日まで數々此季節に旅行した、然しあゝ何等の幸福ぞ、胸に樂しい、嬉れしい空想を懷きながら、今夜は彼の娘に遇はれると思ひながら、今夜は彼の清く澄んだ温泉に入られると思ひながら、此好時節に旅行せんとは。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "食卓には、いつも、切子ガラスの花瓶に、時節の花が挿してあった。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "といったら、考えるまでもなく、それは偽者だというだろうが、なにぶんにも今の時節だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の時節――勤王討幕の議論が沸騰している今の時節では、仮りにも京都の公家にゆかりがあるという者、それは厳重に詮議しなければならない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、この地に棉産を得るとせば、日本は米国より棉花の輸入を仰がずとも済む時節が来るかもしれない。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴等も、この頃は、時節柄現金でなけりゃ、何一つ買うことも出来ねえそうですから。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどその時分は火事の多い時節であった。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹屋の藤は時節にあらず、金格子の東海樓は通つた道の青樓さの、處で今日の腹工合と、懷中の都合に因つて、天利といふので午餉にしよう、其づ其の城を見て梅とやれ、莟は未だ固くツてもお天氣は此の通り、又此の小田原と來た日には、暖いこと日本一だ、喃、御亭主。",
              "citation": {
                "source": "城の石垣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それというのが、時節柄暑さのため、恐しい悪い病が流行って、先に通った辻などという村は、から一面に石灰だらけじゃあるまいか。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "辻の、この辺で、月の中空に雲を渡る婦の幻を見たと思う、屋根の上から、城の大手の森をかけて、一面にどんよりと曇った中に、一筋真白な雲の靡くのは、やがて銀河になる時節も近い。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "時節によって鱸を釣ろうというので、夕方から船宿で船を借りて、夜釣をして居る人がある。",
              "citation": {
                "source": "夜の隅田川",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに、従来のいわゆる統計物理学は物理学の一方の庇を借りた寄生物であったのであるが、今ではこの店子に主家を明け渡す時節が到来しつつあるのではないか。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜の時節だとここの空に造花がいっぱいに飾ってあったりして、正面の階段の下では美しい制服を着た少年が合奏をやっている事もあった。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "キザな言い方であるが、花ひらく時節が来なければ、それは、はっきり解明できないもののようにも思われる。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその粟餅も、時節がら、ずいぶん小さくなったが、これもどうも仕方がないと、黒坂森のまん中のまっくろな巨きな巌がおしまいに云っていました。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "理屈のわかる時節が来たなら二度ビックリするような話が、底の方に隠れておろうやら知れん」「そこでトウトウ思案に詰まった揚句がアンタの事じゃ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "大根の時節に、近郊を散歩すると、これらの細流のほとり、いたるところで、農夫が大根の土を洗っているのを見る。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "其｜言葉の一々を雲飛は心に銘し、やゝ氣を取直して時節の來るのを待て居た。",
              "citation": {
                "source": "石清虚",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い間｜宅にばかりくすぶっていて、たまたまこのよい時節に外の風に吹かれると気持ちはいいようなものの、あまりに美しい自然とそこにも付きまとう世の中の刺激が病余の神経には少しききすぎるようでもある。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "農繁の時節にわざわざ集まってくださってありがたく思います。",
              "citation": {
                "source": "小作人への告別",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのじせつになるとちゃんと秋の風が吹く。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
