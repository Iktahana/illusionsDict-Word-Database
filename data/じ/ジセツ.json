[
  {
    "uuid": "aaa35c65-007c-5263-bd90-0ae9d0c5b222",
    "entry": "時節",
    "reading": {
      "primary": "じせつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
