      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "upper body",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "で上体をヂイツと擡げて、病室の方をみた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「仕様のない我儘娘だな」と云って、柚木は上体を起上らせつつ、足を胡座に組みながら「ほほう、今日は日本髪か」とじろじろ眺めた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "くにゃりと上体をねじ曲げて、歌舞伎のうたた寝の形の如く右の掌を軽く頬にあて、口を小さくすぼめて、眼は上目使いに遠いところを眺めているという馬鹿さ加減だ。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその瞬間に、しかけていた仕事のことを考えると、慌てて立った所から上体を机の方に延ばして、手に触れるにまかせて原稿紙をかき集めた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡瀬さんもそのつもりらしく、上体を机の上に乗りだした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上体を支えて洗い浄められた溝板の上に踏み立っている下肢は薩摩がすりの股引に、この頃はまだ珍しい長靴を穿いているのが、われながら珍しくて嬉しい。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、日常の劇務にすっかり疲れ果てて、何を好んでこれ以上体を疲らせなければならないのかとさえ言う人もありましょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿難は娘の袂を退け、上体を引立て眼を明かに開く。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「仕様のない我儘娘だな」と云って、柚木は上体を起上らせつつ、足を胡坐に組みながら「ほほう、今日は日本髪か」とじろじろ眺めた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり酒に強くない彼は胡座の左の膝に左の肘を突立て、もう上体をふらふらさしていた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まるで男の児のやうだな、上体が寂しいぢやないか。",
              "citation": {
                "source": "一平氏に",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人行儀のような、そしてお互いに相手を呑み込んで軽蔑しているような、それ故に好感を持っていると言ったような妙なお叩頭をし合うと、池上は両手をズボンのポケットへ入れ、上体をやゝ漕ぐように調子を取りながら、こつ／＼堀川の岸に沿うて歩き出しました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ今度はこういう譬えにして話してみようか」と肘に力を入れ、上体をすくと擡げました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいつもながら少し揶揄い気味に、「転んでも、たゞでは起きない相手の胸倉って何よ」　と恍けて訊いてやりますと、母は今度は両袖の口を指先で掴んで背中が痒いように左右に引いて、上体をやけのように身揺ぎ一つさせると同時に、「お巫山戯でないよ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると蛇は、たちまちしつぽの方でからだをさゝへて立ち上り、によろ／＼と上体をゆすぶりながら、タンブーリンの音に合はせて、にじり歩いてをどります。",
              "citation": {
                "source": "蛇つかひ",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "利かない上体を、心持、枕から浮かすように務めながら目をけわしくして、衰えた体力を無理にふりしぼるように罵っている伯父の姿は全く悲惨であった。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は、頭を下げないので、美和子も顎と上体だけをちょっと動かすようなお辞儀の仕方をして、席に着いた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は一昨年の春に流産をして以来何処といつて定まつた所はないが、始終頭痛がしたり軽い眩暈を感じたり、その上体がだるくて熱ざした。",
              "citation": {
                "source": "あかんぼの首",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の足音に振り返ると、うれしい声をあげ、上体を起こした。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような状況には慣れていなかったためか、ルーシィは上体を大きく揺さぶられ、手綱の握りもゆるんでいった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでパーソナルコンピューター部門にも複数のチームを設け、互いの競争の中から月一本で年間百万本売上体制という大きな目標を目指していくという。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの時の光景は今でも露眼に残つてゐるがと隠居は回想して、馬と三輪車の時ならぬ競争を目にした人々があれよ／＼と立ち騒ぐ彼方を、祖父は羽織の裾を突風に翻して虎のやうに上体をのめらせながらこゝを先途と疾走したが、忽ち傍らの泥田の中へ真つ倒まに転落して、全身泥まみれと化し腰に大きな打撲傷を享けた。",
              "citation": {
                "source": "写真に添えて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は足を出したまま、上体を仰向けに投げ出した。",
              "citation": {
                "source": "牢獄の半日",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と軽く言って、お辞儀するように上体を前にこごめて歩きかけた。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また彼の歩き振りは飄々たる抜きあしの態で、爪先から先へひよい／＼と脚を運びますが、上体はやはり長閑なヘチマのやうにぶらついてゐるのに斜めに頤を伸した伏目をもつて、油断なく前後左右を警戒してゐます。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌はやはり石臼をまはすと同様に上体を動かせてゐないと調子がつかぬと見えて、おかくは粉ひきの物腰でいつまでも歌つてゐるのです。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は彼に声を掛けようとした時に、不図正面の湯アガリと顔を見合せ、ハツとして思はず口を塞ぐと乗り出した上体を後ろに退いた。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、今にも息が絶え入りさうなうめき声を発しながら、ぐらぐらする流しの両端に噛りついて、千仞の谷底をのぞく臆病者のやうに上体を前方にのめり出した。",
              "citation": {
                "source": "秋晴れの日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "クララは即興詩でも聞くように興味を催おして、窓から上体を乗出しながらそれに眺め入った。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "不用意に歩き出そうとした葉子は、思わずのめり出さした上体をからく後ろにささえて、情けなげに立ちすくみながら、「ま、ちょっと」　と呼びかけた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
