[
  {
    "uuid": "cff3d944-40ab-5e57-879b-6963930a6500",
    "entry": "上体",
    "reading": {
      "primary": "じょうたい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
