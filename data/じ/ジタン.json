[
  {
    "uuid": "050f989c-e43e-543f-ab7e-93bb9bf2f124",
    "entry": "時短",
    "reading": {
      "primary": "じたん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
