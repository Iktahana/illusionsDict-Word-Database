        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "兵隊が帰って来た晩の街頭の人肉市場の光景もかなりに露骨であるが、どこか少しこしらえものらしいところもある。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと一緒に誰一人肉親のものを持たぬ私の淋しさがヒシヒシと身に迫って来て、いうにいわれぬ悲しさがあとからあとからこみ上げて来た。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪魔は今其の肉を欲する、血を求むる……仏が鬼女を降伏してさへ、人肉のかはりにと、柘榴を与へたと言ふでは無いか。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争の過ぎた跡へかけ付けて、なま臭い人肉を喰う狼見た様な犬がうろ付いとる間で、腰、膝の立たんわが身が一夜をその害からのがれたんは、まだ死をいそぐんではなかろて、勇気――これが僕にはほんまの勇気やろ――を出して後方にさがった。",
              "citation": {
                "source": "戦話",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その伯父は目下奇術師で、朝野の紳士を散々飜弄した揚句、行衛を晦ましている毒婦、雲月斎｜玉兎女史とくっ付き合って、目下、銀座のどこかで素晴らしい人肉売買をやっている事を私はチャント知っている。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日印××なぞといって銀座街頭で南洋女の人肉売買をしているんだ。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中に、不図『人肉』は何うだらうと考へ出した。",
              "citation": {
                "source": "悪魔の舌",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢にも人肉を夢みた。",
              "citation": {
                "source": "悪魔の舌",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "『いや俺は決して人肉は食はぬ。",
              "citation": {
                "source": "悪魔の舌",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "人肉を要求して居たのだ。",
              "citation": {
                "source": "悪魔の舌",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎖の各片、人肉の各片、骨の各片、蓆の破片ともつれつ、くんずして、チエンホールから、あるいは虚空へ、あるいは鎖と共に海へ、十三人の密航婦を分解、粉砕して、はね飛ばしてしまった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギリシアのジオメデス王、その馬に人肉を飼ったが、ヘラクレス奮闘して王を殺し、その尸を馬に啖わしむると温柔しくなったという。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "維新の革命で江戸の洗練された文化は田舎侍の跋扈するままに荒され、江戸特有の遊里情調もまた根底から破壊されて殺風景なただの人肉市場となってしまった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの、したまがりの花の毒々しい色を思わせるような人肉の焼けるにおいは、とても、ほかのにおいでは真似ができぬ。",
              "citation": {
                "source": "死体蝋燭",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつそ古ければまだ古いだけに思ひ出も深いのだが、元亀天正の昔をしのぶ外、（といふのは、中村はいふ迄もなく、太閤様の出生地なので）何のよすがもないとなると、大門を入つて両側に美しくならぶ雪洞にも、たゞもう人肉の切売りといふ、現実の血腥いやうな感じをそゝられるだけである。",
              "citation": {
                "source": "名古屋スケツチ",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "安達ヶ原　群馬の或るところに恐ろしい人肉事件が起った。",
              "citation": {
                "source": "女の手帖",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この壜に入っている異様な赤黒い物こそ、今日私が北岸へでかけて採集してきた七人目の犠牲者の肉片です）　田熊社長は、電話で話は盗めても、その人肉の入った壜を盗視できないことをたいへん口惜がった。",
              "citation": {
                "source": "人間灰",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖畔で採取した人肉の血型検査によるとＯ型だったというじゃありませんか。",
              "citation": {
                "source": "人間灰",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "人肉の主と夫人とは全く別人です。",
              "citation": {
                "source": "人間灰",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "血型Ｏ型の人肉は誰だったのでしょう。",
              "citation": {
                "source": "人間灰",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして人肉散華をやりました。",
              "citation": {
                "source": "人間灰",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "人肉散華から再び帰って、貴下は土饅頭を作り、トラックの跡を消したが、それはもう遅すぎました。",
              "citation": {
                "source": "人間灰",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロレタリヤ・ホールと大書した食堂もあれば、簡易ホテルの看板を出した木賃宿もある、一杯五銭の濁酒があるから、チヨンの間五十銭の人肉もあるだらう！",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "人肉を啖いはじめた犬や、新しい狂人や、疵だらけの人間たちが夢魔に似て彷徨していた。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "人肉を啖ひはじめた犬や、新しい狂人や、疵だらけの人間たちが夢魔に似て彷徨してゐた。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし救護にして至らざりとせば、東京市民は野獣の如く人肉を食ひしやも知るべからず。",
              "citation": {
                "source": "大正十二年九月一日の大震に際して",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど鶴と家鴨とを――否、人肉を食ひしにもせよ、食ひしことは恐るるに足らず。",
              "citation": {
                "source": "大正十二年九月一日の大震に際して",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "人肉を食はずんば生き難しとせよ。",
              "citation": {
                "source": "大正十二年九月一日の大震に際して",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝とともに人肉を食はん。",
              "citation": {
                "source": "大正十二年九月一日の大震に際して",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいには、落盤にへしゃがれるか、蝕ばまれた樹が倒れるように坑夫病で倒れるか、でなければ、親爺のように、ダイナマイトで粉みじんにくだかれてしまうかだ。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
