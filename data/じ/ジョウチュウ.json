    },
    "definitions": [
      {
        "index": 1,
        "gloss": "intravenous injection",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
