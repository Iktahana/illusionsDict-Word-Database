  {
    "uuid": "2d248344-b7a3-5750-98ce-0d3cb703eee6",
    "entry": "磁区",
    "reading": {
      "primary": "じく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "magnetic domain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "同じく海の出て来るボオドレエルの詩だつて、「信天翁」だと、広々として一物も見えぬ、秋も終りの海が見えて来る。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪峡宮沢賢治塵のごと小鳥なきすぎほこ杉の峡の奥よりあやしくも鳴るや　み神楽いみじくも鳴るや　み神楽たゞ深し天の青原雲が燃す白金環と白金の黒の窟を日天子奔せ出でたまふ",
              "citation": {
                "source": "雪峡",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして『西洋の国々と同じく、ここにもやはり醜い生存競争があり、常々不義や奸計が行われている』と、地上の現実社会である日本を見ている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京｜帝国大学の招聘に応じて、松江や熊本の地を去ったことも、同じくヘルンの身にとっては、愛する妻への献身的な犠牲だった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも彼の夫人にとって――世の多くの若い女性と同じく――東京はあこがれの都であり、そこでの生活は一生最高の理想であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日二人は、例によって睦じく連れそいながら、牛込辺の売邸を探しに歩いた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ家の中に住んでる家族の者にさえも、ほとんど全く解らない不思議な言葉で、何時間も倦きずに睦じく語り合ってた二人の男女こそ、この世における最も理想的に幸福な夫婦であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の文学は、本質的に我が『方丈記』や『徒然草』の類と同じく、仏教的無常観によった『遁世者の文学』であり、ヘルン自身がまた現実の『遁世者』であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし實際言へば、芥川君の僕に對する實の興味は、やはり室生君の場合と同じく、僕の氣質の中の野性的直情にあつたのだらう。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は俳句の外に、いくつかの抒情詩と数十首の短歌をも作つてゐるが、それらの詩文学の殆んど全部が、上例の俳句と同じく、造花的の美術品で、真の詩がエスプリすべき生活的情感の生々しい熱意を欠いてる。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生氏の場合も亦これと同じく、彼の句作の態度には、趣味性の遊離した享楽（ヂレツタンチズム）が多分にある。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "凧のかげ夕方かけて読書かな夕立やかみなり走る隣ぐに沓かけや秋日にのびる馬の顔鯛の骨たたみにひらふ夜寒かな秋ふかき時計きざめり草の庵石垣に冬すみれ匂ひ別れけり　彼の俳句の風貌は、彼の人物と同じく粗剛で、田舎の手織木綿のやうに、極めて手触りがあらくゴツゴツしてゐる。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "故にこれを結論すれば、彼の俳句はその造庭術や生活様式と同じく、ヂレツタントの風流であつて、然も「人生そのもの」の実体的表現なのだ。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら音楽は詩と同じく、普遍に通ずるカメラードへの呼びかけであるからである。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの時、初めて日本語に眞の「韻」といふものが出來、支那西洋の國語と同じく、我々の言葉にもまた眞の「韻律」が發生する。",
              "citation": {
                "source": "ローマ字論者への質疑",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句もやはり前のと同じく、実景の写生でなくして、心象のイメージに托した咏嘆詩であり、遅き日の積りて遠き昔を思う、蕪村郷愁曲の一つである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の句と同じく、或る荒寥とした、心の隅の寂しさを感じさせる句であるが、その「寂しさ」は、勿論｜厭世の寂しさではなく、また芭蕉の寂びしさともちがっている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の句やこの句に現われている蕪村のポエジイには、やはり彼の句と同じく人間生活の家郷に対する無限の思慕と郷愁（侘しさ）が内在している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに言うが、一般に言って写生の句は、即興詩や座興歌と同じく、芸術として軽い境地のものである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこの言葉は、おそらく蕪村が幼時に記憶したイロハ骨牌か何かの文句を、追懐の聯想に浮べたもので、彼の他の春の句に多く見る俳句と同じく、幼時への侘しい思慕を、恋のイメージに融かしたものに相違ない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "画面の視野が広く、パノラマ風であり、前に評釈した夏の句「鮒鮓や彦根の城に雲かかる」などと同じく、蕪村特有の詩情である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句に主題されている詩境もまた、前の藪入の句と同じく、遠い昔の幼い日への、侘しく懐かしい追憶であり、母のふところを恋うる郷愁の子守唄である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも前と同じく、はかなく寂しい悲しみを、心の影でじっと凝視しているような句境である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔦かずらの這う古く懐かしい家の中で、薪の燃えるストーヴの火を囲みながら、老幼男女の一家族が、祖先の画像を映す洋燈の下で、むつまじく語り合うことを言うのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしおそらく彼の場合は、恋愛においてもその詩と同じく、愛人の姿に母の追懐をイメージして、支那の古い音楽が聞えて来る、「琴心挑美人」の郷愁から妹が垣根｜三味線草の花咲きぬ　の淡く悲しい恋をリリカルしたにちがいない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉と同じく、魂の家郷を持たなかった永遠の漂泊者、悲しい独逸の詩人ニイチェは歌っている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく彼等が、翻訳を通じて「古池や」等の俳句から感ずるものは、「花の雲」の句を葬式の詩として感心した外国人と同じく、原句の詩趣とは全くちがつた別のヴィジョンに、彼等自身の主観した東洋的エキゾチシズムの幻像を画いたものであるだらう。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車は出發せんと欲してすさまじく蒸氣を噴き出し裂けたる如くに吠え叫び汽笛を鳴らし吹き鳴らせり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の讀み方によるドストイェフスキイは、心理上でポオと共通し、思想上でニイチェ、ショーペンハウエルと類縁するところの作家であつたが、友人たちの見たドストイェフスキイは、やはり白樺派の人と同じく、人道主義的に見たそれであつた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草や酒と同じく、交際もまた一つの「習慣」であると思う。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
