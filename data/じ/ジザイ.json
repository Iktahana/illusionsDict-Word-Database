[
  {
    "uuid": "7f67bcb7-bff5-5a5d-9564-226342589194",
    "entry": "自在",
    "reading": {
      "primary": "じざい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
