    "definitions": [
      {
        "index": 1,
        "gloss": "conveying the views of the subordinates to the rulers",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "山上通信太宰治　けさ、新聞にて、マラソン優勝と、芥川賞と、二つの記事、読んで、涙が出ました。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山上通信は、私の狂躁、凡夫尊俗の様などを表現しよう、他にこんたんございません。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時母上通りかゝり給へり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "門野は是より以上通じない男である。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭台は幕府の医官井上通翁の子である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "※石の事は三村清三郎、井上通泰、日高無外、清水右衛門七の諸家の教に拠つて記す。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「食事でもなんでもお上通りで、お鯉さんとひとつに食るのですよ。",
              "citation": {
                "source": "一世お鯉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに海上通商のことを管理して、海事に關する智識も邃く、且つ自身に多數の海舶を自由にすることの出來る蒲壽庚が元に降つて、その東南征伐に助力したことは、元にとつては莫大の利益で、同時に宋にとつては無上の打撃であつた。",
              "citation": {
                "source": "蒲壽庚の事蹟",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "刺客行　大井川の川会所の軒下には、薄汚れのした木の札がかかっていて帯上通水、九十五文　と、書いてあった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "大井川を渡る賃金は、水｜嵩によってちがっていて、乳下水、帯上通水、帯通水、帯下水、股通水、股下通水、膝上通水、膝通水と分れていた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は井上通泰さんのやうに、結句は三四調であるべきだなどとは云はんが、今度の歌の結句の四三調には肯んじがたいのがある。",
              "citation": {
                "source": "釋迢空に與ふ",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "門野はこれより以上通じない男である。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと、図の三河びな・薩摩びなをくらべて見ると、形に於ては、非常に変化がある様だが、後者は、けづりかけに紙或はきれを以て掩うたものである事が、明らかであると同時に、前者との間にも、形式上通じた所のあるのが見える。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "側室が出世をいたしますと、お上通りと成り、方名が附きます。",
              "citation": {
                "source": "菊模様皿山奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近には、御歌所派の頭目井上通泰氏が、われ／＼一派に向うて、暗に攻撃的の態度を示してゐる。",
              "citation": {
                "source": "古語復活論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰字のことにつき木村正辞、井上通泰の説があるから、別なところに記して置いた。",
              "citation": {
                "source": "人麿の妻",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその協力の仕方は上意下達といふ形もあり、また下情上通といふ形に依つてもできる。",
              "citation": {
                "source": "大政翼賛会と文化問題",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "上通りより道玄坂の右側を通りて下りる。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "予も亦、銃猟者の撃ち来れる鴨に、黐の着き居し実例など語りて之に和し、脚の疲れを忘れて押上通りを過ぎ、業平にて相分れしが、別るゝに臨みて、老人、『その内に是非お遊びに』と言ひかけしが、更に改めて、『併し御承知の通りなれば、雨の日にて無くば』と断りき。",
              "citation": {
                "source": "釣好隠居の懺悔",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "井上通泰氏のお弟子で、井上氏が岡山へ赴任せられた頃からの熟知なのでしょう。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃井上通泰、熊沢蕃山の伝を校正上本せしを見るに、蕃山の詞に、敬義を以てする時は髪を梳り手を洗ふも善を為す也。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "井上通泰氏などは特に御別懇のようでした。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し落附いて何かして見たいと思う時に、兄が井上通泰氏の紹介で松波資之氏へ伺って見よと申されました。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "井上通泰氏が小出氏とお心安かったのは、嗜好が同じだったからかも知れません。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来、この「術」のつくのが問題なのでありまして、美術とか技術とかいずれも「術」がつくのでありますが、このいずれの術も精神的、入神的のものに限りまして、常識上通常の算盤に、はじききれない作用が出来るものを「術」といい、「妙」というのだと思います。",
              "citation": {
                "source": "芸術的な書と非芸術的な書",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "村中故障之筋無御座候に付、何卒右願上通御聞届被仰付被為下候得ば、私共迄難有仕合に奉存候。",
              "citation": {
                "source": "来り人の地位と職業",
                "author": "平民申付候事",
                "note": "青空文庫"
              }
            },
            {
              "text": "私らが婦人科の炎にバケツをもって駆けつけた時、まだ敵機は続いて急降下爆撃をしていたが、上野はその弾の落ちてくる中で「おーい、敵機頭上通過、大丈夫、出て来い、燃えよっぞ」とか、「また来たぞ、落としたぞ、退避、危ないぞ」とか、いちいち叫んで、指導した。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "「頭上通過、出発」　よろよろと路上に立ち出でて急ぐ。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんもしこの削減された銀貨の量がベラ棒に大であり、またはもし造幣局がかかる削減された貨幣片を発行したのであるならば、この削減された貨幣で支払うのが債務者の利益であったかもしれないが、しかしその量は限られており、そしてその価値を保持しており、従って金が実際上通貨の真実の本位であったのである。",
              "citation": {
                "source": "経済学及び課税の諸原理",
                "author": "PRINCIPLES OF POLITICAL ECONOMY AND TAXATION",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
