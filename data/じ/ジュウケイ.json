        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "“銃刑場の壁の後の交響楽”」「カズ子さん、入りましょう。",
              "citation": {
                "source": "千早館の迷路",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "無気味な、銃刑場の壁の後の曲が、化け蝙蝠のように暗黒の空間を跳ねまわる。",
              "citation": {
                "source": "千早館の迷路",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
