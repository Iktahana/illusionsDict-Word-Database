    "definitions": [
      {
        "index": 1,
        "gloss": "sizzling (of cooking meat, fish, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
