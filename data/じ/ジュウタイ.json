[
  {
    "uuid": "78a791ab-17ae-585b-ad52-55ae8a844410",
    "entry": "渋滞",
    "reading": {
      "primary": "じゅうたい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(traffic) congestion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "世話人があまりおおぜいであるために事務はかえって渋滞する場合もある。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "岳神の家としての事務の経営は少しの渋滞もなく夫妻共に呼吸は合っている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鶯の声まだ渋く聞ゆなり、すだちの小野の春の曙」というときの渋味は、渋滞の意で第一段たる「正」の段階を示している。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がもし真理に対する嗅覚を恥としたのであったら、十九世紀の物理学の進歩はたぶん少なからず渋滞をきたしたに相違ない。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しあわせな事には世の中では論理的の証明はわりに要求されないで、オーソリティの証言が代用されそのおかげで物事が渋滞なく進捗するのであろう。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "元より何の苦労も渋滞も君には無い。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集のはじめに",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二）　政治の実権が久しく朝廷を去つてゐたから、公卿は政治の実際に疎く、しかも鎌倉幕府の滅亡と共に、幕府が処理してゐた政務をも朝廷で併せ行はねばならぬことゝなり、政務が渋滞してしまつたこと。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペンを取ると、何の渋滞もなく瞬く間に五枚進み、他愛もなく調子に乗っていたが、それがふと悲しかった。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の渋滞も無いのだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「倍になっただけでこれじゃあ、来年は交通渋滞だ」　下の道に入り、坂が見わたせるようになったとき、柾生がつぶやいた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の家出の因は、勿論その創作生活の奇矯と渋滞からに相違なかつた。",
              "citation": {
                "source": "創作生活にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくも氏が名古屋に於て寵児となったのは、趣味が多方面であり、話が聞き上手であり、性質がさっそくであって渋滞せず、感情的で無くむら気でなく、理性的であって親切であり、絶対に信頼される人――そういう人であったからであろう。",
              "citation": {
                "source": "名古屋の小酒井不木氏",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの頃は、心の歩みのなかに渋滞と障害とを感じて苦しんでいます。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間復興の声が、当時の社会の雰囲気のゆきづまり渋滞を破ろうとする要求から、文化の楯として要望されながら、人間性の恢復、人間主義の思潮にとってルネッサンス以来歴史的な本質であった批判の精神をすてていたことは、どんな声も無駄にする欠陥であった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "格堂の写し置ける元義の歌を見るに皆｜天保八年後の製作に係るが如く天保八年の歌は既に老成して毫も生硬渋滞の処を見ず。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "多く習ひて得たる様にはあらでただ無造作に書きなせるものから大字も小字も一様にして渋滞の処を見ず。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙本の味は、少しでも筆が渋滞すればすぐににじみ勝ちの吸湿性があるのですが、それをにじませないように手早く筆を走らせた軽妙な筆味にあるわけでしょう。",
              "citation": {
                "source": "絹と紙の話と師弟の間柄の話",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "切腹の刀の運びがするすると渋滞なく、手際の最も立派であったのは、この大石である。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "余分な稼ぎに出て居ればそれ丈廻転が渋滞する。",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、芭蕉はかう云ふ難所に少しも渋滞を感じてゐない。",
              "citation": {
                "source": "芭蕉雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　三宅氏は又「批評をも全々（原）小説家の手に委ねておく事は、寧ろ文学の進歩発展を渋滞させる恐れがある」と言つてゐる。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "思つたこと――それは摩訶不可思議な、仙人の見る夢のやうな、名状すべからざるものの影に過ぎない――がそのまま歌になつて少しの渋滞の跡も示さない、斯ういふのを表現の自由といふのであつて、作者の如き才分の豊かさを以てしてもここに達するには二十年の苦しい修練を要したのである。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが補説としては、西比利亜に渋滞している日本の貨物の莫大な量を独逸へ転送されない前に抑留せねばならないといい、また西比利亜にある七、八万の独逸｜俘虜が既に武装しつつあることの危険を報じます。",
              "citation": {
                "source": "何故の出兵か",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "全ソヴェト同盟の大建設事業に伴ってこの夏は、運輸が従来にない重大な意義をもっているにかかわらず、各所に貨物の渋滞、延着が訴えられている。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "廻送されなかった送り状とか、二日前に打たれてた筈の電報がまだアルミニュームの籠の底にへばりついていたり、いろんな事務の渋滞がある。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐紙のこっちからでも、書かれてゆく字のむらのない速力や、渋滞せず流れつづける考えの精力的な勢やを感じさせずに置かない音であった。",
              "citation": {
                "source": "乳房",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人は世界じゅうたいていあるいていて、なんだって話せないことはないくらいでした。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
