    "definitions": [
      {
        "index": 1,
        "gloss": "one's own handwriting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
