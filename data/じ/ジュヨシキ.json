    "definitions": [
      {
        "index": 1,
        "gloss": "awarding ceremony",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
