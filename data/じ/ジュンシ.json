[
  {
    "uuid": "844574c7-1a8b-5edd-97f2-2bbf7cfdc976",
    "entry": "殉死",
    "reading": {
      "primary": "じゅんし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
