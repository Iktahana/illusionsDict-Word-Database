    "definitions": [
      {
        "index": 1,
        "gloss": "housing shortage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一と頃騷がしかつた住宅難の解決がこんな風にしてなしくづしに付いて居るかと思はれた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひところ騒がしかった住宅難の解決がこんなふうにしてなしくずしについているかと思われた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "民法が戸主の権利を縮小したからといって住宅難で若夫婦が父兄の家の一隅を借りていなければならないとき、資本主義社会で育ってきた人々の心持の中は、金銭問題や、義理がからんで、実際の封建的な家長の気分はのけられません。",
              "citation": {
                "source": "今度の選挙と婦人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民学校の教育も戸惑っている形ですし、住宅難の問題もあり、子供は可哀そうに、悪くなってゆくどっさりの条件の中に、さらされております。",
              "citation": {
                "source": "新しい躾",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　家賃　おそろしい住宅難の折から、きのうきょう厚生省と警視庁との意見にくいちがいが示されている適正家賃算出法の問題は、日本全国の借家人が注意をあつめて成行きを案じていることがらだと思う。",
              "citation": {
                "source": "私の感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その失業やストライキや住宅難もともに。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その感じかたのままで話せば、きょうこの著者は、ただ同じところにつとめているというだけの人々が住んでいる官舎で、住宅難も整理の不安もなく暮しているということにもなるだろう。",
              "citation": {
                "source": "ことの真実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日も永井君が逗子の方へ探してやるとは云つてゐましたが、住宅難はなかなか深刻です。",
              "citation": {
                "source": "書簡",
                "author": "家族・親族宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今にすると、田地なんかもう不要になつて住宅難は昔の夢になる。",
              "citation": {
                "source": "火の踵",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "物寂びた森閑とした境内に立っていると、失業だ飢餓だ住宅難だと渦巻いている世の中が段々遠くへ霞んでいってしまいそうな気がした。",
              "citation": {
                "source": "棄てる金",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのわけは、住宅難のこと、資材難のこと、物価がたいへん高くなったことなどのために、戦災で焼けのこったありとあらゆるものが、新しい目で見直されることだった。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の平和の時代に比較して人の心だけを言うのが間違いで、このインフレ時代であり、住宅難、動物的雑居生活、停電、食糧難、物資難、交通難、おまけにそこに住む青年たちは戦場へ追いやられて心ならずも人殺しを稼業にしてきた人々であり、他の人々は空襲火災に追いまくられて家財や肉親を失ったような人々である。",
              "citation": {
                "source": "男女の交際について",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ読むためばかりでなく、モスク※の住宅難から来る子供の遊び場、仕事場補充までやって居る。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、計画的に諸所へ散在、潜伏させた信徒の細胞もあるとかの話で、その原因も、食糧難、住宅難などの結果によるらしく、生活危機は人間どもの問題だけではないのである。",
              "citation": {
                "source": "呉清源",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "新婚後の住居については現在住宅難の時代でもあり、しづは一人で店の留守番をしているのだから、世の中のおさまりがつくまで、しづの所で働いた方がよかろうと申しました。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その二　大岡越前守",
                "note": "青空文庫"
              }
            },
            {
              "text": "よそは住宅難だが、伊東には売家も貸家も多い。",
              "citation": {
                "source": "温浴",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤堂駿平の一行で占められているサヴォイ・ホテルの奥まった一画から、おもての方へ深紅色のカーペットの上を歩いて行きながら、伸子は、モスクの住宅難からある邸の温室を住宅がわりにして、そのガラス張りの天井の下へ、ありとあらゆるものをカーテン代りに吊って、うっすり醤油のにおいをさせながら暮しているのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスク※の住宅難はこのとおりですよ。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "レーニングラードはモスク※より物価もやすいし、住宅難もすくないから、レーニングラードにいるということだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯物的であるということの現実は、めいめいの恋愛や結婚そして家庭生活の幸福の基礎が、働いて生きる男女の労働条件が益々よくなってゆくこと、社会連帯の諸施設がゆきわたり、住宅難、食糧、托児所問題などがどしどし解決されてゆくその事実に立つものだということが、いつか自然と伸子にものみこめて来ていた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「モスク※に住宅難がないなら、あなたがたがわたしたちの広告に返事をよこすこともなかったでしょう」　伸子の心にもきつい抗議が湧いた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、いままで個人的に部屋がしをしている者は、その室をあけて、各組合の住宅難で困難している人々の間にふりかえることに決定された、というのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスク※の住宅難は決して緩和されていないのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、昨今の著しい社会的現象である住宅難を背景として、それに人間が、善い心はよいなりに、悪い心は邪悪ななりに、どんな交渉を持つかということ。",
              "citation": {
                "source": "我に叛く",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――モスクワは御承知の住宅難で、多くの子供は学校が退けてから落付いているところがないんです。",
              "citation": {
                "source": "子供・子供・子供のモスクワ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モラトリアムで学生の学費一五〇円と制限されたが、この食糧難、住宅難、まして交通費の膨脹で、学生は帳面一冊買いにくいこととなった。",
              "citation": {
                "source": "現実の必要",
                "author": "――総選挙に際して――",
                "note": "青空文庫"
              }
            },
            {
              "text": "群盜の横行、諸國の飢饉、道徳の頽廢、疫病の流行、物價高、火災流亡の住宅難など、昭和の敗戰後にあらはれたものは殆どあの時代にもあらはれてゐる。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "巣鴨へ迎えに来た長男も次男も、留守に邸を使って居たことなぞ、ひと言もいわなかったが、これで見ると、住宅難で勝手な人間がここを塒にして居たに違いない。",
              "citation": {
                "source": "面",
                "author": "富田常雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "住宅難にあえいでいる現代の日本では、たとえ、どんな神秘な伝説があろうとも空家などというものは、リアリティをもたないのである。",
              "citation": {
                "source": "日本推理小説の曲り角",
                "author": "十返肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府が計画してつくった住宅難解消のための住宅に入ることができたのだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
