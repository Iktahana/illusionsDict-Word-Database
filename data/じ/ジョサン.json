[
  {
    "uuid": "9954a0b7-fe49-5e61-a33d-fa2f4be6063e",
    "entry": "助産",
    "reading": {
      "primary": "じょさん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
