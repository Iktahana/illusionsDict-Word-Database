[
  {
    "uuid": "0370b627-7f17-5b6e-a541-287355af24d0",
    "entry": "人造",
    "reading": {
      "primary": "じんぞう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "artificial",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "近代人中の極くもう愚劣な、へ理窟屋共が全然人造的なものを作りたいと企図したりする。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "道傍に並ぶ柱燈｜人造麝香の広告なりと聞きてはますます嬉しからず。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この瓦斯はカーバイドと称える人造の石塊に水をかければ発生するから、使用は軽便である。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "フラスコの中で歌う人造人間の歌を、さもさもそうらしく聞かせるような音響トリックもできていいわけである。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十二月一日『東京朝日新聞』）　　　　　　　　　四十九　　　　　　宝石の人造法　近頃仏国のポルダという人が鋼玉石の粉を変じて種々の宝石とする方法を発見した。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十二月十九日『東京朝日新聞』）　　　　　　　　　五十三　　　　　　人造藍と天然藍　藍を人工的に合成する法が出来て以来、人造藍の需要が増すにつれて天然藍の産額が減ずる傾向をもっているのは著しい現象である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また英国では一昨年と昨年との比較統計によると人造藍の輸入高が二割ほど増し、これに反して天然藍の方は七分くらいの減額を示している。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまだまだ天然のが人造のに圧倒されるところまでには月日がある。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年五月十五日『東京朝日新聞』）　　　　　　　　　七十九　　　　　　変った製氷法　ドイツの南部で冬期人造氷を作る法というのを聞いてみると、ちょっと変っている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人造人間の弾機によって、そのたびに粋なナイト・ドレスをつけた夜の女が、写真に絵姿となってあらわれるのだ。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは雨の日の東京の大通りを歩いているときにしばしば経験させられることであるが、人造石を敷いた舗道が非常にすべりやすくなることがある。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "煉瓦やアスファルトの所はすべらないのに、適当に泥の皮膜をかぶった人造石だとなかなかよくすべる。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人造石がかわいている場合にはもちろんすべる心配はない。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもしも軟泥の層が単なるリュブリケーターとして作用しているのなら、何も人造石対ゴムに限る必要はないはずである。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが事実は特に人造石とゴムとの組み合わせによって特別な現象が起こるのであるから、これは必ずしも既知の単純なリュブリケーションの問題として不問に付することはできないように見える。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ少しばかり現実の可能性を延長した環境条件の中に、少しばかり人間の性情のある部分を変形し、あるいは誇張し、あるいは剪除して作った人造人間を投入して、そうして何事が起こるかを見ようとするのである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "足もとの土でさえ、舗装の人造石やアスファルトの下に埋もれてしまっているのに、何をなつかしむともなく、尾張町のあたりをさまよっては、昔の夢のありかを捜すような思いがするのである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり人造でもマーブルか、乳色ガラスのテーブルの上に銀器が光っていて、一輪のカーネーションでもにおっていて、そうしてビュッフェにも銀とガラスが星空のようにきらめき、夏なら電扇が頭上にうなり、冬ならストーヴがほのかにほてっていなければ正常のコーヒーの味は出ないものらしい。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "波の反射が陽炎の様にてらてらと顔から半白の頭を嘗めるので、うるさ相に眼をかすめながら、向うの白く光った人造石の石垣に囲まれたセミオン会社の船渠を見やって居る。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また人工の巧なるも、造化の美には如くべからず、自然の佳味は人造らじ、されば、鳥籠に美を盡し、心を盡して餌を飼ふとも、いかで鳥類の心に叶ふべき。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　万事の設備不完全なるは、一々数え立てるまでもないが、肝腎の風呂場とても今日のようなタイル張りや人造石の建築は見られない。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "……するとその途中で何かしら真黒い、人間のようなものと真正面から衝突したように思うと、二つの身体がドターンと人造石の床の上にたおれた。",
              "citation": {
                "source": "ビルディング",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと云ってこの人造世界に向って猪進する勇気は無論ないです。",
              "citation": {
                "source": "虚子君へ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "銑鉄と人造維質で可憐な揺籠が編まれ、縁にチユーリツプの莟の球が一つ挿され、一見至極単純に見えて雅純新鮮な効果を出し、大形の柩は、材に秩父産の蛇紋石を用ゐ、中を人型に開けて、底に軟い鈴蘭が安らかに活けてある。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "数間の地を測るには尺度にて足るべし、天下の大を度るには、人造の尺度果して何の用をかせむ。",
              "citation": {
                "source": "各人心宮内の秘宮",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、それから、人造石の樺と白との迫持や角柱ばかし目だった、俗悪な無用の贅を凝らした大洋館があたりの均斉を突如と破って見えて来る。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一｜般には落葉や青草の缺乏を感ずると共に便利な各種の人造肥料が供給される。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらと相似れど、京都東山の大文字火同然人造に係る壮観が英国にある。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体の構造は今も昔も変らないが、浴槽も流し場もすべて木造で、人造石やタイル張りのたぐいは殆ど見出されなかった。",
              "citation": {
                "source": "明治時代の湯屋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
