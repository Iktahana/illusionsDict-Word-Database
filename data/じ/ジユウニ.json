    "definitions": [
      {
        "index": 1,
        "gloss": "freely",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼等の愛人同士は、周囲に多くの人々が住んでる環境に居て、しかも無人島に居る二人だけの会話を会話し、二人だけの生活を自由に享楽していたのであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに自分が、アナアキスチックの自由に憧憬してゐるか。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてそれらの自由にまで、いかに必死的な熱情をもつて過去を一貫したかといふこと。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故に本来言へば、詩の翻訳に語学上の詮議は無用で、むしろ訳者自身の個人的主観によつて、自由に勝手に翻案化してしまふ方が好いのである。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由に図書室へ出入りすることを許されたが図書室の中はいつ行ってみても誰もいないでひっそりしていた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は幸いにここでも図書室を自由に開放してもらって、読書したりノートを取ったり、また河のメアンダーに関する小さな「仕事」をさせてもらったりした。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "化学的の分析と合成は次第に精微をきわめて驚くべき複雑な分子や膠質粒が試験管の中で自由にされている。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ、もう三十余年前にただ一度実見したきりなので記憶がはなはだたしかでないが、網を張った叉手の二等辺三角形の両辺の長さが少なくも九尺くらいあり、柄竿の長さもほぼそのくらいあるかと思われ、とにかくずいぶん大きなものであるので、それを自由に操作するには相当の腕力を要するものであったように思う。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚どもは誰に見せようといふ衒ひも無く自由に嬉々として舞ひ遊ぶ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、自由に振舞つてよいといふ許可は與へられてゐるのだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この舌切雀にせよ、また前の瘤取り、浦島さん、カチカチ山、いづれも「日本一」の登場は無いので、私の責任も輕く、自由に書く事を得たのであるが、どうも、日本一と言ふ事になると、かりそめにもこの貴い國で第一と言ふ事になると、いくらお伽噺だからと言つても、出鱈目な書き方は許されまい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今にも大野原の上を、自由に飛翔しようとする大鳥が羽翼を収めて、暫く休息している姿勢を、富士は取っている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺屋の白袴、医者の不養生ということもあるが、物理の学徒等が日常お互いに自由に話し合う場合の用語には存外合理的でないものが多数にあって、問題の「速度のはやい」などもその一例である。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで今度は声を立てないで口を自由に且つ充分に動かして読む真似をしてみると、その歌の口調のあらゆる特徴が驚くほど鮮明に頭に響いて来るのである。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手でも足でも思い切り自由に伸ばしたり縮めたりしてはね回っているけれども、その運動の均衡が実に安定であって、非常によくバランスのとれた何かの複雑なエンジンの運転を見ているような不思議な快感がある。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "花を切つて高崎へでも賣りに出すのかと聞くと、唯々お客さんに自由に進呈するためだといふ。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の祖神の事である、山に棲めるほどのものを自由に操縦できないいわれはない。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くして現代の一般女性たちは、内外特殊の研究家の創造発表するものを容易に採り上げて自由に利用するであろう。",
              "citation": {
                "source": "異性に対する感覚を洗練せよ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（おれはその幾千由旬の海を自由に漕ぎ、その清いそらを絶え絶え息して黒雲を卷きながら翔けれるのだ。",
              "citation": {
                "source": "龍と詩人",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "民族的、歴史的存在規定をもった現象を自由に変更して可能の領域においていわゆる「イデアチオン」を行っても、それは単にその現象を包含する抽象的の類概念を得るに過ぎない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "主観的であるとは、具体的表象に規定されず、芸術の形成原理が自由に抽象的に作動する場合である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、現実界の具体的表象に規定されないで、自由に形式を創造する自由芸術の意味は、模様としては、幾何学的模様にのみ存している。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち個人的または社会的体験が、無意識的に、しかし自由に形成原理を選択して、自己表現を芸術として完了したのである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "運命によって「諦め」を得た「媚態」が「意気地」の自由に生きる｛１３｝のが「いき」である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の運命に対して曇らざる眼をもち、魂の自由に向って悩ましい憧憬を懐く民族ならずしては媚態をして「いき」の様態を取らしむることはできない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は今度はじゆうにあるけないからだまって私のあとをついて来る。",
              "citation": {
                "source": "心配",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ぼく、53ぷんもじゆうになるんなら、ゆっくりゆーっくり、水くみ場にあるいていくんだけど……』24　おかしくなって、さばくに下りてから、８日め。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "後には毎晩のやうに手の指や背中や、そこらじゆうに、ぶたれたあとの赤いあざをつけてかへるので、父は、私を寄宿舎へ入れました。",
              "citation": {
                "source": "村の学校（実話）",
                "author": "アルフオンズ・ドーデー　Alphonse Daudet",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも　しばらくしたら　おちゃも　バタートーストも　ごじゆうに　どうぞ　ってことに　なって。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "殆どまる裸にちかく、ぼろぼろで火に焦げた毛皮が背中の一部分にかかつていたが、体じゆうに毛が一ぱい生えていた。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
