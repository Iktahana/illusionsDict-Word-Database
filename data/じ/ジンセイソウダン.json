        "examples": {
          "standard": [
            {
              "text": "悩みを抱えていた時、先輩に人生相談に乗ってもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はよく、バーのマスターに人生相談を持ちかけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "週末には、寺で無料の人生相談が行われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ニュースから聞こえてくる受験生の嘆きは、実のない男に入れ上げたばかな女の人生相談に聞こえた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でもねえ、いいかい、おれは君の人生相談の相手じゃない、おれは、ただの……」「……わかったよ。",
              "citation": {
                "source": "はやい秋",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかしな抑揚だということが僕にもわかる日本語で、人生相談がおこなわれていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
