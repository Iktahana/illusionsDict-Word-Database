[
  {
    "uuid": "cdb7a196-f905-5854-bec2-ab2cadeb8877",
    "entry": "城外",
    "reading": {
      "primary": "じょうがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "outside a castle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　それから荒れ狂ふ馬に跨つて、城外へ。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "一｜代の覇圖も夢物語に奉天城外の露と消えてしまつたが、例の張作霖は非常な麻雀好きだつたと言ふ。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "材木町、東福田町地先にてこの水路と会する一水は即ち○今川橋下を流るゝ神田堀にして、御城外濠より竜閑橋その他諸橋の下を経て来れるものなり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "城外の平野一面に夕靄が漂うて居る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "城外の柏林に千人の宿をつくるよう工作のものへ言ってくれないか」　「かしこまりました。",
              "citation": {
                "source": "四又の百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌日、彼は城外で戦死した。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "梟娘の死――その奇怪な噂がまだ消えやらない其年の八月｜朔日、巳の刻頃（午前十時）から近年｜稀なる暴風雨がこの城下へ襲つて来て、城内にも城外にもおびたゞしい損害をあたへた。",
              "citation": {
                "source": "梟娘の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲｜正に闌になりて、この楽器のうちに潜みしさまざまの絃の鬼、ひとりびとりに窮なき怨を訴へをはりて、いまや諸声たてて泣響むやうなるとき、訝かしや、城外に笛の音起りて、たどたどしうも姫が「ピヤノ」にあはせむとす。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲まさにたけなわになりて、この楽器のうちにひそみしさまざまの絃の鬼、ひとりびとりにきわみなき怨みを訴えおわりて、いまや諸声たてて泣きとよむようなるとき、いぶかしや、城外に笛の音起りて、たどたどしゅうも姫が「ピヤノ」にあわせんとす。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻子を引連れて福岡の城外練兵場へ出て、タンポポの根なぞを掘って来て露命を繋いでいたというのだから驚く。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "盛政は勝家の子権六と共に捕われ、北の庄落城前、縄付きの姿で、城外から勝家に対面させられている。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "城外の地勢険阻な処に来ると、馬を棄てて子の伊織十四歳になるのを伴って進んだ。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "城外に在った勝成は、「大阪の役に児子の功を樹てた事があったが、今日児孫の先登を見る」と云って涙を流して喜んだ。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "大臣之を王に白し、又自ら地道を造り出て城外に向ふ。",
              "citation": {
                "source": "詛言に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処で王様はまんまと城外に追出されてトムさんは王様と早変りしてしまひました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで王様はまんまと城外に追ひ出され、馬鹿な詩人のトムさんが、王様と早変りをしてしまひました、城の兵士たちも、王様のわがままを憎んでをりましたので、誰もみな喜んだくらゐです。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "弥勒世尊、翅頭末城外の金剛荘厳道場竜華菩提樹下で成道する。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めに金剛座上で説法し九十六億人阿羅漢を得、二会と三会に城外の華林園で説法し、九十四億と九十二億の人が阿羅漢となる。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、城外に出ては、狩猟にのみ日を暮した。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「城外へ漏れてはならぬゆえ、そのことくれぐれも心して、たち騒がずに見張りせいとのお達しじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は遼陽城外の劉という家に二十日余り滞在していたことがある。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もその当時は内々得意であったが、後に遼陽城外の劉家に来て、かの奉天歩隊の勘当息子をみるに及んで、彼らが余りに文を重んじ、武を軽んずるの甚しきを憐れむような心持にもなって来た。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京陵　遼陽の城外に東京陵という古陵がある。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治39・11）（六）蟹　遼陽城外、すべて緑楊の村である。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人形の首をはじめて見たのは、わたしが日露戦争に従軍した時、満洲の海城の城外に老子の廟があって、その祭日に人形をまわしに来たシナの芸人の箱のなかでした。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここらでは遼陽の城内まで薬を買いに行かなければならないのであるが、この頃は戦争のために城内と城外との交通が絶えてしまったので、薬を求める法がない。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "我れわれが遼陽の城外にゆき着いたのは、それから三日の後である。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
