  },
  {
    "uuid": "c5919192-2cdf-5cdc-b972-732f56495709",
    "entry": "場外",
    "reading": {
      "primary": "じょうがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "outside the hall (or stadium, market, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕は毎日のやうに池の端の會場へ行き、夜になればイルミネーシヨンの輝やく不忍池畔で、龍宮の形をした場外の酒場へ飮みに行つた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "場外へ出たときに聞いた電車の音がひどく耳立ってきこえた。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてまた場外の外光が遠くの遠くに小さく、正方形に白く眩ゆく切り開かれているのだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄き給金にて繋がれ、昼の温習、夜の舞台ときびしく使われ、芝居の化粧部屋に入りてこそ紅粉をも粧い、美しき衣をもまとえ、場外にてはひとり身の衣食も足らずがちなれば、親はらからを養うものはその辛苦いかにぞや。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "場外へ出て行ってみたところ、かの本命馬の名の由来となった額の銀色の斑を目の当たりにしてはっとする。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄き給金にて繋がれ、晝の温習、夜の舞臺と緊しく使はれ、芝居の化粧部屋に入りてこそ紅粉をも粧ひ、美しき衣をも纒へ、場外にてはひとり身の衣食も足らず勝なれば、親腹からを養ふものはその辛苦｜奈何ぞや。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄き給金にて繋がれ、晝の温習、夜の舞臺と緊しく使はれ、芝居の化粧部屋に入りてこそ紅粉をも粧ひ、美しき衣をも纏へ、場外にてはひとり身の衣食も足らず勝なれば、親腹からを養ふものは其辛苦奈何ぞや。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "突如として式場の空気などを、少しも顧慮しないようなけたゝましい、自動車の響が場外に近づいた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度工場外ニ足ヲフミ出シテ見レバ分ル通リ、当工場ハマサニ「Ｙノフォード」タル名ニ恥シクナイ充分ノ待遇ヲ、ソノ時間ノ点カラ云ッテモ、ソノ賃銀ノ上カラ云ッテモ、皆サンニ与エテ居ルノデアリマスカラ、コノ際決シテ、カヽル宣伝ニ附和雷同セザル様、呉々モ申述ベテ置ク次第デアリマス。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だが、聴衆は場外にあふれて、所々に乱闘騒ぎを起した。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当時は劇場内に広い運動場というものがなかったのと、もう一つには幕間が随分長いのとで、大勢の観客は前にいったような太い鼻緒の福草履を突っかけて、劇場外の往来、即ち今の電車道をぶらぶら散歩していた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "場外に出ると、三機はそれぞれ機首を別々の方向に向けて、互に離れていった。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "突如として式場の空気などを、少しも顧慮しないやうなけたゝましい、自動車の響が場外に近づいた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊りがすむと人々はもたれ合って場外へ雪崩れ出た。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くも観衆は場外にあふれ、勇ましい軍楽隊の合奏が天地に響き渡りました。",
              "citation": {
                "source": "国際射的大競技",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ場外に群がる数万の市民が有らん限りの鬨を作って停車場の硝子窓が破れるほどに響くのみである。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの現在と同じような境遇と苦悶をもっている沢山の工場外の婦人も、自分が職場にいないからと云って引込むべきではないと思います。",
              "citation": {
                "source": "「我らの誌上相談」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よれよれの茶の背広を着て、洋襟のかわりに首のまわりに青い絹を結んで端をだらりと垂らしてるのが、恐らく前世紀的でもあったし、また観察によっては、領地巡視中の英吉利貴族といった場外れの効果がないでもなかった。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、父や兄達が下らないことで勿体ぶり威張るのを見たり、場外れに大仰なことをしたりするのを見ると、妙にばつの悪い眼をパチリとやらずにいられない擽ったさを感じずにはいられなくなりました。",
              "citation": {
                "source": "「母の膝の上に」（紹介並短評）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲馬組の人達は暇のない働きをしてゐるので、晩の興行の客がどの位場外に詰め寄せて来たか、平生ひつそりしてゐる、マリアの辻にどんな前景気が見えて来たか、知らずにゐる。",
              "citation": {
                "source": "防火栓",
                "author": "DAS GROBE VERGNUGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "数千人が、早く帰つて晩食を食はうと思つて、場外へ押して出る。",
              "citation": {
                "source": "防火栓",
                "author": "DAS GROBE VERGNUGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して場外の名は京師に騒いで、大中四年に宰相になった令狐綯も、温を引見して度々筵席に列せしめた。",
              "citation": {
                "source": "魚玄機",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄き給金にて繋がれ、昼の温習、夜の舞台と緊しく使はれ、芝居の化粧部屋に入りてこそ紅粉をも粧ひ、美しき衣をも纏へ、場外にてはひとり身の衣食も足らず勝なれば、親腹からを養ふものはその辛苦｜奈何ぞや。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "女流劇作家も他にいなかったし、女流の作が劇場外からとられるのも最初だったが、どうしたことか、絵ハガキなぞも上方屋から売り出されたりしたので、母はいよいよ悦ばされ、袴をはいてくれれば、頸からかける金鎖と時計を買ってあげるなどと、とぼけたことを言ったりするほどであった。",
              "citation": {
                "source": "渡りきらぬ橋",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方なしとあきらめて、ベンチに腰おろしけるが、渇を催して堪へがたきまゝに、停車場外に出づ。",
              "citation": {
                "source": "冬の榛名山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて何か思いついた如く、守衛達に一礼して場外に出た。",
              "citation": {
                "source": "真珠塔の秘密",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕達は場外へ出て少時珈琲店で憩んだ。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "道場外に声があって、「その御伝授、お待ち下さい」　と、切羽詰まって、荒々しく響いた。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、その刹那――間髪を入れず、ぱっと躍り上った門倉平馬、師匠から雪之丞へと、渡されようとする巻物を、傍からひっ掴むと、飛鳥のような素早さで道場外へと、飛び出した。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　検事の目が、はりついたようにじぶんの上にあると知ってか知らないでか、その怪人物は席をはなれて、わきたつ見物人たちをかきわけて場外へ出ようというようすだ。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
