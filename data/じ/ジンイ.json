[
  {
    "uuid": "1cdfd4e7-5c79-5c26-9fc6-e9a49ca32856",
    "entry": "人位",
    "reading": {
      "primary": "じんい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
