    "definitions": [
      {
        "index": 1,
        "gloss": "potato (Solanum tuberosum)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
