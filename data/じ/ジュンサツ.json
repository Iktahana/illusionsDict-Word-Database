    "definitions": [
      {
        "index": 1,
        "gloss": "(making) a round of inspection",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
