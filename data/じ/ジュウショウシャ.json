[
  {
    "uuid": "5ad99d5f-6669-5f6a-a591-d0c5e7237d18",
    "entry": "重傷者",
    "reading": {
      "primary": "じゅうしょうしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
