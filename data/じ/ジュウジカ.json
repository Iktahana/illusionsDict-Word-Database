    "definitions": [
      {
        "index": 1,
        "gloss": "cross (for crucifixion)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "空もいんいん、地もいんいん、肢體に青き血ながれ、するどくしたたり、電光したたり、身肉ちぎれやぶれむとす、いま裸形を恥ぢず、十字架のうへ、齒がみをなしてわれいのる。",
              "citation": {
                "source": "情慾",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "火に充ちし手のナポリの聖女、心菫に泣ける薔薇、聖ギヂルが花、汝は見しや天の砂漠に汝が十字架？",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その島の平らないただきに、立派な眼もさめるやうな、白い十字架がたって、それはもう凍った北極の雲で鋳たといったらいゝか、すきっとした金いろの円光をいただいて、しづかに永久に立ってゐるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして島と十字架とは、だんだんうしろの方へうつって行きました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっ白な、あのさっきの北の十字架のやうに光る鷺のからだが、十ばかり、少しひらべったくなって、黒い脚をちぢめて、浮彫のやうにならんでゐたのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見えない天の川のずうっと川下に青や橙やもうあらゆる光でちりばめられ〔〕た十字架がまるで一本の木といふ風に川の中から立ってかゞやきその上には青じろい雲がまるい環になって后光のやうにかかってゐるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてだんだん十字架は窓の正面になりあの苹果の肉のやうな青じろい環の雲もゆるやかにゆるやかに繞ってゐるのが見えました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてたくさんのシグナル〔や〕電燈の灯のなかを汽車はだんだんゆるやかになりたうたう十字架のちゃうどま向ひに行ってすっかりとまりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして見てゐるとみんなはつゝましく列を組んであの十字架の前の天の川のなぎさにひざまづいてゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふりかへって見るとさっきの十字架はすっかり小さくなってしまひほんたうにもうそのまゝ胸にも吊されさうになり　さっきの女の子や青年たちがその前の白い渚にまだひざまづいてゐるのかそれともどこか方角もわからないその天上へ行ったのかぼんやりして見分けられませんでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十字架の基督や矢を受けた聖セバスチアンもそうであるし、また地獄変相図やそれに似た耶蘇教の地獄図、聖アントニオの誘惑の絵の中にも同じようなものが往々見出される。",
              "citation": {
                "source": "山中常盤双紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "回々教と新月形　回教では新月形を記章とする事あたかも基督教の十字架のごとくである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイルやルブランの作品の多くは云ふまでもなく、ポオの『病院横町の殺人犯』チエスタアトンの『青い十字架』など。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして十字架の基督や、僧衣の人の像が其處に掛かつてゐた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眞白い壁と薄樺色に塗られた木具とに、室の中は明るく柔かに沈んで、十字架の基督の像を挾んだ二人の聖者の像が正面の高壇にぢつと立つてゐた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一軒ではエラリイ・クイインの「エヂプト十字架の祕密」と「ロオマ劇場事件」と「支那オレンヂの祕密」の邦譯三册を、一軒ではアガサ・クリスチイの「ハゼルムウアの殺人事件」とカアメン・エデイングトンの「撮影所殺人事件」の二原書を買ひ求めた。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時過ぎ「エジプト十字架の祕密」を讀みながら、體工合の不安な感じで早寢した。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは Stabat mater の一節だというから、いずれ十字架の下に立った聖母の悲痛を現わしたものであろう。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見えない天の川のまん中に青や橙や奇麗にかざられた十字架がまるで一本の木といふ風に川の中から立ってかゞやきその上には青じろい雲がまるい環になってかかってゐました。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてたくさんのシグナルや電燈の灯のなかを汽車はだんだんゆるやかになりたうたう十字架のちゃうどま向ひに行ってすっかりとまりました。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして見てゐるとみんなはつゝましく列を組んであの十字架の前の天のなぎさにひざまづいてゐました。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふりかへって見るとさっきの十字架はもうまるでまるで小さくなってほんたうにもうそのまゝ胸にも吊されさうになり　さっきの女の子や青年たちがその前の白い渚にまだひざまづいてゐるのかそれともどこか方角もわからないその天上へ行ったのかもうぼんやりしてわかりませんでした。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある者は、十字架に釘づけにされるように、脚を宙に浮かして、アカシヤの幹から枝にかけて縛りつけられた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その島の平らないただきに、立派な眼もさめるような、白い十字架がたって、それはもう凍った北極の雲で鋳たといったらいいか、すきっとした金いろの円光をいただいて、しずかに永久に立っているのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっ白な、あのさっきの北の十字架のように光る鷺のからだが、十ばかり、少しひらべったくなって、黒い脚をちぢめて、浮彫のようにならんでいたのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見えない天の川のずうっと川下に青や橙やもうあらゆる光でちりばめられた十字架がまるで一本の木という風に川の中から立ってかがやきその上には青じろい雲がまるい環になって後光のようにかかっているのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてだんだん十字架は窓の正面になりあの苹果の肉のような青じろい環の雲もゆるやかにゆるやかに繞っているのが見えました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
