    "definitions": [
      {
        "index": 1,
        "gloss": "habitual criminal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「大人、露西亜人にやられただ」　支那人の呉清輝は、部屋の入口の天鵞絨のカーテンのかげから罪を犯した常習犯のように下卑た顔を深沢にむけてのぞかした。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは通称を定蔵といって、先年大阪で入墨の上に重敲きの仕置をうけた者で、窃盗の常習犯人である。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも彼は常習犯の入墨者であって故買犯の芳吉も彼から買い取ったと白状し、小間物屋の手代共も彼に相違ないと申立てているのであるから、吉五郎の弁解は到底聞きとどけられるはずがなかった。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれが常習犯の盗賊であるのと、その体格が逞しくみえたのとで、彼は一度に笞打と石抱きとの拷問を加えられたが、歯を食いしばり、口を閉じて、とうとう一言も白状しなかったので、その日はそのままで牢屋へ下げられた。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "成る程のう……しかしこれ位の鍵を一つ開ける位、窃盗常習犯にとっては何でもないじゃろう」　そう云って、今一度タメ息をしいしい一知青年をかえりみた。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ、石太郎みたいな屁の常習犯がいたために、こんななやみが残ったのだと思うと、かれがうらめしいのである。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あそこにいる女、あれ常習犯で病院へ入れられとったのに、毎晩こっそり逃げ出して、商売しとってん。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "葬式があれば故人の知人を装うて葬儀場や告別式場に行き、良い加減な名刺一枚で、会葬御礼のパンや商品切手を貰う常習犯で、被害は数千円に達しているということだった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "葬式があれば知人を装うて葬儀場や告別式場に行き、良い加減な名刺一枚で、会葬御礼のパスや商品切手を貰う常習犯で、被害は数千円に達しているということだった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯人は盗癖を持つ良家の令嬢のようでもあるが、一時に三個を窃取した点から推して、いつも同一手段で市内各所でこの種の店頭を荒らし廻っていた窃盗常習犯の疑いがあり、目下厳重に取り調べ中である。",
              "citation": {
                "source": "秘密の風景画",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞に、洋装をした美しい女の窃盗犯人が、常習犯として捕えられたという記事が出ていたからだった。",
              "citation": {
                "source": "秘密の風景画",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯人は右手の食指が無い男で、その語るところによれば、この男は、最近頻々として京浜間の省線電車を荒らしていたスリの常習犯らしい。",
              "citation": {
                "source": "指",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」どうも、かっぽれは、常習犯らしい。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で彼は、漁家の継名である七郎丸を私の友達の次男に譲つて、自らは太作と名乗る幼名のまゝで、賭博の常習犯であり無頼の酒徒である。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、相手がこの藤次郎なぞのように素人ならば仕事は仕易いのですが、相手が場数を踏んでいる玄人、今日のことばで云う常習犯のような奴になると、向うでもその呼吸を呑み込んでいるので、こっちの詞が少したるむとすぐに、その隙をみて、『恐れながら恐れながら』と打ちかえして来て、なにか云い訳らしいことを云う。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三つの声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中には、少女に戯れる常習犯で前科六犯という豪の者のラピイア郡の一百姓なども混っていた。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "猶又、駄菓子屋の店先に並んだ番重の中から有平糖を盗み取る常習犯であつたことまで数へ立てて、私を、ぬすツと、と言つて触れ廻つた。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは二三年前、Ｆ楼にいた姉を買った、強竊盗常習犯の彼であろうとは、みどりは少しも知らなかった。",
              "citation": {
                "source": "ある遊郭での出来事",
                "author": "公娼存廃論者への参考資料としての実例",
                "note": "青空文庫"
              }
            },
            {
              "text": "アハハハハ……」「フーム、コンナ常習犯の奴の手口は、アイソ、サグリ、ノリと云うて、三度手を入れてみるものじゃがのう。",
              "citation": {
                "source": "骸骨の黒穂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺に似た喰逃の常習犯でも居るのか……」「まあ、御冗談ばかり……それどころでは御座いませんよ先生。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "序に述べておきたいことは、著作者と出版者の間には、現在、さほど面倒な問題は起らぬやうであるが、興行者（職業的なると否とを問はず）との間には、絶えず悶着が繰り返され、多数の劇場乃至劇団は一種の著作権侵害常習犯の観があるのである。",
              "citation": {
                "source": "演劇・法律・文化",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに我ローマの国は国がひらかれてこのかた千三百八十余年寸土尺地といへども他国を侵略したことがなく、むしろ和蘭の如きは侵略の常習犯でいつ何をやりだすか計りがたい国であると切言してゐる。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "実を云うと、僕はその方面では常習犯でね、自分一人かと思って、少し心細がってた所だ。",
              "citation": {
                "source": "白日夢",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "興に乗じての脱走は常習犯だが、他人の持物を無断で借用して、その人を困らせるような振舞は、かつてしたことのない茂太郎だから、無人格な案山子殿のならば、無断借用も罪が浅いと分別したのかも知れません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "Ocean の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "消防組頭、郡農会長、村農会長……それだけでは三人の子供ら――長男は賭博の常習犯、次男は軟派の不良、三男は肺結核――の小遣銭まではとても廻らない。",
              "citation": {
                "source": "瘤",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "母はまた、その話を、誰かからも聞いたつて云ひますから、つまり、常習犯なんですね。",
              "citation": {
                "source": "顔",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
