[
  {
    "uuid": "1c8adeba-2c07-57f8-a1d4-b748e8af4a6b",
    "entry": "時間をつぶす",
    "reading": {
      "primary": "じかんをつぶす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
