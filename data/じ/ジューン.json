        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こちらの方では、まるい銀の頭を、ぴかぴかにみがきあげられたタオルむしが、ひとりで、ジューン、ジューンと湯気をふいていました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャーリーは三津子のことをジューンと呼んでいた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジューンと知り合ったきっかけは、三年まえにスタートしたそのトーク・ショーに出演してもらったことだ、とシャーリーはぼくに説明した。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ジューンだなんて、きまり悪いわ」　笑顔で、三津子は言っていた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、ジューンにしたの。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかしいのはジューンという名前なのだと、やがてぼくは気づいた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "三津子がいまはジューンであることはいっこうに構わないし、たとえばシャーリーが彼女をジューンと呼ぶことにも、違和感はすこしもなかった。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月生まれだからジューンとつけた、とさきほど三津子は言っていた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョイス・サチエ、イヴリン・キミコ、グラディス・ハツミ、ジューン・サトコの四人だ。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
