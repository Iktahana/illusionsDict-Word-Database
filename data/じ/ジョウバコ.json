    "definitions": [
      {
        "index": 1,
        "gloss": "box for holding letters",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "とりあえず御差紙は大目付様からの御状箱に入っておりましたか……」「さあ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "大目付様にも何にも生まれて初めて見る御状箱で御座いましたけに、よくわかりませなんだが、お先方様のお名前は渋川様と御座いましたが……渋川ナニ吾様とか……」「エッ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "町々つじつじの警備に出払ってしまってひっそり閑と静まり返っているお番所の中へさっさとはいっていくと、てこでも動くまいといいたげに、どっかりすわったところは訴状箱の前でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、そこへすわって、あごでもはずして、ふところへしまってから、とっくりとこれを見なよ」　ようやくのことに、訴状箱の中から目ざしたネタを捜し当てたとみえて、さわやかにうち笑みながら、かんかん虫の伝六の目の前に差しつけたのは、じつに次のごとき三通の訴え状です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "訴状箱ひっくり返してみりゃ、どこの権右衛門だかすぐとわからあ」「なるほど、それにちげえねえ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "４　行ってみると、果然、訴状箱の中には、恒藤権右衛門とこそ明記はしてありませんでしたが、朝ほど子どもを連れた女が、夫の討たれた旨を訴えに来たことがちゃんとご記録帳にのせられてありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その五つかっきりにご番所へ参りますると、さっそく訴状箱をひっかきまわして、ひと渡りその日の訴状を調べます。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの訴状箱をかきまわしながら、指を切りとられたという訴えの、小石川台町と厩河岸の所番地を書き取って、そっとそれを懐中しながら、何かうそうそと皮肉そうに笑っていましたが、表へ出るとぽつり伝六にいいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "八の三　手紙は古風な状箱の中にあつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども中にあつた手紙は、状箱とは正反対に、簡単な言文一致で用を済してゐた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、状箱のような容器に毛糸で編んだお金入が入れてある、そのお金入の中にほんの僅なお金を見た時は、自分はほんとに済まないことを言ったような悲しい気持になって、もう決してそんなことは言い出すまいと思ったと書いてよこした。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙は古風な状箱の中にあった。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども中にあった手紙は、状箱とは正反対に簡単な、言文一致で用を済していた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "くどいようじゃが、その心得でな」「畏承りました」　小平太はすぐに身支度をして、例の状箱を受取って立ち上った。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へえ、両国橋のお茶道珍斎からお状箱を持ってまいりました」「そうか、よし通れ！",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の侍も小平太が門をはいるまでじっと後を見送っていたが、仲間体ではあるし、状箱は持っている、別に胡乱とも思わなかったか、そのまま踵を返して行ってしまった。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかお取次ぎを願います」と、手に持った状箱を差出した。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろしくと伝えてくりゃれ」と、小平太の持ってきた状箱を渡した。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "小平太はまず忠左衛門に一礼して、さて安兵衛と勘平の前に持って帰った状箱を差出した。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "褌一つで木刀を一本、その真中に状箱を結いつけたのを肩にかついでいる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といつて状箱のやうなものを出しました。",
              "citation": {
                "source": "狐の渡",
                "author": "土田耕平",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とふしんに思ひながら、その状箱のやうのやうなものをあけてみますと、　サツキハ、バケソコネテ、ヲカシカツタダロ、コバンハ、カヘシテヤルヨ、コンスケ。",
              "citation": {
                "source": "狐の渡",
                "author": "土田耕平",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都から来る飛脚の状箱を、こっそりあけるだけでよかったのだからな」四人は先へ進んで行く。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……江戸、竜ノ口の評定所というところの腰掛場に、目安箱という箱がさがっていますから、それを持って来ていただきたいの」　目安箱というのは、歴代の将軍が民情を知る具にした訴状箱で、老中の褒貶、町奉行、目付、遠国の奉行の非義失政などの忌憚のない密告書が出てくる。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "捨公方",
                "note": "青空文庫"
              }
            },
            {
              "text": "三尺あまりの身体に状箱を縛りつけたような身躯、小さな手足にくらべて莫迦にあくどい大きな顔……。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ弾きだすかと思うと、さにあらず、押入れをあけて、とり出したのは、中を朱に、ふちを黒に塗った状箱です。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その状箱からぞろぞろ這い出したのは、五、六匹の尺とり虫ではないか――。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "何分、子々孫々にいたるまで光栄のお役ゆえ、大過なきよう相勤めらるべく候　　小笠原左衛門佐殿」　それぞれ、二通を状箱にふうじて納めた主水正は、即刻、儀作ともう一人の若党をよんで、同時に別所、小笠原の二家へ、とどけさせることになった。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思うと、さしだされた状箱を奥の一間で、重役らがひたいをあつめて、心配げに開いてみる。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま書いた四、五の状箱をかかえて行った。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
