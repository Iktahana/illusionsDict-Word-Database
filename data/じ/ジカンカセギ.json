        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もったいぶって説明したのは、ただ汽車到着までの時間稼ぎに過ぎなかった。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しつこく時間稼ぎをしたが、コーラはかたくなだった。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた、時間稼ぎをしていますね。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨシオには、時間稼ぎが必要、という自覚しかなかった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神を落ち着かせる時間稼ぎをしたかった。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく家主の所へ行って時間稼ぎしている」　メアリが不意にあの場面を思い出した。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿ぐつわをかまして隠せば都合がいいし、時間稼ぎができる。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかは放っといて、エンジンをかけろ、車庫の扉を開けろ」「二、三分欲しいです」　数分なら時間稼ぎ出来ると男爵が答えた。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
