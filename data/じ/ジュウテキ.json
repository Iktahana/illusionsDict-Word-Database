[
  {
    "uuid": "c0ded19a-b28f-575a-a1a8-179edc9952ac",
    "entry": "従的",
    "reading": {
      "primary": "じゅうてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
