    "definitions": [
      {
        "index": 1,
        "gloss": "subordinate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "△中村金作氏――『機械』いゝ色彩であるといふより自己の神経が色彩の上にでゝゐて、形態の上では追従的であつたが、色彩の上では非妥協的であつてゝ。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "忍従の気分　加能君の作を傍観的だと言つた私の言葉に対して、加藤君は、『いや傍観的ではない、忍従的だ』と言つた。",
              "citation": {
                "source": "野の花を",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、夫人に話しかけられて、たゞ盲従的に返答することも出来なかった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ミサ……」と女性は服従的に答えた。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が悪事を後悔した瞬間程屈従的な心に変ずるものはない。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、夫人に話しかけられて、たゞ盲従的に返答することも出来なかつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "温和で正直で忍従的な人民の多数が、その温和で生産的な社会生活を継続し発展させてゆく可能を保つために、それらの人々がファシズムにくわれつくさずに生きてゆけるだけの自主的余地をこの社会に拡げる力として、日本のレフティストの存在意義は小さくないことがわかってきている。",
              "citation": {
                "source": "世紀の「分別」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この悲惨な経験を生き抜き、「自分」を取り戻そうとしはじめてわずか三年たつかたたないのに、日本の理性は再び戦争の挑発と、根の深い日本のファシズムと権力の屈従的なショーヴィニズムとによって危機にさらされようとしている。",
              "citation": {
                "source": "前進的な勢力の結集",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ男が付け込んで奴隷扱ひにし、女が盲従的に甘んじてその屈辱を受けると云ふのは訳の解らないことです。",
              "citation": {
                "source": "新らしき婦人の男性観",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そこには何か一抹の虚偽がうかがわれ、帝政時代とその屈従的精神とを経験した人間らしいところが見られた。",
              "citation": {
                "source": "「緑の騎士」ノート",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界ファシズムがふたたび擡頭していること、日本の屈従的な政府は、自身の反歴史的な権力維持のためには、人民生活を犠牲にして大木のかげに依存していることなどについて明瞭に理解してきた。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第十一巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、かれは、この低みから、すべての部分がかれの上に在るあの世界をみおろすことのできる、不思議な妖術を学び得た魂である――この屈従的な魂は。",
              "citation": {
                "source": "俯瞰景",
                "author": "富永太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は漸時忍従的になった。",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「君らはすべて盲従的だからいかぬ」　そう松島が言うた。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何が、我らが盲従的だ？",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡庸のなかに根をすえて坐りこんだ、これらの低俗なともがらはお前の隷従的な心にふさわしい。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは結構な料理と酒がふんだんにあり追従的な客の居ならぶ、しかし誠実と真実とは見あたらない食卓につらなった。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局のところ、カーターの観点は臆病で、人畜無害で、内気で、服従的な小男のように思われる。",
              "citation": {
                "source": "観点",
                "author": "THE POINT OF VIEW",
                "note": "青空文庫"
              }
            },
            {
              "text": "勧善懲悪というのは、滝沢馬琴流の小説をいうもので、それは多分に徇法的屈従的であり長いものに捲かれろ主義である。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "平次身の上話",
                "note": "青空文庫"
              }
            },
            {
              "text": "二〇〇一年一二月九日に、小林繁雄が野口英司に宛てたメール――青空文庫の専従的な立場を離れるという野口に対して送ったメールに、その謎を解く鍵があるかもしれない。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "「豊富な湿気が人間に食物を恵むと共に同時に暴風や洪水として人間を脅かすというモンスーン的風土の、従って人間の受容的、忍従的な存在の仕方の二重性の上にここには更に熱帯的、寒帯的、季節的、突発的という如き特殊な二重性格が加わってくるのである」と。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は女王に、屈従的な手紙を書いた。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、Ｋは言い、その男の屈従的態度に思わず知らず刺激され、どうしても信じさせてやろうというように男の腕をとらえた。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父はいつまでも立止って、低くお辞儀をし、やたらに追従的なお世辞を並べたてた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "消極的で忍従的なルイザは、何事をも受けいれると同様に、その不幸をも受けいれた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の服従的な本能は、他人の意思に従うのみである友情のうちに、自己満足を見出していた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼い時から彼は、あらゆる艱難に黙って堪えてゆく雄々しい忍従的な彼女の姿を、いつも見慣れていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその音楽上の本能的｜嗜好をよりも、生来の屈従的精神をさらにはなはだしく傷つけられた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "追従と言えば、彼女はだれよりも追従的であった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし彼が偏狭でなかったならば、その六十年代の婦人に青年の服装をして舞台に立たせ、しかもきれいに――少なくとも追従的な眼には――見えさせている、変装の優美さと技巧の芸当に、敬意を表したかもしれなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
