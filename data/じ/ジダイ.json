[
  {
    "uuid": "208f51e2-75d8-527d-8380-32cda1db0be1",
    "entry": "事大",
    "reading": {
      "primary": "じだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "subserviency to the stronger",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それをひねくり廻している矢先へ通りかかったのが保険会社社長で葬儀社長で動物愛護会長で頭が禿げて口髯が黒くて某文士に似ている池田庸平事大矢市次郎君である。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鵺が來て池で行水を使つたほどに、事大袈裟に立到る。",
              "citation": {
                "source": "怪談女の輪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "盖し、日本の臣民は如何なる塲合に於ても、其身を思ふよりも、國を思ふ事大なれば、若し救ふに良策なくば、乞ふ、大義の爲に吾等を見捨て玉へ、吾等も亦た運命に安んじて、骨を此山中に埋めん。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうか、金に換算されるのか、大したこっちゃないと何か救われて、一筋に思いつめていた事大観念めと重荷がとれる想いがした。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども豚吉は平気なもので、なおの事大きな声を出して云いました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大事大業大功大利が、如何にして限り有る一人の心計｜身作の力で能く成し得るもので有らうか。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "事大主義というんだよ。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "背に腹は代えられぬ情なさだが、しかし「セントルイス」は女の経営にしては、万事大まかに穴があいて、ちゃっかりした抜け目のなさが感じられぬのは、さすがに本妻の気品で、他の京都人経営の喫茶店を嗤っているところもあり、「おれ京都がいやになったよ」　と、京吉が言いに行くには、ふさわしい店でもあった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "大陸序曲　事大陸に関したものを主として蒐めた。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国でもゼームス二世の時諸獣の毛皮を着る事大流行じゃったが、下等民も御多聞に洩れずといって銭はなし兎の皮を用いたので、ロンドン界隈は夥しく兎畜養場が立ったという（サウシ『随得手録』一および二）。",
              "citation": {
                "source": "十二支考",
                "author": "兎に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、見事大外れとなった見通しもある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは、思想として全体を憤慨する前に、おれ自身の恥さらしな、憶病者の、事大主義者の、裏切り者の、利己主義者の、資本主義の番頭のおれを、まず血祭りに上げねばならぬ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、依然事大主義者だった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "大事大業大功大利がどうして、限り有る一人の計画や労務の力で能く成し得るものであろうか。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮ノ亡國的腐敗ハ悉ク事大的國是トナリテ現ハレ、日清戰爭ニ於テハ清國ニ從ヒ、日露戰爭ニ於テハ露西亞ヲ迎ヘ、聊カモ英國ト自耳義ノ結托ニ似タル者ナカリシハ開戰原因ヲ顧レバ明白ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "その事大いに異なれど国言相通ず。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日の新紙に近年蛇を薬用のため捕うる事大流行で、鯡を焼けば蛇｜聚い来るとあったが虚実を知らぬ。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "さていよいよ駒を生んでより馬ども耳を垂れて嚏噫にも声せず、商主かの牝馬飛んだものを生んでわが群馬を煩わすと悪む事大方ならず、毎もこれに乗り好き食物を与えず。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶏に五徳あり、あるいはその家の吉凶を告ぐ、また真言宗に白鶏尾を秘壇の中瓶に立つる事あり、殊に時刻を告ぐる事大事大切なりとあるので分る。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日城攻め合戦剛猛の事に吉し、惣じて万事大吉なりとあるは、その猪突の勇に因んだものだ。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは御覧の通りの善人で、唯もう仕事大事に勤めているんだからね。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "事大主義と、中庸主義とを全く無視する。",
              "citation": {
                "source": "探偵小説の世界的流行",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "住居でも、衣食のことでも、万事大層手軽なものでありますから、今いったような絵画彫刻というようなことに気が附かぬのは当然なことである。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "私の子供の時のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯んな類ひの真面目な質問に出遭ふと私は、変に事大的に考へ過ぎて唖になるのが癖だつた。",
              "citation": {
                "source": "Ｒ漁場と都の酒場で",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夏醍醐に遊んでゐると、その頃の京都府知事大森｜鍾一氏が山へ上つて来た。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは御覧の通りの善人で、ただもう仕事大事に勤めてゐるんだからね。",
              "citation": {
                "source": "茶話",
                "author": "昭和三（一九二八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "権力というものに対する事大主義的な追随や、機械的な政治の文学に対する優位の承認を結果するであろうという危険は、誰の目にも明かである。",
              "citation": {
                "source": "今日の文学の鳥瞰図",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "否、或は、他の多くの作者が何の抵抗をも示さず頭から現実の事大勢力に屈服しているに対して、人及び芸術家としての山本有三氏は一応矛盾をも指摘し、それに抗議せざるを得ない人間の真情をもとりあげ、而して後、一般の温順な市民がそうである通り根本的な妥協への道を開いて見せている。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "孜々として鼻息をうかがっているものなのだそうであるが、リオンスはそういう皮肉そうな言葉づかいでとりもなおさず自身の事大主義的な性根を暴露しているのである。",
              "citation": {
                "source": "近頃の話題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『大きかないや、おんなじだい。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
