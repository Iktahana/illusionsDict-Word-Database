    "definitions": [
      {
        "index": 1,
        "gloss": "I don't want to boast but",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自慢じゃないが、高原越えだけで普道の人間ならば凹垂れるところである。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "自慢じゃないが最近売り物の原稿をさっぱり書かないオレは、ここのところとりわけ貧乏だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は自慢じゃないが文学者の名なんかシェクスピヤとミルトンとそのほかに二三人しか知らんのだ」　津田君はこんな人間と学問上の議論をするのは無駄だと思ったか「それだから宇野の御嬢さんもよく注意したまいと云う事さ」と話を元へ戻す。",
              "citation": {
                "source": "琴のそら音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この通り、自慢じゃないが、一年半に近い外遊中、私達が諸国各地のホテル・停車場・タキシ内――これが一番苦手だ――その他料理店等で置き忘れて来た色んな物品を価格に見積ると、決して馬鹿にならないものがある。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "険呑な仕事なら、自慢じゃないが、慣れっこになっている吾輩だ。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "章介　なに、自慢じゃないが私なんぞ会社じゃ、いてもいなくても大した変りはないんです。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふん、自慢じゃないが、世界広しといえども、わしよりえらい天文学者は、ただの一人もいないのじゃ」　そう言って、蟻田博士は、ここちよげに、からからと笑った。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "コチトラ、自慢じゃないが、トランクに札束あり、と見破ってこのかたツラツラ目に沁みこませておきましたんで、見忘れないツモリですわ」　京都へつく。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「自慢じゃないが、何も知らんよ。",
              "citation": {
                "source": "元禄十三年",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "自慢じゃないが……」　注意された岡田はますます真面目になった。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワンワンほどには行かぬけれど、自慢じゃないが、これでそうとう、ものを嗅ぎわけるほうだから、この感じには間違いはあるまい。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "菊香水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴェルレエヌじゃないが、「げに我れはうらぶれて、ここかしこさだめなく、飛び散らう落葉かな」というわけで、自慢じゃないが婦人病以外の病気はたいていわずらった。",
              "citation": {
                "source": "放浪作家の冒険",
                "author": "西尾正",
                "note": "青空文庫"
              }
            },
            {
              "text": "自慢じゃないがこちとらは、人様の袖に縋ったおぼえはないが、どうかすると百｜文も持っていねえことがある」「自分に引きくらべる奴があるかい、――だが、筋は面白そうだね、もう少し詳しく話してみるがいい」　平次も少し乗出しました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "血潮と糠",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナナがひどく恐れたから、空自慢じゃないが、奴を破滅に追い込める」「来ますかね？",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは自慢じゃないが、尋常科の時に海へ落っこった女の子を助けて、お上からごほうびをもらったことがある」「川へ落っこった子だっていったぜ」　と尾沢生が揚げ足をとった。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の立て方は、自慢じゃないが、盆興行としては理想的なもので、浅草の客をこっちへとっちまふ考へであったが、今日はその狙ひ通り成功したらしい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "自慢じゃないが、私の化粧は完璧だから、たぶん誰も……」　女王が叱責された。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "自慢じゃないが、当時、最難題事件が本官に任せられたものだ。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "自慢じゃないが、ボーア戦争では病院勤務だった。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "マーシさん、私はからくりを知っているし、自慢じゃないが、あなたと同じ位うまく出来ます。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "自慢じゃないが人生の修羅場をくぐってきた身は何事も動じない。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "自慢じゃないが本官の発見です。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "自慢じゃないが、あっしが居ないと無力でやす。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "自慢じゃないが、わしは両方を持ち合わせているし、お前もある程度持っているから、画家として名をあげてくれ。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "自慢じゃないが言わせてもらうと、このロンドンの誰よりも、奴の人生と行動をよく知っている。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
