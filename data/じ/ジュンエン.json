      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "postponement",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "果然雨天順延となって、私の旅行日程にもまた一日の狂いが生じて来たので、無聊に苦しむよりは雨の日本ラインの情趣でも探勝しようかとなった訳である。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "果然雨天順延となつて私の旅行日程にもまた一日の狂ひが生じて来た。",
              "citation": {
                "source": "日本ライン",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月下旬のある日、散歩ながら強羅停車場へ出てゆくと三十一日午後七時から蘆の湖で燈籠流しを催すという掲示があって、雨天順延と註されていた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "元箱根までわざわざ登って行って、雨天順延では困ると、二人はすこしく躊躇していたが、恐らく雨にはなるまいと土地の人たちが云うのに励まされて、七時頃から二人は自動車に乗って出た。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯天候のため、連合軍の上陸は、四十八時間順延となった由。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
