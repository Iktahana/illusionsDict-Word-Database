    },
    "definitions": [
      {
        "index": 1,
        "gloss": "castle garrison",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "城兵這奴憎きものの振舞かなとて、競懸りて半ばより、梯子を折く。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四年正月、燕の先鋒李遠、徳州の裨将葛進を上を攻め、沛県を攻めて之を略し、遂に徐州に進み、城兵を威して敢て出でざらしめて南行し、三月｜宿州に至り、平安が馬歩兵四万を率いて追躡せるをを執って燕王に逼る、相距るたゞ十歩ばかり、童信射って、其馬に中つ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち毛利の第一軍は、地御前より厳島を迂廻し、東北岸鼓の浦に上陸し、博奕尾の険を越え、塔の岡の陶本陣の背面を攻撃し、第二軍は、宮尾城の城兵と協力し、元就軍の本軍が鬨の声を発するを機とし、正面より陶の本陣を攻撃するもので、小早川隆景これを率いた。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その責任上、永禄三年兵を関東平野に進め、関東の諸大名を威服し、永禄四年に北条｜氏康を小田原城に囲んで、その城濠｜蓮池のほとりで、馬から降り、城兵が鉄砲で狙い打つにも拘らず、悠々閑々として牀几に腰かけ、お茶を三杯まで飲んだ。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "速に春日山の留守隊に来援を命じ甲軍の背後を衝かしめられては如何」と進言したが、謙信は「十日の糧食があれば充分だ」と云って聴かず、大和守は「もし晴信海津の城兵を以て我を牽制し彼自ら越後に入らば策の施すべきなし」といえば、謙信笑って「春日山は厳重にしてあるから不安はない。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大高城兵糧入れこそ、家康の出世絵巻中の第一景である。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "大高城兵糧入れに成功した元康は、五月更に大府に向い八月には衣城を下した。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "城兵わずかに五百、殊死して防いだ。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "城は二の丸まで押し破られたが、城兵も殊死して防ぎ、寄手の部将加津佐の三郎兵衛を斃したりした。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "城兵また多く来襲して、貞清自らも肩を槍で衝かれた。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "家臣湯浅覚太夫がその城兵を突伏せたので、危く重囲を脱し得たが、従士は次々に斃れるばかりである。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "信綱、氏鉄、夜討ちの現場を視察して、城兵の死骸の腹を割かしめて検した処が、海草の類を見出した。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "城兵は、四郎を天帝の化身のように考え、矢石当らず剣戟も傷くる能わずと思っていたのに、四郎が傷いたので、彼等の幻影が破れ、意気｜頓に沮喪したと云われる。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ城濠の傍近く馬から下り、城兵に鉄砲の一斉射撃を受けながら、悠々としてお茶を三杯飲んだと云うような豪快な逸話を残している丈だ。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "三成曰く、いや／＼、堤防が出來さへすれば、城兵はみな溺死せむ。",
              "citation": {
                "source": "石田堤",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "城兵を斬らば、他の土民も恐れてにげ去るべしとて、知つて知らぬ風をしたりき。",
              "citation": {
                "source": "石田堤",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "城兵それと知りて頻りに鐵砲を放つ。",
              "citation": {
                "source": "石田堤",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "城兵、卑怯なりと罵る。",
              "citation": {
                "source": "石田堤",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "内膳正が流れ弾にあたって倒れたのを機会に、総敗軍の姿となって引き退く後を、城兵が城門を開いて、慕うて来た。",
              "citation": {
                "source": "恩を返す話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時初めて、将軍から、「城兵は寄手を引き寄せて、夜を待つように見え候、早く戦いを令すべし」と、いう軍令が諸陣の間にふれ渡された。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「甲州勢退くと見るや、城兵一時に安心し、凍えた身肌を暖めんものと甲を脱ぎ鎧を解き弓矢を捨て刀鎗を鞘にし……」「わかった！",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この大雪には城兵といえども、門をひらいて追っては来まい。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵が苦しき經驗を嘗めて後には蒙古人が逃げても追駈けるなといふことになりますると、蒙古人は成るたけ先方を怒らせ、さうして其城兵をおびき出す工夫をする。",
              "citation": {
                "source": "元時代の蒙古人",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥の半乾きになった道を、近藤と、土方とが、結城兵二三を連れて、防禦陣地の選定に廻った。",
              "citation": {
                "source": "近藤勇と科学",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そればかりでなく、駿河守殿は、生粋の佐幕派、それに、城兵も多数居る。",
              "citation": {
                "source": "甲州鎮撫隊",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "城兵かそれとも浪士達か、鉄砲を打ち出したものがあった。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "籠城兵士の筆ではなくとも、一揆に同情しながら加担しなかつた村民や切支丹の遺した記録はないか。",
              "citation": {
                "source": "島原一揆異聞",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "城兵は、これを迎えてなにかと必死になって戦ったけれど、如何とも支え得られそうもない。",
              "citation": {
                "source": "老狸伝",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "城兵も、これがために勢いを盛り返して、奮戦したので、さしもの北条、武田合同軍も、ついに敗走してしまったのである。",
              "citation": {
                "source": "老狸伝",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに乗じて城兵は、城外へ押し出して敵を追跡し、これを殲滅しようとしたけれど、伏兵の虞れありとなし、謙信はこれを制止した。",
              "citation": {
                "source": "老狸伝",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
