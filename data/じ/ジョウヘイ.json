[
  {
    "uuid": "13f2a964-3662-555f-b189-b19b1b6560d4",
    "entry": "城兵",
    "reading": {
      "primary": "じょうへい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
