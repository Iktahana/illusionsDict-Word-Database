    "definitions": [
      {
        "index": 1,
        "gloss": "self-satisfaction",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
