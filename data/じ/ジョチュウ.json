        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（間）ダンシングホールへ行くことも禁じられるし、まるで女中代りよね、此の頃のあたしつたら。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその他の場合では、罪のない笑談を言ったりして、妻や子供の家族を笑わせ、女中までも仲間に入れて、一家｜団欒の空気を作った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした夫婦の会話は女中や下僕にはもちろんのこと、子供たちにさえもよく解らなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "駄目です』などと夫人にからかわれ、『あ、どうしよう、私この鼻』など言って悄気返り、『真ッぴら、真ッぴら』と、今おぼえたばかりの日本語を面白がって使ったりして、夫人や女中たちを大笑いさせたりしているのだが、その後で、『しかし、よく思うて下さい。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた女中ありません。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻や女中たちが、玄関の畳に列び坐って、『お帰り遊ばせ』とお辞儀をする。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで式のある日などには、夫人が無理に押えつけ、女中までが手伝って騒ぎながら、まるで駄々ッ子を扱うように、あやしたりすかしたりして、厭がるのを強いて着せねばならなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中が蛇を追ったといって叱られ、植木屋が筍を抜いたといって怒られ、はては『おババさま』の姑でさえが、枯れた朝顔をぬいたというので『おババさま好き人です。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中が二人、書生が一人、老僕が一人、他に抱車夫が一人という大家族であったので、家も相当に広く、間数がいくつもあって廊下続きになっていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると『それ貝が鳴った』とばかり、夫人を初め女中や書生たちが大騒ぎをし、先を争って離れの書斎に駈けつけた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝飯の膳に向つた時、女中がさりげない風でたづねた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はさらに女中に命じて、念のために新聞を取り寄せさせた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿に著いて、すぐ女中さんたちに輕い冗談言へるやうな、器用な男ではないのである。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中さんがあらわれて、どうぞ、と言う。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処かの女中が裾をからげて、下ばかりみながら近づいて来る。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る時、女中が杓文字の影を壁に映した。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中のお房が雨戸をしめに来たのである。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中は縁側の戸を一枚々々としめて行って残る一枚を半ばで止め、暗い庭の方をじっと見ている。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの後父が再び上京して帰った時の話の末に、お房と云う女中は縁あって或る大尉とかの妻になったと聞いた。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと車の音が玄関へ飛び込んで来ると思うと番頭や女中の出迎える物音がしてそうして急に世の中が賑やかに明るくなった。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの女中などの尊敬の対象であったようである。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日宅の女中が近所の小母さん達二、三人と垣根から隣を透見しながら、何かひそひそ話しては忍び笑いに笑いこけているので、自分も好奇心に駆られてちょっと覗いてみると、隣の裏庭には椅子を持出してそれに楠さんが腰をかけている。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし当時の自分にはその光景がひどく美しく長閑なものに思われ、そうして女中等のそういう態度に対して少なからず不満を懐いたようであった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の女中も、不親切だ。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日の豫定の勉強が濟んで、温泉へ入り、それから夕食にとりかかるのであるが、ビールを一ぱい飮みたくなつて女中さんに、さう言ふと、「ございません。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、女中さんの顏を見ると、嘘だといふことがわかるので、「ぜひ飮みたいんだ。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰度その時女中は台所で、竈の下を焚き付けてゐます。",
              "citation": {
                "source": "家族",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "お婆さんはお掃除が好きで、大好きで、時偶女中がお掃除をしようものなら直ぐまた自分がやりなほすといふふうでした。",
              "citation": {
                "source": "家族",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中はこれから郵便局に、手紙は出しに行つて来ると云ふのでした。",
              "citation": {
                "source": "夜汽車の食堂",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うの階段の下では手拭を冠つて尻端折つて箒を持つた女中が三人、姦の字の形に寄合つて吾々二人の顏を穴のあく程見据えてゐた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
