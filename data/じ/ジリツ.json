  {
    "uuid": "5df05682-2bb9-589c-ba08-026d8a0a0857",
    "entry": "自立",
    "reading": {
      "primary": "じりつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "independence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自立、自立………一つ大に行らう。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳剽し口衒し、色を詭り辞を淫にし、聖賢に非ずして、而も自立し、果敢大言して、以て人に高ぶり、而して理の是非を顧みず、是を名を務むるの蠹という。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "孝孺の此言に照せば、既に其の卓然として自立し、信ずるところあり安んずるところあり、潜渓先生が謂える所の、特り立って千古を睨み、万象｜昭して昏き無しの境に入れるを看るべし。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "繼母が來たので三たび衝突して、遂に自立することになつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "義元を打倒した信長は、義元の壮図だけを承け継いで、その戦勝の余威に乗じて、上洛行動の準備を為し、先づ今川から自立した徳川家康と攻守同盟を結んで、後顧の憂を絶ち、美濃の斎藤を追うて道を開き、近江の浅井長政に妹を嫁して、途中の不安を除き、その上洛の志を達したのが、永禄十一年である。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏に負けずにとうちゃんもがんばっているのだから、子供も自立する心がけをもとう、といった調子です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠隔地との交易を活力源として都市が勃興するに連れ、そこに台頭してくる新しい自立的な民衆が、書籍文化を支えるもう一つの柱を形成しはじめます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "創作活動を自立させ、著作者に支えや励ましを与える上では、著作財産権の定義と保護は有利な選択となる。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し時間が経って、自立のための親への反抗プログラムが働きだした後なら、なにそんなもの、腰が抜けるほど驚きはしなかっただろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "申すまでもなく、この時代の蜀は正統ではありません、乱世に乗じて自立したものですから、三国時代の蜀と区別するために、歴史家は偽蜀などと呼んでいます。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "録異記",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那印度七億ノ同胞ハ實ニ我ガ扶導擁護ヲ外ニシテ自立ノ途ナシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "要スルニ凡テノ原因ハ朝鮮ガ日本支那露西亞ノ三大國ニ介在シテ自立スル能ハザリシ地理的約束ト、其ノ道義的廢頽ヨリ一切ノ政治産業學術思想ノ腐敗萎微ヲ來シテ内外相應ジテ亡ビタルモノナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "自立シ能ハザル地理的約束ト眞個契盟スル能ハザル亡國的腐敗ノ爲ニ、日本ハ露國ノ復讐戰ニ對スル自衞的必要ニ基キテ獨立擁護ノ誓明ヲ取消シタル事ガ眞相ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "英國ヲ破リテ土耳古ヲ復活セシメ、印度ヲ獨立セシメ、支那ヲ自立セシメタル後ハ、日本ノ旭日旗ガ全人類ニ天日ノ光ヲ與フベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "自立的科学的な社会人として、社会のすべての事がらに判断をもち、よい社会を作るために献身する美を知ること。",
              "citation": {
                "source": "日記・書簡",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖縄人はこういう風にして支那に近づき、これによって得た所の利潤の過半を島津氏に納め、その余分を以て自立して来たのでございますが、間もなく支那には明清の大乱が起って沖縄人は二、三十年間も支那に往く事が出来ないようになりました。",
              "citation": {
                "source": "琉球史の趨勢",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭もなく形もととのわず才もない様に育った女が自立しようとすれば一番雑作ないのは女中ですからねえ、やっぱり」「そうなんですよ。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに対して、物価調節、各家庭に対する節約宣伝のような、やや消極的方面の問題、また積極的には女性の自給自立、労銀等の問題から、根本に近い、社会主義上の諸問題が、惹起されます。",
              "citation": {
                "source": "男…は疲れている",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中国に於ては、ヒューマニズムの運動は、その国の置かれている事情に従って、民族自立の問題と結びついている。",
              "citation": {
                "source": "ヒューマニズムの諸相",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る賞のために努力した若い作家は、多くの場合その賞の審査員である諸作家の影響というものに対して、全く自立的な感情を持ち得ないであろうし、又私などはそのことで自身の芸術の素直な発展を阻害されている何人かの人を知っている。",
              "citation": {
                "source": "今日の文学の鳥瞰図",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宣教師の娘であり、宣教師の妻であって、バックが、中国の民族的自立の必然を認め、中国の民衆の独自性を理解して中国にキリスト教と宣教師とは必要ないものであると公言していることは、実に一つの驚くべき人間的誠実である。",
              "citation": {
                "source": "中国に於ける二人のアメリカ婦人",
                "author": "――アグネス・スメドレーとパァル・バック――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしろ、バックの作品中では、まだ、中国の統一的自主のあとに来る、或は中国の自立してゆく過程の内部に含まれてその有力な契機となっている民族自主の観念の発展性、未来の方向については語られていない。",
              "citation": {
                "source": "中国に於ける二人のアメリカ婦人",
                "author": "――アグネス・スメドレーとパァル・バック――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの若い、孤独な妻たちは、季節季節の色どりを健気に身をつけて、さまざまの職業につき、経済上の自立とともに未来のひろやかな展望をもとうとしている。",
              "citation": {
                "source": "世界の寡婦",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことしのメーデーに自立合唱団や劇団はどんな自分たちの催しものを、全勤労者のメーデーの賑わいに交える計画だろう。",
              "citation": {
                "source": "正義の花の環",
                "author": "――一九四八年のメーデー――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポツダム宣言が受諾されて日本の人の声々のなかに、戦争を悲惨とし、平和と自立とを愛するひびきがきかれるようになってから三度目の八月十五日が来ようとしている。",
              "citation": {
                "source": "わたしたちは平和を手離さない",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "平和という言葉は、真に民主的に自立した日本の、まじめで勤勉な男女人民の平和建設を意味してあつかわれるべきである。",
              "citation": {
                "source": "わたしたちは平和を手離さない",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸にも日本の男女は、これまでただの一度も、しんからファシズムに反対して自立たちの力で守りとおした平和というものの、高鳴るような歓喜とほこりとを経験していない。",
              "citation": {
                "source": "わたしたちは平和を手離さない",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "耐えがたい隷属の生活であればこそ、世界平和と民族の自立の要求は、アジア各民族の婦人たちの精神にはげしくもえたって、マライには七千人の婦人たちによる統一戦線がつくられました。",
              "citation": {
                "source": "新しいアジアのために",
                "author": "――アジア婦人大会によせて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝国主義、ファシズムによって荒廃させられた東ヨーロッパの人民も民族の自立と人民生活の確立を方針として、人民民主主義の社会をつくりました。",
              "citation": {
                "source": "宋慶齢への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある豪家の老人が死んだ葬式の晩に、ある男は十二分の酒を飲んで帰る途中の田んぼ道で、連れの男の首玉にかじりついて、今夜ぐらい愉快に飲んだ事は近来にないという事をなんべんもなんべんも繰り返しながらよろけ歩いていた。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
