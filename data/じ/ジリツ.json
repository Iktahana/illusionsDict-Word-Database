    "definitions": [
      {
        "index": 1,
        "gloss": "assisting (a dignitary)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "山彙の遠く綿亘するを睥睨するが如き緩峯、北方に侍立す。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面に丹左衛門尉基康その左右に数名の家来槍をたてて侍立す。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "生徒監や、日頃叱咤する体操教師たちは講堂に侍立してるだけで、この非合法の集会を解散させることは出来なかった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところへ紺飛白の袷一枚を、素肌に纏うた呉一郎が、二人の廷丁に腰縄を引かれて這入って来ると、三人の紳士は左右に道を開いて正木博士に侍立した形になった。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸の樹下に合掌する韋提希夫人あり、婢女一人之に侍立し、樹上に三色の雲かゝり、正中上方一線の霞の下に円日あり、下に海中島ある構図である。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸の樹下に合掌する韋提希夫人あり、婢女一人之に侍立し、樹上に三色の雲かゝり、正中上方一線の霞の下に圓日あり、下に海中島ある構圖である。",
              "citation": {
                "source": "山越しの阿彌陀像の畫因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸の樹下に合掌する韋提希夫人あり、婢女一人之に侍立し、樹上に三色の雲かかり、正中上方一線の霞の下に円日あり、下に海中島ある構図である。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "棺の左右には赤衛兵が一人ずつ侍立して居る。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い後輩らしい詩人が侍立して居る。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "正午になったところで、棺側に侍立していた侍僕の一人が、クルーク侍従に、「この辺でやめましょう。",
              "citation": {
                "source": "泡沫の記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "その最も代表的な例を我々は三月堂本尊に侍立せる白く剥落せる二つの塑像（日光月光）や、戒壇院の四天王や、聖林寺十一面観音などに見いだすことができる。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天文博士帝の右に侍立す。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "（メフィストフェレス階段を登りて左に侍立す。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "棺の頭の左右に、赤軍の兵士が一人ずつ儀仗の姿勢で侍立している。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "川勝氏ノ著書ヲ見ルト、上京区千本上立売上ルニ石像寺ノ阿弥陀三尊石佛ト云ウモノガアッテ、中尊ニ定印弥陀坐像、ソノ向ッテ右ニ観音、左ニ勢至ノ二脇侍立像ガ侍立シテイテ、ソレラ三尊ノ写真ガ各別々ニ載ッテイル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳山がはじめて龍潭に参した時、侍立するほどにいつか夜が更けてしまった。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍立の百官は、「首尾よく、凱旋あれよ」　と、万歳を唱えて、それを歓送した。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "督郵は、左右に、随員の吏を侍立させ、さながら自身が帝王のような顔して、高座に構えこんでいた。",
              "citation": {
                "source": "三国志",
                "author": "桃園の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "側には、屹と、呂布が侍立していた。",
              "citation": {
                "source": "三国志",
                "author": "桃園の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "総帥の袁紹も、はなはだ冴えない顔をしていたが、ふと座中の公孫※のうしろに立って、ニヤニヤ笑みをふくんでいる者が眼についたので、「公孫※、貴公のうしろに侍立している人間は誰だ。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで結構です」　と、かたく辞退し、そのまま公孫※のうしろに侍立していた。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、関羽と張飛のふたりは、歩を移して、改めて玄徳の背後に屹と侍立していた。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時は、よけい胆気をすえるに限る」　と、侍立の部下をかえりみて、「酒を持ってこい」と、命じた。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "呂布は、悠々、後から姿をあらわして、彼の側に侍立した。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく、室の外に、楚々たる気はいがして、侍立の女子が、帳をあげた。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "張飛、関羽のふたりは、彼のうしろの壁ぎわに侍立していたが、「つまらない遠慮をするものだ。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "高祖もつねにその徳を称せられ、高祖のおわすところ必ず二者侍立しておりましたとか。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、侍立の諸将のあいだから、一名の将が前へすすんで、「兄顔良に代る次の先鋒は、弟のそれがしに仰せつけ下されたい」と、呶鳴った。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある豪家の老人が死んだ葬式の晩に、ある男は十二分の酒を飲んで帰る途中の田んぼ道で、連れの男の首玉にかじりついて、今夜ぐらい愉快に飲んだ事は近来にないという事をなんべんもなんべんも繰り返しながらよろけ歩いていた。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）わが家へと入りてみれば　　なごやかにうちまじりつつ秋の日の夕陽の丘か炊煙か　　　　われを暈めかすもののあり　　　　　　　　　　　　古き代の富みし館の　　　　　　　　　　カドリール　ゆらゆるスカーツ　　　　　　　　　　カドリール　ゆらゆるスカーツ　　　　　　何時の日か絶えんとはする　カドリール！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
