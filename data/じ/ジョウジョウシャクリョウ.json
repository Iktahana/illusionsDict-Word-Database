    "definitions": [
      {
        "index": 1,
        "gloss": "taking the extenuating circumstances into consideration",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
