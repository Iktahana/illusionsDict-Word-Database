        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "澄していても何となく微笑の俤があるのは、豊かだがういういしい朱の唇が、やや上弦の月に傾いているせいでもあろうか。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲に近く、細い上弦の月が上っている。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜ひとりボートデッキへ上がって見たら上弦の月が赤く天心にかかって砂漠のながめは夢のようであった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一痕上弦の月、天に印し、林下寂として人なし。",
              "citation": {
                "source": "杉田の一夜",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "上弦の月いつしか沒して、星斗闌干たり。",
              "citation": {
                "source": "川越夜行記",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、或る夜、淡い上弦の月が西空に傾いてる頃、その焼跡に、青白い火がどろどろと燃えて、狸石のほとりにぼーっと明るみを投げ、人の姿を浮き出さした。",
              "citation": {
                "source": "狸石",
                "author": "――寓話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷かな夜風がそよ吹いて、上弦の月が西空にかかっていた。",
              "citation": {
                "source": "朝やけ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "上弦の月が中空にかかっているのを後ろにして、スタスタと歩き出すと、「もし百さん」と言って塀の蔭から出たのは、女の姿であります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "梨枝子は薄いスエタアの臂を抱へるやうにすぼめて、黒い森の上にかかつた上弦の月を、物珍らしさうに眺め入つた。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕霜が下りて、上弦の月が心細く沈みかけてゐました。",
              "citation": {
                "source": "井上正夫におくる手紙",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "上弦の月半天に大暈をおび、鑓、杓子おぼろに沈む。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
