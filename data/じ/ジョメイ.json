[
  {
    "uuid": "ef8c5e20-8f13-5ce5-af89-3d3253d23a7c",
    "entry": "助命",
    "reading": {
      "primary": "じょめい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sparing a life",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "古来数知れぬ刑死者の中にもおそらくは万一の助命の急使を夢想してこの激烈な楽しみの一瞬間を味わった人が少なくないであろう。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も眞個に、此世でまた貴女にお目にかゝらうとは思ひ設けませんでした、實に不思議ですよ、一體あの時は如何して御助命になりました。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "三斎公その時死罪を顧みずして帰参候は殊勝なりと仰せられ候て、助命遊ばされ候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "大野治長は千姫を脱出せしめて、秀頼母子の助命を請うたが、その効なく、東軍は秀頼の籠る山里｜曲輪を目がけて砲撃したから、翌五月八日、遂に秀頼淀君と共に自刃し、治長、速水守久、毛利勝永、大蔵卿等之に殉じた。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その心の底には、もし秀頼が助命されるような事があらば、大助をも一度は世に出したいと云う親心が、うごいていたと思う。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ権兵衛殿に死を賜わるとなったら、きっと御助命を願って進ぜよう。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "御助命だけはいかようにも申してみようと言った。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "和尚は殿様に逢って話をするたびに、阿部権兵衛が助命のことを折りがあったら言上しようと思ったが、どうしても折りがない。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "天祐和尚の逗留中に権兵衛のことを沙汰したらきっと助命を請われるに違いない。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄二人はつし王をいたはつたので助命せられ、末の三郎は父と共に虐けたので殺される。",
              "citation": {
                "source": "歴史其儘と歴史離れ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは遠くもない田舎に、甚五郎が隠れているのが知れたので、助命を願いに出たのである。",
              "citation": {
                "source": "佐橋甚五郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "源太夫は家康にこの話をして、何を言うにも年若の甚五郎であるから、上の思召しで助命していただければよし、もしかなわぬ事なら、人手にかけず打ち果たしてお詫びをしたいと言った。",
              "citation": {
                "source": "佐橋甚五郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそちも言うとおり、弱年の者じゃから、何かひとかどの奉公をいたしたら、それをしおに助命いたしてつかわそう」「はっ」と言って源太夫はしばらく畳に顔を押し当てていた。",
              "citation": {
                "source": "佐橋甚五郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "放りし者ことごとくその財物を捧げて助命さる。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『無明羅刹経』に、海渚中の神馬王八万四千の諸毛長く諸動物これに取り着いて助命さる。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "またしばしば熊野の猟師に聞いたは、猴に銃を向けると合掌して助命を乞う事多しと。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "常磐が三子助命のために忍んで夫の仇に身を任せたは美談か知らぬが、寵｜弛んで更に他の男に嫁し、子供多く設けたは愛憎が尽きる（『曾我物語』四の九、『源平盛衰記』一九、『昔語質屋庫』五の一一、『平治物語』牛若奥州｜下向の条）。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同直ちに殺さうと言つたが一人勸めて之を助命し、其代りアイリッシユ人が常に羨やむデーン人特長のヘザー木から美酒を造る秘訣を傳へよと言ふた。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "一使早馬で駈付け王に勸めて、王の眼前で内大臣が女たるを檢出して之を助命したとあるから餘程露骨な檢査をしたらしい。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕われた直人もまた、大西郷たちの心からなる助命運動があったが、皮肉なことにも、山県狂介たちの極刑派に禍いされて、まもなく銃殺台にのぼった。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、かれが出勤している舞台で、わたしの記憶に残っている役々は市村座の「今文覚助命刺繍」で、おたきという唖娘。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、その香木は「白菊」と銘を改め細川家にとって数々の名誉を与えるものとなったのであるが、彌五右衛門は、三斎公に助命された恩義を思って、江戸詰御留守居という義務からやっと自由になった十三年目に、欣然として殉死した。",
              "citation": {
                "source": "鴎外・芥川・菊池の歴史小説",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、いくたびかはげしく咳きいりながら、虫のような声でくりかえしくりかえし歎願し、椋島の助命を頼んだのであった。",
              "citation": {
                "source": "国際殺人団の崩壊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにフランス公使は、土佐の人々が身命を軽んじて公に奉ぜられるには感服したが、何分その惨澹たる状況を目撃するに忍びないから、残る人々の助命の事を日本政府に申し立てると云った。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "次いでフランス人が助命を申し出たので、死を宥められた。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此等の事情を具備し、且つ父母より助命を出願した場合に限つて、特にその不孝者の死罪を免じ、その代りに杖百七を加へ、更に百日の苦役を科するので、誠に情意を兼ねた處分法ではあるまいか。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "成る程うまい口実だ――もし、皆が助命されたとしたなら？",
              "citation": {
                "source": "寺坂吉右衛門の逃亡",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃんと、名の入っている書付が、お上の手にあるんだからな――助命か、切腹か。",
              "citation": {
                "source": "寺坂吉右衛門の逃亡",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、お慈悲による助命。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
