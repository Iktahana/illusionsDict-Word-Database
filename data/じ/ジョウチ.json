[
  {
    "uuid": "40bfc341-02fd-51ab-a9bb-a23f2b5c31aa",
    "entry": "上智",
    "reading": {
      "primary": "じょうち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "supreme wisdom",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "中庸の方は上智英略あらざるものの方策なるを言ふ也。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし夫子も上智と下愚とはうつらずと申して居らるる。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "上智と下愚は移り難いと言った時、孔子は子路のことを考えに入れていなかった。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "身を殺して仁を成すべきことを言いながら、その一方、どこかしら明哲保身を最上智と考える傾向が、時々師の言説の中に感じられる。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "正義は高き主を動かし、神威は、最上智は、最初愛は、われを作る。",
              "citation": {
                "source": "倫敦塔",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "上智の人はしばらく措き、中人以下に至りては必ず先入を主となすの思想を有す、しかれどももし自他の思想を比較し今昔の変遷を考量するときは、あるいはもってようやく己れの誤謬を知るを得べく、あるいはもっていよいよ己れの真正を確かむるを得べし、しからば吾輩のここに『近時政論考』を草する豈に無用の業ならんや。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖道門の修業は正像の時の教えであるが故に上根上智のものでなければ称することは出来ない。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "――格別｜上智のものの申し候には、今般英仏とシナとの戦争長続きはあるまじき由、左候えばイギリス使節はほどなく御当地へ参り申すべく候。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の学ぶ上智大学は、ドイツ人が主だが、カソリックだから、ナチスおよびヒトラーには寧ろ反対である。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の頃からの童話好き人形好き、それから後に上智大学に入つてドイツ語を勉強したのもとりわけドイツの人形が興味をひいたからだつたといふのは因縁が深い。",
              "citation": {
                "source": "オルゴール",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "玩具の国ドイツ、人形の国ドイツ、私は玩具人形を研究したい若い日の夢を追つて、やがてドイツ語を勉強したいために上智大学に入つた。",
              "citation": {
                "source": "オルゴール",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上智と下愚は移らず。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和二十四年（1949）　五十七歳上智大学講堂にて「文芸と宗教」の題下で講演する。",
              "citation": {
                "source": "年譜",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "右近と女の關係を書いてゆくと、上智大學の先生あたりからすぐ横槍が出た。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが上智大学のラウレス教授から痛烈な抗議が来た。",
              "citation": {
                "source": "美しい日本の歴史",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついに私は一日、上智大学へ赴いて、教授の宣教師諸兄へ、「文芸と史実、及び宗教」にわたって、るる一場の咄弁をこころみたが、ついには面倒になって、小説も結びをつけてしまった。",
              "citation": {
                "source": "美しい日本の歴史",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっそく、上智大学のラウレス教授などを初め、多くのクリスチャン読者から抗議が出ました。",
              "citation": {
                "source": "小説のタネ",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とどのつまり僕は一日、上智大学へ行って、「文芸と宗教」という演題をかかげて、あそこの講堂で二時間ばかりしゃべッたりしました。",
              "citation": {
                "source": "小説のタネ",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "迎賓館に通じる大通りを渡り、四谷見附橋を渡り、最後に赤信号を無視してホテルニューオータニに抜ける小さな横断歩道を小走りに渡ると、北門から上智大学に入った。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "四谷見附橋のところで民族衣装をまとったインド人の女性から輪廻転生を解いたヒンズー教布教のためのパンフレットを買ってほしいと言い寄られたが、浩はウォークマンを聞きながらそのせいで聞こえないふりをしてやり過ごし、上智大学の｜Ｈ・Ｈの部室に向かう。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "お夏は可憐で楚々として、充分に美しい娘でしたが、性根もなか／＼に確かりしてをり、その上智慧も逞ましく、近頃は道樂者の金之助も、次第にお夏の良さに引摺られる恰好になつて來ました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "夕立の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番最初にかけて来たのは、赤いリボンの帽子をかぶったかあいいおじょうちゃんでした。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、おじょうちゃんのお母さん、荷物をドッサリ持った書生さん――と、こう三人です。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤とんぼは、かあいいおじょうちゃんの赤いリボンにとまってみたくなりました。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、おじょうちゃんが怒るとこわいな――と、赤とんぼは頭をかたげました。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けど、とうとう、おじょうちゃんが前へ来たとき、赤とんぼは、おじょうちゃんの赤いリボンに飛びうつりました。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤とんぼは、今におじょうちゃんの手が、自分をつかまえに来やしないかと思って、すぐ飛ぶ用意をしました。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、おじょうちゃんは、赤とんぼをつかまえようともせず、「まア、あたしの帽子に！",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かあいいおじょうちゃんは、今まで空家だったその家に住みこみました。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤とんぼは、あのおじょうちゃんだろうと思って、そのまま、声のする方へ飛んで行きました。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
