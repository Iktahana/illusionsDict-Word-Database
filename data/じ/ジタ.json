    "definitions": [
      {
        "index": 1,
        "gloss": "oneself and others",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ゆつくりいつくしめば、いつくしんだだけ人様に対して反動を廻すとかなんとか、さういふ自他のけぢめを掻き毟つたやうな行為は少くなるんだし、自分としてもコクのある気分でゐられるんだ。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなわけで我々の口にする美しいみたいな話は、みんなただ自他の目を誤魔化すために過ぎないのです。",
              "citation": {
                "source": "津輕地方とチエホフ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯るときに於てはじめて芸術は人類に必需で、自他共に恵沢を与えられる仁術となる。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その代りとして、四年兵になるまで残しておかれるだろうとは、自他ともに覚悟をしていた。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもが、さし向かえば、些の尊敬をするわけでもない、自他平等、海藻のつくだ煮の品評に余念もありません。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし甲はまたある場合に臨んで利害を打算せず自他の区別を立てないためにたのもしくあたたかい人間味の持ち主であることもありうるであろう。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自と他とが一つの有機体に結合することによってその結合に可能な最大の効率を上げ、それによって同時に自他二つながらの個性を発揚することでなければならない。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、もし自分が「眼」のたちの人間でそれに相応した業務をもち、それによって成果を得られるならば、「鼻」のたちの人がそれによって得られる成果を羨望しないところに、この人生の良き現実の世界が在り、自他の区別が整然とついた立派な差別相が保てるのです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝も無事じゃ、我等も満足、自他の幸福というものじゃ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "意識的に示す媚態で赧くなったりするのは自他ともに嫌いである。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "我儘をたたきつぶして、自他本然の真実心を発露せずにはいられなくなる。",
              "citation": {
                "source": "鉄鉢と魚籃と",
                "author": "――其中日記から――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一ぴきの雌に対する三びきの雄の候補者であることを自他の意識から完全にカムフラージュしていた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "給仕人はイゴとか男性とかいういかついものは取除かれた品よく晒された老人たちで、いずれはこの道で身を滅した人間であろう、今は人が快楽することによって自分も快楽するという自他移心の術に達してるように見ゆる。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女が二十歳近くも年齢の違う規矩男と歩いていて殆ど年齢の差も感ぜず、また対者にもそれを感ぜしめない範囲の交感状態も、かの女の稚純な白痴性がかの女の自他に与える一種の麻痺状態ではなかろうかと、かの女は酷しく自分を批判してみるのである。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "八、自他ともに恨みかこつ心なし。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂照は「あな、とうと」と云いて端然と食を摂り、自他平等｜利益の讃偈を唱えて、しずかに其処を去った。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何にも自他共に實際は然樣で有らう。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "之を自己一人にて飮み盡せば、醉を得るに足り、他人と共に之を飮めば、自他共に醉を得るに足らずといふ場合に際して、自己一人にて之を飮み盡して、同座又は同寓の人に頒ち與へざるのは、福を專らにするのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして其の爲に自他に取りて何等の幸福をも來さずして、卻つて幾干かの不幸福を自他に貽りて居ることが無いには限らぬと思はずには居られ無かつた。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かく打明けるのが、この際｜自他のためと思ったから、高坂は親しく先ず語って、さて、「姉さん、お前さんは麓の村にでも住んでいる人なんか。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に、地方にゐて何の爲事も無くぶらぶらしてゐながら詩を作つたり歌を作つたりして、各自他人からは兎ても想像もつかぬ樣な自矜を持つてゐる、そして煮え切らぬ謎の樣な手紙を書く人達の事を考へると、大きな穴を掘つて、一緒に埋めて了つたら、何んなに此の世の中が薩張するだらうとまで思ふ事がある樣になつた。",
              "citation": {
                "source": "硝子窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　何をか試むる、と怪んで、身を起し汀に立つて、枯蘆の茎越に、濠の面を瞻めた雪枝は、浮脂の上に、明かに自他の優劣の刻み着けられたのを悟得て、思はず……『はつ、』と歎息した。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは、自宅の敷居を跨いでから今が今まで出来ることなら破綻も小さい範囲にとどめ、自他共になるべく手負い人を出さないことにして先へ生活を流して行き度いと心がけていたのですけれど、さすが半月あまり吹き曝されて来た山河の広い風は、わたくしの心の戸障子を吹き外ずさしたものと見えます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ、歿き父のかずけたいのち、歿き母のかずけたいのち、うつし身のまゝ霞を距てゝ負担を負わされている感じの安宅先生や池上、葛岡の不如意のいのちも、この心田に入る場合には自他を無みし不如意も如意もございません。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "がかつて右翼陣営の言論人として自他共に許し、さかんに御用論説の筆を取っていた新聞の論説委員がにわかに自由主義の看板をかついで、恥としない現象も、不愉快であった。",
              "citation": {
                "source": "終戦前後",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が謡曲を始めてから今日までこれ位に感動を他人に与えた事はないので、全く自他の本懐といい祖母への孝養といい申し分のない大成功であった。",
              "citation": {
                "source": "謡曲黒白談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自他の流儀の玄人、素人に笑われてもよい。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、彼を脅かす東国の諸豪相次いで世を去つたので、彼の天下一統は必ず近きにあり、と自他共に信じてゐたが、測らずも、十七年間重用し来つた家臣光秀のために、京都本能寺に於て、弑せられた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も記者が簡単に云へるものと考へてゐるとは思はないけれど、それを一般世間が可なりオーム返しに信じたりする風景は、なさけなく思はれるのである。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "車が芝南寺の少し手前まで来ると、助手台に乗つてゐた谷丹三の親友が、急に停車を命じた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
