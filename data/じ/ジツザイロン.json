    "definitions": [
      {
        "index": 1,
        "gloss": "realism (as opposed to idealism)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
