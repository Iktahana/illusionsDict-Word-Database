          "literary": [
            {
              "text": "人生意気に感ずとか何とか云う。",
              "citation": {
                "source": "入社の辞",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬へば人生意気に感ずといふやうな、おめでたい、子供らしい、頗る sentimental なわけで書く。",
              "citation": {
                "source": "追儺",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "編輯者　人生意気に感ずと云ふぢやありませんか？",
              "citation": {
                "source": "売文問答",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そのためにこそ僕は、その様な劇作家の「人生意気に感ず」式の、吹けば飛ぶような軽薄な感傷（それ自体としては概して善意に基くものである事を僕が知っていても）を心から憎む。",
              "citation": {
                "source": "俳優への手紙",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
