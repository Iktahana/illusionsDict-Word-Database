[
  {
    "uuid": "0b29f6f4-a5ff-5081-8dd4-ebe6fd436d09",
    "entry": "十回",
    "reading": {
      "primary": "じっかい",
      "alternatives": [
        "じゅっかい"
      ],
      "is_heteronym": false
    },
    "grammar": {
