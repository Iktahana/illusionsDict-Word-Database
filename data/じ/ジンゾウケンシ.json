        "examples": {
          "standard": [
            {
              "text": "人造絹糸は、その光沢と滑らかな肌触りから広く普及した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このブラウスは、軽くてシワになりにくい人造絹糸でできている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔は人造絹糸が貴重品として扱われていた時代もあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "人絹だと最初は、軽蔑せられた人造絹糸も、今日は天然絹糸と肩を並べて工業界に進出し、天然絹糸と人造絹糸とは、製品としての分野がはっきりわかれ、お互に持ちつもたれつの発展をつづけている。",
              "citation": {
                "source": "人造物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまのモスクワで、身許のはっきりした田舎出の女中は、人造絹糸でない絹ものと同じくらい珍しいじゃあないか。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人造絹糸が発明された。",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の話の中に、近く某氏が満洲に於てアカシヤの木から良質の人造絹糸を造る発見をした。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            }
          ]
        }
