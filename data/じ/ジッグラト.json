        "examples": {
          "standard": [
            {
              "text": "古代メソポタミアのジッグラトは、神殿として使われていたと考えられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "砂漠の地平線にそびえ立つジッグラトの姿は、異様な迫力があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "考古学者は、ジッグラトの発掘調査から、当時の人々の信仰を知ろうとしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "かつて古代バビロンの奇怪な塔ないしジッグラトの外側を登っていた通路を塔の内側に持ってきたようなものだ。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
