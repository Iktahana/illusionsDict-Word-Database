[
  {
    "uuid": "db041118-9339-58b8-acde-637fbf49927f",
    "entry": "侍する",
    "reading": {
      "primary": "じする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-特殊",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to wait upon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "洪武二十八年、初めて諸王の封国に就く時、道衍｜躬ずから薦めて燕王の傅とならんとし、謂って曰く、大王臣をして侍するを得せしめたまわば、一白帽を奉りて大王がために戴かしめんと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "余ははじめて病牀に侍するエリスを見て、その変わりたる姿に驚きぬ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日われは獨り姫の病牀に侍することを得て、わが久しく言はんと欲するところを言ふことを得たり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "當時は戰爭で人氣が湧き立つて居る上に、自分等が軍人の家族ではあるしそれに兎に角僕が軍醫であつたりしたものだから、自然普通の人に侍するとは感情が違つて居たかも知れぬ。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は始めて病牀に侍するエリスを見て、その變りたる姿に驚きぬ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は始めて病牀に侍するエリスを見て、其變りたる姿に驚きぬ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、いつの世かこの町のこの家に、時の王に仕侍する主馬頭が住んでいたことがあった。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俊寛」と「歌わぬ人」と「病む青年と侍する女」とを集めてあるのですが、私はもっとたくさん書いてから集めて出したかったのですが、書店のほうの都合と私の生計のほうの便宜とで、貧弱な書物になって何だか気恥ずかしく思っています。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "表医者の名を以て信順の側に侍することになったのである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時保と脩とは再び東京にあって母の膝下に侍することを得たが、独り矢島｜優のみは母の到著するを待つことが出来ずに北海道へ旅立った。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は始めて、病牀に侍するエリスを見て、その変りたる姿に驚きぬ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼京都産の女中二人と共に剃髪して黒田家に留まり、瑤津院の木位に侍することとなつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "不純な者が少しでも混じっていては他の者の迷惑になりますよ」　と御忠告になり、全部の中から十幾人だけが尼姿で侍することになった。",
              "citation": {
                "source": "源氏物語",
                "author": "鈴虫",
                "note": "青空文庫"
              }
            },
            {
              "text": "院はごりっぱな御｜風采で、あの方の後宮に侍することができれば女として幸福至極だろうとは思いますが、盛りの過ぎた方だと今の御位置からは思われますからね。",
              "citation": {
                "source": "源氏物語",
                "author": "竹河",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一月二十三日）　　　　　俗漢　バルザツクのペエル・ラシエエズの墓地に葬らるるや、棺側に侍するものに内相バロツシユあり。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "此等の宦官は何れも君側に侍するので、時に政治上に相當の權勢を振うたことも稀有でない。",
              "citation": {
                "source": "支那の宦官",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "妓某は常に高尾氏の家の宴席にも侍する女であるらしい。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "我國の古俗にては人事を汚穢とするが故に、神祇に奉侍する婦人は大概人に嫁せざるを常とす。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "因て案ずるに、卑彌呼が年長じても夫壻なきは、神祇に奉侍する自己の地位の然らしむる所にして、他の故ありしにあらず。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく耐うる人は強き人　ドイツの先帝フリードリヒ陛下が不治の病気に罹りて数日間病床に呻吟し、しかもその病気は苦痛の最もはげしいものであったので、かたわらに侍するもののみならず、国民全体がふかき同情をよせ、一日も早くご平癒あらんことを祈った。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "古代には、其人たちの侍する内廷の控へ所であつたのだらう。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "或いは殿に侍する人、これをトネリ（舎人）と云い、村主と書いてスグリと云う。",
              "citation": {
                "source": "「ケット」と「マット」",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "不動明王の左右に侍する可愛らしい矜迦羅・制※迦の二童子、その他八大童子の類、すなわち所謂護法童子である。",
              "citation": {
                "source": "憑き物系統に関する民族的研究",
                "author": "その一例として飛騨の牛蒡種",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧侶名宛ての文書に、何々御房とか、何某御房御中などとあるのは、今の手紙に侍者とか、侍者御中とか書くのと同じことで、寺の一室におって住持たる高僧の左右に侍する低い地位の僧侶を指したものである。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は子供の時から彼らの席に侍するのを心苦しく感じていた。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに孔子に侍するものの顔ぶれは（一）と（三）とが類似し、ただ（三）において曾皙が加わっているだけである。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神の信仰に入りさえすれば、いかなる堕落漢たりとも、立所にその罪を許されて天国に入り、神の御前に奉侍することができると。",
              "citation": {
                "source": "霊訓",
                "author": "SPIRIT TEACHINGS",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時直ぐにクロニオーン天妃ヘーレーの胸の中、　5瞋恚を起すつらき言紆餘曲折に宣んし曰ふ、2　ヂュウスとヘーレーとの女、宴席に侍するもの。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "修道院長の昼餐の始まるまでにと思って（もちろん、ただ食卓に侍するために）修道院をさして庵室の囲いの外へ出た時、急に心臓を激しく締めつけられるように覚えて、彼はその場に立ちすくんでしまった。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは常にわたしが行くところにしたがい、いたるところでわたしに侍する。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
