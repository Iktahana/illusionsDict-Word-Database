    "definitions": [
      {
        "index": 1,
        "gloss": "a heavy bomber",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
