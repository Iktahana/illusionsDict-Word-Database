[
  {
    "uuid": "aa657bfb-22b9-551a-9499-bc3944a45b16",
    "entry": "自刃",
    "reading": {
      "primary": "じじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "suicide by the sword",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして、戦敗れ、自刃する際に臨んで「七度この世に生れて君恩に報いん」とさえ誓っております。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その「どいまつ」は後に七人程人を殺して、某という老人の介錯で自刃したとのことであった。",
              "citation": {
                "source": "不動像の行方",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "安政元年に竜池父子の贔屓にした八代目団十郎が自刃した。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "また八代目が自刃した後、権十郎の実父七代目団十郎の寿海老人が江戸に還っていたので、香以はこれをも贔屓にした。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "島子の一戦に寺沢勢を敗走せしめ、本戸まで追撃して、ついに大将藤兵衛を、乱軍の中に自刃せしめた。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤右衛門は、本戸の役に自刃した藤兵衛の子であるから仇討ちをしたわけになる。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "大野治長は千姫を脱出せしめて、秀頼母子の助命を請うたが、その効なく、東軍は秀頼の籠る山里｜曲輪を目がけて砲撃したから、翌五月八日、遂に秀頼淀君と共に自刃し、治長、速水守久、毛利勝永、大蔵卿等之に殉じた。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一子大助は、城中において、秀頼公の最期間近く自刃して果て、父の言葉に従った。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし悟れなければ自刃する。",
              "citation": {
                "source": "夢十夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしんば、腹切るすべも、自刃するすべも知らないための入水にしたところで、大小差したまま投身するというのは、いかにも筋が通らないのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の娘の女としての行末もやはり自分のように他人の意志によってあちらへ動かされ、こちらへ動かされするはかないものであって見れば、後に生き永らえさせることも哀れと思うからというはっきりした遺書をのこして、娘たちをわが手にかけて自刃したのであった。",
              "citation": {
                "source": "新しい船出",
                "author": "――女らしさの昨日、今日、明日――",
                "note": "青空文庫"
              }
            },
            {
              "text": "人民もしこの趣意を忘れて、政府の処置につきわが意に叶わずとて恣に議論を起こし、あるいは条約を破らんとし、あるいは師を起こさんとし、はなはだしきは一騎先駆け、自刃を携えて飛び出すなどの挙動に及ぶことあらば、国の政は一日も保つべからず。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "男が一度｜跳飛ばされながら、瀕死の女を抱いて、決して一人では死なせないという事を耳に口をよせて繰返しきかせて後自刃したのは、彼れの品性の高く情操のいかに清らかで、純な情熱の所有者であったかという事を一般に認めさせ非常に同情を集めた。",
              "citation": {
                "source": "芳川鎌子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "某伯爵の夫人、疾を得て某病院の外科室にあり、一醫學士の手術を經、半途に手術者の手を拉して遽かに自刃し、手術者も亦同日に自刃す。",
              "citation": {
                "source": "泉鏡花作『外科室』",
                "author": "八面樓（宮崎湖処子）",
                "note": "青空文庫"
              }
            },
            {
              "text": "遺書には敵の消息と自刃の仔細とが認めてあった。",
              "citation": {
                "source": "或敵打の話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "弓既に折れ箭既に尽く、英風一世を掩へる源三位も遂に其一族と共に自刃して亡び、高倉宮亦南都に走らむとして途に流矢に中りて薨じ給ひぬ。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れ共従兵既に悉く死し僅に慓悍、不敵の四郎兼平一騎を残す、兼平彼を見て愁然として云つて曰「心静に御生害候へ、兼平防矢仕りてやがて御供申すべし」と、是に於て、彼は、単騎鞭声粛々、馬首粟津の松原を指し、従容として自刃の地を求めたり。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由を唱道してポムペイウスに與せしがポムペイウス、カエサルに敗らるゝに及びウティカに退き自刃して死すカトーは自由の保護者として淨火の島の島守となり、罪の覊絆を脱却して靈の自由を求むる魂等を勵ますなり、ダンテは他の著作に於ても屡※カトーを激賞せり（『デ・モナルキア』二、五・一三二以下。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "イスラエル王サウル、ペリシテ人と戰ひて利あらず、ギルボア山上に（パレスチナにあり）自刃して死す（サムエル前、三一・一以下）【雨露】サウルの死を悼めるダヴィデの哀歌に曰く。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "尼子勝久は自刃した。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "武田勝頼が天目山に自刃のとき、秀吉は中国征伐の陣中でこの報告をきいたが、思はず長大息、あたら良将を殺したものよ、甲斐信濃二ヶ国を与へて北方探題、長く犬馬の労をつくさせるものを、と嘆いた。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏切りを憎むは兵家の常道で、落城、城を枕に、といふ時には、押込みの裏切者をひきだして首をはね、それから城に火をかけて自刃する。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "此四ヶ月の間には、明治天皇の崩御、乃木翁の自刃、など強い印象を人に与うる事実が相ついだ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正元年　九月十三日）乃木大将夫妻自刃　九月十五日、御大葬の記事を見るべく新聞を披くと、忽初号活字が眼を射た。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "義経の自刃の場所である。",
              "citation": {
                "source": "平泉紀行",
                "author": "──専攻科第一類歴史部──",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、水戸側で三人は闘死し、一人は縛に就き、三人は品川で自刃したという。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは幕府の手で秘密に葬られようとしたが、六人のほかに長州屋敷へ飛び込んで自刃した壮士の懐から出て来たもので明らかにされ、それからそれへと伝えられるようになった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は最後の二十一日まで踏みとどまろうとしたが、その時は山崎に退いた長州兵も散乱し、久坂、寺島、入江らの有力な同僚も皆戦死したあとで、天王山に走って、そこで自刃した。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
