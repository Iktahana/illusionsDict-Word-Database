[
  {
    "uuid": "261be1bf-88f5-532b-ac44-a6b6c2b22bba",
    "entry": "自適",
    "reading": {
      "primary": "じてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
