[
  {
    "uuid": "2a58b9d4-5e41-5a16-a02f-26deeb530508",
    "entry": "自他共に",
    "reading": {
      "primary": "じたともに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
