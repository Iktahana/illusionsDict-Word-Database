    "definitions": [
      {
        "index": 1,
        "gloss": "ego",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あまりに自我の強い芸術は、無意識、つまり法悦的境地を欠くから、感覚の性質が如何によくとも、人をジツクリと楽ませることが出来ない。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術とは、自我を愛することの、誠実であることの、褒賞である！",
              "citation": {
                "source": "詩論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "“〔L'art, mes enfents, d'e^tre en soi-meme!〕”（生きるとは、自我を愛することである！",
              "citation": {
                "source": "詩論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが三造は家でも外でも、自我に就いては一言もせぬ。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さしづめ、彼は教養ある「姉さん」なのだが、しかしそれにしては、ほんの少しながら物質観味の混つた、自我がのぞくのが邪魔になる。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、自我崇拝主義者（となつた）であつた。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる時自我崇拝主義は微笑んだ――。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボオドレヱルは「自我崇拝閣下」と綽名された。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らばボオドレヱルは――ボオドレヱルのは、彼が彼自身の部屋に於ける、天才的狂爛の、それが対他するに際して、即ち狂爛が諦念の形式にまで置換されるに際して、その瞬間線上に於ける「自我崇拝閣下」であつたのだと、君が若しボオドレヱルを好きなら考へなければなるまい。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（とまれ一切物中に於ける、各自我のスペクトルの乱雑が、近時世界の芸術に萎凋を来してゐる。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、み空はたかく、吹く風はこまやかに　　――祈るよりほか、わたくしに、すべはなかつた……寒い夜の自我像きらびやかでもないけれどこの一本の手綱をはなさずこの陰暗の地域を過ぎる！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一にはημωνの尖端的強調による民族的自我の自覚である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二にはψυχηと「意気」との間に原本的関係が存することに基づいて、自我の理想性が自己認識をすることである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間が感情の困難に遭遇するときつねに頭角をあらわすものは思考力をなくした真の自我なのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "自我が現実に当面したとき自らを失って生命の価値をなくするのは当然なことであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「根本的に云へば、革命なんかを幾度繰り返してみたつて、少數の革命者が自我の滿足をかひ得るだけで、人間全體は決してより善くも、より幸福にもなり得ないと僕は思ふね。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋人の詩にも漢詩にも、そうした傾向のものがいくらかはあるかもしれないが、浅学な私の知る範囲内では、外国の詩には自我と外界との対立がいつもあまりに明白に立っており、そこから理屈が生まれたり教訓が組み立てられたりする。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂、自我に目ざめたブルジョアジーの世界観から来ている。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由はわがままや自我の押し売りとはちがう。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術の尊厳、自我への忠誠、そのような言葉の苛烈が、少しずつ、少しずつ思い出されて、これは一体、どうしたことか。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その場合に、もし研究者の自我がその心眼の明を曇らせるようなことがあると、とんでもない失敗をする恐れがある。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなる赤誠があっても、それがその人一人の自我に立脚したものであって、そうしてその赤誠を固執し強調するにのみ急であって、環境の趨勢や民心の流露を無視したのでは、到底その機関の円滑な運転は望まれないらしい。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもはなはだふに落ちない不都合な話だと思ったのであったが、しかし翻ってこれを善意に解釈してみると、やはり役人たちがめいめい思い思いの赤誠の自我を無理押しし合ったのでは役所という有機的な機関が円滑に運転しないから困るという意味であるらしい。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風雅は自我を去ることによって得らるる心の自由であり、万象の正しい認識であるということから、和歌で理想とした典雅幽玄、俳諧の魂とされたさびしおりというものがおのずから生まれて来るのである。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "格別細い感じがした。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨、魂はにがい深淵だぞといふやうなことを我々日本人が云ふと、一寸そぐはない感じがしよう。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし「偶然うまく行つた」といふ感じがするのです。",
              "citation": {
                "source": "書信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "数にすれば少しでも、文学に無関係な文士なぞといふものが在るのは何れにしろ奇現象であるから、事実上は決して少い感じがするどころではない。",
              "citation": {
                "source": "非文学的文士",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポマードは生え際ばかりに厚く塗つたくつてあつて、その太い首が動くたびに山猫か何かの感じがした。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻翼の所はおしろいが剥落ちてゐて、一寸突いたらビリビリと破けさうな感じがする。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
