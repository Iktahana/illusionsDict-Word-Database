    },
    "definitions": [
      {
        "index": 1,
        "gloss": "raising the ridgepole",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
