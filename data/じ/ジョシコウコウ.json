        "examples": {
          "standard": [
            {
              "text": "彼女は、歴史と伝統のある女子高等学校に通っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "女子高等学校の文化祭は、毎年盛大に開催される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「私たちの女子高等学校は、校則がとても厳しかったのよ」と、先輩が懐かしそうに話した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "三十七年一月二十三、四の両日、教育テレビの料理ロケのために、家内や親類の女子高校生を連れて、富士の山中湖へワカサギを釣りに出かけた。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "マリには、どこかひどく分別くさい勝気な女子高校生みたいな面もあって、在学中に保井と結婚したのも不似合いなことではなかった。",
              "citation": {
                "source": "演技の果て",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただその人の抱いている夢を妹に語ったのが、その妹の夢となり、夢は大きく波紋を描いてこの女子高校の全級にひろがり被っていただけのことであった。",
              "citation": {
                "source": "愉快な教室",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
