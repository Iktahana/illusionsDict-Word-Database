[
  {
    "uuid": "9b8aec85-6ca3-5bc8-a5ee-9cdf3a815fe3",
    "entry": "人跡",
    "reading": {
      "primary": "じんせき",
      "alternatives": [
        "ひとあと"
      ],
      "is_heteronym": false
    },
    "grammar": {
