    "definitions": [
      {
        "index": 1,
        "gloss": "Jōdo Shinshū (offshoot of the Jōdo sect)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
