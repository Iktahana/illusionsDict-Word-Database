    "definitions": [
      {
        "index": 1,
        "gloss": "(slowly and) carefully",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私の体は夜具の底にかたく丸まり、じっくりと汗になって居ました。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、老先生にはこの両方の極端のところだけあって、中辺のじっくりした考えが生れ付き抜けていなさる。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、それはほかの土地よりも高かったのだと言えば、余りに身びいきになりすぎるかも知れないが、すくなくとも私は大阪は香りの高い、じっくりと味うべき珈琲だった筈だと、信じている。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大臣はメガネを動かして、何もないはた織り機をじっくり見ました。",
              "citation": {
                "source": "はだかの王さま",
                "author": "THE EMPEROR'S NEW SUIT",
                "note": "青空文庫"
              }
            },
            {
              "text": "卓子も長椅子もじっくりと湿っていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっくりと枕木も小砂利も濡れて、右も左も椴松の林が遠い、遠い、遠い。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがシャーロック・ホームズは、心のなかにわだかまる問題があると、何日も、いや何週間も休みなく、そいつをひっくり返しては事実を再び並び替え、隅から隅までじっくり眺め回して、そいつを見極めるか、検討材料が不十分だとわかるかするまで起き続ける、そんな人間だった。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある午後のこと、ジョン・フェリアは椅子に腰掛け、この悩みについてじっくり考えてみた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがじっくり考えて決心したのだ、これくらい失ってもいい。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "』って、それから、その男は一歩後ずさり、首を傾げて、こっちが恥ずかしくなるほど髪をじっくり見るのです。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "書いたものをじっくり吟味すれば、自分はなぜそう感じるのか、そう考えるのか、突き放して調べられることを体験していきます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めての本を出すにあたって、私は抜きがたい影響を自分に与えた体験とじっくり向き合いたいと考えました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "商売の理屈と折り合いをつける覚悟も決めて、じっくりと原稿を練り、しっかりした本を作るのか。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "書き手の知名度や人気を背景にして、大量に売れるものが書店の目に付く場所を占領する一方で、じっくりと売れていった優れた本が品切れのまま放置される。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっくりと話し合い、理解し合う機会を祖母とは持てませんでしたが、残された『蜉蝣』を通じて、今も私は、祖母の言葉に耳を傾けることができます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じっくり読むときは紙」という暗黙の了解が、作る側使う側の双方にあって、画面で快適に読む工夫は、これまでほとんど試みられてきませんでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその時は、代わりに載った原稿をじっくり読んでみて、妙に納得してしまいました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "小型機にとどまらず、特別の部屋を用意してミニコンピューターや大型機までコレクションしている人の奥さんは、どんな気持ちで亭主の道楽を受けとめているのか、一度じっくり聞いてみたいような気になりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっくりと練り上げた電子本を作るのもいい。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度そこのところを、Ｄ博士にじっくりと聞いてみよう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがじっくり読んでいく際は、読む側が早めにキーを押すように調節してしまうこともあって、一〇〇でもストレスを感じなかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただＯＳ／２からＷｉｎｄｏｗｓへの転換に一体どんな理があるのか、マイクロソフトにも今度じっくり聞いてみたい。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、その話を聞き外していた間は、何をしていたかとじっくり調べてみると、或いは自分の商売の駆け引きを考えたり、或いは明日の米代の才覚をしていたり、或いは昨日の酒宴に侍した芸妓の振りまいた空世辞を、愚にもつかず悦んだりしていたのである、という事が調べ出せるだろう。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "能くこの一章を理解しようとするならば、この章の最初から最後までを、十度、百度、千度と熟読し、一々の字を知り尽し、句を熟誦し、語意を覚り、言葉の調子に留意して、その上で咀嚼し、じっくりと味わえば、聖教賢訓の全ての趣旨精神は自然と、まさに髣髴として現われ、ハッキリと明らかになる。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでじっくり落着いて競馬を見て、いい穴の一つも取ろうと思えば、先ず午前中ぐらいは馬券は控え目に慎み深く、静かに構えているに越したことはない。",
              "citation": {
                "source": "競馬の一日に就いて",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、仙市さんだがね」　じっくりとことばを向けると、ずばりと予想外なホシをさしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この衣装にゃ、ちっと用があるんだッ」　いいつつ見調べていたようでしたが、と、――果然、その内前すそが五寸四方ほど食いちぎられていることが発見されましたので、なんじょう名人の目のさえないでいらるべき――いとも皮肉にからんだ真綿責めのことばが、じっくりと飛んでいきました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "曲芸三人娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "とすれば、もはや残る希望は伝六の報告を待つ以外になかったので、右門はお組屋敷へ引き下がると、じっくり腰をすえながら、その帰来を待ちわぴました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬局から、通りを挟んで向かいにあるスペンサー氏の靴屋に目を向けて、ラルフ・Ｄ・スペンサーという男をじっくり見た。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うむ」というと早引の忠三、改めてじっくり考えた。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
