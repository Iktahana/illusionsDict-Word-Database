[
  {
    "uuid": "7a807294-9f22-50b8-9c6f-624944817ada",
    "entry": "常温",
    "reading": {
      "primary": "じょうおん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
