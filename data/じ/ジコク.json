    "definitions": [
      {
        "index": 1,
        "gloss": "time",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は今しがた彼の家を出掛ける時に、行かうと決めた友人の所へ、行くのならばぐづぐづしてはをれない時刻だと思ひながら、上り込んだ。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "愉快に友達と話してゐても、或る時或る時刻から、急に何の理由もなく暗くなるといふ風だ。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりは暗くなる時刻が来る少し前あたりから人に会ふやうな機会になつてゐたことが不運みたいなもんで、それ故何もかも神秘なやうなものでもある。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう汽車に行くべき時刻だつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学の放課の鐘の、あの黄ばんだ時刻を憶ひ出すとして、タダ物だと思ひきれるか？",
              "citation": {
                "source": "Me Voila",
                "author": "―― a Cobayashi",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツ生れのＯ夫人がちゃんと時刻をたがえずやって来て一つの鍋のロースを日本の箸ではさんでいた。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時刻にそこから十町も下流の河口を船で通りかかった人が、何かしら水面でぼちゃぼちゃ音がしていると思ってよく見ると、一匹の「えんこう」が、しきりにぐるぐる廻転運動をしているのであった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが最後の集便時刻を過ぎていたので消印が翌日の日附になったものであろう。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかく「四時」「九時」と時刻を克明に書いている所に何となく自分の頭にある子規という人が出ているような気がする。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "罪、誕生の時刻に在り。",
              "citation": {
                "source": "同じ星",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分自身のやりきれなさを、私は自分の誕生の時刻に歸着せしめた事さへあつたのである。",
              "citation": {
                "source": "同じ星",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の思ひ出摘み溜めしれんげの華を　　夕餉に帰る時刻となれば立迷ふ春の暮靄の　　　　土の上に叩きつけいまひとたびは未練で眺め　　さりげなく手を拍きつつ路の上を走りてくれば　　　　（暮れのこる空よ！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "翔びゆく雲の落とす影のやうに、田の面を過ぎる、昔の巨人の姿――夏の日の午過ぎ時刻誰彼の午睡するとき、私は野原を走つて行つた……私は希望を唇に噛みつぶして私はギロギロする目で諦めてゐた……噫、生きてゐた、私は生きてゐた！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう時刻だから、紫の風呂敷を開ける。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時刻には、誰だって眠っていなければならない筈であった。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、その（時刻）は眠る時刻であったが、（時代）は健康を失っていた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　一人前の水夫になりかけていた、水夫見習は、もう夕飯の支度に取りかからねばならない時刻になった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろしゅうございます、暁の祭までにはまだ間の時刻もございます。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくのごとき理想的の場合においても地震の突発する「時刻」を予報する事はかなり困難なるべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京辺と四国の南側の海岸とでは満潮の時刻は一時間くらいしか違わないし、満干の高さもそんなに違いませんが、四国の南側とその北側とでは満潮の時刻は大変に違って、ところによっては六時間も違い一方の満潮の時に他の方は干潮になる事もあります。",
              "citation": {
                "source": "瀬戸内海の潮と潮流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような訳ですから広い灘と灘を連絡する海峡の両側の海面の高さが時刻によって著しく違うようなところも出来ます。",
              "citation": {
                "source": "瀬戸内海の潮と潮流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して東京の夏には地方的季節風が相当強い南東風として発達しているためにそれが海陸風と合成され、もしこれがなければべた凪になるはずの夕方の時刻に涼しい南東がかった風を吹かせるらしい。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁側で新聞が読めるか読めないかというくらいの明るさの時刻が開花時で、開き始めから開き終りまでの時間の長さは五分と十分の間にある。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその時刻にはもうあの恐ろしい前代未聞の火事の渦巻が下町一帯に拡がりつつあった。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜日の開演時刻にこの劇場の前を通って見ると大変な人の群が場前の鋪道を埋めて車道まではみ出している。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分でも何の事だか分らないが、しかしその日のその時刻の私のある感じだけは出ているようだから、ともかくも御目にかけます。",
              "citation": {
                "source": "二科狂想行進曲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この不都合をなくするには陸上の天文台で定めた正確な時刻を無線電信で海上の船に毎朝報じ時計の誤りを正すようにすればよいというので、今度カナダ政府ではこれを実行する事になったそうな。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は食事の時刻になると、いつも極つて僕の所へ訪ねて來た。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あたし、じこくのみです。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「僕もじこくのみだ。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
