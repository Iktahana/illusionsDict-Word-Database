[
  {
    "uuid": "69c5641f-dbe3-5145-9d0c-a776b654fef0",
    "entry": "什宝",
    "reading": {
      "primary": "じゅうほう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
