    "definitions": [
      {
        "index": 1,
        "gloss": "female-led army",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私たちの自動車は、思わぬこの娘子軍の出現にいきなり前方を塞かれて、たじたじとなるとガソリンの爆音のみ、いたずらに我が天心へ反響さして、さて停ると、ますます燥いで、浮かれて、ひっかかえたペコペコ三味線の連れ弾きと来た。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "サッと、娘子軍途を開く。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの娘子軍の一行、浮かれ浮かれて、村はずれを、人の気もない山へ山へと練り出した、そこで遭遇した私たちだったのだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、ありったけの娘子軍は、すでにチャンチャカチャンチャカの鰌すくいに出払ってお留守なのである。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて野人の女が優種の男に幸せられんと望むは常時で、ギリシアの旧伝にアレキサンダー王の軍女人国に近付いた時、その女王三百人の娘子軍を率い急ぎ来って王の胤を孕みたいと切願し、聞き届けられて寵愛十三昼夜にわたった。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方に、海外の殖民地を見て来た人なぞには、よく日本の娘子軍の威力を賞め千切る人がある。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇モダン・ガール　やいゐないか　やいゐたら縞蛇おつかけるぞ縞蛇　やいモダン・ガール　やいゐないか　やいモダン・ガール　やいゐたら縞蛇おつかけるぞ毒消売りの娘子軍　やがて中之条町についた。",
              "citation": {
                "source": "大利根八十里を溯る",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中、越後から来た毒消売りの娘子軍と道連れになつた。",
              "citation": {
                "source": "大利根八十里を溯る",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘子軍は世間ずれはしてゐるが、さすがは女である。",
              "citation": {
                "source": "大利根八十里を溯る",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "「皆なが、先生を呼んでゐる――私達も出掛けるんですよ、私達の娘子軍も……」　お雪は、投網を畳んで登山袋に詰めはぢめた。",
              "citation": {
                "source": "ダニューヴの花嫁",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼子とはいゝ地名だ、そこには船へまで出かける娘子軍がゐるさうな。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「春意一場娘子軍。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一門の子弟は皆、殿上後宮の娘子軍のみ、之を以て波濤の如く迫り来る革命軍に当らむとす、豈朽索を以て六馬を馭するに類する事なきを得むや。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "圭さんと吉公とはまあ仲のいい方で、そして二人はカフェ・ネオンに於ける正しく男子現業員の全部で、そして気の毒にも一階受持ちの女給八人、二階受持ちの女給七人、合計十五人の娘子軍に対し、名実共に頭が上らなかったのである。",
              "citation": {
                "source": "電気看板の神経",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "植民地といへば、特にこの地方の日本人コロニイに一種独特の色彩を添へるものは、いはゆる娘子軍の地方訛りであつて、そこに作者は捨て難い興味を感じたので、友人の協力を得て、故ら「文字で見ると」難解のそしりを免かれぬ「方言」を使はせた。",
              "citation": {
                "source": "「風俗時評」あとがき",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸海軍一致したら、娘子軍百万ありといえども恐るるに足らずだ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃から叔父の生活様式が変化して、授業が終ると早速引上げる習慣の叔父が、弟子を相手にいつまでも無駄話をするやうになり、娘子軍の一隊を引率れて、散歩や映画を見廻ることが連日のことになつてきた。",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論叔父の目的が一人の秋子にあることは誰の眼にも明らかで、娘子軍の話題にもそれが公然のことになると、一大隊の連日の散歩も自然芹沢東洋と伊吹山秋子の二人をとりまくやうな形にもなり、二人の噂は東洋を知る全ての人に伝はるほどになつてゐた。",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は丁度授業の時で、アトリヱには娘子軍が勢揃ひもしてをり、勿論秋子も居合はした。",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "切符売場から、楽屋口から、待合室から、劇場を十重廿重にとりまいて占領した娘子軍は、実にボージャク無人、余人をよせつけない。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の祖国はこの十何年間人の国を占領したり、自分の国を占領されたり、占領ということについて往復多忙をきわめたが、ここの娘子軍のように懐疑心がなくて、ボージャク無人の独裁的占領軍は珍らしい。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十四歳海外に渡航するや五大洲各国の娘子軍と々を退治せり。",
              "citation": {
                "source": "桑中喜語",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、娘子軍も敗けておらない。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで娘子軍と吏員の監視隊は睨み合いの姿になった。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで娘子軍は持久策を取り守護隊は暫時専門的にそのほうに掛ることにきめた。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、男と女というものは妙な融合性があるものと見えて、監視に来た吏員の中には娘子軍に降伏して、サイダーを持って来たり、ミルクキャラメルをご馳走したりする人間が出来た。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、仕舞いには、娘子軍の守衛を敵が引受けているという形になった。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "庁内の娘子軍は事務に一生懸命である。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それで娘子軍の日程が終ったのではなかった。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
