        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "太初の女王か終末の女王？",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思うと、それほどけばけばしく女性尊重を放送しないフランス人が、家庭は全く主婦の女王の傘下に従順に温まって易々諾々である。",
              "citation": {
                "source": "女性崇拝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――アダ、僕はまた、貴女が金羊毛で故国の女王の詩を朗読するルーマニアの士官とゼノアの産児病院あたりへ身を殺しに行くのではないかと気づかったのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾が流行界の女王になったらあなたどうするつもり？",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "プーシキンの短編にもカルタのスペードの女王がまたたきをする話があるが、とにかくわれわれの神経が特殊な状態に緊張されると、こんな錯覚が生じるものと見える。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "清潔に皮膚が張り切っていて、女王のようである。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "市ヶ谷の女学校に徒歩で通っていたのですが、あのころは、私は小さい女王のようで、ぶんに過ぎるほどに仕合せでございました。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この赤いダァリヤは花の女王にならうと思ってゐました。",
              "citation": {
                "source": "まなづるとダァリヤ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰もまだあたしを女王さまだとは云はないんだから。",
              "citation": {
                "source": "まなづるとダァリヤ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "客が無いとき彼等はうつろな瞳のうしろで、おそらくトランプの半身しかない女王のことでも考えているのだろう。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面にくぎり正しい、雪白な霞を召した山の女王のましますばかり。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "家柄に対する尊敬と、人柄に対する憧憬とが此人の上に集つて、小さい村の云はば女王であつた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も村民はこの女王を真中に守護して、お練りをする時のやうにごたごたして居ながらも、此人の前に立ちふさがるやうなぶしつけをしようとするものはなかつた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちど女王にしてくれたら、あしたは死んでもいいんだけど。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女王のテクラが、もう非常な勇気で云いました。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "劇壇の女王は、気色した。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだあちこちに咲きのこっている花もありましたが、花の女王にふさわしいほど美しくはありませんでした。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのむかしには、色あざやかなゴンドラの上でタンバリンの音がひびき、婚約の指輪が輝かしい総督の船ブーチントロから海の女王アドリアへ投げこまれたのです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中の一つだけをとって、女王さまのかんむりにつけても、きっと、りっぱなかざりになるでしょう。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの中には、ミツバチの女王もいる？",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この子は、ほんとうのミツバチの中には女王がいることを、ちゃんと知っていたのです。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女王バチはね、ミツバチが、いちばんたくさんむらがっているところを、とんでいるんだよ。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなの中で、いちばん大きいのが女王バチでね、地面の上にちっともじっとしていないんだよ。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の夜には、女王バチは、よく、町の通りをとびまわって、ほうぼうの家の窓からのぞきこむんだよ。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雪の女王は、ここへはいってくることができる？",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "このひとこそ、雪の女王だったのです。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ずいぶん遠くまできたのよ」と、雪の女王は言いました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」女王は、こう言うと、カイを大きなそりに乗せて、自分のそばにすわらせました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、雪の女王はたずねました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものすごい　こわい　じょおうさまで、　だれかに　はらを　たてると　きまって　そういうんだ。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
