        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "姿のない作品といふやうなものが充満してゐて、身動きも出来ない有様である。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりの空気には、死屍のような臭気が充満して、気圧が刻々に嵩まって行った。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "見れば町の街路に充満して、猫の大集団がうようよと歩いているのだ。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "図画室は既に生徒及び生徒の父兄姉妹で充満になっている。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには豚の脂肪や、キャベツや、焦げたパン、腐敗した漬物の臭いなどが、まざり合って、充満していた。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨が続くと私の部屋には湿気が充満します。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはと思う、右も、左も、前の枝も、何の事はないまるで充満。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴場は、つい最近新築されたものらしく、よごれが無く、純白のタイルが張られて明るく、日光が充満していて、清楚の感じである。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "疾翔大力、微笑して、金色の円光を以て頭に被れるに、その光、遍く一座を照し、諸鳥歓喜充満せり。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "疾翔大力微笑して、金色の円光を以て頭に被れるに、その光｜遍く一座を照し、諸鳥歓喜充満せり。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で前の晩は、諸鳥歓喜充満せりまで、文の如くに講じたが、此の席はその次ぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "疾翔大力、微笑して金色の円光を以て頭に被れるに、諸鳥歓喜充満せり。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "疾翔大力、微笑して、金色の円光を以て頭に被れるに、その光、遍く一座を照し、諸鳥｜歓喜充満せり。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "疾翔大力｜微笑して、金色の円光を以て頭に被れるに、その光｜遍く一座を照し、諸鳥｜歓喜充満せり。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で前の晩は、諸鳥歓喜充満せりまで、文の如くに講じたが、此の席はその次じゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "疾翔大力、微笑して金色の円光を以て頭に被れるに、諸鳥｜歓喜充満せり。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お能気分はむろん充満している。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おやまあ可いお色ですこと」と母は今自分を睨みつけていた眼に媚を浮べて「何処で」「ハッハッ……それは軍事上の秘密に属します」と軍曹酒気を吐いて「お茶を一ぱい頂戴」「今入れているじゃありませんか、性急ない児だ」と母は湯呑に充満注いでやって自分の居ることは、最早忘れたかのよう。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「充満で御座います」とお徳は一言で拒絶した。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず器械の歴史から、その原理構造などを明快に説明した後にいよいよ実験にとりかかった時には異常な緊張が講堂全体に充満していたわけである。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも明けい、とおっしゃりますについて、あの、入口の、たいてい原ほどはござります、板の間が、あなた様、道者衆で充満で、足踏も出来ません処から、框へかけさせ申して、帳場の火鉢を差上げましたような次第で、それから貴女様がお泊りの筈、立花が来たと伝えくれい、という事でござりまして。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "手桶の中に充満になつて、のたくつてるから、それだから、遁げると不可いから蓋をしたんだ。",
              "citation": {
                "source": "夜釣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……影が天井へ懸って、充満の黒坊主が、汗膏を流して撫じょうとする。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女などはびくびくもので一晩じゅうまんじりともしなかった。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "小鳥は、一｜夜じゅうまんじりと眠ることができませんでした。",
              "citation": {
                "source": "小さな金色の翼",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　その晩、浩一は靖国神社のそばの小さなホテルに泊ったが、一と晩じゅうまんじりともせず、泣きあかした。",
              "citation": {
                "source": "女妖",
                "author": "前篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "時計塔の秘密　小林君は、その夜は園田家にとまることになりましたが、一晩じゅうまんじりともせず、考えにふけっていました。",
              "citation": {
                "source": "塔上の奇術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
