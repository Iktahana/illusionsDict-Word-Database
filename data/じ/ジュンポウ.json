[
  {
    "uuid": "0941b721-1c5a-5aff-80d8-3fb02a55dfdf",
    "entry": "旬報",
    "reading": {
      "primary": "じゅんぽう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ten-day report",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "斯んな事は僕達より、旬報さん、あんた方の方がよく御存じです。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十年の目出度き春を迎えるに際しましてキネマ旬報誌に折入って懇願致したい事があります。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "山中貞雄には、旬報さんよ、ダマッて活動写真だけを撮らせて置いて下さい。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和九年六月、キネマ旬報）　　　　　六　バンジャ　映画「バンジャ」を見た。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和七年十一月、キネマ旬報）",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直な話、私のクレール観は以上でおしまいなのであるが、これでやめてしまつたのでは『キネマ旬報』の印刷所がひまで困るだろうから、もう少しルネ・クレールをもてあそんでみるが、それにつけても残念千万なのはルネ・クレールが日本の雑誌を読まないことである。",
              "citation": {
                "source": "ルネ・クレール私見",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『キネマ旬報』昭和十一年六月二十一日号）",
              "citation": {
                "source": "ルネ・クレール私見",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（四月九日）（『キネマ旬報』再建第三号・昭和二十一年六月一日）",
              "citation": {
                "source": "政治に関する随想",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「映画清談」をキネマ旬報七月号に。",
              "citation": {
                "source": "年譜",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キネマ旬報へ三枚書いた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜、友田純一郎楽屋へ金二十円借りに来た、旬報が不安な気がする。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二時頃辞して、キネマ旬報社へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "レニン鈴木・木村千疋男等ゐて、こゝも旬報が廃刊されさうな気運なので活気なし。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "床に入って「キネマ旬報」廃刊号へ四枚書く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙制限といふことが根本の意なのであらう、殆んど映画雑誌等は廃刊を命じられ（内務省）キネマ旬報も映画之友も今や危機に瀕してゐる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "○雑誌その他の刊行物に対する統制は、此の頃になっていよ／＼激しくなり、映画雑誌など例へば「キネマ旬報」「映画之友」等も廃刊を命ぜられ、会議々々で日を送ってゐる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月二十六日（金曜）　十二時すぎに出て、内幸町の旬報へ寄り、スティルの新しいのを五六枚貰って来た。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "旬報の脚本募集一等当選が無いので、僕のストーリーで菊田に書かせたのを当選としたので、百円来た。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三のキネマ旬報一等当選脚本（実は菊田一夫が書いた）の「沙漠のメリーゴーランド」てものが、ひどいものださうで、役者皆大くさり。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "旬報のため「エノケンを評す」五枚書く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "旬報でレーニンが愚弟の演じ方があまり白痴すぎると、評してゐる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "川端康成来訪、旬報へ「近頃の雑感」五枚書いた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひる済んで、中華丼食ひ、旬報の、五日に書いたのを又三枚足して書直す。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "座へ帰ると、友田来てゐて、旬報十五周年号が出来たと見せる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところへ又、旬報へ「或夜の出来事」その他のことを書いたのに、早田が間に合はぬと断って来たといふので、電話をかけたら無礼だったから、うんと怒った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、旬報へ久しぶりで寄る、いろんなスティルを沢山貰って、座へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角気になるから帰って、旬報の批評を出して読んでみると、あった／＼、飯島正が「セヴィラ」の評を書いてる、その頁の上欄に、僕が「エノケンを評す」てのを書いてる、下手に読むと、之がゴッチャになるのだ、それをバカめ錯覚してるらしい、よし、あの無礼、このまゝには捨て置かんぞ！",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月十一日（木曜）　昨夜の柳田貞一の酔態がシャクなので、旬報を持って、出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "キネマ旬報に芦原英了といふ人の「凸凹ロマンス」の評が出た。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、旬報へ電話して、友田純一郎を煩はし、菊田にでも書かさうと、七時にランチルームで逢ふことにした。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
