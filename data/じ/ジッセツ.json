  {
    "uuid": "a0bf65ff-e573-5207-a196-0a6819a4d1b9",
    "entry": "十刹",
    "reading": {
      "primary": "じっせつ",
      "alternatives": [
        "じっさつ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ten important Rinzai temples, second in significance to the Kyoto Gozan",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "其故に洛中洛外の諸社、諸寺、五山｜十刹、公家、門跡の滅亡はかれらが所行なり。",
              "citation": {
                "source": "応仁の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　十刹海　中野江漢君の僕を案内してくれたるものは北海の如き、万寿山の如き、或は又天壇の如き、誰も見物するもののみにあらず。",
              "citation": {
                "source": "北京日記抄",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど最も面白かりしは今日中野君と行って見たる十刹海の遊園なるべし。",
              "citation": {
                "source": "北京日記抄",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "此たびはじめて出來たる足がるは、超過したる惡黨なり、其故に洛中洛外の諸社、諸寺、五山十刹、公家、門跡の滅亡はかれらが所行也。",
              "citation": {
                "source": "應仁の亂に就て",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "錦襴の法衣、雲上の施與は、足利將軍の歴代を通じ、五山十刹の群僧がほこるところだつた。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お経のよみかたが違い、お経が違い、儀式が違い、お寺の構造が違い、衣や袈裟が違う、それだけで禅宗の特色が出るものなら、五山も十刹も、片端しからつぶして、それを皆真宗に代えたらよい。",
              "citation": {
                "source": "僧堂教育論",
                "author": "――禅僧の友人に与う――",
                "note": "青空文庫"
              }
            },
            {
              "text": "十刹の僧ども経を捧げ諷経をなせり。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
