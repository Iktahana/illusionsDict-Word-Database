[
  {
    "uuid": "9bdbc6c5-217c-5350-b91b-90054ec02af0",
    "entry": "実説",
    "reading": {
      "primary": "じっせつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "true story",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「実説正銘にござりまして、へい。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り弟の方が千葉門下の免許取りであったからそれに御免状が下がった……というのが実説らしいのじゃ。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん誰かからそういう説明を聞けばよく分って警戒もしたであろうが、事実説明はなかったとのことである。",
              "citation": {
                "source": "暗号数字",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "話は神話から実説に移る。",
              "citation": {
                "source": "毒と迷信",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう云やア課長の談話に些し思当る事も有るから、或は実説だろうかと思うんだ。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮令それ等は実説にもしろ、人の痛いのなら百年も我慢すると云う昇が、自家の利益を賭物にして他人の為めに周旋しようと云う、まずそれからが呑込めぬ。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた、この杉の森は、享保のころ、芝居でする『恋娘昔八丈』や『梅雨小袖昔八丈』などの白木屋お駒――実説では大岡裁判の白子屋お熊の家のあった場所であり、お熊の家は材木商であったのだから、堀留は、深川｜木場の材木堀のように、材木を溜めておく置場にもなっていたのかもしれない。",
              "citation": {
                "source": "鬼眼鏡と鉄屑ぶとり",
                "author": "続旧聞日本橋・その三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お岩の実説と言ふものが数種伝つてゐて、互に矛盾もあり、此芝居が名高くなつてから、出来た話も多いやうで、一向信じられない。",
              "citation": {
                "source": "涼み芝居と怪談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "団七の方は、古い実説と伝へるものに大和橋の畔で袖乞ひした浮浪児だつたと言ふのをとりあげて書いたらしい。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "段々種を探って見ると詰らぬもので、彼の浄瑠璃で名高いお染久松のごときも、実説では久松が十五、お染が三歳であったというから、何うしても浮気の出来よう道理がござりませぬ。",
              "citation": {
                "source": "闇夜の梅",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三は大形果実説ですなわちウは太い意、メは実すなわちミの転化で大なる実の意を表わしそれがウメの語原だといわるる。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち此説話は真正の歴史的事実説話なりや、或はまた、一個の普通の説話に過ぎざるや。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "め組の喧嘩の実説は文化二年の出来事なのであるが、であるからとて殊更に其水文化年間の品川風景を描く可く苦心したとも考へられない。",
              "citation": {
                "source": "山の手歳事記",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "洒落を生命としていた巷間の戯作は、江戸風のいわゆる通人生活の描写から、悪ふざけが嵩じて遊里の評判、時の政道のそれとない批判まで織りこむようになり、寛政度のお叱りにあって一転し、善玉悪玉の教訓物となったが、やがてそれもあかれて今この実説風の敵討物万能となったのである。",
              "citation": {
                "source": "仇討たれ戯作",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "実にこれらの事はその地にいたって実際を見ない者の想像以外で、話だけ聞いては私共でさえ始めは信じなかったのですが、いろいろの地を経て来て始めてその前に聞いた話の実説であることを確かめた訳です。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "○百樹曰、牧之翁が此草稿にのせたる図を見るに少しくおもふ所有しゆゑ、其実説を詳究せし事左の如し。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると沼津の段は実説かね？",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「此処では実説にして貰わないと都合が悪い。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
