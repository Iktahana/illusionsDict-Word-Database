        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ジャクモンが『一八二八｜至三二年｜印度紀行』一にジャグルナット行の巡礼葉竹の両端に二つ行李附けて担い行李ごとに赤布片を付ける、林中の虎を威すのだとあるが、そんな事で利く事か知らん。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "その猛勢に猟士また虎（ジャグアル）も辟易して木に上りこれを避くる由（フンボルトの『旅行自談』ボーンス文庫本二巻二六九頁、ウッドの『動物画譜』巻一）。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣かされて来たのか顔が涙でグジャグジャに汚れてゐる。",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しめしめ」　鉄瓶のお湯をひとたらし、二たらし、いよいよ羊羹をグジャグジャに溶かせ、そいつをお六の頭のなかへ、めちゃめちゃに塗り込んでいった。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪が湾の中央部より奥へ進行すると、浪そのものがグジャグジャになって、光り物も見えなくなった。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "このまま、バイドクと脳軟化とアルコールでグジャグジャと腐って行くことが残されているだけだ。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "グジャグジャからかわれても相手になるでねえよ。",
              "citation": {
                "source": "鈴が通る",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに進むと自制を失ってエリオット氏のある節のように「ジャグ、ジャグ、ジャグ」や「バム、ブー、ビミ、バムの木」のように全くサキソフォンのようなたわごとになってしまう。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "色と云い、形と云い、切口のグジャグジャになった所と云い、触って見てコツコツ音がするまでは、誰の目にも本物の生腕としか見えなかった。",
              "citation": {
                "source": "妖虫",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
