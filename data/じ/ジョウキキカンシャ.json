    "definitions": [
      {
        "index": 1,
        "gloss": "steam locomotive",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "俺は蒸気機関車のように描きつづけている。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "林のなかの機関車庫から、濃いグリーンに塗られた蒸気機関車が一台、出て来た。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "古風な蒸気機関車だ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "線路の上を、その蒸気機関車は、滑らかに走った。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "湾の近くにある砂糖精製工場に、ダーク・グリーンの蒸気機関車は到着した。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＨＯゲージの電気で走る模型の蒸気機関車は、精製工場の建物のわきにぴたりと停まった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのサーフを愛してきた数多くの人たちの象徴として作ってみた」「なるほど」「しかし、この蒸気機関車はよく出来ている」　かがみこんで模型をしげしげと見ていたクレイトン・カウアが、感心して言った。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女たちがまだ十歳にもならない子供だった頃、島のここには実際に鉄道があり、いまマニュエルが走らせたのとおなじ型の蒸気機関車が、煙を吐いて走っていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "機関車庫の前に停まった蒸気機関車のいたるところに畑仕事の男たちが乗り、なにかの記念写真のようにして撮った写真もあった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ミカド型という蒸気機関車だ」　写真を指さしながら、マニュエルが説明した。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鉄道の最盛期には、ハワイ諸島にいろんなタイプの蒸気機関車が走っていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根を覆っている樹の葉が風に揺れると、蒸気機関車に当たっている陽も、揺れ動いた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たち五人は、それぞれに蒸気機関車を眺めた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夕方、蒸気機関車を見にいったとき、オイル・パンを強くぶつけたから」　海沿いのアイランド・ハイウエイを北に向かってゆっくり走りながら、第57番サーフが消えるにいたるまでのいきさつを、順序立てて僕はジェーンに語った。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔のハワイの鉄道に興味を持っているマニュエルたちのグループは、すでに小さな蒸気機関車を一台、昔のとおりに修復して走らせている。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは砂糖会社の廃屋のような機関車庫に、埃まみれで眠っているミカド型の蒸気機関車に目をつけた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸気機関車による昔の鉄道が復活すれば、観光資源としての可能性が大いに期待出来る。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "発電所の冷却排水管のことから始まって、抵抗運動、電力会社による詐欺的な妥協案とその発覚、コンクリートの人工海底、抵抗運動の分裂、そして昔の蒸気機関車の復活にいたるまでが、面白く画面に展開した。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その模型の光景を走るミカド型蒸気機関車の模型が、近接撮影でとらえられていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂糖会社の機関車庫に眠っている埃だらけのミカドがスクリーンに映り、そこからその蒸気機関車の復活の話になった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸気機関車のレストアがほぼ完成し、罐のなかに蒸気を作れば動き出すという段階まで来たところで、ジェニファーの映画は終わっていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あとは蒸気機関車が走るところを撮ればいいだけだな」「そうなの」「どんなふうに撮るつもりだい」「早朝の明るい光のなかで、機関車庫に向かって、線路の上をドリー・インしていくの。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「夕陽を西に見ながら北へ走っていく蒸気機関車を美しくとらえてから、第57番サーフに出来たコンクリートの桶を、やはり夕陽をバックにシルエットでとらえ、望遠レンズで引っぱった大きな太陽が水平線に沈みきると、クレディットが水平線に向かってフレームの上から下がって来て、水平線で消えるの。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "三輛だけすでに復元された客車を牽引して、一九二八年製の蒸気機関車が全線公開試運転をおこなうのは、今日から一週間後だ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "林の向こうに消えているレールから視線をはずしたその瞬間、彼女のその視線に引き出されるようにして、蒸気機関車が一台、林から出て来た。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙突から灰色の煙を噴きあげ、蒸気機関車は林の向こうから、姿をあらわした。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔のままに作りなおした三輛の客車を引っぱり、蒸気機関車は土手の線路を軽快に走った。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の蒸気機関車が、古風な客車を三輛、引っぱって走っている。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔どおりによみがえった砂糖会社の鉄道が、全線公開試運転をおこなったその日、病院の窓から蒸気機関車を見た記憶喪失の老女が突然、記憶をとり戻した。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして土手にレールが敷かれていくのを見守り、林の向こうから昔の蒸気機関車が走り出して来るのを、目撃した。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
