[
  {
    "uuid": "7a0311a0-689b-5296-ad88-72c9ed12c0be",
    "entry": "陣中",
    "reading": {
      "primary": "じんちゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
