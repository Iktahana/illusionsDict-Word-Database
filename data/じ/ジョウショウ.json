[
  {
    "uuid": "8edd57cd-d920-5cc5-b054-8e8e408305dc",
    "entry": "上昇",
    "reading": {
      "primary": "じょうしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
