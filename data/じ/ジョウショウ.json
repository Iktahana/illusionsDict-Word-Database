      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rising",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これはつまり比較的暖かい地上近くの空気が温気を含んだままで気流につれて上昇し、高層の気圧の低い処へ行くに従って膨脹して冷えて来る、ある処まで行くと雲と凝り雨になってしまう事もあるが、ごく寒い時にはこれが直ちに凍って小さい雪片となりこれが次第次第に大きく生長する。",
              "citation": {
                "source": "雪の話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして更に面白いことには、良い論文を落第させればさせるほど、あたかもその審査員並びにその属する学団の品位が上昇するかのごとき感じを局外者に与えるらしく思い込まれる場合もあるようである。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上昇気流のために生ずる積雲が、下降気流その他の原因で消滅した跡には、これらの凝縮核の集合した層が取り残される。",
              "citation": {
                "source": "塵埃と光",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふのは、星は、閉ぢた眼瞼から拔け出して、上昇し、明るくなつて、空にぢつとしてゐる、人間の眼なのだからである。",
              "citation": {
                "source": "夢",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三の星は直接に上昇して、天使の窮みない意識のなかへ消え失せます。",
              "citation": {
                "source": "ドゥイノ悲歌",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑色のカーテンが上昇した。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民党上海駐屯の武官、フ・ハン・パウはノラと恋愛の上昇のために自殺して死んでしまった。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "エンゼルフィッシの子が数尾同じ槽にいるのを見ていると、一尾が徐々に上昇し始めるとほとんど同時に他の仲間も上昇を始める。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして頂上の峠の海抜九百五十メートルまで、実に四百五十メートルの高さをわずかの時間の間に客車の腰掛に腰かけたままで上昇する。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつたがなんべんとなく茂兵衛を呼び止めるのがいったいならくどくしつこく感ぜられるはずであるが、ここでは呼び止める一度一度に心理的の展開があって情緒の段階的な上昇があるから繰り返しがかえって生きてくるのである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上昇速度は目測の結果からあとで推算したところでは毎秒五六十メートル、すなわち台風で観測される最大速度と同程度のものであったらしい。",
              "citation": {
                "source": "小爆発二件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高く上がるにつれて頂上の部分のコーリフラワー形の粒立った凹凸が減じて行くのは、上昇速度の減少につれて擾乱渦動の衰えることを示すと思われた。",
              "citation": {
                "source": "小爆発二件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に美濃近江の国境の連山は、地形の影響で、上昇気流を助長し、雪雲の生成を助長するのであろう。",
              "citation": {
                "source": "伊吹山の句について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思うと大鷲のごとく両翼を拡げた飛行船は徐々に上昇し初める。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行船は始めその両翼を静かに動かしながら徐々に上昇しつつあったが、次第にその速力を早めて来た、秋山男爵は東の方へ、雲井文彦は西の方へと針路を取って進んで行く。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二人は急ぎ外に出て、飛行船に乗るや否や全速力を以て上昇した。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "同様にして、芸術が上昇せんが為には、矢張り或る抵抗のお蔭に頼ることが出来なければなりません。",
              "citation": {
                "source": "鬱屈禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "傾むく地平線、上昇する地平線、落ちくる地平線。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "傾むく地平線、上昇する地平線。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "理智主義と云われる程、上昇しても居ません。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "換言すれば又太陽の温熱が加はつたり、空氣の※度が異なつて來たりする爲に、末端が刺激されて、そして其の爲に水氣等のものが、促進されて上昇する、とも云ひ得ることを示して居る。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "純氣未だ毀れざるものは、晝間は極少々ばかり極めて適度に血が上昇して居る。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "天地和熙の時、晝は地氣の上昇し、夜は天氣の下降すると同じに、健全純氣の童子は、晝は氣が上り、夜は氣が下り、晝は陽動し、夜は陰靜し、そして平穩に靈妙に、腦力も發達し、體力も生長するのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "日出頃よりして地氣は上昇する。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "風が吹くたびに、空気は揺れて、チューリップの紅と鬱金とのよじれた色が、閃きうねり宙に上昇するように見えた。",
              "citation": {
                "source": "唇草",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝子の厚みのために緑色に見える気泡の上昇する行列。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
