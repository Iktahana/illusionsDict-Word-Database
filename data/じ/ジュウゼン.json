    "definitions": [
      {
        "index": 1,
        "gloss": "the ten good acts",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "十善のみくらゐに君はおはすを。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく不埒千万な野干も七日不食十善を念じ兜率天に生まれたと『未曾有経』に出づ。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに『十善法語』にも見える通り、仏教には細滑というて肌に触るを最も強く感ずるとす。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからこの北洲の人はことごとく十善を行い悪行を教え作さず。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "十善梅といふは、幹の廻り一丈三尺、關東第一の梅の大木と稱す。",
              "citation": {
                "source": "越ヶ谷の半日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹の廻り一丈にて、十善梅より稍※小なる四恩梅は、今上陛下御即位大典の記念に植ゑたるものなりと記せるに、裸男一首うなり出して曰く、幾千代の雪を凌ぎて梅の花　　我大君の御世にあらはる　車を返して久伊豆神社に詣づ。",
              "citation": {
                "source": "越ヶ谷の半日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も、彼には、人間として精進し、十善に達したい意慾が、真心から熱烈にあった。",
              "citation": {
                "source": "有島武郎の死によせて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　其れより西北に向つて雑木の中の険路を下り、浄瓶峰に在る高い石段を登つて、中会寺を訪ひ、福堂（十善仏、観音、地帝）と慈雲殿（釈迦、弥陀、薬王）の両堂を拝し、客堂で小憩して茶を飲んだ。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "又唄の文句にも、王は十善、神は九善と云ふことあり。",
              "citation": {
                "source": "帝室論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が法皇のクーデターを聞くや、彼は「北国の雪をはらうて京へ上りしより一度も敵に後を見せず、仮令十善の君にましますとも甲を脱ぎ弓の弦をはづして降人にはえこそまゐるまじけれ」と絶叫したり。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "国々の神が、位を貰ふといふ不思議を、仏教では、王は十善・神は九善などゝ説明してゐるが、此は、当然なことであつた。",
              "citation": {
                "source": "呪詞及び祝詞",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此に就いて、仏教では、王は十善、神は九善と称して、王の方が、一善だけ上である。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に寺址と思われるものも多く、そして大段坊の外にも円戒坊、十善坊など云う名も伝わっている。",
              "citation": {
                "source": "周防石城山神籠石探検記",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "十善の帝位に誇られる身であっても、黄泉の国に行かれてから、牛頭馬の責を免れられぬのですぞ」「不逞至極の坊主なり、牢に入れよ」　と文覚は検非違使庁の役人の手で牢に入れられた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第五巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "手に取つて見ると十善具足の名器で、茶に凝つて居る要屋山右衞門などは、一と身上投げ出しても惜しくない氣になる品物です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "井戸の茶碗",
                "note": "青空文庫"
              }
            },
            {
              "text": "手に取って見ると十善具足の名器で、茶に凝っている要屋山右衛門などは、一と身上投げ出しても惜しくない気になる品物です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "井戸の茶碗",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし人間があの御殿に住まえるような、十善の王位に生れるには、前世にそれだけの功徳を積まなければならないのだ。",
              "citation": {
                "source": "二人の稚児",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その座ではいちばん年長であるし、ながいこと将軍の側用人を勤め、まえの年に若年寄となって、「当代十善人の一人」と評されているくらいだから、甲斐に対する雅楽頭の態度を、そのままみのがしていることができなくなった。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "十善の天子とお生れあっていらい、初めて“非情な世の粗土”というものに、そのお跣足を噛まれたのである。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
