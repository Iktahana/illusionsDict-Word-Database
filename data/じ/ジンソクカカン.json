        "examples": {
          "standard": [
            {
              "text": "彼は迅速果敢な判断で、窮地を脱した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "リーダーには、迅速果敢に事態を収拾する能力が求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の迅速果敢な行動が、多くの人々の命を救った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その迅速果敢が、いかにもジガ蜂らしかつた。",
              "citation": {
                "source": "ジガ蜂",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この決心処置は迅速果敢しかも適切敏捷に行なわれナポレオンを嫉視ないし軽視していた諸将を心より敬服せしめるに至った。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
