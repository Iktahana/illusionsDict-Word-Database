[
  {
    "uuid": "cb4771b4-4d16-5131-9103-468d96c75cae",
    "entry": "上疏",
    "reading": {
      "primary": "じょうそ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
