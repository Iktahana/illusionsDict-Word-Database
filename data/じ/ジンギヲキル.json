    "definitions": [
      {
        "index": 1,
        "gloss": "to make a formal salutation (between yakuza, street vendors, gamblers, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "埃で黄くなつた頭髪、泥と血の塊り、男の不安げな眼、それからあのいくらか仁義を切るやうな半シャツの甥の身構へだの、それらがもう一度頭の中に蘇り、一列になつて通つて行つた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……こいつはしまった」はたと、自分の頬ッぺたを打って、さっそく最敬礼の仁義を切るなどは、どう見てもどこか憎めない男であった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "随身を許されて、二人は、喜色をたたえながら、いかめしい顔を並べている諸将へ向って、「へい、どうかまあ、これからひとつ、ご昵懇におねがい申します」　と、仁義を切るようなお辞儀をした。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
