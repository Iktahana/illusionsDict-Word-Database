      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "self-satisfaction",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「ふん、」と兎は輕蔑し、「自業自得ぢやないの。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう人で、悪気はなくとも少し慾気が手伝っていると、百貨店で品物を買ったような訳ではない目にも自業自得で出会うのである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "仰向けた茶わんとうつ向けた同じ茶わんとが同一物である事を自得するまでにはかなりな経験を重ねなければならぬ。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あれは自業自得です。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人、小間使が好奇心で、照子様をおどしたので、謂わば自業自得というものです。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるを、わざと人間どもが、迎え見て、損わるるは自業自得じゃ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はた雪叟が自得の秘曲に、桑名の海も、トトと大鼓の拍子を添え、川浪近くタタと鳴って、太鼓の響に汀を打てば、多度山の霜の頂、月の御在所ヶ｜嶽の影、鎌ヶ嶽、冠ヶ嶽も冠着て、客座に並ぶ気勢あり。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "残っているのは待合の借りばかりだ」「……………」「みんなお前さんの自業自得さ。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ふん、」と兎は軽蔑し、「自業自得ぢやないの。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんは、まあ、自業自得で仕方がないとしても、あたしにまで、こんな赤い太鼓の片棒かつがせて、チンドン屋みたいな事をさせてさ、お母さんはきっと、お父さんをうらんで、化けて出るわよ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "前半は巵酒　歓楽、学業の荒廃を致さんことを嘆じ、後半は一転して、真楽の自得にありて外に待つ無きをいう。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "左様いふ人で、悪気は無くとも少し慾気が手伝つてゐると、百貨店で品物を買つたやうな訳では無い目にも自業自得で出会ふのである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「違うでしゅ、それでした怪我ならば、自業自得で怨恨はないでしゅ。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ト此の鑿を持ち、鏨を持つべき腕は、一度掌を返して、多勢を圧して将棊倒しにもする、大なる権威の備はるが如くに思つて、会心自得の意を、高声に漏らして、呵々と笑つた。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何をやらしてみても、力いっぱいつかいすぎて、後になるほど根まけしてしまうといういつもの癖が、こんな話のしかたにも出てしまったわけで、いわば自業自得ですが、しかしこうなればもうどうにもしようがない、駈足で語らしてもらうほかはありますまい。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘をつく快楽が同時に真実への愛であることを、彼は大いに自得すべきである。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "自得の門に三宝の引接を希ひしかば。",
              "citation": {
                "source": "処女の純潔を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「強情ぬかした老ぼれめ、刀の錆は自業自得だ」　其の時傍の闇から直助が顔を出した。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そりやアあなたの自業自得といふものです――めかけでなけりやア、圍ひ者が天道さまのお罰を受けたのでしよう」と、かの女はお鳥を睨み返してから、もとの言葉をこちらに向つて續けた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あいつは」と、千代子はお鳥のことを云つて、「自業自得だから、仕かたがない、さ――けれど、この人も、どうせ、碌な死にかたはしますまいよ――何度わたしに苦勞や心配をかけたか分らないんですもの。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "越前の場合は、毎日の裁判で見る多くの犯人を、実例として人相学の研究を積むのであるから、一年も経った頃には、その道で自得するところが多く、よほどの自信を持つようになって居た。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "自業自得、そんな言葉も彼は吐いた。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、それも自業自得だつた、と言つては言ひ過ぎだらうか。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに生れつき剛直で世に恐れるものがなかったので、傲誕自得という有様であった。",
              "citation": {
                "source": "令狐生冥夢録",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間にか僕は、僕流の型を自得して、勇敢な「フラツペ」で、吾と吾が胸を守つたり、鮮やかな「ヴオレイ」で、敵を参らせ、口笛を吹きながら「モツケ」してやつたり――そして、威気昇天の想ひを駆せて胸をひろげ、歌をうたひます。",
              "citation": {
                "source": "僕の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それですから勇二は逃げるも、どうするもありません、なんの苦もなく召し捕られました」「金造はなぜ殺されたんですか」「金造の殺されたのは自業自得で……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "金造め、わっと叫んで表まで逃げ出したが、急所のひと突きで脆くも往生という始末、まったく自業自得と云うのほかはありません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作家の筆は、一見すると他奇なきものと見られますが、どうして容易ならぬ飛躍性が充ち充ちてゐて、うつかりと、われわれが技巧的なことなどを口にしたら、こつちこそ飛んだ自業自得に陥入るであらう、長成を見逃すことになるでせう。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分からいえばそれは「自業自得」であった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昨日、旦さんがドツサリ焙じとくなはつたばツかりやおまへんか。",
              "citation": {
                "source": "父の婚禮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
