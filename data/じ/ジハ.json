[
  {
    "uuid": "f250dff0-7943-542f-9c3b-fd86316e0ac5",
    "entry": "自派",
    "reading": {
      "primary": "じは",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
