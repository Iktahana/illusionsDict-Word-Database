    },
    "definitions": [
      {
        "index": 1,
        "gloss": "person's name",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼の知人名簿には十年も前に死んだ人の宿所がそのままに残っていて、何の符号も付いていない。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論土佐の日下は山地である、人名等より来たであろうが、もとは渡しかもしれぬ、崇神紀に「クスハノワタシ」というのがある。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る患者等は、病氣中の自己をＢ氏といふ他人名で呼び、自分とすつかり別の人物として語つてゐる。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護長は、帳簿を拡げ、一人一人名前を区切って呼びだした。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこれほど専門家の目には顕著な人物の名前が「世間」というものの人名簿には今日という今日までどこにもかいてなかった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその話を今だに忘れていないが、人名や地名は今は既に林間の焚火の煙のように、何処か知らぬところに逸し去っている。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう意味から言えば、新聞記事に現われた除幕式は純然たる概念的公式的の除幕式であって、甲のものと、乙のものとは人名などの活字面が少しちがうだけであって、どれもこれも具象的内容においては全く同じものである。",
              "citation": {
                "source": "ニュース映画と新聞記事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりわけ、地名や人名または切支丹の教法上の術語などには、きっとなやまされるであろうと考えた。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "製本されて纏まった文章になって、蒸気とガソリンの速力で全国の読者に配布されても地名や人名は仮名になっているし、標題に含まれている暗示もよほど注意深く新聞を読んでいる人か、又は実地を調査した係官の中でもかなり職務に忠実な人間でなければわからないようにしておいた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝三郎は蒼くなって、電話の名儀を他人名儀にしたりして権右衛門の差押えにそなえた。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、今では、人名辞典を開けば、すなわち「葛原勾当」の項が、ちゃんと出ているのであるから、故勾当も、よいお孫を得られて、地下で幽かに緩頬なされているかも知れない。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は、私が人名辞典やら、「葛原勾当日記」の諸家の序やら跋やら、または編者の筆になるところの年譜、逸話集、写真説明の文など、諸処方々から少しずつ無断盗用して、あやうく、纏めた故葛原勾当の極めて大ざっぱな略伝である。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、たしかに HERBERT だ、そんなに有名な作家でもないようだから、ちょっと人名字典か何かで調べてみて呉れ、と重ねてたのみました。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "藏から父の古い人名辭典を見つけだし、世界の文豪の略歴をしらべてゐた。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔵から父の古い人名辞典を見つけだし、世界の文豪の略歴をしらべていた。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして其話を今だに忘れてゐないが、人名や地名は今は既に林間の焚火の煙のやうに、何処か知らぬところに逸し去つてゐる。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "連載物など、前に掲載した分を読み返すか、主要人物の姓名の控えを取って置けば間違いはないのに、それをしないものだから、平気で人名を変えたりしている。",
              "citation": {
                "source": "鬼",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "作中に「オダ」という人名が出て来ますが、これは読者が佐伯は作者であるなど思われると困りますので、「オダ」が出て来るのです。",
              "citation": {
                "source": "吉岡芳兼様へ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇　翁が稽古中に先輩や筆者を叱った言葉の中で記憶に残っているものを、云われた人名と一緒に左に列記してみる。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "後記この合戦記を作るに際して、　『余呉床合戦覚書』及び『別本余呉床合戦覚書』上下を主たる参考本とし、諸本によっては人名の多少異るものがあるが今は総てこの覚書に従った。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これはパリの人名住所録ですが」　と彼は云いました。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "『これはパリの人名録で、人の名前のあとに職業があります。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "開発者の個人名が表に出るのは、商品としてのプログラムでは異例でしょう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二〇〇五年一月一日、青空文庫は呼びかけ人名で、著作権保護期間の七〇年延長に反対する意思を示した。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なに、教師をしていると、人名や地名の説明を求められますから、この位な本がないと、心細いのです。",
              "citation": {
                "source": "二人の友",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "文中人名に漢字を当てたは予の手製でなく実に符秦の朝に支那に入ったカシュミル国の僧伽跋澄の音訳に係る。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "また猪飼部の称や赤猪子てふ人名などありてこれを証す（明治三十九年版、中沢・八木二氏共著『日本考古学』三〇四頁）。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "畢竟大洞のやうな先生が虚誕の共喰をしてゐるので人名地名の発音の間違どころか飛んでもない見当違ひを一向御頓着なく見て来たやうな虚誕を書く。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくの如きは余り多くない例で、八犬士その他の登場人物の名は歴史にあらざる歴史を作って人名字書中の最大の名よりもヨリ以上に何人にも知られておる。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
