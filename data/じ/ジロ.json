    "definitions": [
      {
        "index": 1,
        "gloss": "magnetic circuit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
