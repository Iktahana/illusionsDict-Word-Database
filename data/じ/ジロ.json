[
  {
    "uuid": "3ac15bf4-23d0-5a94-b418-61b3216044cc",
    "entry": "地炉",
    "reading": {
      "primary": "じろ",
      "alternatives": [
        "ちろ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fireplace or hearth dug into the ground or floor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして、戸外へ走りでようとして起きながら見ると、もう何もいずに灰をかけてあった地炉の火が微に光っていた。",
              "citation": {
                "source": "妖怪記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅僧はずだ袋の中から赤い小さな紙片を二三枚出して、何か唱えながらそれを地炉の火に入れた。",
              "citation": {
                "source": "妖怪記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お作はいきなり起って地炉の傍へ往くとともに、懐の守袋の中に入れてある木札を執ろうとしたが手が顫えて執れないので、その紐を引きちぎって袋ごと火の中へ投げ入れた。",
              "citation": {
                "source": "妖怪記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "消えかけた地炉の火の微に残っているのが室の真中に見えた。",
              "citation": {
                "source": "怪しき旅僧",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、地炉の火の光で頭だけ朦朧と見えていた旅僧の右の手は、其の時地炉の火の中へ延びて往った。",
              "citation": {
                "source": "怪しき旅僧",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、旅僧は其の鍋の中へ米と水を入れて、地炉の自在鉤にかけた後で左右の足を踏み延ばして、それを炉縁に当て何時の間にか傍に来ていた鉈で、膝節から薪を割るようにびしゃびしゃと叩き切って、其の切れを地炉の中にくべると、火が盛んに燃えだして鍋の飯が煮立って来た。",
              "citation": {
                "source": "怪しき旅僧",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯がなくなると、旅僧は手桶の杓をとって一口水を飲んだが、咽喉へ入れたあまりを地炉の火の上へ吐きだした。",
              "citation": {
                "source": "怪しき旅僧",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると地炉は泥池になって水が溢れるようになるとともに、ふいふいと蓮の葉が浮きだして白と紅の蓮の花が一時にぱっと咲き、数多の蛙が集まって来て声をそろえて喧しく鳴きだした。",
              "citation": {
                "source": "怪しき旅僧",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、裏口からそっと入ってみると、室は元の室になって、旅僧は地炉の傍に仰向けになってぐうぐうと鼾をかいて睡っていた。",
              "citation": {
                "source": "怪しき旅僧",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……戻ったの、遅かったから心配しておった、都合が好かったの」と、地炉の前にいた女房が庭の方を見て云った。",
              "citation": {
                "source": "雁",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "久兵衛と女房は午飯も喫わずに地炉の傍でぽかんとしていた。",
              "citation": {
                "source": "雁",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭い板葺の家の中に、主人らしい男が地炉に火を焚いておりました。",
              "citation": {
                "source": "死人の手",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人は草鞋を解いて、簀子を敷いた縁側を跨いて地炉の傍へあがりました。",
              "citation": {
                "source": "死人の手",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人は地炉にかけた茶釜を見つめながら、主人の跫音に耳をやっておりましたが、其の跫音は次第次第に遠退いて、やがて聞えなくなりました。",
              "citation": {
                "source": "死人の手",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "地炉の火のぼんやりさした死骸の頭はむこう向きになって、此方には束ねた黒髪がありました。",
              "citation": {
                "source": "死人の手",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人も気が丈夫になったので、おずおずと地炉の傍へ寄りました。",
              "citation": {
                "source": "死人の手",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、地炉の火の前で母の噂をしていたが、どうも帰って来そうな模様が無ので、総領｜女は二人の年下の弟妹に、「お母さんは鬼婆が怖いから、今晩は泊って明日の朝帰って来る、寝て待っておりましょうよ」と云って、戸締をしてから、地炉の傍で三人が枕を並べて寝た。",
              "citation": {
                "source": "白い花赤い茎",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親はつかつかとあがって、地炉のそばに寝ている二人の小供をじっと見ていた。",
              "citation": {
                "source": "白い花赤い茎",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "地炉に焚く榾の火が狭い荒屋の中を照らしていた。",
              "citation": {
                "source": "ある神主の話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前さんは何人であったかな、俺はものおぼえが悪いから」「お前さんは知らないかも判らない、私は近比この村へ来た者だから」「そうか、それなら、これからおつきあいをしよう、さあ、おあがり」「そんじゃ、あげてもらおうか」　小柄な男はそう云って地炉の傍へあがった。",
              "citation": {
                "source": "ある神主の話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "破鐘　　　　　　シャルル・ボドレエル悲しくもまたあはれなり、冬の夜の地炉の下に、燃えあがり、燃え尽きにたる柴の火に耳傾けて、夜霧だつ闇夜の空の寺の鐘、きゝつゝあれば、過ぎし日のそこはかとなき物思ひやをら浮びぬ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央に地炉ありて、自在鍵を用う。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒地では日光乾燥が間に合わなくて、地炉の煙に当てて防腐したものと思われる。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して他の二カ処でヂロと載せているのは（肥後、信濃）、ヂとジとの差異を聴き分けたのではなくて、おそらくジロは地炉だという学問が干渉したものである。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な『後三年絵詞』の「地火炉ついで」の話などもあって、「地炉」に近い語は早くから知られているが、右の全国的なるジロをもって、軽率に地面にしつらえた炉のことと、解してしまうことは事実の無視になる。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、いづこぞ夢の序樂のぽろねえず、會社は河岸に涙をひたし、花店の飾窓つゆにぬれたり、しばしまたつりがね鳴らむ、あさまだきにほふ葉影に、しろじろとかざし泳がせ、この列をなす少女らあゆむ。",
              "citation": {
                "source": "若き尼たちの歩む路",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔つめたき朝の真鍮に〕宮沢賢治つめたき朝の真鍮に胸をくるしと盛りまつりこゝろさびしくをろがめばおん舎利ゆゑにあをじろく燐光をこそはなちたまへり",
              "citation": {
                "source": "〔つめたき朝の真鍮に〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜はほのじろく明けんとす僕はここに去りまた新しい汽車に乘つて行かうよ僕の孤獨なふるい故郷へ。",
              "citation": {
                "source": "別れ",
                "author": "旅の記念として、室生犀星に",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのちがつた空氣は、意地の惡い觀察の眼をもつて、じろじろと自分の醉態を眺めてゐる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち、言い知れぬ恐怖に、強く強く抱き合ったまま、身じろぎもせず、そのお庭の葉桜の奥から聞えて来る不思議なマアチに耳をすまして居りました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
