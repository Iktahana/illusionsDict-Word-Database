  {
    "uuid": "9380efec-9a0f-52ef-8b73-85bad53cc793",
    "entry": "時評",
    "reading": {
      "primary": "じひょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "commentary on current events",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "露伴の妹などは一時評判であったがやはり駄目だと云う事だ。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "北原氏が荷風以下多くの作家を時評で退ける時の強さを、いつ作品の上で示すのだろうか。",
              "citation": {
                "source": "文学的饒舌",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "時評に依ると、お前の心境いよいよ澄み渡ったそうだね、あはは。",
              "citation": {
                "source": "或る忠告",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三面をザッと読んでから、文芸欄を開いて、随筆や時評などを漫然と読んでいると、ふと「新劇研究会の公演」という見出しが眼についた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "本書はソフトバンク刊の『パソコン・マガジン』に「インサイドウォッチャー」と題して連載した時評コラムを、まとめ直したものだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒の席などで、作家は（どんな馬鹿な作家でも）さすがにそうではないけれども、君たちは、ああ、太宰さんですか、お逢いしたいと思っていました、あなたの、××という作品にはまいりました、握手しましょう、などと言い、こっちはそうかと思っていると、その後、新聞の時評やら、または座談会などで、その同一人が、へえ？",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "−−−−−−−−−−−−−−−−−−−−−−−−−−洋画壇時評　　　　美術批評家に思索力なし『洋画壇時評』と銘打つての時評であるが、幸ひなことには私は全くの画に就いては素人であるといふことである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "−−−−−−−−−−−−−−−−−−−−−−−−−−洋画壇時評　三つの展覧会　　　　新進ＮＯＶＡ展　ノバ展の一般的な世評を私は度々耳にしたが、大体この展覧会に就いては「余りパッとしない展覧会だ」といふ評判が多かつた。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "−−−−−−−−−−−−−−−−−−−−−−−−−−洋画壇時評　旺玄社展を観て　　　上野山清貢と岩井弥一郎　岩井弥一郎――最も場内で個性的だといふ意味に於いて、この作者の絵の前に私は吸ひつけられた。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "−−−−−−−−−−−−−−−−−−−−−−−−−−洋画壇時評　独立展を評す　　　　第一室　中間冊夫　筆法が濶達でのびのびした作画態度にこの人の将来の仕事への余地を示してゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝大新聞、三田新聞、都新聞などに文芸時評、文化時評を発表。",
              "citation": {
                "source": "小熊秀雄全集-1",
                "author": "短歌集",
                "note": "青空文庫"
              }
            },
            {
              "text": "文壇の警官　阿部氏の頽廃取締役　▼改造新年号の『文化時評』で阿部知二氏が事変下に於ける国民の『頽廃、享楽面』を取締る政府のやり方に就いて意見を述べてゐる。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にそれが当時評判の高い李香であるというので、船頭もよくその顔をおぼえていたのだ。",
              "citation": {
                "source": "女侠伝",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "草の上にあぐらをかくやいなや、懐中から、文芸時評という雑誌を出してあけたままの一ページを逆に三四郎の方へ向けた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎は「偉大なる暗闇」が気にかかるので、ノートのそばに文芸時評をあけたまま、筆記のあいまあいまに先生に知れないように読みだした。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "二週間後には文芸時評社から原稿料が取れるはずだから、それまで立替えてくれろと言う。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "文芸時評の売れ高の少ないのは当人の自白したとおりであるのに、麗々しく彼のいわゆる大論文を掲げて得意がるのは、虚栄心の満足以外になんのためになるだろうと疑っていたが、これでみると活版の勢力はやはりたいしたものである。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "やむをえなければ今月｜末までこのままにしておこう」「今月末になればできる見込みでもあるのか」「文芸時評社から、どうかなるだろう」　三四郎は立って、机の引出しをあけた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばかげている」「文芸時評から原稿料をくれたか」「原稿料って、原稿料はみんな取ってしまった」「だってこのあいだは月末に取るように言っていたじゃないか」「そうかな、それは間違いだろう。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が取りにいかなくっちゃ」「どこへ」「じつは文芸時評がいけないから、原口だのなんだの二、三軒歩いたが、どこも月末でつごうがつかない。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "文芸時評の六号活字の投書にこんなのが、いくらでも来る。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして最近には、生田長江氏の左翼の諸作品に対して加えた批評とそれに対する片岡鉄兵氏の駁論（ともに『読売新聞』所載）および川端康成氏の『文藝春秋』二月号の時評等の対立によりてこの同じ問題が再燃しようとしている。",
              "citation": {
                "source": "二つの文学論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "小林秀雄氏が最近の時評でいち早く自身が提唱した日本的なるものの迷子になることを予言しており、ヒューマニズムも同様に行方知れずになるだろうと言っておられる。",
              "citation": {
                "source": "ヒューマニズムの諸相",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "別な作者の小説「希望館」についての感想を敷衍しつつ、嘗て或る時期に、実際運動をしていた人々が文学の仕事に移って来て今日示している或る種の文学活動に向って感じられたいろいろの疑を私はその時評の中に述べた。",
              "citation": {
                "source": "不必要な誠実論",
                "author": "――島木氏への答――",
                "note": "青空文庫"
              }
            },
            {
              "text": "時評の中で佐藤氏は、帝国芸術院が年金をきめていないことをあげ、芸術家の経済的窮乏が芸術家と政府とを惧しめる結果になることを惧れているけれども、一個の芸術家が生ける屍として現れるのは、あながち経済的窮乏のみによらないことを教えられるのである。",
              "citation": {
                "source": "文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中でいけないのがあるとか「時評」にわるいところがあるとか、つまり毎号意地悪く発禁攻めにしても大衆の伸びる力はおそろしい。",
              "citation": {
                "source": "ますます確りやりましょう",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らが『働く婦人』のいけないところというのが、世界と日本の情勢を正しく伝える「時評」および反帝国主義戦争の投書に外聞を忘れた露骨さで集注されている例でも、ファッショ化した支配階級が何を恐怖しているか明らかではありませんか。",
              "citation": {
                "source": "ますます確りやりましょう",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
