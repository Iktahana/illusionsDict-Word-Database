    },
    "definitions": [
      {
        "index": 1,
        "gloss": "casual laborer (labourer)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼等はその殆んどが半自由労働者なので、どれも惨めな生活をしていた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに実質上は何んたって反自由労働者で、職場から離れている。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "会社は更に市内に溢れている失業労働者やすぐ眼の前で動物線以下の労働を強いられている半自由労働者――浜人足たちのことを、たゞそれッ切りのことゝして見てはいなかった。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "小樽や函館にいる自由労働者は、この俊寛達を敵よりもひどくにめつける。",
              "citation": {
                "source": "北海道の「俊寛」",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い弟が自由労働者として働いている間に、溝の中でつぶされて死ななければならなかった事情を彼等の皮膚の白さがかえはしなかった。",
              "citation": {
                "source": "中国に於ける二人のアメリカ婦人",
                "author": "――アグネス・スメドレーとパァル・バック――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴーリキイは彼の胸をムカムカさせる小市民と、善良な人々ではあるが貧と無恥、野蛮の中にとめられているヴォルガ河岸の家のない羊の塊りのような自由労働者の生活としか知らなかった。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "風のたよりでは、戻つて来た加野は、何を考へてか、一切のいままでの生活にそむいて、横浜で自由労働者になつてゐるとも聞いた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分の家に南千住あたりの自由労働者を大勢ひっぱってきて、集合をしたり、演説会をしたりして、官憲の圧迫に反抗しながら勇敢に宣伝を続けておりました。",
              "citation": {
                "source": "ある男の堕落",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣室に、二人の大学生と一緒に住んでる、年の若い自由労働者だった。",
              "citation": {
                "source": "傷痕の背景",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "松浦久夫という、以前小さな或るグループを拵えていた仲間で、自由労働者上りの男ですが、僕をいきなり、あの生活から引抜いてくれました。",
              "citation": {
                "source": "道化役",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "公卿、小間使、重役、自由労働者、下士官、居候、舅、末つ子、伯母、親友、先生の奥さん……一寸かう並べて見ても、そこに、それらしい言葉使ひがありさうに思はれる。",
              "citation": {
                "source": "「語られる言葉」の美",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "○※シリーサ、自由労働者の露骨な逞しさ。",
              "citation": {
                "source": "『どん底』ノート",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一部分）九月一日　金曜『毎日新聞』　二百十日平穏　板垣正（26）転向声明を発表、自由労働者の生活をしていた。",
              "citation": {
                "source": "日記",
                "author": "一九五〇年（昭和二十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "県庁の庭に三百人ほどの自由労働者が赤旗をふってデモをやってる。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "貸元の賭場ではなくて、車夫だとか、自由労働者とか、本職でもなしズブの素人でもなしという手合の半常習的なレッキとした大人の世界へのりこんで行くのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと安川は牛乳配達であらうと自由労働者であらうと商売に軽重をつける気持はもたない男で、生来の怠け癖と非力からさういふ働きを愛さなかつたまでであるが、いよいよ仕方のない時はさういふ仕事をしていいと考へてゐた。",
              "citation": {
                "source": "老嫗面",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その選んだ職業としては、第一に市民の為に労働して、その日その日を送って行くという、今日のいわゆる自由労働者や、上方地方でいわゆる手伝（テッタイ）の如き道に流れて行った。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔ならば河原者、坂の者、散所の者となるべき運命の下に置かれたものも、今日では木賃宿へ仮住まいして、自由労働者と呼ばれている。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか今のいわゆる自由労働者の徒や、俳優等遊芸者の類は、もちろん問題以外であったのです。",
              "citation": {
                "source": "融和問題に関する歴史的考察",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でも東京や大阪へ、諸国から多くの落伍者が流れついて、自由労働者の名の下に、木賃宿などに陣取って、その日その日の労働に生活しているものが少くありません。",
              "citation": {
                "source": "融和問題に関する歴史的考察",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "また聞きで私が聞いたところでは、自由労働者たちが一日二百円あるひは二百五十円位の賃金で道路の掃除をしたり焼跡を片づけたりする、さういふ時にその辺に落ちてゐるクヅ鉄を拾つてこれをクヅ鉄買入れの店に持つてゆけば、一日平均三百円ぐらゐのお金に売れるといふ話である。",
              "citation": {
                "source": "子供の言葉",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういへば自由労働者たちがよその垣根の内の物まで持つてゆくやうに聞えるが、そんな事はない、彼等は潔白である。",
              "citation": {
                "source": "子供の言葉",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小樽ではこの夏、挑発されて火炎ビン事件がおこり、ビンを投げた自由労働者の組合は、鮮明に右旋回してあっといわせた。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「知識階級に関してはそのうちのブルジョア分子は問題外として、注意すべきことは賃金労働に従事している層と、未だに独立の小ブルジョア的生活を営む者（自由労働者）とを区別することである。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し、彼等が、皆、人間らしい大様さと朗らかさと自信とを持った自由労働者なら、私は、心から手を差し延ばして、他国で廻り遭った悦びを述べるだろう。",
              "citation": {
                "source": "南路",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "会社の正門前に、ふつうの通勤工以外の自由労働者の大群が、毎朝まッ黒に見えるようなときは、一号二号三号ドックとも全部の竜骨台に入渠船が坐っていて、沖にも入渠待ちの内外船が混んでいる証拠だった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蛇の様に冬眠が出来るといいなあ」　突然、すぐ側でそんなかぼそい声が聞えたので、見ると、目の前のベンチに若い栄養不良な自由労働者がいて、隣りの少し年取った同じ様な乞食みたいな男に、話しかけていたのだった。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "関東木材産業労働組合、東京地方自由労働者組合、東京製糖労働組合の組合長をやり、日本労働総同盟に参加して、深川木場の労働者のために多くの争議を指導した。",
              "citation": {
                "source": "私の履歴書",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或いは、港の船を目あてに、ペンキ塗りでも何でもやる自由労働者のことと通用してもよい。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
