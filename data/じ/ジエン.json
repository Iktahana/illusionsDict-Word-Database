  {
    "uuid": "45caa28c-c555-55b3-8605-d5ef9c4c1109",
    "entry": "自園",
    "reading": {
      "primary": "じえん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "one's own garden",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "シャンパンは葡萄畑を買ひ取つて自園の酒をこしらへた。",
              "citation": {
                "source": "雪",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この老母に言はせると、おそらく深山のやうな老舖で賣る茶は多年の經驗から、古葉に新葉をとりまぜ、いろ／＼な地方で産するものを鹽梅し、それに茶の中の茶ともいふべき『おひした』（味素）を加味して、それらの適當な調合から香もあり味もある自園の特色を造り出してゐるのであらうとの話もあつた。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜蔬は蘭軒の妻が常に店頭の物を買つて送つたが、或日それに自園の大根を雑へて、蘭軒の詩を添へて遣つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "自園でとれた南京豆一袋いただく。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「じえんこ（錢）は？",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄、じえんこ――油ば貰つてくるんだ。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "けい古終ると東宝劇場で「たからじえんぬ」を見る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
