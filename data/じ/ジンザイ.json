[
  {
    "uuid": "4c11a3f2-c59e-50ce-a98e-33ce4b3ed349",
    "entry": "人材",
    "reading": {
      "primary": "じんざい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
