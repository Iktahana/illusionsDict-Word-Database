    },
    "definitions": [
      {
        "index": 1,
        "gloss": "second son",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "のみならず、堀辰雄、中野重治、萩原恭次郎等、所謂新進詩人の作物にも、一通り廣く目を通してゐた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大河内伝次郎は、必ず試合に勝たなければいけない。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人たちは私を呼ぶのに佐野次郎左衛門、もしくは佐野次郎という昔のひとの名でもってした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ、私を佐野次郎なぞと呼びはじめたのは、たしかに馬場なのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、口に出して言われないような、われながらみっともない形で女のひとに逃げられたものであるから、私は少し評判になり、とうとう、佐野次郎というくだらない名前までつけられた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い質問、「知ることは幸福であるか」　　佐野次郎左衛門様馬場数馬。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、この帝大生が佐野次郎左衛門さ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐野次郎、呑まないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐竹、太宰、佐野次郎、馬場、ははん、この四人が、ただ黙って立ち並んだだけでも歴史的だ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐野次郎にしちゃ大出来だ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐野次郎さんには、死んでも言うものか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべ佐野次郎が電車にはね飛ばされて死んだのを知っているか」「知っている。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐野次郎氏と遊びたくてせっせとこれだけこしらえたのだが」「僕におくれ」「いいとも」「菊ちゃん。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐野次郎は死んだよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで綺麗な着物と帯とを買えば、きっと佐野次郎のことを忘れる。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "重兵衛さんの長男楠次郎さんから自分は英語の手ほどきを教わった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりは小館保治郎氏であり、ひとりは、寺町の豐田太左衞門氏であり、いまひとりは、書のたくみなる齋藤常次郎氏であらう。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "齋藤常次郎氏は、いま、たはむれに書畫骨董をあきなつて居られる由であるが、そのひとがら、その前半生、明治初年に沒したる大通中の大通細木香以を思はせる態の灑脱の趣があるのである。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし案内の剛力（名を勝又琴次郎という）が、今まで幾回も登山したが、頂上へ登らずに、下山したのは、ただの一度しかないと「山運の好い男」を誇っているのが、何だか便りのようにも思われて、私と弟とは、その男に先導されて、闇の中を、行けるところまで行くことにした。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "本田富次郎の頭脳が、兎に角物を言う事の出来た間中は、彼は此地方切っての辣腕家であった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕を高くした本田富次郎氏は、樫の木の閂でいきなり脳天をガンとやられた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に私は藤原慶次郎といっしょに出て行きました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、九月の末のある日曜でしたが、朝早く私が慶次郎をさそっていつものように野原の入口にかかりましたら、一本の白い立札がみちばたの栗の木の前に出ていました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶次郎も顔を赤くして何べんも読み直していました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私が云いましたら慶次郎は少し怒って答えました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると俄かに慶次郎が私のところにやって来てしがみつきました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶次郎の顔を見ましたらやっぱりまっ青で唇まで乾いて白くなっていました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでそっと慶次郎に云いました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　慶次郎はなんにも云わないでだまってきのこをはきごのまま棄てました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これから、イヌ小屋へ行って、いっしょに骨をかじろうってのさ。",
              "citation": {
                "source": "雪だるま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
