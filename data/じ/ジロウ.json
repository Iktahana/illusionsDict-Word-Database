[
  {
    "uuid": "4655b928-f3ac-5786-a40d-af2ee48a9613",
    "entry": "痔ろう",
    "reading": {
      "primary": "じろう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "anal fistula",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「これから、イヌ小屋へ行って、いっしょに骨をかじろうってのさ。",
              "citation": {
                "source": "雪だるま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜあなたは好んでそれを踏みにじろうとばかりしているんです。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供は大喜びで家へ帰ると、すぐさま箱からとり出してぜんまいをねじろうとすると、その肝心のぜんまいが駄目になっているのであった。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オヤ、何故私は大きいまんまかじろうとしないんだろう、気取るつもりでこんな事をしたんだろうか……」　クスリと歯ぐきの間で笑って向うに岡持を下げて居る男と懸命にしゃべって居る娘の黒い横がおを望めた。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は今まで守り通してきた貞操を――それも夫に対してではなく、子の名誉のために守り通りしてきた貞操を――僅かな金銭のために、自分でふみにじろうとしていたのだ。",
              "citation": {
                "source": "椎の木",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あだなる戀に泣く子らの手に育ちけむ花のごと色青じろう影やせて隱れも行くか雲の外。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀樂月ほのじろう森黒くあらし睡れるさよ中に下界離るゝ魂二つ、ひとつの聲はさゝやきぬ「樂しかりけり世の夢は」ほかなる聲はつぶやきぬ「哀しかりけりわが夢は」嗚呼樂みか哀みかもゝ年足らぬ夢の世の差別は何のわざならむ、仰げば星はまたゝきぬ月ほのじろう森黒くあらし睡れるさよなかに下界はなるゝ魂二つ。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "火星兵部隊の方でも、何だかわからないが、しきりに怪しい声をあげ、人間突撃隊を踏みにじろうと、押出して来る。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼を外らそう、せめて頸だけでもねじろうとするが、全くいうことをきかない。",
              "citation": {
                "source": "幽霊",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　村人は死罪という言葉にたじろうた。",
              "citation": {
                "source": "野に臥す者",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「口惜しい、口惜しい、私はこんな、こんな木偶に見返られ――て」絶え入るばかりの泣声、おさよもさすがに堪え兼ねたのでしょう、兎もすれば夫の手を振りもぎって、人形の顔を踏みにじろうとします。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第六夜　人形の獄門",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　母親がその足の下で踏みにじろうとすると、笏はにわかに止めた。",
              "citation": {
                "source": "後の日の童子",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、何よりもいけないのは最後の瞬間まで、紙幣を踏みにじろうなどとは、夢にも思ってなかったにしても、やはり予感していたらしいことです。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "お供をいたしたひと／″＼は、日向のかみをはじめとして、なかじましん兵衛、なかじま九郎次郎、きむらたろじろう、木むら与次、浅井おきく、わきざかさすけ、などのかた／″＼でござります。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに家の者らは、屋根裏に住む者の常として薄暗がりになれた目で、彼らの姿をすっかり見て取ることができて、じろじろうちながめていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は五体をよじろうとかまわないのだ。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓から、外をながめていた女が、二人の会話にふり向いて、これも話にまじろうとするように、坐り直す。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "打ち交じろうではないか、一名おきに」　と、みずから努めて親しみを寄せて行った。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ見ておれ」　すこし身をねじろうとしたが、体が動かない。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
