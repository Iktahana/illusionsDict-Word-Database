  {
    "uuid": "b20f1d57-d2cf-5342-964f-d48609907e7f",
    "entry": "次郎",
    "reading": {
      "primary": "じろう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
