    },
    "definitions": [
      {
        "index": 1,
        "gloss": "mounting (during animal copulation)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "同じ『後漢書』東夷列伝に、辰韓は秦人（支那人）が馬韓より地を割き受けて立てた国で、〈牛馬に乗駕す〉と特書せるを見ると、当時韓地にも牛馬を用いぬ所があったので、千年ほど前出来た『寰宇記』に、琉球に羊と驢と馬なく、〈騎乗を知らず〉といえるもその頃そうであったのだ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "専ら野馬を猟りて食った時代は措き、耕稼乗駕馬を労する事多き人が、その上にもこれを殺し肉を食い皮を用いなどするは、創持つ足の快からぬところから出で来った馬鬼の話が諸国に多い（『山島民譚』一参照）。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "記録書翰は読む進むにつれて、いよいよこの独逸人の一隊が優美な美しい都会へ足を踏み入れ、そこにおいて長老たちから芳醇なる葡萄酒が供せられ、各自｜轎に乗駕してこの都会の貴族邸へ、賓客として舁かれてまいることが誌されているのであります。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳永さん、どじょうが欲しかったら、いくらでもあげますよ。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄宇迦斯は追いまくられて逃げこむはずみに、自分のしかけたつり天じょうがどしんと落ちて、たちまち押し殺されてしまいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "はいってみると、この部屋は天じょうがふつうの部屋の倍ほど高く、ひろさは三十坪ばかりであった。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもよくまあ、いのちにべつじょうがなくて着陸できたもんだね」「千ちゃん、いったいここはどこの国だい」「さあ、どこの国か、どこの星なんだか、けんとうがつかないね。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼうや　なにしてるのシカちゃん　なにしてるのあたしがくるのは　今夜っきりこれで　もうこられないのよ　王さまは、もうこれいじょうがまんしていることができません。",
              "citation": {
                "source": "にいさんと妹",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京では埼玉の越ヶ谷辺の地黒というどじょうが上物で大きく、以前、うなぎの大和田あたりで盛んに蒲焼きにして、「どかば」と称して、一時人気を呼んだものである。",
              "citation": {
                "source": "一癖あるどじょう",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、何年も作らなかった田にどじょうがたくさんいることが見つかった。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほくほくして浦上へ帰ってきたら、なんとあれほどたくさんいたどじょうがたちまち一匹もおらなくなってしまったのである。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と聞くと、「喜安※太郎はお前知っといじょうが。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ　てんじょうが　ひくくて　リューシの　あたま　すれすれで、　つぼや　おなべも　ちいさくて、　そこにある　なにもかもが　そうなのです。",
              "citation": {
                "source": "チギウィンクルおばさんのはなし",
                "author": "THE TALE OF MRS. TIGGY-WINKLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝ごとに裏の川よりあげて捕るウケの山がには黒く太かりき捕りためしバケツの底を山がにの鳴らすがきこゆ秋の夜長を　稲の穂花の白く浮いた田の水が溝川に落とされるころから、どじょうがよく捕れる。",
              "citation": {
                "source": "かき・みかん・かに",
                "author": "中島哀浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて御城内におきましては、十八日からひろまにおより合いなされまして御ひょうじょうがござりましたが、くわしいことは存じませぬけれ共、亡君のおん跡目相続のこと、明地闕国の始末についての御だんごうらしゅうござりました。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれども長居は無用とおぼしめされましたか、御ひょうじょうがおわりますと、夜半にきよすをしのんでおたちのきあそばされ、みのゝくに長松をすぎてながはまへおかえりなされまして、一旦は無事におさまりましたことで厶り升。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと目を開いてみますと、ふしぎふしぎ、ちか室のてんじょうがなくなっているではありませんか。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "てんじょうがきかいじかけで、両方へ開くようになっていたのです。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "11　ちか室のてんじょうが大きく開いて、おとなの三ばいもあるせいどうのまじんが、ふわふわとちゅうにうき、そのまま空の方へまい上がっていきました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下室を合わせて三階しかない建物に、エレベーターがあるのは、おかしいようですが、地下室の森は、ひじょうにてんじょうが高いので、エレベーターが必要なのかもしれません。",
              "citation": {
                "source": "鉄人Ｑ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっというまに、この世がさかさまになって、ゆかがすうっとてんじょうに上がり、てんじょうが下になってしまったのです。",
              "citation": {
                "source": "まほうやしき",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "まわりのかべや、てんじょうが、はこのようにできていて、それがくるくるまわるので、自分たちが、てんじょうに上がったようにかんじるのさ」「うん、えらい。",
              "citation": {
                "source": "まほうやしき",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "カチンという音がして、怪人の両手に手じょうが、かけられました。",
              "citation": {
                "source": "怪人と少年探偵",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "変装をとくのです、それには、この手じょうがじゃまじゃ。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれが、手じょうやぶりのめいじんだということをしらないのか」　パチンと音がして四十めんそうのりょう手から、手じょうがはずれてしまいました。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンクリート大仏の内部に、板をはり、鉄の階段をつけて、上と下の二つにわけただけで、二階の部屋は、てんじょうが見あげるほど高く、上の方はうす暗くて、はっきり見えません。",
              "citation": {
                "source": "灰色の巨人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　岩あなのてんじょうが、グッと、ひくくなってきたので、首領は、背をかがめて歩きながら、うしろのジャックに話しかけます。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ここは洞窟で、てんじょうがあるんですもの。",
              "citation": {
                "source": "魔法博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "原っぱには、てんじょうがないから、なんのしかけもできません。",
              "citation": {
                "source": "魔法博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "てんじょうが、スーッとうす暗くなり、電球は水の中で光っています。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
