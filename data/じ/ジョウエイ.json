    },
    "definitions": [
      {
        "index": 1,
        "gloss": "screening (a movie)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "上映中の映画がどんな愚作であってもそれは問題でない、のみならずあるいはむしろ愚作であればあるほどその治療的効果が大きいような気もするのである。",
              "citation": {
                "source": "映画と生理",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、せんだって上映されたシャリアピンの「ドン・キホーテ」はそういう意味ではむしろ不純なものであったかと思う。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三　「世界の終わり」と「模倣の人生」　同時に上映されたこの二つの映画の対照が自分には興味があった。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、文楽座は人形芝居はかかっていず、古い映画を上映しているらしく、映画のスティールが陳列されていた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃千日前で尾上松之助の活動写真を上映しているのは、「千日堂」の向いの常盤座であった。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　文楽でも見ようということになり、佐野屋橋の文楽座の前まで来ると、夏の間は文楽は巡業に出ていて、古い映画を上映していた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "『サンプルブック』の中では、文中で触れている同窓会のスライド上映のために集められた写真を使った。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一方の「著作財産権」には、二〇〇四年一二月一日の改正時点で、「複製権」「上演権及び演奏権」「上映権」「公衆送信権等」「口述権」「展示権」「頒布権」「譲渡権」「貸与権」「翻訳権、翻案権等」「二次的著作物の利用に関する原著作者の権利」が、束ねられている。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、で見た、マコーイズ（うっかり、マッコイズなどと発音すると、ワラに死ぬほど馬鹿にされる）の〈ハング・オン・スルーピー／フィーヴァー〉というシングル、そして、『ポップ・ギア』と同時上映になっていた、『五人の週末』という映画に出ていた、デイヴ・クラーク・ファイヴのＥＰを、友人の長兄にさしだした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、「近日上映」という細長い紙が貼りつけてある、ビートルズの四人の背中に、残像のようなものがついているポスターだった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "33今夜、きみに必要なのは愛といつくしみきみと、きみの友人たちに愛といつくしみを〈ラヴ・アンド・マーシー〉ブライアン・ウィルスン（ビーチボーイズ）　みなが、正装からカジュアルな服に着替えたりで、バーベキューの開始が遅れ、サロンでヴィデオ上映がはじまったときには、時計は八時半をまわりつつあった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし、ここでヴィデオを上映したころは、十九インチのテレビだった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日四回の上映の合い間を縫って、冗談のように重い「ヴィデオコーダー」（と呼んでいた）をかかえ、慶一たちは校舎のなかを右往左往した。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に「チャップリン黄金狂時代、近日上映」という広告が貼ってあった。",
              "citation": {
                "source": "雪の夜",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、被告の申立てる犯行当日に於ける上映映画のプログラムや内容については、間違いないんですが、被告人が入場者の行列の先頭に立っていたと云う事については、一日に何回も開館するのだし毎日のことだから少しも覚えがないって、その証人の従業員達はつッぱねちまったんです。",
              "citation": {
                "source": "あやつり裁判",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実この映画は、割れ返る程の人気を博して、同じものを二度も三度も上映させられた。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこのうえはさいわいにして彼らが無能であってこれ以上映画界に害毒を流すことさえなければまことに見つけものだと思ってそれだけで十分消極的に喜んでしかるべきであろうと思う。",
              "citation": {
                "source": "映画界手近の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、Ａ社を自由退社することによって協定に触れたものの出演映画がＢ社系統の館に上映せられた場合、Ｂ社はＡ社に対して金十万円を支払う罰則が設けられているのである。",
              "citation": {
                "source": "映画界手近の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはりそのころ池袋の平和館へ何かむしかえしの外国物（「ジゴマ」の再上映？",
              "citation": {
                "source": "私の活動写真傍観史",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "作品の不足から街には早くも再上映の氾濫らしい。",
              "citation": {
                "source": "思い",
                "author": "――情報局の映画新体制案について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "写真が何べん上映されても、作つた人にはいつさい関係がないというのは合点の行かない話だが、これも結局はこちら側の不行きとどきで、いまさらあわててみたところで始まらない。",
              "citation": {
                "source": "思い",
                "author": "――情報局の映画新体制案について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを上映する館の再生機という難物が控えている。",
              "citation": {
                "source": "雑文的雑文",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物から金を取つてトーキーを上映するからには原音どおり再生できる機械を備えるのが館として当然の義務である。",
              "citation": {
                "source": "雑文的雑文",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "先頃上映されていた「命ある限り」という映画は通俗化されながらも、これまでひたかくされていたこれらの事情をいくらかは人々に会得させたのであった。",
              "citation": {
                "source": "世界の寡婦",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つを「ピカデリイ」、他はオリムピアと呼号し、前者はいま――というのは私のいたとき――ロン・チャニイ主演「刑罰」、後者はアイリン・プリングルとチェスタア・コンクリン共演の喜活劇を上映していた。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから原作のままの「アジアの嵐」なんぞ上映することを許さないんだ。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、たまたま日本映画を上映すると、観衆は、あるとてろできまつて哄笑するのを不思議に思つて、よく注意してゐると、どうも、彼等に一番可笑しいのは、日本人の「お辞儀」であるらしいことを発見した、といふのである。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "２．レマルクの映畫「西部戰線異状なし」は一再ならず政府委員によつて上映を禁止された。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四句「戸締りのない家に」云々は、かくも驚天動地の大犯罪映画許り逐次上映されたるがための江戸つ子らしい揶揄である。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
