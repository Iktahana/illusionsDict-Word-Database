    "definitions": [
      {
        "index": 1,
        "gloss": "if I do say so myself",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
