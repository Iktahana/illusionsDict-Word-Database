    "definitions": [
      {
        "index": 1,
        "gloss": "Pure Land teachings",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
