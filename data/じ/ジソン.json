[
  {
    "uuid": "c141faea-ec0e-5da9-91ff-3c78d52d3a62",
    "entry": "児孫",
    "reading": {
      "primary": "じそん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
