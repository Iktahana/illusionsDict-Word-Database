    },
    "definitions": [
      {
        "index": 1,
        "gloss": "children and grandchildren",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大恩のある簡先生の名誉のため、名望高い一門のため、郷党のため児孫のため、わしは断じて折れてはいかん。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "負えるあり、抱けるあり、児孫を愛するが如し。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "城外に在った勝成は、「大阪の役に児子の功を樹てた事があったが、今日児孫の先登を見る」と云って涙を流して喜んだ。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾家遺法人知否　　　　我が家の遺法、人知るや否や、不爲兒孫買美田　　　　児孫の為めに美田を買はず。",
              "citation": {
                "source": "閑人詩話",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "万頃の豊田｜眼路はるかにして児孫万代を養ふに足る可く、室見川の清流又杯を泛ぶるに堪へたり。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダカラ近来は芝居を見物したり、又は宅に芸人など呼ぶこともあるが、是れとて無上の快楽事とも思われず、マア／＼児孫を集めて共に戯れ、色々な芸をさせたり嗜きな物を馳走したりして、一家内の長少睦しく互に打解けて談り笑うその談笑の声を一種の音楽として、老余の楽みにして居ます。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "児孫の世を思へと言ふが、その末の世を思へばこそ、かうして忠告もするのだ。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今目前の事にかゝづらうて、禍を児孫の代に残すことを虞れゝばこそ、かうも言ふのだ、と人に思ひ返させようとして居る風が見える。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "志深い大和侍の児孫と称する人があつて、南都の神事芸能を興すことを以て、偏に祖先にこたへる道と信じ、世の思議を越える奇特を行つたことによるのである。",
              "citation": {
                "source": "薪能と呪師走の翁",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "盆が済むと、蓮の葉や青薦に捲いて、川に流す瓜や茄子は、精霊の依代となつたものだから流すので、単に供物であるならば、お撤りを孝心深い児孫が御相伴せないではゐない筈である。",
              "citation": {
                "source": "盆踊りと祭屋台と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "特殊の人々をして、これが伝承に努めしめて、罔極の祖先から永劫の児孫に及さうとしたのである。",
              "citation": {
                "source": "「しゞま」から「ことゝひ」へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生が産を治むる事をやめられてから、一家の主人役に立たれたあなたが、児孫の為に利益を計り権利を主張し、切々と生活の資を積む可く努められたのも、致方はないと云った様な御気の毒なわけで、あなたの方から云えば先生にこそ不平あれ、先生から不足を云われる事はない筈です。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、児孫の村をおとづれて、幸福の予言を与へて去る。",
              "citation": {
                "source": "古代生活の研究",
                "author": "常世の国",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしてかの富はひとり腕力を制するのみならず、腕力の児孫たる涙なり、血なり、怨恨なり、争闘なり、嫉妬なり。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは老後に児孫のない事を以て、しみじみつくづく多幸であると思わなければならない。",
              "citation": {
                "source": "西瓜",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "児孫は老父を慰め団欒の楽しみをなすと雖障子はいつも穴だらけなり。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちそれは大力量の士たる「仏祖の児孫」のみが、嫡々相伝して住持するところの、什麼物（Was）である。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しるべし禅宗の称は魔波旬の称するなり、魔波旬の称を称しきたらんは魔党なるべし、仏祖の児孫にあらず」（正法眼蔵仏道）。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "侵塵一路出城門、泥壁茅軒智利村、南米人文何処遍、田家猶未教児孫。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みんなきとくれたわねえ」　母はもう一遍あいた目で枕べによる児孫たちの顔を見まわしながらそんなことをひと言いう。",
              "citation": {
                "source": "母の死",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "会稽の太守｜王朗は、その日、城門をひらいて、自身、戦塵のうちを馳けまわり、「黄口児孫策、わが前に出でよ」と、呼ばわった。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はそのパジャマの袖を取って、それを崖の上に置いて、如何にもそこで幸子とお前との間に格闘でも行われたように見せかけて、その筋の発見を早めようかと思ったがなまじそんな細工をして、お前自身に第三者の介在を気付かれては却って困ると考えて、止めた。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "『さざなみ』に行つて一應ガラツ八の樣子を見ようと思ひましたが、なまじそんな事をして、曲者に用心させてはと、手先捕方を隙間もなく配置し、兎も角も夜の明けるのを待つことにしたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "平次屠蘇機嫌",
                "note": "青空文庫"
              }
            },
            {
              "text": "『さざなみ』に行って一応ガラッ八の様子を見ようと思いましたが、なまじそんな事をして、曲者に用心させてはと、手先捕方を隙間もなく配置し、ともかく夜の明けるのを待つことにしたのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "平次屠蘇機嫌",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
