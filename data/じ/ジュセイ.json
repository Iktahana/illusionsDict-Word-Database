[
  {
    "uuid": "c3cd7576-ca41-539a-b7a2-ee5eb93bfb4f",
    "entry": "儒生",
    "reading": {
      "primary": "じゅせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Confucian scholar",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "憾むらくは、通篇儒生の口吻多くして、説話は硬固勃率、談笑に流暢尖新のところ少きのみ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "山東参政鉄鉉は儒生より身を起し、嘗て疑獄を断じて太祖の知を受け、鼎石という字を賜わりたる者なり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "開州の軍将に冉従長という人があって、財を軽んじて士を好むというふうがあるので、儒生や道士のたぐいは多くその門に集まって来たが、そのなかに※采という画家もまじっていた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "始皇は儒生を喜ばず、泰山に封じ、梁父に禪するに及んでも、其禮は雍に於て上帝を祀るの儀を用ゐた、と云はれてゐる。",
              "citation": {
                "source": "道教に就いて",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰山の封禪は其爲といふわけでも有るまいが、暴風雨に遇つて好結果を得なかつたので儒生等はこれを譏つた。",
              "citation": {
                "source": "道教に就いて",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其うち幾分儒生も混じて居つたやうであるけれど、此等の儒生とても、咎を人に嫁して平然たるが如き破廉恥漢で、儒生の名あつて儒生の實なきものである。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "北の儒生は皆兵射に達して居つたが、南方では餘り流行せぬ。",
              "citation": {
                "source": "晉室の南渡と南方の開發",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "後年の犬儒生活は此に基くらしい云々』と、迢空自身の記述にある如く、彼は未だ獨身である。",
              "citation": {
                "source": "釋迢空",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉は通じなかつたが、五峯といふ明の儒生が乗つてゐて筆談を交すことができた。",
              "citation": {
                "source": "鉄砲",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔しは儒生実地に用なきの空論にのみ汲々たりしかば人をして六経は争論の資のみと嘲らしめたりき。",
              "citation": {
                "source": "信仰個条なかるべからず",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛政三年彼れ年十二、立志編を作りて曰く噫男児不学則已、学当超群矣、古之賢聖豪傑、如伊傅如周召者亦一男児耳、吾雖生于東海千歳之下、生幸為男児矣、又為儒生矣、安可不奮発立志以答国恩、以顕父母哉。",
              "citation": {
                "source": "頼襄を論ず",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "大炊介は郷士の伜だが、いまは儒生のはしくれにすぎないから、もちろん供などは連れず、小狩衣に侍烏帽子をかぶったくらいのところ。",
              "citation": {
                "source": "うすゆき抄",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "見付けたのは毎朝聖堂に通ふ、儒生の吾妻屋丹三郎、若旦那崩れで、身體が弱くて、足が惡く、その上落ぶれ町人で、まともには聖堂に通ふわけに行かず、散歩かた／″＼門外から遙かに孔子の像を拜んで涙を流して歸つて來るといつた、世にも氣の毒な純情青年でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "處女神聖",
                "note": "青空文庫"
              }
            },
            {
              "text": "師の日野民部｜忠経は、元｜南家の儒生で、儒学においては、朝に陰陽師の安倍｜泰親、野に日野民部といわれるほどであったが、磊落な質で、名利を求めず、里にかくれて、児童たちの教育を、自分の天分としていた。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねがわくは治乱の道を、説いて聞かせたまえ」「山村の一｜儒生が烏滸なる言とお怒りなくば、一言申してみましょう。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "崔州平は、かぶりを振って、「山野の一儒生、もとより世上に名利を求める気はありません。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ところが、いま呂蒙も亡く、国中この難局に心をいため、これらの故人を、仰ぎ慕うこと、まことに切なるものがありますが、まだ以て、黄口の一｜儒生にすぎない陸遜を目して、護国の英傑と恃むものは一人もないでしょう。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに年は若いし、世の儒生と同じように柔弱で、どう贔屓目に見ても、取り立ててこれという程な秀才とも思われぬから、おそらくは用いてみても、部下の諸将が彼に服すまい。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
