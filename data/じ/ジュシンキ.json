    "definitions": [
      {
        "index": 1,
        "gloss": "(television, radio, etc.) receiver",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
