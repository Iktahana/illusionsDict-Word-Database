        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たとえば僕は一千九百十九年の七月に、アメリカのジャイアントアーム会社の依嘱を受けて、紅宝玉を探しにビルマへ行ったがね、やっぱりいつか足は紅宝玉の山へ向く。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "台頭する低価格ソフトは「パーソナルコンピューターを一億人の必需品に変える」と吼えた　新宿の雑踏に紛れ込んだ田舎者を見つけるのは、幼稚園児の列に加わったジャイアント馬場を発見するよりたやすいことだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャイアント馬場でも天龍でも前田日明でもなく、猪木であるのか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "探偵のヴァンスも溌剌としたフラッパー〔おてんば娘〕に好かれそうなタイプでもなければ、ホームズやルパン型のジャイアントでもない。",
              "citation": {
                "source": "ヂユパンの癖とヴァンスの癖",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルコポロは、自分で書いたらしい本を持ってきまり悪そうにして居るし…………　地球を片手で持ちあげるジャイアントの様な気持で、得意な笑を浮べながら私は私の根元にひろがって居る、可笑しい世界をながめて居る。",
              "citation": {
                "source": "暁光",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "信夫山と阿武隈川　昔ジャイアントが居た。",
              "citation": {
                "source": "「禰宜様宮田」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ら、それが信夫山になって、そのジャイアントは、その山の頂上に腰をかけて、下をはるかにながれて居るあぶくま川で足を洗った。",
              "citation": {
                "source": "「禰宜様宮田」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "火成岩は※々奇妙な規則的構造を示す――有名なアイルランドのジャイアント・コーズウェイ(*21)のように――だがレイクが初め噴煙を上げる円錐を疑った件を除けば、この驚嘆すべき山塊は明らかなその構造からしてどう考えても非火山性だったのだ。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
