        "examples": {
          "standard": [
            {
              "text": "家を出る前に、必ず玄関の錠を下ろすのを忘れないでください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、誰にも邪魔されないよう、部屋のドアに錠を下ろしました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あー、もう学校終わった！早く帰って、お家のドアに錠を下ろそうっと。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "というのは、第一の、部屋の外側より部屋の内側の扉にさしこんである鍵をまわして錠を下ろすという方法は、この研究室ではできないことだった。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルマー　お芝居は止せ（扉の錠を下ろす）こゝにゐて、すつかり自分のしたことを話すがいゝ。",
              "citation": {
                "source": "人形の家",
                "author": "ET DUKKEHJEM",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
