          "standard": [],
          "literary": [
            {
              "text": "駅の附近のバアのラジオは私を追いかけるようにして、いまは八時に五分まえである、台湾はいま夕立ち、日本ヨイトコの実況放送はこれでお仕舞いである、と教えた。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争が終って間もなく、ある野外音楽会の実況放送があったが、紹介の放送員はさすがに戦争中と異った型を出そうとしたらしく、「ここ何々の音楽堂の上の青空には、赤トンボが一匹スイスイと飛んでおりまして、まことに野外音楽会にふさわしい絶好の秋日和でございます」と猫撫声に変っていた。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラジオ会社の実況放送、各新聞社の記者、カメラマンのいならぶ前で、三日の深夜に実験が行われた。",
              "citation": {
                "source": "立春の卵",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏場所角力六日目の実況放送がはじまつたのである。",
              "citation": {
                "source": "角力",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラジオからは、東京裁判の実況放送が流れていた。",
              "citation": {
                "source": "黄色い日日",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
