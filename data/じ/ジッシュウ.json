    "definitions": [
      {
        "index": 1,
        "gloss": "practice (in the field)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大内は夏服の上に黄色な実習服を着て結びを腰にさげてずんずん藪をこいで行く。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私は毎日の実習で疲れていましたので、長い説明が面倒くさくてこう答えました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の朝早く私は実習を掲示する黒板にこう書いておきました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月八日農場実習　午前八時半より正午まで　　除草、追肥　　　第一、七組　　蕪菁播種　　　　第三、四組　　甘藍中耕　　　　第五、六組　　養蚕実習　　　　第二組（午后イギリス海岸に於て第三｜紀偶蹄類の足跡標本を採収すべきにより希望者は参加すべし。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その半分書いた分だけを実習がすんでから教室でみんなに読みました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか校長も黄いろの実習服を着て来ていました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は実習の九日目です。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "演習なり実習なりである講義を理解する下地の出来たものは自由に入れてやって、普通学の素養などは強要しない。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の実習にはそれをやった。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでほかの実習の組の人たちは羨ましがった。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前中その実習をして放課になった。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "教科書がまだ来ないので明日もやっぱり実習だという。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月二日　水曜日　晴今日は三年生は地質と土性の実習だった。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実習は苗代掘りだった。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実習は今日も苗代掘りだった。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月八日　水、今日は実習はなくて学校の行進歌の練習をした。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実習のほうが却っていいくらいだ。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の実習は陸稲播きで面白かった。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実習している間になんべんも降りたのだ。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一千九百廿五年十月廿五日今日は土性調査の実習だった。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日｜実習が済んでから農舎の前に立ってグラジオラスの球根の旱してあるのを見ていたら武田先生も鶏小屋の消毒だか済んで硫黄華をずぼんへいっぱいつけて来られた。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはいやで仕方なかったので内藤先生が行ってからそっと球根をむしろの中へ返して、急いで校舎へ入って実習｜服を着換えてうちに帰った。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしたちは黄いろの実習服を着て、くずれかかった煉瓦の肥溜のとこへあつまりました。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生の時分に天文観測の実習をやった。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私は毎日の実習で疲れてゐましたので、長い説明が面倒くさくて斯う答へました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の朝早く私は実習を掲示する黒板に斯う書いて置きました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月八日農場実習　午前八時半より正午まで　　除草、追肥　　　第一、七組　　蕪菁播種　　　　第三、四組　　甘藍中耕　　　　第五、六組　　養蚕実習　　　　第二組　（午后イギリス海岸に於て第三紀｜偶蹄類の足跡標本を採収すべきにより希望者は参加すべし。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
