        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "わたしもそれを知らないのじゃないがハッキリ覚えていないので歴史を開けてみると、その歴史には年代がなく曲り歪んで、どの紙の上にも「仁道義徳」というような文字が書いてあった。",
              "citation": {
                "source": "狂人日記",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔子のいわゆる仁者仁道を以て立つという訳である。",
              "citation": {
                "source": "東亜の平和を論ず",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁道を以て隣国に臨む。",
              "citation": {
                "source": "東亜の平和を論ず",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
