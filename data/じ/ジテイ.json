[
  {
    "uuid": "e62ebbe2-7238-5012-af52-cc0e1765a79a",
    "entry": "自邸",
    "reading": {
      "primary": "じてい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
