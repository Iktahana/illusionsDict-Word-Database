[
  {
    "uuid": "9ca80eb5-cdac-5357-859a-d434b4e98fa0",
    "entry": "女性らしい",
    "reading": {
      "primary": "じょせいらしい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
