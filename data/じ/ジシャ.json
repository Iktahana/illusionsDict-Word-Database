[
  {
    "uuid": "ec2179e1-157b-5efa-b8b9-ebff0e1d3577",
    "entry": "侍者",
    "reading": {
      "primary": "じしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "attendant",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "）は、手水をそのまま捨ててこまった侍者を叱りつけられたということである。",
              "citation": {
                "source": "水〔扉の言葉〕",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリストは、だから、――おや、叔父さんが、多勢の侍者を引きつれて、血相かえてやって来た。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの眼に妖気がある、あれを呼べ」　侍者の一人が呼びに往ったが、許宣はもう山をおりかけていたので聞えなかった。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれが、法海禅師様だ、活仏だ」　和尚の侍者が許宣を呼びに来た。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "降将李陵は一つの穹盧と数十人の侍者とを与えられ賓客の礼をもって遇せられた。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "病人が人に接するのを嫌うからとて、食事は膳部の者が次室まで運んで置き、それを豎牛が病人の枕頭に持って来るのが慣わしであったのを、今やこの侍者が病人に食を進めなくなったのである。",
              "citation": {
                "source": "牛人",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "良夫は燭を執る侍者を退席させ、自ら燭を持って公に近付き、低声に言った。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "良夫は燭を執る侍者を退席させ、自ら燭を持つて公に近付き、低聲に言つた。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれが、法海禅師様だ、活仏だ」　和尚の侍者が許宣を呼びにきた。",
              "citation": {
                "source": "雷峯塔物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍者等は香爐を搖り動したり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこからはしのび足の侍者が、無言のまま、多くのうす暗い入り組んだ廊下を通って主人の書斎へと私を導いた。",
              "citation": {
                "source": "アッシャー家の崩壊",
                "author": "THE FALL OF HOUSE OF USHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて侍者は扉をさっと開いて、主人の前に私を案内した。",
              "citation": {
                "source": "アッシャー家の崩壊",
                "author": "THE FALL OF HOUSE OF USHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "小室は一人の侍者を從へ長やかな服裝に太刀を杖いて立つて居る。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな夜に侍者は少なくて、しかもありたけの人は寝てしまっていた。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "簡単な網代車で、女の乗っているようにして奥のほうへ寄っていることなども、近侍者には悲しい夢のようにばかり思われた。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハヌマン像に戦士と侍者の二態あり。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかれども一八八九年板モニエル・ウィリアムスの『仏教講義』に、オックスフォード大学の博物館に蔵する金剛尊は三猴を侍者とすと記し、文の前後より推すにどうもチベット辺のもので日本製でなさそうだった。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "大日｜窃かに侍者を呼んで言いけるは景清見参疲れたり、酒を買い来り飲ませよという。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍者走りて出で行くを景清見て、我を源氏の方へ訴えて捕えんとするにやと心得、大刀抜き大日を切り殺しける（『梅村載筆』八巻）。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "石橋君は大黒天に鼠はもとクベラ神像と混じたので、その像は金嚢その他の宝で飾った頭巾を戴き玉座に踞し傍に金嚢から財宝をまく侍者あり。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "後には侍者の代りに鼠鼬となった。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、跫音がして山狩姿をした武士が、五六人の侍者を従えて来た。",
              "citation": {
                "source": "村の怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと窕子は向うの廊下に五六人の人だちの氣勢のするのを耳にしたと思ふと、その階段のところに、兼家の腹ちがひの弟で、式部の副官をしてゐる政兼が勅使の衣冠をつけて、侍者二人に扈從されながら徐かにその姿をあらはして來るのを目にした。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "假裝舞踏者、門衞、番衆、侍者等。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "スーラーブは、明りの差し込む窓の下で侍者と一緒に、ぼんやり湯の沸くのを待っていた。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍者に、膏でこすらせ、寝台に横わりながら、彼の少し血走った眼は心に休みない或る考えで光り、じっと天幕の天井に止まった。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十　考えに耽りながら躯をこすらせ、食物を食べ終ると、スーラーブは、侍者にフーマンを呼ばせた。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "13　酒姫――酒の酌をする侍者。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "峨山禅師言行録にいう「侍者師の室前なる水盤の水を替えけるに、師はそのそばにありて打ち見やりたまいしが、おもむろに口を開き、なんじも侍者となりて半年もたつから、もう気がつくだろうと思っていたが、言っておかぬと生涯知らずに過ごす。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまもなく、あしたは春の遠足という日に、久助君はじしゃくをさがすため、茶だんすの引き出しをみなひっぱり出して、いろんなガラクタのなかをかきまわしていた。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
