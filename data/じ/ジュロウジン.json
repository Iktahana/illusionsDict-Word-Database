        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "修業が積んで来るに従って体は枯木のように瘠せ、眼は垂れて福禄寿老人のようになって来る。",
              "citation": {
                "source": "仙術修業",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大横幅著色寿老人一｜掛寺僧｜兆殿司の画ところなりといへども新様にして疑ふべし。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲「安田善次郎君よ、茶があるからおつな頭巾を冠つて、庭を杖などを突いて歩いて居る処は、恰で寿老人の相があります。",
              "citation": {
                "source": "七福神詣",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "町方で探ったところによると、蛭子三郎次、布袋の市若、福禄の六兵衛、毘沙門の紋太、寿老人の星右衛門、大黒の次郎、弁天の松代、これが彼らの名であって、弁天の松代が一党の頭で、そうして松代は美しい、若い女だということであった。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにさなにさ風だって吹く、どこかへ飛ばされて行ったんだろう」こう云ったのは爺むさい小男、他ならぬ寿老人の星右衛門。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "故田口米作画伯が文晁の寿老人の画幅を愛蔵していたが、あるとき幼い令息が、件の画幅へ赤インキを垂らした。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどインキはほとんど消えたが、胡粉を塗った鶴の姿も寿老人の彩色もなんら異状がなかった。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
