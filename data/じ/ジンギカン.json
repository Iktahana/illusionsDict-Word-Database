[
  {
    "uuid": "b6e79df2-7e98-5de2-a55a-b245ead79af6",
    "entry": "神祇官",
    "reading": {
      "primary": "じんぎかん",
      "alternatives": [
        "かみづかさ",
        "かんづかさ"
      ],
      "is_heteronym": false
