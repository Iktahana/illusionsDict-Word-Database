      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "tactician",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "燕王は初より朝野の注目せるところとなり、且は威望材力も群を抜けるなり、又｜其の終に天子たるべきを期するものも有るなり、又｜私に異人術士を養い、勇士｜勁卒をも蓄え居れるなり、人も疑い、己も危ぶみ、朝廷と燕と竟に両立する能わざらんとするの勢あり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "インドのゴンド人は毎村術士あり、虎を厭して害なからしめ、ゴイ族は虎殺すと直ぐその鬚を取り虎に撃たれぬ符とす（一八九五年六月『フォークロール』二〇九頁）。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "トダ人水牛を失う時は、術士｜私かに石三つ拾い夜分牛舎の前に往き、祖神に虎の歯牙を縛りまた熊｜豪猪等をも制せん事を祈り、かの三石を布片に裹み舎の屋裏に匿すと、水牛必ず翌日自ら還る。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "またベシシ族の術士はチンドウェー・リマウ（虎チンドウェー）という小草を磨潰し胸に塗ると虎に勝ち得るという。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "この草の葉に虎皮同様の条紋ありその条紋を擬して術士の身に描く、セマン人言う藪中に多き木蛭が人の血を吮るを引き離し小舎外で焼くと虎血の焦げる臭いを知って必ず急ぎ来る。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしエリスの『古英国稗史賦品彙』二版一巻六二頁に、古ブリトン王アーサーの父アサー陣中で竜ごとき尾ある彗星を見、術士より自分が王たるべき瑞兆と聞き、二の金竜を造らせ、一をウィンチェスターの伽藍に納め、今一を毎に軍中に携えた。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "術士メルリン城よりもまず女を落すべく王に教え、王ゴーロアの偽装で入城してイゲルナを欺き会いて、その夜アーサー孕まる。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなもの今もあるにや、一九一四年ボンベイ版エントホヴェンの『グジャラット民俗記』一四二頁に或る術士は符※を以て人咬みし蛇を招致し、命じて創口から毒を吸い出さしめて癒す。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛇咬を療ずる呪を心得た術士は蛇と同色の物を食わず産蓐と経行中の女人に触れると呪が利かなくなる。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "インドの術士は能く呪して、手で触れずに蛇を引き出し払い去る（一九一五年版エントホヴェンの『コンカン民俗記』七七頁）。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "また人が蛇に化けて所願を遂げた例もありて、トランスカウカシアの昔話に、アレキサンダー大王はその実偉い術士の子だった。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "得たり賢し善は急げと、術士得意の左道を以て自ら蛇に化けて一夜を后と偕に過ごし、同時に陣中にある王に蛇となって后に遇う夢を見せた。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮓答は胡語ジャダーの音訳で、今日もアルタイ地方に鮓答師てふ術士あり。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "パウサニアスの『希臘廻覧記』五巻二七章に曰く、オリンピア廟へフォルミス・メナリウスが献納した、二つの鍮金製の牝馬像のその一に術士が魔力を附けた。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "テンネントの『錫蘭博物誌』にいわく、インド人はハヌマン猴が殺された処に住む人はやがて死ぬばかりか、その骨を埋めた地上に家建てても繁昌せぬと信じ、必ずまず術士を招き、きっとその骨が土中になきと占い定めた後家を立てる。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "金入用に及び、これを術士二人に売る。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "術士化け来って、その指環を衒り取ると、ミネカニエロまた老人となり、指環を取り戻さんと鼠が住む深穴国に至る。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠ども術士の指を咬んで環をミ翁に復す。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミ翁また若返り、二術士を二｜驢に化し、自らその一に騎り、後山より投下す。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "伏蔵とは「田原藤太竜宮入りの譚」に書いた通り、インド等には莫大の財宝を地下に埋めあり、今もそれを掘り当てる事を専門にする者が多く、それを言い中るを業とする術士も少なからぬ。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "追記　英國で最も古い人柱の話は有名な術士メルリンの傳にある。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし、孟蜀にすぐれた術士があつた。",
              "citation": {
                "source": "水仙の幻想",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に鬼眼という術士があって、その店を州の役所の前に開いていたが、その占いがみな適中するというので、その店の前には大勢の人があつまっていた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "輟耕録",
                "note": "青空文庫"
              }
            },
            {
              "text": "『パロとその臣下の前に投げうちしに、蛇となりぬ』とあつて、エジプトの博士と法術士等もおの／＼その杖を蛇と爲し得たが、アロンの杖はすべて之を呑んでしまつた。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月一日には海軍の技術士官となり、その後敗戦まで、音波探知器に携わることになる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ブラウンシュワイク普通医学校より受託の日本医学生降矢木鯉吉（算哲の前名）は、予てよりリチャード・バートン輩と交わりて注目を惹ける折柄、エクセター教区監督を誹謗し、目下狂否の論争中なる、法術士ロナルド・クインシイと懇ろにせしため、本日原籍校に差し戻されたり。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "錬金魔法師の声名高しといえども、通性論哲学者であり、かつまた中世著名の物理学者ことに心霊術士としては古今無双ならんと云わる。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "万事につけてその筆法で、その意味の専門技術士であった。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "術士が司祭の服を著て、青葉の飾を戴いて出た。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、三十分もすると、その男は、べつの町のびじゅつしょうのみせにあらわれました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
