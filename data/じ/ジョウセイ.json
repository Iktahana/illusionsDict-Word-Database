[
  {
    "uuid": "cee6b090-b54c-599e-9ab9-760be8ddef9d",
    "entry": "上製",
    "reading": {
      "primary": "じょうせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "superior make",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それと、もうひとつこれもおれの智慧だが、同じ薬に上製と特製の二種類を設けたことが、非常に効果的だった。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "京子が婚禮の時桐の箱に入れて持つて來た上製の京人形で、二つとも女であるが、一つには緋縮緬の着物を着せ、一つには紫縮緬の着物を着せ、腰に下げた將棊の駒の形の迷子札には、麗はしい墨色で名前まで書いてあるのだ。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "また帝王は、高官の者の勲功に対して上製の茶を贈与したものである。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は井上製鞣へ出ていた。",
              "citation": {
                "source": "乳房",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "燈刻小瀧氏日かげの花上製本持參。",
              "citation": {
                "source": "荷風戰後日歴　第一",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰板の六尺もあらうと思ふものは杉の焼板、上は上製瓦に定紋を抜いてある。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "品質から云うと赤毛布よりもずっと上製である。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすが酒好きの是公も高粱酒の比較飲みは、思わしくないと見えて、並製も上製も同じく謝絶した。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "陶器を作っている部屋もあったようだが、これはほんの試験中で、並製も上製もないようであった。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "（公定価格の点で上製の菓子の製造停止中なることを聞いて）内地でもこんどは特別技術のあるものには公定価の例外を認めることになった。",
              "citation": {
                "source": "台湾の民藝について",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草蔵前に暖簾も古く、店の柱に朱塗りの剥げた名筆の看板、黒塗りの箱を重ねて古風な構え、羊羹は並と上製、風味はもちろんムッチリとした舌ざわり、下戸ならでは知らぬ味、多年これ一品で売り込んだ名物だけの値があった。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の「茶と美」上製本の用紙は同氏の監督の許に作製された。",
              "citation": {
                "source": "和紙十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
