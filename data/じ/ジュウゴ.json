    "definitions": [
      {
        "index": 1,
        "gloss": "fifteen",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "第十三、十四、十五、十六行。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か処方せんけれあならんと思つたかした校長は、その五名を放校に、他の十五名を謹慎処分といふことにしました。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "トリスタン・コルビエールは、千八百四十五年、七月十九日、午前八時、モルレーに於て汽船会社の社長の息子として生れ、千八百七十五年、三月一日午後十時同所で死んでゐるから三十年に足らぬ生涯であつた。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが相手は七十だし私は十五、その十五も危ッかしい十五なのだ。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく一つの社会的風潮は十五年経てば一先づ決算期に入るものださうであるから。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が在世中なれば、問いただすこともできるのですが、父がなくなって、もう、かれこれ十五年にもなりますものね。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の目算では、身丈は五尺七寸、体重は十五貫、足袋は十一文、年齢は断じて三十まえだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は始業時間にもう十五分なのに、教師達がまだ半数しか出席してゐないのに先づ腹を立てた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十五年五月、「朝の歌」を書く。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和二年九月十五日中原中也高橋新吉様",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し序に言ふが、給料はといつたら、それはそれはお話にならないもので、女優の三分の一は十円乃至十五円といふ、彼等の必需品化粧料を買ふさへ出兼る程のそれだつたのである。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "お花、梅吉、喜三郎ことし十五の小性とて娘お蝶がませぶりをさげすみしたる樣もなく家代代の重寶をそつと小縁に運ぶ哉。",
              "citation": {
                "source": "煤掃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時私は大学の講師をして月給三十五円とおやじからの仕送りで家庭をもっていたのである。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度二十五周年記念号を出すので何か書くようとの懇篤な御すすめがありましたので何かと考えてみましたが右様の次第でありますからほとんど何も申上げる材料はないのでありますが、せっかくの御すすめでありますから、ただほんの少しばかり思い付いたことを申上げたいと思います。",
              "citation": {
                "source": "書簡（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（九月二日斎藤茂吉宛）（大正十五年十月『アララギ』）",
              "citation": {
                "source": "書簡（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後についているのは十五、六の色の黒い白手拭を冠った女の子であった。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五円で御釣りが三円なにがし。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五日　今日のようなしめっぽい空気には墓の匂いが籠っておるように思う。",
              "citation": {
                "source": "窮理日記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日すぎから、腰の右方に腫物ができて、粗末にしてゐたら次第にそれが成長し、十五日までは酒を呑んだりして不安の氣持をごまかしてゐましたが、たうとう十六日からは、寢たつきりになつてしまひました。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "驛まで、歩いて、十五分くらゐかかる。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」母は、ことし六十五歳であるが、デユマや、コナン・ドイルの傳奇探偵物語の類を好むのである。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また私は、二月二十五日までに今月の豫定の仕事はやつてしまつた。",
              "citation": {
                "source": "義務",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十五日から、二十九日までには約束の仕事は何も無い。",
              "citation": {
                "source": "義務",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、現代（昭和十五年）の讀者を、あまり、たよりにしてゐない。",
              "citation": {
                "source": "大恩は語らず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「惜別」の意圖太宰治　明治三十五年、當時二十二歳の周樹人（後の世界的文豪、魯迅）が、日本國に於いて醫學を修め、以て疾病者の瀰漫せる彼の祖國を明るく再建せむとの理想に燃え、清國留學生として、横濱に着いた、といふところから書きはじめるつもりであります。",
              "citation": {
                "source": "「惜別」の意圖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十五日　宮川の池に沿いて、宮川の窪を登り、岩壁を直進して、御幣岳の最南峰に登り、各峰を縦走して、二十一日の来路と合し、降路は下宮川谷に入りて、梓川に下り、上高地温泉に帰宿。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺はことし六十五であるが、穂高山の主と言われるくらいな山男で、何でも二十五、六歳のころ、旧の師走であったが、三人連れで、この温泉の上まで、猟にやって来たとき、雪崩れに押し流されて、一里も下まで落っこち、左の脚を折ったということで、もし自分一人であったら、到底命は助からなかったろうと、物語った。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "おびただしく並べられた瓶に試験管、そして塩酸のきつい刺激臭が物語るのは、彼が一日じゅうご執心の化学実験をやっていたということだ。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "お上のだんながお許しくださいましたとならば、久しぶりに若返りましょうよ」　ようやくそれと知ったとみえて、投げ節笠に面をかくしながら、ばち音涼しく両人のかたわらへ近づくと、「おむつまじゅうござんすね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "この、金剛寺門前町と鷹匠町がそれで、昔から、犬猿のあいだがらだったから、やれ、縁日の縄張りがどうのこうの、祭の割り前が多いのすくないのと、しじゅうごたごたをつづけている。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
