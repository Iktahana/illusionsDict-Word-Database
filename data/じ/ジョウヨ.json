[
  {
    "uuid": "2c6d578e-541a-5ac5-a46a-2482261e6e49",
    "entry": "丈余",
    "reading": {
      "primary": "じょうよ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
