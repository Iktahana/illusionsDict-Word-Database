[
  {
    "uuid": "58160aab-b72f-5ef9-a623-3b454093cc83",
    "entry": "弱",
    "reading": {
      "primary": "じゃく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "接尾辞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "a little less than",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は弱いので、　悲しみに出遇ふごとに自分が支へきれずに、　生活を言葉に換へてしまひます。",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "この私の弱い骨を、暖いトレモロで満たして下さい。",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞に拠れば、神経衰弱が原因だし、宇野女史との恋愛なぞといふことも一寸載つてゐたが、どれも直ちに信じる気にはなれない。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮りに正しく神経衰弱が原因だつたとしても、単純な受験生のそれではあるまいし、その神経衰弱の因つて来た所を考へてみたくなる。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかあらぬか彼はただ徒らに気を弱くされてゐた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら詩性に乏しい現今は、兎角、あまりに貧弱なモチーフを取上げることから、多くの詩が妙な複雑に堕しがちである。",
              "citation": {
                "source": "菊岡久利著「貧時交」",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、友達として一言忠告させて貰ふなら、その生活ぶりに、時として余りに野放図なものがあるので、謂はば必要以上に衰弱して居る日があつて、そんな日に出来た詩は、あの感覚と同居しにくい抽象概念を招きすぎて、読者を混乱させる場合がある。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し人間は弱いものであるから、自分の労を多としまいと思つてゐても傲慢になり易いものであるから、そこで何か一つどうしても宗教に入るといふことが必要であると思つた。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだの弱さうな人だと思つてゐた。",
              "citation": {
                "source": "逝ける辻野君",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだの弱さうな、気の弱さうな人であるけれども、あれで却々野心家だとも思つてゐた。",
              "citation": {
                "source": "逝ける辻野君",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一見突慳貪にも見えるけれど、実は寧ろ気が弱い迄に見解の博い人である。",
              "citation": {
                "source": "萩原朔太郎評論集　無からの抗争",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「我は強き時弱く、弱きとき強し。",
              "citation": {
                "source": "萩原朔太郎評論集　無からの抗争",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "前二者が注射や服薬ならば、之は神経衰弱や軽微な肋膜の療養に似て、呑気にブラブラすることを要請してゐるのである。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに妥協的な、薄弱な、謂はば実質なしに動いてゐる社会とでも云ふべきものだ。",
              "citation": {
                "source": "非文学的文士",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しま、私の貧弱な歴史的知識によれば、精神を閉却した時にその社会は幸福ではなかつた。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局僕一人が引越の手伝ひ人であり、その弱々しい、事実またちよく／＼大病を患ふその叔母と僕との二人だけが引越万端のことをするのだとすると、まづまづ僕一人が大部分のことをしなければならない。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなのにやつぱり人とそのまゝ一緒にゐるといふならば、ただ意志が弱いといふことになるやうなもんだが、それかといつて、ああ今は一人になるべきだといつて一人になつてみたとて、何事にまれさう運ぶものでもない。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "神經衰弱の證據だよ。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどい神經衰弱と痔疾のために、骨と皮ばかりになつてる芥川君は、それでも快活に話をした。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分その絶望的な病氣と、それに原因する創作力の衰弱とが、事情の主なるものであると思つた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "實に彼はその病弱の體躯の中に、無限の精力に溢れた「少年客氣の勇」をもつてゐたのだ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと一人、くらい境遇に落ち込んだ場合、その肉親のうちの気の弱い者か、または、その友人のうちの口下手の者が、その責任を押しつけられ、犯しもせぬ罪を世人に謝し、なんとなく肩身のせまい思いをしているものである。",
              "citation": {
                "source": "緒方氏を殺した者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "病弱を美しいと思い描いたことがなかったか。",
              "citation": {
                "source": "緒方氏を殺した者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "語彙が貧弱だから、ペンが渋るのである。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事では、作家は、衰弱するばかりである。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "弱者の糧太宰治-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）猛っている：入力者注　主に外字の説明や、傍点の位置の指定（例）「映画でも見ようか。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」-------------------------------------------------------　映画を好む人には、弱虫が多い。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おたまじゃくしさえ読めるかどうか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "くじゃくの彩羽の紋所ばかり抜いて並べたパンジー。",
              "citation": {
                "source": "五月の朝の花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　布団の下からは、それには答えずに、泣きじゃくりが聞えて来た。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
