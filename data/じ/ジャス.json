    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese Agricultural Standard",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "表だって見える最初ののろしは、日本音楽著作権協会（ＪＡＳＲＡＣ）が上げた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに、保護期間の死後七〇年への延長を求める、ＪＡＳＲＡＣからの要望が盛り込まれていた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "中では、そもそもの火付け役を演じたＪＡＳＲＡＣが、同小委員会の事務局の求めに応じて二〇〇四年八月三一日に提出した、三つの主張からなる要望書が、比較的良くまとまっている。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "その際に「そらもよう」に書いた内容と重複するが、ここで再び、ＪＡＳＲＡＣの論拠に反論しておきたい。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「午後一時ジャストに、研究所へお集りを願います。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそ一時ジャストである。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間前に電話で問い合せた時に、明瞭な発音で「午後一時ジャスト」などと言って教えたあの女性の声であった。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この委員会の上に立つべき政務長官と、全サモアの司法権を握るべきチーフ・ジャスティス（裁判所長）と、この二人の最高官吏は欧洲から派遣されることとなり、又、爾後、王の選出には政務委員会の賛成が絶対必要と定められた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間前、チーフ・ジャスティスは混血児の通訳をそそのかして、私に不利な証拠を掴ませようとあせっていたし、私は私で今朝も、此の男を猛烈に攻撃した第七回目の公開状をタイムズへ書いていた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私への書簡は一々チーフ・ジャスティスの検閲を受けねばならぬ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（チーフ・ジャスティスと政務長官とがムリヌウからティヴォリ・ホテルに避難したそうだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の乱の始まる直前に、新任のチーフ・ジャスティスのイイダ氏が議会を通じて首狩禁止令を出しているのだから、之は当然である。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツェダルクランツの失政のあとを受け、今度のチーフ・ジャスティスは次第に白人や土人の間に於ける政府の信用を回復しつつあるかに見えた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃の私は最早政府の敵ではない筈で、事実、新長官のシュミット氏や今度のチーフ・ジャスティスとも、かなり巧く行っているのだから、新聞を唆しているのは領事連に違いない。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "条約による土地委員会とチーフ・ジャスティスとは、間もなく任期を完了するでしょう。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして爾後の努力は、凡て、その性情の為した選択へのジャスティフィケイションにのみ注がれるであろう。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えようによれば、古往今来のあらゆる思想とは、各思想家がそれぞれ自己の性情に向って為したジャスティフィケイションに外ならぬではないか。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気取ったポーズや、手の込んだジャスティフィケイションのかげに助平根性を隠そうとするのが、みっともないと言ってるんだ。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャスパ・ミーク勲士かペンローズ・フィッシャなり、このロンドンにいる適当な人物を連れてこよう。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "西からはジャストシステムの浮川和宣社長、東からは東芝パソコン・ワークステーション事業部の溝口哲也部長と、両横綱が勝ち上がってくる結末がはなから見えてしまっている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが結局のところ、印刷機の縮小版としてＤＴＰにアプローチせざるを得なかったワークステーション（後に触れるジャストシステムの大地の流儀もこれだ）は、人の手の中にある絵筆と鉛筆の拡張版としてこれに取り組んだマッキントッシュの前に、抵抗らしい抵抗をなしえなかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "スーパーＤＴＰ「大地」は肥えだめの哀れな編集者を救うのか　ジャストシステムが発表したデスクトップ・パブリッシング・システム（場所ふさぎなので、以下はＤＴＰと書く。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七九年にジャストシステムが設立されたころ、オレは編集プロダクションの屋根裏で、肥えだめに落ちたガキのように日本語にまみれていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし瀬戸内海をはさんだ愛媛県新居浜市在住の高校三年生、浮川和宣少年（後のジャストシステム社長だ）にとって、東大入試の中止は他人事ではなかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時は知るよしもなかったが、ジャストシステムの日本語ワープロが製品化のきっかけをつかんだのは、ちょうどそのころだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやく漢字の使えるオフコンが出始めていた当時、日本語の処理できる安いシステムの提供は、ジャストシステムの大きな狙い目だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "索引の配列プログラムを作ってから、オレは目の前のマシンが漢字を使えないことに気づいて「こりゃダメだ」と音を上げたが、ジャストシステムはパーソナルコンピューターの漢字化の波を逃さなかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "開発中のＰＣ―１００にバンドルする（要するにおまけに付ける）ワープロ作りを日本電気から依頼されていたアスキーは、ジャストシステムのソフトに目を着けた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ジャストシステムはその後、自社ブランドへの転換を図った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一太郎は日本語ワープロの標準になり、徳島にジャストシステムの自社ビルが建った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
