        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "是レ決シテ人種問題ノ範圍ニ非ズ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "所得税の問題、物価問題、人種問題などを漠然ととりあげていたトルーマンは、今やタフト・ハートレー法の非民主性について演説し、世界ファシズムに反対し、強国間の協力の可能について言及しなければならなくなった。",
              "citation": {
                "source": "現代史の蝶つがい",
                "author": "――大統領選挙の感想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、また考へが人種問題ともつれ合つて來て、樺太のギリヤク人種やアイノ人種は白樺のたぐひで、同島に權力を振つてゐた露西亞人は松の種族だ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの土言を見ると、人類学者坪井正五郎博士在世の時のコロボックル人種問題を思い出す。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の皮膚の色も、こんなに変えられたら、人種問題の解決に、大いに役立つかもしれない。",
              "citation": {
                "source": "金鱗湖",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一度は「眼前の異人種問題」というのであった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば産児制限問題や優生学上の問題や、更には人種問題、人口問題までが、何等か生物学的解決に俟つと考えられ易い。",
              "citation": {
                "source": "辞典",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して、人種問題ではない。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒人を人種問題として枠づけることは、資本主義に対して人々に目かくしをすることだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "人種問題としての解決は、とっくに終っている。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ハイヌーン』はアメリカの危機を、『折れた矢』は人種問題を、それぞれテーマとしてかくれて意図していたのかもしれない。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
