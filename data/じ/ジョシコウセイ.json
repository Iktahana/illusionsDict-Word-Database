        "examples": {
          "standard": [
            {
              "text": "この女子校の生徒たちは、皆、真面目に勉強に取り組んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、男子校に比べて女子校の方が、仲間との絆が強いと感じている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「先生、女子校生にも部活の選択肢はありますか？」と、新入生が尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
