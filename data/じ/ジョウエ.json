    "definitions": [
      {
        "index": 1,
        "gloss": "white robe or costume",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼はわざと拗ねたのであろう、きょうの華やかな宴の莚に浄衣めいた白の直衣を着て、同じく白い奴袴をはいていた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "壇にのぼる者は五人で、白、黒、青、黄、赤の五色に象った浄衣を着けていた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "千枝太郎泰清は青の浄衣を着けて、おなじ色の麻の幣をささげて、南にむかって坐っていた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの三人は黒と赤と黄の浄衣を身にまとって、おのおのその服と同じ色の幣をとって、北と東と西とに向かって坐った。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "安倍播磨守泰親は白の浄衣に白の幣をささげて、壇のまん中に坐っていた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはやはり五色に象った浄衣をつけていた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "修法をさせていると聞いて大将は僧たちへ出す布施や浄衣の類までも細かに気をつけて山荘へ贈ったのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "夕霧一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして二人の乙女はといえば、白の浄衣に緋の袴を穿き、髪をみずらに取り上げている！",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて子の刻間近くなると、道清の儀といって、御食、幣帛を奉り、禰宜が腰鼓羯鼓笏拍手をうち、浄衣を着た巫二人が榊葉を持って神楽を奏し、太刀を佩き胡※を負った神人が四方にむかって弓の弦を鳴らす。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "猫眼の男",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗盛はもう白い浄衣を身に着けていた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それにしても、そのお召物では、余りに見すぼらしい、せめてお召し替えだけでも」　と、北の方は袷の小袖に、浄衣を添えて差し出した。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「南無権現金剛童子、ねがわくは憐れみをおかけ下さいまして、都へ帰し、妻子の顔を今一度びみせて下さいますように」　これが毎日続くと、着替えの浄衣もないから、麻の衣を身につけ、沢の流れで水ごりをとりながら、岩田川の清流にみたてるのである。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは一様に浄衣の下に薄紫色の衣を着けていたが、水にぬれて、丁度喪服の色に見えた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "筑後守貞能が、これをみて、「何で又、喪服めいた浄衣などお召しなのですか？",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼朝は新しい烏帽子、浄衣をつけ身を浄めると、院宣を三度拝してから封を開いた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第五巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「黙れ、黙れ、黙れッ」「ヘエヘエ」「それほど大事な山登りなら、それぞれの形がある筈だ、浄衣、金剛杖の用意があるか」「それは、その」「その扮でコソコソとお留山へ登ろうと言うのは、怪しい奴に相違あるまい、ひと詮議してやる、来い」　山役人が三人、左右から清作を引き立てるのです。",
              "citation": {
                "source": "天保の飛行術",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　時々には浄衣の更えを給与して欲しい。",
              "citation": {
                "source": "美しい日本の歴史",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "凍える身を拭いて、範宴は白い浄衣を肌に着、少僧都の法衣を上に纒った。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
