    "definitions": [
      {
        "index": 1,
        "gloss": "joy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ナウエンの無線電信塔の鉄骨構造の下端がガラスのボール・ソケット・ジョイントになっているのを見たときにも胆を冷やしたことであった。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ファビアン」を読んで、次にジョイスの「ユリシーズ」を読み、僕は更に新しい文学の行き方が判り、僕らの野心とは僕らの「ファビアン」を作ることであり僕らの「ユリシーズ」を作ることにあると納得した。",
              "citation": {
                "source": "土足のままの文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ性慾を一つの生活気分として、客観的にエンジョイすることの興味を知った。",
              "citation": {
                "source": "老年と人生",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりこうした中年者らは、享楽の対象を直接の性的慾求に置くのではなく、むしろその性的なものを基調として、一種の客観的な雰囲気を構成する事で、気分的に充分エンジョイしているのである。",
              "citation": {
                "source": "老年と人生",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェームスジョイスなどこの紋切型を破ろうとして大胆不敵な「ユリシイズ」を書いたが（「……」と彼は言った）などという月並みな文章がやはりはいっていて、何から何まで小説の約束から逸れるというわけには参らなかったようだ。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし一九九二年十月に、米ボイジャー社と日本のソフト制作者グループとのジョイントベンチャーによって、日本法人のボイジャージャパン（正式名称、株式会社ボイジャー）が設立されており、一九九三年三月のリリースをめどに日本語化の作業が進められている。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてカリフォルニア大学バークレー校でＵＮＩＸのお守りに携わっていたビル・ジョイに頼み、このマシンにＵＮＩＸをのせる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした試みの中から、サンはビル・ジョイの書いたネットワーク上でファイルを共有するためのＮＦＳ（ネットワーク・ファイル・システム）を標準に押し上げ、マサチューセッツ工科大学開発のＸ　Ｗｉｎｄｏｗがウインドウ環境の標準となれば、自らが開発したＮｅＷＳに加えてこれを採用する姿勢を打ちだした。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その声清けれどきれぎれに「ジョージ・ジョイス」と呼ぶごとし。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しゴルスワーシイのジョイを「喜び」と訳す人もある世の中だからな。",
              "citation": {
                "source": "TZSCHALLAPPOKO",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここからだと、坂をくだる車が玄関まえにたどりつくまで撮るには、「く」の字の鏡像を描くようにカメラを動かさねばならないが、トライポッドのジョイントは、そんな動きをするようにはできていない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃木大将の程度のものでさえ、田舎おやじの風体で微行して、その土地の関係者が彼を発見したときの恐縮や一変した待遇をエンジョイしたことは有名である。",
              "citation": {
                "source": "ジャーナリズムの航路",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェームズ・ジョイスの『ユリシーズ』物語つまりオデュッセイア物語の主人公は、ディーダラスで、之はオデュッセイア（ホメロスのものと云われるあのオデュッセイア）に於ける主人公テレマコスに該当すると、評論家は云っている。",
              "citation": {
                "source": "技術的精神とは何か",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊藤整のように、ジェームズ・ジョイスの文学を深く理解した作家が、より若い世代のヨーロッパ文学の手法追随に対してむしろ警告的であるのも注目される。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェームス・ジョイスやＤ・Ｈ・ローレンスから多くのものを摂取して来た一人の日本の文学者として、以上の言葉は、その人の真実を告げている。",
              "citation": {
                "source": "人間性・政治・文学（１）",
                "author": "――いかに生きるかの問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会主義リアリズムの方法は、わたしにとって、「それによって創作する」という方法――ジョイスの方法と伊藤整の小説のような関係には、なかった。",
              "citation": {
                "source": "「道標」を書き終えて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "トマスが「なんじ静かなるところに退きて神をエンジョイせよ」といったのが心にしみます。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ユリシーズ」が、著者の如き分析力によってふわけされた上、昔は普通のスタイルで書いたジェームス・ジョイスが、なぜ欧州大戦後、人間意識の流れをこういう風に扱い出したか、その点を心理学的に究明することは、意味ないことであろうか。",
              "citation": {
                "source": "芸術が必要とする科学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九六八年十二月、ＡＣＭとＩＥＥＥがサンフランシスコで共催した、秋のジョイントコンピューター会議で、増大研究センターはＮＬＳのデモンストレーションを行った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九五九年十二月にボストンで開かれたジョイントコンピューター会議において、ＤＥＣは初のマシンとなるＰＤＰ―１のプロトタイプをデモンストレーションする。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "オプションとして示されたものには、最大二五六ＫバイトへのＲＡＭの拡張、プリンター接続用アダプター、カラーもしくは白黒のディスプレイ、八インチのディスクドライブ、浮動小数点演算用プロセッサー、ジョイスティックがあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの生活のエンジョイの仕方が、終戦になつた現在では、もつと美しく、もつと華々しく展開されてゐるに違ひない。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "プルーストの「失われし時を索めて」やジョイスの「ユリシーズ」などは、殊に後者は、小説の在来の形式を破壊するものだと云われているが、その芸術的構成には並々ならぬ苦心が払われている。",
              "citation": {
                "source": "性格批判の問題",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「記憶の連鎖」を、ジェームス・ジョイスは「意識の流れ」で置きかえて、過去と現在との境界を更に撤廃し、距離の観念を抹殺して、自由奔放な意識の動きを追求する。",
              "citation": {
                "source": "文学以前",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "プルーストやジョイスの模倣者は、殊に超現実主義の末派は、既にこの危険に陥りつつある。",
              "citation": {
                "source": "文学以前",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "がジェームズ・ジョイスは、意識の動きを直接に跡づけようとした。",
              "citation": {
                "source": "現代小説展望",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "プルーストの「失いし時を索めて」やジョイスの「ユリシーズ」などはその例である。",
              "citation": {
                "source": "現代小説展望",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
