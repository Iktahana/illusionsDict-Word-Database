[
  {
    "uuid": "f218df87-7dae-5963-9e47-13de1cd9d071",
    "entry": "時流",
    "reading": {
      "primary": "じりゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fashion (current) of the times",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "時流に超越した人の不遇思うべしである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち私等のした最初の行動は、徹頭徹尾「時流への叛逆」であつた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは明白なる時流への叛逆であり、併せて詩の新興を絶叫する最初の狼火であつたのだ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んやまた詩の情想に於ても、表現に於ても、言葉に於ても、まるで私等のスタイルは当時の時流とちがつてゐた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "這個髯斑に眼円にして面赤き辺塞の驍将に対して、爾き言を出さむには、当時流行の剣劇の朱鞘で不可、講談ものゝ鉄扇でも不可い。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもちゃではポペンというものが一時流行した。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやどうも……柿の渋は一月半おくれても、草履は駈足で時流に追着く。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時流行の作家であります。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "数年経って「外来語所感」を発表したこのごろは、外囲の事情が全く反対になってしまって、ある読者には私が現時流行の日本主義に阿諛苟合するかのような感を与えたかも知れない。",
              "citation": {
                "source": "伝統と進取",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　詩はいつも時流の先導に立つて、來るべき世紀の感情を最も鋭敏に觸知するものである。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かのあらゆる一切の形相を假象として排斥し、ひたすら時間上の實在性を捕捉しようとした象徴主義、藝術上に於ける音樂至上主義を主張した象徴主義の如きも、實にこの時流的自由主義の精神を極端に高調したものに外ならぬ。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高蹈派の詩人たちは、その詩派の名目が示す如く、常に高蹈的な超俗の態度を取り、デモクラチックの思想を軽蔑して、時流の外に高く持すことを誇っていた。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも彼等はジャーナリズムを、時流に属するものを憎悪した。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時流行の気質本を読み、狭斜の巷にさすらひ、すまふ、芝居の見物に身を入れたはもとよりである。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "講習所の娘たちの間に、これを読んで、「丹花の呪禁」だといつて、活け剰りの花を口に銜へ、腰に手を当てゝ、映画に出て来るジヨルヂユ・サンドのやうな気取つた恰好で濶歩するのが一時流行つて、やがて廃れたが――。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "不遇傲岸に見える小布施は、案外、時流に神経質で、十六七年も前桂子と同門で矢来町のＹ――先生の画室に預けられてゐた時分から、逐次独立するまで、後期印象派、ダヾ、表現派、新古典、超現実派と、およそ日本で尖端的に見える画風は魁けしてこれを取り入れ、通俗派の方面にぶつかつて行つた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "程君房とか方干魯とかいふ桂子の耳には縁遠い支那の古墨の作銘の名を、桂子は先頃から屡々小布施の口から聴いたものだが、それを自居の雅名にして、標札にまで書いて出さねばならない気持にまでなつたのか――小布施の時流憧憬は病の進むに従つて、一々、即物化さねば心が安まらない風に見え出した。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの時流にもまたついて行けない。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はやっぱり阿呆みたいに、時流にうとい様子の、謂わば「遊戯文学」を書いている。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "時流に対して、なんの号令も、できないのである。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等がたよりで、隠居仕事の寮番という処を、時流に乗って、丸の内辺の某｜倶楽部を預って暮したが、震災のために、立寄ったその樹の蔭を失って、のちに古女房と二人、京橋三十間堀裏のバラック建のアパアトの小使、兼番人で佗しく住んだ。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "嗚呼｜暫時流離の胸も脈絡の炎に爛れ、痛楚なる人が呻吟も、念仏も悲鳴も知らず、情界の熱き愉楽に、わが霊は喘ぎ焦がれぬ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二　主人側の後藤等はこの宴会の興を添えむために、当時流行の幇間｜松廼家花山を呼んだ。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、家元ばかりはドンナ事があっても衣食に困らないようにして、芸道の研究に生涯を捧げ、時流に媚びず、批評家に過またれず、一意専心、自己の信念に向って精進せねばならぬ。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "咲き誇る桜の下で当時流行の連歌会を催し、義政自ら発句を作って、「咲き満ちて、花より外に色もなし」と詠じた。",
              "citation": {
                "source": "応仁の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴力団の首領と云ふよりも、時流の浪に乗り損つた志士と云ふべきだらう。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり神職もなく、財産、社地も定まらざる廃社同前のもの、また一時流行、運命不定の淫祠、小祠の類を除き、その他在来の神社を確立せしめんと力めたるもののごとし。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度あゝ云ふ譯で一時流行して來たのであります。",
              "citation": {
                "source": "假名遣意見",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
