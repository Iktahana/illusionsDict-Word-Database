  {
    "uuid": "2a8af6e6-e701-53ec-8985-557bf37c3d8a",
    "entry": "ＧＩＦ",
    "reading": {
      "primary": "ジフ",
      "alternatives": [
        "ギフ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "GIF",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大阪を立つ時は勉はジフテリヤの病後であった。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒い日ではあり、末の四郎がまだジフテリヤの病後なので彼女は早く帰って来るように注意したのではあったが、彼等はなかなか帰って来なかった。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気でもワクチンや血清の発明によってチブスとかジフテリヤとか、昔絶望だったものが今日では手当さえ早ければもう危険な病気ではありません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなら、人間の腸チブスが鐘にうつるということもあるはずだし、人間のジフテリヤが鐘にうつるということもあるはずである。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは幼年時、身体が弱くてジフテリヤや赤痢で二三度｜昏絶致しました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジフテリヤの血清をジフテリヤ患者に注射するとステキに利く。",
              "citation": {
                "source": "探偵小説の正体",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "百発百中と云ってもいい位おそろしい効果を以て、ジフテリヤの病源体をヤッツケてしまうらしい。",
              "citation": {
                "source": "探偵小説の正体",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいてジフテリヤの病源体はまだ発見されていない。",
              "citation": {
                "source": "探偵小説の正体",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやら脳黴毒らしい」赤井は簡単にそう言い放ったが、直ぐ心配そうな顔になると、最近さる所へ「肉体の解放」に行ったが、とても汚ならしい女だったから、どうやらジフレスを貰ってもう脳へ来ているかも知れないと、しょんぼりした声で言った挙句、「僕の青春はもう汚れているんだ！",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも私のきいた所によると娘さんが一人あったんだそうだが、バーミングハムへいった時、ジフテリアで死んじまったのだそうだ。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞いたところでは娘がひとりあったそうだが、バーミンガムへ行った際にジフテリアで亡くなったそうだ。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "近時とても軍旅、労働、斎忌等の節一定期間男女別れて群居する民少なからず、古ギリシアやマレー半島や南米に女人国の話あるも全く無根でない（一八一九年リヨン板『レットル・エジフィアント』五巻四九八頁已下。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その価値がモジフハイされたのであると思う。",
              "citation": {
                "source": "作物の批評",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "子宮病で入院中にジフテリ性の心臓麻痺で死んだようにして処理して頂くよう曼陀羅先生にお願いして置きます。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫草さんはかなり重い子宮内膜炎で私のところへ入院しましたが、そのうちに外で感染して来たらしいジフテリをやりましてね。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジフテリ程度の注射なら耳鼻科医でなくとも院内で遣っております」「成る程……」「それがヤット治癒りかけたと思いますと、今月の三日の晩、十二時の最後の検温後に、自分でモヒを注射したらしいのです。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをまかれると、やたらにクシャミがでて、しまいには頭痛｜嘔吐になやむジフェニール、クロールアルシンなど、また涙がポロポロ出てきて、眼があけられず、胸が痛みだすというピクリン瓦斯。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう風に愚図愚図していたから、私はとうてい「ヤマトジフエー」なる先生の気に入る事は出来なかった。",
              "citation": {
                "source": "私の子供時分",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその冬は、年が明けてから、ある日出先のお銀の弟の家で、急にジフテリアに罹って、危いところを注射で取り留めたほかは何事もなかった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼の百分の一の天賦しかない一個の青年も、今日の歴史の中に生きているという事実によって、例えばエールリッヒが、ジフテリア血清の最初の注射のために闘った対立に高貴なものを感じとり、自分のうちなるささやかな善意に鼓舞をうけとるのである。",
              "citation": {
                "source": "バルザックについてのノート",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに現在では六尺二十貫の大男、アドルム中毒と種々の妄想症の他、別に病気はないが、幼年時は百日咳、ジフテリヤ、チフス、赤痢、おまけに狂犬にさえ噛まれた経験さえあるほど多災多病で、時々めまいがして卒倒したり、二六時中、生命の危険に直面させられていた。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがジフテリイになって大学の病院に這入った。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジフテリイは血清注射で直ったが、跡が腎臓炎になって、なかなか退院することが出来ない。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後ビジカルクには、表計算ではじき出したデータをグラフ化するためのビジプロットや、データを整理して保存するためのビジファイル、電話回線を通じてデータをやり取りするためのビジタームなどの関連商品が生まれていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女達も嘗ては球のような新しい身をもって生まれ、何よりも母親たちの恐れる麻疹、天然痘、疫痢、ジフテリア等に、幾種もの小児病を幸いにも無事に経過して来た、尊い肉体である事は、人として異りないものを。",
              "citation": {
                "source": "ある遊郭での出来事",
                "author": "公娼存廃論者への参考資料としての実例",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
