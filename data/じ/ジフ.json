[
  {
    "uuid": "2cac5818-2037-5339-b43b-d1791c802863",
    "entry": "慈父",
    "reading": {
      "primary": "じふ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "affectionate father",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」こゝまで云つて、句切をして、スタニスラウスは女主人とフリイデリイケとの顔を見て、「我々の慈父」と云つた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし子供のような心で門下に集まる若い者には、あらゆる弱点や罪過に対して常に慈父の寛容をもって臨まれた。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし先生は、「むだ」や「余白」だらけのだらしのない弟子たちに対して、真の慈父のような寛容をもって臨み、そうしてどこまでも懇切にめんどうを見てやるのに少しも骨身を惜しまれなかったように見える。",
              "citation": {
                "source": "田丸先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "賢い少女の黒髪と、慈父の首と懐かしい……春春は土と草とに新しい汗をかゝせる。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ儂や親愛なる慈父母あり、人間の深情｜親子を棄てて、また何かあらん。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "願う、余の慈父と師友との祈祷空しからずして、この著のさらに世の憂苦を除き去るの一助として存せんことを。",
              "citation": {
                "source": "基督信徒のなぐさめ",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙台で生まれて、維新の時には国事に奔走して、明治になってからここに来て、病院を建てて、土地の者に慈父のように思われたという人の石碑もあった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども思え、いたずらに哭して慟して、墓前の花に灑ぎ尽したる我が千行の涙、果して慈父が泉下の心に協うべきか、いわゆる「父の菩提」を吊い得べきか。",
              "citation": {
                "source": "父の墓",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "慈父の手に縋るようにして帰って来ます。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は果して慈父に取り縋るような、しおしおした目をして、しばらく庸三を見詰めていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "みすみす大家に損をしろというようなことはなり立たないという厚生省のいわれたのは、大家にとって慈父の言であろうが、厘毛をあらそう小商人さえ配給員となって、三十五円、四十円の月給とりで国策にそおうという今日、家主も国家的任務を自覚させてもらうことについて異議はなかろう。",
              "citation": {
                "source": "私の感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父には、慈父の直感で、私のその生来の弱点が見抜けて、それを心配していたのではあるまいか。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "がこれは果して慈父の愛に欠けていなかったであろうか？",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "見分が済んで、鵜殿吉之丞から西丸目附松本助之丞へ、酒井家留守居｜庄野慈父右衛門から酒井家目附へ、酒井家から用番大久保｜加賀守忠真へ届けた。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この犬どもにとってノズドゥリョフは、さながら一家の慈父そのままであった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察部長は或る意味に於いてこの市の慈父であり、恩人であった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがためにわざわざ、あの、読者には先刻お馴染の、この市の慈父であり恩人であるところの警察部長の邸で集会が催されることになったのである。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十章　読者には先刻お馴染の、この市の慈父であり恩人であるところの警察部長の邸に集まった役人連は、ゆくりなくも、重なる不安と焦燥からげっそり痩せ細った顔を、互いに見合わせた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "今では私は博士を啻に恩師としてでなく、慈父のように慕っているのだ。",
              "citation": {
                "source": "血液型殺人事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "集まるものはことごとく少壮の士、ふきだしそうな血は全身におどっている、その欝勃たる客気はなにものかにふれると爆発する、しかも今や涙をもって慈父のごとく敬愛する校長とわかれんとするのである。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "その慈父のやうなやさしい慰めと介抱とに対して、スタンレーは感謝の涙にくれました。",
              "citation": {
                "source": "アフリカのスタンレー",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――おい、岡部伍長と工藤上等兵は、大分疲労しておるようじゃから、皆で、よくいたわってやれ」　加瀬谷少佐は、慈父のような温いことばをそこに残して、立ち去った。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それか有らぬかこれらの者は、ちょうど慈父でも慕うように、私を慕うのでございました。",
              "citation": {
                "source": "正雪の遺書",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "己天下に深き恨み無しと雖も慈父の憤りを継げるのみ。",
              "citation": {
                "source": "正雪の遺書",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……しかし然うだ、青年の煩悶を、旨く解決してやったら、慈父のような人間だと云われてもよかろう）　で、私は青年へ云ってやりました。",
              "citation": {
                "source": "さまよう町のさまよう家のさまよう人々",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "波木井殿に対面ありしかば大に悦び、今生は実長が身に及ばん程は見つぎ奉るべし、後生をば聖人助け給へと契りし事は、ただ事とも覚えず、偏に慈父悲母波木井殿の身に入りかはり、日蓮をば哀れみ給ふか。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "六二　講論語、是慈父教子意思。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔譯〕論語を講ず、是れ慈父の子を教ふる意思。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "――おまえの悩める慈父アルフォンス・フランケンシュタインジュネーヴ、一七××年五月十二日」　この手紙を読むうち私の顔を見守っていたクレルヴァルは、はじめ手紙を受け取った時に表わした喜びが、絶望に変ったのを観て、驚いた。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "』の叫び共に贏ち得られたる　花々しきサアルブルックの捷利三十五サンチームにてシャルルロワで売つてゐる色鮮かなベルギー絵草紙青や黄の、礼讃の中を皇帝は、燦たる馬に跨つて、厳しく進む、嬉しげだ、――今彼の眼には万事が可い、――残虐なることゼウスの如く、優しきこと慈父の如しか。",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
