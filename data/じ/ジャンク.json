    "definitions": [
      {
        "index": 1,
        "gloss": "junk",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「あれですか、なに、あいつは、ジャンクに乗ってた時、一緒に働いてた船方でがすよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の中島にガルバをすえて、小船でサーモジャンクションを引っぱりあるいては、時々の水温の水平ならびに垂直分布を測った。",
              "citation": {
                "source": "池",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この橋から間もなく、河口の鵜の喉の膨らみのようになっている岸に、三層楼の支那の倉庫店がずらりと並び、河には木履型のジャンクが河身を埋めている。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャンクリストフ第三巻。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱や緑で塗り立てたジャンクがたくさんに通る。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士はその方をジロリと見ただけで、またすぐ沖合の灰色のジャンク船の片帆に視線はかえった。",
              "citation": {
                "source": "軍用鮫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "空からなりと、海面からなりと、一機の敵飛行機であれ、一隻の怪ジャンクであれ、向こうから近づけば、どんなことがあっても生かしては帰さぬ決心であった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつては確かに生きていたと思われる会社のジャンクにまみれた残骸のようなＭＩＴＳでは、女性が一人で催促の電話の対応に追われ、「アルテアは間違いなくそのうちに届く」と繰り返していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあちゃんの家の隣にはラジオ屋があり、この店で捨てられるジャンクはもっぱら彼の部品供給源となっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが西村によれば、秋葉原にはビジコン管という比較的安い撮像管がジャンクとして出回るようになっており、これならアマチュアでも手に入れることができるという。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした根性こそが、アマチュアの神髄ではないだろうか」（『ＣＱ ｈａｍ ｒａｄｉｏ』一九六九年四月号「ジャンクのビジコンを使った「アマチュア局用」テレビカメラの製作」）　だが松本にとっては、厄介な作業も覚悟しなければならないという警告こそが、最大の誘惑の言葉だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "表通りに大型電気店の立ち並ぶこのエレクトロニクスの街では、マニアにとってのおいしいネタは、電子部品やジャンクのあふれかえった裏通りにまず届いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "予備校に通うと称して、祭りの夜店のようないかがわしさと勢いにあふれた裏道の店を覗き回っていた当時、秋葉原にはＩＣ電卓のジャンクが出回るようになっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "松本が浪人時代を過ごした一九七二（昭和四十七）年ごろ、猛烈な勢いで電卓が小さく、安くなる中で、秋葉原にはすっかり時代遅れとなった初期のＩＣ電卓がジャンクとなって流れはじめていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "デジタル技術を経験してこなかった松本にとって、ＩＣ電卓のジャンクは格好の練習台だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "予備校の帰り、小遣いの範囲で収まるジャンクを買ってきて利用できる部品を抜き取り、松本は電卓の基本的な動作を実行する回路を作ってみた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "大半の出展者がジャンクから取った部品でどうにかやりくりして安く仕上げたシステムを並べている中で、早稲田大学の学生であるという西は、数百万円はするのでないかと思われるＨＰ製の機器を接続し、オルガンの自動演奏システムを組んで悦に入っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "前常念とのジャンクションから頂上までは本沢へ向って相当大きな雪庇がつづいていた。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……妾の袋は、ルスキー島から二海里ばかりの沖へ投げ込まれると間もなく、軍艦と擦れちがったジャンクに拾われたので、その船頭の女房の介抱で息を吹き返したんですってさあ。",
              "citation": {
                "source": "支那米の袋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七番のナターシャさんも同じジャンクで拾われていたし、パン屋のソニーさんも鯨捕り船だったかに拾われて来たのを、白軍の巡邏船が見付け出して警察に引き渡したんですって。",
              "citation": {
                "source": "支那米の袋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "淋しい山に取かこまれた港は基隆名物の濛雨におおわれて淡く、陸地にこがれて来た私達の眼前に展開され、支那のジャンクは竜頭を統べて八重山丸の舷側へ漕いで来た。",
              "citation": {
                "source": "梟啼く",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは近所にクラパム・ジャンクションと云う大停車場のある御蔭である。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "このジャンクションには一日のうちに、汽車が千いくつか集まってくる。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "船がウースン河へ這入り、岸の楊柳が緑青のような色に萌え、サンパンだのジャンクだのが河の上をノンビリと通っている風景は美しかった。",
              "citation": {
                "source": "支那の思出",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "救貧院はグランド・ジャンクション水道会社からの供給の他に、ポンプ井戸がその構内にあり、収容者はブロード・ストリートに水汲みに行くことは決して無かった。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "グランド・ジャンクション会社は事業所（取水場）をチェルシーからブレンフォードに移し、そこに大きな沈殿池を作った。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことはハマースミスでテムズ川から取水しているウェスト・ミドルセックスも同様であり、ブレントフォードで取水しているグランド・ジャンクション会社も同様であった。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "グランド・ジャンクション社は、潮が届く範囲で人口が多いブレントフォードから水を受け取っていたが、会社は水を大きな貯水池に貯め、社員が言うところによると水を濾過していた。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
