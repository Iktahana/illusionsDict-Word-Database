    "definitions": [
      {
        "index": 1,
        "gloss": "(heavy) drinker",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三　三上戸　あるビルディングの二階にある某日本食堂へ昼飯を食いに上がった。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事をうかうか考えている自分を発見すると同時にまた、現在この眼前の食堂の中に期せずして笑い上戸おこり上戸泣き上戸｜三幅対そろった会合があったのだという滑稽なる事実に気がついたのであった。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「焼酎でも結構結構」と、焼酎五、六合に胡瓜の漬物を出して貰い、まだ一缶残っておった牛肉の缶詰を切って、上戸は焼酎をグビリグビリ、下戸は仕方がないので、牛肉ムシャムシャ、胡瓜パクパク。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮川君丈が上戸であとはみんな下戸であつた。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "――このことを、春松は、いつか千恵造の前でいい出して、それが酒をのんでいる時だったので、泣上戸の彼は泣き出したことがある。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣に親たちがいるので、彼もそれ以上戸を叩かず、すごすご帰って行くのだったが、いつもそれでは済まず、木槿の咲いている生垣を乗りこえ、庭へおりて縁の板戸を叩くこともあった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "五尺七寸の毛むくじゃらの男が、大汗かいて、念写する女性であるから笑い上戸の二、三の人はきっと腹をかかえて大笑いするであろう。",
              "citation": {
                "source": "女人創造",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見た老人の役人は、「おまえさんは泣き上戸と見える。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは笑い上戸で、泣いている人を見るとよけい笑えて来る。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣き上戸のおくの手が出るかな。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「上戸も死ねば下戸も死ぬ風邪」で、毒酒の美さに跡引上戸となつた将門も大酔淋漓で島広山に打倒れゝば、「番茶に笑んで世を軽う視る」といつた調子の洒落れた将平も何様なつたか分らない。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、たうとう我慢のならなくなつた笑ひ上戸の吉田が、※の締め殺されるやうな奇聲を上げて噴き出してしまつたので、それに釣り出されたみんなの笑ひ聲が堤の切れたやうにどつと迸つた。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いずれ、何か隠喰さ、盗人上戸なら味方同士だ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "千代若とも変な工合に親しくなり、蘆屋に帰る日もすくなく、急に笑い上戸になった……。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたはノッポやさかい、すぐ見つかる」　首だけ人ごみの中から飛び出ているからと、「千日堂」のお内儀さんは昔から笑い上戸だった。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一｜切合切投げいだせ、私ももとより泣き上戸。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまわりさんが国の女房や子供を干し上げて置いて、大きな顔をして酒を飲んで、上戸でもない爺いさんに相手をさせていた間、まあ、一寸楽隠居になった夢を見たようなものですな」と、頭をつるりと撫でて云った。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "気になるのは、昼間｜腕車が壊れていましょう、それに、伊予紋で座が定って、杯の遣取が二ツ三ツ、私は五酌上戸だからもうふらついて来た時分、女中が耳打をして、玄関までちょっとお顔を、是非お目にかかりたい、という方があるッてね。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大田黒は泣き上戸なのです。",
              "citation": {
                "source": "岬の春霞",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑い上戸のマア坊が叱られたのもそれでわかる。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣上戸に与ふいまこそ悲鳴を精一杯あげる時だ、いまこそ君の体から、肉の袋から悲しみをすつかり搾り出してしまふ時だよ、誰にむかつて君は悲しむことをはばかつてゐるのか――。",
              "citation": {
                "source": "小熊秀雄全集-5",
                "author": "詩集（４）小熊秀雄詩集２",
                "note": "青空文庫"
              }
            },
            {
              "text": "『甲陽軍鑑』一六に、馬に薬を与うるに、上戸の馬には酒、下戸の馬には水で飼うべし、馬の上戸は旋毛下り、下戸は旋毛上るとあり。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひつくりかへせば、果して上戸不知毒の五字あり。",
              "citation": {
                "source": "獨笑記",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "大箱とて、左右の石柱の絶壁、相距ること、ほぼ一町ばかりとなれる処に至り、釣り得たる「やまべ」を下物として、上戸は飲み、下戸は食す。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "上戸は酔うて陶然たり。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの家にもあるテレビ受像器のブラウン管の中では、じょうごの筒にあたる部分から打ち出された電子が、偏向コイルによって曲げられ、蛍光面上の狙ったところを光らせて像を作っている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒に酔えば泣きじょうご、痺れて手も足もばらばらになってしまいそうなこのいゝ気持。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　薬屋の亭主は一オンス入りの空壜と、小型のガラスのじょうごと、「じゃこうエッセンス」と書いた壜をだして、また魔法使いのような動作をはじめた。",
              "citation": {
                "source": "予謀殺人",
                "author": "A CASE OF PREMEDITATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるでじょうごに水でも流し込むようです。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "まぶしい光源に海水が勢いよく流れ込み、じょうごのように白い渦を巻き、はっきり見えたのは海水が深い穴に流れ込み、周りのすべてを渦の中に引き込んでいる。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
