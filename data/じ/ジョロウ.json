    "definitions": [
      {
        "index": 1,
        "gloss": "prostitute (esp. Edo period)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
