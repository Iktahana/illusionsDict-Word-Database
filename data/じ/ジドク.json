        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "乃ち屍を※燼中より出して、之を哭し、翰林侍読王景を召して、葬礼まさに如何すべき、と問いたもう。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲平はまだ江戸にいるうちに、二十八で藩主の侍読にせられた。",
              "citation": {
                "source": "安井夫人",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅竜は妙法院｜堯恭法親王の侍読にせられた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰も好し叔父杏坪が当主｜重晟の嫡子｜斉賢の侍読となつて入府するので、山陽は附いて広島を立つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "是より先春水は浅野家の世子侍読として屡江戸に往来した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "初め京都に入つて古義堂を敲き、後｜世子昌暢の侍読となつて江戸に来り、紀平洲等と交つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "九年四十二歳、世子｜正精侍読。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」門田朴斎は江戸にあつて儲君阿部正弘の侍読をしてゐたが、遠く思を水西荘に馳せて、「遙思三面闢窓処、寂寞迎春梅影疎」と云つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "門田家で此年朴斎が再び出でて誠之館教官兼侍読となつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "安政四年に江戸に遊学し、万延元年には江戸で容堂侯の侍読になり、同じ年に帰国して文館の助教に任ぜられた。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "頃之ニシテ妙法院親王ノ召ニ応ジテ侍読トナル。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "門田堯佐は福山侯阿部伊勢守正弘の侍読。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "今細井平洲の安永九年庚子の歳始めて尾公徳川｜宗睦に聘せられて侍読を命ぜられた時の待遇をその墓碑銘について見るに、座席は親衛隊のまさに列せられ廩米三百包を賜ったのである。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄恵は、彼らに利用されるのを、知ってか知らずにか、唯々として、それにも出席し、天皇の侍読に挙げられれば、それにもなった。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
