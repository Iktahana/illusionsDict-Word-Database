[
  {
    "uuid": "19fbd411-3205-56b4-aa62-ca6e44f7415b",
    "entry": "仁人",
    "reading": {
      "primary": "じんじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
