  {
    "uuid": "7c4b6157-2432-58ee-b6ae-19545d676dcb",
    "entry": "持明院統",
    "reading": {
      "primary": "じみょういんとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
