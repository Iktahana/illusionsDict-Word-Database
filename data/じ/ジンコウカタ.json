        "examples": {
          "standard": [
            {
              "text": "人口過多（じんこうかた）による食糧不足は、世界的な飢餓問題の根源となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "経済成長と並行して、一部の地域では人口過多が顕著な問題となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「将来、人口過多（じんこうかた）を解消するために、宇宙への移住が現実味を帯びてくるかもしれない。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "午後四時過ぎ、東京という人口過多の都会の心臓はその血を休養の為めに四肢へ分散するのか。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "又人口過多の結果（前八、七世紀）、地中海沿岸の殖民を見るに至つた。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
