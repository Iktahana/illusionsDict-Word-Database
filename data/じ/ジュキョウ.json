[
  {
    "uuid": "b845c782-93bd-5035-ad2b-c984dc8d95c4",
    "entry": "儒教",
    "reading": {
      "primary": "じゅきょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
