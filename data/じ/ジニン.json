[
  {
    "uuid": "2f4b8aa6-6340-528b-9ce5-2cbce623f69f",
    "entry": "自認",
    "reading": {
      "primary": "じにん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
