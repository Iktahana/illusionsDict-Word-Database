    "definitions": [
      {
        "index": 1,
        "gloss": "congestion (with blood)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
