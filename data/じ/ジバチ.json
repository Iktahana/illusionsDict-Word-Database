    "definitions": [
      {
        "index": 1,
        "gloss": "Vespula flaviceps (species of yellowjacket)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
