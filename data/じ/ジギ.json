    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "妻や女中たちが、玄関の畳に列び坐って、『お帰り遊ばせ』とお辞儀をする。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時、妻はわざわざ私の所へやって来て、『遅くなりますから、お先へ休ませて戴きます』と言う、丁寧に三つ指をついてお辞儀をし、それから自分の寝床へ入る。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と私は少しまごついてお辞儀した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "受持の時間に竹村君が教場へはいるときに首席にいる生徒が「気を付け」「礼」と号令をすると生徒一同起立して恭しくお辞儀をする。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」○「訣れの挨拶のお辞儀をしてしまってから、また立話をする。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪口を云われる方では辛抱して罵詈の嵐を受け流しているのを、後に立っている年寄の男が指で盆の窪を突っついてお辞儀をさせる、取巻いて見物している群集は面白がってげらげら笑い囃し立てる、その観客の一人一人のクローズアップの中からも吾々はいくらも故旧の誰彼の似顔を拾い出すことが出来るのである。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペエテルは腰を掛けてしまふと、一声うなつて、それから腮で辞儀をする。",
              "citation": {
                "source": "老人",
                "author": "GREISE",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の人も左の人も、辞儀が伝染したやうに、器械的に頷く。",
              "citation": {
                "source": "老人",
                "author": "GREISE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぢいさんは左へ一遍と右へ一遍と辞儀をする。",
              "citation": {
                "source": "老人",
                "author": "GREISE",
                "note": "青空文庫"
              }
            },
            {
              "text": "左でも右でも器械的に辞儀の真似をする。",
              "citation": {
                "source": "老人",
                "author": "GREISE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」お富はしとやかに辞儀して去こうとした。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とぺこぺこお辞儀をする。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "まアザッとこんな苦しいわけで……けれどつかい込みの一件は、ごく内密にお願いします」と言って立ち上がり、石井翁が何も言い得ぬうちに、河田翁は辞儀をペコペコして去ってしまった。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と庄屋の下婢は、いつもぽかんと口を開けている、少し馬鹿な庄屋の息子に、叮嚀にお辞儀をして、信玄袋を受け取った。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」杜氏は重ねてお辞儀をした。",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四郎は一寸お辞儀をして云いました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺三郎がエヘンエヘンとせきばらいをしながら幕の横から出て来て丁寧にお辞儀をしました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ジョバンニは、お辞儀をして台所から出ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大烏は二人を見て立ちどまって丁寧にお辞儀しました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大烏はすっかり悄気て翼を力なく垂れ、何遍もお辞儀をして「ありがとうございます。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蠍が沢山の手をついて平伏して薬をのみそれから丁寧にお辞儀をします。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとではあわててみんなお辞儀をしました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだお辞儀のしかたも習わないのだな。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は丁寧に王にお辞儀をいたしました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　けらいたちが一度に恭々しくお辞儀をしました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも風俗のかわった方がいらっしゃいますと、大事にしてお辞儀をすることだけは知ってでございますが、まだご挨拶をいたしませんね。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、お辞儀をお忘れかい。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにご覧なさいまし、お辞儀一ツいたしますさえ、あの通り大儀らしい。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前様はおかみさんだろう、柳屋のおかみさんじゃねえか、それ見ねえ、此方でお辞儀をしなけりゃならないんだ。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子は三度もお辞儀をした。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
