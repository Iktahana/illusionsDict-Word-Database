[
  {
    "uuid": "18b77628-0843-5fa1-91a7-e60bd6a3ee0b",
    "entry": "事宜",
    "reading": {
      "primary": "じぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fitting thing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "貴志余一郎殿、安見宅摩殿、臙脂屋と御取合下されて、万事宜敷御運び下されい。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞこゝに擧げ置くは、酒類は之を用ひる事宜しきを得ざる時は血行を亂すものであるから成る可く用ひぬが宜しい事、呼吸機能を完全に遂行する事、唱歌吟詠によつて、血行を催進する靈妙の作用の大有力なる事等の數點に止める。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時諸天｜偈を説いて曰く、頭を断たぬ内は殺したと言えぬ、また起ちて能くかくのごとき業を作す、事宜に随って他を損ずるも害と名づけず、白膠王の子を害したもののごとしと。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "何分新役のことだから、萬事宜しく頼む。",
              "citation": {
                "source": "死刑",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "断の一字あるのみ」「断の一字あるのみ」英雄｜胸膈非無策当見、赫々邦家新「新七、うまいぞっ」「ちぇすとう」勿言大業機未到精神一発｜起皇風況又大勢由人事宜将一死先群雄「然り然り、ただ一死を以て、天下に先んずるのだ」「まず、奸賊を倒して、吾が藩国を浄め、次に、王事に任じて、皇運の挽回に従うべし。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは策略は下手なんだから、万事宜しく頼む。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だつて、貴方が萬事宜しく願ひますと、叔父さんに仰しやつたんでせう」と云ふ。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "人事宜しく射の如く然るべし。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども害あるものもし用ゆる事宜しければ転じて利となる事無きに非らず。",
              "citation": {
                "source": "猥褻独問答",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに於いてか我が政府を始めとし、大日本公道会以下、民間特志の団体または個人に於いて、つとにこれが救済改善の事に努力せらるるもの多々これ有り、近く同情融和会の開催築地本願寺に於いて行われ、遂には帝国議会の建議とも相成り候う事、まことに事宜を得たる施策と、御同慶の至りに存じ候う。",
              "citation": {
                "source": "「特殊部落研究号」発刊の辞",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "子恋の森　武江｜遊観志略を見ると、その三月｜事宜の項に――。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして相生町の口入屋へ行つて見たが、保証人が入ると云ふので吉田由太郎（船頭）の宅へ引き返して事情を打ち開けて話して万事宜敷く頼む、父の方へは一切秘密にして置いて呉れる様にとくれ／″＼頼んで置いて、昼の十二時の蒸汽で引揚げた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はあ」「もう皆出勤していましょうから、御紹介申上げます」「万事宜しくお願い申上げます」「木下君以外に御存知の方がおありですか？",
              "citation": {
                "source": "負けない男",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大舟に乗った気でい給え」「万事宜しく頼む」　と、僕は斯うなると、菊太郎君に反対することが出来ない。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何卒万事宜しく頼む」　と本音を吹いた。",
              "citation": {
                "source": "嫁取婿取",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはな、首へ市蔵と書いたふだをぶらさげて、私は以来市蔵と申しますと、口上を云って、みんなの所をおじぎしてまわるのだ。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　夜だかはおじぎを一つしたと思いましたが、急にぐらぐらしてとうとう野原の草の上に落ちてしまいました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へは帰らずジョバンニが町を三つ曲ってある大きな活版処にはいってすぐ入口の計算台〔に居ただぶだぶの白いシャツを着た人に〕おじぎをしてジョバンニは靴をぬいで上りますと、突き当りの大きな扉をあけました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニはすぐ入口から三番目の高い卓子に座った人の所へ行っておじぎをしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニはおじぎをすると扉をあけてさっきの計算台のところに来ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニは俄かに顔いろがよくなって威勢よくおじぎをすると台の下に置いた鞄をもっておもてへ飛びだしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニは何も云へずにたゞおじぎをしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶次郎がぽいっとおじぎをしましたから私もしました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾度となくおじぎをしては私を見上げる彼の悲しげな眼を見ていた私は、立って居室の用箪笥から小紙幣を一枚出して来て下女に渡した。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "向ふの方ではお母さんたちが心配さうに手をかざしてこっちを見てゐましたが、やがて一寸おじぎをしました。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は振り返って見ますとその鼠色の旅人も笑ひながら帽子をとっておじぎをして居りました。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」おじぎをしたのでこの人はもう行かうとする。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺三郎が二人の前に来て、丁寧におじぎをして云いました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二人もおじぎをしてうちの方へ帰りました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へは帰らずジョバンニが町を三つ曲ってある大きな活版処にはいってすぐ入口の計算台に居ただぶだぶの白いシャツを着た人におじぎをしてジョバンニは靴をぬいで上りますと、突き当りの大きな扉をあけました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
