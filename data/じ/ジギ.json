  {
    "uuid": "2521b161-6ce9-58c4-9efa-90c192004090",
    "entry": "辞儀",
    "reading": {
      "primary": "じぎ",
      "alternatives": [
        "じんぎ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
