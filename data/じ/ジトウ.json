[
  {
    "uuid": "c7e486e4-19c6-504b-8961-8466712b9ffa",
    "entry": "地頭",
    "reading": {
      "primary": "じとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
