    "definitions": [
      {
        "index": 1,
        "gloss": "one's own style",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――そして兎に角にも自己流の珍らしい建築を完成した。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼が石を集め、苔を植ゑて庭を造り楽しむ時、しばしばその自己流の道楽芸が専門の庭園師を嘆息させるほど、真にユニイクな芸術創作となるのである。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "後にも例解する如く、蕪村は支那の故事や漢語を取って、原意と全く無関係に、自己流の詩的技巧で駆使している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし蕪村一流の技法によって、これを全く自己流の表現に用いている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも例えば長母音を勝手に二音に数えたり、重母音を自己流に分けたり合したりすると短歌と同じ口調に読めるものが多数にある。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自分が以下に試みに随筆的に述べてみたいと思う自己流の俳句観のはしがきのような意味で、やはり自己流の俳句源流説を略記して一つには初心読者の参考に供し、また一つには先輩諸家の批評を仰ぎたいと思うのである。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "付言　以上は自分の自己流の俳句観である。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "発音は自己流でいいかげんのものであるが、およその体裁だけはわかるであろう。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし「涼しさは暑さとつめたさとが適当なる時間的空間的週期をもって交代する時に生ずる感覚である」という自己流の定義が正しいと仮定すると、日本における上述の気候学的地理学的条件は、まさにかくのごとき週期的変化の生成に最もふさわしいものだといってもたいした不合理な空想ではあるまいかと思うのである。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尺八の稽古といえば、そのころ村に老人がいまして、自己流の尺八を吹いていましたのを村の若い者が煽てて大先生のようにいいふらし、ついに私もその弟子分になったのでございます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども元大先生からして自己流ですから弟子も皆な自己流で、ただむやみと吹くばかり、そのうち手が慣れて来れば、やれ誰が巧いとか拙いとかてんでに評判をし合って皆なで天狗になったのでございます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと後に先生が留学から帰って東京に住まわれるようになってから、ある時期の間は、ずいぶん頻繁に先生のお宅へ押しかけて行って先生のピアノの伴奏で自己流の演奏、しかもファースト・ポジションばかりの名曲弾奏を試みたのであったが、これには上記のような古い因縁があったのである。",
              "citation": {
                "source": "田丸先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者はかつて「郷土望景詩」の或る詩篇で、一種の自己流な漢文調から、独逸語に似た詩韻を出そうと試みた。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人に頼まれて書を書く事もあるが、自己流で、別に手習いをした事は無い。",
              "citation": {
                "source": "文士の生活",
                "author": "夏目漱石氏−収入−衣食住−娯楽−趣味−愛憎−日常生活−執筆の前後",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学というものは、その難解な自然を、おのおの自己流の角度から、すぱっと斬っ（たふりをし）て、その斬り口のあざやかさを誇ることに潜んで在るのではないのか。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "文人は文人で自己流の文章を尺度にしてキチンと文体を定めたがッたり、実に馬鹿馬鹿しい想像をもッているのが多いから情ないのサ。",
              "citation": {
                "source": "ねじくり博士",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ拍子の当りが確か過ぎるのを只圓翁が嫌って、今一層向上させるべく鞭撻していたのを後人が、自分の力の足りなさから、自己流に解釈して、芸道を堕落させたものに相違ないのである。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句の一般的な理論的考察は他日に讓るとして、茲では與へられた「天文と俳句」の題目の下に若干の作例を取上げて、前述の如き自己流の見地から少しばかり評釋を試み度いと思ふ。",
              "citation": {
                "source": "天文と俳句",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "調子に乗ると、手拍子が張扇子になって、しかも自己流の手ごしらえ。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、其方は先王古聖の訓えを差し置いて自己流で行うことを願う、なぜに其方は非を用いて是とし、是を以って非とすることなのだと分らないのか、先王古聖の訓えを無視しては、過ちが多くなり、悔いても取り返しがつかない。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "碁・将棋のような些細な技においてすら、自己流では上達せず、昔の定石を学び、昔の名人上手の碁譜棋譜を究めることに努める者の方が、上達が遅いようでいて実は早いのである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば下層社会の低劣な品性の如きも教育の不備よりはむしろ精神欠陥に帰し、一時好んで下層社会に出入するやライフの研究者を任ずると共に下層社会に共通する悪俗汚習の病因たる精神欠陥を救うの教師を自任し、細さに下級の生活状態を究めて種々の自己流の精神医療の方法を案出して試みた。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「煙リモ見エズ　雲モナク……」　彼は全く自己流の怪し気な口調で喚きながら、玄関にのめり込んだ。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "溺れて死ぬまいとする婦人たちは、子供たちをかばいながら、そのためにあがきは一層不自由になり、疲れを早めながら、みんな自己流に水をかいて、やっと水面から顔をあげている。",
              "citation": {
                "source": "『この果てに君ある如く』の選後に",
                "author": "――ここに語られている意味――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「十月」を自己流に考えて得だと思ったから、革命的な貧農と共に、のり越えた。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村八段はそこで、「上手に対して飛車落ち程度でさせるようになると、そろそろ定石を無視して自己流の差し方をするものであるが、それは厳重に慎まねばならぬ。",
              "citation": {
                "source": "名人上手に聴く",
                "author": "野呂栄太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己流の業には相違ないが、それにしても恐ろしい奴だ。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "強情で頑固なところが最進智識をすこしも求めようとしないで、自己流の工夫でコツコツやるのだった。",
              "citation": {
                "source": "木魚の顔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
