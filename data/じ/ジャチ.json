    "definitions": [
      {
        "index": 1,
        "gloss": "knowledge applied to evil purposes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
