    },
    "definitions": [
      {
        "index": 1,
        "gloss": "office",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "學校の廊下には、べたべた推薦のビラが張られて、選擧事務所なども、ものものしく、或るものは校門の下に立つて、登校の生徒ひとりひとりに名刺を手交し、よろしくたのみます、といつて低くお辭儀をして、或るものは、中學校の先輩といふ義理のしがらみに依つて、後輩を威嚇し、饗應、金錢、などといふばかな噂さへ立つた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時彼は代議士の選挙運動事務所に学校の道場を使ふが好いかと校長に申出た。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "駐在所は会社の事務所に注意した。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「私は、今｜事務所から、こちらで働らけと云われてやって参りました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「事務所へ泊りました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この専制君主的な儀礼の門を潜って、ロダンさんが事務所で入場券をお求めになると、妾達はこの悪徳による王国の財政の基礎の中に這入って行ったのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "三階のマネキンの事務所では、競馬馬のような女の舞台女優気どりの饒舌がきこえてきた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がホテルの寝床からそのまま父の輸出綿花事務所へやってくると、夜の疲労をぬりかくした、濃化粧したタイピストが電話機の電鍵を敲くように、昨夜の記憶を白紙にうずめていた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨今の上海投機の気まぐれで、銀塊相場を有史以来の崩壊に導いた、その余波のためにこの輸出綿花事務所は不況のどん底にいた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "向いのＮ万ビルのマネキン事務所には、アメリカン・スタイルの女たちが地面にカードをひろげたように、緋の絨氈の上でお化粧を始めていた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が出たあと、半年ほどして、山漢社長はつゞまりがつかなくなって事務所にも、バラックにも、火をつけて焼いてしまったという話だ。",
              "citation": {
                "source": "自伝",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "火を入れた二番口の醤油を溜桶に汲んで大桶へかついでいると、事務所から給仕が健二を呼びに来た。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕にかゝった醤油を前掛でこすり／＼事務所へ行くと、杜氏が、都合で主人から暇が出た、――突然、そういうことを彼に告げた。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "松雲閣の玄関からそのまゝ事務所へ廻りみちして支配人の福地第三郎君に会った。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹太郎は事務所の方へ歩いた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "王洪吉ら五人は、夕方、おずおずと、事務所へ這入った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿舎からは、工人の金属的な、激昂した声が、やかましく事務所の方へもれて行った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」俺はそういって歩き出した――しかしこのために、俺は近々事務所を首になるかもしれない。",
              "citation": {
                "source": "防備隊",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "杜氏は、醸造場へ来ると事務所へ与助を呼んで、障子を閉め切って、外へ話がもれないように小声で主人の旨を伝えた。",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　三十分のタバコがすむと、仁助は事務所から出て来て、労働者にそれぞれ仕事を命じた。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」焚き火の方へ行こうとして事務所からやって来た仁助がきいた。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃坑春ちかけれど坑々の、　　　　祠は荒れて天霧し、事務所飯場もおしなべて、　　鳥の宿りとかはりけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、おかしいことには、これと同日同所で見せられたアメリカ映画「流行の王様」に、やはり同様に破産した事務所の家具が運び出される滑稽な光景がある。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「私は、今事務所から、こちらで働らけと云はれてやって参りました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、この事務所の書記の数はいつもただ四人ときまつてゐましたから、その沢山の中で一番字がうまく詩の読めるものが、一人やつとえらばれるだけでした。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもこの事務所では、何せ事務長が黒猫なもんですから、このかま猫も、あたり前ならいくら勉強ができても、とても書記なんかになれない筈のを、四十人の中からえらびだされたのです。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな事務所のまん中に、事務長の黒猫が、まつ赤な羅紗をかけた卓を控へてどつかり腰かけ、その右側に一番の白猫と三番の三毛猫、左側に二番の虎猫と四番のかま猫が、めいめい小さなテーブルを前にして、きちんと椅子にかけてゐました。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務所の扉をこつこつ叩くものがあります。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが今のおはなしからちやうど半年ばかりたつたとき、たうとうこの第六事務所が廃止になつてしまひました。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、ふたりで、明智たんていじむしょへいそぎました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
