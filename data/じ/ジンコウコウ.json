        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "沿岸部の開発が進み、大規模な人工港（じんこうこう）が建設されることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "人工港は、天然の良港が少ない地域において、物流の拠点として不可欠な存在だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この人工港（じんこうこう）のおかげで、多くの貨物船が安全に停泊できるようになりました。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
