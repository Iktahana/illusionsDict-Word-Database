[
  {
    "uuid": "b00dd915-594e-5573-b058-0ddd5fc0b15b",
    "entry": "事案",
    "reading": {
      "primary": "じあん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
