[
  {
    "uuid": "d4c94f94-358d-58cb-94af-a46c019c2200",
    "entry": "地味",
    "reading": {
      "primary": "じみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
