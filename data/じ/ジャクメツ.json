    "definitions": [
      {
        "index": 1,
        "gloss": "achieving nirvana",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
