        "examples": {
          "standard": [
            {
              "text": "人生朝露のごとし、悔いのない日々を送りたいものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の急逝は、人生朝露の儚さを改めて知らしめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "若くして亡くなった友を見て、まさに人生朝露だと感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "人生朝露のごとしといえあまりのことに自分は自失しそうだと書いてあった。",
              "citation": {
                "source": "睡蓮",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生朝露、感慨深いものを感じた。",
              "citation": {
                "source": "赤げっと　支那あちこち",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一口に人生朝露の如しと言うが、たださえ妻を失ってその感を深くしている現在の私は更に一層感慨無量ならざるを得なかったのであった。",
              "citation": {
                "source": "逗子物語",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
