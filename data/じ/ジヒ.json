    "definitions": [
      {
        "index": 1,
        "gloss": "lady-in-waiting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
