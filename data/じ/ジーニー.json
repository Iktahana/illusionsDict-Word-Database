        "examples": {
          "standard": [
            {
              "text": "彼は、Oracleが開発した分散コンピューティングプラットフォーム「ジーニー」について調べている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ジーニー」アーキテクチャは、ネットワーク上のデバイス連携を容易にする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "開発者たちは、「ジーニー」のAPIを使って、新しいサービスを構築しようとしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "一九六八年、ジーニー・Ｃ・ライリーがうたった『小さなこと』は、次のような内容だった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじくジーニー・Ｃ・ライリーの『ダラスの裏通り』では、さびしくひとりで生きる女性が娼婦になっていく歴程が、うたわれていた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
