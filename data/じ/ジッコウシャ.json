[
  {
    "uuid": "3dff9949-19a1-5688-9f33-64ccfa37cf7e",
    "entry": "実行者",
    "reading": {
      "primary": "じっこうしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
