        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "飛田遊廓を中心にしてこの地帯はほぼ焼け残っているのだが、昔はたぶん安サラリーマンの住宅地帯であったろう。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "道頓堀罷り通る",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争の焼跡を利用して、都市計画を実施し、大道路を新設したり、工場地帯、緑地帯、住宅地帯を区劃する。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日妻が、グリンベイという、シカゴとその北部の住宅地帯とを結ぶ、一番賑かな通りで、雉子が轢かれて死んでいるのを見たと言っていた。",
              "citation": {
                "source": "シカゴの雉子",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "街から外れて、住宅地帯へ入つて、両側に大きな邸宅の並んでゐるだら／＼坂を下り出した。",
              "citation": {
                "source": "四人",
                "author": "芥川多加志",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを過ぎると再び中産階級の住宅地帯である。",
              "citation": {
                "source": "四人",
                "author": "芥川多加志",
                "note": "青空文庫"
              }
            },
            {
              "text": "下町に対する山の手で、そう言や、四の橋の、俺のおやじの工場のあった、あのきたない川沿いも山の手だが、普通、山の手と言うときは、屋敷町――高級住宅地帯のイメージをともなっていたものだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
