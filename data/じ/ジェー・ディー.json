    "definitions": [
      {
        "index": 1,
        "gloss": "female university student",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "続いて私はランドフスカ夫人の入れた「クラヴサン組曲」を挙げたい（ビクターＪＤ九四五―五〇）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ曲をコルトーがピアノで弾いたのもある（ビクターＪＤ一六七四）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌　歌は「感謝の歌」をバリトンのヒュッシュ（ビクターＪＤ一五八三）とソプラノのラシャンスカ（愛好家協会第五集、「アリオーソ」の題目で）が入れている。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ラルゴー」はヘンデルの看板のような歌だが、ポリドールのシュルスヌス（六〇一八三）かビクターのジーリ（ＪＤ一七一）などがよかろう。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビクターには、ブッシュの指揮したのが四曲｜揃っている（ＪＤ一〇四六―五一並びにＪＤ一〇五二―六）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴァイオリン・ソナタ　六曲の無伴奏ヴァイオリン・ソナタ（並びにパルティータ）は、チェロの組曲と共に、バッハの器楽曲の双璧であるが、そのうちの優れたレコードは、「第一ソナタ＝ト短調」のメニューイン（ビクターＪＤ一二四七―八）を挙ぐべきであろうか。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「第二ソナタ＝イ短調」はコロムビアのシゲティーが当然良く、「第二パルティータ＝ニ短調」は同じくメニューイン（ビクターＪＤ七四〇―三）とハイフェッツ（同上ＪＤ一五九三―六）が対立する。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「第三ソナタ＝ハ長調」もメニューインのがある（ビクターＪＤ一五〇八―一〇）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは弦楽四重奏に編曲したものを、コロムビアにロート弦楽四重奏団が録音し（Ｓ一〇一三―二二）、一つは弦楽合奏用に編曲したものをディナー教授がコレギウム・ムジクム合奏団を指揮してビクターに入れている（ＪＤ一五二一―三〇）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピアノ協奏曲「ピアノ協奏曲＝ニ短調」はオリジナルの曲ではないが、フィッシャーの演奏したビクター・レコードは美しい（ＪＤ四二一―三）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二台のピアノのための協奏曲＝ハ長調」はシュナーベル父子のがビクターにあり（ＪＤ一二八九―九一）、楽しき限りのレコードである。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イタリー協奏曲へ長調」はランドフスカのクラヴサン（ビクターＪＤ一二四二―三）と、シュナーベルのピアノのがある（ビクターＶＤ八一一五―六）が、シュナーベルほどの名ピアニストを煩わしても、これはランドフスカのクラヴサンの古朴な面白さに及ばない。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ゴールドベルク変奏曲」はバッハの作品中でも大物だが、この貴人の眠りを誘うために作られたという伝説を有する曲も、ランドフスカのクラヴサンの名演奏で聴くとこよなくも楽しい（ビクターＪＤ二七一―六）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「半音階的幻想曲と遁走曲ニ短調」もランドフスカのクラヴサンのと、ドルメッチのクラヴィコードのと、フィッシャーのピアノのと三通りあり、それぞれに美しくもあり興味もあるが、この曲の魅力的な美しきを味わうためには、ランドフスカのクラヴサンをもって第一とするだろう（ビクターＪＤ八〇一―二）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろトスカニーニの指揮した「時計シンフォニー」（ビクターＪＤ一四九五―八）、ワルターの指揮した「軍隊シンフォニー」（コロムビアＪＳ三八―四〇）並びに「オクスフォード・シンフォニー」（コロムビアＪＳ一一七―九）などを採るべきであろうか。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランドフスカ夫人の「クラヴサン協奏曲ニ長調」も逸することの出来ないものだろう（ビクターＪＤ一三一六―八）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「交響曲第四十番ト短調Ｋ五五〇」は一脈の哀愁を湛えて、しばしば「ジュピター」より好ましいとする人のある曲であるが、レコードではビクターのトスカニーニがＮ・Ｂ・Ｃ交響管弦団を指揮したのが白眉であろう（ＪＤ一七二〇―二）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイフェッツは（ビクターＪＤ三七八―八一）吹込みも新しく手際も見事だ。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ピアノ協奏曲第二〇番ニ短調Ｋ四六六」はフィッシャーのがある（ビクターＪＤ三一五―八）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "女性らしい思いやりのある、巧緻な演奏である（ビクターＪＤ一〇七六―九）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ曲をハイフェッツとベイの組合せで入れた、歯切の良い冷美さと比べて見るがよい（ビクターＪＤ一三二九―三一）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイフェッツとベイの入れているもう一つの「ソナタ＝変ロ長調Ｋ三七八」は技巧的には玲瓏たる良さを持ったもので、この享楽的とさえ見える、縦横無礙の美の追及者の若い作品を、ハイフェッツの人間離れのした冷たい技巧でひきまくる快さは非凡だ（ビクターＪＤ一〇二一―二）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な「トルコ行進曲ソナタＫ三三一」は四種か五種レコードされているが、ビクターのフィッシャー（ＪＤ三六七―八）とポリドールのケンプ（四五二三一―二）で代表される。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "コロムビアにレナー四重奏団とドリヴェラのがあり（Ｊ七七六三―六）、ビクターにプロ・アルテ四重奏団とホブディのがあるが（ＪＤ三七一―四）、情緒的で甘美な前者と、理知的で素気ない後者と好み好みがあろう。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番古いのはレナー四重奏団とドゥレーパーの組合せ（コロムビアＪ七四五一―四）、次はブダペスト四重奏団とベンジャミン・グッドマンの組合せ（ビクターＪＥ一六七―九、ＪＤ一三七四）、一番新しいのはロート四重奏団とベリスンの組合せである（コロムビアＪＷ二〇三―六）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いてビクターのトスカニーニがＢ・Ｂ・Ｃを指揮したのは、やや古いが胸のすく演奏だ（ＪＤ一五四六―九）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビクターに入ったトスカニーニのＮ・Ｂ・Ｃを指揮した「第五」（ＪＤ一六二―四）は、反響を取り去った不思議な録音と、素気ないうちに、クライマックスに盛上げていく燃え立つような力と、ややテンポの速い古典的な端正さのうちに、一種の気魄と情熱を包んだ演奏はすばらしい。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「第七シンフォニー＝イ長調作品九二」はトスカニーニがニューヨーク・フィルハーモニック管弦団を指揮したレコードを推す（ビクターＪＤ八一九―二三）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
