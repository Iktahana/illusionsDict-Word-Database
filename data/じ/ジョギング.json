        "examples": {
          "standard": [
            {
              "text": "毎朝、公園でジョギングをしています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "健康維持のために、ジョギングを始めました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "週末は、友人たちと海岸沿いをジョギングするのが楽しみです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ジョギングをする男性は苦痛に堪える充実した表情。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたサイズほど大きいジョギング・シューズに黒いショート・パンツ、そして赤いＴシャツを、彼は着ていた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョギング・ショーツに、肩ひもの細い、紫色のタンクトップ、片手で髪をかきあげ、もういっぽうの手を、フェリーにむかって振っている。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "タンクトップの胸のふくらみがいいし、ジョギング・ショーツからのびている脚が、すんなりと、しかも、力を秘めている。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗せて」「その格好では、無理だ」　タンクトップにペラペラのジョギング・ショーツのミーヨを、ぼくは指さした。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
