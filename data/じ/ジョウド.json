    "definitions": [
      {
        "index": 1,
        "gloss": "soil",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "砂壌かなたに受くるもの、　　多くは酸えず燐多く洪積台の埴土壌土と、　　　　植物群おのづとわかたれぬ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨が降り続けば沼になり、炎天が続くと、粘質壌土は荒壁のように亀裂が立った。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "粘質壌土ではあり、土鼠穴は十分に塞いだつもりだったので、これ以上は手の下しようが無かった。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　粘質壌土の田圃の一部が掘崩されて、其処に小さな水揚げ水車が拵えられた。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一｜尋もあるかと思われる黒い壌土の層が、水気をふくんだうるみ顔をこちらに向けている。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
