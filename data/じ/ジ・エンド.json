        "examples": {
          "standard": [
            {
              "text": "激しい戦いの末、ついに物語はジ・エンドを迎えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「これで全てが終わった、ジ・エンドだ！」彼は絶望の淵で呟いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "映画のラストシーンで、強烈な印象を残すジ・エンドのテロップが表示された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "すなわちスクルージ・エンド・マアレイと云うように。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "この商会はスクルージ・エンド・マアレイで知られて居た。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、それはしかたが無いとして、その童貞……つまり、せつかく男に生れついてだな、このヘタをすると一人前の人間になりきれないままで、ジ・エンドだぞ。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
