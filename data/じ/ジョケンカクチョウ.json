    "definitions": [
      {
        "index": 1,
        "gloss": "extension of women's rights",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
