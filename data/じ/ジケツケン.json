          "standard": [
            {
              "text": "全ての民族は、自らの政治的地位を決定する先住民族としての自決権を有している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "国際連合の憲章には、人民の自決権を尊重することが明記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自分の体の扱いや治療方針を自分で決める権利も、広義の自決権に含まれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "英国トーリー党は欧州における自決権を守ろうとする一方インドでのそれには反対しており、それでいて一貫性を欠くとは感じていない。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
