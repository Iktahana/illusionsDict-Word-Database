        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ジュバン（襦袢）などになると完全に時効にかかってしまって外来臭を脱している。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえりに西川、三越へよって夜着ジュバンを買う。",
              "citation": {
                "source": "日記",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の誕生日、大変暖い日で毛のジュバンぬぐ。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "巣鴨へ、夏がけ、麻ネマキ、大島ひとえ、麻半ジュバン、もってゆく。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "塚田はそれから眼鏡をとつてジュバンの袖でふいてゐる。",
              "citation": {
                "source": "勝負師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンコ型の力士は健康なものではなくて病的なものだから、我々男がふとった大女のジュバンの相撲などに興味がもてないように、女には男の相撲に興味がもてないのかも知れない。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、ジュバン一枚の大女の相撲が浅草に現れても人気を博すとは思われないが、ストリップ・ショオが人気を博すのはうなずくことができる。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "袖の短いシャツのような白ジュバンに白パンツをはき、頭髪をキリリと手拭で包んでいる。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その六　血を見る真珠",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはフランスのランジュバンが初めて巴里の大気中で発見したので、発見者の名をとってランジュバン・イオンと呼ばれている。",
              "citation": {
                "source": "雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "比較的低い所、例えば地上二千米まで位の大気中で水蒸気の凝縮が起る時は、その核となるものは細塵とこのランジュバン・イオンであろうと思われている。",
              "citation": {
                "source": "雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一枚の単衣の方はさし当り、去秋（九月中旬）お送りしてかえらず、そちらにあるメイセン絣ペナペナだけれども、今ごろジュバンの上へお着になれます、どうぞそれを着ていらして下さい。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "下着類は、人絹シャツ三枚同ズボン下二枚、麻半ジュバン等お送りしました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　ボルドーの高等法院長であったラジュバトンのことだという説と宰相ミシェル・ド・ロピタルだろうという説とある。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
