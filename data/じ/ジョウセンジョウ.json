        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三津ヶ浜というのは松山藩時代の唯一の乗船場で、私たちが初めて笈を負うて京都に遊学した頃はまだこの三津ヶ浜から乗船したものであった。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗船場まで行くには、林をつき切って二キロメートル歩かなければならなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗船場へ大急ぎで駆けつけなければならなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし乗船場まではまだかなりあった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗船場に行くと、こう言われた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし次の乗船場で、優美な貴婦人が乗り込んで近くにすわると、彼女はすぐに元気になって、感傷的な上品なことをクリストフに言おうとつとめた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
