[
  {
    "uuid": "6eb374b1-688e-5d3e-a447-69bc2dd1efa6",
    "entry": "常時",
    "reading": {
      "primary": "じょうじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
