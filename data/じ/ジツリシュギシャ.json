        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれども、山高きが故に貴からず、樹木あるが故に貴し、とか、いやに興覚めなハツキリした事を断言してはばからぬ実利主義者もあるのだから、津軽の人たちは、敢へてその山脈の低きを恥ぢる必要もあるまい。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一面情熱的な理想家、人類改善の使命の自覚者である彼が他の一方では極めて実務家で、理想の懐疑者、「原論」の嫌悪者、実利主義者である。",
              "citation": {
                "source": "微妙な人間的交錯",
                "author": "――雑誌ジャーナリズムの理想性と現実性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れつきの実利主義者であった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、彼は古文書などに全く趣味のない実利主義者でした。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな心の醜悪な人間も、実利主義者も、また悪人も、ロマンチシストであったのです。",
              "citation": {
                "source": "童話の詩的価値",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
