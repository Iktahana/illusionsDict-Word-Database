    "definitions": [
      {
        "index": 1,
        "gloss": "camp (supporters of a doctrine, party, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
