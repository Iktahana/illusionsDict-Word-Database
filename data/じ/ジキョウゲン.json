      {
        "index": 1,
        "gloss": "local amateur kabuki performance (esp. popular in the late Edo and early Meiji periods)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
