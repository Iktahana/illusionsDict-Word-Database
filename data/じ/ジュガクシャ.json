    "definitions": [
      {
        "index": 1,
        "gloss": "Confucian scholar",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
