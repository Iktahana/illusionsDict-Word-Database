[
  {
    "uuid": "bb8e847c-8b1a-5e06-bd0e-5a9701148d1a",
    "entry": "受容",
    "reading": {
      "primary": "じゅよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
