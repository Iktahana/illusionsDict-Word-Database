        "examples": {
          "standard": [
            {
              "text": "エスペラント語は、国際的なコミュニケーションを目的として作られた代表的な人工言語（じんこうげんご）だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、人工言語の構造を学ぶことに強い興味を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「いつか、世界中の人々が共通の人工言語（じんこうげんご）で話せるようになるといいな。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
