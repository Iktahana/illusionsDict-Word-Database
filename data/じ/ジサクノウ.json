    },
    "definitions": [
      {
        "index": 1,
        "gloss": "farming on one's own land",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "が昔から自作農であったことに変りはない。",
              "citation": {
                "source": "小豆島",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自作農は、直接地主から搾取されることはない。",
              "citation": {
                "source": "小豆島",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、五段歩ほど田を持っている自作農もいる。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで「吾々貧乏人は……」と云われても、五反歩の自作農は、自分にはあまり関係していないことを喋っているように思ったりするのである。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自作農で小作農も兼ねている。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "地主の娘と、小作兼自作農の伜との結婚は、家と家とが、つり合わなかった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "七年間に、彼は、全然の小作人でもない、又、全然の自作農でもない、その二つをつきまぜたような存在となった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見通しのきく自作農の竹さんは、土地をすっかり売ッぱらって都会へ出た。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小作人から、自作農に成り上って行こうと、あがいている者も僕の親爺一人に止まらなかった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自作農で破産をする人間、誰れもかれも街へ出て作り手がなく売りに出す人間、伊三郎が、又、息子の学資に畠の一部を売る場合――秋に入ると一と雨ごとに涼しくなる、そんな風に、地価は、一つの売出し毎に、相場がだん／＼さがった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "地主も、自作農も、麦が踏まれたことは、金が這入ることを意味する。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田と畠を頼母子講の抵当に書きこみ、或は借金のかわりに差押えられようとしていた自作農は、親爺だけじゃなかった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄兵衛も作右衛門も、藤太郎も、村の自作農の半分はそういう、つらいやりくりであえいでいた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな地主や自作農もあった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "地主も、自作農も、――土地を持っている人間は、悲喜｜交々だった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "源作は、村の貧しい、等級割一戸前も持っていない自作農だった。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　夜明け前から出掛けて行った父親の春吉が、山畑でひと仕事して帰って来た時は、大百姓の（それは大きな自作農であった）片岡の家に、日傭に行くので、先に食事を始めた菊枝が、ちょうど食事を終わったばかりのところだった。",
              "citation": {
                "source": "駈落",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而シテ日本ガ小農法ノ國情ナルニ考ヘテ之ヲ自作農ノ所有權ニ移シ以テ土地民有制ヲ取ルコトモ、日本トシテノ物質生活ヨリ築カルベキ幾多ノ理論ヲ有ス。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "小作人は地主の小作料に、自作農は拓殖銀行の年賦の拂込金にそれが成りあがつてしまつた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "二百町歩――Ｓ村所有田　百五十町歩――大学所有田・「学田」　百二十町歩――吉岡（旭川）　五百町歩――岸野（小樽）　二百町歩――馬場（函館）　二百十町歩――片山子爵（東京）　三百町歩――高橋是善（東京）外ニ、自作農五戸、百五十町歩。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを直接借りるのは自作農かが時々Ｈ町へ行くのは何んのためだか、知っているか。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "つひにある老いた自作農の家にそれが押しつけられた。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "沼波はこの村では裕福な部に屬する自作農である。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "┌収入　三二二円自作農　┤支出　四七七、八九　　　　└不足　一二五、八七　　　　┌収入　四〇四、八一自小作農┤支出　四八九、八五　　　　└不足　　八五、〇四　　　　┌収入　二五九、二三小作農　┤支出　三三六、六三　　　　└不足　　七七、四〇　平均、九十六円十一銭の不足である。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい自作農の息子が分家をするだけの経済力がないために結婚難に陥っていること、またそういうところの若い娘たちが、また別の同じような農家へいわば一個の労働力として嫁にもらわれ、生涯つらい野良仕事をしなければならないことを厭って、なるたけ附近の町かたに嫁ぎたがる心持。",
              "citation": {
                "source": "若き世代への恋愛論",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして見ると、直接農村に一般ラジオ加入者が多くなったとは云えず、寧ろ、中農、地主から没落した自作農等の相場への関心或は農産品仲買関係者が、米や繭の売買で幾分かは儲けてラジオでも引こうかという工合になっていることが推察されるのである。",
              "citation": {
                "source": "「ラジオ黄金時代」の底潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "農村のはてしない収奪と資本主義の高利貸搾取と二重の重圧によって祖先伝来の樹木さえ失い「樹のない村」となった山間のＫ部落の自作農らが、更に戦争の軍事費負担を加重される。",
              "citation": {
                "source": "一連の非プロレタリア的作品",
                "author": "――「亀のチャーリー」「幼き合唱」「樹のない村」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "自作農らはついに共同墓地の松の木を伐ってそれを出すことに決議したが、昭和二年の鉱山閉鎖以来共同植付苅入れをしている「やま連」と呼ばれる農村の集団的な労働者がそれをきっかけに、未組織のＫ部落における闘争に率先して立つことになった。",
              "citation": {
                "source": "一連の非プロレタリア的作品",
                "author": "――「亀のチャーリー」「幼き合唱」「樹のない村」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "部落は自作農ばかりだから、闘争組織は農民委員会であると規定し、「僕はいよいよ実行運動に入ろう」「時はあたかもウンカ問題で村会とこじれている」「やさしくなくとも僕はやる。",
              "citation": {
                "source": "一連の非プロレタリア的作品",
                "author": "――「亀のチャーリー」「幼き合唱」「樹のない村」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄米一石の生産費（昭和十二年度）自作農二五円八七銭　小作農二八円七一銭　現在の農村は事変以来二割近い手不足で甚だ困難している。",
              "citation": {
                "source": "新しき大地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
