[
  {
    "uuid": "772846bb-e5d0-5b34-ab97-dc7f9eebf90e",
    "entry": "自作農",
    "reading": {
      "primary": "じさくのう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
