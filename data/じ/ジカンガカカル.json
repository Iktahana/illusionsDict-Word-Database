    "definitions": [
      {
        "index": 1,
        "gloss": "to take time",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "役者が劇中人物に成り切るまでにはやはり相当な時間がかかるからである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鉛筆が、すつかり現れて、その慘めな姿をさらけだすまで、まだなかなか時間がかかることでせう。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　有楽町から自分の駅まではかなりの時間がかかる。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのＴへゆくまでがＭからだとＥからの二倍も三倍もの時間がかかるのであった。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "断崖のしたの海岸まで行くのには、どうしても、それだけの時間がかかるのである。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、岩滑新田と大野の間には峠が一つあるから、よけい時間がかかる。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "燃えはじめてから燃え尽きるまで、実に永い時間がかかるものだ。",
              "citation": {
                "source": "薄明",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰でも知っている通りサナダ虫は一｜丈も二丈もある上に、短かい節々のつながりが非常に切れ易いので、全部を引出し終るにはナカナカ時間がかかる。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして火葬にする前に、西谷にだけは、その顔だけでも見せてやり度かったのだが、それには相当の時間がかかるのだし、劇悪性の伝染病で一刻も早く火葬にしなければならないところから、それも出来なかった。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「随分時間がかかるんだね。",
              "citation": {
                "source": "秘密の風景画",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "弾が額を割っており、意識を取り戻すにはしばらく時間がかかるそうだ。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "追い込みや送りの操作に時間がかかること。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の前の商品開発が優先されるだろうから、この技術の公開にはもう少し時間がかかるだろう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆者は電子本の試みを「マルチメディア化には当面時間がかかるから、先ず手の付けやすい文章を取り込んでみた消極策」とはとらえない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにそもそも、一バイトで文字を表現できる英語圏で作ったものを、後からわけのわからない文字のごちゃまんとあるところに持ち込んで二バイト文字に対応させようとするから、難しい点が出てくるし手直しの時間がかかる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなりできの良い個人情報管理ツールのハイパーカードに全面的に依拠しきれないでいるのは、要するにオレのマックがしょっちゅう眠っており、こいつを起こそうとするとハードディスクを回し、メモリ・チェックをかけ、システムを読み込んでと、とんでもなく時間がかかるためだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＤＯＳの環境に手書きを持ち込むＣＩＣのＰｅｎＤＯＳに続いて、一九九二年四月にはＧＯのＰｅｎＰｏｉｎｔとマイクロソフトの Windows for Pen Computing がアメリカ市場で出荷となったが、市場で弾みがつくのにはまだ時間がかかるだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり、ゆうに百年単位の時間がかかるのではなかろうか。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、それには長い時間がかかる。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、何万フィートだか駆けあがって、また降りてくるわけだし、あっちこっちで、めったやたらとスウィッチングするから、時間がかかると思うよ」　ワラが、技術的注釈をほどこした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな風に二三本ずつ切って、これだけの太さの束にするには、よほどの時間がかかるだろう」「沢山の女から切り集めたのではないでしょうか？",
              "citation": {
                "source": "謎の咬傷",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "作家はいつの時代にでも、一つの段階からより成長した段階への移行に時間がかかる。",
              "citation": {
                "source": "両輪",
                "author": "――創造と評論活動の問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "書籍かり出しに、相変らず時間がかかると見えて、いつからそうなったのか、皮ばりの大長椅子が二列、三かわほど置かれ、そこにすき間なく閲覧者がかけて待っている。",
              "citation": {
                "source": "図書館",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩劇だから、科白は詩だが、この「射撃」に出演したメイエルホリド劇場の若手の俳優たちが、モスクワ芸術座の俳優のように鮮明な発音で朗読法をこなすまでには、大分時間がかかるという感じだった。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたは初産だから、ほかの人より時間がかかるんです……安心していらっしゃい」　そこへ、看護婦が入って来た。",
              "citation": {
                "source": "モスクワ日記から",
                "author": "――新しい社会の母――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん新世代のマイクロコンピューターが誕生しても、そのメリットを生かしたマシンが作られ、これに対応した言語やＯＳが用意され、その基盤の上でアプリケーションが書かれるまでには時間がかかる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
