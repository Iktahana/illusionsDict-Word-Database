        "examples": {
          "standard": [
            {
              "text": "運動場の隅で、小さな塵旋風が舞い上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "乾燥した畑に塵旋風が立ち、土埃を巻き上げていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "突然の塵旋風で、帽子が飛ばされてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "また関東に特別に旋風が多いかどうかはこれも充分な統計的資料がないからわからないが、小規模のいわゆる「塵旋風」は武蔵野のような平野に多いらしいから、この事も全く無根ではないかもしれない。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "火先が凹の正面を以て前進するとき、其曲り角には塵旋風と名づくべきものが起る。",
              "citation": {
                "source": "地震の話",
                "author": "今村明恒",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
