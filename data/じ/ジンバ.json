    "definitions": [
      {
        "index": 1,
        "gloss": "man and horse",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "わが行軍の日は憩はず人馬先に爭ひ走りて輜重は泥濘の道に續けり。",
              "citation": {
                "source": "南京陷落の日に",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時計屋の店には明るくネオン燈がついて、一秒ごとに石でこさえたふくらふの赤い眼が、くるっくるっとうごいたり、いろいろな宝石が海のやうな色をした厚い硝子の盤に載って星のやうにゆっくり循ったり、また向ふ側から、銅の人馬がゆっくりこっちへまはって来たりするのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして最後に、漸く人馬の足跡のはっきりついた、一つの細い山道を発見した。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "円錐形にそびえて高く群峰を抜く九重嶺の裾野の高原数里の枯れ草が一面に夕陽を帯び、空気が水のように澄んでいるので人馬の行くのも見えそうである。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりを見るとかしこここの山の尾の小路をのどかな鈴の音夕陽を帯びて人馬いくつとなく麓をさして帰りゆくのが数えられる、馬はどれもみな枯れ草を着けている。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "時計屋の店には明るくネオン燈がついて、一秒ごとに石でこさえたふくろうの赤い眼が、くるっくるっとうごいたり、いろいろな宝石が海のような色をした厚い硝子の盤に載って星のようにゆっくり循ったり、また向う側から、銅の人馬がゆっくりこっちへまわって来たりするのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "○千住の大橋は千住駅の南組中組の間にかゝれる橋にして、東京より陸羽に至る街道に当るをもて人馬の往来絶ゆることなし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "西北隣のロシアシベリアではあいにく地震も噴火も台風もないようであるが、そのかわりに海をとざす氷と、人馬を窒息させるふぶきと、大地の底まで氷らせる寒さがあり、また年を越えて燃える野火がある。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時計屋の店には明るくネオン燈がついて、一｜秒ごとに石でこさえたふくろうの赤い眼が、くるっくるっとうごいたり、いろいろな宝石が海のような色をした厚い硝子の盤に載って、星のようにゆっくり循ったり、また向こう側から、銅の人馬がゆっくりこっちへまわって来たりするのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時計屋の店には明るくネオン燈がついて、一秒ごとに石でこさへたふくろふの赤い眼が、くるつくるつとうごいたり、いろいろな寶石が海のやうな色をした厚い硝子の盤に載つて、星のやうにゆつくりめぐつたり、また向う側から、銅の人馬がゆつくりこつちへまはつて來たりするのでした。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが戸外が急ににぎやかになって、町の中を狂気のように馳せちがう人馬の足音が聞こえだしたと思うと、寺々のかねが勢いよく鳴りはじめました。",
              "citation": {
                "source": "かたわ者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼を挙げて日本橋を見ると晴れた初夏の中空に浮いて悠揚と弓なりに架かり、擬宝珠と擬宝珠との欄干の上に忙しく往来する人馬の姿はどれ一つとして生活に自信を持ち、確とした目的に向って勇ましく闘いつつある姿でないものは無い。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "慧鶴は寺にたった一人馬翁と一緒に残った。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅亭の禿頭に教へられた樣に、人馬の徃來繁き街道を西へ／＼と凡そ四五｜町、唯ある十字街を左へ曲つて、三｜軒目の立派な煉瓦造りの一構、門に ｜T. Hamashima, と記してあるのは此處と案内を乞ふと、直ぐ見晴しのよい一室に通されて、待つ程もなく靴音高く入つて來たのはまさしく濱島！",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "人馬の交通を遮るべき厳寒の時節も漸く迫り来るのである。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　出る先へ立って、お神は銀子の寿々龍にそんなことを言って聞かせたが、そういうものが一人現われたのは、この土地にも春らしい気分が兆しはじめ、人馬も通えるように堅く張り詰めた河の氷もようやく溶けはじめたころで、町は選挙騒ぎでざわめき立っていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ川には汽車の鉄橋と、人馬の渡る木造の橋とが重なり合って眺められ、汽車が煙を吐きながら鉄橋を通ると、すべての景色が玩具染みて見えた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が古小説家の雄を曲亭主人馬琴と為す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "賽児これより妖術に通じ、紙を剪って人馬となし、剣を揮って咒祝を為し、髪を削って尼となり、教を里閭に布く。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "営中｜紛擾し、人馬｜滾転す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "先月の六日の第一回の裁判を受け、女と共に他の窃盗人殺印鑑偽造等の囚徒達と因人馬車に同車して市ヶ台の未決監に送られたのも事実です。",
              "citation": {
                "source": "わが敬愛する人々に",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "わかい馭者は窓のないカキ色の囚人馬車を梧桐のかげにひき入れたまま、しづかに読み耽る……こころもち疲れた馬の呼吸……短く刈つた栗毛の光沢から沁み出る臭の奇異な汗ばみ、その上にさしかくる新聞紙の新しい触感、わか葉の薄い緑の反射。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、曠原の風景が愈彼の為めに新らしくされ、野末を通る人馬も自づから彼の姿を振り返つてゆく。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集のはじめに",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝が初めて町の安床に行つた時……と又眼が憎さげに顫へる……がらがらと駆けて通つた囚人馬車がまるで汝の頭を轢き潰して鏡｜一面に黄色く光つて行つた時、あの狆のやうな下司ばつた顔の親方が何と云つた。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「囚人馬車の癖に宮様のやうに威張りかへつてのさばりやがる……一体あん中に幾人乗つてやがるんだろう……あんな罪人なんて奴は何だね樺太三界にでも追放つちまつた方がいいんだ、ねえ旦那。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "東海道に掛かると、人馬が不足した。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時寺本四郎右衛門が京都にいる弟又次郎の金を七百両借りて、坂下、関、亀山三箇所の人馬を買い締めて、山の中に隠して置いた。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて綱利の到着するのを待ち受けて、その人馬を出したので、綱利は土山水口の駅で光之を乗り越した。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜叉王　俄にきこゆる人馬の物音は、何事かと思うたに、修禪寺へ夜討とは……。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗ばんだ猪首の兜、いや、中折の古帽を脱いで、薄くなった折目を気にして、そっと撫でて、杖の柄に引っ掛けて、ひょいと、かつぐと、「そこで端折ったり、じんじんばしょり、頬かぶり。",
              "citation": {
                "source": "若菜のうち",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
