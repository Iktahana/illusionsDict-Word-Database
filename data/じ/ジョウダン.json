[
  {
    "uuid": "4d4f519d-8deb-5b68-b001-0b3cb32548ae",
    "entry": "上段",
    "reading": {
      "primary": "じょうだん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
