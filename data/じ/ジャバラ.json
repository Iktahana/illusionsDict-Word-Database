[
  {
    "uuid": "09bd2e5c-6fbb-5000-b890-8b3c1d79e78e",
    "entry": "蛇腹",
    "reading": {
      "primary": "じゃばら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
