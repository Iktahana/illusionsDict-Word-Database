[
  {
    "uuid": "c81deeda-5255-5205-8e56-e05920478a2e",
    "entry": "事後",
    "reading": {
      "primary": "じご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞"
      ],
