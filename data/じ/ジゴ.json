      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "after",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その夜、客となった長者の家の奥座敷で食事後休んでいると、お蘭老女が尋ねて来た。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "領事のほうからは、本国の家族から事後の処置に関する返電の来るまで遺骸をどこかに保管してもらいたいという話があって、結局Ｍ教授の計らいでＭ大学の解剖学教室でそれを預かることになった。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう災難に会った人を、第三者の立場から見て事後にとがめ立てするほどやさしいことはないが、それならばとがめる人がはたして自分でそういう種類の災難に会わないだけの用意が完全に周到にできているかというと、必ずしもそうではないのである。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かにつけて、彼及彼女を思ひだす、見頓思漸、理先事後、詮方もない事実である。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのね、麻川さんが、晩のお食事後、こっちにお客さんの居るうちじゅうお部屋の壁の外に椅子を運んでじっとして腰のかけづめでしたよ。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸に逃げ帰つた、近藤は、その後色々と画策したが、一度落目になると、する事なす事後手となつて、甲州勝沼の戦に敗れ、下総流山で遂に官軍の手に捕へられた。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　我々の活動は絶え間なくめまぐるしいから、読者諸君もおそらくご推察のことだろうが、しばしば私にとって困難となるのが、物語を締めくくること、つまり世の人々の知りたがるであろう事後を細かに記すことなのである。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて凶事の最中または事後に馬が逃げ出したものとすると、行く先は一体どこか？",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し位ゐなら歩き度いとの事で食事後、打ち連れて近所を散歩しました。",
              "citation": {
                "source": "樹木とその葉",
                "author": "温泉宿の庭",
                "note": "青空文庫"
              }
            },
            {
              "text": "事後れて手古奈を人妻と聞くこともあらば、吾命も今日を限りと思へ。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいてい食事後に、いそいで便箋を出して書いているが、書きたい事はたくさんあるのだし、この手紙も二日がかりで書いたのだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、兎に角、河野の代理にやったことだから、一応は河野に話して、その事後承諾を得なければならぬと思って居た。",
              "citation": {
                "source": "神の如く弱し",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "何人ガ大經世家タルカ大發明家大哲學者大藝術家タルカハ、彼等ノ立案スル如ク社會ガ認メテ勞働ヲ免除スト云フ事前ニ察知スベカラズシテ悉ク事後ニ認識セラルル者ナレバナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "この最後の歌はかつて（別項「蛇の話」の初項）論じた婬婦の体に、驢や、羊や、馬や、蓮花を画き置きしを、姦夫が幹事後描き替えた笑談と同意だ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三）　食事後の気分は前よりも一｜層打寛いだものであつたが、彼等の或者は尚も未練がましく私達の傍へ寄つて来て、揉手をしながら「キヤンニユスピイク、イングリシユ？",
              "citation": {
                "source": "微笑の渦",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "……仲々繁昌します」　すると片山助役は、その答弁にどうやら元気をつけられたらしく今度は話題を変えて、「犯人がまだ挙げられないとしますと、捜査や、事後の警戒はどうなっていましょうか？",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "降り続いた火事後の雨が霽ると、伝染病発生の噂と共に底冷のする秋風が立つて、家を失ひ、職を失つた何万の人は、言ひ難き物の哀れを一様に味つてゐた。",
              "citation": {
                "source": "札幌",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "降り續いた火事後の雨が霽ると、傳染病發生の噂と共に底冷のする秋風が立つて、家を失ひ、職を失つた何萬の人は、言ひ難き物の哀れを一樣に味つてゐた。",
              "citation": {
                "source": "札幌",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事後に、栗村君はすゞりと筆と白扇とを取りよせ、その日の記念にと私に揮毫を求められた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "このニュースは、事後承諾の形で新聞にあらわれた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事後、また碁を二三番戰つたが、義雄も氷峰もねむけがさして來たので、いつのまにか、二人ともうたた寢をした。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴行の事実は、それがこの殺人の第一目的と推定して、疑いを容れる余地もなく、またナイフと事後の水に依る局部の損害にも係らず、幾多の専門的検査ののち明白以上に立証されたところでもある。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "今仮りに谷中村堤内を買収したりとして事後の状態に就て少しく考究すれば真に恐るべき結果を発見すべし。",
              "citation": {
                "source": "非常歎願書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭事後故に市商甚盛なり。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "按ずるに癸亥は事後に官裁を仰いだ年であらう。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "四年前、京橋際のビルディングの一室を借りて、好日書院という特殊出版を初めた時でも、私など一言の相談も受けず、更に驚いたことには夫人へも一言の相談もなく、みな事後報告に過ぎなかったのである。",
              "citation": {
                "source": "十一谷義三郎を語る",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "義観が、万事後を引受けてくれて――わしは、これから、牧の後を追うが、何か、耳に入っておらんか」「京の藩邸を、二三日前に出たということは、聞いておるが――」「わしも、それは聞いた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事後私達は本多翁をも加えて、ここから三里の諏訪池を見に行く。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "二一　法律の事後公布　徳川時代の刑典は極めて秘密にせられたものであるが、刑の執行はこれを公衆の前において行って、人民の鑑戒としたものである。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おじご、何を、何をしてござるのか。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
