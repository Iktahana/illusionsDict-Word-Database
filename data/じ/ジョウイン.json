    },
    "definitions": [
      {
        "index": 1,
        "gloss": "repeated rhymes (in Chinese poetry)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "理は元来、璞玉（宝石の原石）の中に通っている「すじ」に従って解き分けて之を治める意味で、「理」と「治」とは畳韻の字である。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶山には数首の作があつて、其中に古賀精里に寄する畳韻の七律三首等があり、又｜除夕の五古がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
