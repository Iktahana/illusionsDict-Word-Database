  {
    "uuid": "1a37e095-3ecd-533d-912d-1fb2260b7aa1",
    "entry": "上淫",
    "reading": {
      "primary": "じょういん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "being romantically involved with someone of higher class (esp. of a man)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "総じて貴人というものは、上淫を嗜むのです。",
              "citation": {
                "source": "紅毛傾城",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が好んで、大名の屋敷にはいるのは土蔵の現金と、閨房の上淫がのぞかれるからであった。",
              "citation": {
                "source": "治郎吉格子",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なべて、高貴な上淫に異様な、妄念にこがれるのは凡下のつねで、そのささやきは、餓鬼が壁をへだてて、隣の食物のにおいに美味を想像するのと異ならない。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川どのは、下淫を好む質と聞くが、前に申したようなせいか、わしは上淫を好むほうだ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれが、上淫を好んだのも、良風良俗のうちに育まれた子女には、おのずから、優雅な香気があるからであった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
