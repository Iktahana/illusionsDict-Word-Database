          "literary": [
            {
              "text": "老人は立ち上つて、「鱒の人工孵化をお目にかけませうか。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は立ち上って、「鱒の人工孵化をお目にかけましょうか」　と板囲いの一棟へ私を案内した。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツルゲーネフは「父と子」とを外国にあって、手帳の上で人工孵化した。",
              "citation": {
                "source": "ツルゲーネフの生きかた",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫と河鹿　松虫、鈴虫、轡虫、さては草雲雀、螽斯なんど、いずれ野に聞くべきものを美しき籠にして見る都びとの風流は、今も昔に変らぬが、ただこの虫というもの、今は野生のを捕え来て商うのではなくて、大方は人工孵化。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮭の人工孵化を行い得られるのは、鮭が自分の生れ故郷を忘れないからである。",
              "citation": {
                "source": "故郷",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
