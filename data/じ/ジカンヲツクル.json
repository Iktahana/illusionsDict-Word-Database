          "literary": [
            {
              "text": "読書の時間を作るために、無駄に忙しくなっている生活を整理することができたならば、人生はそれだけ豊富になるであろう。",
              "citation": {
                "source": "如何に読書すべきか",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "また例へば、一日中に家族の全員が同時に閑になるやうな時間を作ることが必要であらう。",
              "citation": {
                "source": "生活文化の建設",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかになにかが存在していて、それとの関係のなかではじめて、時間がきまってくるんだから」「人の頭が時間を作るの？",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰宅を少しおくらせて、事務所に近い日比谷公園に立寄り片隅のベンチに、短い語らいの時間を作ることもあった。",
              "citation": {
                "source": "孤島の鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
