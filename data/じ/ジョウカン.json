  {
    "uuid": "8b15ae6f-00f5-54d2-a128-32b4494c32c2",
    "entry": "上燗",
    "reading": {
      "primary": "じょうかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "moderately heated sake",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして、『あ、上燗だあ、上燗だあ』と云つてゐるところを父は話した。",
              "citation": {
                "source": "念珠集",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "口をつけると上燗に出来上っている酒の香りが、五臓六腑に沁み渡ります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄瓶から直接にうつした燗だから、金気があって飲まれないかと思うと、そうでない――上燗だ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
