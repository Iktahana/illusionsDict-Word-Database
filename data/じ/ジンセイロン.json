[
  {
    "uuid": "50a18986-2077-56c6-b43d-51e29bea51c6",
    "entry": "人生論",
    "reading": {
      "primary": "じんせいろん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
