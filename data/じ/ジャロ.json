        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「……独逸語のうちでもこれは大分むずかしんじゃろう。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「洋服がなけりゃ会社イ出られんのじゃろうし……困ったこっちゃ！",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの神戸で頼んだ行李は盗まれやせんのじゃろうかな？",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「袷じゃせに、これゃ寒いじゃろう。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「道に迷やせんじゃろうかの。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「こん中にゃ、だいぶわざと負傷してきた奴があるじゃろうがい？",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんで身投げなどしたんじゃろかなと、女は自問し、この世がいやになったんでしょうかなと自答した。",
              "citation": {
                "source": "短命長命",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうじゃろうか。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あしこには、ろくに飯を食わさんのじゃろう。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そら、腹が減ったじゃろう。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうこれで戻りゃせんじゃろうんの。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうじゃろう、私等は別条ないんだろうか？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「またもう一つ、別の電車をつくんじゃろうか。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らくたって、彼は「あの、やめるんじゃったら毎月の積金は、戻して貰えるんじゃろうのう？",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きれいじゃろうが。",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、山の気か、女の香か、ほんのりと佳い薫がする、私は背後でつく息じゃろうと思った。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついてはこれから連合で、大乱舞会をはじめてはどうじゃろう。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして又あんなおとなしい子が、人につかまるような処に出たもんじゃろうなあ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このサ中に何処へ行たもんじゃろか……あの朝寝坊が……」　それから毎日のように晴れ続いた福岡博多の狭い町々に、蔵元屋の騒動の噂が隈もなく行き渡ってしまった三日目……三月十三日の正午下り。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八か九の別嬪が、一昨日の朝早よう、万延寺の菩提所で、胴中から真二つに斬られとった騒動なあ……最早、聞いておんなさるじゃろう」「聞いとる処か。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうアンタに先手を打たれたか」「先手なら商売柄アンタの方じゃろう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの黒い血は毒殺した証拠じゃろう」「そこじゃ、そこじゃ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンタもそこに気が付いて口の中を覗いてみなさったものじゃろうが……感心感心……一度、痕跡も残さずに拭い上げた口の中の黒血の残りが、斬られて投棄てられる拍子に、仏様の咽喉からセグリ上げて来ようなぞとは閻魔様でも気が付かん事じゃろう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処とのう苦味走ったアクの利く眼の配りは大阪役者なら先ずもって嵐珊吾楼どころ……と言うあの侍じゃろう」「ウン。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "事件の起りが三月の十一日じゃろう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "大方それは袖の下の催促じゃろう」「もちろんじゃ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大風呂敷が何を包んだものか、何処の穴から出て来たものかがわからぬうちは、お気の毒ながらお役目柄がお先まっくらじゃろう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あそこは追剥強盗が名物じゃけに仕事には持って来いじゃろう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間外れたシコ溜め屋の奉公人とおなじ事じゃ」「しかし、ほかに気の向く仕事もないけにのう」「あんたはホンニ目明に生まれ付いた人じゃろう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            }
          ]
        }
