[
  {
    "uuid": "36ec18fc-18ec-527a-bbaf-88f07d8efc70",
    "entry": "陣取り",
    "reading": {
      "primary": "じんとり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
