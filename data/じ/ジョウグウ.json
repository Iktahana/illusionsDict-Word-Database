    "definitions": [
      {
        "index": 1,
        "gloss": "building of a Shinto shrine complex built upon the highest ground",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうかと思うと『源氏物語』や『続世継』などに尺八の名があり、さらに上宮太子が尺八を吹かれたという話がある、シナには唐あたりの古いところにもとにかく尺八の名がある。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿日、壬辰、午剋、鶴岳上宮の宝前に羽蟻飛散す、幾千万なるかを知らず。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿二日、庚寅、天晴、未剋、鶴岳上宮の宝殿に、黄蝶大小群集す、人之を怪しむ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上宮中学の、蔵鷺庵という寺の真向いの路地の二軒目。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒々とした薄暗い焼跡を上本町八丁目まで歩き、上宮中学のまえを真っ直ぐ三町ばかし行くと、右側にこぢんまりした二階建のしもた家があった。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸上宮殿の柱像たらんは、海の女王たらんことの崇高なるには若かず。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはイ列とエ列とでも同樣の例があるので、上宮聖徳法王帝説に等已彌居加斯支移比彌乃彌己等とあるのを見れば、彌の字はミにもメにもなるので、其の區別が判然しなかつたことが分る。",
              "citation": {
                "source": "平安朝時代の漢文學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "彌をメと訓む例は黒川氏の北史國號考に上宮聖徳法王帝説、繍張文の吉多斯比彌乃彌己等、また等已彌居加斯支移比彌乃彌己等、註云　彌字或當賣音也とあるを引けるなどに從ふべし。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "また能楽の性質上宮内省または華族団体の保護を仰ぐといふことは不当な要求でもなく、また一方より言へば今日これを特別保護の下に置くのは宮内省または華族団体のなすべき至当の仕事であらうと信ずる。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "海上宮島を望こと至て近がごとし。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「好古小録法隆寺上宮太子画像。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "釋日本紀に引れたる上宮紀に、皇女たちの中に、某比賣と申せる中に、大中比彌、田宮中比彌、阿那爾比彌、布利比彌命、また上宮聖徳法王帝説の中に載たる古文に、吉多斯比彌乃彌己等、加斯支移比彌乃彌己等など、なほあり。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程銅の大鳥居から四十二丁の上宮迄は樹海の中を登りつめるので、見はらしはなし、谿流は添わず、大英彦全体を眺める事の出来ない凹凸の多い山なので、ひととおりの登山丈では、一向変化のないつまらぬ山と思えるのもむりはない。",
              "citation": {
                "source": "英彦山に登る",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "思わずたじたじと十歩程もと来た方へ下りかけた私は、いや待て、折角ここ迄きて、上宮へのぼらず帰るのは残念だ。",
              "citation": {
                "source": "英彦山に登る",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "上宮ではつい二三日前に初雪が降ったと、禰宜は私を霧囲いの傍の天水桶の辺につれていって残りの雪片をさし示した。",
              "citation": {
                "source": "英彦山に登る",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "南岳の原生林をぬける時の深山らしい感じは、上宮道にはない。",
              "citation": {
                "source": "英彦山に登る",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "優しい威厳に充ち満ちた上宮太子などの兄弟です。",
              "citation": {
                "source": "神神の微笑",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝紀と言ふ名目は、古事記・日本紀・上宮法王帝説などを古いものにして、後期王朝の物にも見えてゐる。",
              "citation": {
                "source": "日本書と日本紀と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖徳太子を上宮法王と言ひ、又降つて奈良の道鏡にも、其先蹤による称号を与へられたのも、此為であつた。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人は嘗て思へり、日本開化小史の最も優れたる所は其思想の発達と物質的の進歩とを観察せし点に在り、日本開化小史巻の四に於て日本文学の変遷を序述し、上宮太子の憲法十七条より説起し平安朝の四六文を評論し、進んで和文世に出でゝ言語と文章の漸く親密に近きし事情を叙する所、鋭敏なる観察力は火の如く耀けり。",
              "citation": {
                "source": "明治文学史",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "但しペルリの船の人々には、此等の墓と共に今一つ、左手に突出した岩塊（波上宮のある）の傍に、思ひがけなく翻つてゐた英國の「ユニオン・ジヤツク」の旗が目を惹いたが、これは當時那覇に滯在して、耶蘇新教の布教に從事して居つたベツテルハイムと云ふ英人の宿所護國寺に立てられてゐたものである。",
              "citation": {
                "source": "沖繩の旅",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　那覇の波上宮と護國寺　那覇の市中には市役所の高塔が、最初の且つ唯一（？",
              "citation": {
                "source": "沖繩の旅",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            },
            {
              "text": "波上宮へお參りをすると、これは明の詩人が筍崖と呼んだ港の外に突出した珊瑚礁の塊の上に立つてゐる沖繩縣内唯一の官幣社である。",
              "citation": {
                "source": "沖繩の旅",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            },
            {
              "text": "波上宮の入口に近い護國寺には、かのペルリの時こゝに居つて英國の旗をあげ、基督教の傳道に從事し、遂に琉球語の聖書を印行した、ベツテルハイムの記念碑がある。",
              "citation": {
                "source": "沖繩の旅",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは上宮太子御生誕後幾年になる。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし明治維新後八年、上宮太子降誕一千三百余年は、彼自身が彼を記念するには好い年代である。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "素人タンテイの心眼だから我ながら鋭い把握はないのだが、しかし「上宮聖徳法王帝説」という本を読むと、どうも妙だな、と思うことがあります。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
