    "definitions": [
      {
        "index": 1,
        "gloss": "receipt (of a letter, money, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "食糧や、慰問品の受領に鉄道沿線まで一里半の道のりを出かけていた十名ばかりが、帰ってきたのだ。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　防寒帽子をかむり、防寒肌着を着け、手袋をはき、まるまるとした受領の連中が扉を開けて這入ってくると、待っていた者は、真先にこうたずねた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は受領書に印を捺して持って来る。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は受領書と風呂敷包を見っぱっている。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "特務曹長「これはどの戦役でご受領なされたのでありますか。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二日、甲辰、和田左衛門尉義盛、上総の国司に挙任せらる可きの由、内々之を望み申す、将軍家、尼御台所の御方に申合せらるるの処、故将軍の御時、侍の受領に於ては、停止す可きの由、其沙汰訖んぬ、仍つて此の如き類、聴されざる例を始めらるるの条、女性の口入に足らざるの旨、御返事有るの間、左右する能はずと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "将門の弟の将頼は下野守に、上野守に常羽御厩別当多治経明を、常陸守に藤原玄茂を、上総守に興世王を、安房守に文室好立を、相模守に平将文を、伊豆守に平将武を、下総守に平将為を、それ／″＼の受領が定められた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "惜い哉、朝廷の御覺目出度きに乘じて、私に受領したために兄の忌むところとなつて終を全くしなかつた。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "真女児は己はこの国の受領の下司県の何某が妻であったが、この春夫が歿くなったので、力と頼むものもない。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "余が文書を受領して大臣の室を出でしとき、相沢はあとより来て余と午餐をともにせんといいぬ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾子が受領すべきは、緇き衣と大なる帽となり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "局へ殘す筈の受領證を渡して仕舞つたから換へて呉れとお辭儀をするのであつた。",
              "citation": {
                "source": "鉛筆日抄",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "余が文書を受領して大臣の室を出でし時、相澤は跡より來て余と午餐を共にせんといひぬ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし還俗の望みがあるなら、追っては受領の御沙汰もあろう。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "源義経（平安末期の武将、源頼朝の弟）もまた平家討滅の大功があったが、惜しい哉、朝廷の御覚目出度に乗じて官位を私的に受領したために、兄の嫌うところとなって終りを全うしなかった。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "受領といって地方の政治にばかり関係している連中の中にもまたいろいろ階級がありましてね、いわゆる中の品として恥ずかしくないのがありますよ。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二回だか第三回だかの博覧会にも橋弁慶を出品して進歩二等賞の銅牌を受領した。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "頗る略式化した一種の商品受領証と云ったようなものですね。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はドレゴが急にこんな翻意をするようになったわけは、その前夜、アイスランドから一通の無線電信を受領したことに拠る。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　ノーベル賞金の受領者、瑞典の女流作家、ラゲルレフの作も多分に猟奇的である。",
              "citation": {
                "source": "他界の味其他",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹村章一という印の捺された水道料金の受領証、それも昨年の六月分だけ一枚それから四年前の書留の受取、そうした無意味な紙片にまじって、大切そうに半紙に包んだ小さなものが出て来た。",
              "citation": {
                "source": "忘れがたみ",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "四人分の受領書を持つて行つた校長が、役場から帰つて来ると、孝子は大抵｜紙幣と銀貨を交ぜて十二円渡される。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "四人分の受領書を持つて行つた校長が、役場から歸つて來ると、孝子は大抵紙幣と銀貨を混ぜて十二圓渡される。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化勲章受領者で、云わば必要にして充分という感じを与えるものは、自然科学者のトリオである。",
              "citation": {
                "source": "日本の頭脳調べ",
                "author": "――特に自然科学者に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "理論物理学者・実験物理学者として、世界的な業績に富むこと、当代第一級の人物だから、文化勲章の受領者として、之ほど適切な人はないだろう。",
              "citation": {
                "source": "日本の頭脳調べ",
                "author": "――特に自然科学者に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがこの間『科学知識』の事実投票によると、勲章受領者の第一位は本多博士の方で、長岡博士は第六位かであった。",
              "citation": {
                "source": "日本の頭脳調べ",
                "author": "――特に自然科学者に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　夫人は指を鳴らして、この私のお世辞に対する喜ばしき受領証の笑いに換えた。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "余が文書を受領して大臣の室を出でし時、相沢は跡より来て余と午餐を共にせんといひぬ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
