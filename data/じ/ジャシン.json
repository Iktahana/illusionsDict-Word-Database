[
  {
    "uuid": "ce433e9a-eef8-5550-b466-636f1c48026e",
    "entry": "邪心",
    "reading": {
      "primary": "じゃしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
