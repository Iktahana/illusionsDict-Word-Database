        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "第一場（舎衛城郊外の池、呪術師の娘水を汲みに来り、水甕を水に浸せし儘、景色に見入りて居る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中にまぎれて呪術師の娘施行台の前に立つ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三場（舎衛城の城壁に沿うて呪術師の娘が帰って行く。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四場その一（呪術師の老女の部屋。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡座を組んで居る呪術師の老女の膝に身を投げかけ、娘はしきりに哀願して居る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはもう呪術師ではない。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは呪術師として祈らずに、娘を愛する母として、日頃使い馴れた呪術の力を借りるとしよう。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）第六場（再び呪術師の老女の部屋、既に阿難と娘は毛綱にて縛り上げられ、引据えられて居る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "目※連　――ここに居るのが呪術師の娘で御座います。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは呪術師の老女である。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪しげな呪禁や祈祷をして、助かる病人まで殺してみたり、医者の薬を遠ざけて、ますます病気を悪くしてみたり、盛んに迷信や邪信を鼓吹して、愚夫愚婦を惑わしている、いいかげんな呪術師がありますが、ほんとうにこれは羊頭を掲げて狗肉を売るもので、あくまでそれは宗教の名において排撃せねばなりません。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "原始社会の統制形態についても、支配者が母であったとする説、種族の父であったという説、あるいは僧侶や呪術師であったという説などいろいろあるが、それらの仮説がどうであれ、要するに国家の起源は、これを人間の共同生活そのものの、内的な必要に求めるのが正しいといわねばならぬ。",
              "citation": {
                "source": "政治学入門",
                "author": "矢部貞治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
