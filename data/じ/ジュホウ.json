[
  {
    "uuid": "b0201f31-1d81-50b7-85c8-b31ebd35fa5a",
    "entry": "呪法",
    "reading": {
      "primary": "じゅほう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
