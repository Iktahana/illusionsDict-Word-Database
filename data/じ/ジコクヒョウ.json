          "literary": [
            {
              "text": "」　私は時刻表を繰ってみた。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "バスに乗らなくてすむようになるのかな」　大船と金沢八景をむすぶ路線バスは、路線バスである以上、いちおう時刻表を掲示しているが、だれもそんなものを見たりはしない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとはなにを何時何分にすると、くわしい時刻表をこしらえて、三人は手わけしてそれを持った。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて私は未練らしく頭の上の時刻表を見上げた。",
              "citation": {
                "source": "停車場で感じたこと",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "バス停があったので近寄ってみたが時刻表はほとんど空欄で運行は一日に五便しかない。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            },
            {
              "text": "時刻表通りに、定期郵便船が。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケーブルを切ったのとかラジオ局を掌握したのはやつらだと思うけど、時刻表通りに進むのなら、それで問題はないよ。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハレマイヤ　時刻表が守られてるってことは、人間世界の秩序が、宇宙の秩序が、なにもかもが守られるべくして守られてるってことだ。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "時刻表は福音書より重要なんだ。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "時刻表っていうのは、人間の理性が作った完全な創造物なのだ。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は三番です」「三番は何時ですか」　海老塚が答えないので、警部はバスの発車時刻表をとりだした。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "時刻表は次のようなものであった。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれ、時刻表をみせてごらんなさい。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "アロハ・エアラインの時刻表で飛行機を選び、空港のオフィスに電話し、とりあえず片道の席をふたつ予約した。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "停留所の標識に取りつけてある時刻表を、三人は見た。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "標識に取りつけてある時刻表を彼女たちは見た。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの汽車が午前十時前後に停車するのは、どこの駅かを当時の時刻表で調べたりするのです。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私と冬彦くんとは、京都からいっしょに神戸へいくことになると思うわ」「僕は東京から直行する」「前日に到着して、神戸に一泊かしら」「成り行きでいいよ」「汽車を選んで」　向かい側の壁の本棚に時刻表があった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "列車の時刻表を見せて。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "「伯爵夫人はいまブラッドショー鉄道時刻表をあわててめくっていますので、確実にえさに食いつきました。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "かすれ声で時刻表を探した。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "電報と時刻表を残していました。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "列車時刻表を調べよう。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
