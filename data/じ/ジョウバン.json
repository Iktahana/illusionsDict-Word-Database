        "gloss": "surface plate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "師弟二人の男世帯、工房はその六畳で、漆を扱う小机ほどな定盤と、蒔絵筆さえあれば足る至極ちんまりした仕事である。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲルハルトはこの時もう老境には入っていたが、さすがに最も優れたものであった（ヴオルフ協会のゲルハルトについては小著「名曲決定盤」に詳説している）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、終日、蒔絵師用のじょうばんと称する机に似た物の前に坐って、輸出物の下絵仕事に根気をつめていても、ぼくは倦むことを知らなかった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは上がり口の三畳に机とじょうばんをすえて、終日仕事の蒔絵筆をもっているだけなので、よく頭の上を、てん屋物やら酒やらが通ってゆく。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
