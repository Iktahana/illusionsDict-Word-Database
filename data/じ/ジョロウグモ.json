    "definitions": [
      {
        "index": 1,
        "gloss": "jorō spider (Trichonephila clavata)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
