[
  {
    "uuid": "dced31c8-2a92-5797-9ab9-5ead6ef399ff",
    "entry": "従属的",
    "reading": {
      "primary": "じゅうぞくてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
