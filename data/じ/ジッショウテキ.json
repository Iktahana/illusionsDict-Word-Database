[
  {
    "uuid": "53685b67-4190-5c7b-8565-bde749f56f6f",
    "entry": "実証的",
    "reading": {
      "primary": "じっしょうてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
