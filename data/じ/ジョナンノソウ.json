        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼に、女難の相を説くことは、愚の骨頂であつたらうが、其だけにまた身に沁みて言ひ聴かせる人が多かつたであらう。",
              "citation": {
                "source": "市村羽左衛門論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたには女難の相がある。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば、女難の相なぞ現れた場合に、誰のかわからぬから顔を赤らめずにすむというもの。",
              "citation": {
                "source": "稲生播磨守",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新九郎や、お前の相というものは、怖ろしい剣難の相と、剣難より怖い、女難の相というものを持っているのですとさ。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
