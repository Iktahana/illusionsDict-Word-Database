        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「はっはっは、ジッコさんといふのは磁鉄鉱だね、もうわかったさ、喧嘩の相手はバイオタイトだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はっはっは、ジッコさんというのは磁鉄鉱だね、もうわかったさ、喧嘩の相手はバイオタイトだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "磁石の如きはまた一方に於ては不老長生の作用を有すると考へられ、ゼイランの王は常に磁石（磁鉄鉱）で作つた皿で、食事を取つたといはれて居る。",
              "citation": {
                "source": "毒と迷信",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "石炭は半無煙炭で、埋蔵量弐億噸、鉄は磁鉄鉱で総量八千万噸と云はれる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外に四三酸化鉄、即ち磁鉄鉱の薄膜も少しはできることであろう。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "磁鉄鉱はまた少し別の黒さである。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "磁鉄鉱も、黄銅鉱も、金もあるのだよ。",
              "citation": {
                "source": "白い雲",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どれ、そいつは磁鉄鉱らしいな。",
              "citation": {
                "source": "白い雲",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
