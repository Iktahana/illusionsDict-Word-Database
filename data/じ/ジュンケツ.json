[
  {
    "uuid": "dd83c81c-1734-5a3c-8ae8-65d4ddda97a2",
    "entry": "純潔",
    "reading": {
      "primary": "じゅんけつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞-の形容詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "purity",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこには少年に特有なあの美しい感傷と、生娘のやうな純潔の気高さがあつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼ほど馬鹿正直で、彼ほど子供らしい純潔と卒直さをもつた人間はない。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもさうした純潔の詩人の生涯こそ、かの音楽家のそれと等しく、人生の最も神聖なる住宅、即ち道徳及びその他の感情生活の世界を支配する最高至美の権威でなければならない。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "極めて稀にみる子供らしい純一無垢な性情と、そして何よりも人間としての純潔さを、私共は互に愛し悦びあつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "「願の糸も白きより」は、純潔な熱情で恋をしたけれども――である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "純潔な処女をこの一角の怪獣の棲家へ送り込むと、ウニコールがすっかり大人しくなって処女の胸に頭をすりつけて来る。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このセンチメントの純潔さが、彼の詩に於ける、最も尊いエスプリだつた。",
              "citation": {
                "source": "中原中也君の印象",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "レムブルグを抱えた米良が舞踊場に機械が造り出した人間の造花の美と、同志の終りに近づいた純潔を撒き散らした。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "理解しにくいと聞いてそのためにかえって興味を刺激される人ももとよりたくさんあるだろうし、また謙遜ないしは聞きおじしてあえて近寄らない人もあるだろうし、自分の仕事に忙しくて実際暇のない人もあるだろうし、また徹底的専門主義の門戸に閉じこもって純潔を保つ人もあるだろうし、世はさまざまである。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして最も純潔な尼僧の生活から、一朝つまらぬ悪漢に欺かれて最も悲惨な暗黒の生涯に転落する、というような実験を、忠実に行なった作品があるとする。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方科学者のほうではまた、その研究の結果によって得られた科学的の知識からなんらかの人間的な声を聞くことを故意に忌避することがあたかも科学者の純潔と尊厳を維持するゆえんであると考えるような理由のない慣習が行なわれて来た。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩、あなたに、強くなってもらいたく、あなたの純潔信じて居るものの在ることお知らせしたく、あなたに自信もって生きてもらいたくて、ただ、それだけの理由で、おたよりしようと、インク瓶のキルクのくち抜いて、つまずいた。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の下等にして黒く暗憺なるを憂うるなかれ、桂正作はその主義と、その性情によって、すべてこれらの黒くして暗憺たるものをば化して純潔にして高貴、感嘆すべく畏敬すべきものとなしているのである。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の下等にして黒く暗澹なるを憂うるなかれ、桂正作はその主義と、その性情によって、すべてこれらの黒くして暗澹たるものをば化して純潔にして高貴、感嘆すべく畏敬すべきものとなしているのである。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも今のところおぬいさんは処女の美しい純潔さで俺の心を牽きつけるだけで、これはいつかは破れなければならないものだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何らの手管もなく、たった純潔一つで操られていると思うと渡瀬は心外でたまらなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "純潔――そんなものの無力を心でつねに主張している彼には（そして彼は十七歳の時から立派に純潔を踏みにじってきているのだ）小癪にさわった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の酷たらしい抱擁の下に、死ぬほどに苦しみ悶えながら彼女の純潔が奪われていく瞬間を想像すると、渡瀬はふたたび眩惑するような欲望の衝動を感じないではいられなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んの恐れ気もなく、平和に、純潔な、そして園の心におのずと涙ぐましさを誘うような淋しさ、――淋しさではない。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ乙女の純潔と無邪氣とをどこかにそのまゝ持つてゐた妻の顏にメスをあてゝ支離滅裂にするのはとても忍び難い事だつた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはあれから宿へ帰りあなたが交換して下さった短冊の歌を繰返し繰返し読んで、わたくしの心の一部はあなた同様純潔な寂光の世界が望まれるような気がいたしました。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　女は全く貞淑な、むしろ純潔な、処女が示す哀憐の様子を作つて、「此｜瘢は貴方の一生の瘢よ。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "白糸の鉄拐はこれを天真に発して、きわめて純潔清浄なるものなり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……双方の御親属に向って、御縁女の純潔を更めて確証いたします。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もっとも二十歳の鶴雄にわざわざ「女ぎらい」という形容が大袈裟だというなら、純潔といいかえても良い。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の肌を知らず、甘い囁きも知らぬ純潔さが、しかし爛れ切った玄人女にとっては、何か焦燥のような魅力であった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、お嬢さまは、相手が縦令どんなに取るに足らなそうな男でも、そのひたむきな純潔な愛は天地にかけ更えもない優美な貴いものだ――その愛情にほだされない様な女は永遠に真実の愛に祝福される機会を取り逃がす不幸せな女だ、と仰有って、しまいには泪さえ流して、あなたのために弁護なさいました。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "商売している以上、体はどうも仕方がない、汚れた体にも純潔な精神的貞操が宿り、金の力でもそれを褫うことはできないのだと。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
