        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ことしは、実業之日本社から「東京八景」が出ました。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "-------------------------------------------------------　コフマンの「科学の学校」が、神近市子の翻訳で実業之日本社から出版された。",
              "citation": {
                "source": "科学の常識のため",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この心の誇り」という題で（実業之日本社、定価一円五十銭）鶴見和子氏がパール・バックのこの作品の抄訳を出している。",
              "citation": {
                "source": "『この心の誇り』",
                "author": "――パール・バック著――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（実業之日本社）三月の第四日曜。",
              "citation": {
                "source": "年譜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（実業之日本社）一九四七年（昭和二十二年）一月から〔八〕月まで中央公論につづけて「二つの庭」を書いた。",
              "citation": {
                "source": "年譜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（実業之日本社）一九四八年（昭和二十三年）中心的な執筆は、小説「道標」である。",
              "citation": {
                "source": "年譜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうしてまとめて置けば、他日わたくしの子どもたちが何かの底から見附け出し、母の生活の記録の断片として読んでくれるかも知れないくらゐに考へてゐましたのですが、幸なことに、実業之日本社の御厚意に由り、このやうに印刷して下さることになりました。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "早稻田の総長をきめたとき、増田義一（実業之日本社長）などの名誉理事を動かして、内部工作をやったのが、気に入らなかったからだという。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのゲラが見つかって一九四七年実業之日本社より出版『婦人と文学』。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "実業之日本社からスタンダールの伝記が出ます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "『サント・ブーヴ選集』（実業之日本社版）中、私が訳した「モンテーニュ」の項及び白水社版『モンテーニュ全集』第二巻の口絵、ボルドー本書き入れ、および「家事録」の記入参照。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "実業之日本社の倉崎さんに、「短篇集の件、どうしたのか」伺うこと。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
