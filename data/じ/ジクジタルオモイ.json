        "examples": {
          "standard": [
            {
              "text": "自分の過ちに気づき、忸怩たる思いで顔を伏せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の裏切りを知り、忸怩たる思いが募るばかりだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "約束を守れなかった自分に、忸怩たる思いでいっぱいだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "夫に決意を見せつけたけれども、忸怩たる思いは夫に疑いをかけたこと、三年前にも人生を破滅させかけた。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "忸怩たる思いは、もっと早くこの男に、単なる儀礼的な気持ちしかありませんと、伝えていればなあ。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
