  },
  {
    "uuid": "c7157b01-34f0-5e18-a5ee-0226d8605855",
    "entry": "情状",
    "reading": {
      "primary": "じょうじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "circumstances",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "被告銘々にそれ／″＼酌量すべき情状がなかつたか。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝまでは将門の言ふところに点頭の出来る情状と理路とがある。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄明の事に就ては少し無理があり、信じ難い情状がある。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に其の得失の状を覧れば、古今の情状略具備すといふ也。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "小倉百人一首に載っている、赤染右衛門、やすらはで寝なましものを小夜ふけて傾くまでの月をみしかな、は実に好い歌であるが、あれも右衛門自身の情から出た歌では無くて、人に代って其時の情状を写実に詠んだものである。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "福を分たぬものの卑吝の情状は抑※何樣である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "餓狗の其の友に讓らざるのは、畜生の已むを得ざるところで有るが、苟も人として畜生と多く異ならざるの情状を做すのは、實に情無い談である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡そ是の如きの情状を做し得てこそ、人も聊か他の動物の上に立ち得るのであれ、然なくば那處に人の動物たらざるところを見んやである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにたゞ單に其の法律には盲從せずして、造化の其の法律の精神を體得し、其の法律の如何なるものであるかを知りて之を運用し、被治者の地位たる野猿山羊の羣より超越して仕舞つて、漸やくにして治者、即ち造化の分身たる地位に到達せんと欲して居るのが人類の情状で、古來の賢哲は皆幾分か其の望を達し得て居るのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然樣いふ場合には一婦人の身を以ても、中々侮り難い事を做し出すもので、所謂『氣の張り』は才智をも發展させ、擧手投足をも敏活にさせるもので有るから、「其の人の天より稟けただけのものを十分に使用し盡す」情状になる。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "張る氣を以て事に從ふ情状は即ちそれであり、全部の火氣一鍋に對して居るので、一鍋中の熱氣おのづからに鍋中の物に作用して、そこで熟されたところである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の習慣は吾人の靈性を熏染して、熏染又熏染、遺傳又遺傳、先祖代々同一情状を重複した結果、電燈もあれば瓦斯燈もある今日に於ても猶且吾人は、日出でて起き、日入つて睡るといふ周期作用に服從して居る。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "草木は正直に無私に一氣の流行を示し、其の起伏消長の情状を見せて居る。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「而して吾人が特に本論に於て、感嘆崇敬措く能はざる所の者は、彼が戰時に於ける一般社會の心的及び物的情状を觀察評論して、露國一億三千萬人、日本四千五百萬人の、曾て言ふこと能はざる所を直言し、決して寫す能はざる所を直寫して寸毫の忌憚する所なきに在り。",
              "citation": {
                "source": "トルストイ翁論文",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "裁判所の方でもいろいろの情状を酌量されたらしい。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "情状酌量すべき所無いでもないが、都亭主人を欺いて社会にとって危険極る人物となり、ために貴重な一つの生命を奪ったことは罪に値するという訳だった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たしかに水莽草だ」　祝はそこで指輪を出して少女の情状を話した。",
              "citation": {
                "source": "水莽草",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤原平三に、重クロム酸加里を混入せる酒を呑ましめたることも、自分の利得のための殺人として情状酌量の余地なし。",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "情状酌量すべきものが十分ある。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この亜米利加人のアベー・スラネーは、ノーアウィッチの冬期巡回裁判で、死刑を宣告されたのであったが、しかしヒルトン・キューピット氏が、最初に発射したと云うことが明瞭になったので情状酌量して、死刑を改めて懲役刑とされた。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは天保十年のことで、本来ならば放火は火烙りですが、花鳥はなかなか弁の好い女で、抱え主の虐待に堪えられないので放火したという風に巧く云い取りをしたと見えて、こんにちでいえば情状酌量、罪一等を減じられて八丈島へ流されることになりました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "照之助は年も若いし、兄のかたき討ちというところに情状酌量の点もあるので、遠島になりました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日でしたら情状酌量にもなったのでしょうが、その時代ではどうもそう行きませんでした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雷獣と蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし先づ道教が如何なるものであるかを平明に看取して、そして次に道家・神僊家が如何なるものであるかをも平明に看取して、さて三者の與ふる概念を比較して見るときは、そこに道教成立の情状をば、無批判にせよ自然批判的に解知し得る譯であらう。",
              "citation": {
                "source": "道教に就いて",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その法律に盲従しないで、造物主のその法律の精神を体得し、その法律のどんなものであるかを知り之を運用し、被治者の地位である野猿｜山羊の群れを超越して、次第に治者、即ち造物主の分身の地位に到達しようと欲しているのが人類の情状で、昔の賢人や哲人はみな幾分かその望みを達し得ているのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この習慣は我々の霊性を薫染して、薫染また薫染、遺伝また遺伝、先祖代々同じ情状を繰り返した結果、電灯のある今日においても尚我々は、日が出ては起き、日が入っては眠るという周期作用に服している。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "『易経（雷地豫の卦・九四）』にも、これに近い情状が有り、「由って予（楽し）む、大いに得ること有り、疑う勿れ、友相集まる」とあるものはこれである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大観は仕事の感情を盛り上げてゆく、今度の陸海軍への報国的制作、海と山とに因んだ二十点などは、さうした感情状態でできあがつた作品である。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、そこをその……情状酌量というわけには行きませんか。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "過失罪として情状を酌量されるかどうかも、今となっては疑問で、ことによると謀殺と認定されるかもしれないのです。",
              "citation": {
                "source": "予審調書",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
