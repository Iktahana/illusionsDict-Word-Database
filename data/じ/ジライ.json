[
  {
    "uuid": "abfb2e5c-5069-5ad1-9f28-8f01f9a67ad2",
    "entry": "爾来",
    "reading": {
      "primary": "じらい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
