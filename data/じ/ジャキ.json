    "definitions": [
      {
        "index": 1,
        "gloss": "devil",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "祭日〔二〕宮沢賢治アナロナビクナビ睡たく桐咲きて峡に瘧のやまひつたはるナビクナビアリナリ赤き幡もちて草の峠を越ゆる母たちナリトナリアナロ御堂のうすあかり毘沙門像に味噌たてまつるアナロナビクナビ踏まるゝ天の邪鬼四方につゝどり鳴きどよむなり",
              "citation": {
                "source": "祭日〔二〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天の邪鬼の小便の音さ。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほう、天の邪鬼の小便ぁ永ぃな。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の邪鬼の小便ぁたまげだ永ぃな。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「永ぃてさ、天の邪鬼ぁいっつも小便、垂れ通しさ。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はこれからはもう天邪鬼になって、新人がどれだけ巧い作品を書いても、感心しないことにする。",
              "citation": {
                "source": "土足のままの文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "口が腐っても、惚れているとは言わぬ積りだったが、この際は簡単に言ってのける方が、お加代への天邪鬼な痛快さがあった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな無駄なお喋りを、信吉がペラペラと続けていたのは、実は薄井を本来の俗物の地位まで、自分と共にひきずり下したいという天邪鬼からであった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "天邪鬼のあんたの事だから、きっとそうに違いありませんですわ」　すると池上は諾いて、「それもある。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一　行くなと言われると、陽子はもう天邪鬼な女だった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つには、京吉が命令するように停めたということへの、天邪鬼の反撥が、陽子の足を田村へ向けたのだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまた、それと同じ天邪鬼が、田村へ行く時間を出来るだけ伸ばして、春隆を待たせてやろうという気持を、ふと起させた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな悔恨めいた気持があっただけに、再び戻って来た京吉の言葉をきくと、陽子は思わず起ち上り、日頃の勝気な天邪鬼の手がもはや一皮むけば古い弱い女の手になって、「どうしたの、京ちゃん、おかしい人ね」　ついぞこれまで、どんな男にもあけなかったドアをあけた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（金内吉平氏談）　　　　　　　　　　◇　前述のような数々の逸話は、翁一流の天邪鬼の発露と解する人が在るかも知れぬが、そうばかりではないように思う。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "題は「十銭芸者」――書きながら、ふとこの小説もまた「風俗壊乱」の理由で闇に葬られるかも知れないと思ったが、手錠をはめられた江戸時代の戯作者のことを思えば、いっそ天邪鬼な快感があった。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだね」「なんだもないものだ、お前さんは、おっかない骸骨と抱きあってるじゃないか」「骸骨、骸骨って、あれかね」「笑いごとじゃないよ、お前さん、おっかない骸骨と、何をしようというのだ、お前さんは、邪鬼に魅いられてるのだよ」　喬生も薄気味悪くなってきた。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は邪鬼に魅いられて、殺されようとしているところでございます、どうかお助けを願います」　魏法師は喬生から理由を聞くと朱符を二枚出した。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この頃、邪鬼が祟りをして、人民を悩ますから、その者どもを即刻捕えてこい」　武士は道人の命令を聞いてどことなしに行ってしまったが、間もなく、喬生、麗卿、金蓮の三人の邪鬼に枷鎖をして伴れてきた。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士は邪鬼にそれぞれ鞭を加えた。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "邪鬼は血塗れになって叫んだ。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その邪鬼の口供の概略をあげてみると、喬生は、伏して念う、某、室を喪って鰥居し、門に倚って独り立ち、色に在るの戒を犯し、多欲の求を動かし、孫生が両頭の蛇を見て決断せるに効うこと能わず、乃ち鄭子が九尾の狐に逢いて愛憐するが如くなるを致す。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士達は泣き叫ぶ邪鬼を曳いて行った。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだね」「なんだも無いものだ、お前さんは、おっかない骸骨と抱き合ってたじゃないか」「骸骨、骸骨って、あれかね」「笑いごとじゃないよ、お前さんは、おっかない骸骨と、何をしようと云うんだね、お前さんは、邪鬼に魅られてるのだ」　喬生もうす鬼魅悪くなって来た。",
              "citation": {
                "source": "牡丹燈籠　牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「じゃきっと間もなくつかまるねえ。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そいじゃきつねが人をだますなんて偽かしら。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「八斗なんかじゃきかないよ。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「じゃきみは主人のとこに雇われているんだね。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局こんな間接のことまで論じていたんじゃきりがない、ただわれわれはまっすぐにどうもいけないと思うことをしないだけだ。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと聞いておくれ、むじゃきな子どもの言うことなんだ。",
              "citation": {
                "source": "はだかの王さま",
                "author": "THE EMPEROR'S NEW SUIT",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　それを聞くと、父親は、このむじゃきな、かわいい子のひたいにキスをしてやりました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
