    "definitions": [
      {
        "index": 1,
        "gloss": "seasonal greeting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
