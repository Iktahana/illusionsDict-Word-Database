        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "結城の弘経寺は寂寞たる山間にあって、猿の声悲しく風の甚寒い処であったことは、梅痴枕山二家の作にしばしば言われている。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚寒にいたれば他所より稿をもとめて作りおきたる※に入りて眠る。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            }
          ]
        }
