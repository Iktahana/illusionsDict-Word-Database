[
  {
    "uuid": "7ae9bb36-83b0-5d81-b8a0-52b845817a29",
    "entry": "人間",
    "reading": {
      "primary": "じんかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
