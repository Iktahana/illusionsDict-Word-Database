[
  {
    "uuid": "384e8afb-fab2-5162-85a6-84b449a61723",
    "entry": "尽瘁",
    "reading": {
      "primary": "じんすい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
