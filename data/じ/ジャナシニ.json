          "literary": [
            {
              "text": "わからんじゃ無しに、ひっくり返るね。",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は雛じゃなしに鶏じゃ。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩くのじゃなしに、揃えた趾で跳ねながら、四五匹の雀が餌を啄いていた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「勿論個人的な意味じゃなしに――わかるでしょう？",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草はペラゴロの昔から、人情的でありすぎ、一座とお客とナレアイでありすぎた、お客は芸や劇を見るのじゃなしに、一座を見にくるだけで、演劇の進歩というものは殆どなかったようだ。",
              "citation": {
                "source": "モンアサクサ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "★　十九の娘の縁談などゝいうものは、男が好きだの嫌いだのと云っても、恋愛感情によってじゃなしに、全然浪漫的気分によって自分の人生を遊んでいるに過ぎないようなものだから、好きも嫌いも、ちょッとの風の吹き廻しで、百八十度にグラリと変ってすましたものだ。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "八紘一宇という、科学的な推論じゃなしに、神話の中から民族の理想と予言をひきだしてくる、何々教のお筆先、璽光様の世直しの御理想と全然異るところがないじゃないか。",
              "citation": {
                "source": "邪教問答",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "応援団ばかりじゃなしに、満場の大半が拍手を送っている。",
              "citation": {
                "source": "町内の二天才",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、素子がしそうもないのじゃなしに、谷村がそれを巧妙にくいとめているように思われるのだ。",
              "citation": {
                "source": "戯作者文学論",
                "author": "――平野謙へ・手紙に代えて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争ばかりじゃなしに、正義も人道も思慮も機転もみんなホーキしてしまったように思われる。",
              "citation": {
                "source": "安吾巷談",
                "author": "巷談師退場",
                "note": "青空文庫"
              }
            },
            {
              "text": "願わくは、娘さんの方で婿えらびをするのじゃなしに、婿さんの方から娘さんに求婚するのでありたいものだよ。",
              "citation": {
                "source": "真珠の首飾り",
                "author": "ZHEMCHUZHNOE OZHERELJE",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱だけじゃなしに、あたしをここへ連れて来たのもその人よ。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ近頃になって気管支じゃなしに、肺らしいという見立てをする人が出てきたんで、もしそうなら、どうもなんともいわれんからな。",
              "citation": {
                "source": "トリスタン",
                "author": "TRISTAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のような事だけじゃなしに、何もかもみんなお話ししますわ。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからユスリの種は父だけじゃなしに、母を通して父、そんな風な事もあるのじゃないかと想像した事もあるのですが、これも単に僕だけの想像なんです」　私はあやか夫人のパジャマが、あんまり華麗なので呆気にとられていた。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも一度の事件じゃなしに、三日もつづいて、皆様の御知り合いの方々が四人もつづいて殺される。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は当局ばかりじゃなしに、巨勢博士も、海老塚と神山について、メンミツに調査していることを知っていた。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり交戦状態ですから、他人じゃなしに、敵ですな」「なるほど。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "正一郎という立派に経済科出身の学士が、誇張じゃなしに、こういう思いきったことを言う。",
              "citation": {
                "source": "淪落の青春",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
