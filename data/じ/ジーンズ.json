        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "〈ヒピー・ヒピー・シェイク〉スウィンギング・ブルー・ジーンズ　二カ月後、起床音楽はがらりと変わった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "スウィンギング・ブルー・ジーンズは、声が気に入らない、という高志の主張で、消滅。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志が身につけているのは、ブルージーンズだけだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "上半身裸なのに、下はちゃんと長いジーンズを穿いている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志のジーンズは短くて、裾がくるぶしの上にきている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志がブルージーンズだけ穿いて、慶一のとなりに黙って腰をおろした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志はジーンズのポケットをさぐって、カギをとりだした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "裾幅が十六センチしかないホワイトジーンズを脱ごうとして、高志は片足で立ち、二、三歩バックステップを踏んで、飛び板に背中をぶつけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一は、Ｔシャツ、ジーンズ、バスタオルと、ていねいにたたんだ上に、靴底を上にむけてスニーカーをおいた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一行とともにジーンズに長髪の連中がたむろする彼らの事務所を訪れた渡辺は、雑誌のバックナンバーを求め、定期購読の手続きを取って日本に送ってもらうことにした★。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さて、ひげ面で、長髪を頭のうしろで束ね、リーヴァイスのジーンズをはいたヒッピー風の若者ふたりがカウンターにやってきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "７　科学が文章となる過程　Ｊ・ジーンズ卿の『神秘の宇宙』（藪内清氏訳）が重版になった。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジーンズは物理学的観念論者の典型ともいうべき人であろうが、そういう哲学は勝手にしゃべらしておけばいいだろう。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し科学的名文家としてのジーンズは充分に尊重されていいと思う。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく物理学的観念論者の一人であるエディントンも亦、食い込むような厚みのある説明を与える叙述力を持っているが、ジーンズはこの本で、もっと掌を指すように、又もっと手玉に取るように、対象を生々と転がしている。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論科学者や技術家の本格的な研究は必ずしもジャーナリスティックな表現を有てないだろうし、又仮に有てたにしても敢えて有つ必要のない場合の方が多いだろうが、併し一方に於てラッセルやジーンズ又エディトン等が卓越した「文章家」であることも忘れてはならないのである。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "八朔入りの大福などを買い求め、食べ歩く彼のすぐ前を、ジーンズにトレーナー姿でカメラをたすき掛けした男が歩いていくのを彼は見つめて、果たして以前に、こうして自分の背中をまじまじと見つめたことがあったかなと彼は考え、それが取材中の自分であることには、疑いさえも浮かばない。",
              "citation": {
                "source": "鉄道模型の夜",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "エディントンとジーンズは科学を「現象の計量的すなわち数学的な記載」すなわち生物学部門すら除外する概念に限った。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "服と言っても、ジーンズに半袖シャツ、そして靴下にトレッキング・シューズだ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "半袖の白いラグビー・ジャージーに、はき古したブルー・ジーンズ。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "無漂白ダンガリーのフレアード・ジーンズに、濃いオリーヴ色の洗いざらしたＴシャツだ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "忘れるところだった」　と、ラリーは、古びたフレンチ・ジーンズのポケットに手を入れた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィリピン系の女性は、膝の上で切った古いブルージーンズに、リーヴァイ・ストラウスの赤いマークをプリントしたＴシャツを着ていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒いジーンズに、明るい華やぎのある、きわめて洒落たマドラス・チェックの半袖のシャツ。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "色の淡いブルー・ジーンズに白いテニス・シューズの彼女は、生地を裏がえしに使ったアロハ・シャツを着ていた。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベッドで布団にくるまってると、そのうち直るよ」「私も、長袖のシャツとジーンズに着替えると、いつのまにか直ってる」「だから秋なんだ」「そうだね」　坂を下りたふたりは、水路沿いの道に出た。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "色の落ちたスリムなブルージーンズ。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "白いＴシャツの上に長袖のシャツを着て、ブルージーンズをはいた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰から足首まで、自分の体のかたちに沿ってほどよく包みこんでくれるスリムなこのジーンズを、邦子は気にいっていた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "コイン・パースとバンダナだけをジーンズのポケットに入れて、彼女は部屋を出た。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
