    "definitions": [
      {
        "index": 1,
        "gloss": "to begin to like something (one did not initially like)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "よくいじわるなんかしないように気をつけないといけないぞ」　ホモイはつかれてねむくなりました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとすぐ目の前をいじわるの狐が風のように走って行きます。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "にいさんや、ねえさんたちさえも、やさしくしてくれるどころか、かえっていじわるをして、いつも言うのでした。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら、さいしょに歌をうたいはじめた、あのいじわるの、いたずらっ子には？",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "あそこの息子さん感じわるいのん？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたが感じわるい思うのん無理ないなあ」　十五銭ずつ出し合って、勘定をはらい、喫茶店を出ると、もう暗かった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹一の魅力をほんとうに味うためには、彼女には、やはり「俗物」とまじわることが必要だった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "やむをえず負える靴をとりおろして穿ち歩むに、一ツ家のわらじさげたるを見当り、うれしやと立寄り一ツ求めて十銭札を与うるに取らず、通用は近日に廃せらるる者ゆえ厭い嫌いて、この村にては通用ならぬよしの断りも無理ならねど、事情の困難を話してたのむに、いじわる婆めさらに聞き入れず。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "たすけの船はと思ってあたりをたえずさがしたのですが、いじわるく、船のかたちも、煙のかげも見あたりません。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "西雲南の、東経百度の線と北回帰線のまじわる辺り、そこだけ周囲とかけはなれた動物区をいとなんでいる、いわゆる察緬小地区の盆地だ。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、二人のもとめているものは、いじわるく、なかなか手にはいらなかった。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　と、こえをかけたであろうものを、運命の神は、時に、このようにいじわるなものである。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんた、いじわるね。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "４　二人ははずかしくてしかたがありませんでしたが、犬さんのお父さんに、「犬さんにいじわるをしないやうにいつて下さい。",
              "citation": {
                "source": "あひるさん　と　にはとりさん",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の噂にはいろいろの詐偽もまじわるものじゃ。",
              "citation": {
                "source": "武蔵野",
                "author": "山田美妙",
                "note": "青空文庫"
              }
            },
            {
              "text": "いじわるく、身をかくすに足る大木もない。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月十七日（月曜）　京都　ぶすの気取りと、いじわる。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "手に――腕に――力がつく感じわるくなし。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚の儀式がすむとまもなく、こんどのおかあさんは、さっそくいじわるの本性をさらけ出しました。",
              "citation": {
                "source": "灰だらけ姫",
                "author": "またの名「ガラスの上ぐつ」",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、ふたりのきょうだいは、ぷっと吹き出して、サンドリヨンをからかったり、あざけったり、いじわるく追いだそうとかかりました。",
              "citation": {
                "source": "灰だらけ姫",
                "author": "またの名「ガラスの上ぐつ」",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔かたちの美しいばかりでなく、心のすなおで善いこのむすめとはうらはらで、ふたりの姉たちは、あいにく、いじわるでねじけていて、妹の美しい美しいとほめられるのがにくらしくてなりませんでした。",
              "citation": {
                "source": "ラ・ベルとラ・ベート（美し姫と怪獣）",
                "author": "ヴィルヌーヴ夫人　Madame de Villeneuve",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あるいじわるな妖女が、わたしを苦しめるため、魔法で呪って、みにくいけものの姿にかえてしまったのです。",
              "citation": {
                "source": "ラ・ベルとラ・ベート（美し姫と怪獣）",
                "author": "ヴィルヌーヴ夫人　Madame de Villeneuve",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹見は、いじわるくにやりとわらって、ポケットに手を入れた。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵曹長は、わかい青江三空曹のことを、いじわるくからかったのではありませんでした。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（たった一目でもいいから、あの巌壁によじのぼり、ながめおろしたいものだ）　太刀川がそんなことをつぶやきながら歩きだした時、いじわるく、彼を呼ぶ者があった。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーヒーの棒は、まわりに白い湯気をからませながら、いじわるく三郎をおいかけまわすのであった。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは君をおどかすようないじわるじゃないよ。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
