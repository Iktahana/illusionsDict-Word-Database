[
  {
    "uuid": "e9cb05e3-31c8-5c4d-a34f-b3581b36a33d",
    "entry": "滋養",
    "reading": {
      "primary": "じよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
