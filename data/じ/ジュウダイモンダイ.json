[
  {
    "uuid": "2ec98635-a2c0-54e9-bcc0-fe1734d7e19f",
    "entry": "重大問題",
    "reading": {
      "primary": "じゅうだいもんだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
