          "standard": [
            {
              "text": "彼女は、熱心な女権拡張論者として知られています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "女権拡張論者たちは、社会の不平等を是正するために活動しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この作家は、自身の作品を通じて女権拡張論を唱えています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "近頃女権拡張論者と云ったようなものがむやみに狼藉をするように新聞などに見えていますが、あれはまあ例外です。",
              "citation": {
                "source": "私の個人主義",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "モンテーニュの精神的娘といわれたグルネ嬢が女権拡張論者であったことと思いくらべると、ここにもモンテーニュの思想の一つの鍵があるように思われる。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
