        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "作者は素直な筆つきで、そこに傭はれてゐる女店員の心に映じた爭議を――彼女達がその爭議によつて體驗して來たことを描いてゐる。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五の女店員を、「彼女等はまだ髮を引つ詰めにして、身體の痩せた、着物の裾と足袋の間に脛の見えてゐる娘たちであつた。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "女店員を書き女店員の些末な心遣ひを書くのに、作者の筆は正しく女流の筆である。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "職業は、南京路角、百貨店｜泰興公司の女店員、支配人デー・ダブリュ・クロフォードに愛さる。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は百貨店レーン・クロフォードの女店員になった。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "何處か大商店の避難した……其の店員たちが交代に貨物の番をするらしくて、暮れ方には七三の髮で、眞白で、この中で友染模樣の派手な單衣を着た、女優まがひの女店員二三人の姿が見えた。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "予定が今日に伸びた女店員の徒歩競争が通って行くのだ。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒眼がち、まじめそうな細面の女店員が、ちらと狐疑の皺を眉間に浮べた。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "百貨店の女店員達の忙しく動いている指。",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこし有りふれては産婆、看護婦、保姆、タイピスト、女事務員、女店員、見張女、マッサージ師、美容術師、女車掌や運転士、交換嬢、モデル女、女優一切。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "神田の某文具店の女店員は、鉛筆部、ノート部、帳簿部、万年筆部といった風に受け持ちがあって、勘定一切の責任を負うている。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "某大百貨店と某大呉服店の女店員（茶酌み女も含む）が平均十円程度の売り物である事は、上流の貴婦人にもかなり知られているらしい。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの女店員はどこの桂庵が一手販売だ。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの工女とか、女店員とか専門のもあれば、お望み次第のデパート式もポツポツある。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに小僧や女店員がわからないで番頭の処に聞きに行ったりすると、いよいよそうした気もちになる。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草店が繁昌して、やがて女中を兼ねた若い女店員が雇われて来ると、間もなく、いままで穏かだった二人の調和が、みるみる乱れて来た。",
              "citation": {
                "source": "銀座幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "澄子と呼ぶ二十を越したばかりのその女店員は、小麦色の血色のいい娘で、毬のようにはずみのいい体を持っていた。",
              "citation": {
                "source": "銀座幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草屋の二階では、半分開けられた硝子窓の向うで、殆んど無地とも見える黒っぽい地味な着物を着た、色の白い女主人の房枝が、男ではない、女店員の澄子を前に坐らせて、なにか頻りに口説きたてていた。",
              "citation": {
                "source": "銀座幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "数年前デパートの女店員は家庭を助けたが、今は家庭が中流で両親そろい月給で生計を助ける必要のないものというのが採用試験の条件である。",
              "citation": {
                "source": "「大人の文学」論の現実性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いや君、この事件は意外に複雑だよ」　この時、水野刑事が帰って来て、女店員中島せい子と細工師谷村三造とを連れて来た旨を告げた。",
              "citation": {
                "source": "謎の咬傷",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "開店分列式（男女店員数百名の）　（三星デパートのビルデング）五月十日　晴、曇、比古居、大阪。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "このミディネットというのは、字引をひいてもちょっと出て来ない字だが、ミディすなわち正午にあちこちの商店や工場からぞろぞろと飯を食いに出てくる女という意味で、いろんな女店員や女工員を総称するパリ語だ。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍客――私達――の出現にすっかりよろこんで、お客のほうは女店員に任せっきり、いろいろ江戸時代の絵を出して来たり、自分の著した“Netsuke”と題する研究的な一書を見せたり、そのあいだも、何にするのか女中のお仕着せみたいな染め絣が一尺二尺とよく売れて行く。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "女店員たちの仕舞にしろ、そこには様々の興味ある問題があると思われる。",
              "citation": {
                "source": "今日の生活と文化の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、女店員がその謡曲による仕舞を稽古するということに果してどこまで働く女性の感情にとって必然があるのだろう。",
              "citation": {
                "source": "今日の生活と文化の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると殆ど例外なしに訊かれた女店員は、一寸お待ち下さいと云って、売場のどこからか男の店員をつれて来るだろう。",
              "citation": {
                "source": "女の歴史",
                "author": "――そこにある判断と責任の姿――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまで働く婦人と云えば、志を立てて上京し新聞雑誌の記者として働いている少数の特殊な人たちか、さもなければ電話交換手、女店員、あとは夥しい女工、女中で、これらの勤勉で無知のままに暮している同性たちへの関心は、一般の女のひとの心に決して目ざめていなかった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、その厭世的な女店員生活からの脱出であったが、変質的な良人との間が苦しくて、一人の女の児をもって離婚した。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女店員時代から詩を書いて、「文学をやろうという意志で自分の生活を計画しているというような自覚的なものはなかったけれども」彼女は「文学に対しては高い喜びで接していた。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
