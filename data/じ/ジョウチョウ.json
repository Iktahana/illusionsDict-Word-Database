[
  {
    "uuid": "98762661-c9a6-5ebd-8fd7-6980d7dc1d6c",
    "entry": "上長",
    "reading": {
      "primary": "じょうちょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "one's superior",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "せっかく続けている観測も上長官が交迭して運悪く沿革も何も考えぬような後任者が来ると、こんな事やっても何にもならんじゃないかの一言で中止になるという恐れがあった。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勲績のある上長として、盛名のある君子として、礼を尽した態度であった。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "研究題目は上長官の命令で決まっており、その上に始めから日限つきでその日までにはどうでも目鼻をつけなければならないこともある。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、例えば蚯蚓の研究所で鯨の研究をやりたいといったような場合には、ともかくも一応上長官の諒解を得るために、その研究の結果がその研究の目的に直接適合する所以を説明して許可を得るのが穏当である。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上長官がよほどの人でない限りあまり勝手な事は許されないであろう。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上長々しい前置きによって私は多くの読者の倦怠を招いたであろうと思う。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学に関する理解のはなはだ薄い上長官からかなり無理な注文が出ても、技師技手は、それはできないなどということはできない地位におかれている。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一方下級の技術官たちの間では実に明白に有効重要と思われる積極的あるいは消極的方策があっても、その見やすい事が、取捨の全権を握っている上長官に透徹するまでにはしばしば容易ならぬ抵抗に打ち勝つことが必要である。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉時代の上長けたらんといと床し。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "云う事、為す事が皆、上長の機嫌に触りますので……もっとも只今では政党の関係は無くなりましたが、昔の有力者という者が残っておりまして、近づいて参ります選挙でも、警察の力を利用して、勝手な事をしてやろうと腕に捩をかけて待っているような情勢であります」「フムフム。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ以上長い詩形は、いくら試みても駄目である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "墨子の此の主張が、多分を治者優者に對つて爲されてゐるのは特に有理であつて、其意は先づ人の上長たる者の「兼」を以て道とせんことを求め、そして此「兼」の道に民庶も從ふに至るによつて理想的幸福世界を現ぜんとするに在る。",
              "citation": {
                "source": "墨子",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてこの土堤に捨てられた角は、日数経て一｜掌、もしくはそれ已上長き根を石だらけの荒地に下す事、草木に異らず、他に例もなければ訳も別らず。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに、老人は自分の握っている権力で、父としての権力や、支配者としての権力や、上長者としての権力で、青年を束縛しようとする。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪を普通の倍以上長くしている。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年はこの上長くはもう居られまいと思った。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "上長に対して、そんな云い方は、この工場としては全くめずらしかった。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "お徳もまあそれで安心して、むこうの云う通り、三年以上長年するという証文を入れて帰って来ました」「その時、妹には逢わなかったんですね」「はい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "向島の寮",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに、老人は自分の握つてゐる権力で、父としての権力や、支配者としての権力や、上長者としての権力で、青年を束縛しようとする。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし、天火同人というのは、上長の命に従って、目下の者には服従するなという意味が一番強いのだぞ。",
              "citation": {
                "source": "馬車",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピジャマ姿の宮子は上長衣をひっかけたまま出て来ると、黙って参木を長椅子に坐らせた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひっかけた上長衣が宮子の肩からずり落ちた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮子は床に落ちている上長衣を足で跳ね上げた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "親父さん躍起になつて運動した結果、漸と許されて割合に仕事の楽な兵站部に働く事になつたが、不思議にも朝夕顔を合はせる上長官は、自分の子息であつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二箇月以上長崎に留まつてゐた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　以上長四尺｜許の半紙の巻紙に書いた書牘の全文である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上長途の事ゆえ、簾を垂れたままでは、鬱陶しく思われるでありましょう。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "行人莫上長堤望　　　　行人長堤に上りて望むこと莫れ、風起楊花愁殺人　　　　風起れば楊花人を愁殺す。",
              "citation": {
                "source": "閑人詩話",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "長官や上長に対して、若い者の間には、何たる不埒な考えが拡がっとることか！",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "上長に対しては、彼は更に上手に立ちまわった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
