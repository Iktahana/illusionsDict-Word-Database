[
  {
    "uuid": "7aedcca0-d645-564c-897e-9896877a20cb",
    "entry": "上書",
    "reading": {
      "primary": "じょうしょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
