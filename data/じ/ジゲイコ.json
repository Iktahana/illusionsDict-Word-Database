        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "剣道の昇段審査を控え、道場の仲間たちと互いに切磋琢磨する地稽古に励んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地稽古では勝敗にこだわりすぎず、自分の構えや足さばきを確認することが大切だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "休憩を挟まずに何度も地稽古を繰り返し、体力と精神力を極限まで追い込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
