    "definitions": [
      {
        "index": 1,
        "gloss": "bull's-eye (pattern)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
