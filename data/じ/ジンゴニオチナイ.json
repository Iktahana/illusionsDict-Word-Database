[
  {
    "uuid": "de12c010-63f0-5f92-9e23-df037efbb32c",
    "entry": "人後に落ちない",
    "reading": {
      "primary": "じんごにおちない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
