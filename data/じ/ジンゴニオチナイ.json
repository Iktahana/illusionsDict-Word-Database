      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be second to none (in)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれども、小生と雖も、貴兄の幸福な結婚を望んでいる事に於いては人後に落ちないつもりだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕だって、マルクスやレーニンに関心を持つことは敢て人後に落ちないつもりですからな。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人中に出ることをひどく恥ずかしがるくせに、自らを高しとする点では決して人後に落ちない彼の性癖が、才能の不足を他人の前にも自らの前にも曝し出すかも知れない第一の生き方を自然に拒んだのでもあろう。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん無理な註文も多いに違いないが、それでも自分の註文に嵌まった本格探偵小説を憧憬れ望んでいる事は決して人後に落ちないつもりである。",
              "citation": {
                "source": "探偵小説漫想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "学問は大したものではないが、当時の剣客としては、人後に落ちない位の素養はあつたのであらう。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、歴史を愛し、歴史上の諸人物に親しみを持つ点に於ては、多く人後に落ちないつもりである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪筆では人後に落ちない私には、「悪戦苦闘の末勇気をふるい」原稿用紙への書き写しを終えたという祖母の気持ちが、良く分かります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕には詩というものがちっともわからぬけれども、君も御存じのとおり、天才の詩人というものを尊敬する事に於いては、敢えて人後に落ちないつもりだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎは亜米利加人だが、これあまあ大概の事物には興味を持つんだし、ことに金を出すことにかけちゃあ何にだって人後に落ちない気でいるんだから、この今夜の一隊も、例によってほとんど、英米両国の旅行者だけだったと言っていい。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその何かを感じてゐることは必ずしも人後に落ちないつもりである。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、記憶力の点に於て、殆ど零に近く、人の顔や、名を忘れる事には、いつも呆れているが、本を読んで忘れる事も、人後に落ちないつもりである。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "劇評家として独自の地歩を占め、印象批評の輝やかしき筆を揮ひつゝあつたジュウル・ルメエトルは、『女弟子』『赦免』等の心理喜劇に、繊細な観察と潤ひある機智を盛り、「劇作にかけても人後に落ちない」器量を示したが、「あまりに洗練された趣味」が災ひをなして、「力」ある作品を創造することができなかった。",
              "citation": {
                "source": "仏国現代の劇作家",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀行の副頭取だが、古美術では人後に落ちない趣味家であった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十八　踊る時計",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから地球人類が栄えるように、ねがうことについても人後に落ちない。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はとりたてて能がないが、ただ一つ中庸を尊ぶことに於て人後に落ちないことが取柄ではないかと考えている。",
              "citation": {
                "source": "中庸",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はバカげた飲んだくれぶりでは歴戦の勇士で、性こりもない点では人後に落ちない方である。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その二　大岡越前守",
                "note": "青空文庫"
              }
            },
            {
              "text": "名は小みどりと呼び、三絃、笛、太鼓はもちろんであるが、婦芸一般に精をだし、書を読むことも人後に落ちない。",
              "citation": {
                "source": "純情狸",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、誰がなんといっても美食没頭の体験においては人後に落ちない自信を有している。",
              "citation": {
                "source": "河豚食わぬ非常識",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはその頃既に近代仏蘭西の小説を多く読んでいた事については、窃に人後に落ちないと思っていたが、しかしいざ筆を取って見ると文才と共に思想の足りない事を知って往々絶望していたこともあった。",
              "citation": {
                "source": "正宗谷崎両氏の批評に答う",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ベク助とても悪党の筋が一本通っている点では人後に落ちない曲者だから、みんな見破られているようだと分っていても、よろしい、一そうやってやれという不逞な根性が鎌首をもたげるのである。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十三　幻の塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分などはまだまだこの内容に近づくことが出來る程の境地に到達してゐないながらに、猶これを讚嘆するに於いては人後に落ちないことを期してゐるものである。",
              "citation": {
                "source": "三太郎の日記　第三",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "イヤに持たせずに、手っ取早く発表したまえ」　これも退屈がり屋では人後に落ちない、会社員の筒井｜知丸が早速食い付いて来ます。",
              "citation": {
                "source": "古城の真昼",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角、妹と称する女を競売にすると言うのは怪しからん事で、出鱈目に於いては人後に落ちない友人達も、此の時ばかりは顔を見合せて、黙ってしまいました。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第二夜　匂う踊り子",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆者は先生の地震学に対する甚大なる貢献に敬意を表する点においては人後に落ちないつもりであるが、そうかと言って先生のお説に盲従することは、筆者の良心が許さない。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものの判斷は覺束ないが、見ることと聞くことは人後に落ちない筈の八五郎です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "闇に飛ぶ箭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「美人礼讃」では、決して人後に落ちない江戸っ子達が、急に騒ぎ出したのも無理のないことでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "恋患い",
                "note": "青空文庫"
              }
            },
            {
              "text": "『美人禮讃』では、決して人後に落ちない江戸つ子達が、急に騷ぎ出したのも無理のないことでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "戀患ひ",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『玉藻』、二九、一）慧眼の士のみ　私も常に俳句の新しい事を希って居ることは人後に落ちない。",
              "citation": {
                "source": "俳句への道",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、私は、他のいろいろのおもしろく無い性質を持っていることにかけては、人後に落ちない人間であるが、この手の分裂症状だけは、ほとんど持っていない。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
