[
  {
    "uuid": "f1642160-b24b-5104-920a-ada7a0afee68",
    "entry": "実母",
    "reading": {
      "primary": "じつぼ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
