  {
    "uuid": "fa933927-76d2-567c-ad81-ba8d295eb750",
    "entry": "銃傷",
    "reading": {
      "primary": "じゅうしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
