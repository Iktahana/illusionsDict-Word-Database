    "definitions": [
      {
        "index": 1,
        "gloss": "cowardly soldier",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
