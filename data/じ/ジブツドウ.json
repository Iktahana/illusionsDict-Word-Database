[
  {
    "uuid": "5a72b3d7-2e97-5dd5-b3a5-09240a7ff918",
    "entry": "持仏堂",
    "reading": {
      "primary": "じぶつどう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
