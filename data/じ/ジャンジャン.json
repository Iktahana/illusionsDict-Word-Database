        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「夜店のステッキがまたじゃんじゃんするといけないから、貴女は早くお帰り。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "イトウで皆とわかれる時にも、じゃんじゃん飲んだよ。",
              "citation": {
                "source": "雀",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃんじゃんお洗濯をする。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "九、これからは太宰治がじゃんじゃん僕なんかを宣伝する時になったようだ。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　吉弥のじゃんじゃんが初まった。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなか探せぬと思っていたところ、いくらでも売物があり、盛業中のものもじゃんじゃん売りに出ているくらいで、これではカフェ商売の内幕もなかなか楽ではなさそうだと二の足を踏んだが、しかし蝶子の自信の方が勝った。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからおしまいには大きなランプのホヤのこわれたのを取り出して、どんどんじゃんじゃんという物すごい囃子に合わせてそれを見物の前に振り回して見せたあとで、そのホヤのガラスの一片を前歯で噛み折りそれをくちびるの間に含んで前につき出し両手を広げて目をむき出し物すごいみえをきった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の白痴がいつのまにかやって来て昨日の通りに石を持ち腕を曲げ首をかしげて、今朝ほどじゃんじゃんと鳴りわめいた半鐘の下に佇んでいたのである。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、じゃんじゃんと鳴り渡るすり半とともに、どやどやと駆けつけてきたものは、江戸の名物火事ときいて鳶の装束の一隊でありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "年の瀬近い江戸の大路の屋並みは、すでにまったく大戸をおろして、まこと名物の江戸の花が、いまにもそこらあたりからじゃんじゃんぼうとやりだしそうな夜ふけでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃんはじゃんじゃん」　といってから、慶一は、なんだこれは、と自分のことばの意味と文法を再検討し、なにかべつのいい方はないものかと、必死で頭を回転させた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだ、なにごとか」「電文によりますと、どうもトーキーのフィルムをそんなにじゃんじゃん消費せられては困るというのです。",
              "citation": {
                "source": "軍用鮫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴーぴーじゃんじゃんやかましい楽器を鳴らしている見世物もある。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "近火の摺りばんを滅多打ちにじゃんじゃんと打ち立てることもある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半鐘の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等が夜通し厳重に見張っているあいだは別になんの変ったこともなかったが、少し油断して横着をきめると、半鐘はあたかもかれらの懶惰を戒めるように、おのずからじゃんじゃん鳴り出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半鐘の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ね、面白いじゃありませんか、ふだんから火の見櫓にあがって、打てば打たるる櫓の太鼓、か何かやっていたもんだから、同じいたずらをするにしても、火の見梯子へ駈けあがって、半鐘をじゃんじゃん打っ付けたと見えるんですね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半鐘の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは何うあっても少佐が怪しいことになって貰わなくてはと、各紙筆を揃えてじゃんじゃん書き立てたから、弱ったのは少佐殿だ。",
              "citation": {
                "source": "土から手が",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃんじゃんコピーして配れる。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "管理人になってからは、いうまでもなく凡ての管理人と同じように振舞って、村で小金でもためていそうな連中とは互いに交際をしたり、子供の名附親になったりするが、貧乏人からは特定の小作料を勝手に増額してじゃんじゃん取りたてる。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって、うなぎのきもを焼くのだって、とっときの炭をじゃんじゃんつかっているし、お醤油だってジャブジャブつかって、これぢゃ大変なことになってしまうわ。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「専吉さんがつかまったりして、わたしは、なおじゃんじゃんお正月でもしてやりたい気持でしょ？",
              "citation": {
                "source": "鏡餅",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前の思うとおりをじゃんじゃん答えるんだぞ。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたいが三つの時のことなんだ、しんさいがあってさ、関東大震災でじゃんじゃん家が燃えちまってさ」　しんさい――と聞いて子供たちの呟きがなぜか一時に停るのであった。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七人の若い女が、南加州の各地で、ルウス・ジュッドに似ていると言うので逮捕され、身許保証がはっきりするまで留置されるという騒ぎ――何時ものことながら、亜米利加式にじゃんじゃん騒いだ光景が思いやられる。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命も思考力も、電気現象にもとづいているのだから、そういうことを知っている者なら、かんたんにやれるのだ」「なるほど」「そこでわしは、これからこの部屋で、生きている金属をじゃんじゃん作ろうと思う。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "“総員退去せよ”と、ベルがじゃんじゃん鳴ったよ。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "警鈴が、じゃんじゃん鳴りだしたのは、それから更に、五分ほど経て後のことだった。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コーヒー茶碗とか、花瓶とか、灰皿とか、スタンドとか、そういったものを、あれっとか、あらっとかいいながら、じゃんじゃん下に墜として壊してください」「そんなことをすれば、私はすぐ馘になってしまいますわ」「なあに大丈夫。",
              "citation": {
                "source": "什器破壊業事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十×年八月八日　室内温度、湿度、照明度すべて異状なし　配給も正確なり　本日は、地下千メートルを征服し、現在われわれの棲んでいるこの極楽地下街建設の満三ヶ年の記念日であるので、ラジオは朝から、じゃんじゃんと楽しい音楽を送ってくる。",
              "citation": {
                "source": "今昔ばなし抱合兵団",
                "author": "――金博士シリーズ・４――",
                "note": "青空文庫"
              }
            }
          ]
        }
