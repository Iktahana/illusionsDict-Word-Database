        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "遙か河下に星の如くまたたくは淺草の人家なめり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "西の渡の簇々とした人家を崖の上に仰いで、船を着けた、満島からこゝまで九里の間を、三時間半。",
              "citation": {
                "source": "天竜川",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の本館から下方の山腹にはもう人家が少く、色々の樹林に蔽はれた山腹の斜面が午後の日に照らされて中々美しい。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山葡萄は矢張り人家にはそぐはないと見える。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちの麓へ降りようとも、人家のある所へ着きさえすれば、とにかく安心ができるのである。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "人家も、燈灯も、畑も、森も、川も、丘も、そして歩いてゐる我我の體も、灰を溶したやうな夜霧の海に包まれてゐるのであつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、左手の方に人家の燈灯がぼんやり光つてゐた――Ｆ町かな‥‥と思ひながら闇の中を見透すと、街道に沿うて流れてゐる狹い小川の水面がいぶし銀のやうに光つてゐた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇の中を見透すと、人家の燈灯はもう見えなくなつてゐた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の人家や、海がだんだんに眼の下に見えて來た。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に、モリエールの晩年の「タルチーフ」や、「厭人家」などは、喜劇と云っていゝか、悲劇と云っていゝか分らないものだ。",
              "citation": {
                "source": "愛読した本と作家から",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人家を離れて四五｜丁も泝ると既に路もなければ畑もない。",
              "citation": {
                "source": "都の友へ、Ｂ生より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "田畑ある島と知れけりあげ雲雀、これは僕の老父の句であるが、山のむこうには人家があるに相違ないと僕は思うた。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御承知の通り、こんなに人家が建て込んでいるところですから、蛇も蛙も滅多に出るようなことはありません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、まだここばかりじゃあない、この頃この近所でも、たびたび飼い鶏を取られるんですよ」　寺内の鶏をぬすみ、人家の鶏を盗み、その悪事重々の奴であるから、そのくらいの仕置は当然であるというような彼の口ぶりであったが、それならば猶更のこと、土地の者がわたくしの刑罰を加えるのはよくないと半七は思った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくゆくと人家が絶えて路が暗くなり、わずかに一つの電燈が足もとを照らしている、それが教えられた場所であるらしいところへやって来た。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途中にたった一軒だけ人家があって、楓のような木が幻燈のように光を浴びている。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜私は私達がそれからいつも歩いて出ることにしていた銀座へは行かないで一人家へ歩いて帰った。",
              "citation": {
                "source": "器楽的幻覚",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその辺りの地勢や人家の工合では、その近くに電車の終点があろうなどとはちょっと思えなくもあった。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かがどこかで見ていやしなかったかと、自分は眼の下の人家の方を見た。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの人家から見れば、自分は高みの舞台で一人滑稽な芸当を一生懸命やっているように見えるにちがいなかった。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その蔭にちょっぴり人家の屋根が覗いている。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは途中にただ一軒の人家しかない、そしてその家の燈がちょうど戸の節穴から写る戸外の風景のように見えている、大きな闇のなかであった。",
              "citation": {
                "source": "蒼穹",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、もう気がたるみ、筋が弛んで、早や歩行くのに飽きが来て、喜ばねばならぬ人家が近づいたのも、たかがよくされて口の臭い婆さんに渋茶を振舞われるのが関の山と、里へ入るのも厭になったから、石の上へ膝を懸けた、ちょうど目の下にある滝じゃった、これがさ、後に聞くと女夫滝と言うそうで。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今もなほ南岸の人家に往時の船宿のおもかげ少しは残れるがなきにあらず。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "兩岸の人家低く高く、山に據り水に臨む其｜數數百戸。",
              "citation": {
                "source": "少年の悲哀",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんな事は、」とお正はうつむいた、そして二人は人家から離れた、礫の多い凸凹道を、静かに歩んでいる。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車の歌志内の渓谷に着いた時は、雨全く止みて日は将に暮れんとする時で、余は宿るべき家のあてもなく停車場を出ると、流石に幾千の鉱夫を養ひ、幾百の人家の狭き渓に簇集して居る場所だけありて、宿引なるものが二三人待ち受けて居た。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い町を辿つて人家を離れると、渓を隔てゝ屏風の如く黒く前面に横はる杣山の上に月現はれ、山を掠めて飛ぶ浮雲は折り／＼其前面を拭ふて居る。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "両岸の人家低く高く、山に拠り水に臨むその数｜数百戸。",
              "citation": {
                "source": "少年の悲哀",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "なりひらが、Ｔ「そうよ半分だ」　おいッ大将、Ｔ「しかもかんじんかなめのお前さんの名前の処が無えんだよ」　アッ、と驚く左衛門。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
