    },
    "definitions": [
      {
        "index": 1,
        "gloss": "space between trees",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "吾々は、この映画を見ることによって、吾々自身が森の樹間をかける山鳩や樫鳥になってしまうのである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "只、取残された昔のかたみとして、なかば朽ちている軒が、かすかに樹間を通して外から気味悪く窺われていた。",
              "citation": {
                "source": "窓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱根を進発してすぐに峠にさしかかり、振りかへつてみると箱根の湖は樹間に小さくいぢらしげに碧水を湛へてゐるのが眼下に見えました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に抗弁するのでも無ければ、駁撃するというでも無く、樹間の蝉声、聴き来って意に入るもの無し、という調子にあしらって終った。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊び疲れたヴィナスが森の奥の奥の冷い泉で、汗ばんだ四肢をこっそり洗っていると、あちらの樹間に、また、ついそこの草の茂みのかげに、神々たちのいやらしい眼が光っていた。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶因狂疾成殊類　　災患相仍不可逃今日爪牙誰敢敵　　當時聲跡共相高我爲異物蓬茅下　　君已乘※氣勢豪此夕溪山對明月　　不成長嘯但成※　時に、殘月、光冷やかに、白露は地に滋く、樹間を渡る冷風は既に曉の近きを告げてゐた。",
              "citation": {
                "source": "山月記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶因狂疾成殊類　災患相仍不可逃　　　今日爪牙誰敢敵　当時声跡共相高　　　我為異物蓬茅下　君已乗※気勢豪　　　此夕渓山対明月　不成長嘯但成※　時に、残月、光｜冷やかに、白露は地に滋く、樹間を渡る冷風は既に暁の近きを告げていた。",
              "citation": {
                "source": "山月記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔母は此方を見も返らで、琵琶の行方を瞻りつつ、椽側に立ちたるが、あわれ消残る樹間の雪か、緑翠暗きあたり白き鸚鵡の見え隠れに、蜩一声鳴きける時、手をもって涙を拭いつつ徐に謙三郎を顧みたり。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "石燈籠が、ずらりと両側に並んで、池の端から、下谷の花柳界の賑いの灯が、樹間に美しく眺められた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれは、この映画を見ることによって、われわれ自身が森の樹間をかける山鳩や樫鳥になってしまうのである。",
              "citation": {
                "source": "からすうりの花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やゝ長けた午前の日影が樹間からさし込んで、それが草の葉の上にチラチラした。",
              "citation": {
                "source": "ひとつのパラソル",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹿島の祠は寂寞として日影が樹間から線を成して斜にさし込んでゐるのを見たばかりであつた。",
              "citation": {
                "source": "船路",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "一歩々々草を分けて進んで行く一行のすがたは、時には樹のかげに、時には岩角に、また時には林の中にそれと長く連つて、Ｈの負つた水筒にをりをり樹間をもれて来る影がキラキラと美しく光つたりなどした。",
              "citation": {
                "source": "草道",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄春の夜ふかく月影に、庭の樹間をさまよひて、よき物の音のきかましき宵よといへば、妹は―やをら緒琴をとりおろし、奏でいでつる一曲のあまりに調のかなしきに、睫毛うるみし夜もありき。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "半ば山蔦に蔽はれた古い上射水車は、樹間を漏れる暖い陽光をまだらにうけてゐる。",
              "citation": {
                "source": "水車のある教會",
                "author": "オウ・ヘンリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅い鳥が、青い樹間から不意に飛び出した。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "孤りこれ等の姉妹と道を異にしたるか、終に帰り来らざる「理想」は法苑林の樹間に「愛」と相｜睦み語らふならむといふに在りて、冷艶素香の美、今の仏詩壇に冠たる詩なり。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "孤りこれ等の姉妹と道を異にしたるか、終に帰り来らざる「理想」は法苑林の樹間に「愛」と相睦み語らふならむといふに在りて、冷艶素香の美、今の仏詩壇に冠たる詩なり。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏訳詩集",
                "note": "青空文庫"
              }
            },
            {
              "text": "孤り此等の姉妹と道を異にしたるか、終に歸り來らざる「理想」は法苑林の樹間に「愛」と相睦み語らふならむといふに在りて、冷艶素香の美、今の佛詩壇に冠たる詩なり。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "常公はいつも獨りで別に桐油を樹間にかけた。",
              "citation": {
                "source": "歸國",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹間に幾つとなくかけられた桐油小屋、バケツの中に一杯滿された酒、年寄も若者も一緒になつて賑はしく歌を唄つて躍つた。",
              "citation": {
                "source": "歸國",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぼつかなくも籬に沿い、樹間をくぐりて辿りゆけばここにも墓標新らしき塚の前に、一群の男女が花をささげて回向するを見つ、これも親を失える人か、あるいは妻を失えるか、子を失えるか、誠にうき世は一人のうき世ならず、家々の涙を運ぶこの青山の墓地、芳草年々緑なる春ごとに、われも人も尽きぬ涙を墓前に灑ぐべきか。",
              "citation": {
                "source": "父の墓",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "妖惑の羽搏絶えて、しめらへる樹間や。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い樹間を絡りながら流れる煙。",
              "citation": {
                "source": "榛名",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園のマルモの樹間には、蛍がいっぱいだ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩を移すごとに迫る競技の日のことなど遠い昔の日のようにのどかとなり、視界は拡がり空気は清澄、人かげ稀で樹間からわずかに隠見する屋舎の紅い瓦は平和な楽園を思わせる。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹間をもる月影に照されたあさ子の、波打つ肉体の顫律を感じたとき、丹七は二十年の昔、河の中から引き上げられたあさ子の母の死骸に触れた時の感じを思い起してぎょっとした。",
              "citation": {
                "source": "血の盃",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｇ・Ｂ・Ｓ　ジョウジ・バアナアド・ショウは、樹間の白い小砂利道を踏んで私たちのまえまでくると、そこで立ちどまって、ポケットからはんけちを掴み出してちんと鼻をかんだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "はるか樹間の村屋に炊煙の棚曳くあり。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでは緑に囲まれて坐るというところによさがあり、九州――臼杵で見た庭は、心が自ら樹間を逍遙する宏やかさがある。",
              "citation": {
                "source": "九州の東海岸",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
