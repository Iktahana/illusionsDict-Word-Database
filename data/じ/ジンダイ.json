[
  {
    "uuid": "eea771d0-4f9b-5628-8e1c-534fad6a9d3e",
    "entry": "甚大",
    "reading": {
      "primary": "じんだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
