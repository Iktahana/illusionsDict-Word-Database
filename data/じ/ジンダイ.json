      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "very great",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その代りその会合たるや極めて古典的で当時温泉に浴してこれを見聞した筆者の無為を慰すること甚大であった。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの恐ろしい函館の大火や近くは北陸地方の水害の記憶がまだなまなましいうちに、さらに九月二十一日の近畿地方大風水害が突発して、その損害は容易に評価のできないほど甚大なものであるように見える。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏らが当時の少青年の情緒的教育に甚大な影響を及ぼしたことはおそらくわれわれのみならずまたいわゆる教育家たちの自覚を超越するものであったに相違ない。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "▲実に社会主義、自然主義は共に、警戒すべき日本の今日に甚大なる害毒を流すもの、当局者が之れに圧迫を加ふるは理の当然と云ふの他はなし。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと得るところも、甚大であろうと思う、と私は或るとき一人の学生に、まじめに言ったことがあるけれども、そのとき学生は、にやりと笑って、行ったって、僕たちには逢ってくれないでしょう、と正直に答えたのである。",
              "citation": {
                "source": "困惑の弁",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚大甚深のものなのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し凝る氣で從事するものは、其の絹紙筆墨を費すや甚大甚夥なるも、畢に繋がれたる馬の一つの柱を遶り、籠められたる猿の六つの窗に忙しげなると同樣に、何の進境をも示さぬものである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "叡山筑波山の如きは無くもがなのものだといふ評さへ聞くが、こゝのは蓋し出來れば出來た方が婦女老幼のために甚大の利を餽ることにならう。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦ふ毎に悪戦ならざるはなく、勝つ毎に甚大の犠牲を払はざるはなかりき。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れどもこの新光景が今後の舞台に重大の変化を与ふるの動機たるは何人と雖ども拒み難き所、吾人が甚大の戒心を要すと云ふは乃ち此の点にありて存す。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "幽深｜見難し、甚大無量の、また、円満｜無礙の、謂うところのおぎろなき物、この霊妙音は何から来る。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "『応仁記』等に依って見ると、如何に被害が甚大であったかを詳細に列挙して、「計らざりき、万歳期せし花の都、今何ぞ狐狼の臥床とならんとは」と結んで居る。",
              "citation": {
                "source": "応仁の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌を止めてしまつてから誰にも会はないんだが、彼等の宣言式でない方面の熱情には今以て僕は甚大の敬意を払つてゐるつもりだ。",
              "citation": {
                "source": "貧しき文学的経験（文壇へ出るまで）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "其他「人情的福音書」、「婦人の為にせる福音書」と称えらるる路加伝が来世と其｜救拯と審判とに就て書記す事は一々茲に掲ぐることは出来ない、若し読者が閑静なる半日を選び之を此種の研究に消費せんと欲するならば路加伝の左の章節は甚大なる黙想の材料を彼等に供えるであろう。",
              "citation": {
                "source": "聖書の読方",
                "author": "来世を背景として読むべし",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚大甚深なものなのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば純粋哲学を学ぶには甚大な能力を要するが、或る学者を選んでその哲学を攻究するとすれば、研究は自然とその深を為し易い理屈である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "朋友有って道を同じくすれば、相益すること甚大、悦び楽しむべきことである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど社会を根底より顛覆せんとする思想に至りては、之を唱ふる当人も、其禍の甚大なるを知らず。",
              "citation": {
                "source": "文壇一夕話",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその後に於ける朝鮮の我国に貢献した功績の甚大さは全く想像にあまるものがある。",
              "citation": {
                "source": "日本上古の硬外交",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "有力にして天分有る隠れたる作家が多数現われ、そこに科学小説壇というものを作り、お互いに研究し合い、刺戟し合いしてこそ、始めて意義あり且つ甚大なる発展が期待されるのである。",
              "citation": {
                "source": "『地球盗難』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ドイツの女子の選手は、勝敗によって嫁入りの結果に甚大なる影響を及ぼすとの事である。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと同様なわけで、太陽もその進化の初期に、まだその直径がずっと大きかったころにはその潮汐作用によって諸遊星に甚大な影響を及ぼしたであろう。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "又たとい敵を撃退せる場合に於ても軽挙追撃して隊伍を紊る時は、敗者のなお所有する集結せる兵力のため反撃せらるる危険甚大で、追撃は通常行なわれず、徹底的な戦捷の効果は求め難かった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一七四四年第二シュレージエン戦争に於てベーメンに突進したフリードリヒ大王が、敵の巧妙な機動戦略のため一回の会戦をも交える事なく甚大の損害を蒙って本国に退却した如きはその最も良き一例である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "トラウンは巧妙なる機動に依り一戦をも交えないで大王に甚大なる損害を与え、その全占領地を回復したのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時西方の敵再び前進し来たるの報告に接しただちにこれに向い、十一月五日二万二千の兵力をもって六万の敵をロスバハに迎撃、これに甚大の損害を与えた。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇襲的効果は甚大であった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのため財政的負担は甚大であった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "満州軍の建設には人知れざる甚大な努力が払われた。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本でジイドは、実に驚くべき過重評価をうけたのであるが、且て二十年近い昔、「狭き門」「背徳者」などが翻訳出版された時文学愛好者がアンドレ・ジイドなる名に払った注意は決して甚大なものではなかった。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
