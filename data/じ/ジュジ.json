[
  {
    "uuid": "919a9441-c7da-5edc-857d-bbab5dc68d05",
    "entry": "受持",
    "reading": {
      "primary": "じゅじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
