      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "announcement of time",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（昭和八年四月、日本放送協会『調査時報』）",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日午前十一時とかに東京天文台から放送される時報を受け取ってクロノメーターの時差を験するためである。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラジオを聞いたらいいではないかといったら、電池を消耗するから時報と天気予報以外は聞かないのだという。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和六年十二月、日本放送協会調査時報）",
              "citation": {
                "source": "ラジオ・モンタージュ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜の疲労で今朝は七時の時報を聞いても仲々起きられなかった。",
              "citation": {
                "source": "新郎",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月十一日花房敬吾　　福岡時報　記者様』　編輯長は、洋半紙に鉛筆で書いたこの手紙を、私の前に投げ出しながらフフンと笑った。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……旦那、おらが時計は、日に二回、東京放送局の時報に合わせるから、一｜厘も間違わねえぞ、と大分｜大形なのを出して威張る。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、世間は如何に見ようとも、自分の使命は国際的舞台にあるをあくまでも任じて、少しも志望を曲げずに極東時局に関する内外の著書は得るに随って精読し、内外新聞の外交に関する事項は細さに究めて切抜きを保存し、殊に『外交時報』は隅から隅までを反覆細読していた。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "『外交時報』は第一号から全部を取揃えて少しも座右から離さなかった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　村井保の証言　村井｜保は、映画雑誌、シネマ時報の編集主任で、年齢は三十四歳、雑誌記事のことで、東京キネマのスタジオへ出入りしているうちに山上みさをと知り合いになり、半年ほど前から彼女と情事関係をむすんでいたものである。",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとから来たのは、シネマ時報の記者でしょう、機嫌をそこねると出鱈目な悪口を書きなぐるんです。",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　ボーイ鷲尾の証言　植田欣子の証言によって、シネマ時報記者村井保は、三時頃に被害者山上みさをの室を出ていったことがわかった。",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "国際局の機関雑誌『外国文学時報』も亦大きな欠点をもっている。",
              "citation": {
                "source": "ニッポン三週間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "がらんとした白壁の裾には、荒繩で束った日露時報の返品が塵にまみれて積んである。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このアウチイ・ベエコンの口を土台に、デトロイト時報のアウチイ・オットマン画伯が「その男」のスケッチを画いた。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "この屍体発見の時のことを、ドウマイアはデトロイト時報へ寄書して、「私は眼を瞑ってドロシイの屍体を堤の草の上へ下ろした。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、筆者は検屍をしたジェネシイ郡警察医 D. R. Brassie 博士が前記のデトロイト時報記者ラルフ・ガル氏に寄せた個人的手記に基いて、ガル氏が遠廻しに記述しているところを簡明に解釈しているのである。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "度びたびデトロイト時報を引用するが、大きく言えば劃時代的な表明として、同紙上にも特筆してある。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京一、日本一の東洋時報社で、給仕からタタキ上げた腕ッコキの新聞記者といえば、チョット立派に聞こえるかも知れないが、それがアンマリ腕ッコキ過ぎたのだろう。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お恥かしい話だが、吾輩、コンナに真剣になったものは四五年以前に東洋時報社で、初めて社会部外交記者に編入されて三面記事を取りに行った時以来、今度が初めてである。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとある時報恩講が勤まるからといって五、六日暇をとって帰って行った。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "（24）所謂絶縁状は民國十六年九月二十六日の『順天時報』に掲載された。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "時報社の報告によると、この書状が確にロシアから投函されたことは、郵券の消印が證明するといふ。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルナンやジュリアンは、特に景教碑のみに關する論文はなく、彼等の意見は別の題目の著書の中に附記されて居るのみであるが、ノイマンは「西安の僞造碑」と題する論文を、『ドイツ東洋協會時報』に掲載して居る（25）。",
              "citation": {
                "source": "大秦景教流行中國碑に就いて",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正十四年十二月六日）（大正十五年一月『外交時報』第四十三卷第一號所載）",
              "citation": {
                "source": "支那猥談",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は自分の室の時計に綿様のものを支って、時報を鳴らなくした筈だったね。",
              "citation": {
                "source": "後光殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「順天時報」はそのために大きい彼の写真を出したり、三段抜きの記事を掲げたりした。",
              "citation": {
                "source": "馬の脚",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「順天時報」の記事によれば、当日の黄塵は十数年来｜未だ嘗見ないところであり、「五歩の外に正陽門を仰ぐも、すでに門楼を見るべからず」と言うのであるから、よほど烈しかったのに違いない。",
              "citation": {
                "source": "馬の脚",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "常子は「順天時報」の記者にこの時の彼女の心もちはちょうど鎖に繋がれた囚人のようだったと話している。",
              "citation": {
                "source": "馬の脚",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも「順天時報」の記者は当日の午後八時前後、黄塵に煙った月明りの中に帽子をかぶらぬ男が一人、万里の長城を見るのに名高い八達嶺下の鉄道線路を走って行ったことを報じている。",
              "citation": {
                "source": "馬の脚",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
