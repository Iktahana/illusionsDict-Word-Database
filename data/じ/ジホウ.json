[
  {
    "uuid": "666d7824-8d98-5a06-b766-d83fbbd6a0d1",
    "entry": "時報",
    "reading": {
      "primary": "じほう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
