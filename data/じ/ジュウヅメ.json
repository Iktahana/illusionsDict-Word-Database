    "definitions": [
      {
        "index": 1,
        "gloss": "food packed in nest of lacquered boxes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
