        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ああ十字疾行する街路のうへそのするどさに日輪もさけびくるめき群集をこえて落しきたるを感じいのり齒をくひしめ受難の日のひくれがたわれつひに蛇のごとくなりて絶息す。",
              "citation": {
                "source": "受難日",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頭の上には古い受難図が掛けてある。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして無意識に仰向いて太い石の柱の角を辿つて、その上の方に掛つてゐる古い受難図を見た。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、何の事もなく疑ひだけで濟んだのだが、一｜夜を思はぬ所で明かしてしまつた誰彼、あまり寢覺めがよかつた筈も無いが、何でも物事の先驅者の受難の一卷とすれば、近頃の仕合せな新しい麻雀好きの面面はすべからくそれ等の諸賢に敬意を捧げて然るべきかも知れない。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリストの磔刑を演出する受難劇の場面で始まるこのフランス映画には、おしまいまで全編を通じて一種不思議な陰惨で重くるしい悪夢のような雰囲気が立ち込めている。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思ってみると、一年に一回ずつ特別な日を設けて、それを理由などかまわずとにもかくにもめでたい日ときめてしまって強いてめでたがり、そうしてそのたびに発生するいろいろな迷惑をいっそう痛切に受難することにもなかなか深い意義があるような気がしてくる。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてエイズス・キリストスの降誕、受難、復活のてんまつ。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この劇に取扱った栴陀羅（低い階級）の娘との関係も、彼の愛の受難史の一つである。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから昔のけなげな恋の受難者たちのように、最後迄勇気を失さぬことを誓い合って、砂丘を降りた。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……青白く痩せこけて……髪毛をクシャクシャに掻き乱して……無精髪を蓬々と生やして……憂鬱な黒い瞳を伏せた……受難のキリストじみた……。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニイチェこそは、実に近代の苦悩を一人で背負つた受難者であり、我々の時代の痛ましい殉教者であつた。",
              "citation": {
                "source": "ニイチェに就いての雑感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "フリドリヒ・ニイチェもまた、近代知識人の苦悩を一人で背負つて、十字架の上に死んだ受難者である。",
              "citation": {
                "source": "ニイチェに就いての雑感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ecce homo とは、十字架に書きつけられた受難者キリストの標語であつた。",
              "citation": {
                "source": "ニイチェに就いての雑感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）にもかかはらず、ニイチェこそは新しい時代の受難者、耶蘇キリストにまちがひなかつた。",
              "citation": {
                "source": "ニイチェに就いての雑感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眠れない夜の續く枕許に、休息のない水の流れの、夜更けて淙淙といふ音をきく時、いかに多くの詩人たちが、受難者として生れたところの、自己の宿命を嘆くであらう。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私自身で人生のかがやかしい受難者になりたく思はれたのである。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "住み難き世を人一倍に痛感しまことに受難の子とも呼ぶにふさわしい、佐藤春夫、井伏｜鱒二、中谷孝雄、いまさら出家｜遁世もかなわず、なお都の塵中にもがき喘いでいる姿を思うと、――いやこれは対岸の火事どころの話でない。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、ほんたうの幸福とは、外から得られぬものであつて、おのれが英雄になるか、受難者になるか、その心構へこそほんたうの幸福に接近する鍵である、といふ意味のことを言ひ張つたのであつた。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、ほんとうの幸福とは、外から得られぬものであって、おのれが英雄になるか、受難者になるか、その心構えこそほんとうの幸福に接近する鍵である、という意味のことを言い張ったのであった。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この本の主人公シッダールタは、釈尊のコースを直線とすれば、これに対して弧形を描き、受難求道して幾分か大乗仏義を窺い得た形跡がある。",
              "citation": {
                "source": "褐色の求道",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから例の娘さんの、受難の地も決して見紛うようなところではなかった。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "若いご婦人の受難の地も見紛うところではなく、開けた荒れ地とイチイの藪に挟まれて道が伸びており、藪の奥に巨木がちらほら見える館の広場があった。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "神の如き先生の受難と思つたらしく、美しい娘は彼の傍らに寄り添うて、敵意を含む眼光で私を睨めてゐた。",
              "citation": {
                "source": "彼に就いての挿話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴォルテール、ルソオの受難を知るや。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからお前達は基督の受難によって罪からあがなわれたのだ。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう受難者は怒っていい。",
              "citation": {
                "source": "大衆物寸観",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い役人たちは外国へやられる事は受難だと思ってあきらめていると云っている。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルジョア作家、自由思想家などもその衝撃を披瀝し、三・四月の文芸時評はことごとく何かの形で、同志小林の受難にふれたのである。",
              "citation": {
                "source": "同志小林の業績の評価に寄せて",
                "author": "――誤れる評価との闘争を通じて――",
                "note": "青空文庫"
              }
            }
          ]
        }
