    "definitions": [
      {
        "index": 1,
        "gloss": "second accession to the throne",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
