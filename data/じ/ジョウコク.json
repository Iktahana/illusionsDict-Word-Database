[
  {
    "uuid": "62e4e0f9-2c40-54fc-a12e-cb456885c2d7",
    "entry": "上告",
    "reading": {
      "primary": "じょうこく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
