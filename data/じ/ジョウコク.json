  {
    "uuid": "7677ddd9-3743-5e7c-b364-ba021446b9bd",
    "entry": "上刻",
    "reading": {
      "primary": "じょうこく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "first third of a two-hour period",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "巫女　丁どや――丑の上刻ぞの。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "天竜、雲を遣り、雷を放ち、雨を漲らすは、明午を過ぎて申の上刻に分豪も相違ない。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "卯の上刻頃には、先鋒有馬勢が崩れたのを切っかけに、鍋島勢、松倉勢、みな追い落された。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "光秀の方は、丑の中刻で、秀吉の方は丑の上刻であったと云う。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "丑の上刻と云えば二時半で、中刻は三時だから、三十分違いである。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "天竜、雲を遣り、雷を放ち、雨を漲らすは、明午を過ぎて申の上刻に分毫も相違ない。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは風が南に変って、珍らしく暖いと思っていると、酉の上刻に又｜檜物町から出火した。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "見分の役人は戌の上刻に引き上げた。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「正月二日卯上刻妻出産仕、女子出生仕候間、御定式之通、血忌引仕候段御達申上候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "同月八日此間出生仕候娘病気之処、養生不相叶申上刻死去仕候、七歳未満に付、御定式之通、三日之遠慮引仕候段御達申上候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日卯上刻御供揃、巳中刻御出、先施薬院へ御入、御装束召換、巳時と申て午の時御参内あり、入夜還御。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「七つ半時頃より御呼吸御短促に被為成、卯之上刻御差重被遊候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "御隠居様昨卯上刻御逝去被遊候に付、為伺御機嫌今五日四時より九時迄之内、改服に而出仕可致旨。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "右に依れば、里落命致し候は、私検脈後｜一時の間と相見え、巳の上刻には、篠既に乱心の体にて、娘死骸を掻き抱き、声高に何やら、蛮音の経文｜読誦致し居りし由に御座候。",
              "citation": {
                "source": "尾形了斎覚え書",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "集まるのは羅生門、刻限は亥の上刻――みんな昔から、きまっているとおりさ。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　　六　ふけやすい夏の夜は、早くも亥の上刻に迫って来た。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夜の戌の上刻頃、数馬は南の馬場の下に、謡の会から帰って来る三右衛門を闇打ちに打ち果そうとし、反って三右衛門に斬り伏せられたのである。",
              "citation": {
                "source": "三右衛門の罪",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「日は四月十三日、辰の上刻（午前八時）、場所は船島に於いて」　と云う事になった。",
              "citation": {
                "source": "巌流島",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "興長主武蔵ニ謂テ曰ク、明朝辰ノ上刻向島ニ於テ、岩流小次郎ト仕合致スベキ由ヲ諭ス。",
              "citation": {
                "source": "巌流島",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "小次郎は辰の上刻少し前に、美々しく飾られた小舟で検使役人と共に向島で待っていた。",
              "citation": {
                "source": "巌流島",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして渚に近よって、「武蔵殿、拙者は辰の上刻前に渡っているに、余りの遅参不届で御座らぬか」　と声をかけた。",
              "citation": {
                "source": "巌流島",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵衛殿の臨終は、今朝寅の上刻に、愚老確かに見届け申した。",
              "citation": {
                "source": "或敵打の話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同は今夜｜丑の上刻までに、この宿と、本所三つ目杉野十兵次どのの借宅と、前原神崎両人の店と、この三箇所へ集合することになっている。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうだ、丑の上刻！",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「公方様、御不例御座遊ばされ候ところ、御養生かなわせられず、去る二十日｜卯の上刻、大坂表において薨御遊ばされ候。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて未の上刻となり、いよいよ古今｜未曽有の捕物吟味御前試合。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "丹頂の鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "番所の控えには、『酉刻上刻、紀州様御内、御中※以下〆二十二挺』と、ちゃんと記帳されたのに、正門を入ったときは、それが、わずか九挺になっていた。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "御代参の乗物",
                "note": "青空文庫"
              }
            },
            {
              "text": "早朝｜卯の上刻から、お呼び寄せの大太鼓が、金線を溶かしたお城の空気をふるわせて、トーッ！",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "謡曲羽衣の一節、柄になく風流なところのある男で、大迫玄蕃が、余念なくおさらいに耽っていると、夜は戌の上刻、五ツどき、今でいう午後八時だ。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "「半時ほど前だから卯の上刻だ、親分も知ってなさるだろうが采女の馬場の中屋敷ね、あすこの西尾様お長屋の普請場へ面出しすべえとこちとら早出だ、すたすた来かかってふいと見るてえとこの獄門じゃあねえか、いや、親分の前だが、これにゃああっしも胆を潰したね。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怨霊首人形",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
