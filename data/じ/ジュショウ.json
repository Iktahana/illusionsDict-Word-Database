[
  {
    "uuid": "3d8f3509-9831-5f1d-9d70-0abe6330265f",
    "entry": "受賞",
    "reading": {
      "primary": "じゅしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
