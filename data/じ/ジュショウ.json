          "literary": [
            {
              "text": "知事はチチコフと同様に、あまり肥ってもいなければ痩せてもいない人物で、頸にアンナ十字章をかけていたが、まだその上に、近く星大授章を貰うことになっているという噂であった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と皇居における授章式のもようなどもよく人に訊かれるところである。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
