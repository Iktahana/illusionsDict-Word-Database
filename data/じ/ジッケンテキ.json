[
  {
    "uuid": "314985ba-265d-5a55-ba36-34a7dc7dc3e1",
    "entry": "実験的",
    "reading": {
      "primary": "じっけんてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
