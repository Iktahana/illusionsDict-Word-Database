        "examples": {
          "standard": [
            {
              "text": "その神学書は、人格神論の観点から神の存在を論じている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、無神論者であると同時に、人格神論にも懐疑的だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "中世ヨーロッパでは、人格神論がキリスト教思想の根幹をなしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それは、例へば人格神論的なる宗教が實踐を重んずるのと違つて、つねに觀想的であることをその本質としてゐる。",
              "citation": {
                "source": "唯物史観と現代の意識",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "汎神論はいふに及ばず、通常有神論又は人格神論（Theismus）と呼ばれ宗教的色彩の濃厚さを自らも誇り人も許してゐる世界觀でさへ、この峻嚴なる論理的歸結を囘避し難い。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
