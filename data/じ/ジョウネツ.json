[
  {
    "uuid": "b326b95c-9f8a-5053-affb-937df38de6b8",
    "entry": "情熱",
    "reading": {
      "primary": "じょうねつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
