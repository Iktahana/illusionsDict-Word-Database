        "examples": {
          "standard": [
            {
              "text": "満月が昇ると、彼は恐ろしい人狼に変身してしまうという伝説がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その村では、古くから人狼の襲撃に備えて、夜間は戸締りを厳重にしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "映画では、特殊効果を駆使して、リアルな人狼の姿が描かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
