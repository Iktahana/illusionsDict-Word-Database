[
  {
    "uuid": "02b26440-b7b1-57dd-b873-7cea318ce76f",
    "entry": "上京",
    "reading": {
      "primary": "じょうきょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
