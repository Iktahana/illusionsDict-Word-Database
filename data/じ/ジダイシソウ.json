    "definitions": [
      {
        "index": 1,
        "gloss": "admiration of the powerful",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
