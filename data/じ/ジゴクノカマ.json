[
  {
    "uuid": "3df3f62f-18e4-59b5-9123-b33a1ab49131",
    "entry": "地獄の釜",
    "reading": {
      "primary": "じごくのかま",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
