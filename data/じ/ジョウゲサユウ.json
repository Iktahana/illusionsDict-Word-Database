    "definitions": [
      {
        "index": 1,
        "gloss": "up and down, left and right",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
