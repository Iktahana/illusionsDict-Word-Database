[
  {
    "uuid": "c829f680-7b8d-57db-a0af-4885f4c3e5cc",
    "entry": "上述",
    "reading": {
      "primary": "じょうじゅつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
