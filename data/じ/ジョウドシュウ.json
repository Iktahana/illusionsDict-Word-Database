    "definitions": [
      {
        "index": 1,
        "gloss": "Pure Land sect (of Buddhism)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
