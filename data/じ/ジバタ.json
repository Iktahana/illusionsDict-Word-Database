        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おつぎは死んだお品が地機に掛けたのだといふ辨慶縞の單衣を着て出るやうに成つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸も手紡で、染めも正藍を用い、昔風な地機で織ります。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔を守る者は今も地機を用い続けます。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高田近くの磯野や御所で細々ながらも地機で「大和絣」を織るのを見られるでしょう。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来は手紡の糸を地機で織ったのでありますが、段々普通の絹糸を使うようになりました。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論｜養蚕とか地機とか糸繰りとか、若干農村に縁のある内職も探し得たであろうが、何にしても労働が土と関係が薄くなるようでは、村に居住しても次第に異分子をもって目せられる結果は免れ得なかったのである。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "家に地機の置いてあった頃でも、夏は少なくとも買木綿を着る人が多くなっていた。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の地機は紐でからだを機に結わえたものだったが、心のやさしい女なのでその煩わしさも厭わず、紐をほどき機から下りて、遠くへ水を汲みに行って来て飲ませた。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
