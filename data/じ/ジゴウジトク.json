    "definitions": [
      {
        "index": 1,
        "gloss": "paying for one's mistakes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「ふん、」と兎は輕蔑し、「自業自得ぢやないの。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう人で、悪気はなくとも少し慾気が手伝っていると、百貨店で品物を買ったような訳ではない目にも自業自得で出会うのである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あれは自業自得です。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人、小間使が好奇心で、照子様をおどしたので、謂わば自業自得というものです。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるを、わざと人間どもが、迎え見て、損わるるは自業自得じゃ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "残っているのは待合の借りばかりだ」「……………」「みんなお前さんの自業自得さ。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ふん、」と兎は軽蔑し、「自業自得ぢやないの。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんは、まあ、自業自得で仕方がないとしても、あたしにまで、こんな赤い太鼓の片棒かつがせて、チンドン屋みたいな事をさせてさ、お母さんはきっと、お父さんをうらんで、化けて出るわよ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "左様いふ人で、悪気は無くとも少し慾気が手伝つてゐると、百貨店で品物を買つたやうな訳では無い目にも自業自得で出会ふのである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「違うでしゅ、それでした怪我ならば、自業自得で怨恨はないでしゅ。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何をやらしてみても、力いっぱいつかいすぎて、後になるほど根まけしてしまうといういつもの癖が、こんな話のしかたにも出てしまったわけで、いわば自業自得ですが、しかしこうなればもうどうにもしようがない、駈足で語らしてもらうほかはありますまい。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「強情ぬかした老ぼれめ、刀の錆は自業自得だ」　其の時傍の闇から直助が顔を出した。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そりやアあなたの自業自得といふものです――めかけでなけりやア、圍ひ者が天道さまのお罰を受けたのでしよう」と、かの女はお鳥を睨み返してから、もとの言葉をこちらに向つて續けた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あいつは」と、千代子はお鳥のことを云つて、「自業自得だから、仕かたがない、さ――けれど、この人も、どうせ、碌な死にかたはしますまいよ――何度わたしに苦勞や心配をかけたか分らないんですもの。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "自業自得、そんな言葉も彼は吐いた。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、それも自業自得だつた、と言つては言ひ過ぎだらうか。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それですから勇二は逃げるも、どうするもありません、なんの苦もなく召し捕られました」「金造はなぜ殺されたんですか」「金造の殺されたのは自業自得で……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "金造め、わっと叫んで表まで逃げ出したが、急所のひと突きで脆くも往生という始末、まったく自業自得と云うのほかはありません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作家の筆は、一見すると他奇なきものと見られますが、どうして容易ならぬ飛躍性が充ち充ちてゐて、うつかりと、われわれが技巧的なことなどを口にしたら、こつちこそ飛んだ自業自得に陥入るであらう、長成を見逃すことになるでせう。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分からいえばそれは「自業自得」であった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "自業自得を、人の責任におっつけるのは、図々しすぎるぜ」船長は、こいつ一つ脂をすっかりしぼりぬいてやろうと考えた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "今我々親子の世間から疎れてゐるのは、自業自得の致すところで、不名誉の極です！",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "古人これを猟った唯一の法は、毎人鏡を持ちて立ち向うに、バシリスクの眼毒が鏡のためにその身に返り、自業自得でやにわに斃れたのだ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "甥の身の上は自業自得の因果で是非ないとしても、自分の宗家たる藤枝の家をこのまま亡ぼしてしまっては、先祖に対しても申し訳がない、死んだ兄に対しても申し訳がない。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んでもかまはぬから舟を出せといふ客もありたるが、その客は、自業自得、死んでもかまはざるかも知れざるが、名所に傷が付きて、我等の商賣がばつたり。",
              "citation": {
                "source": "北條より一ノ宮へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "自業自得と世の中では申します。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうに自業自得でございます。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでその過失の反理性的な処に、どうかすると一旦堕落した女の、自業自得の禍から遁れ出る手掛かりもあるものだ。",
              "citation": {
                "source": "クサンチス",
                "author": "XANTHIS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「でも自業自得だわ。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "じごうじとくと、あきらめるんだね」　人形の顔の怪人は、ニヤニヤわらいながら、きみのわるいことをいうのです。",
              "citation": {
                "source": "怪人と少年探偵",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
