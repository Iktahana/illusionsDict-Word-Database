        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」みんなは叫んで、じゃんけんをするために、水の中から手を出した。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、はさみ無しの一人まけかちで、じゃんけんをした。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その声は街へ遊びに行くのがおじゃんになったのを悲しむように絶望的だった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が鶏に餌をやろうとしていた時、ＫＳ電鉄の重役が贈賄罪で起訴収容され、電車は、おじゃんになってしまったことを、村の者が知らしてきたのである。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三に、やはりだちんがもらえなかったので、雑誌や模型飛行機の材料を買う夢が、おじゃんになってしまいました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」みんなは叫んで、じゃんけんをするために、水の中から手を出しました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、はさみ無しの一人まけかちでじゃんけんをしました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "座敷では、じゃかじゃかじゃん……ここらは本職だわね。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃんちきちき面白そうに囃すかと思うと、急に修羅太鼓を摺鉦交り、どどんじゃじゃんと鳴らす。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "突如として、どどん、じゃん、じゃん。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夜店のステッキがまたじゃんじゃんするといけないから、貴女は早くお帰り。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……ジャン、チェーコン、リウコン……コンリウ、コンジャン、チェーコンチェー……チェーリウコンコンジャンコンチェー……じゃんすいじゃんすい、ほうすいほう……すいすいじゃんすい、ほうすいほう……」　子供は又も黒い顔を見合わせた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "広場の中央と、遥か離れた町の片側とに出来ている音楽隊の屋台では却ってじゃん／＼激しい曲を吹奏し出した。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの喜びも、ちょっとしたおとなの気持ちの変化でたちまちおじゃんになってしまう。",
              "citation": {
                "source": "空気ポンプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "イトウで皆とわかれる時にも、じゃんじゃん飲んだよ。",
              "citation": {
                "source": "雀",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃんじゃんお洗濯をする。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
