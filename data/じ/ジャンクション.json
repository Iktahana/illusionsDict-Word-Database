        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "池の中島にガルバをすえて、小船でサーモジャンクションを引っぱりあるいては、時々の水温の水平ならびに垂直分布を測った。",
              "citation": {
                "source": "池",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前常念とのジャンクションから頂上までは本沢へ向って相当大きな雪庇がつづいていた。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは近所にクラパム・ジャンクションと云う大停車場のある御蔭である。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "このジャンクションには一日のうちに、汽車が千いくつか集まってくる。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "救貧院はグランド・ジャンクション水道会社からの供給の他に、ポンプ井戸がその構内にあり、収容者はブロード・ストリートに水汲みに行くことは決して無かった。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "グランド・ジャンクション会社は事業所（取水場）をチェルシーからブレンフォードに移し、そこに大きな沈殿池を作った。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことはハマースミスでテムズ川から取水しているウェスト・ミドルセックスも同様であり、ブレントフォードで取水しているグランド・ジャンクション会社も同様であった。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "グランド・ジャンクション社は、潮が届く範囲で人口が多いブレントフォードから水を受け取っていたが、会社は水を大きな貯水池に貯め、社員が言うところによると水を濾過していた。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "「赤い貨車」というようなものは、かかれていることより、ああいう焦点であれをかいた作者の成長の節がおもしろいので、そこから、どっさり啓蒙的旅行記をかくようになったその間のジャンクションが、内面から作品化されていないということは、やはり注意をひくところですね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一本の花」から「赤い貨車」、それから一つのジャンクションとなるものとしての作品です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "レイナーズ嬢は自分で運転するか、運転手に頼んで、そうですね、バーハムジャンクションまで行ったでしょう。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャンクションを曲がるとき、向こうのガス・ステーションの給油ポンプのわきで、アテンダントのジョーが手を振った。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこからバスでビクトリアまで行き、クラパム・ジャンクションまで乗った。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "車に乗れ、マリ・ジャンクションまで乗せてやる、来い」　チャフィが昔の威厳を取り戻して言った。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェルシー社、イーストロンドン社、ウエストミドルセックス社、グランドジャンクション社、サウスワーク社、ボクソール＆ランベス社はすべてテムズ川に依存する。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "サンベリティからメイフェアまでグランドジャンクション社の給水系だから苦しむだろう。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
