[
  {
    "uuid": "b1af1938-0993-5081-acfd-d05d8c2a11f9",
    "entry": "儒家",
    "reading": {
      "primary": "じゅか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
