        "examples": {
          "standard": [
            {
              "text": "教室には、熱心にノートを取る女子生徒がたくさんいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、クラスで一番活発な女子生徒として、文化祭の実行委員長を務めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この席、男子生徒と女子生徒が隣り合わないように配慮したんだ」と先生が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "女子生徒だけが入試の手伝いに駆り出されることへの抗議と事態の改善要求。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二年前に卒業した、ひとりの女子生徒について」「この出来事について本格的に取材するとなると、取材相手の重要度にしたがって、端から順につぶしていかなくては」　彼女の言うとおりだった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
