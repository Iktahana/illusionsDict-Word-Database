[
  {
    "uuid": "625d3758-9964-5dd8-905c-3c84d3319306",
    "entry": "順境",
    "reading": {
      "primary": "じゅんきょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "favorable circumstances",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "つまり逆に言へば、子供の自然的な童話精神が、そのまま順境に發育して、巨大な文化にまで茂つたものが、即ち文學や藝術の詩なのである。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "順境に自らにして生じた張る氣でさへも上説の如くである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "余はわが身一つの進退につきても、またわが身にかかわらぬ他人のことにつきても、決断ありと自ら心に誇りしが、この決断は順境にのみありて、逆境にはあらず。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな場合でもフン詰まらず、如何なる逆境でも順境に引っくり返す事が出来て、世間はどこまでも拡がって行くように見える。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "郷里から來たものに聞いて彼は勘次が次第に順境に赴きつゝあることを知つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして女だけに彼の服裝から其順境らしいのを見てとつて心から愉快らしかつた。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "順境に立つて私が專門の學術を攻究することが出來たとしても到底私は間斷なく腦力を消耗して行かねばなりません。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は我身一つの進退につきても、また我身に係らぬ他人の事につきても、決斷ありと自ら心に誇りしが、此決斷は順境にのみありて、逆境にはあらず。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は我身一つの進退につきても、また我身にかゝはらぬ他人のことにつきても、決斷ありと自ら心に誇りしが、此決斷は順境にのみありて、逆境にはあらず。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "順境に自然に生じた張る気でさえも上説のようである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、これは君子の順境の時の事であって、偉大な聖賢も逆境の時に遇えば、苦しみ悩むことを免れない。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "だとするとこの一節は、学問をして徳を積む人の順境の場合を説き示されたものとして観るべきである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一概にこれを語ることは出来ないが、諺にさえ、「運去って佳人に遇い、時至って友を得る」というように、先ず順境好運の時は朋を得ることが有ることを知る。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "善が用いられ悪が捨てられるのは当然の道理であるが、雲が日を覆い霜が草を圧する様に、君子必ずしも順境ばかりでなく、大人も否運に遇うのを免れない。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しそれ順境に我が意を得て、世の憂きも人の無情も知らず、空に漂う雲のように日を送る者は、或いは何も思うことも無いかも知れないが、そのような人でも、一旦、何かの折に触れて発憤し、我が身を省みる時には、或いは突如として深い思いに入り、或いは愴然として永い憂いに沈む。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、芥川はまだ年が若いし、順境にのみ在つて、人生の煉獄は少しも経て居ないのですから真に力のある作品はむしろ今日以後に期待すべきものだとも思ひます。",
              "citation": {
                "source": "芥川の印象",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後だ、この友からの手紙に、「君は順境の幸運児なり。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は我身一つの進退につきても、また我身に係らぬ他人の事につきても、決断ありと自ら心に誇りしが、此決断は順境にのみありて、逆境にはあらず。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "榛軒の生涯は順境を以て終始したので、その人と為を知るべき事実が少い。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして順境と云ってもいい。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "學校を已めた當座は、順境にゐて得意な振舞をするものに逢ふと、今に見ろと云ふ氣も起つた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、百合子さんは、あまりに順境に育ったので、人生は戦ひである事を知らずに物見遊山と心得てゐる……といふお話もあったが、わかった様なわからない様な気がした。",
              "citation": {
                "source": "日記",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うに先生は生涯順境にあって、邪心を知ること少く、いかにも無邪気な人であるようだ。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その六　暗い哉　東洋よ",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｅ――は幸福で順境にあったころ、一人の美しい魅力的な少女の愛情をかちえたのだった。",
              "citation": {
                "source": "傷心",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "順境にあれば礼節をわきまえ、逆境ゆえにむしろワガママになりがちなものではあるが、おのずから限度がなければならない。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の一年間の休學は、寧ろ順境に育まれた麒麟兒英一君を更に崇高なる人格に築き上げる素地を造つたものと謂へよう。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "之れを大隈伯が、久しく政權と近接せざるに拘らず、常に夫の終始順境を來往する伊藤山縣兩公と盛名を※うしうし」に白丸傍点］、既に政黨の總理を辭任したる後すらも、尚ほ且つ生氣溌溂たる政治家たるを失はざるに比すれば、其の差果して奈何と爲すや。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "之れを大隈伯が、久しく政権と近接せざるに拘らず、常に夫の終始順境を来往する伊藤山県両公と盛名を※うし、既に政党の総理を辞任したる後すらも、尚ほ且つ生気溌溂たる政治家たるを失はざるに比すれば、其の差果して奈何と為すや。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の栄誉順境のすべてを犠牲に、ともに誓い誓われたお艶ではないか。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからさ、順境にあるものがちょっと面喰うか、迷児つくか、蹴爪ずくかすると、そらすぐ眼の球の色が変って来るんだ。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
