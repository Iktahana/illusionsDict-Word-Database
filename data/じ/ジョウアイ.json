[
  {
    "uuid": "895b4d34-e24d-56b5-b53d-dd7a5bfc4cd7",
    "entry": "情愛",
    "reading": {
      "primary": "じょうあい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
