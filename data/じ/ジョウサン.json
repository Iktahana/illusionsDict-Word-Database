[
  {
    "uuid": "3985d67d-0a61-54fa-911f-4673b6c9049c",
    "entry": "蒸散",
    "reading": {
      "primary": "じょうさん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
