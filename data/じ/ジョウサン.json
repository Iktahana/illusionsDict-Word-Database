        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "transpiration",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして恐怖は蒸散していった。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「不感蒸散」すなわち見えない発汗はどの程度であったろうか？",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "変化を数字で記録し自分の不感蒸散を数字で示すことができた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "生体は不感蒸散によって１日あたり数ポンドを排泄しているという結論に達しこの数値によって種々の病気の診断や治療の適応を示すことができると彼は信じた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故かと言うとヒポクラテスやガレノスによると不感蒸散の異常はすべての病気の原因であり不感蒸散をこの方法によって精確に測定することが出来るからである。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことを信ずる理由は不感蒸散は目に見え触ることができるすべての排泄物を合わせたよりも大量だからである。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガレノスが不感蒸散について何も知らなくても問題ではなかった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "「不感蒸散が実際に存在することで充分であるから」と。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "臨床体温計の発明が不感蒸散を量るのに秤を使ったのに続いた理由は容易に理解できる。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "五人女にも、於七が吉三のところへ夜決心してしのんで行って、突如、からからと鈴の音、たちまち小僧に、あれ、おじょうさんは、よいことを、と叫ばれ、ひたと両手合せて小僧にたのみいる、ところがあったと覚えているが、あの思わざる鈴の音には読むものすべて、はっと魂消したにちがいない。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "へいの中ではさっきから、はさみを持ったお金持ちが、おじょうさんにかごを持たせて、色のよいリンゴをえらびながら、チョキンチョキンと切ってまわっていました。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あッ、おじょうさん、帽子に赤とんぼがとまりましたよ。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おじょうさん、背中を洗いましょうか？",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんでなくっちゃ――」「困ったおじょうさん。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おじょうさん、赤とんぼをつかまえましたよ。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、カシムはお金持のおじょうさんをおよめさんにもらいました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "お金持のおじょうさんをもらったカシムは、毎日ぶらぶら遊んでくらしていましたが、そのはんたいに、アリ・ババは毎日せっせと働かなくてはなりませんでした。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かわいいおじょうさん。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "林の中にいた小鳥たちはおやゆび姫を見て、「なんてかわいいおじょうさんだ。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ありがとう、かわいいおじょうさん。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "君はほんとに優しくかわいいおじょうさんだ。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽のすばらしい才能をもっていながら、じぶんでは気づかずにいる、あるおじょうさんを、ぼくは知っていますが、その人は、ひとりでいるとき、どんなりっぱな音楽を作曲しているのか知らずにいるし、そのことを人からいわれても本気にしません。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "メグは、マフォット家の、三人のわかいおじょうさんたちの気にいって、散歩、乗馬、訪問、芝居やオペラ見物、夜会など、いつもいっしょに、たのしい時間をすごしました。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルック先生は、とりなすように、「アメリカのおじょうさんがたは、先祖がそうであったように、独立し自活することがたっとばれるのです。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おじょうさんには、よくにあうことでしょう。",
              "citation": {
                "source": "白雪姫",
                "author": "グリム",
                "note": "青空文庫"
              }
            },
            {
              "text": "「われわれは今夜ダブリンまで遠乗りして、おじょうさんを一人ぬすんでこようと思うんだ。",
              "citation": {
                "source": "ジェミイの冐険",
                "author": "片山広子",
                "note": "青空文庫"
              }
            },
            {
              "text": "妖精たちはおじょうさんをだいて外につれだし、その代りに一本のぼうをベッドにおくと、それがおじょうさんのすがたに変った。",
              "citation": {
                "source": "ジェミイの冐険",
                "author": "片山広子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の妖精がおじょうさんを自分の前にのせて少し行くと、またべつの妖精にわたし、ゆくときのとおりに町々の名をよびながら馬を走らせる。",
              "citation": {
                "source": "ジェミイの冐険",
                "author": "片山広子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みんなが代りばんこにおじょうさんを乗せているね、ぼくも、ちょっとでも乗せてあげたい。",
              "citation": {
                "source": "ジェミイの冐険",
                "author": "片山広子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「よろしいとも、お前もおじょうさんをのせてあげな。",
              "citation": {
                "source": "ジェミイの冐険",
                "author": "片山広子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
