    "definitions": [
      {
        "index": 1,
        "gloss": "taking command of a corps in a battle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
