    "definitions": [
      {
        "index": 1,
        "gloss": "ground",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その音楽の布いて行く地盤の上に、遠い昔の北国の曠い野の戦いが進行して行った。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の日はポツオリに行って腹立たしくうるさい案内者に悩まされながらセラピスの寺の柱に残る地盤昇降の跡を見、ソルファタラ旧火口の噴煙を調べ、汚い家でスパゲッティの昼食を食って、帰りの電車で、贋銀貨をつかまされた外にはあまり人間味のある記憶が保存されていない。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この岸壁だけを見ていると、実際｜天柱は摧け地軸も折れたかという感じが出るが、ここから半町とは離れない在来の地盤に建てたと思われる家は少しも傾いてさえいないのである。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海上の日の出がどんなに美しかろうが、海鳥が飛ぼうが、鯨がはねようがそんな事はどうでもよい、一刻も早く目的地に上陸して動かぬ地盤が踏みたいと願う。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "穏やかな日光が広い園にいっぱいになって、花も緑もない地盤はさながら眠ったようである。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "河流が完成して後に一体の地盤が沈降したのではないかと疑われる。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見ていると当時の地盤の揺れ方がおおよそどんなものであったかという想像がつくような気がした。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは精神科学が物質科学ほどに堅固な地盤におかれていない所以である。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手工は勿論高等教育を受けるための下地にはならないでも、人間（〔sittliche Perso:nlichkeit〕）として立つべき地盤を拡げ堅めるために役に立つ。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その冒頭に、先ず有能な学者を日本に派遣して大学地震研究所におけるあらゆる研究の模様を習得せしめよということ、次に末広所長を米国に迎えて講演させ、また米国における将来の研究方針についてその助言を求め、また末広式の地震分析器を各所に据え付けて地盤の固有振動の検出を試みよといったようなことが書いてある。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方面の専攻者にとっては、地震というものはただ地盤の複雑な運動である。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またいわゆる震度の分布という問題についても地質学上の見地から見ればいわゆる「地盤」という事をただ地質学的の意味にのみ解釈する事は勿論の事である。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本画には到底科学などのために動揺させられない、却ってあるいは科学を屈服させるだけの堅固な地盤があると思う。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然を恐れることなしに自然を克服しようとする科学の発達には真に格好の地盤であろうと思われたのである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車が通ると地盤のはげしく振動するのが坐っている私のからだには特にひどく感ぜられた。",
              "citation": {
                "source": "断片（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "堯の窓からは、地盤の低い家々の庭や門辺に立っている木々の葉が、一日ごと剥がれてゆく様が見えた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この地鳴りの音は考え方によってはやはりジャーンとも形容されうる種類の雑音であるし、またその地盤の性質、地表の形状や被覆物の種類によってはいっそうジャーンと聞こえやすくなるであろうと思われうるたちのものである。",
              "citation": {
                "source": "怪異考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地すべりの或るものでは地盤の運動は割合に緩徐で、すべっている地盤の上に建った家などぐらぐらしながらもそのままで運ばれて行く場合もある。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼らの立っていた地盤は今の自然科学のそれとはむしろ対蹠的に反対なものであったように見える。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな地変のために地盤が傾動すれば河流の転位なども当然起こりうるであろう。",
              "citation": {
                "source": "ロプ・ノールその他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この現象は単に上を流れる流体のみならず、地盤となる砂や泥の形質にもよるらしいから、問題は決してそう簡単でないであろう。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の手の、地盤の固いこのへんの平家でこれくらいだから、神田へんの地盤の弱い所では壁がこぼれるくらいの所はあったかもしれないというような事を話しながら寝てしまった。",
              "citation": {
                "source": "断水の日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような亀裂の入ったのはどういうわけだか、たとえば地盤の狂いといったような不可抗の理由によるのか、それとも工事が元来あまり完全ではなかったためだか、そんな事は今のところだれにもわからない問題であるらしい。",
              "citation": {
                "source": "断水の日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけの地盤の上に、それだけの材料でなんらかの考察を築き上げようとするのである。",
              "citation": {
                "source": "浮世絵の曲線",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "書生芝居が歌舞伎の本城を奪いしとて、好劇家は驚異の眼をみはり、書生芝居の地盤もここに漸く固まる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし工場の在る処へ、ほとんど埋立地に等しい少しばかりの土地を、数年かかってそこを地盤としている有名な代議士の尽力で許可してもらい、かさかさした間に合わせの普請で、とにかく三業地の草分が出来たのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "分家も方々に散らばっており、息のかかった人たちも多いので、その附近の地盤を堅めるのに、その勢力はぜひとも必要であり、投票を一手に集めるのにその信望は利用されなければならなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある日、奥さんから川西家の親類で「じばんじょう」を借りてくるように言いつけられた。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだかわからないが、忘れたらたいへんと『じばんじょう、じばんじょう……』とお経のように唱えながら道を急いでいると、途中で犬がつがい合っていた。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "肝心の「じばんじょう」を忘れてしまったのである。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            }
          ]
        }
