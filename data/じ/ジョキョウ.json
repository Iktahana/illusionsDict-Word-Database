    "definitions": [
      {
        "index": 1,
        "gloss": "assistant professor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "中年学校、老年学校を設置して中年、老年の生徒を収容し、その教授、助教授には最も現代的な模範的ボーイやガールを任命するのも一案である。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと彼の椅子が出来ると間もなく、チューリヒの大学の方で理論物理学の助教授として招聘した。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌三十五年助教授となり、四十二年応用力学研究のため満二年間独国及び英国へ留学を命ぜられ、これと同時に工学博士の学位を授けられた。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀念写真学生壇を並び立ち、　　　教授助教授みな座して、つめたき風の聖餐を、　　かしこみ呼ぶと見えにけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "助教授室……ヘエヘエ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "助教授の退出を待受けて何かしきりに問い合わしている男学生達。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "医科大学の助教授である彼女の夫が肺を患って寝こんでしまった時、他に男手のない二人暮しの家が物騒だというので、柔道部の選手をしていた轡川に言わば用心棒代りに寝泊りしてもらうことにした。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に其の｜寄王助教達善の長詩の前半、自己の感慨｜行蔵を叙して忌まず、道衍自伝として看る可し。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "中秋の或る快晴の日の午後、景子は友人の某大学英文科の助教授宮坂を案内して彼がしきりに逢いたがって居た此の国の文学者ジョン・ガルスワーシー邸を訪ねて行った。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて助教授宮坂は日本人的のぎこちない真面目な顔付きでガルスワーシーを覗き込むようにしながら氏の近作「銀の匙」と「白鳥の歌」に就いて発言しようと口を切った時、玄関へ一団の訪問客の押しかけて来たけはいを感じて言葉を切った。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "創作はあきらめ給え」　そうして彼を無理に研究室に入れ、次いで助教授にした。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "又註脚に大学助教授ドヨオジヒ氏の言つてゐることは一顧に値する。",
              "citation": {
                "source": "十三時",
                "author": "THE DEVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一度は毎土曜日の午後に、二人の助教師に連れられて、一団となってどこか付近の野原をしばらく散歩することを許されるときで、――あとの二度は日曜日に、村に一つある教会の朝と夕との礼拝式へ、いつも同じ決ったとおりに列を組んで行くときであった。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは「古典」の助教師の講壇で、もう一つは「英語および数学」の助教師のであった。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "この本に監修者としてかかわっている浜野保樹放送教育開発センター助教授の『ダイナブック』に関する指摘はもっと辛辣だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ米ＰＣ　ＭＡＧＡＺＩＮＥからの強力スタッフに加えて日本からは、東芝の溝口哲也パソコン・ワークステーション事業部長、日本電気の高山由パーソナルコンピュータ販売推進本部長、古川享マイクロソフト社長、脇英世東京電機大学助教授の豪華メンバーである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご存じ坂村健東京大学助教授の提唱する、ＴＲＯＮプロジェクトである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五歳にして学校の助教諭を托せられ、三円の給料を受けて子弟を訓導するの任に当り、日々勤務の傍ら、復習を名として、数十人の生徒を自宅に集め、学校の余科を教授して、生徒をして一年の内二階級の試験を受くることを得せしめしかば、大いに父兄の信頼を得て、一時はおさおさ公立学校を凌がんばかりの隆盛を致せり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚｜沙汰の止みてより、妾は一層学芸に心を籠め、学校の助教を辞して私塾を設立し、親切｜懇到に教授しければ、さらぬだに祖先より代々教導を以て任とし来れるわが家の名は、忽ち近郷にまで伝えられ、入学の者日に増して、間もなく一家は尊敬の焼点となりぬ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る助教授の受け持っているフリイドリヒ・ヘッベルと云う文芸史方面のものがある。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのつぎの年に、六十五になる滄洲翁は飫肥の振徳堂の総裁にせられて、三十三になる仲平がその下で助教を勤めた。",
              "citation": {
                "source": "安井夫人",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "美雲氏は既に故人となったが、後に美術学校の助教授をもしたことであって、至極穏健な作をする人であった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "皇居御造営の事、鏡縁、欄間を彫ったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "臼杵先生ったら……白鷹先生は、あなたよりもズットお年上で、Ｋ大耳鼻科の助教授をしていらっしゃるんですよ」「ワア。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に彼女の儚ない空想を現実に満足させようとしたのと同じ心理から出た作り事で、彼女がＫ大耳鼻科、助教授の要職にいる人から如何に信頼を受けておったかと言う事を、具体的に証明したいばっかりの一片の虚構に過ぎなかったのであったが、しかしその時の私が、どうしてソンナ事に気付き得よう。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし間もなく平生の無邪気な快活さを取り返した彼女は、さもさも嬉しそうに……あたかも白鷹助教授と臼杵病院長を紹介する光栄を喜ぶかのようにピョンピョンと跳ね上りながら電話室へ走り込んで行った。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは約二時間前に私に面会した白鷹助教授が、すぐに下六番町の自宅へ電話をかけた結果であったらしく、非常に冷静な、同時にこの上もなく友誼的な口調で、白鷹夫人が私の一家に対して警告してくれたものであった。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方にその後、警官や刑事諸君が遊びに来ての話によると、彼女は向家の蕎麦屋にいる活弁上りの出前持を使って電話をかけさせておったものだそうで、白鷹助教授に化けて東京から電話をかけたのもその弁公だったそうである。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "両親には風邪気味と申しましたので、夕方になって、近所に住んでおられる大学の助教授さんとか言う、若いお医者さんを呼んでくれましたが、別に何処と言って悪い処は御座いませんし、熱も何もなくて、脈も変っていなかったので御座いましょう。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "松下生」　松下というのは、丘よりも一年前に卒業した助教授の名だった。",
              "citation": {
                "source": "キド効果",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
