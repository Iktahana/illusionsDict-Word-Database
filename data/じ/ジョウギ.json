    "definitions": [
      {
        "index": 1,
        "gloss": "placing on the agenda",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
