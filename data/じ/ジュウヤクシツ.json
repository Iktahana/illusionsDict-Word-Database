        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "苦々しい奴だと思っている筆者を皆して引っぱって、重役室に挨拶に行った。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その職工はすぐに重役室に呼び出された。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは偉いな、俺なぞ、かうして重役室に納まつてはゐるが、家に帰ると見すぼらしい借家住まゐだからな。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一躍一流会社の支店長級になり済したもの、庶民から一遍に新設官庁の役人に立身したもの、浪人から一足飛びに重役室の主人公となった者、新聞社や雑誌社の尤もな処へ目出たくおさまった者が〔多く？",
              "citation": {
                "source": "友情に関係あるエッセイ",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "重役室で梶は友人に逢うと、自分のいなかった間に変化して来た裏面の動きを訊ねてみた。",
              "citation": {
                "source": "厨房日記",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "列の先頭にいた組合支部長と二人の幹部が被馘首者を残して重役室の方に出掛けて行った。",
              "citation": {
                "source": "組合旗を折る",
                "author": "永崎貢",
                "note": "青空文庫"
              }
            },
            {
              "text": "――社へ行くと、まだ相棒さんは見えなくて、若い重役の相良さんが一人で、二階の広い重役室で新聞を読んでいた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドンの汽船会社の重役室では、社長ラングレー氏が首脳部をあつめて協議を進行させていた。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕らのはいっていったところは、大きな会社の重役室と大して変った点はなかった。",
              "citation": {
                "source": "宇宙尖兵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへお秀さんが馳け込むのは当り前じゃないか」　津田は病院へ来る前、社の重役室で吉川から聴かされた「年寄に心配をかけてはいけない。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は直接専務に呼ばれるといふことが、なんか人違ひのやうな気がして、そつと重役室の扉を叩いた。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝出勤した時、清之介君は辻村君その他十数名と共に支配人室から重役室へ呼び出された。",
              "citation": {
                "source": "女婿",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お互にもう此辺で足を洗おうか、勇」「――――」　そんな事を話して居る最中、重役室では千種十次郎と早坂勇をどう褒めたものか評議して居りました。",
              "citation": {
                "source": "音波の殺人",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「千種さん、早坂さん、重役室までお出下さい」　給仕が呼んで居ります。",
              "citation": {
                "source": "音波の殺人",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "重役室の給仕が曽谷君を呼びに来たのは、それから半月ばかり後のことだった。",
              "citation": {
                "source": "小問題大問題",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "平社員は重役室から一寸と来ると誰しも恐れを為す。",
              "citation": {
                "source": "小問題大問題",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「津島さん、専務さんが一寸お出下さいと仰有います」　と又重役室の給仕が現れた。",
              "citation": {
                "source": "小問題大問題",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "社長室や重役室に近いところを受持っている。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四日目に、重役室へ容態を訊きに行ったら、赤石さんが、「まあ／＼、話して行き給え」　と私達を引き止めた。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三階の重役室へ入るや、秦豊吉の曰く、「今月は特賞無しだぜ」と、クサらされた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "北野の重役室へ寺本支配人を訪れる、感じ悪い奴だが今日は頗る機嫌よく、色々話す、ロッパ映画が内務省あたりで評判よき話をきゝ嬉しい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「歌のパラダイス」をやり、重役室へ寺本を訪れ、「さらば青春」の脚本料二百円とってやった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "八階、重役室、菊田ニコ／＼顔で迎へる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "重役室へ通る、森岩雄と話す十五分間位。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階には、会議室や重役室があるのです。",
              "citation": {
                "source": "黄金豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話交換台の女事務員は、重役室に電話をかけて、「ドアをしめきって、豹をいれないようにしてください。",
              "citation": {
                "source": "黄金豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
