    "definitions": [
      {
        "index": 1,
        "gloss": "subterranean rumbling",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
