    },
    "definitions": [
      {
        "index": 1,
        "gloss": "vice-chief",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "祭司次長、ウィリアム・タッピングという人で、爪哇の宣教師なそうですが、せいの高い立派なじいさんでした、が見兼ねて出て行って、祭司長にならんで立ちました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをしも、祭司次長が諸君に告げんと欲して、敢て咎めらるべきでない。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭司次長ウィリアム・タッピング祭司長ヘンリー・デビスに代ってこれを述べる。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その拍手の中でデビス長老は祭司次長に連れられて壇を下り透明な電鈴が式場一杯に鳴りました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭司次長が又祭壇に上って壇の隅の椅子にかけ、それから一寸立って異教徒席の方を軽くさし招きました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると私たちの席から三人ばかり祭司次長の方へ手をあげて立った人がありましたが祭司次長は一番前の老人を招きました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭司次長は立って異教席の方を見ました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭司次長は軽く会釈しました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "拍手と一処に六七人の人が私どもの方から立ちましたが祭司次長が割合前の方のモオニングの若い人をさしまねきました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番前列に居た小さな信者が立ちあがって祭司次長に何か云いました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次長は大きくうなずきました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭司次長がしばらく式場を見まわして今のざわめきが静まってから落ちついて異教徒席へ行きました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかにお立ちの方はありませんかとでも云ったようでしたが誰もしんとして答えるものがありませんでしたので次長は一寸礼をして引き下がりました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭司次長がすぐ進んで握手しました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭司次長がすぐ進んで一人ずつ握手しました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は私はこのお祭を賑やかにする為に祭司次長から頼まれて一つしばいをやったのです。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このわれわれのやった大しばいについて不愉快なお方はどうか祭司次長にその攻撃の矢を向けて下さい。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」という意味の速達を寄こして、僕も何だか、ハッと眼が覚めたような気持ちになり、急ぎ上京して、そうして今のこの「新現実」という文芸雑誌の、まあ、編輯部次長というような肩書で、それから三年も、まるで半狂乱みたいな戦後のジャアナリズムに、もまれて生きてまいりました。",
              "citation": {
                "source": "女類",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "参謀本部出仕を罷められ、戸山学校次長に補せられさせ給ふ。",
              "citation": {
                "source": "能久親王年譜",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸山学校次長を罷められ、同じ学校の教頭に補せられさせ給ふ。",
              "citation": {
                "source": "能久親王年譜",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "編輯次長はわざわざ編輯長の部屋へ呼ばれた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "編輯次長と社会部長が編輯長室へ呼ばれ、そして出て来た顔を見て、はじめて人々は、おや変だぞと気がついた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "土門がいないので、編輯長は自然次長と社会部長の両人に当り散らすより外に仕方がなかった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、こんな大きな問題は、やはり責任を次長や部長に転嫁して置く方が適わしいのではないか。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう次第で、『あづま日報』が、当局の無能を攻撃する度に、二木検事は、何故か、『あづま日報』の社会部次長として、事実上社会部の実権を握っている村井に、二木検事自身が、揶揄されているような気がしてならないのだった。",
              "citation": {
                "source": "殺人迷路",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この文は印刷せられ次長以下各部長等に呈上せられた筈である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、当時の参謀本部の総長か次長かの何とかの（四字削除）ら各師団長および各旅団長に宛てたもので、（十七字削除）、そのつもりで将校や兵の教育をしろ、という命令風のものであった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九六九（昭和四十四）年五月、富士通の音響機器部次長だった友納春樹が設立した通信機器メーカー、サイバネット工業は、歴史の波に翻弄されてジェットコースターに乗ったような急成長と急激な衰退とを短期間で経験していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "総長の下に三人の次長がある。",
              "citation": {
                "source": "国際聯盟とは如何なものか",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（ちんじちょうようだ、此奴、）　と爺様が鉈豆のような指の尖で、ちょいと押すと、その圧されたのがグググ、手をかえるとまた他のがググ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
