        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかも非人同様の姿ながら恐れ気もないその態度と、プンプンする熟柿臭い異臭が、いかにも不快な感じを与えたらしい。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "吃驚して文三がフッと貌を振揚げて見ると、手摺れて垢光りに光ッた洋服、しかも二三カ所｜手痍を負うた奴を着た壮年の男が、余程｜酩酊していると見えて、鼻持のならぬ程の熟柿臭い香をさせながら、何時の間にか目前に突立ッていた。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "」鵬斎は熟柿臭い息をついた。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "外套、上衣とも襟の処には葉巻の芳香と、熟柿臭い臭気とが沁み込んでプンプンと匂っている。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　と指し乍ら熟柿臭い呼吸を吹いた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "茹蛸のように真っ赤になって、熟柿臭い息をフウフウ吐いている丑松だったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "身投げする女",
                "note": "青空文庫"
              }
            },
            {
              "text": "襟も裾も亂れたまゝ、熟柿臭い顏を、わが子の濡れた頬に持つて行くのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "受難の通人",
                "note": "青空文庫"
              }
            },
            {
              "text": "襟も裾も乱れたまま、熟柿臭い顔を、わが子の濡れた頬に持って行くのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "受難の通人",
                "note": "青空文庫"
              }
            }
          ]
        }
