          "literary": [
            {
              "text": "十七日伊藤九三様才谷梅太郎御直披",
              "citation": {
                "source": "手紙",
                "author": "慶応三年一月十七日　伊藤助太夫あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三日〆寺田屋様うめより御直披",
              "citation": {
                "source": "手紙",
                "author": "慶応三年二月十三日　寺田屋お登勢あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月八日龍馬慎蔵様左右三吉慎蔵様坂本龍馬御直披五月八日出帆時ニ認而家ニ止ム。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年五月八日　三吉慎蔵あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "船のものハ申ニ及バず便船かりも皆金も何も（以下断欠）伏見宝来橋京橋の回船宿大浜濤次郎事寺田屋伊助様才谷梅太郎事取巻抜六御直披遠目鏡一つ添時計　一面",
              "citation": {
                "source": "手紙",
                "author": "慶応三年五月中旬　寺田屋伊助あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿八日龍九三先生御直披才谷",
              "citation": {
                "source": "手紙",
                "author": "慶応三年五月二十八日　伊藤助太夫あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿八日龍九三様才谷御直披",
              "citation": {
                "source": "手紙",
                "author": "慶応三年五月二十八日　伊藤助太夫あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月九日梅太郎〆上町本一丁目坂本権平様坂本龍馬御直披",
              "citation": {
                "source": "手紙",
                "author": "慶応三年十月九日　坂本権平あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月七日謹言〆後ト丙丁中　四条通室町上ル西側沢屋御旅宿　陸奥源二郎様才谷楳太郎御直披内用ナリ御独見",
              "citation": {
                "source": "手紙",
                "author": "慶応三年十一月七日　陸奥宗光あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "二日龍　九三様才谷御直披",
              "citation": {
                "source": "続　手紙",
                "author": "伊藤助太夫あて（推定、慶応三年春頃、二日）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一通は、渋沢栄一からの御直披とある厳しい書面だった。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう、じきひとりまえになるのだもの、私は、そうついて歩くまい。",
              "citation": {
                "source": "どこかに生きながら",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　乞食娘は、思いがけないよろこびにかえって怯えたらしく、セエラの顔を穴のあくほど見ていましたが、じきひったくるようにパンを取ると、夢中で口の中につめこみました。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            }
          ]
        }
