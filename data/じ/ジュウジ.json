[
  {
    "uuid": "6eb51328-2227-527e-9545-907d6ba80f7d",
    "entry": "住持",
    "reading": {
      "primary": "じゅうじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "chief priest of temple",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "寺の老僧とも懇意になり、ついにある時、自分がその住持になりたいと言い出し、夫人と次のような問答をした。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺の住持になって世を隠遁し、読経と墓掃除に余生を送りたいといった彼の言葉は、決して一時の戯れではなく、彼の心の無限の悲哀を告白した言葉であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "開山より何代目か経って、室町時代も末、この寺に三要という僧が住持をしていました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧たちの訴えを静かに瞑目して聴いていた住持三要は、いちいちうなずいていましたが最後に、「判った。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲※に拠る住持の三要は正面に控え、東側は大衆大勢。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この後、住持三要は、間違いがあってはならぬというので、淵の鯉魚へ生飯を遣る役は老体ながら自分ですることにしました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥州筋近来の凶作に此寺も大破に及び、住持となりても食物乏しければ僧も不住、明寺となり、本尊だに何方へ取納しにや寺には見えず、庭は草深く、誠に狐梟のすみかといふも余あり。",
              "citation": {
                "source": "甲冑堂",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "住持といっても木綿の法衣に襷を掛けて芋畑麦畑で肥柄杓を振廻すような気の置けない奴、それとその弟子の二歳坊主がおるきりだから、日に二十銭か三十銭も出したら寺へ泊めてもくれるだろう。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "住持も若僧もいないように静かだ。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "住持の透鱗はじめ僅かばかりの寺の人数は裏の竹藪の中に仮小屋を作りうずくまって住んでいた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お住持はなくて、ひとりものの親仁が堂守をしていましたそうです。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "住持も若僧も居ないやうに静かだ。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "今より六代の前、報恩寺に住持たりし偉運僧正が浄書したりと云ふ西行法師の山家集、これは我が財産中、おのれの詩稿と共に可成盗まれたくなしと思ふ者なり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の名音は、最初｜泉の某と云う庵にいて有徳の住持に事えていた。",
              "citation": {
                "source": "法華僧の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「早朝から恐縮ですが、住持様は、もうお眼覚めでしょうか」　男は其のくだけた服装にも似ず、態度や詞つきが丁寧であった。",
              "citation": {
                "source": "法華僧の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "名音はこんなに早くては住持様が迷惑するだろうと思ったが、男の態度に好感が持てたので、住持に取りついだ。",
              "citation": {
                "source": "法華僧の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "住持は名音を信用しているので、すぐ二人を客間へ通した。",
              "citation": {
                "source": "法華僧の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一口に尼になりたいとおっしゃっても、それは容易なことではありませんからな」　住持は痛ましそうに女の方を見た。",
              "citation": {
                "source": "法華僧の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の時まで何も云わずに俯向いていた女が、初めて顔をあげて住持を見た。",
              "citation": {
                "source": "法華僧の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私も幾度も思いとまらせようといたしましたが、よほど思いつめておりますから、どうか人間一人を助けると思って、曲げてお許しを願いたいと思います」　住持はどうしたものだろうかと云うような表情をして名音を見た。",
              "citation": {
                "source": "法華僧の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「住持様、あんなにおっしゃいますから、肯いておあげになっては如何でございます」「そうじゃな、それでは、こうして頂きましょう。",
              "citation": {
                "source": "法華僧の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜もう一度お考えなすって、それでも決心が変らなかったら、明日改めてお出でを願いましょう」　それを聞くと二人は喜んで帰って往ったが、翌日になって女が移って来たので、住持が最初｜鋏を入れ後は名音の手で剃髪した。",
              "citation": {
                "source": "法華僧の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉音は顔だちも美しく素直な女だったので、住持にも気に入られた。",
              "citation": {
                "source": "法華僧の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣室に寝ていた住持も其の声を聞きつけて起きて来た。",
              "citation": {
                "source": "法華僧の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうなされた、お肚でも痛まれたか」　住持の詞に玉音は蒼褪めた顔をちょっと赧らめた。",
              "citation": {
                "source": "法華僧の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "某日住持は檀家の待夜に招かれたので、名音も其の供をして往ったが、意外に手間取って帰ったのは夜の十二時過ぎであった。",
              "citation": {
                "source": "法華僧の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "住持は直ぐに寝室に入ったが、名音は便所へ往きたくなったので、土間続きの便所へ往って、帰りに手を洗おうとしたところで、自分の傍を通り抜けた者があった。",
              "citation": {
                "source": "法華僧の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝になって名音は、平生のように起きて朝の礼拝を終り、前夜のことを住持に話そうと思っていると、玉音が急に緊張した顔になった。",
              "citation": {
                "source": "法華僧の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで知ったのですが、その出家は鎌倉でも五山の一つという名高い寺のお住持で、京登りをした帰り路に、山越えをして北陸道を下らるる途中であったのです。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれも汚れてますで……」　姉が合点合点などしてゆっくり捜しかけるのを、じゅうじゅうと音をさせて煙草を呑んでいた兄は「扇子なんかどうでもええわな。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
