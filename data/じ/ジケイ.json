[
  {
    "uuid": "60f23e3b-4397-5ffd-ab98-ea36cec45787",
    "entry": "字形",
    "reading": {
      "primary": "じけい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "character style",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "猟師は楓の細木を伐り朴し、枝葉を払わないままで、柱を立て、私たちの用意して来た、二畳敷ほどな油紙二枚を、人字形に懸けて、家根を作る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "石は人の手入れを経ない、全くの自然石で、不思議にも中はおのずと、コ字形に刳ぐられていて、濶さは一坪半ぐらいはあろう、四人ぐらいは潜れそうであるが、うっかり立てば頭を打ちつけるほどに低い。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "万字は垂直線と水平線との結合した十字形の先端が直角状に屈折しているので複雑な感を与える。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち星形や十字形のものと、円形のものとを見分けることができるというのである。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "くの字形に距離を置いてとんでくる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らくして、両脚を踏ンばって、剣を引きぬくと、それは、くの字形に曲っていた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天神川は亀戸天神祠前に流るゝを以て名づけられたる一水にして、南は砂村より北は請地村に至るまでの間を南北に流るゝ一渠にして、丁字形をなして請地にて会する一水は、西中の郷にて堀溜となれど、東は境橋下を過ぎて中川に達する六間川これなり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "○三十間堀即ち真福寺橋の流れの続きにして、豊倉橋紀国橋豊玉橋朝日橋三原橋木挽橋出雲橋等の下を流るゝ一水は、前の一水と新橋の下、蓬莱橋の上にて丁字形をなして相会す。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "小山の峰通り立てる松の並木の遠見には馬の鬣のやうなるが現はれつ隠れつする、金字形したる山の嶺の、心あてに見しあたりならぬところに突として面出す、ことにおもしろし。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば池のみぎわから水面におおいかぶさるように茂った見知らぬ木のあることは知っていたが、それに去年は見なかった珍しい十字形の白い花が咲いている。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二のテーマでは鉛直な直線の断片が自身に並行にＳ字形の軌跡を描いて動く。",
              "citation": {
                "source": "踊る線条",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり茎の上端が「り」の字形になったわけである。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで今度は飛行機翼の模型を作って風洞で風を送って試験してみたところがある風速以上になると、補助翼をぶらぶらにした機翼はひどい羽ばたき振動を起こして、そのために支柱がくの字形に曲げられることがわかった。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの場合に数条の並行した、引き延ばされたＳ字形となって現われているこの線は、鬢の下端の線などと目立った対偶をしている。",
              "citation": {
                "source": "浮世絵の曲線",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "筒井氏の調査によると、冬季降雪の多い区域が、若狭越前から、近江の北半へ突き出て、Ｖ字形をなしている。",
              "citation": {
                "source": "伊吹山の句について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは或る気温の関係で太陽の周囲に白虹が出来、なお太陽を中心として十字形の虹が現われるのだが、その交叉点が殊に光度を増すので、真の太陽の周囲四ヶ所に光体に似たものを現わす現象で、北極圏内には屡※見られるのだがこの辺では珍らしいことだといって聞かせてくれた。",
              "citation": {
                "source": "北海道に就いての印象",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "客は丁字形に二つ並べた、奥の方の縁台に腰をかけて、掌で項を圧えて、俯向いたり、腕を拱いて考えたり、足を投げて横ざまに長くなったり、小さなしかも古びた茶店の、薄暗い隅なる方に、その挙動も朦朧として、身動をするのが、余所目にはまるで寝返をするようであった。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでは二枝カンデラーブル、Ｕ字形をつくる。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンデラーブル、Ｕ字形であります。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄日は射したがまだ融けぬ、道芝に腰を落して、お鶴はくの字形に手を小石。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十畳と八畳に、廻縁を取廻して、大い巳の字形に、襖を払った、会場の広間は、蓮の田に葉を重ねたように一面で、暗夜に葉うらの白くほのめくのは浴衣である。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、表からは、木戸を一つ丁字形に入組んだ細い露地で、家と家と、屋根と屋根と附着いて居る處だから、珊瑚の流れは、壁、廂にしがらんで、堰かるゝと見えて、表欄干から見たのと較べては、やゝ疎であつた。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずつと見通しの、油堀から入堀の水に、横に渡した小橋で、それと丁字形に、眞向うへ、雨を柳の絲状に受けて、縱に弓形に反つたのは、即ち、もとの渡船場に替へた、八幡宮、不動堂へ參る橋であつた。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "永喜橋――町内持ちの、いましがたの小橋と、渡船場に架けた橋と、丁字形になる處に、しばらくして私たちは又たゝずんで、冬木の池の方を振返つたが、こちらからは、よくは見通せない。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな折烏帽子が、妙に小さく見えるほど、頭も顔も大の悪僧の、鼻が扁く、口が、例の喰しばった可恐しい、への字形でなく、唇を下から上へ、への字を反対に掬って、「むふッ。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "口を、ヘの字形に曲げて、鼻の両側に深い皺を作りたいのだが、どうも、うまく行かない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
