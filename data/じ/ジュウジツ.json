[
  {
    "uuid": "3d98f49e-be37-5236-be21-8a1aa50eebab",
    "entry": "充実",
    "reading": {
      "primary": "じゅうじつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
