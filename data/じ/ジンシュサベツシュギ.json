          "standard": [
            {
              "text": "彼の発言は、人種差別主義に基づいていると批判された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "人種差別主義は、歴史を通じて多くの悲劇を生み出してきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "学校教育では、人種差別主義を許さないという意識を育むことが重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その主たる推進力は過去および現在におけるケルト民衆の偉大さへの信条であって、人種差別主義の色彩が濃い。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
