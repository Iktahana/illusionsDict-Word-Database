        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "きわめて保守的な教育刷新委員会が出来たのもこの結果であるし、人文科学振興委員会が設けられたのもこの意味にほかならない。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の学術を民主的に解放し日本の民主化と再建に現実的な動力となろうとして民主的な自然科学者、人文科学者を包括した「日本民主主義科学者協会」が一九四六年に結成された。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "修養部の課程は、精神講座、数学、自然科学、人文科学、日本文学、外国語、外国文学等に大別します。",
              "citation": {
                "source": "文化学院の設立について",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が成長の後、自然科学へ赴くか、人文科学へ赴くか、何れの方面に向うにせよ、彼にとって大切な思い出になると思えば、私は甚だ嬉しい勇みたった気持だった。",
              "citation": {
                "source": "箱根の山",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "物理や化学の応用による工学的な技術もあり、人文科学の領域に於ける調査研究の技術もあり、更に法律の運用、事業経営の技術、大にしては国政の処理、小にしては帳簿の整理まで、これを技術と呼んで呼べないものはありません。",
              "citation": {
                "source": "文化とは",
                "author": "――力としての文化　第一話",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌記事索引も、自然科学、人文科学に別けて、毎月発刊し、二十六冊を既刊した。",
              "citation": {
                "source": "国会図書館のこのごろ",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然科学万能主義の時代は既に去りて、人文科学の研鑚は、今や旭日東天に昇るの勢を以て、進歩しつつあり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "人文科学の一分科としての神話学の研究は、今日に於ても尚、依然として行われつつあり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治の人文科学は、果してその凡ての方面に於て、完全に発達しつつありや。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "人文科学の範囲は、極めて広大なり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れの人文科学に於ても、比較研究の必要なきは、殆んど之なきも、其の必要を感ずることの大なる、神話学の如きは罕なり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そが一個の方便たるは、宗教史学、文芸科学其他の人文科学に対して、一個の方便たると、其趣に於て、著しき差異あるを見ず。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その説簡単にして、甚だ明晰、その根本に於ては、凡ての人文科学に於けると同じく、固より仮定説に過ぎずと雖も、其学説の大躰に於て、殆んど動かす可からざるものあり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一個の独立せる人文科学にして、宗教学、人類学、言語学等は、すべてその補助学科たる可く。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三節　比較神話学の方法及神話の種類　神話学は、一個の人文科学なり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベックの定義に曰く、人文科学は人間の精神的生産物の認識なりと。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に人文科学は、一個の法則もしくは技術に非ずして、法則の応用を要す。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に一歩を進めて之を云わば、一個の人文科学としての神話学の目的は、比較神話学に依るに非ざれば、之を達すること能わざるなり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "神話学は、一個の人文科学として、其方法に於ても、亦た一般人文科学の方法と異るところある可からず。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "純粋自然科学が、その研究の対象とする、純粋の自然現象と、人文的現象と相違する点に於ては、人文科学はまた精神科学と称するを得可し。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども人文科学の研究者は、独り精神的の現象にのみ関係して、自然現象をば、全く度外視するも可なりとするは、大なる誤謬なり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神界の現象が、自然界の現象の影響を蒙り、自然界の事物が、人間の精神によりて、支配せらるる点に於て、人文科学はまた、自然をも観察するを要す。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "人文科学はまた、此現象をも観察せざる可からず。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に人文科学の観察は、小にしては、個人の心的現象より、大にしては、国家社会の制度文物に及び、その傍ら、四囲の自然をも、度外視するを得ず。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民心理学及び其他の近世心理学の人文科学に与うる利益は、决して鮮少にあらざるなり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は神話学の方法に関する一般の原理にして、其大躰に於て、一般人文科学に於けると異ることなし。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その自然的源泉の研究に関しては、凡ての自然科学は、其補助学科たる可く、歴史的源泉の研究に際しては、凡ての人文科学は、其補助学科たる可く、殊に言語史学と文芸史学の必要なるを見る。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "其三　日本神話の天地開闢説　人文科学の対象たる、一国民の精神的産物は、四囲の天然を離れては、了解す可からず。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学的というのは、もちろん人文科学を含めての話である。",
              "citation": {
                "source": "北海道開発に消えた八百億円",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
