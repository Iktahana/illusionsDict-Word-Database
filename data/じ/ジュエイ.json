[
  {
    "uuid": "4fdd8442-51ab-55cf-8ad3-ca20643f9015",
    "entry": "寿永",
    "reading": {
      "primary": "じゅえい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
