    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Juei era (1182.5.27-1184.4.16)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『玉葉』四十に寿永三年正月元日伊勢怪異の由を源義仲の注進せる内に、元日の夜大風雨雷鳴｜真虫蛇打ち寄せられ津々に藻に纏われてあるいは二、三石あるいは四、五石（石は百か）皆生きあり、両三日を経て紛失しおえぬ、およそ昔も今も真虫海より打ち上げらるる事は伊勢国に候わず、件の蛇海より来り寄す云々と見ゆ。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔この所に悪七兵衛景清の伯父入道蟄居せり、寿永三年八島の軍敗走して景清ここに来る。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜のわらべなど　　　　　　　　　　（一）寿永四年五月、長門国壇の浦のゆうぐれ。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "寿永のみささぎはどの辺であろう。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "寿永年間桜尾周防守（周防国桜尾城主）近実といふ者天神七代を此山に祀。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "建禮門院は史上の女性の内でも作者の好んで涙を注いだ人で、既に前にもほととぎす治承寿永の歌を出したが、平家を詠ずる歌の中にも　西海の青にも似たる山分けて閼伽の花摘む日となりしかな　といふのがある。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "是、寿永元暦の革命が、漸くに其光茫を現さむとするを徴するものにあらずや。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "寿永元暦の革命は、彼によつて其導火線を点ぜられたり。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "平氏は、福原の遷都を、掉尾の飛躍として、治承より養和に、養和より寿永に、寿永より元暦に、天暦より文治に、円石を万仞の峰頭より転ずるが如く、刻々亡滅の深淵に向つて走りたりき。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして、寿永二年七月、赤幟、洛陽を指して、敗残の平軍、悉く都に帰ると共に、義仲は北陸道より近江に入り、行家は東山道より大和に入り、革命軍の白旗、雪の如く、近畿の山河に満てり。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "翠華は、揺々として西に向ひ、霓旌は飜々として悲風に動く、嗚呼、「昨日は東関の下に轡をならべて十万余騎、今日は西海の波に纜を解きて七千余人、保元の昔は春の花と栄えしかども、寿永の今は、秋の紅葉と落ちはてぬ。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふるさとを焼野のはらとかへり見て末もけぶりの波路をぞゆく　　　　　三　最後鳳闕の礎空しく残りて、西八条の余燼、未暖なる寿永二年七月二十六日、我木曾冠者義仲は、白馬金鞍、揚々として、彼が多年、夢寐の間に望みたる洛陽に入れり。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "寿永の革命はかくして彼が凱歌の下に其局を結びたり。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "是実に寿永二年十一月十五日、法住寺の変に先つこと僅に三日。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "寿永三年正月、彼が、股肱の臣樋口次郎兼光をして行家を河内に討たしむるや、兵を用ふること迅速、敏捷、元の太祖が所謂、敵を衝く飢鷹の餌を攫むが如くなる、東軍の飛将軍、源九郎義経は、其慣用手段たる、孤軍長駆を以て、突として宇治に其白旄をひるがへしたり。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "時実に寿永三年正月二十日、粟津原頭、黄茅蕭条として日色淡きこと夢の如く、疎林遠うして落葉紛々、疲馬頻に嘶いて悲風面をふき、大旗空しく飜つて哀涙袂を沾す。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して彼が寿永革命史上に一頭地を抽く所以のものは、要するに彼は飽く迄も破壊的に無意義なる繩墨と習慣とを蹂躙して顧みざるが故にあらずや。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "寿永革命史中、経世的手腕ある建設的革命家としての標式は、吾人之を独り源兵衛佐頼朝に見る。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は寿永革命の大勢より生れ、其大勢を鼓吹したり。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初｜一瞥して寛永と見たが、見直すと寿永に見えた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寿永では古い、平家没落の頃だ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寿永だ、寿永だ、寿永にして措け、と寿永で納まって居ると、ある時｜好古癖の甥が来て寿永じゃありません宝永ですと云うた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寿永の昔の平家都落ち、近くば維新当時の江戸幕府の末路を偲ぶ光景です。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『吉記』寿永二年十二月十五日の条にそのことが見えているのである。",
              "citation": {
                "source": "奥州における御館藤原氏",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はすでに寿永元年四月において、文覚上人を高雄より請して相模の江の島に大弁才天を勧請し、三七日間の断食の荒行をまで修せしめて、秀衡調伏の祈願を籠めしめたのであった。",
              "citation": {
                "source": "奥州における御館藤原氏",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
