  {
    "uuid": "8753dba2-d9c3-57a7-913f-89759aec8754",
    "entry": "樹影",
    "reading": {
      "primary": "じゅえい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "shadow of a tree",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "老人は、手拭で引摺って袖を拭きつつ、見送って、「……緑樹影沈んでは魚樹に上る景色あり、月海上に浮んでは兎も波を走るか、……いやいや、面白い事はない。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一文の林の淺緑樹影しづけきこの庭に桂の庵の露むすび惠みの星を迎ぎ見て春また春といそしめば心の枝も若芽すも。",
              "citation": {
                "source": "唱歌",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "『竹生島』の謡曲に緑樹影沈んで魚樹に登る景色あり月海上に浮かんでは兎も波を走るか面白の島の景色やとあるは『南畝莠言』上に拠ると建長寺僧自休が竹生島に題せる詩の五、六の句〈樹影沈んで魚樹に上り、清波月落ちて兎流れに奔る〉とあるを作り替えたのだ。",
              "citation": {
                "source": "十二支考",
                "author": "兎に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "うとうとして、三時半目を開きしに、樹影天幕に映れり。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "日を帯びた樹影がちらちらと籐椅子の上に動く。",
              "citation": {
                "source": "孤独と法身",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しばかり強く風が渡ると、光りの薄い星が瞬きをして、黒いそこらの樹影が、次ぎから次ぎへと素早く囁きを伝へて行く。",
              "citation": {
                "source": "散歩",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それどころか、枝をいっぱいに伸ばし、車道の三分の二ほどをおおって、樹影をひろげている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「青と白」の終わりには森のなかで桃色のパラソルを持った少女と大学生と恋を語っているのを見て、それを祝し自らは淋しい樹影にかくれて、静かな魂の休息の深いなぐさめを感ずる青年が描かれてありましたが、それを私はたいへん心地よく感じました。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "正義、博愛、平和、文明などいふ外形ばかり美しい幻影が破れた樣に、渠の空想してゐた札幌市中の樹影の美觀が滅してしまつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "畳古きにも旅情うごく　　　　□　樹影雲影猫の死骸が流れてきた・土手草萌えて鼠も行つたり来たりする　　　　□　水鳥の一羽となつて去る　飾窓の牛肉とシクラメンと三月六日　曇后雨、あとは昨日の通り。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ私の態度は湖水の静かな水のようにその上を去来する白雲や時には乱雲や鳥の影や、また樹影やらを去来のままに映し来り映し去って行きたいと思っています。",
              "citation": {
                "source": "遺書",
                "author": "尾崎秀実",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹影の色で青白んで見える客の中には居眠っている顔も見えた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、樹木の上の空が無限のかなたにじっと結びつけられているのがわかったし、樹影の沈黙のなかに秘められている言葉がみつかりそうだった。",
              "citation": {
                "source": "雲の裂け目",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の此處に來るや、その激怒極めて烈しく、極めて盛に、只是千百蚊龍の頭を並べて飛下するが如く、高きこと一二間に及べる岩をも難なく飛越え跳り越えて澎湃激越天地も崩れんばかりの絶大絶高の響を作し、更に集りて深碧染むるが如き一瀞淵を作り、更に亂れて又靜り、更に動きて又止まり、終に樹影欝葱たる處に隱れ行きぬ。",
              "citation": {
                "source": "日光山の奧",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩角を穿ち木根を越え、纔かに仰ぎて之を見る境既に暗黒、加ふるに樹影重蔽せるを以て分明にその首尾を辨ずる能はず。",
              "citation": {
                "source": "日光山の奧",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその境極めて促、極めて狹、極めて險、極めて必迫、一縷の路絶えんとする事數次、漸く山※を穿つて、樹影の少しく開けたる所に出づ。",
              "citation": {
                "source": "日光山の奧",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "謠曲の「竹生島」に、緑樹影沈んで魚木に登る景色あり、月海上に浮んでは兎も浪を走るか、面白の景色や　といつてゐるのは實景である。",
              "citation": {
                "source": "湖光島影",
                "author": "琵琶湖めぐり",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほやり／＼水蒸気立つ土には樹影黒々と落ち、処女の袖の様に青々と晴れた空には、夏雲が白く光る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕日傾く頃となれば、風はます／＼涼しく、樹影は黒く芝生に跳った。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へ帰って庭を眺めると、土塀に映る林檎や柿の樹影は何時まで見ていても飽きないほど面白味がある。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の樹影がかさかさと揺いだので後は耳を澄すと、あたりが寂然と静まり返った。",
              "citation": {
                "source": "恩人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は余りに激しく見つめていた自分の視線に懼然として、一寸樹影に身を引いて、それから低く呼んだ。",
              "citation": {
                "source": "恩人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "満庭の樹影｜青苔の上によこたはりて清夏の逸興｜遽に来るを覚ゆる時、われ年々来青花のほとりに先考所蔵の唐本を曝して誦読日の傾くを忘る。",
              "citation": {
                "source": "来青花",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "断膓亭の小窗に映る樹影墨絵の如し。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之二大正七戊午年",
                "note": "青空文庫"
              }
            },
            {
              "text": "年改りて早くも半月近くなりたる此頃窗の樹影は昼過二時より三時頃最も鮮にして、四時を過ぎても猶消去らず。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之二大正七戊午年",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖の草生茂りて午後の樹影夏らしくなりぬ。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之五大正十年歳次辛酉",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹影一つない平野を過ぎると、やがてうるわしい丘陵地帯になって、相当な町に出た。",
              "citation": {
                "source": "撥陵遠征隊",
                "author": "服部之総",
                "note": "青空文庫"
              }
            }
          ]
