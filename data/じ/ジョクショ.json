        "examples": {
          "standard": [
            {
              "text": "今年の夏は例年以上に溽暑が続き、うんざりする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "溽暑の中、冷たい麦茶が体に染み渡りました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「うわー、今日もすごい溽暑だね。外に出たくないよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "溽暑蒸濁の夏を背きて、冷々然として獨り涼しく逝きたまひぬ。",
              "citation": {
                "source": "芥川龍之介氏を弔ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿大蔵谷駅溽暑至夜猶甚納涼海磯乃赤石浦也。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "両三日空くもりて溽暑甚しく大雨降り来りては忽ち歇む。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲低く空を蔽ひ溽暑六月の如し。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "溽暑恰も温室に在るがごとし。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之五大正十年歳次辛酉",
                "note": "青空文庫"
              }
            }
          ]
        }
