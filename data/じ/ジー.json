    "definitions": [
      {
        "index": 1,
        "gloss": "G",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "科学の授業で、重力加速度の「Ｇ」について学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼のユニフォームには、背番号「Ｇ」が大きくプリントされていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "週末に開催される「Ｇカップ」という名のテニス大会に出場する予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そこへＣやＤやＥやＦやＧやＨやそのほかたくさんの人物がつぎつぎに出て来て、手を変え品を変え、さまざまにＢを中傷する。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、Ｇペン買ひに、まちへ出た。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（下）　甲府偵察のこと　きらきら光るＧペンを、たくさん財布にいれて、それを懷に抱いて歩いてゐると、何だか自分が清潔で、若々しくて、氣持のいいものである。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、Ｇペン買つてから、甲府のまちをぶらぶら歩いた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がＧの絃で話せば、マリアナはＥの絃で答える。",
              "citation": {
                "source": "秋の歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからひとつ、Ｇ――通りにでも廻って、大いに飲んで飲んで、飲みつぶれて、あのローマの意気な貴族ペトロニューの様にドラマティックな最期を遂げたいと思っていますよ。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "唄いながら、原稿用紙の塵を吹き払い、Ｇペンにたっぷりインクを含ませて、だらだらと書きはじめた。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥棒　Ｇメン、アルカポネ、キングコング、のらくろ伍長、江戸ツ子健ちやん、すゝめフクちやん、まだいろいろある。",
              "citation": {
                "source": "ラムプの夜",
                "author": "――学芸会のための一幕劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "用筆は最初Ｇの金ペンを用いた。",
              "citation": {
                "source": "文士の生活",
                "author": "夏目漱石氏−収入−衣食住−娯楽−趣味−愛憎−日常生活−執筆の前後",
                "note": "青空文庫"
              }
            },
            {
              "text": "超現実に美しく魅惑的な金魚は、Ｇ氏が頭の中に描くところの夢の魚ではなかった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そのうちＧ氏の頭の方が早くも夢幻化して行った。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」Ｇ氏は創造する金魚につけるはずのこの名を呼びながら、乞食のような服装をして蒼惶として去った。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへＣやＤやＥやＦやＧやＨやそのほかたくさんの人物がつぎつぎに出て來て、手を變へ品を變へ、さまざまにＢを中傷する。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "假令Ａ、Ｂ、Ｃより進んで、Ｄ、Ｅ、Ｆ、Ｇ、と既知數を多く増し得たにしても同じ事である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｇ　美濃十郎は、実業家三村圭造の次女ひさと結婚した。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかり支度をしてしまってもう明日は船に乗り込めばいいことにして、千代重は私とＧホテルのベランダで、夏の夜更けまで、港の灯を眺めながら語った。",
              "citation": {
                "source": "唇草",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧が追々薄れて窓からはいる光が増して来ると、新進室内装飾家Ｇ―氏の特性が追々明らかになって来る。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この芸術的手法に於てスワンソン邸のジョージアン式の骨董的建物の心臓に喰込み、その建物の躯幹を侮辱するような振舞いを新進室内装飾家Ｇ―氏に委嘱したスワンソン夫人にそれを後援する明確な現代的新意識があるかというに、そうでも無い。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人はこの部屋が出来上った時Ｇ―氏に云った。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯父は直ぐに帰って来て母親からその地図を捲き上げると、哈爾賓に引返して、私の父が軍事探偵である事を｜Ｇ・Ｐ・Ｕに密告したに違いないのだ。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "入学の宣誓式の時、生徒主事のＧ教授が長時間にわたって生徒の赤化に就て注意的訓話を述べたが、Ｇ教授は物凄い東北弁で、喋っていることの意味がちっとも分らなかった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｇ教授の訓話が終った途端、うしろの父兄席にいた一人の紳士がいきなり立ち上って、「あなた今何を喋られたのですか。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "交差点のＧＯ・ＳＴＯＰはいまＳＴＯＰの字版を示していっさいの交通を遮断していた。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａ・　ＥＬＲＩ・ＥＳ　ここで、ＴとＧをうめると、何とか意味が通じる。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＥＬＳＩＥ　・ＲＥ・ＡＲＥ　ＴＯ　ＭＥＥＴ　ＴＨＹ　ＧＯ・　ここにＰとＤを加えて、伝言は完成です。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸僕はＧ警視を知つてゐるからあそこへ往つて見るだけの許可を得るのは造作はないよ。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は帰りみちで要塞のＧ――中尉に会って、まったくなんの考えもなしに、その虫を貸してやったんだ。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の健康について二こと三こと尋ねてから、私は、なにを言っていいかわからなかったので、Ｇ――中尉からもう例の甲虫を返してもらったかどうかと尋ねた。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから間もなく僕たちは家へ帰りかけたが、その途中でＧ――中尉に会った。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時イージーゴーイングな方面で一番好都合なのは、言つてみればその歌の動機を説明しては、トンポエムすることなのである。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
