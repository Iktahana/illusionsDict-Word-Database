        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この新しいハードディスクは、１「Ｇ」バイトという大容量だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
