        "examples": {
          "standard": [
            {
              "text": "スペイン語では、「la casa」（家）は女性名詞である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ドイツ語の授業では、文法的な性、特に女性名詞の見分け方に焦点を当てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この単語は女性名詞だから、定冠詞は『die』になるわよ」と先生は教えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "然して、貨幣を女性名詞とす。",
              "citation": {
                "source": "貨幣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう言われてみると、ドイツ語でもフランス語でも、貨幣はちゃんと女性名詞という事になっていますからね。",
              "citation": {
                "source": "女神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャンブルは女性名詞のはずだ。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　フランス語では貞潔 〔chastete'〕 は女性名詞である。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
