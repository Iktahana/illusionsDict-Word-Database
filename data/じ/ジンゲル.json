        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その歌手（シンガー）は、パワフルな歌声で聴衆を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は幼い頃から歌うことが大好きで、将来はシンガーになりたいと夢見ていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新進気鋭のシンガーソングライターが、待望のデビューアルバムをリリースした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「おい、島野、なぜこのジンゲル（芸者）が赧くなったか知ってるか」「おれに気があるからだろう……？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の言葉の特長　ねーえ　と引っぱってというが如し　だに　おいでた　だかね　居ますんね〔欄外に〕ジンゲル　singer　　　　　木曾　山々信州より丸し。",
              "citation": {
                "source": "一九二七年春より",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、グリージンゲルという人は、それに癲癇様の痙攣を伴うとも云っているんだ」と法水はなにげなさそうに答えたけれども、なにやら逆説に悩んでいるらしく、苦渋な暗い影が現われていた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "となりの部屋の男ジンゲルを買う。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にすぐ隣のベンチに腰をかけてゐる書生が二人、「見ろ／＼、ジンゲルだ。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にすぐ隣のベンチに腰をかけている書生が二人、「見ろ見ろ、ジンゲルだ。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "名アルト歌手オネーギンとクルト・ジンゲルの指揮した、ベルリン国立歌劇場管弦団のレコードがビクターに入っている。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
