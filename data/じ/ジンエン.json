[
  {
    "uuid": "b4adb05d-f822-5288-ae31-d2d804cdd9de",
    "entry": "人煙",
    "reading": {
      "primary": "じんえん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
