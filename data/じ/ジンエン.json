    "definitions": [
      {
        "index": 1,
        "gloss": "smoke from human habitations",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蛮地では人煙が稀薄であり、聚落の上に煙の立つのは民の竈の賑わえる表徴である。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二十三回　十二の樽海底戰鬪艇の生命――人煙の稀な橄欖島――鐵の扉は微塵――天上から地獄の底――其樣な無謀な事は出來ません――無念の涙　大海嘯後の光景は、實に慘憺たるものであつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "極目人煙を見ず、まれに訪れるものとては曠野に水を求める羚羊ぐらいのものである。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだその頃の早稲田は、雑木林があり、草原があり、竹藪があり、水田があり、畑地があつて、人煙の蕭条とした郊外であつた。",
              "citation": {
                "source": "雑木林の中",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央アジアの、人煙稀薄な曠野の果てに、剣のような嶺々が、万古の雪をいただいて連なっている。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人煙の稀少なること北海道石狩の平野よりも甚し。",
              "citation": {
                "source": "遠野の奇聞",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人煙まれなる森林地帯ででもあるように、原始的な草原ででもあるように感じさせる景色であった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の村は、山陽道と山陰道を分ける中国の脊梁山脈の北側に、熊笹を背に、岩に腰をおろしてもたれかかっているような、人煙まれな険阻な寒村であった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "半身を起して見※すと、室内の人は悉くひつそりと横になつて誰一人煙草を吸つてる者もない。",
              "citation": {
                "source": "熊野奈智山",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯く山深く人煙また極めて疎なるに係らず、わが生れた村の歴史は可なりに古いらしい。",
              "citation": {
                "source": "古い村",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだその比の早稲田は、雑木林があり、草原があり、竹藪があり、水田があり、畑地があって、人煙の蕭条とした郊外であった。",
              "citation": {
                "source": "雑木林の中",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――足柄郡曾我村五郎丸字｜夜見、何処へ出るにも馬の背を借りずには街の灯も見ることも許されぬ人煙稀なる草深いところに、遊蕩的性格の持主である私が酒も飲まずに永い滞在が保たれてゐたのは、夙にこの社のスヾメ蜂の巣のお蔭であつたのだ。",
              "citation": {
                "source": "夜見の巻",
                "author": "「吾が昆虫採集記」の一節",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今日もただ一人煙草畑へ出てゐるじゆんのことを思つた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は英吉利直輸入の婦人煙草「｜仕合せな夢」を喫かしつづけた。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ荒漠としている開墾の遙か彼方の山並の上に三春富士を眺め、その下に連る古い町々の人煙を見ながら、松林の中へ三層楼の役場を建てた当時の人々の感情のなかには、明治というものがどんなに明るく、広く、真直な美しさをもってうちひらけ、描かれていたかが実に髣髴とするようである。",
              "citation": {
                "source": "村の三代",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六世紀の中葉、ニコツト大使の職を帯びて西班牙に派遣せらるるや、フロリダ渡来の葉煙草を得て、その医療に効あるを知り、栽培大いに努めしかば、一時は仏人煙草を呼んでニコチアナと云ふに至りしとぞ。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙が鳴る――人煙皆無の大樹海のかなたに、毎日、日暮れちかくになるとこの霧が湧くという。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、バダジャッカの喇嘛寺があり、人煙はそこで杜絶える。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論この川筋には、さっきから全然｜人煙の挙っている容子は見えなかった。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私を繞つてゐるものは、人煙を絶つた谿谷であつた。",
              "citation": {
                "source": "槍ヶ嶽紀行",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "行手は今まで来た路に比べると遙に人煙が少ない。",
              "citation": {
                "source": "芋粥",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあたり一帯、人煙稀薄、枯すすきの原さえつづいているのだが、寛永寺末の、院、庵のたぐいが、所まだらに建っていて、おおかたの僧坊は、信心深そうな僧尼によって住みなされていた。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "山間の地は勢ひ人煙薄からざるをえざれども、ひとり有田に於てしからず、このごろ益々繁栄を来せり。",
              "citation": {
                "source": "松浦あがた",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "西には青森の人煙｜指す可く、其｜背に津軽富士の岩木山が小さく見えて居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから折曲った壁に添うて改札口に近い腰掛には制帽の学生らしい男が雑誌をよみ、買出しの荷を背負ったまま婆さんが二人煙草をのんでいる外には、季子と並んでモンペをはいた色白の人妻と、膝の上に買物袋を載せた洋装の娘が赤い鼻緒の下駄をぬいだりはいたりして、足をぶらぶらさせているばかりである。",
              "citation": {
                "source": "或夜",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから折曲つた壁に添うて改札口に近い腰掛には制帽の學生らしい男が雜誌をよみ、買出しの荷を背負つたまゝ婆さんが二人煙草をのんでゐる外には、季子と並んでモンペをはいた色白の人妻と、膝の上に買物袋を載せた洋裝の娘が赤い鼻緒の下駄をぬいだりはいたりして、足をぶら／＼させてゐるばかりである。",
              "citation": {
                "source": "或夜",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　少し上の踊り場で、中学生が二人煙草を吹かしながら見おろしていたが、グーロフにはそんなことはどうでもよく、アンナ・セルゲーヴナを自分の方へ引き寄せると、その顔や頬や手に接吻しはじめた。",
              "citation": {
                "source": "犬を連れた奥さん",
                "author": "DAMA S SOBACHKOI",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は人煙まれなドンヅマリだが、戦争がすんで遊山気分がおこると、遊楽地帯の発展ぐらい急速なものはない。",
              "citation": {
                "source": "水鳥亭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
