          "literary": [
            {
              "text": "場内の壁に何カ所も、「リズム・チークジルバー　　右　固くお断り申し上げます」　と貼り紙がされている。",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "（残っている方のオダリスクをも取り去り、ヨロヨロと、酔ったあげくのジルバのようなステップで、ステージの一番前へ乗り出して来る）なんでもよいから、早くやってしまえ！",
              "citation": {
                "source": "殺意（ストリップショウ）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジルバやヴギがはじまると、首をかしげ、肩をひいて笑った。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
