    "definitions": [
      {
        "index": 1,
        "gloss": "bodyguard",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "階下には侍衛らしい者が、数千人も控えている。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラビアの大旅行家イブン・バツタも、インドの猴王を、四猴、棒を執りて侍衛すと述べた。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは宮中の侍衛を勤める武人で、ふだんから勇気があるので、それを聞いて大いに怒った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "子不語",
                "note": "青空文庫"
              }
            },
            {
              "text": "於東海之上蓬莱之頂、南宮西庶、有群仙所居、上元女仙太真者即貴妃也、謂什伍曰、我太上侍女、頴上元宮聖上太陽朱宮真人、以宿縁世念其願頗重、聖上降居於世、我謫人間、以為侍衛耳、此後一紀、自当相見、　羽衣説話に関しては、別に云う可きことなし。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "四天王の三人、長老｜哲別、参謀長｜忽必来、箭筒士長｜速不台、及び主馬頭｜者勒瑪ほか参謀侍衛ら多勢、それぞれ焚火のまわりに陣取り、弓、矢、鎗、長刀、太刀など、思い思いに武器の手入れをしている。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手の立樹の間から、侍衛長馳せ来る。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍衛長　はっ、今日の死者は、わずかに六人。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽必来　侍衛兵、一千――。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍衛長　はっ、死者はございません。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍衛の百官も、「変れば変るもの」と、涙を催さぬ者はなかった。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍衛の人々、文武の諸官、追うもあり、残るもあり、一時に混雑に陥ちてしまった。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかれども侍衛の臣、内に懈らず、忠志の士、身を外に忘るるものは、けだし先帝の殊遇を負うて、これを陛下に報いんと欲するなり。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "斉シク入リシニ、人アリ、燈下ニ対シテ碁ヲ囲ムモノ両人、側ニ侍衛スルモノ十数名ヲ見ル。",
              "citation": {
                "source": "三国志",
                "author": "篇外余録",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
