[
  {
    "uuid": "ca96b18f-9dd5-5da5-b105-213e3a5d098e",
    "entry": "十年",
    "reading": {
      "primary": "じゅうねん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
