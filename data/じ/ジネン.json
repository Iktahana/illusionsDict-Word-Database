[
  {
    "uuid": "5d4ef489-c340-53bf-a3db-8ef1e2a3687d",
    "entry": "次年",
    "reading": {
      "primary": "じねん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the next year",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」というように損害の苦痛を忍んで次年の計画を良くしたならば幸運が終に来ないとは限るまい。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて次年また子を生んだ当日より母馬その子の在所を見定めた上ならで身を動かす事なく子よく生い立った。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "個人の耕作段別はどうしてきまるかといふに、はじめ村組合に、その次年度の段別を配當して來たものを、組合長と總代會に於て、各部落にそれぞれの段別を再配當する。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前年の割當てといふものがちやんときまつて居り、次年度においてもそれが變更されるといふことはまづなかつたからである。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶山の書は次年八月十三日に裁したもので、此に由つて此文化紀元八月中旬の四日間の連続した事実を知ることが出来る。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "次年以下の勤向覚書を検すれば、此間の消息を知ることが出来る。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし次年二月に筆を起してある勤向覚書に徴するに、蘭軒は此年十二月下旬より痼疾の足痛を患へて、医師谷村｜玄※の治療を受けた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは次年の菅茶山の手紙の考証に資せむがために記して置くのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "前年己卯には元日に七絶一首を作り、次年辛巳には五古一首を作つたのに、独り此年庚辰には七律二首を作つてゐるからである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは次年十二月に至つて刻成せられた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆゑ正精の丸山邸に居るに及んで、次年元日の詩に和して、其引に侯の挂冠の事を追記した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "次年八年辛未二月二十一日には嵯峨の竹里の家が出来た。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち晩春より次年仲春に至る一年の間である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは霞亭が、市に入つた次年の二月下旬に、関宿に往つて凹巷を待ち合せたことを言つたのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "事は次年歳首の詩の註に見えてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "事は次年に作つた長古「芳桜歌」と其小引とに載せてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "辛巳より算すれば此年乙酉は第五年、西遊の次年壬午より算すれば第四年である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "次年に蘭軒に与へた書に、「君公御入国に而一度めされ候時病気に而御断申上候、其のち又めされ御居間にて御酒頂戴、かへりには御盃、筆墨箋、たばこ入をいただき候、十二月廿二日也」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしの推定の本づく所は、此年四月頃の茶山の尺牘の断片と、次年戊子元旦の蘭軒の詩の註とである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し更に蘭軒の次年戊子元旦の詩註を取つて合せ看るときは、榛軒の妻｜勇が来嫁の後未だ幾ならずして懐胎したことが知られるであらう。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬に入つて十一月に榛軒が女子を挙げたことは、次年戊子元日の詩の註に見えてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "是も亦次年元日の詩の註に見えてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋江抽斎の挈へて往つた妻は比良野氏｜威能で、前年己丑に帰いで、次年辛卯には死ぬる女である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "里恵は次年癸巳の春｜聿庵の江戸より来るのを待つてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "次年五月は廩米中より糯米三俵を取つて柏餅を製し、津軽藩士と親戚故旧とに貽るを例としてゐたさうである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "是は次年の記に、「去年八月、善直因戸田氏之恵、此三枚橋の家を得たり」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "次年は文政四年で、京水瑞英が自記の筆を把つた年である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "次年己酉の四月には春が嗣子｜磐を生んでゐるからである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "胎内の子は次年甲寅の初に生るべき棠軒の女長である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "次年丙辰に富岡に遊んだ記も亦さうである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
