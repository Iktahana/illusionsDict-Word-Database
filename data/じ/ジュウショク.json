    },
    "definitions": [
      {
        "index": 1,
        "gloss": "chief priest (of a Buddhist temple)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "旅行の目的は、もしも運がよかったら鯨を捕る光景が見られるというのと、もう一つは、自分の先祖のうちに一人室戸岬の東寺の住職になった人があるのでその墓参りをして来るようにという父からの命をうけていたことである。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりは住職に逢つた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "住職は四十前後で、色の白い、髯のあとの青い人であつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "客の一人は侍、一人は御用聞きといふので、住職も疎略には扱はなかつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "住職は默つて聽いてゐた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、住職は珠數を爪繰りながら不安らしく訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　をぢさんと半七とは鋭い瞳のひかりを住職に投げ付けると、彼は蒼くなつて少しく顫へた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "住職は一杯も飮まなかつたが、二人は鱈腹に飮んで食つた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "歸る時に住職は、「御駕籠でも申付けるのでござるが……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "住職の顔色の變つたのも、自分たちに鄭重な馳走をしたのも、無言のうちに彼の降伏を十分に證明してゐた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「聞けば淨圓寺の住職は破戒の堕落僧だといふ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の信じてゐる住職の教へにしたがつて、こゝの屋敷を立退くより他はないと決心した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "淨圓寺の住職はなんの目的でお道に怖ろしい運命を豫言したか、それに就いては半七も餘り詳しい註釋を加えるのを憚つてゐるらしかつたが、それから半年の後にその住職が女犯の罪で寺社方の手に捕はれたのを聽いて、お道は又ぞつとした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "きかせばや信田の森のふる寺の小夜ふけがたの雪のひゞきを　斯くて三十四歳の時は、押しも押されもせぬ一廉の禅師になり、亡師のあとを継いで松蔭寺の住職となり、まだ破れ寺ではあるが、そこに蟠※してぽつぽつ集って来た雲水に向って教育をはじめた頃である。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓所にはまだ折れたのがそのままでありましたから、外のと違って、そう言った事情で、犬にも猫にも汚させるのが可厭でしたから、俥ではるばると菩提寺へ持って来て、住職にわけを言って、新に塔婆を一本｜古卒塔婆の方は些少ですが心づけをして、寺へ預けて、往かえり、日の短い時の事です。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その古寺へ四、五年前から二人の出家がはいり込んで来て、住職は全達、納所は全真、この二人が先ず居すわることになりました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ひとりだちして　どこかの　じゅうしょくに　なれ、と　すすめられましたが、一休さんは、「いいえ、もっと　がくもん　します。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなが、「そうじゅんさん、おしょうさまの　あとを　ついで、さいごんじの　じゅうしょくに　なって　ください。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かそうさまの　さしょうは、どんな　りっぱな　てらの　じゅうしょくにも　なれる　高い　ねうちの　あるものです。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえは　わしの　あとを　ついで、大とくじの　じゅうしょくに　なって　もらわねばならぬ。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かそうさまは　一休さんを　じぶんの　あとつぎにして、むらさき野の　大とくじの　じゅうしょくに　しようと　して　いたのでした。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしょうさまの　おなさけに　そむくようで　こころが　いたみますが、わたしは　てらの　じゅうしょくには　なりたく　ございません。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "てらの　じゅうしょくに　なれば、いろいろ　わずらわしい　人とも、また　えらい人とも　つきあわねば　なりません。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまがさきの　こうとくじ　と　いう　おてらの　じゅうしょくの　じゅうちゅう　と　いう　おしょうさんが　ごつちみかどてんのうの　つかいと　して、この　しょうおんあんに　きました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一休さんに、大とくじの　じゅうしょくに　なって　もらいたいと　いう　つかいでした。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "大とくじの　じゅうしょくに　なっても、つねづねは　この　いおりに　すむことを　おゆるしくだされば　おうけ　いたします。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま　大とくじの　じゅうしょくに　なるような　とくの　たかい　かたは、あなたの　ほかにありません。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
