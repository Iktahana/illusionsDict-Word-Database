    "definitions": [
      {
        "index": 1,
        "gloss": "Jinshin revolt (671 CE)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
