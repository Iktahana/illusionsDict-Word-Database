        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして人に接するのにも、わきの方からそつと寄つて行つて、じろりと横目で見て、「ああ、あれは變態だ！",
              "citation": {
                "source": "津輕地方とチエホフ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "双方、法堂へ行って支度をしなさい」　三要はこう言ってじろりと昭青年を見ました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕暮になって、一行が水神の八百松へ晩餐をとりに入ろうとすると、みち子は、柚木をじろりと眺めて「あたし、和食のごはんたくさん、一人で家に帰る」と云い出した。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "局長は疑ぐるように、うわ眼を使って、小使をじろりと見た。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに盤台の方をじろりと見て……おや、きょうはなんにも持って来なかったのかいと、こう云ったときに、おまきさんの顔が……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では、まことに申しにくうございますが、この御相談はお断わり申しとう存じます」　女の眼はじろりと光った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "小山は、骨ばった手を口にあてゝ煙にむせながら、こっちから、じろりと眼をやった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　山崎は、もみ合っている工人達をじろりと一瞥した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中隊長は、通訳からその意味をきくと、じろりと、いかつい眼で暫らくその男を睨みつけた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と小川は、ゆっくり言葉を切って、じろりと源作を見た。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "火鉢の傍に坐りこんでいる内儀の眼がじろりと光る。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、祖母は云ったが、父母は、じろりと彼を見て、放っとけというような顔をした。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく私が方をじろりと見たっけよ、舌不足が饒舌るような、愚にもつかぬ声を出して、（姉や、こえ、こえ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何為か、その上、幼い記憶に怨恨があるような心持が、一目見ると直ぐにむらむらと起ったから――この時黄色い、でっぷりした眉のない顔を上げて、じろりと額で見上げたのを、織次は屹と唯一目。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "百人長は毛脛をかかげて、李花の腹部をむずと蹈まえ、じろりと此方を流眄に懸けたり。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡の中のＩ氏は、実物の筆者のほうを時々じろりじろりとながめていた。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の大将が食卓でオール・ドゥーヴルを取ってから上目で給仕の女中の顔をじろりと見る、あの挙動もやはり「生きてはたらきかける」ものをもっている。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「母上さん、そりゃア貴女軍人が一番お好きでしょうよ」とじろりその横顔を見てやる。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "母はじろり自分を見たばかり一言も言わず、大きな声で「お光、お銚子が出来たよ」と二階の上口を向いて呼んだ。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と急きこんで問うたが、妻はその凄い眼で自分をじろりと見たばかりで一語も発しない。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何故開けた、どうして開けた」「委員会から帳簿を借してくれろと言って来ましたから開けて渡しました」とじろり自分の顔を見た。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
