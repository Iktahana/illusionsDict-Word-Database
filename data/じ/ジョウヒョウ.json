[
  {
    "uuid": "9de0010d-6809-59dd-866d-fd7f4afe31cb",
    "entry": "上表",
    "reading": {
      "primary": "じょうひょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
