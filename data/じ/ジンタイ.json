[
  {
    "uuid": "2c733d7a-cf5e-56f3-8649-481ab35c72f5",
    "entry": "人体",
    "reading": {
      "primary": "じんたい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
