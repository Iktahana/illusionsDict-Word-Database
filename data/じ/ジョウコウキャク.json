    "definitions": [
      {
        "index": 1,
        "gloss": "passengers getting on and off (a train)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
