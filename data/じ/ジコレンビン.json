        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ゆっくりと、悲嘆と自己憐憫にひたる時間もくれないなんて、最低の奴だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎の小さな心は、自己憐憫や感謝の念それに新しく同情を得たことに気がついて、今度は喜びでいっぱいになった。",
              "citation": {
                "source": "赤い婚礼",
                "author": "RED BRIDAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己憐憫は弱者の事である。",
              "citation": {
                "source": "三太郎の日記　第二",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "固より弱く生れついた者には自己憐憫の心がない譯に行かない。",
              "citation": {
                "source": "三太郎の日記　第二",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し自己憐憫から自己嘲笑に、自己嘲笑から自己超越に磨き上げるのが――カントの言葉を用ゐれば――彼の「義務」である。",
              "citation": {
                "source": "三太郎の日記　第二",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
