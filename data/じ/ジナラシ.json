    "definitions": [
      {
        "index": 1,
        "gloss": "ground levelling (leveling)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "二人が靴で踏み荒した雪の上へ新しい雪は地ならしをしたように平らかに降った。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂上は簡單に地ならしされ、十坪ほどの赭土がむきだされてゐた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家を建てようとして地ならしをして、それつきり、家を建てようともせずその赤土の空地にかぼちやなどを植ゑてゐる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し行くと古い寺の隣の杉林を切り倒して、きれいに地ならしをした上に、青ペンキ塗りの西洋館を建てている。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "片隅にブランコが二つ設けてあったが、いっこうに地ならしがしてないので、雨あがりなどには其処らは一面の水溜りになってしまって、ブランコの傍などへはとても寄り付くことは出来なかった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "列を作って、地道な蟻のように、廃墟の地ならしにとりかかりました。",
              "citation": {
                "source": "対話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、音吉が馬鈴薯の種を籠に入れて持って来て見ると、漸く高瀬は畠の地ならしを済ましたところだった。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "黎明会的な啓蒙運動としての批判主義哲学や文化哲学が、その地ならしをした。",
              "citation": {
                "source": "哲学の現代的意義",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "石劒片、石槍、貝輪、輕石製浮標等出づ）　これは大變と、總掛りで地ならしをして、今度は又思ひ思ひに陣を取り、西から東に向つて坑道を進め掛けた。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "權現臺の懷古",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから此処の家を建てる時に、藪を切り開いて地ならしをした時に、地鎮祭を行はなかつたことも崇つて居るといふことであつた。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オイ、お前の華族の友達あ、日本アルプスの地ならしを始めたていじゃねえか」「一体、雪を掘って、何にする気だい」「お前の華族の友達あ、気が違ったんじゃねえか」　こういった質問が代表的のものだった。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで文化建設への地ならしは出来るであろう。",
              "citation": {
                "source": "文学精神は言う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、この地ならしの過程に於て、真の建設精神は、恐らく次のように呟くかも知れない。",
              "citation": {
                "source": "文学精神は言う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "新文化建設への地ならしは甚だ結構だが、それをして高きを崩してすべてを低きに平均せしむるものたらしめず、低きを向上さしてすべてを高きに平均せしむるものたらしめることは、出来ないものであろうか。",
              "citation": {
                "source": "文学精神は言う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れから地ならしをして植附を終るまでの人夫｜其他費用一切が百エエカアに就て千円｜乃至二千円を要し、監督者の家屋の建築に千円｜乃至二千円を要する。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんたうに芝居を見る地ならしだけは、博士（一部分は鴎外翁その外）のおかげで出来て居ます。",
              "citation": {
                "source": "芝居に出た名残星月夜",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "朧の奥に星を埋めて、限りなき夜を薄黒く地ならししたる上に、稲妻の穂は一を引いて虚空を走った。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に地ならし植えつけに費やすべき金高が以外に多い。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "建築をするため、地ならしをする時、切株は取り除かれたのでした。",
              "citation": {
                "source": "霊感",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには先ず、地ならしをして、地所の浄めをしなければなりません。",
              "citation": {
                "source": "霊感",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒竹の茂みを背景に、平らに地ならしが出来ていて、そこの小地域、四方に竹を立て、注連縄が張ってあります。",
              "citation": {
                "source": "霊感",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「然し、石を取り除き、地ならしして、平地にしてしまっても、そこにはまた、靄が立ちこめるように、一種の濛気が立ちこめてくるかも知れない。",
              "citation": {
                "source": "非情の愛",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "拝殿は見えないが、恐らく右手の杉樹立を隔てた高みにあり、一段低く地ならしをした広場が舞台となつてゐる。",
              "citation": {
                "source": "かへらじと",
                "author": "日本移動演劇連盟のために",
                "note": "青空文庫"
              }
            },
            {
              "text": "巽　　土俵の地ならしは？",
              "citation": {
                "source": "かへらじと",
                "author": "日本移動演劇連盟のために",
                "note": "青空文庫"
              }
            },
            {
              "text": "火事の隣にアメリカの兵隊がローラーで地ならしゝてゐる。",
              "citation": {
                "source": "戯作者文学論",
                "author": "――平野謙へ・手紙に代へて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の火事に目もくれず、進んだり戻つたり、地ならしゝてゐる。",
              "citation": {
                "source": "戯作者文学論",
                "author": "――平野謙へ・手紙に代へて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある朝のこと、まだ床の中に眼覺めたまゝでゐると、向うの双子山の麓のところで山を崩して地ならしをしてゐる、岩を摧く鐵槌の音が靜かに山に反響してゐるのが長閑に枕にひゞいて來る。",
              "citation": {
                "source": "箱根の山々",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "のこぎり山の向こうは、ちゃんと地ならしをしてありまして、りっぱな飛行基地のようです。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もうちやんと地ならしがでけとるだで、わしや助かるです」「ぢや、お序に副組長の指名をして下さい」　田丸の言葉を受けて、八谷は、云つた。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌日から久作はミササギで仕事にかかったが、十日あまりで石を全部谷へ投げこみ、地ならしして、ミササギが畑になっていたのである。",
              "citation": {
                "source": "保久呂天皇",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
