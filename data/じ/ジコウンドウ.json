  {
    "uuid": "b9357087-b297-51fa-a04f-ee9ce02d7779",
    "entry": "自己運動",
    "reading": {
      "primary": "じこうんどう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
