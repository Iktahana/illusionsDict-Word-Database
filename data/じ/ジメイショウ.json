    "definitions": [
      {
        "index": 1,
        "gloss": "mechanical clock with a bell-ringing mechanism",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
