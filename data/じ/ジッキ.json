    "definitions": [
      {
        "index": 1,
        "gloss": "real machine (as opposed to a model or simulation)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "事実機敏な映画会社でも彼女を引っこ抜くのは、もう少しあとでと思っていたくらいである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日にいたるまで、二人はアルテアの実機では、ついに一度もベーシックの動作を確かめられなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本電気はＺ80互換のμＰＤ７８０という製品を作っており、実機にはこれを載せる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがこんなスケジュールでは、開発したベーシックを実機でチェックする期間は、きわめて短くなってしまう。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこの時期以後になってもまだ窒素が多いと、かえって稔実機能に障害を来し易いという研究が為されている。",
              "citation": {
                "source": "稲の一日",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はきはきした「由」はじっきに、きりきりとした紺股引と紺｜足袋を穿いてやって来るのであった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じっきに出るのはよう解り切ってるのに、まだじゃまだじゃと吐しおって……」「おなごの手じゃわい、そりゃ」「ちょっとでも長う楽しもうと思うてけつかるのや」　屋根の下は急に賑わって来た。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁の言ひ立ての後で、三番叟（信州新野では、しようじっきり）が出て、翁のおどけ文句以上に、狂言を述べる。",
              "citation": {
                "source": "翁の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此を三番叟といふ処もあり、しようじっきりと言ふ地もあります。",
              "citation": {
                "source": "翁の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "信州｜新野の雪祭りに出るしようじっきりと言ふ黒尉は、其上更に、もどきと言ふ役と其からさいほうと称する役方とを派生してゐます。",
              "citation": {
                "source": "翁の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あんたに会いたいいうてたけど、……今じっき帰って来るよって待ってたらどう？",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辺の人にきいてみますと、「そら料理屋違いまッしゃろ、宿屋でっせ」いうのんで、「何処です」いいますと、「じっきこの先のろうじの奥だ。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
