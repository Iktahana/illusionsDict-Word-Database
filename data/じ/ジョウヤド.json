    },
    "definitions": [
      {
        "index": 1,
        "gloss": "first-class inn",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さそくに案内せい」　だが、誘なっていったその千種屋が、番頭の言葉だとあまり上等ではなかろうと思われたのに、どうしてなかなか容易ならぬ上宿なのです。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上宿を貸したとて、別に害はしないで、馬の力を十倍にしてくれるというのです。",
              "citation": {
                "source": "天下一の馬",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "松陰神社の入口から世田ヶ谷の上宿下宿を打通して、約一里の間は、両側にずらり並んで、農家日用の新しい品々は素より、東京中の煤掃きの塵箱を此処へ打ち明けた様なあらゆる襤褸やガラクタをずらりと並べて、売る者も売る、買う者も買う、と唯驚かるゝばかりである。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒髪をわけたような青芒の武蔵野を縫う一すじの青梅街道を、三ツ木、上宿と、二里ばかりあるくと、田無だった。",
              "citation": {
                "source": "野槌の百",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本街道のほうは下宿と上宿、本宿まで、馬、駕籠の問屋はもちろん、旅館をぜんぶ当ってみた。",
              "citation": {
                "source": "その木戸を通って",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上宿命の跡はあまりに歴然としていて、人をしてそれに触れることを躊躇さしたのである。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅費と日当と鑑定料を取られる」「はゝあ」「その上宿屋は此方持ちさ。",
              "citation": {
                "source": "村の成功者",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来、史上宿題の人である。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
