[
  {
    "uuid": "f8c4b7cf-a53b-5568-8739-8037db2bb4ae",
    "entry": "上宿",
    "reading": {
      "primary": "じょうやど",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
