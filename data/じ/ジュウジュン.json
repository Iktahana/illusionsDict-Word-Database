[
  {
    "uuid": "2ac75a87-0ddc-590c-8693-930847942c15",
    "entry": "従順",
    "reading": {
      "primary": "じゅうじゅん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
