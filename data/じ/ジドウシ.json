        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "Yell（ユェル）【自動詞】（with pain ―― with fury ―― with delight ―― with laughter, etc.）わめく、おめく、（いわゆる）黄色い声を出す。",
              "citation": {
                "source": "熟語本位英和中辞典",
                "author": "Y",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い日本の文法には、自動詞にも目的格があつた。",
              "citation": {
                "source": "古代民謡の研究",
                "author": "その外輪に沿うて",
                "note": "青空文庫"
              }
            },
            {
              "text": "即、有対自動詞の形をとるのである。",
              "citation": {
                "source": "古代民謡の研究",
                "author": "その外輪に沿うて",
                "note": "青空文庫"
              }
            },
            {
              "text": "生ひば生ふるかにの「生ひば」は、自動詞「生ふ」の目的で、現代の言語情調には、這入りきらぬ文法感である。",
              "citation": {
                "source": "古代民謡の研究",
                "author": "その外輪に沿うて",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、泣く、寝るは共に自動詞で、はだかで拠り所のない語だ。",
              "citation": {
                "source": "古代中世言語論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大槻文彦博士の分類では、こんぷるめんとの有無によつて有対自動詞・無対自動詞と分けてある。",
              "citation": {
                "source": "古代中世言語論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣く・寝るはその後者に属するが、昔は、この今の我々が無対自動詞と思つてゐるものが、所謂有対自動詞であつた。",
              "citation": {
                "source": "古代中世言語論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "い・ねはこんぷるめんとではないのだが、かうした形が進んで来て、自動詞にも、どうしても目的なり対象なりがなければならぬ。",
              "citation": {
                "source": "古代中世言語論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり有対自動詞といふやうな形が出来て来るのだ。",
              "citation": {
                "source": "古代中世言語論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤、古い人には別の論を立てる人があつて、を・に等の助詞は非常にゆるく使はれて居るとも言ふから、或は又他の意味があつたのかも知れぬが、とにかく、自動詞が対象を要求した。",
              "citation": {
                "source": "古代中世言語論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも自動詞が目的語乃至補足語を取らねばならぬ様になつた結果、寝るをいぬる、泣くをねなくと言ふ様になつた。",
              "citation": {
                "source": "古代中世言語論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に近時、「乱」字を四段の自動詞に活用せしめた例が万葉に無いとして「入り乱れ」と訓んだ説（沢瀉氏）があるが、既に「みだりに」という副詞がある以上、四段の自動詞として認容していいとおもったのである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "また自動詞他動詞の区別は絶対的でない以上、四段のミダルは平安朝以後のように他動詞に限られた一種の約束を人麿時代迄｜溯らせることは無理である。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、四段の自動詞に活用しないという結論に本づく根拠もあるのだが、私は今回もミダルに従った。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルナアルさんは、しどろもどろになり、自動詞と他動詞を間違えたり、不定法の現在と命令法の複数を間違えたりする。",
              "citation": {
                "source": "葡萄蔓の束",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "119P.102　「自動詞多きことに注意せよ」とあるは「自動詞に sein で完了時稱を作るもの多きことに注意せよ」――の誤り。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に「山に登る」なる自動詞があげてある。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "三省堂のに比較すると自動詞以外は殆ど同じだが、ただ「登山（業）者」として、登山者と登山を職業にする者とをわけたところが面白い。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動詞はこれから類推できるような意味を持っているし、名詞はこの動詞の転化したものである。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「スル　スル　スル」とじどうしやが　はしつてきましたが、あめくんに　であふと　すつかり　ぬれてしまひました。",
              "citation": {
                "source": "あめくん",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、もんのそとに、じどうしゃのとまるおとがしました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "足おとのしないようにかけだして、もんのそとへでてみると、大がたのじどうしゃがとまっていました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "じどうしゃのうしろの、にもつをいれるとらんくのふたがうまくひらきました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなく、くろめがねのおとこが、女の子をつれて、じどうしゃにのると、そのまま、どこかへはしりだしました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "くろいめがねをかけたおとこが、かわいらしい女の子をじどうしゃにのせて、どこかへつれていくのです。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょうねんたんていだんのぽけっと小ぞうは、じどうしゃのうしろのとらんくの中にかくれました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "じどうしゃは、さびしいはらっぱでとまりました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしっ、ぼくは、きっと、ほうせきばこをとりかえしてやるぞっ」　くろめがねは、ほうせきばこをもって、じどうしゃにのりました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい二つの目が、じどうしゃのライトのようにひかっています。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふうせんは、かぜにふかれてりくのほうへとんでいくので、みんなは、ランチでりくにもどり、れんらくしておいたけいさつのじどうしゃにのって、おいかけました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
