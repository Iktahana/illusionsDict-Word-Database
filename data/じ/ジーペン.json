        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は、Ｇペン買ひに、まちへ出た。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（下）　甲府偵察のこと　きらきら光るＧペンを、たくさん財布にいれて、それを懷に抱いて歩いてゐると、何だか自分が清潔で、若々しくて、氣持のいいものである。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、Ｇペン買つてから、甲府のまちをぶらぶら歩いた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "唄いながら、原稿用紙の塵を吹き払い、Ｇペンにたっぷりインクを含ませて、だらだらと書きはじめた。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペンはＧペン、一日一本です。",
              "citation": {
                "source": "身辺打明けの記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐藤春夫なども太い字を書く方で、昔はよくＧペンの腐り加減になつた、へたばつた奴を使つてゐたが、直きに折れてしまつたり、股が開き過ぎてインキを吸はぬやうになつたりして、ちやうど使ひ頃の間と云ふものは、ほんの僅かである。",
              "citation": {
                "source": "文房具漫談",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "万年筆にも太く書けるのがないことはないが、しかし毛筆やＧペンの柔かいもの程自在でない。",
              "citation": {
                "source": "文房具漫談",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきのプツンときれたＧペンを横縦につかって、こんな図案のような字をかくことが和一郎のお得意の一つだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "変らないのは、ミセス・レイマンがＧペンを風雅につかって書く手紙の文字と、彼女の温い親切な生れつきだけだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍しくきょうはＧペンでかいていて、その方が万年筆よりなだらかでした。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヂパングとは日本國の支那音ジーペンクオ（〔Jih-pe^n-kuo〕）を訛つたものである。",
              "citation": {
                "source": "東西交通史上より觀たる日本の開發",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
