        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "折角、自分は善良な慈悲心でして居るつもりのことが、利己主義の慈悲心になっては残念です。",
              "citation": {
                "source": "慈悲",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角、自分は善良な慈悲心でしているつもりのことが、利己主義の慈悲心になっては残念です。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女性には柔軟な優しみ、惻々たる慈悲心、風雅な淑かさ、繊細な可憐さなどの情緒が蓄積されて来ます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時すがら悪き病疾に罹れるやらむ、近寄りては面倒、と慈悲心無き男なれば遠くより素通りしつ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかれども懸賞して細民を賑わすにしかずと、一片の慈悲心に因りて事ここに及べるなり、と飯炊に雇われたる束髪の老婦人、人に向いて喋々その顛末を説けり。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――世の中のうろたへものは、佛法僧、慈悲心鳥とも言ふであらう。",
              "citation": {
                "source": "飯坂ゆき",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで保胤は性来慈悲心の強い上に、自ら強いてさえも慈悲心に住していたいと策励していたことであろうか、こういうことが語り伝えられている。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂心は若い時から慈悲心牛馬にまで及んだ人である。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは人間の征服性の興味が、慈悲心を超越しているからであろう。",
              "citation": {
                "source": "首を失った蜻蛉",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも彼はその田舎地方では、慈悲心と親切心とで有名であり、彼の判事席からかける言葉のやさしいことは、周知の所だったのだ。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "慈悲心で黙って書かしてくだすったのであるという。",
              "citation": {
                "source": "おばけずきのいわれ少々と処女作",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎度のこと故その気になってしからばなって見ようというと、『維摩経』に、法喜を以て妻とし慈悲心を女となし、諸淫舎に入りては欲の過ちを示し、諸｜酒肆に入りては能くその志を立つとある。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "見馴れない卵であるからその親鳥をきくと、それは慈悲心鳥であることが判った。",
              "citation": {
                "source": "慈悲心鳥",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "日光山の慈悲心鳥――それを今さら詳しく説明する必要もあるまい。",
              "citation": {
                "source": "慈悲心鳥",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯貝は途方もない物好きと、富豪の強い贅沢心とからで、その慈悲心鳥を一度飼ってみたいと思い立って、中禅寺にいる者に頼んでいろいろに猟らせたが、霊鳥といわれているこの鳥は声をきかせるばかりで形を見せたことはないので、彼は金にあかしてその巣を探させた。",
              "citation": {
                "source": "慈悲心鳥",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの鳥ならばなんでも引受けるが、慈悲心鳥の飼い方ばかりは彼にも判らなかった。",
              "citation": {
                "source": "慈悲心鳥",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし慈悲心鳥の斃れたことを彼は東京へ報らせてやらなかった。",
              "citation": {
                "source": "慈悲心鳥",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "六兵衛が帰ったあとで、磯貝はこれを宿の者に自慢らしく見せると、おなじ鶯の巣に育ちながらもそれは慈悲心鳥でないことが証明されたので、彼はまた怒った。",
              "citation": {
                "source": "慈悲心鳥",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "じひしんちょう（慈悲心鳥）の聲は山中でなければ聞かれません。",
              "citation": {
                "source": "森林と樹木と動物",
                "author": "本多靜六",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
