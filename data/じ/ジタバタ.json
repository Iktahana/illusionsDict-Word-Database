        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼女はただただジタバタしてゐた。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一体どうするのが、俺には一番いいのだろう）　彼は、暑さにジタバタする子供の寝顔を、薄暗い陰気な電燈の光に眺めた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからジタバタしたって駄目だぞ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学というものは、結局誇張だと思うところから、ジタバタ書いて行くのが、若い世代の文学であろう。",
              "citation": {
                "source": "文学的饒舌",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "忌避するためにジタバタ致します。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "▼ジタバタする杉山氏の姿を、良い気持で眺めてゐる読者を杉山氏は責めることはできない。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "――然し金菱にかゝったら、いくら専務がジタバタしようが、桁から云ったって角力にならない。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今中さはさまって、野郎ジタバタしてる！",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなかもってあのような獲物は、一人で取ろうの儲けようのと、ジタバタしたところで出来ない相談、莫大なねうちでございますからな。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルジョア文壇に悪行があるとすればそれはとりも直さずその作家たちの属する社会層の悪行であり、その根絶への方向は、一作家の文壇の枠内でのジタバタ騒ぎにすぎないことはわれわれの目に明らかなのである。",
              "citation": {
                "source": "一九三四年度におけるブルジョア文学の動向",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "英米の高圧外交にかかって、ひねり殺されたくないばっかりに、必死的なストラグルを続けているという、見っともない、情ないジタバタ時代であった。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本民族の腸が……特に朝鮮官吏の植民地根性が、ここまで腐り抜いている以上、吾輩がタッタ一人で、いくらジタバタしたって爆弾漁業の勦滅は……」「……黙り給えッ……司直に対して僭越だぞ……」「何が僭越だ。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もういくらジタバタしたって駄目だ。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "賊「ジタバタしても役にゃア立ねえ、金の有ることを知って這入ったのだ、金エ出せ／＼」　と云ってる奴は余程｜胆の据った者の様子。",
              "citation": {
                "source": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "author": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジタバタしたって最う駄目だよ。",
              "citation": {
                "source": "天主閣の音",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがもし下手にジタバタすると、喉笛に手先がかかるかもしれねえ。",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジタバタ騒ぐと怪我をするぜ。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何と云って君はジタバタしたって、所詮君という人はこの魔法使いの婆さん見たいなものに見込まれて了っているんだからね、幾ら逃げ廻ったって、そりゃ駄目なことさ、それよりも穏なしく婆さんの手下になって働くんだね。",
              "citation": {
                "source": "子をつれて",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ジタバタ騒ぐな！",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は戦争中は天命にまかせて何でも勝手にしろ、俺は知らんといふ主義であつたから、徴用出頭命令といふ時も勝手にするがいゝや何でも先様の仰有る通りに、といふアッサリした考へで、身体の悪い者はこつちへ、と言はれた時に丈夫さうな奴までが半分ぐらゐそつちへ行つたが、私はさういふジタバタはしなかつた。",
              "citation": {
                "source": "魔の退屈",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一ツや二ツのことにジタバタしたって、オレが失った人生は取り返されやしない」「破産したから離婚だの慰藉料をよこせだのと仕たい放題に振舞われても、刀をぬいて斬りつけることもできないのね。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒板が――僕としては幸福なめぐりあわせであつたのだが黒板は幾らか重すぎるために、博士は遂ひに自ら黒板の下敷きとなり泡を激しく吹き乍らジタバタして、「タ、助けないと、アンゴウは、ラ、ラ、ラ、落々々々……ぢやアよ！",
              "citation": {
                "source": "霓博士の廃頽",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は死物狂ひに憤慨しながらジタバタしてゐたが、つひにエイッ！",
              "citation": {
                "source": "霓博士の廃頽",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は戦争中は天命にまかせて何でも勝手にしろ、俺は知らんという主義であったから、徴用出頭命令という時も勝手にするがいいや何でも先様の仰有る通りに、というアッサリした考えで、身体の悪い者はこっちへ、と言われた時に丈夫そうな奴までが半分ぐらいそっちへ行ったが、私はそういうジタバタはしなかった。",
              "citation": {
                "source": "魔の退屈",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が天命主義でちっともジタバタした様子がないので薄気味悪く思ったらしいところがあった。",
              "citation": {
                "source": "魔の退屈",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから苦しいのを堪えて、ジタバタしながら兵馬を押し退けて、刀を抜こうとするのであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジタバタしたって追っ付かない。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジタバタしたって追っ付かない、しょびいて行くからその意りでおいでよ」烏組の副将お竹である。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
