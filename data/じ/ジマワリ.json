          "literary": [
            {
              "text": "私を地回りとにらんで逃げたのでしょう。",
              "citation": {
                "source": "悪魔の聖壇",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君、地回りかい」　放二はクスリと笑っただけである。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「地回りに、なぐられないかい」「まだそんな経験はありません」　二人の会話は重点がずれているようだ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が一人で、そういうしょうばいをしていれば、地回りなどがすぐ因縁をつけるか、しょうばいの邪魔をする。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
