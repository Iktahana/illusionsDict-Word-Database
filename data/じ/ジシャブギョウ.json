    "definitions": [
      {
        "index": 1,
        "gloss": "governmental position of the shogunate, responsible for the management of temples and shrines",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし御寺社の方はよろしいのでございましょうな」　寺の門前地は寺社奉行の支配で、町方の係りではない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝六十手を示して、Ｔ「少しお訊ねしたい事があるんですがね」　和尚が、Ｔ「寺社奉行様への手続を踏んで参られたか」　伝六返答に困った。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "右門考えていたが、Ｔ「暮れる迄に寺社奉行様の手続を頼んだぞ」　「それじゃ旦那」　右門堅く決する処がある。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "御承知でもありましょうが、坊主や虚無僧は寺社奉行の支配で、町方では迂濶に手を着けることが出来ないのですから、そこを見込んで思い思いに化けたんでしょう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、寺社奉行、勘定奉行、町奉行、大目附、目附を掛員として、評定所に開く、一種の特別裁判であつた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "十分の証拠を挙げて、町奉行所から寺社奉行に報告し、その諒解を得た上でなければ、町方の者が自由に活動することを許されない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは浅草寺内の出来事であるから、寺社奉行の係りである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺社奉行所にだって人足アいくらでもあるんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、伝六のいうとおり、お差し紙の文面に現われたあな（事件）そのものはまことにたわいのなさそうなことではあるが、係り違いの寺社奉行所から特に出馬を懇請してきたところに味があるのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "興照寺より届けいでこれあり候とあったその永代橋へたどりついてみると、名人の出馬いまかいまかとかたずをのんで、寺社奉行ご支配の小者たちが群がり集まる群衆を制しつつ、その到着を待ちあぐんでいるさいちゅうでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺社奉行さまが、さばきのむちと情とを持って、お待ちかねでござろうわ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "参りまするでござります……」　とぼとぼと力なく足を運んで、卒塔婆、新墓立ち並ぶ裏墓地を通り抜けながら、罪の蓮信坊は寺社奉行所目ざしつつ、悲しげに裏門をくぐりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "かりそめにも寺社奉行さまからお許しのお富士教、わたしはその教主でござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "おって寺社奉行のほうに突き出し、ご法どおり日本橋へさらし者にしたうえ百たたきの罰を食わしてやるから、さよう心得ろ」「いいえ、ただでとは申しませぬよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "耳のない浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとっ走り、伝六、寺社奉行さまのところへ行ってきな」「フェ……？",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺社奉行さまのところへ大急ぎに行ってこいといってるんだよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、やにわと途方もねえ、寺社奉行さまなんぞになんのご用があるんですかい」「お町方とはお支配違いのお寺で少しばかり調べ物をしなくちゃならねえから、踏むだけの筋道を踏んでおかなくちゃならねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねんごろに葬っておやりよ」　紅絹の袋から寺社奉行へ、寺社奉行からまた四ツ谷ご門へ、なんのかかわり、なんのなぞの橋があるか、不意打ちだけにおよそ不思議な右門流です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "へえい、ただいま――」　声を押し分けながら、八つ当たりに当たり散らして、黙然とあごをなでなで待ちうけていた名人の前へがちゃがちゃと駕籠を止めさせながらようやくに姿を見せたのは、寺社奉行所へお断わりにいった伝あにいです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざわざと寺社奉行さまなんぞにお断わりをして、お寺の何をいってえ調べなさるんですかい」「下手人の女よ」「その女が、お寺のどこを詮議したらわかるんですといってきいているんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "八丁堀同心近藤右門ちと詮議の筋があるゆえ、寺社奉行さまのお許しうけてまかり越した。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "八丁堀同心近藤右門、吟味の筋あって寺社奉行さまのお許しこうむり、寺帳改めにまかり越した。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "老中、寺社奉行の権職にある公儀役人と雖も、許しなくては通れぬ場所じゃ。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいやな、これ程申してもお用立出来ぬと仰せあるならば、致し方がおじゃりませぬゆえな、今から江戸へ急飛脚飛ばして、寺社奉行様のお裁きを願いましょうわい。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "御領内に鎮座まします御社でござるゆえ、御身のものと申さば御身のものじゃが、社寺仏閣の公事争い訴訟事は寺社奉行様御支配じゃ。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しんざえもんは　一休さんの　えらさに　かんしんして、わざわざ　じしゃぶぎょう　と　いう　たかい　やくめを　やめ、一休さんの　しんじゃに　なった　ひとでした。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
