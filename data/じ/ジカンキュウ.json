[
  {
    "uuid": "7fbb7d95-12c0-5059-aca9-9f0d34e2e072",
    "entry": "時間給",
    "reading": {
      "primary": "じかんきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hourly pay",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」三　義雄の英語教師は時間給で出るのだから、その受け持ち時間だけ行つたらいい。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　専門学校以上の教師は、原則として一校限りの専任とし、時間給などゝいふ制度を廃止して十分生活を保証し、学生と接触する機会を多く作らしめること。",
              "citation": {
                "source": "一国民としての希望",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいていは耕作期間だけの作男で、時間給になっている。",
              "citation": {
                "source": "コロラド通信",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シヅを呼びだして、いっしょに職安へ行ってもらったが、英語が話せないと、時間給のひどい雑役で追い使われることになるらしい。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「月給ぢやない、時間給ですよ。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼方は時間給だから、稼げば稼ぐ丈け余計取れる」「心当りがございますの？",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間給かけるその日働いた時間が、その日のお給料。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
