[
  {
    "uuid": "7e1bf765-9795-5922-b3e4-6fd1472d0a3b",
    "entry": "場内",
    "reading": {
      "primary": "じょうない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
