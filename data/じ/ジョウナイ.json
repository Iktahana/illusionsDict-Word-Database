    },
    "definitions": [
      {
        "index": 1,
        "gloss": "in-house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "黒板へ書いている数式が間違ったりすると学生が靴底でしゃりしゃりと床をこするので教場内に不思議な雑音が湧き上がる。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし二度目の最大動が来たときは一人残らず出てしまって場内はがらんとしてしまった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "場内の通風はあまり良好でないのか、傍聴席の空気は甚だ不純なようであった。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして十五回の終りに判定者がロスの方に勝利を授けたが、この判定に疑問があるというので場内が大混乱に陥ったということである。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もこんな事は美術とは何の関係もない事ではあるが、それでも感受性の鋭い型の観覧者に取っては、彼等が場内にはいって後に作品から受取る表象の同化異化作用に何らかの影響を及ぼさないものだろうか。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "場内は蒸暑さに茹だるようであった。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次耐らなくなって立ち上りキョロキョロ場内を見廻す。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝道場内　用意万端整えて白倉、悠然と進み出る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "場内は気が狂ったように男女が歓声をあげていました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "場内はビールの満が引かれ人々は五色の陽光に上気するのであった。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのたびに、黒いつめえりをつけた行員が矢のように場内を馳せまわった。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "太田ミサコは売あびせのために底値を入れた××新株の反撥を予想して買いあつめると、雑株安をねらって、引たたぬ××百貨店株を後場引値で、これを指名人に買わすとさっさと場内を引あげた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕間はあんた、場内の視聴を妾に貸してちょうだい。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "おりから驟雨のあとで場内の片すみには川水がピタピタあふれ込んでいた。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場内で、工人を慄えあがらし、えらばっている小山は、通りへ出ると顎が落ちて、燐くさく、芯が頼りなげに、ひょろ／＼していた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　まもなく、寄宿舎と工場内に大騒動が起った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとどよめきに沸き返りまたすーっと収まってゆく場内の推移が、なにか一つの長い音楽のなかで起ることのように私の心に写りはじめた。",
              "citation": {
                "source": "器楽的幻覚",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日この劇場前を通ったら、なるほど、すべての入り口が閉鎖され平生のにぎやかな粧飾が全部取り払われて、そうして中央の入り口の前に「場内改築並びに整理のために臨時休業」という立て札が立っている。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとともに場内は一時にざわめきだして、人々はひとりでに浮足になった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後は場内上を下への大混乱となって芝居はめちゃめちゃとなった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍浴場内に大の字に成ってへた張ったところ、三人して頭からガジャガジャ冷水の洗礼を見舞うとこ、たちまち家屋を震動せしむるウエーウエーの大声を連発する数回。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚ろいたのは場内の見物人。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで騒々しかった場内は急に水を打ったようになる。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "表飾りの景気から推せば、場内の広さも、一軒隣のアラビヤ式と銘打った競馬ぐらいはあろうと思うのに、筵囲いの廂合の路地へ入ったように狭くるしく薄暗い。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "株式市場内外の混雑を評して、火事場のようだとはいい得るかも知れない。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "既にして場内アナウンスの少女の声が、美しく神秘的である。",
              "citation": {
                "source": "星の劇場",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが終ると、場内にはにわかに黄昏の色が忍び込んで、鮮かな美しさだ。",
              "citation": {
                "source": "星の劇場",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "……極めて徐々に……徐々に……工場内に重なり合った一切の機械が眼醒めはじめる。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言いましたら、場内に笑声が湧きました。",
              "citation": {
                "source": "みみずく通信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老紳士が、かの女たちに話しかける声音は、場内で一番大きく響いたが、誰も聞き咎める様子もなかった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
