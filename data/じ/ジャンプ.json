        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ホップ、ステップ、エンド、ジャンプなんて飛び方でなくて、ほんのワンステップで、からりと春になってしまうのねえ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "超空間をジャンプして恒星間旅行を可能にする宇宙船や、立体映像の再生装置、電子銃、電子銃が噴き出す原子流を吸収してしまう力場防御壁と、ＳＦらしい道具建てはいくつも出てきます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらかじめリンクを仕込んでおけば、マウスのボタンの操作で、ある項目から一瞬に別の項目にジャンプできるのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "けどいくら何だって腕を取られれば転んでみせる、肩を入れられればジャンプして吹っ飛んでみる、挙げ句にねっころがったところに尻もちつかれて起き上がってこないんじゃ、目立つのは北尾の道化ぶりばっかりだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一二塁間突破をねらったヒットエンドランは、ライナーになって、ジャンプした二塁手にとられ、飛び出した一塁走者も刺されて、一瞬にしてチェンジになってしまった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎつぎと、飛び板ジャンプの絵がつながって出てくる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホップ・ステップ＆ジャンプ。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピンをもらった人は、ダブルクリックで該当のページにジャンプできる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈もう一人の西〉を生んだ古川享のＷＣＣＦ体験「おまえなあ、大きくジャンプしようというときに両手に荷物を持ってたら高く跳び上がれへんやろ」　長髪をかきながら、西が諭すような口ぶりで言った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来、前年比一〇パーセント程度だった売上高の伸びが、一九七四（昭和四十九）年には八〇パーセントを超え、一九七五年には、大きくジャンプした前年をさらに一〇〇パーセント以上上回った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡部自身にとっても初めて使い込む一六ビット機となったマルチ16には、「八ビットからのジャンプによって確実に世代を画したマシン」との印象があった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまざまな電子機器がデジタル化されはじめる中で、松本にはアナログの世界からいつかはデジタルにジャンプしない限り、エレクトロニクスの先端から置いていかれるとの思いが募っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "モオリスさんが、大きいパイプをくわえて、ピアノを彈いている姿やペットにジャンプを教えてくれた、かっと照りつける夏の日の思い出が、ペットの頭に浮かんで來た。",
              "citation": {
                "source": "美しい犬",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに後の面々もかぎつけて柄にないジャンプを試みる。",
              "citation": {
                "source": "五色温泉スキー日記",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "制動法も朽木の倒れ方もジャンプには応用できない。",
              "citation": {
                "source": "五色温泉スキー日記",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャンプ場なんか、まるでウィンブルドンの中央テニス・コウトの観がある。",
              "citation": {
                "source": "踊る地平線",
                "author": "白い謝肉祭",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は元来インターミドルで優勝したジャンプの選手で、又、野球も選手、投手であった。",
              "citation": {
                "source": "二十一",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "スポーツでボクがやったのはジャンプ――三段跳び、走高跳び――水泳、それから柔道、これは割に強くて段つきになったが、立業では敗けたことがない。",
              "citation": {
                "source": "スポーツ・文学・政治",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャンプ競技は特別そうで、自分の限界へくると、バアを一センチあげても、一尺あがったような恐怖を感じてしまうものだ。",
              "citation": {
                "source": "安吾巷談",
                "author": "世界新記録病",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのころの中学生は強豪ぞろいで、短距離の高木、ジャンプの織田、南部、いずれも中学生にして日本の第一人者であった。",
              "citation": {
                "source": "安吾巷談",
                "author": "世界新記録病",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤城山のシャンツェで、諾威の選手や日本の選手が、秩父、高松両殿下にジャンプをお目にかけた時、ある新聞が「アプローチ君八十米を飛ぶ」という見出しで記事を載せた。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "テレマーク、クリスチャニア、ジャンプ・ストップ……近藤リーダーは時おり注意を与えた。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "10　セオリー・マニア　主としてバア、カフェー等にてスキーのセオリーを論じ、時にジャンプ・ストップを実演して隣の客の卓子を倒し、撲られることあり。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっと、ジャンプ・クリスチャニア。",
              "citation": {
                "source": "大雪山二題",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の傾きがきつくなり、ついにスキージャンプ台のようになった。",
              "citation": {
                "source": "もしも世界",
                "author": "THE WORLDS OF IF",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために私有財産の否定と国体の否定との距離を出来るだけ大きくし、この距離をジャンプすることを転向と称して奨励する処の、極めて国民道徳的な法律となって行きつつあるのである。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャンプに臨んでしゃがんではいるが、実際に飛び出してくることは決してないのだ。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺は一度マイクを握ると離さない方だからなあ」　三人が楽しく歓談している一方、俊文は一人部屋の隅で『ヤングジャンプ』を黙々と読み耽っていた。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
