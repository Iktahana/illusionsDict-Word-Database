        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "友達の住所録も、整理した。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これはパリの人名住所録ですが」　と彼は云いました。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "オレが日常的にもっとも長く使っているマシンのハードディスクには、かなりの分量の住所録が収まっている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈住所録〉作りに、不便を感じたのだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "とネットスケープの〈住所録〉機能は、かなり充実している。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貴女ぐらい住所の変る人はないわね、私の住所録を汚して行くのはあんた一人よ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貴女ぐらいよく住所の変る人ないわね、私の住所録を汚して行くのはあんた一人よ。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、左から畳み込んである別の紙に住所録がついてゐる。",
              "citation": {
                "source": "ゼンマイの戯れ（映画脚本）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりつく島がないし、それをことわる理由もないので、私は古い手帳や住所録の類を取り出してリストを作りはじめた。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも住所録や手帳から書き拔いてみると二十名ばかりあつた。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも持ち歩く手帳の住所録を見て、封筒の宛名を書いた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは、部屋に置いてある手帳やノートに、書き写しておくとか」「いつも持って歩く住所録や電話帳のようなものは？",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "順子が人から受け取った手紙や葉書、それに住所録などは、優子が持っている。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「住所録にはオードリ地区が複数あります。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁護士の住所録は捨ててないでしょうね」「まさか。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞社へ私が電話すれば、医者住所録で調べてくれます。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
