    "definitions": [
      {
        "index": 1,
        "gloss": "suicide by drowning",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうして、自分がなぜ入水したのか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九　入水者はきっと草履や下駄をきれいに脱ぎそろえてから投身する。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "心中もその宿を出て、近所の海岸から入水するか、山や森へ入り込んで劇薬自殺を企てるたぐいは、旅館に迷惑をあたえる程度も比較的に軽いが、自分たちの座敷を最後の舞台に使用されると、旅館は少からぬ迷惑を蒙ることになる。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し彼女は最初からの蛇体であるのか、あるひは入水の後に龍蛇と変じたのか、その議論は区々で遂に決着しなかつた。",
              "citation": {
                "source": "梟娘の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は、この帯はお店のお友達から借りている帯やから、と言って、帯をほどき、畳んで岩の上に置き、自分もマントを脱ぎ、同じ所に置いて、一緒に入水しました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれのスパルタを汚すよりは、錨をからだに巻きつけて入水したいものだとさえ思っている。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "もういちど入水をやり直さなければならない。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "師走、酷寒の夜半、女はコオトを着たまま、私もマントを脱がずに、入水した。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときの、入水の場所が、江の島であった。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちどは入水して失敗した。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が抱上げると、彼女は、寒天質の中に植物の種子を入れたような、草入水晶に似た瞳をむけて、甘えた声で訴えるのであった。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年はお蓮といえりし渠の姉が、少き時配偶を誤りたるため、放蕩にして軽薄なる、その夫判事なにがしのために虐遇され、精神的に殺されて入水して果てたりし、一条の惨話を物語りつ。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "以後、娘の村では、娘の入水の日を娘の命日にして赤飯を蒸し山へ持ち行きて小沼に投げ込む。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそう思いつくと、入水する人のすると云うように、穿いていた草履を水際に並べて置いて、西安寺と云う寺のある方へ往ってしまった。",
              "citation": {
                "source": "鮭の祟",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新次郎は別に怪我もなかったが、お節が刃物をたずさえて狂い出したのを見れば、彼女が夫の久兵衛を殺害して、自分も入水したものと認めるのほかは無い。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして一旦は納まったものの、お節の入水も久兵衛の変死も近所ではみな知っているのであるから、人の口に戸は立てられぬという譬えの通りで、その噂はそれからそれへと伝わって、神田の吉五郎の耳にもはいった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐渡へ渡つた母は、舟で入水したうば竹に離れて、粟の鳥を逐はせられる。",
              "citation": {
                "source": "歴史其儘と歴史離れ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "石浦に往ったものは、安寿の入水のことを聞いて来た。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "安寿が亡きあとはねんごろに弔われ、また入水した沼の畔には尼寺が立つことになった。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今ヲ去ル千八百余年前日本武尊御東征ノ砌海上浪高ク激シキ風雨ニ遭セラレルヤ、妃｜弟橘媛命ハ竜神ニ祷リヲ捧ゲ、身ヲ以テ尊ニ代ラントシテ入水シ給ヒシ為御安行ヲ得タリト云フ。",
              "citation": {
                "source": "或るハイカーの記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "只｜看る、宮は行き行きて生茂る柳の暗きに分入りたる、入水の覚悟に極れりと、貫一は必死の声を搾りて連に呼べば、咳入り咳入り数口の咯血、斑爛として地に委ちたり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋の袂には血に染みた鎌が捨ててあったばかりでなく、お園の袷と襦袢の袖にも血のあとがにじんでいるのを見ると、かれはまず伊八を殺害し、それからここへ来て入水したものと察せられた。",
              "citation": {
                "source": "真鬼偽鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "入水いたした者の懐中から抜けて浮きあがったものに相違ないぞ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「女持ちのこのふた品じゃ、かような品が浮いているからには、昨夜のうちに入水した女があったに相違ない。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の濠をさらえとはなにゆえじゃ」「下の濠にこのふた品が浮いていたゆえ、入水の者はこの水底に沈んでおると見るはおしろうと考え、あのとおり水門から今もなおこちらへ濠水が流れ込んでおりますからには、このふた品もまた上から流れてきたものかもしれませぬ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "――普通に考えれば、恋を入れられなかったために、思いをよせている女の持ちものを懐中して、入水したとも考えて考えられないことはないのでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしんば、腹切るすべも、自刃するすべも知らないための入水にしたところで、大小差したまま投身するというのは、いかにも筋が通らないのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやらそのぶんでは、まず十中八、九――」「乱心ざたの入水か！",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてや、二本差す身でござります、入水などと恥多い死に方をするはずござりませぬ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによると、お静への打擲折檻はむろんのことににらんだとおりで、今までも近所かいわいに評判なほどでしたが、ことに浪人者の不審なる入水以後は、どうしたことか毎夜五つから四つまでの時刻にいっそう折檻の度が強まって、ひいひいと痛苦に泣き叫ぶお静の悲鳴が近所にもしばしば聞こえたということでありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
