    "definitions": [
      {
        "index": 1,
        "gloss": "GI (soldier in the US Army)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ＧＩはキャア／＼喚声をあげ、女の子のハダをなでたり、一心同体のうちとけぶりを現すが、日本人の観客は拍手ひとつ送らないのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "ストリップ罵倒",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＧＩだけ人種がちがうというわけはない。",
              "citation": {
                "source": "安吾巷談",
                "author": "ストリップ罵倒",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人だって酔っ払えばＧＩなみなハデな喚声をあげる仁もある。",
              "citation": {
                "source": "安吾巷談",
                "author": "ストリップ罵倒",
                "note": "青空文庫"
              }
            },
            {
              "text": "素質がないわけではないのだから、こっちのやり方ひとつで、日本人をＧＩなみの見物態度に誘導できないはずはない。",
              "citation": {
                "source": "安吾巷談",
                "author": "ストリップ罵倒",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＧＩがもう一人車内を睨めながら釣革でぶらんこをしてゐる。",
              "citation": {
                "source": "おばあさん",
                "author": "ささきふさ",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ釣革でぶらんこをしてゐるＧＩは私の近づくのを見ると、不意に手と體躯とでアーチをつくつてくれた。",
              "citation": {
                "source": "おばあさん",
                "author": "ささきふさ",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本にいるＧＩが淋しくなったりトラブルに陥ったりしたら、君はいい相談相手になるだろう」と笑っていたが、数日後、仕事が変って当分あえないから……と挨拶したあげく「僕はこの間いったことを取消す。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういう訳か、サムはほかのＧＩにくらべて、事務所勤務の度数が多かった。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしコレヒドールではＧＩとして戦った。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「〈変ったこと〉というのはどういう変ったことの〈こと〉ですか」「武器を持った日本のＧＩがお前のホームへはいりこまなかったか」「ノオ」　ジープがとまるたびに海兵隊がふえて十人ぐらいになり、それがみないつでも射ちだせるように自動小銃を腰だめにしている。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "電気冷蔵庫も、電気洗濯機も……それから、ＧＩキャンプで働いていた、よく馴れたメードも一人頼んであります。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと見られる洋装の女のひとが、目の青い黒毛の子供を連れ、銀座のしかるべき四つ角に立っていて、ＧＩが通りかかると、そっと子供を前へおしやる。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供は心得て、小走りに走って行き、ＧＩのズボンにつかまって、「パパ」と、せいいっぱいな声で呼ぶ。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "どのＧＩも、身におぼえがあるので、ぎょっとして、早いとこ、何ドルかの紙幣を子供の手に握らせ、後も見ずに逃げて行く。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族連れのＧＩが、窓ガラス越しにカメラをむけて、しきりにシャッターをきっている。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争で多くのＧＩたちがハワイになじみ、戦後、特に一九五〇年代に入ると、ハワイはいっきょに、普通の人たちのための観光地になっていったのね。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、一九四六年雇用法が成立し、四四年にできたＧＩ憲章で除隊兵が大学に入ったために、一九四六年はじめには失業者の数は無視してしまってよいほどのミニマムで、好況だった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "国内での異文化の交流がおこり、戦場でもＧＩたちのあいだにおなじことがおこった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、反戦を目的としたフォークソングは、まずなによりもさきに、アメリカのＧＩたちにむかってうたわれた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＧＩたちに反戦をうたいかけることを無報酬の仕事にしている人たちがアメリカにはたくさんいて、このなかには、バーバラ・ガースン、フィル・オクス、ピート・シーガー、ジョー・マクドナルド、ドナルド・ダンカンたちも含まれている。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どのようにしてＧＩたちに反戦をうたいかけるかというと、まず基地のある町まで、でかけていく。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "路上、街頭で、ＧＩたちにチラシをくばる。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＧＩたちは常におかねがないからそのようなブルースに同化できるし、うたいおわってからの語りかけで、おかねのないつらさをジョークにしてＧＩたちを笑わせようという意図があるからだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＧＩのヒロイズムをくすぐる。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが終ると、軍人として最も正しい態度についていささか感情的な美文でうったえた歌をはなち、ＧＩの気分を盛り立てる。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "テキサスとかカリフォルニアにはメキシコ系アメリカ人のＧＩが多いので、メキシコがひんぱんに登場する。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "地理的にも親近感があり、ＧＩたちの気分をつなぐために有利なのだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞きなれたメロディに、もと歌からは想像もつかないような歌詞をつけることにより、新しい価値の世界が自分たちの目の前にひらけた感じを、ＧＩたちにあたえるからだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、終戦直後、ＧＩたちの、おこぼれを頂戴して飲んだ頃は、うまいなあと思った。",
              "citation": {
                "source": "清涼飲料",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
