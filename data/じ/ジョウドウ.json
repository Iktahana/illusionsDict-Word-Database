        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "normal practice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "気の違って居る者に人生の順序や常道を言った処で始まらない。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰もがいつの間にか行く常道、その平凡こそなまじ一個人の計いより何程かまさった真理を包含しているものなのだろうということを自分自身に感得した智子であった。",
              "citation": {
                "source": "明暗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中に詠み入れる内容も變つて來たが、第一自分自身の調子どころか二千年來歌の常道として通つて來た五七五七七の調子をも押し破つて歌ひ出したのであつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "島三題",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜があけると近所の人々は寺へ行つたり無常道具を買ひに行つたり、他村の姻戚への知らせに行つたりして家には近所の女房が二三｜人義理をいひに來て居た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "男女共中學程度終業ヲ以テ國民タル常道常識ヲ教育セラルル者。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しそれは決して性的任務の常道ではない。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中に寮内を歩くときは、舎監や当直教師の注意をひかぬよう、はだしで歩くのが常道だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのわけは、手口が同じと思われること、及び同一場所を利用するのは犯人の常道であること（その自信は犯罪淫楽性による）、別の犯人による犯罪現場の暗合は殆んど生ぜざるものであることによる。",
              "citation": {
                "source": "探偵小説と犯罪事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつがまた、なかなか常道を踏まない奴なんです」　市川の話になると、岡見は我を忘れて膝を乗出すようなところがあった。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "よき子であれ、よき夫（或は妻）であれ、よき父であれ、それ以外によき人間となる常道はない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　　　　（昭和十一年十月十二日午前十時記す）――所詮、私は私の道に精進するより外はないのである、たとへ、その道は常道でなくとも、また、難道であつても、何であつても、私は私の道を行かざるを得ないのである。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そこでは政治の金属的常道が交通遮断されるということを忘れてはならぬのである。",
              "citation": {
                "source": "挙国一致体制と国民生活",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し今日の日本では割合そういう傍白が芝居の常道になっていない。",
              "citation": {
                "source": "一九三七年を送る日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "闘牛は、言うまでもなく、一時この国に権力をふるったアラビヤ人の影響で、十六世紀の初期までは、勇猛な一人の騎士が槍を持って悍馬に跨がり、おなじく勇猛なる牡牛に単身抗争してこれを斃すのがその常道だった。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」氷峰は例の芥子坊主の樣な、そしてまた竹の筒の樣な顏に苦笑ひをしながら、「來月一日から、また、今度は通常道會が招集されるので、十勝から出て來るあの議員を捉へて、いよ／＼泣きついて見ようかとも思うてをる??然しそれには、雜誌が全く僕の實權内にある樣になつてゐなければ困るから、なア。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、十一月一日から、通常道會が開らかれた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "」氷峰は例の芥子坊主の樣な、そしてまた竹の筒の樣な顏に苦笑ひをしながら、「來月一日から、また、今度は通常道會が招集されるので、十勝から出て來るあの議員を捉へて、いよ／＼泣きついて見ようかとも思うてをる――然しそれには、雜誌が全く僕の實權内にある樣になつてゐなければ困るから、なア。",
              "citation": {
                "source": "――泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　読者諸君、これがいつもの私の書くような小説だったら、私は探偵小説の常道として次のように最後の章をむすぶだろう。",
              "citation": {
                "source": "途上の犯人",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "江蘇の揚州（今の淮揚道江都縣）とか、蘇州（今の蘇常道呉縣）とかが、日本船出入の要津であつた。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "又恐愚民不知侍養常道。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃、天下に、密々と行われておりまする、幕府衰亡の取沙汰、これを、史上より見ましても、三百年を経れば、一新するのが、常道となっておりまする」「その論もよいが、わしの、只今の――」「斉彬公の仰せの如く、家中に党を立てて、争う機ではござりませぬ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「道道非常道、天天小有天」――そう云う洒落さえあると云う事だから、その贔屓も一方ならず、御念が入っているのに違いない。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "道の道とすべきは常の道にあらずとやら、武士の道を武士道と名付ける間はまだ武士の守るべき常道を穿ったものではあるまい。",
              "citation": {
                "source": "平民道",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日この武士の階級が廃せらるるといえども、根本のいわゆる常道は決して失わせることなく広く施されて万民これを行えばこれが少数の武士階級に行わるるより遥に有力な、かつ有益な道徳となるに違いはない。",
              "citation": {
                "source": "平民道",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "キッドが、その種族の偉大なる原因は、平民的なる日常道徳を有してこれを行うことと、勤勉にして、真理を愛し、かつ正直なるとにありと主張するは正当の説にして、またデモランがこれらを以て、アングロ、サクソン人種の雄大なる所以の主質なりと説明せることも、また大にその理あり。",
              "citation": {
                "source": "我が教育の欠陥",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
