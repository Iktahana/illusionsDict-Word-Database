[
  {
    "uuid": "fdced00a-8b81-574a-b18e-d2d957916d3c",
    "entry": "常道",
    "reading": {
      "primary": "じょうどう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
