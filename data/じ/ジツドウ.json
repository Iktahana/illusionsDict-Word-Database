  {
    "uuid": "ed78a0d6-70c5-597d-898b-cc963451935c",
    "entry": "実動",
    "reading": {
      "primary": "じつどう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞",
        "形容詞-語幹"
      ],
      "ctype": null,
