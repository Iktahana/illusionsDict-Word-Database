        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "第一には、この「透明人間」という訳語が原名の「インヴィジブル・マン」（不可視人間）に相当していないではないかという疑いであった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレカラ　花タチハ　ジブンタチノ　スガタヲ　ナガメアヒ、ジブンタチカラ　ナガレデル　ニホヒヲバ　カギアツテ、ジブンタチガ　ミナ　オナジヤウニ　キイロイ　キモノヲ　キテ　ヲリ、ホカノ　木ヤ　クサニ　マケナイホド　ウツクシイノヲ　シツテ　イツソウ　ヨロコビアヒマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "コレハ　テツキリ、ジブンヲ　コロシテ　カネヲ　トルノダナト　オモヒマシタ。",
              "citation": {
                "source": "カゴカキ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "カタツムリガ　ツノヲ　フツテルノヲ　ミテ　ヰルト、王サマハ、子ドモノ　ジブン、何ダカ、カタツムリノ　ウタヲ　ヨク　ウタツタ　コトヲ　オモヒダシマシタ。",
              "citation": {
                "source": "カタツムリノ　ウタ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレヲ　キイタ　コノ　マヅシイ　ヲトコノ　ヒトハ、「ヨシ、ソレデハ　ジブンモ　センサウノ　アル　トコロヘ　イツテ、リツパナ　テガラヲ　タテ　タイシヨウニ　ナラウ」ト　ヒトリゴトヲ　イヒマシタ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジブンガ　リツパナ　タイシヨウニ　ナツテ、ムネニ　ヅラリト　クンシヨウヲ　ナラベ、ピカピカ　ヒカル　ケンヲ　モツテ、ウマノ　上ニ　ソリカヘツテ　ヰル　ユメヲ　ミテ　ヰルト、ヤガテ　ヨガ　アケテ　アサニ　ナリマシタ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "コレサヘ　アレバ　ジブンハ　テガラヲ　タテル　コトガ　デキル。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジブンハ　ラツパシユニ　ナラウ」ト　タイヘン　ヨロコビマシタ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コドモタチヤ、コノ　バシヤハネ、オマエタチガ　マダ　ウマレナカツタ　ジブン、マダ　ジドウシヤト　イフ　モノガ　ナカツタ　トキ、ムラカラ　マチノ　テイシヤバマデ　マイニチ　カヨツタ　モノダヨ。",
              "citation": {
                "source": "フルイ　バシヤ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "カイドウニ　ソツタ　イエイエノ　ヒトタチハ、ムカシ　ジブンタチノ　ノツタ　バシヤガ　コドモタチニ　ヒカレテ　イクノヲ　ミルト、シゴトヲ　ヤメテ　オモテニ　デテ、バシヤヲ　ミオクルノデ　アリマシタ。",
              "citation": {
                "source": "フルイ　バシヤ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンザシヲ　ジブンノ　モノニ　シタイト　オモヒマシタ。",
              "citation": {
                "source": "カンザシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジブンデ　オヒロヒナサイ」　ヲンナノ　コハ　コマツテ　シマヒマシタ。",
              "citation": {
                "source": "カンザシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミズハ　フカイノデ　トテモ　ジブンデ　ヒロフ　コトハ　デキマセン。",
              "citation": {
                "source": "カンザシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソシテ、ソノ　トキ、ジブンノ　アタマニハ　カンザシハ　サセナイ　コトガ　ハジメテ　ワカリマシタ。",
              "citation": {
                "source": "カンザシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソシテ　マタ、ホカノ　ヒトニハ　トウトイ　モノデ　アツテモ、ジブンニハ　チツトモ　トウトクナイ　コトモ　アルノダ、ト　イフ　コトガ　ワカリマシタ。",
              "citation": {
                "source": "カンザシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポストハ　ウシロヲ　ミルト、ソコニ、ホントウニ　ブカツカウナ　ジブンノ　カゲガ　アリマシタノデ　アカク　ナリマシタ。",
              "citation": {
                "source": "タレノ　カゲ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、私に、王さまはセレンジブさまというお名前で、世界じゅうで一番えらくて、一番の金持だと、話して聞かせました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "セレンジブ王の御殿は、大へんりっぱなものでした。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてすぐに、カリフさまの御殿へ行って、手紙と、セレンジブ王からいただいたみやげ物とを、さし上げました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、「さあ、シンドバットや、セレンジブ王が、どんなにお金持で、どんなにりっぱであるか、話してごらん。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "セレンジブ王は、いつも大きな象に乗っておいでになりますが、おそばには、金色の着物を着た千人の騎兵が、つかえているのでございます。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは、セレンジブ王に、手紙と、おくり物とを、さし上げたいと思うのだが、お前、持って行ってくれまいか。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、おだやかな航海をつづけた後、セレンジブの島へつきました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "第２図　支那四川産橙色仰鼻猴　猴はなかなか多種だが熱帯と亜熱帯地本位のもの故、欧州にはただ※爾たるジブラルタルにアフリカに多いマカクス・イヌウスとて日本猴に酷似しながら全く尾のない猴が住んでいたが、十年ほど前流行病で全滅した。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "註にいわく、ジブラルタルでも猴の屍を見た事なしというと。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "見果てぬ夢過ぎし日のしづこころなき口笛は日もすがら葦の片葉の鳴るごとく、ジブシイの晝のゆめにも顫ふらん。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "マアー、コトモアロウニ、ジブンタチノ死ンダオ母ッチャニアゲタモノヲ、君チャンヤ弟ヤ妹ガ、ムチウニナッテ、タベテイルデハナイノ。",
              "citation": {
                "source": "テガミ",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
