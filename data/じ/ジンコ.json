[
  {
    "uuid": "bd9b0588-c930-515b-87ff-82cdf877798e",
    "entry": "人虎",
    "reading": {
      "primary": "じんこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
