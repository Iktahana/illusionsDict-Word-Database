        "examples": {
          "standard": [
            {
              "text": "映画の爆破シーンで、カウントダウンを刻む時限装置がアップで映し出された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "工場の機械には、一定時間が経過すると自動的に停止する時限装置が組み込まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は部屋の照明に時限装置を取り付け、不在時でも防犯対策を徹底している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "◯時限装置らしきものも落ちていた。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "目的地についたとき共軛回転弾が活動するようにと、時限装置を合わせるぞといってやったじゃないか。",
              "citation": {
                "source": "共軛回転弾",
                "author": "――金博士シリーズ・11――",
                "note": "青空文庫"
              }
            }
          ]
        }
