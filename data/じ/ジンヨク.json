        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人間の住してゐる世俗の國 civitas terrenna は人欲の私に本づいて立てられてゐる。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "社會問題は資本家も勞動者も皆人欲を主張するより起る。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月ばかり前の夜、同じこの歌枕で会った時、蝶吉はそれとはなく、頻に子が一人欲しくはないかといったのを、気にも留めないで聞棄にしたが、松の鮨の毒口を、ここで聞正せば実際で、梓は思い懸けず、且つ驚き且つ呆れ、あわれにも情なくも思ったのである。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そんなことを思ふと、彼は妻でなくとも好いせめて恋人なり一人欲しいと思つた。",
              "citation": {
                "source": "悲しめる顔",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の子が一人欲しいようなことを言ってるけれど、やらずかやるまいか、まアもっと先へ寄ってからのことだ。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「男の子が一人欲しい。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの林羅山の如きも、既に煙癖があったと見えて、その文集の中に佗波古、希施婁に関する文章が載っており、またその「莨※文」の中に、拙者性癖有レ時吸レ之、若而人欲レ停レ之未レ能、聊因循至レ今、唯｜暫代レ酒当レ茶｜而已歟。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの林羅山の如きも、既に煙癖があったと見えて、その文集の中に佗波古、希施婁に関する文章が載っており、またその「莨※文」の中に、拙者性癖有時吸之、若而人欲停之未能、聊因循至今、唯｜暫代酒当茶｜而已歟。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "道心は人心のその正を得たる心と王陽明は説いたが、正を得るとは、人欲のまざらないところで、つまらぬ感情のなきをいうところであると思う。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし知つてゐるが故に人欲を煽り己の爲めにするものありとすれば是は免すべからざるものである。",
              "citation": {
                "source": "安藤昌益",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたみたいな娘が一人欲しいなんて云ふとつたよ、うちの婆さん……。",
              "citation": {
                "source": "沢氏の二人娘",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人欲しい」と言うた母のことあげの過ちから、蛇（又は野獣）の子が授かる。",
              "citation": {
                "source": "小栗外伝（餓鬼阿弥蘇生譚の二）",
                "author": "魂と姿との関係",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに此情といふ者は、其大源は肉體欲即ち人欲に根ざす者なりと雖ども、夙に靈性欲即ち物欲と混合し易くして、飮食男女安逸より竟に權勢の欲、聲色の欲、勝克の欲、錢貨の欲と相混同し以て一種の情操偏癖となることあり。",
              "citation": {
                "source": "情智關係論",
                "author": "西周",
                "note": "青空文庫"
              }
            },
            {
              "text": "※説自註無欲故靜、程伯氏因此有天理人欲之説。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "以身我害心我、人欲也。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "身我を以て心我を害す、人欲なり。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "その面はまた幽霊に向く人相じゃないよ、浅草の化物屋敷で、大入道の役者を一人欲しいって言って来たぜ」「チェッ」「怒るな八、近江屋へ真っ直ぐに案内しろ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "幽霊にされた女",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「身内の者で、力になる用心棒が一人欲しいと思ひませんか。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "江戸の夜光石",
                "note": "青空文庫"
              }
            },
            {
              "text": "御身の望むところ他の二人欲せず。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ごろ、ご近習の気のきいたのが一人欲しいようなことを仰っしゃっていたから、御辺の運がよければ、多分、採用になると思うがね」　すこぶる頼りない口吻だが、ともかく、次の日、高はその王晋卿を訪ねてみた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "くれぐれ、人欲に迷うなよ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
