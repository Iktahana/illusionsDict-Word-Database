        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夫人乳母を伴れて入る。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔雀の羽根の扇や人乳を飲んだ豚の仔の料理さえそれらの人びとにはそれだけでは決して満足を与えないのである。",
              "citation": {
                "source": "十本の針",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉱毒婦人乳汁欠乏之儀、御すくひ被下度候事」　　　四十日の入獄　直訴の翌年、明治三十五年の夏、翁は官吏侮辱罪で四十日の軽禁錮に処せられた。",
              "citation": {
                "source": "臨終の田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時頃から、二時間置きに人乳を五｜瓦ずつ与えることになった。",
              "citation": {
                "source": "生と死との記録",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方から、堯には人乳十瓦ずつ与えられるようになった。",
              "citation": {
                "source": "生と死との記録",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてたとえ十瓦の人乳でも落ち附いてゆけば非常な幸いであった。",
              "citation": {
                "source": "生と死との記録",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "十瓦の人乳を飲むのに、長くかかるようになった。",
              "citation": {
                "source": "生と死との記録",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "十瓦の人乳を一度に飲めないで中途で止すようになった。",
              "citation": {
                "source": "生と死との記録",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、……やはり人乳や食塩水を時々与えなければならなかった。",
              "citation": {
                "source": "生と死との記録",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝――熱八度二分、脈搏百二十八、呼吸四十四、　午――熱八度四分、脈搏百三十六、呼吸四十二、　夕――熱九度四分、脈搏百三十四、呼吸五十二、　夜――熱九度二分、脈搏百四十、呼吸四十五、　尿二回、便五回、嘔気二回、カンフル注射二回、腸注入一回、人乳五瓦三回、十瓦三回。",
              "citation": {
                "source": "生と死との記録",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそっと立って行って、氷嚢の氷を取り換えたり、人乳十瓦はいったコップを持って来たりした。",
              "citation": {
                "source": "生と死との記録",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に堯の病室用の氷や人乳や薬がはいっていた。",
              "citation": {
                "source": "生と死との記録",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が三時に与えた人乳十瓦を、堯はよく飲んでくれた。",
              "citation": {
                "source": "生と死との記録",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "便二回、嘔気一回、カンフル三回、滋養腸注一回、人乳十瓦二回。",
              "citation": {
                "source": "生と死との記録",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九歳の若い奥さんは、夫に離れ、家人に離れ、みどり児からも引き離されて、ただ一人乳の張りに悩んでいた。",
              "citation": {
                "source": "『団栗』のことなど",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何分此上とも御願申上置候草々」　そこで筆をおいたが、まだ一言も老妻のことに触れなかったのに気づいて、「二日、兎角失礼も多し、御病後折角御大切に、鉱毒婦人乳汁欠乏之儀御すくい被下度候事」　と書き添えた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
