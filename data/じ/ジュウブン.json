  {
    "uuid": "25dd08d8-ba62-509a-baf6-23780bfade81",
    "entry": "従文",
    "reading": {
      "primary": "じゅうぶん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "subordinate clause",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "既而意有所決、譲産於弟、専従文学。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供は噛み取った煎餅の破片をじゅうぶんに咀嚼して咽喉へきれいに嚥み下してから次の端を噛み取ることにかかる。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、ナイチンゲールは、お礼を申しあげて、ごほうびは、もうじゅうぶんいただきました、と申しました。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうに、ごほうびは、それでじゅうぶんでございます」　そう言うと、またまた、人の心をうっとりさせる、美しい、あまい声で、うたいました。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを影はまたじゅうぶんに見ぬくことができました。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこはとてもすてきな場所で、お日さまもよくあたり、空気もじゅうぶんにありました。",
              "citation": {
                "source": "モミの木",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、カイは、自分の知っていることは、まだまだじゅうぶんではないような気がしました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまでは、からだも、じゅうぶんに休まりました。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして準備もじゅうぶんにして、自分こそ、お姫さまをお嫁さんにもらうことができるものと、思いこんでいました。",
              "citation": {
                "source": "とびくらべ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きっかけなんて、じゅうぶんありますよ」「あんまり、そばへ寄らないでくださいな」と、靴下どめは言いました。",
              "citation": {
                "source": "カラー",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまたなんどみてもそこで行なわれている細かい仕事はじゅうぶんわれわれを楽しませてくれたのである。",
              "citation": {
                "source": "空気ポンプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人たちは、あまり時間がないし、もうみんなじゅうぶん別れを惜しんだのだから、鐘供養はしなくてもいいだろう、といった。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今晩じゅうぶん懽を尽しましょう、明日はまたどんなさしさわりが起らないともかぎりませんからね」　そこで僮子を呼んで言った。",
              "citation": {
                "source": "嬌娜",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは彼が後甲板で、きのう、かの幻影が現われた場所をじっと見入っているのを見たので、またどうかするのではないかとじゅうぶん覚悟していたが、別に何事も起こらなかった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "海豹の貯蔵のなかに臥ていれば、春まではじゅうぶん生きてゆかれる。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "明朝出発することが出来そうな見込みはじゅうぶんである。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああ、じゅうぶん、じゅうぶんです。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "波止場と建物のあいだの水路は、流れが急であったから、重くなった外套だけが残って、人間の方は脱げて川へ引き込まれた、そんな考えもじゅうぶん成り立つ。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの男、インド人にはじゅうぶん金を払って部屋を借りているので、僕の秘密はその館のなかから外へ漏れないというわけです。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "辺りに不審者がないかどうかも、じゅうぶん注意願います。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "出世に必要な知性はじゅうぶんお持ちだ。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴は黒い僧服をまとって乗り込み、箱のなかにじゅうぶんな金を入れてて、それで竜骨から大檣までまるごと買収できる。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゅうぶん見せていただきました、ストーナさん。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが返事が来て、次の日曜に来てくれればすぐにでも新規に採用する、見てくれさえじゅうぶんなら、と言うのです。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから申し出るのは君の能力に比してじゅうぶんと言えないが、モウソンのと比べれば光と陰。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "選考などせずともじゅうぶんだ。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実に関して正確たるのが本分であるのに、この頃の病気で揺らいでおり、このささいな出来事からも、友人は本調子からまだほど遠いことがじゅうぶんわかる。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですがその間がみなじゅうぶんとは言い難いため、ご覧ください、あとの男が『時の』と『分前』のあいだに『十五』を押し込んでいます。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上のことはじゅうぶん明白ですが、いまだぼんやりとしたところも多々あります。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この事件における君たちのあれこれはじゅうぶん判然としている。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
