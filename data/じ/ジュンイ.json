[
  {
    "uuid": "b1aa4987-a680-575b-a7c9-ff35ce7e90ae",
    "entry": "准尉",
    "reading": {
      "primary": "じゅんい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
