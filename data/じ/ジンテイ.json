      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "personal appearance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし人体に感ずる暑さは必ずしも寒暖計の示度ばかりでは分らぬ。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人体諸機関の活動を支配する脳神経の作用は別として、人間の五体殊に手足のごときものを力学的に見ればただ複雑な槓杆の組み合せだと云うことも出来る。",
              "citation": {
                "source": "相撲と力学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は医科大学生Ｆ兄弟の宅へ招ばれ、素晴らしく大きなクリスマス・ツリーの下で御馳走になり乍ら、医科大学の教室でつくるツリーへかける飾付けは、人間の心臓や肺、そのあらゆる人体諸臓器の形をボール紙で造らえて色彩をつけたものだという話など聞き夜を更かしました。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "地球の物理を明らかにしないで地震や火山の現象のみの研究をするのは、事によると、人体の生理を明らかにせずして単に皮膚の吹出物だけを研究しようとするようなものかもしれない。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人体の周囲の空間が大きいせいかもしれない。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人の説によると、人体に適度な弱い電流を通し、これを鋭敏な電流計に接続しておくと、その人の心の状態によって電流の強さが変り電流計に感じる。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隧道内の空気中にはレールや機関の摩擦のために生ずる微細な鉄粉がかなりに浮游しているが、これは案外人体を害わないそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "屍体とＸ光線　生きている人体の腹部をＸ光線で照らし写真を撮っても胃や腸を識別する事が出来ぬが、死後間もなく写して見ると明らかにこれらの臓腑の所在がわかる。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに人体や湿土中における該菌の寿命は数週ないし数月にもわたるという。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年一月二十七日『東京朝日新聞』）　　　　　　　　　六十二　　　　　　迅速なるＸ線写真　従来Ｘ線で人体の内部などを写真するに当って一つの欠点は照射時間の長い事である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台に噛ぶり付いて瞬きせず仲蔵に見入って居る老いさらばえた浪人体の老武士がある。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "人体の解剖学的構造は二千年前の先祖とほとんど同じでも人間の思想は決して同じところにとどまっていないのである。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくしかしそれにしてもと、あんまりお帽子の菱がたが神経質にまあ一寸詩人のやうに鋭く尖っていささかご人体にかゝはりますが、）（えい、畜生まだ何か云ってやがる。",
              "citation": {
                "source": "電車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず心（mind, animus or mens）は他の学者の説くごとく人体の調和原理でもなく生命原理でもなく、ちょうど頭や足が人体の部分であると同様の意味において人体の「部分」であるに過ぎない。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同様に精神（soul, anima）もやはり人体の一部で全体の調和ではない。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれは人体に含まれている元素であって、全体の調和原理でもなんでもない。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "火山を人体の病気にたとえた後に、物の大きさの相対性に論及し、何物も全和に対しては無に等しいと宣言している。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　身長と寿命　地震研究所のＩ博士が近ごろ地震に対しての人体感覚の限度に関する研究の結果を発表した。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在の「秒」はメートル制の採用と振り子の使用との結合から生まれた偶然の産物であるが、このだいたいの大いさの次序を制定したものはやはり人体の週期であるという事はほとんどたしからしく自分には思われる。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地上で人体には感じない程度の風でも巻き煙草に点火したのを頭上にかざしてみれば流向がわかる、その程度の風にとんぼは敏感に反応して常に頭を風に面するような態度を取るのである。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "炭は炭でもそのコロイド的内部構造の相違によって物理的化学的作用には著しい差がある場合もあるから、蛇の黒焼きとたぬきの黒焼きで人体に対する効果がなにがしか違わないとは限らない。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦から見ても横から見ても土地侍とは見えぬ人体じゃもん」「うんうん。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "店の信用に拘わってはならぬとあって、役人体の者なぞは滅多に近寄らせんように取計ろうておったものじゃが……言語道断……」「ヘエヘエ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い土手の上に子守の小娘が二人と職人体の男が一人、無言で見物しているばかり、あたりには人影がない。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近医学の進歩につれて、この性欲なるものは、人体内の諸所より血液中へ分泌される内分泌物、すなわちホルモンの司る作用であって、そのホルモンが血液に混じて体内をめぐり、一方性欲を惹起させ、他方また精神、肉体を強靱ならしめていることが実証されて来ました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "両者を人体に譬うれば、田舎は胴体であり、都会は頭部であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「では、その方は、さような御串戯をなさる御人体でござりますか、立花様とおっしゃるのは。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
