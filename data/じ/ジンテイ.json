[
  {
    "uuid": "a71983cb-a876-5865-81ea-2435f5a1a7e2",
    "entry": "人体",
    "reading": {
      "primary": "じんてい",
      "alternatives": [
        "にんてい"
      ],
      "is_heteronym": false
    },
    "grammar": {
