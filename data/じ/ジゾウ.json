    "definitions": [
      {
        "index": 1,
        "gloss": "Kshitigarbha (bodhisattva who looks over children, travellers and the underworld)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
