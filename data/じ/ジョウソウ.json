[
  {
    "uuid": "e2a37eb2-466a-5c3e-b0a5-37cb56e7394e",
    "entry": "上奏",
    "reading": {
      "primary": "じょうそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
