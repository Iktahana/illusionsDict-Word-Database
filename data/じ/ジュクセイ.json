[
  {
    "uuid": "0d3a70cb-0d00-56af-9d6b-d993b89195be",
    "entry": "塾生",
    "reading": {
      "primary": "じゅくせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
