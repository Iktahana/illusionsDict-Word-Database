[
  {
    "uuid": "e2b27c6f-d962-51f3-804f-80a0e696961d",
    "entry": "実験",
    "reading": {
      "primary": "じっけん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
