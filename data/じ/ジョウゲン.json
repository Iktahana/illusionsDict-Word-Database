  {
    "uuid": "908f3149-ed53-5baa-9794-144106b58d74",
    "entry": "上元",
    "reading": {
      "primary": "じょうげん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "15th day of the 1st lunar month",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは至正庚子の歳に当る上元の夜のことであった。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが上元の日に十王殿に参詣したが、その日は参詣者が非常に多くて雑沓していた。",
              "citation": {
                "source": "陸判",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "牡丹燈記　元の末に方国珍と云う者が浙東の地に割拠すると、毎年正月十五日の上元の夜から五日間、明州で燈籠を点けさしたので、城内の者はそれを観て一晩中遊び戯れた。",
              "citation": {
                "source": "牡丹燈籠　牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし全体としてみれば星のスペクトル線の地上元素のそれとはかなりまでよく一致しているのは事実である。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような楽しみのほかに、私には上元気の午後三時頃、酔ったようになって盛夏の空と青葉の光輝とに見とれる悦びがある。",
              "citation": {
                "source": "この夏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "榛軒詩存に「丁未早春途上詠所見」の七絶と、「丁未上元後一日、次豆日小集韻、兼似柏軒」の五律とがある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "成都に遊ぶに及び、始めて識る、謂はゆる小桃なるものは、上元前後即ち花を著け、状は垂糸の海棠の如くなるを」。",
              "citation": {
                "source": "放翁鑑賞",
                "author": "その六　――放翁絶句十三首和訳（つけたり、雑詩七首）――",
                "note": "青空文庫"
              }
            },
            {
              "text": "成都に遊ぶに及んで、始めて所謂小桃なる者は、上元前後即ち花を著け、状は垂糸の海棠の如くなるを識る。",
              "citation": {
                "source": "放翁鑑賞",
                "author": "その七　――放翁詩話三十章――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（老学庵筆記、巻四）○上元は旧暦正月十五日。",
              "citation": {
                "source": "放翁鑑賞",
                "author": "その七　――放翁詩話三十章――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前さん、何してるだよ」「叫太乙天上元君……」吃男は依然として奇妙な呪言を止めなかった。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "上元の歌垣が、漢訳せられ、習合せられて、踏歌節となつた事は、疑ひもない事である。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "此が漢人の上元儀式と一つになつて、十四日・十五日或は節分・立春の行事などに変つた地方が多い。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁女・奉公人の藪入りも、上元・中元をめどとした親拝みの古風である。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、上元の前日や、節分の日や、大晦日の夜に行ふべきのが、十一月中の神事ときまつてゐた。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上元・中元に接した十六日を以て、子どもの閻魔に詣る日だと考へはじめたのは、訣のない事とは思はれぬ。",
              "citation": {
                "source": "たなばたと盆祭りと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五日は、支那の暦法でも上元の日で、重く見られてゐる。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、昔の正月として、上元の日を定めて、農村では守つてゐた。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "とどうだろう依然として、篝火は盛んに燃えており、その上元気よく鼻歌をうたい、鋸や、鉋や斧や槌などで、木を伐ったり板を削ったり、釘を打ったりして建築をしている、ノンキな物音が聞こえて来た。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其最古い形は、上元の踏歌である。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "上元の行事たる踏歌節会の夜に、ことほきびとの高巾子などにやつした異風行列の練り歩くのも、此群行のなごりである。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｙの父上元気な由、よかった。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬へば、大晦日と元日、十四日年越しと小正月（上元）、節分と立春との関係を見ると、元々違つた其々の日の意味が、互に接近して考へられて来たのは事実である。",
              "citation": {
                "source": "古代生活の研究",
                "author": "常世の国",
                "note": "青空文庫"
              }
            },
            {
              "text": "大祓への如きも、單に上元・中元に先だつ季節祓へでなく、やはり一年を二年と見た傳習から出たものと見る方がよい樣だ。",
              "citation": {
                "source": "國文學の發生（第三稿）",
                "author": "まれびとの意義",
                "note": "青空文庫"
              }
            },
            {
              "text": "其で上元の外に、中元を考へ、季節の祓除・鎭魂を行ふことになつた。",
              "citation": {
                "source": "國文學の發生（第三稿）",
                "author": "まれびとの意義",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど上元の日であった。",
              "citation": {
                "source": "封三娘",
                "author": "蒲松齢",
                "note": "青空文庫"
              }
            },
            {
              "text": "於東海之上蓬莱之頂、南宮西庶、有群仙所居、上元女仙太真者即貴妃也、謂什伍曰、我太上侍女、頴上元宮聖上太陽朱宮真人、以宿縁世念其願頗重、聖上降居於世、我謫人間、以為侍衛耳、此後一紀、自当相見、　羽衣説話に関しては、別に云う可きことなし。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "マネージャーの井上元佶君が「先生、そのモンペはチンドン屋のようで可笑しいからおよしなさい」というのを「赤くてとても綺麗じゃあない、私気に入ったわ」と、井上君の注意に大不服だった。",
              "citation": {
                "source": "三浦環のプロフィール",
                "author": "吉本明光",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもマネージャーの井上元佶君がいない晩なぞずいぶん淋しかったのだろう、空襲警報が解除されると傍にいた僕の老母に「お母さんよござんしたね」といっていきなりキッスをした。",
              "citation": {
                "source": "三浦環のプロフィール",
                "author": "吉本明光",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
