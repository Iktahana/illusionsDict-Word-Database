[
  {
    "uuid": "fdf6099f-1917-5815-bb36-3817a6c55374",
    "entry": "邪険",
    "reading": {
      "primary": "じゃけん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
