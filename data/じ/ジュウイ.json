    },
    "definitions": [
      {
        "index": 1,
        "gloss": "veterinarian",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一人はたしかに獣医の有本でも一人はさまざまのやつらのもやもやした区分キメラであった。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも判然はわからぬけれど念のため獣医を呼んで一応見せるがよかろうと申して。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "獣医を呼ぶまでもなしと予が云うたので。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "当区内の鵞口瘡は此六日を以て悉皆主治したとの話をした十二日　午前警視庁の巡回獣医来る　健康診断のためである。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は獣医に府下｜鵞口瘡の模様を問うた。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう心配なことはなかろうとの獣医の答であった十三日　午前二時朝乳を搾るべき時間であるから。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの乳牛に消化不良なのがあって、今井獣医の来たのは井戸ばたに夕日の影の薄いころであった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は今井とともに牛を見て、牧夫に投薬の方法など示した後、今井獣医が何か見せたい物があるからといわるるままに、今井の宅にうち連れてゆくことにした。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "見坊獣医から分けて貰ったのであります。",
              "citation": {
                "source": "柳沢",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "紳士は「弱ったなあ、あしたは僕は陸軍の獣医たちと大事な交際があるんだ。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしないでこの悪癖を直す方法はないかと思って獣医に相談すると、それは去勢さえすればよいとの事であった。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「失敬じゃないか、あしたは僕は陸軍の獣医官たちと大事な交際があるんだぞ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもデストゥパーゴが大びらに陸軍の獣医たちなどと交際するなんて偽らしいとわたくしは思いました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人の獣医は毎金曜、狆の歯を磨きに午前中だけ通って来る。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）獣医の家は家畜の毛もていろどられ、歯科病院の帷は入歯のごとき色したり、その真中にただひとつ、研ぎすましたる悲愁か、冷き理髪の二階より、剃刀の如く閃々と銀の光は瞬けり。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それが獣医も頭を痛めてまして。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "……品夫の父親というのは今から三十年ほど前に、親父の玄洋が、この村の獣医として東京から連れて来た、実松源次郎という男で、死んだ時が四十いくつとかいう事でした。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして獣医学校に籍を置いて勉強しているうちに、同じ下宿に居た関係から私の養父の玄洋と懇意になったのだそうで……」「ハハア。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "品夫の実父の源次郎氏の事なども、獣医には惜しい立派な人物だと云って賞め千切っていたようですが、よく聞いてみるとそれ程の人物でもなかったようで、こんな村の獣医相当の人間だったのでしょう。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから後暫くの間、殺生は無論の事、本職の獣医の方も放ったらかしにして、毎日のようにＫ市の遊廓に入り浸ったものだそうで、お磯婆さんや、養父の玄洋が泣いて諫めても、頑として聴き入れなかったという事です」「……いかにも……。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくさっそく獣医に見せたけれど、獣医の診断も曖昧であった。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "警視庁の獣医も来て評価人も規定どおり三人そろうたから、さっそくということで評価にかかった。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい学問をした獣医はまだすくない時代であるから、糟谷は獣医としても当時の秀才であった。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "札幌農学校や駒場農学校あたりから、ぞくぞくとして農学上獣医学上の新秀才がでてくる。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝島獣医学博士が駒場農学校のまさに卒業せんとする数十名の生徒をひきいて種畜場参観にこられたときは、教師はもちろん生徒にいたるまで糟谷のごときほとんど眼中になかった。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはみな糟谷と同出身の獣医で糟谷の知人であった。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど糟谷が遊んでおったをさいわいに、その主任獣医となった。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "びっくりしてはね起きて見ると、外ではほんとうにひどく風が吹いて、林はまるでほえるよう、あけがた近くの青ぐろいうすあかりが、障子や棚の上のちょうちん箱や、家じゅういっぱいでした。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔じゅういっぱいに口をあけようと、針で突いたほどにつぼめようと自在である。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "末の弟さまの火遠理命は、これはまた、山でりょうをなさるのがそれはそれはお得意で、しじゅういろんな鳥や獣をどっさりとってお帰りになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
