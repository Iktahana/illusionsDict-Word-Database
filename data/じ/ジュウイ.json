[
  {
    "uuid": "4d0a43cb-22f4-5799-9934-f79625a22f54",
    "entry": "獣医",
    "reading": {
      "primary": "じゅうい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
