    "definitions": [
      {
        "index": 1,
        "gloss": "direct transmission (of mystery, skill, secret, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
