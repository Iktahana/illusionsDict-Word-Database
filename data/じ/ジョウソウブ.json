    "definitions": [
      {
        "index": 1,
        "gloss": "top brass",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自社の製品は自社の技術でまかなうという原則も、上層部はこの市場に大して期待もしていなかったのか、守られなかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒涼たる心持で周囲を眺め、大人の文学をつくり、その大人の文学によって現実社会で官吏、実業家、軍人等によって占められている支配的上層部に伍そうとしたとして、それは容易なことであるだろうか。",
              "citation": {
                "source": "文学における今日の日本的なるもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子が黒須を動かして、彼の知っている、その新聞社の上層部の好意で、特別に記事の訂正かたがた葉子のために記事の載せられたのは、それから間もなくであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "人民の眼からかくされている上層部の裏面的な政治勢力は、内閣および議会をかいらいとして表面上は財閥解体令を受け入れながら緊急金融措置令によって新円切換えを行い、さらに半年のうちに第二回の金融措置（一般に預金封鎖とよばれた）を行って特権的階級に手厚い保護を与えた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい素子としてのトランジスターの実用性確認と、大容量の磁気コアメモリーのテストを公式な提案理由としてかかげたＴＸ―１プロジェクトを、研究所の上層部は却下した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の上層部には、祭司と教師の階級があって律法や誡命などの解釈に当っていた。",
              "citation": {
                "source": "文学以前",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "上層部の講和運動、本土決戦の一般宣言など、後に明らかになった支離滅裂な動きのなかの小さな一つに、その回教徒工作がありました。",
              "citation": {
                "source": "高尾ざんげ",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かゝる傾向が国民の上層部まで浸み込んで行く結果は、長期建設の途上、必ず、わが国民への他民族の軽侮、不信といふ形で表れて来ます。",
              "citation": {
                "source": "文芸の側衛的任務",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しひたげられ、踏みつけられても、浮かびあがらうとする浮力がもはや片鱗すらないやうな、家庭の暗がりに蠢めく一匹の虫とか、家庭の上層部には明るい波があるけれども、その下層部には澱んだ不吉な暗闇があつて、自分の姿はその暗闇をまもるところの醜悪にして貪婪な餓鬼の姿にほかならぬやうな苦痛にみちた思ひがした。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の上層部のサンが焼け、ガラスが落ちたのだと思います。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その三　精神病診断書",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、自分は狸界の上層部にあって、指導者の最高峰であり、実力の保持者だ。",
              "citation": {
                "source": "支那の狸汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "従來、島中君は上層部に接し極めて理解ある態度を示され、この人々の判断に信頼してきたのであるが、若い警察部方面の策動は、そうした最高方面を皆目無力ならしめたのである。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェット気流というのは、対流圏の上層部、非常に高いところにある気流である。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "表面に出ているのは島の暴民だが、ゲリラを指揮しているのは、マニラの知識的な上層部だということがわかっている。",
              "citation": {
                "source": "蝶の絵",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "であればこそ、彼等の指導部乃至上層部は遂に事実上反軍の汚名を買って出たというわけである。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "かろうじて残ったとしても、自然の風雨により上層部が損なわれ、三重が二重になるかもしれない。",
              "citation": {
                "source": "三重塔にて",
                "author": "福永信",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　朝倉先生は沈痛な眼をして、「実は、これは田沼先生にうかがったことだが、現在の上層部の人たちで、世界の事情に少しでも明るい人なら、さっきいった悪の勝利でさえ信じているものは一人もないらしい。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝ數年の近代的ヤミ世相よりも、室町中期から以降への、「明日はどうなるか」を憂ひつゞけた暗黒期のはうが、上層部はともかく、一般の庶民にとつては、いかに長く、晦く、果しない不安であつたかしれないとおもふ。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その事実を上層部に報告に及んだ。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "上層部ではすでに城介君に目星をつけていたらしい」　汽車は大同に到着。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは院政以来の上層部の大きな欲求で、保元平治の乱の頃の大立物であった悪左府頼長、すなわち道長の直系の関白忠通の弟であった頼長は、ことに政治制度の上での復古主義者で、律令格式の研究に熱中し、政令上に出でて下これを通ずる一糸乱れない平安初期の秩序にかえそうと思っていた。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺のしかめ面を北槻中尉はどう取ったのか、「軍の上層部はこの団体を快く思ってないようだが、その点は心配無用……」と俺に言った。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "「軍の中枢部の幕僚将校がこの団体に結集している以上、上層部もこれを弾圧することは不可能だ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "それどころか、上層部をもかならず動かせるし、上層部のなかでも心ある人はすでに自分たちの決意に共鳴している」と中尉は言って、その決意の明記された文章を俺に示した。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "不発に終った原因は、軍の上層部が時期尚早という断定を下したためだという。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自分らの手でやはり独断専行すべきだ」「軍の上層部は信用できない」　そうした議論は、尾垣大将への不信になった。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　北槻中尉らの話を、聞くともなく聞いていると、軍の上層部には派閥があって、醜い勢力争いをしているようだった。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月事件に失敗した青年将校は、あの場合、軍の上層部が計画に加わっていたことがまずかったのだと見て、自分らの手で事を行おうと企てた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "政権奪取を目的とするクーデターは、支配階級の上層部をやっつければ、それですむが、俺たちは大衆｜蜂起が必要である。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
