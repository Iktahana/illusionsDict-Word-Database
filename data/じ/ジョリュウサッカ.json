    "definitions": [
      {
        "index": 1,
        "gloss": "woman writer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あまり名を見ない女流作家である。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "女流作家としての明瞭な足跡を印したと云つていい。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると叔父さんは、それを半分も読まずに手帖を投げ出し、和子、もういい加減に、女流作家はあきらめるのだね、と興醒めた、まじめな顔をして言いました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女流作家として仙子氏をまつことはもう出來ない。",
              "citation": {
                "source": "水野仙子氏の作品について",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治以來出現した女流作家の數は少くない。",
              "citation": {
                "source": "水野仙子氏の作品について",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、女流作家はだめだ。",
              "citation": {
                "source": "雌に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は女流作家には評判が悪いのだ、どうもねえ。",
              "citation": {
                "source": "雌に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はあなたが有名な女流作家であるからとか、年長の美しい婦人に興味を持つとか、単なるそんな意味ばかりではなし、何故あなたのような方が、あの晩、あんな態度で僕をおつけになり、最後に僕を不良青年かなぞのように恐れてお逃げになったか、その意味が伺い度いのです。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こよいは、イギリスの或る女流作家の傑作、『迎え火』という劇詩を演出して御覧にいれまする。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて誠実な人間でだけありたい等と、それが最低のつつましい、あきらめ切った願いのように安易に言っている恐ろしい女流作家なんかもあったようですが、何が「せめて」だ。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、ひどく太って気の毒な或る女流作家の言葉なのです。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいいち、あの女流作家に対して失礼です。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "−−−−−−−−−−−−−−−−−−−−−−−−−−小倉遊亀論　画壇でも、文壇でもさうであるが、女流作家は、男の作家に較べて、いくつかの特点をもつといはれてゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "』といふ点のつけられ方の甘さなどもその特点の一つであらうか、この特点は必ずしもその女流作家のための都合のよい特点とはかぎらないこともある。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが小倉遊亀氏は幸なことには、さうした女流作家の特点といふものに決して恵まれてゐる作家だとはいへないやうだ。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "この女流作家は、ドイツでは新派と旧派との中間に出たやうな人で、パウル・ハイゼなどの後につゞいて出て来たが、新しい思潮が、輓近派が確然首をもたげて来たので、その間に挟まれて、右にも左にも出られなくなつたやうな作者であらうと思ふ。",
              "citation": {
                "source": "ペチヨリンとゲザ",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "小森は昨夜栄子と女流作家のＴ女史について話してゐたことを、うつとり思ひ出してゐた。",
              "citation": {
                "source": "女流作家",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論それは作品を通してで、女学校卒業前後と結婚生活時代とに亙つて、その頃唯一の女流作家であつた彼女の作品は、大抵愛読したものであつた。",
              "citation": {
                "source": "女流作家",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あれこそ本当の女流作家よ。",
              "citation": {
                "source": "女流作家",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、そうした変装者のなかに、一人の女流作家がいて、あの地獄変を体験していたとは、まだあの時は知らなかった。",
              "citation": {
                "source": "「屍の街」",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは我社の企てであつた女流作家研究のうちで、明治時代の女流作家として、仙子さんを一枚どうしても加へたい念願があつて、それを自分の受持にしたのである。",
              "citation": {
                "source": "水野仙子さんの思ひ出",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は作家ではないから、特に仙子さんの作品に觸れて評する事はむづかしいが、青梧堂といふ書店から發行された塩田良平氏の「明治女流作家」といふ書物のなかにある「水野仙子」といふ項目のなかに、よく委しく其作にも觸れて書かれてある。",
              "citation": {
                "source": "水野仙子さんの思ひ出",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お貞さんの其時の作は「徒勞」といふもので田山花袋氏の激賞を受け、一般文壇的にも此作によつてお貞さんの名は女流作家として自他ともに許すやうになつた。",
              "citation": {
                "source": "水野仙子さんの思ひ出",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　ノーベル賞金の受領者、瑞典の女流作家、ラゲルレフの作も多分に猟奇的である。",
              "citation": {
                "source": "他界の味其他",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "極く初歩的な問題から再出発する気組で――文章が粗雑だと、ある女流作家から注意されたので――今は志賀直哉のものをノートし、まず文体の研究をしているのだと、そういうことまで卒直に打明けるのであった。",
              "citation": {
                "source": "翳",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の文章が粗雑だと指摘した女流作家に、岩井繁雄は最初結婚を申込んだことがある。",
              "citation": {
                "source": "翳",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "これには流石の女流作家も弱らされたが「私は聾や唖を好かないから。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "襟飾３・４　マアク・トヱンといへば米国の名高い滑稽作家だが、この小説家が女流作家のストウ夫人と隣合せに住んでゐた事があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい女流作家10・20（夕）　この頃二科会の展覧で京都に来てゐる有島生馬氏が、先月末の事、米国通ひの伏見丸へ人を見送りに往くと、甲板で小柄な日本人の娘が、洋装をして、父らしい人と一緒に大勢の見送人に挨拶してゐるのを見た。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
