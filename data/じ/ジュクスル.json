    "definitions": [
      {
        "index": 1,
        "gloss": "to ripen",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "想像するがままに任せた山、感情を塗りかえした山、その山の暗き森と、深い谷、過去へと深く行き、遠く行くだけ、紀念は次第に成熟する、石の上を走っている水の面の経緯は、幾世の人の夢を描いては消し、消しては描いているのである。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで事相の成不成、機縁の熟不熟は別として一切が成熟するのである。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲の熟するころとなると、谷々の水田が黄ばんでくる。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "官立大学で経済を学んでいたために、父亡き後の母は、この遠縁に当って足繁く自家へ出入する青年を、何かと相談相手にして、いわば私との恋仲も黙許よりも、寧ろ奨励する形で、結婚にまで熟するのは容易な道行でありました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "釈迦はその晩年、その思想いよいよ円熟するに従て全く菜食主義者ではなかったようである。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今其集に就て交友を考うるに、袁」］と張天師とは、最も親熟するところなるが如く、贈遺の什甚だ少からず。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨發達して、殆んど成熟すると、生氣が漸くにして中に屯鬱して、終に外に洩るゝに至つて、又｜新に生氣の一寓處を成すのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "七年碁を弄び、九年俳諧を嗜んで、千局二千局を圍み、一萬句二萬句を吐いても、たゞ熟するといふ事が有つて、更に進むといふ事の無いのが有る。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "爰に於て俳諧の頓かに、成熟するあり、更に又た戯曲小説等の発生するあり。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は極致と共に死したり、而して他の極致を以て更生するまでの間は所謂無心無知の境なり、激奮猛奔して、而して中奥に眠熟するが如き境なり、この境を過ぐるは心機一転に欠くべからず、而してこの境は石火なり、流星なり、数秒時間なり。",
              "citation": {
                "source": "心機妙変を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれは、然し、葡萄の熟するのを待つてゐるのではない。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争開始前、高山右近の家来の甘利八郎太夫と云う男が、牀几に依って戦機の熟するのを待っている右近の前に出て、「私は、只今どちらにしていいか分らない事があるから、御判断を願いたい。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "世高と秀英の二人は機の熟するまで迹をくらますことにした。",
              "citation": {
                "source": "断橋奇聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "句々洗錬の足らざるが恨なり、ホラチウスの教を知らずや、唯だ放置せよ、放置してその熟するを待てといへり、おん身の作も亦然なり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "永い日は僅な日數の内に目に渺々たる畑をからりとさせて、暫くすると天候は極りない變化の手を一｜杯に擴げて、黄色に熟する梅の小枝を苦めて居る菜や石龍※の黄色い小粒な花を持たせて、棟にさへ長い短い草を生ぜしめる。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて発達して殆んど成熟すると生気が次第に中に溜まって終には外に洩れて、また新に生気の拠り処と成るのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "七年碁を弄び、九年俳諧を嗜んで、千局二千局を囲み、一万句二万句を吐いても、ただ熟するというだけで更に進むことの無いのがある。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "学ぶ時は繰り返し繰り返して、嫌気を起こさずにこれを習熟するがよい。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "習熟することこれがこの一節の眼目であり、重要なことである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして聖人の学問は仏教や道教の学問が空寂清虚を尊ぶのと異なり、全て皆これ実際のことで、現実離れしたものでは無いので、その学問が次第に成熟するに従って、日常行動の一挙手一投足の間にも、その徳光・道光は自然と溢れ出し、人の認めるところとなるのは自然な成り行きである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「伝えて習わざるか」とは、朱子の「伝えるとは之を師より受けることを云い、習うとは之を自分に習熟することを云う」という解釈が実に優れている。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「賜や、汝は予を多く学んでそれを知識とする者だと思うか」と問われると、子貢は自分が元来、博学は学問の道に熟する基本であると思っていたから、「そうでございます」と直ちに答えた。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔子の道を学ぶ上に於いては勿論の事、忠が第一歩から終局まで大切なもので、忠によってのみ醇熟するのであるが、たとえ小道小枝に於いても忠に成り得ない人は必ず何をしても進歩しないのであり、忠の心状を知らない人ほど世に悲むべき哀れな者は無い。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の生まれ持つ人の人である根本のもの、即ち禽獣と異なる根本のものを湛えて、之を損傷しないで、本性に率い工夫純熟する「忠」が存在し、発して皆妥当する（節に中る）。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀州の白崎では、以前榕実熟する時、猴これを採りに群集し、田辺附近の竜神山にも、千疋猴とて、夥しき猴の団体を見た事あるも、近年一向なし。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人ありて他の一人の所有地に甘蕉を植え、その果熟するに及び互いにこれを争う。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを釜に盛りて焔味球という珠を下に置けば、その光で飯が熟するを四方の人来り食うに尽きず。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は豕を教育する時日を費やさず、齢一歳に及べば屠殺するから、智能の熟するはずがないと言った（ボスエルの『ジョンソン伝』七十五歳の条）。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "果実はその熟する少し前に於て、落ちたり腐つたりすることが非常に多い。",
              "citation": {
                "source": "旅から帰つて",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の家には昔大きな蜜柑の木があったが、その蜜柑が熟する頃になると、母の父（即ち私の祖父）は、近処の子供を大ぜい集めて、自分は蜜柑の木の上に登って、そこから蜜柑をちぎっては投げ、ちぎっては投げ、そして子供が喜ぶのを見て面白がっていた。",
              "citation": {
                "source": "私の母",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
