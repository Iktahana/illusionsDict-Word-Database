        "examples": {
          "standard": [
            {
              "text": "資源の少ない国では、石炭から人造石油を製造する研究が進められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "人造石油の生産コストは、天然石油に比べてまだ高い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の研究室では、バイオマスから人造石油を作る技術が開発されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "小山いと子は従来の婦人作家としては社会現象に対して強い興味と追求心をもった作家で、この二つの作品にしろ、みもしらない外国を背景として日本技師のダム工事にからむ事件や、人造石油製造の技術の発展とそれにからむ人事などをあつかっている。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「熱風」にしろ「オイル・シェール」にしろ、婦人作家としては珍しく、見知らぬ外国を背景として、そこでの日本技師のダム工事にからむ事件や人造石油製造工業技術の発展に絡む人事などが扱われている。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
