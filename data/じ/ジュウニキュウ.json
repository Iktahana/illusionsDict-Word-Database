    "definitions": [
      {
        "index": 1,
        "gloss": "the twelve zodiacal signs",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
