        "examples": {
          "standard": [
            {
              "text": "将棋の序盤戦において、相手の狙いを読み切ることが勝敗を分ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「序盤戦で焦りは禁物だ。じっくりと駒組みをしていこう。」とコーチは指示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "序盤戦での一つのミスが、終盤に響いてしまうことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "序盤戦はいずれも慎重をきわめ互に、口舌を以て牽制これ努めるという風であつた。",
              "citation": {
                "source": "この握りめし",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
