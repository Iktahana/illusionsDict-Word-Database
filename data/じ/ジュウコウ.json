[
  {
    "uuid": "e224685f-3754-589e-8dd0-e9d367d6d403",
    "entry": "銃口",
    "reading": {
      "primary": "じゅうこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
