        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ジグスのやうに、パンのし棒でのされるにしても、あのやうに朗に飲めるのならば、酒は確かに百薬の長だが。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジグスとマギーの漫画のようなものもそうであり、お伽噺や忠臣蔵や水戸黄門の講談のようなものもその類である。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの考へてゐるのは対称はとりながらごく不規則なモザイクにしてその境を一尺のみちに練瓦をジグザグに埋めてそこへまっ白な石灰をつめこむ。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日がまはるたびに練瓦のジグザグな影も青く移る。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう大概で打ち切りにしてもよさそうに思われるのに、そうしないのは、やはりジグスとマギーのような「定型」の永久性を要求する大衆の嘱望によるものであろう。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾年もつづけてジグスとマギーをかいている画家は、おしまいには生きたジグスとマギーの存在を信じて疑わなくなるだろうが、それと似た頭の迷いが起こりはしないか。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姫さまは、波のあいだをただよう氷山の上に静かに腰をおろして、青いいなずまが、ジグザグに、ピカピカ光る海の面にきらめき落ちるのをながめていました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "人夫たちはベンゲット山腹五千フィートの絶壁をジグザグによじ登りながら作業しなければならず、スコールが来ると忽ち山崩れや地滑りが起って、谷底の岩の上へ家守のようにたたき潰された。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "リンガエン湾附近に上陸した皇軍は恐らくベンゲット道路を通ってマニラへ向うと思うが、自分はあのジグザグ道のどこに凸凹があり、どこの曲り角が向うの崖から丸見えかを知っているのだ、バギオにはアメリカの兵舎があり、うっかりベンゲットを通ると危い、どうぞ自分を道案内にしてくれと、頼みこんだ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、たちまち眼の前の、ぼーっとした仄暗い空を切り裂いて、青光りのする稲妻が、二条ほどのジグザグを、竪にえがいた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "リンガエン湾附近に上陸した皇軍は恐らくベンゲット道路を通ってマニラへ向うと思うが、自分はあのジグザグ道のどこに凸凹があり、どこの曲り角が向うの崖から丸見えかを知っているのだ、どうぞ比律賓へやらしてくれと、頼みこんだ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「『ジグブリット夫人、五幕新作悲劇』おやおや、これはなんだ。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "客窓の徒然を慰むるよすがにもと眼にあたりしままジグビー、グランドを、文魁堂とやら云える舗にて購うて帰りぬ。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "――髮の毛をひツつかんで引きずり廻はされるやうな、ジグザツクな、しかも胸突八丁だつた。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の戦術は向うのブルジョワジーのジグザッグな戦術に適確に適応して行かなければならない。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもその代りに、杉本は、妙な毛の生えた小さな肉片を、まるでジグソー・パズルでもする様な意気込んだ調子で鉄火箸の先に挟んで持出して来ました。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さうだ、いよ／＼あれは僕の迎へだ――ジグザグの径にかゝつたよ。",
              "citation": {
                "source": "舞踏会余話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔伏字二十八字〕（この一行は復元できない）ロシア民衆の生活がいかなるジグザグの道をとおり、流血と犠牲をもって十月革命の大道へ辿りつき、更にその道を前へ前へと進んでいるかということを、その多様さ、複雑さ、矛盾のままの姿で描いた作家は、ゴーリキイなのである。",
              "citation": {
                "source": "マクシム・ゴーリキイの人及び芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "床板はモザイクまがいに、小さな板きれをジグザグに並べた、ちょっとしゃれたものだった。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の生えた岩石の島がちらばって、ジグ・ザグの小半島が無数に突出し、端倪すべからざる角度に両側から迫っている。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはあの妻楊枝を満載した英吉利貨物船の編成隊が不意の光線に追われた油虫の家族のように仲の好い一列を作ってダンジグ港へ投錨した時の華美な光景を御存じですか？",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれ永いジグザグの道を経た上でのことだろうが、女の幸福の問題はやがて次第にその局部的な、しかしきわめてその社会の基本的なありようと関係しあった特殊性を高めひろげ、揚棄して行って、いつかは人間の幸福についての具体的な条件の一つとして、女の幸福が扱われるようになって来るだろうと考えられる。",
              "citation": {
                "source": "幸福の感覚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女も人類のために貢献するために生きたいという希望、そのために知能をもゆたかにしたいという希望を抱いて努力している事実は、いわば地球の動きのようなもので、いつかはそれが承認され具現する可能に向って、今日の文化はジグザグなりに動いていると思う。",
              "citation": {
                "source": "科学の常識のため",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の人たちが終生仲間は離せなくて、漫画の親爺教育のジグスのあわれおかしき仲間恋いの心持は、もう私たちの心にももちものとなっているかと思う。",
              "citation": {
                "source": "なつかしい仲間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の民主化は非常にジグザグなコースをとって根気づよく、人民の力によって行われなければならない内外の事情におかれている。",
              "citation": {
                "source": "文学と生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水路や溝の上には小さな静かな光の輝き――エメラルド色や薔薇色そして鉄の淡青色に煌めき、音もなくジグザグに飛び交って――トンボがあちこちに止まっている。",
              "citation": {
                "source": "赤い婚礼",
                "author": "RED BRIDAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、みのえはジグザグ裏通りの狭いところを通って、女学校の往きに、時々油井の家へよった。",
              "citation": {
                "source": "未開な風景",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツ語のものでは、これも大きいが、ジグワルトの『論理學』なぞ、論理學から認識論への道を開くものとして適當であらう。",
              "citation": {
                "source": "哲學はどう學んでゆくか",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "スティーブン・ウォズニアックにとって、一九七五年はジグソーパズルのすべてのコマが手元にそろった決定的な一年となった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
