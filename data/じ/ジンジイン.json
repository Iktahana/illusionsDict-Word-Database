          "literary": [
            {
              "text": "日本の人民の独立に関する一つの問題としてあれほどみんなが関心をもった大学法案、二十七名の中立的な学者たちが反対署名した非日委員会問題、「南原の線を守る」という表現がある意味では常識となって来ているほど広汎に人事院とりしまり規則に反対している人々の群。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "河合栄治郎が学者としての良心の最低線を守ろうとした抵抗の精神は、人事院規則に対する南原の線を守る人たちの抵抗でもある。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "労働省が、人事院が、その後を追うていった。",
              "citation": {
                "source": "機構への挑戦",
                "author": "――「場所」から「働き」へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとまずその日の会議は閉じ、人事院をして調べさせた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
