          "literary": [
            {
              "text": "人工衛星、原子力問題、人工頭脳、南極観測と……、この近年の新聞や雑誌に、科学関係の記事が、一つも載らない日は、まず無いといってよい。",
              "citation": {
                "source": "科学ブームへの苦言",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇宙ロケットがとび、人工頭脳がそれを操作する。",
              "citation": {
                "source": "犬がなくとガラスがこわれるか",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロケットも、人工頭脳も、原子力発電も、科学によってつくられたものであって、科学そのものとは、いいかねる。",
              "citation": {
                "source": "犬がなくとガラスがこわれるか",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
