    "definitions": [
      {
        "index": 1,
        "gloss": "high-status Shinto shrine with connection to imperial family",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "電車で街を縦走して、とある辻から山腹の方へ広い坂道を上がって行くと、行き止まりに新築の大神宮の社がある。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大神宮のすぐ下にソビエト領事館がある。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "木綿をきり売りの手拭を下谷の天神で売出した男の話は神宮外苑のパン、サイダー売りを想わせ、『諸国咄』の終りにある、江戸中の町を歩いて落ちた金や金物を拾い集めた男の話は、近年隅田川口の泥ざらえで儲けた人の話を想い出させて面白い。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "金刀比羅宮、男山八幡宮、天照皇大神宮、不動明王、妙法蓮華経、水天宮。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "式は銀子が塩釜で遊んでいるころ、仙台の神宮で行なわれ、宮古川で披露の盛宴が張られたものだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日、癸卯、霽、鶴岳の別当公暁、宮寺に参籠して、更に退出せられず、数ヶの祈請を致され、都て以て除髪の儀無し、人之を恠しむ、又白河左衛門尉義典を以て、大神宮に奉幣せんが為、進発せしむ、其外諸社に使節を立てらるるの由、今日御所中に披露すと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "将門は一人で、官職といへば別に大したものを有してゐるのでも無い、たゞ伊勢太神宮の御屯倉を預かつて相馬｜御厨の司であるに過ぎぬのであるに、父の余威を仮るとは言へ、多勢の敵に対抗して居られるといふものは、勇悍である故のみでは無い、蓋し人の同情を得てゐたからであつたらう。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "有っても一向｜心懸のございません僕なんざ、年の暮に、太神宮から暦の廻りますまでは、つい気がつかないでしまいます。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一時間のち、私は少年と共に、渋谷の神宮通りを歩いていた。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "神宮通りをすたこら歩いた。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――（再び槌を取りあげ）南無｜帝釈四天王、五道｜冥官、日本伊勢大神宮、八幡大菩薩、春日大明神其他｜氏神、南無阿弥陀仏。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "純粋の日本風でというので結婚式は大神宮の神式で行われた。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "早春香取神宮槙のこずゑに、青鷺の群れて巣をもつ幽けさよ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "神苑明治神宮西参道幽けさや、この日なかの邃き木の木しづく。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "神苑明治神宮西參道幽けさや、この日なかの邃き木の木しづく。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "また武芸神宮本玄心である。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "綿うたす媼はさもあれ、提灯屋｜老の猫脊が、さてゑがく牡丹に唐獅子、太神宮祭近しと、子供組｜勢ふよろしと、えやうやと受け合ふものから、向ひ屋の浄瑠璃の師匠、越太夫を我は。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は天照皇太神宮と、阿弥陀仏と、我が皇室と、この三体を一つに祭って、いやその祭壇を私の家庭にこさえたのです。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで命は、急いで伊勢におくだりになって、大神宮にお仕えになっている、おんおば上の倭媛にお別れをなさいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇はその女の言うとおりになすって、ご無事に大和へおはいりになり、石上の神宮へお着きになって、仮にそこへおとどまりになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると二ばんめの弟さまの水歯別王が、その神宮へおうかがいになって、天皇におめみえをしようとなさいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからあくる日そこをお立ちになり、大和の遠飛鳥という村までおいでになって、そこへまた一｜晩おとまりになったうえ、けがれ払いのお祈りをなすって、そのあくる日｜石上の神宮へおうかがいになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、室の一方には蒲団を畳んで積み、衣類を入れた葛籠を置き、鎧櫃を置き、三尺ばかりの狭い床には天照大神宮の軸をかけて、其の下に真新しい榊をさした徳利を置いてあった。",
              "citation": {
                "source": "海神に祈る",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三造がはいって行くと、伯父は寝顔を此方へ向けて、真先に、ちょうどその頃神宮外苑で行われていた極東オリンピックのことを彼に訊ねた。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀杏の葉の散る神宮外苑をうそ寒く歩いてゐた時も、島民共と石燒のパンの實にむしやぶりついてゐる時も、お前は何時もお前だ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀杏の葉の散る神宮外苑をうそ寒く歩いていた時も、島民どもと石焼のパンの実にむしゃぶりついている時も、お前はいつもお前だ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな恰好で神宮を出でたつと道路の傍に、年の頃二十｜計りの若者が羽織を着、膝を付けて、信長に声を掛けられるのを待って居る様子である。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の時間で丁度八時頃、神宮の南、上知我麻祠の前で、はるか南方に当って一条の煙が、折柄の旭の光に、濃い紫色に輝きながら立ち上るのが見られた。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "天狗党に居た時は、潮来の宿で、気に食はぬ事があつて、部下三名を並べて首を斬つたり、鹿島神宮へ参詣して、拝殿の太鼓が大き過ぎて目障りだと云つて、これを鉄扇で叩き破つたと云ふ程の乱暴者であつた。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
