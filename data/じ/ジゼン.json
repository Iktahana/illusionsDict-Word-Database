  {
    "uuid": "a9e1631c-2149-5396-af3c-686edf43042c",
    "entry": "次善",
    "reading": {
      "primary": "じぜん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
