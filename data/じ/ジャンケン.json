        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "どうも相変らず寒いじゃありませんか」と云う常の通り元気の好い主人を見ると、子供を大勢自分の前へ並べて、その中の一人と掛声をかけながら、じゃん拳をやっていた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」みんなは叫んで、じゃんけんをするために、水の中から手を出した。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、はさみ無しの一人まけかちで、じゃんけんをした。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」みんなは叫んで、じゃんけんをするために、水の中から手を出しました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、はさみ無しの一人まけかちでじゃんけんをしました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃんけんさえ、はっきりは知らなかった。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "「泉ちゃん、じゃんけんしようよ――」　などと言って兄と共に遊ぼうとする繁には母の記憶が無いばかりでなく、兄の泉太ですら亡くなった母さんをよく覚えていないと言う程で、二人の子供は唯々父を便りにし、父と共に住むことを何よりの幸福としている。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃんけんをしたり、拗ねたり、怒ったり、泣いたり、笑ったりする声がはっきりと手にとるようにきこえた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなでじゃんけんをして、勝ったものが一番｜先に、ハンケチで目かくしをして、まっすぐに歩きだしました。",
              "citation": {
                "source": "風ばか",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのことを聞いて嬉しくなり、国男さんに、すぐじゃんけんを仕よう、仕ようと云った。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルが鳴って、二階の席に戻る時、負けては困る彼の心持を察し、じゃんけんはしないでも、私は行かないことにしよう、ときめた。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃんけん、おはじき、影写し、おばーけ、こーこはどーこの細道じゃ、人取り、お馬ごっこ、ダンス………夫人や姪まで笑いくずれたし、お清も見物したし、中頃からは、洋太郎ものっそり勉強室から出て来た。",
              "citation": {
                "source": "人の国",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっと三人で、じゃんけんしてみておくれ。",
              "citation": {
                "source": "嵐",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オイ、じゃんけんだとよ。",
              "citation": {
                "source": "嵐",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃんけんというと、いつでも僕が貧乏くじだ。",
              "citation": {
                "source": "嵐",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「じゃんけんして、負けたものにしようや。",
              "citation": {
                "source": "二百十日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二人は、じゃんけんをしました。",
              "citation": {
                "source": "二百十日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃんけんで負けた方がこそぼられるんや」「ほんなこと、かなん」「晋さんは喉だけやが、なあ、しようまいか」　自分の手で、自分の喉や腋を擽っても、何の感じもない。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めのじゃんけんは私が勝った。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃんけん、じゃんけん……」「もう、わし、せん」「なんでや。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、チッチノホー（じゃんけん）して負けた者が行こうと云っても、何といっても、仲間はきいてくれないので、とうとう、彼が一番先に立ってそのあとから皆が付いて行くということに定まった。",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
