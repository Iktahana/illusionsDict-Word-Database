        "examples": {
          "standard": [
            {
              "text": "公平な人事行政は、公務員の信頼を維持するために重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、長年人事行政に携わってきたベテランだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい人事行政の仕組みが導入され、期待が寄せられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしドイツ軍部もこの頃は国防の根本に対する熱情が充分でなく、ややもすれば行き詰まりの人事行政打開に重点を置いて軍拡を企図した形跡を見遁す事が出来ない。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "公然であるべき政治というようなものを、わけても人事行政などを、私的｜情誼的におやりになる。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
