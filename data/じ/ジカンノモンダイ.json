        "gloss": "matter of time",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「あいつらが逃げて来るようじゃ、こゝが陥落するのも、もう時間の問題だ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "解決に曰く、時間の問題さ。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こうなればもう時間の問題だ」　私は彼から離れてそう云った。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あとはもう時間の問題だ。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはや時間の問題だ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "とまあパーソナルコンピューターの世界では、小型化をめぐってこんな時間が流れたが、この余波がワークステーションと呼ばれる一段上の処理能力を持つ兄貴分にも及ぶことは時間の問題だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょせんは時間の問題で、永久に破裂を防ぐことの出来ないのは母子もあらかじめ覚悟していなければならなかった。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大坂の落城は、もう時間の問題であった。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間の問題だからな。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　ネバ河　レニングラードの陥落も時間の問題となった。",
              "citation": {
                "source": "世界の裏",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはもう時間の問題であった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここまで判れば、この一件の解決は時間の問題に過ぎないと、半七は多寡をくくってしまったのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "解決は時間の問題ではないか。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方には、現在の状勢でプロレタリア文学運動の確立のために組織活動なしでどうするものぞ、組織活動によってこそ、多数者獲得の課題に答え得るのだ、今書けないのは仕方がない、という左翼的日和見主義があり、他には、時間の問題とする部分もある。",
              "citation": {
                "source": "一連の非プロレタリア的作品",
                "author": "――「亀のチャーリー」「幼き合唱」「樹のない村」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは時間の問題である。",
              "citation": {
                "source": "いのちの使われかた",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで我々はゲーテについて時間の問題を考察してみよう。",
              "citation": {
                "source": "ゲーテに於ける自然と歴史",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間の問題は歴史哲學の中心に立たねばならぬ。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてひとは歴史的時間の問題は、或は自然科學的時間との區別に於て、或は所謂空間化された時間との對立に於て取扱はれねばならぬと考へる。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにもし人間の歴史にして自然を基礎とするものであり、何等かの仕方で自然と織り合はされてゐるものであるとするならば、よし自然科學的時間の問題は歴史の問題にとつて沒交渉であるとしても、自然的時間の問題は決してさうではあり得ない筈である。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて時間の問題が歴史に關係して論ぜられるとき、そこには必ず明かにさるべき三つのものの關係のあることが知られるであらう。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくてアウグスティヌスにあつては時間の問題は神に對して被造物の根本的な存在の仕方の問題に關係してゐるのである。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しながらそれにしても、彼に於ける時間の問題がフッセルなどのいふ「内的時間意識」の問題に過ぎなかつたと考へることは出來ない。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでジンメルの如きも『歴史的時間の問題』に就いて論じ、次のやうに書いてゐる、「一の現實内容は、我々がそれを我々の時間體系の内部に於て一定の所に綴ぢ付けにされてゐるのを知るとき、一の歴史的なものである――尤もこのやうな限定はその際樣々な精密さの度合をもち得るであらう。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故に彼は歴史的時間の問題を現實的に解決することが出來ない。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しこの場合に猶問題があるとすれば、それは時間の問題に過ぎないだろう。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "山本は今、大川の生命はただ時間の問題であることはよく知っている。",
              "citation": {
                "source": "黄昏の告白",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこうしておられることもただ時間の問題である、こんなふうにも常規を逸してしまった人は、いつまで自分をこうさせてはおくまいと悲しんでおいでになった。",
              "citation": {
                "source": "源氏物語",
                "author": "夕霧二",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、ルウスの逮捕は時間の問題に相違ない。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
