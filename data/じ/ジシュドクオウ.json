        "examples": {
          "standard": [
            {
              "text": "彼は、実家を出て、自主独往の生活を始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "人生の目標は、経済的にも精神的にも自主独往を確立することだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「大学卒業後は、自主独往の道を歩んでいきたいと考えている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "人間社会の進歩の原動力は、何といっても、ひとりびとり人間の自主独往の気象であり、その個性に応じた創意工夫の能力であります。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "その点ではあくまでも自主独往、いささかも他にゆずる必要はありません。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            }
          ]
        }
