    "definitions": [
      {
        "index": 1,
        "gloss": "assistant professor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "中年学校、老年学校を設置して中年、老年の生徒を収容し、その教授、助教授には最も現代的な模範的ボーイやガールを任命するのも一案である。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと彼の椅子が出来ると間もなく、チューリヒの大学の方で理論物理学の助教授として招聘した。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌三十五年助教授となり、四十二年応用力学研究のため満二年間独国及び英国へ留学を命ぜられ、これと同時に工学博士の学位を授けられた。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀念写真学生壇を並び立ち、　　　教授助教授みな座して、つめたき風の聖餐を、　　かしこみ呼ぶと見えにけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "助教授室……ヘエヘエ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "助教授の退出を待受けて何かしきりに問い合わしている男学生達。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "医科大学の助教授である彼女の夫が肺を患って寝こんでしまった時、他に男手のない二人暮しの家が物騒だというので、柔道部の選手をしていた轡川に言わば用心棒代りに寝泊りしてもらうことにした。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "中秋の或る快晴の日の午後、景子は友人の某大学英文科の助教授宮坂を案内して彼がしきりに逢いたがって居た此の国の文学者ジョン・ガルスワーシー邸を訪ねて行った。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて助教授宮坂は日本人的のぎこちない真面目な顔付きでガルスワーシーを覗き込むようにしながら氏の近作「銀の匙」と「白鳥の歌」に就いて発言しようと口を切った時、玄関へ一団の訪問客の押しかけて来たけはいを感じて言葉を切った。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "創作はあきらめ給え」　そうして彼を無理に研究室に入れ、次いで助教授にした。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "又註脚に大学助教授ドヨオジヒ氏の言つてゐることは一顧に値する。",
              "citation": {
                "source": "十三時",
                "author": "THE DEVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "この本に監修者としてかかわっている浜野保樹放送教育開発センター助教授の『ダイナブック』に関する指摘はもっと辛辣だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ米ＰＣ　ＭＡＧＡＺＩＮＥからの強力スタッフに加えて日本からは、東芝の溝口哲也パソコン・ワークステーション事業部長、日本電気の高山由パーソナルコンピュータ販売推進本部長、古川享マイクロソフト社長、脇英世東京電機大学助教授の豪華メンバーである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご存じ坂村健東京大学助教授の提唱する、ＴＲＯＮプロジェクトである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る助教授の受け持っているフリイドリヒ・ヘッベルと云う文芸史方面のものがある。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "美雲氏は既に故人となったが、後に美術学校の助教授をもしたことであって、至極穏健な作をする人であった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "皇居御造営の事、鏡縁、欄間を彫ったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "臼杵先生ったら……白鷹先生は、あなたよりもズットお年上で、Ｋ大耳鼻科の助教授をしていらっしゃるんですよ」「ワア。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に彼女の儚ない空想を現実に満足させようとしたのと同じ心理から出た作り事で、彼女がＫ大耳鼻科、助教授の要職にいる人から如何に信頼を受けておったかと言う事を、具体的に証明したいばっかりの一片の虚構に過ぎなかったのであったが、しかしその時の私が、どうしてソンナ事に気付き得よう。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし間もなく平生の無邪気な快活さを取り返した彼女は、さもさも嬉しそうに……あたかも白鷹助教授と臼杵病院長を紹介する光栄を喜ぶかのようにピョンピョンと跳ね上りながら電話室へ走り込んで行った。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは約二時間前に私に面会した白鷹助教授が、すぐに下六番町の自宅へ電話をかけた結果であったらしく、非常に冷静な、同時にこの上もなく友誼的な口調で、白鷹夫人が私の一家に対して警告してくれたものであった。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方にその後、警官や刑事諸君が遊びに来ての話によると、彼女は向家の蕎麦屋にいる活弁上りの出前持を使って電話をかけさせておったものだそうで、白鷹助教授に化けて東京から電話をかけたのもその弁公だったそうである。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "両親には風邪気味と申しましたので、夕方になって、近所に住んでおられる大学の助教授さんとか言う、若いお医者さんを呼んでくれましたが、別に何処と言って悪い処は御座いませんし、熱も何もなくて、脈も変っていなかったので御座いましょう。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "松下生」　松下というのは、丘よりも一年前に卒業した助教授の名だった。",
              "citation": {
                "source": "キド効果",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その折環女史と差向ひに、腰かけてゐたのは、京大の助教授浜田青陵氏だつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "女流声楽家三浦環女史が倫敦に居る頃、女史の周囲には医者や、銀行員や、外交官や、大学の助教授やが油虫のやうに寄つて集つて、御機嫌取りに色々の進物を女史の足もとに持ち運んで来たものだ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「怪しからん、一｜片位僕にも裾分けしたつてよかりさうなもんぢやないか」と近眼の銀行員が側にゐる助教授の耳許で呟いた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と助教授は相手をなだめながら皆の顔を見た。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　助教授は皆の眼のなかに、こんな言葉を読む事が出来た。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう芸術品ほか持得ない感銘の活々とした歓喜を以て、「助教授Ｂの幸福」「盧生の夢」等の御作を拝読しますと、私は種々の考えに打たれずにはいられなく成りました。",
              "citation": {
                "source": "野上彌生子様へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「助教授Ｂの幸福」の中には、貴女が一個の芸術家として自己を御認めになりながら、一方では、人間的興味、感動による観察、表現よりも、もっと心理的に直接な、本能的潔癖に触れた、というような心持を感じます。",
              "citation": {
                "source": "野上彌生子様へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
