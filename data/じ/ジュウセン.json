  {
    "uuid": "7038dada-57d1-5552-a6a4-3b0f1dffa50a",
    "entry": "縦線",
    "reading": {
      "primary": "じゅうせん",
      "alternatives": [
        "たてせん"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
