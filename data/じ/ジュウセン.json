    },
    "definitions": [
      {
        "index": 1,
        "gloss": "vertical line",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一より九に至るの数を九格正方内に一つずつ置いて、縦線、横線、対角線、どう数えても十五になる。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一より十六を正方格内に置いて縦線、横線、対角線、各隅、随処四方角、皆三十四になる。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」此「而」の字の中の縦線二条が右辺に逸出してゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "己巳席順に養玄の右傍に「待蔵」と註したのを見るに、啻に縦線を以て養玄の二字を抹してゐるのみならず、線は上「西」字にも及んでゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口は西にあって、墓は※［横線に長い縦線四本の記号、上巻-241-12］形に並んで居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その次の、第二の縦線（途中段を持って釣針のように曲った線）も殆ど同じ味である。",
              "citation": {
                "source": "現代能書批評",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "故にこの均衡は、支点が縦線上の重心より下にある物体の均衡に比すべきもので、もし重心が縦線を離れるとすると、ますますこれを遠ざかり、これを支点の下に置くのでなければ、自ら重力によっては復帰をしない。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての漢字を正方形の枠の中に入れ、横線は全部水平、縦線は全部垂直、斜線は四十五度の方向に引くという書道なのである。",
              "citation": {
                "source": "字の書き方",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最大水深を示す数字が見たところ池の中心にあるのに気がついてわたしは定規を縦にあて、それから横にあてて、最大縦線が、最大横線と正確に最大水深の点で交叉しているのを発見しておどろいた。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "――中央部はほとんど平坦にちかく、池の輪郭は決して規則的ではなく、かつまた、最大縦線も最大横線も入江までこめて計ったのにもかかわらず。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして最大横線は、そこで二つの相対する突角がお互いに接近し、二つの湾が引込んでいる最小横線のごく近くにきたので、わたしは試みに後の線から少しはなれておるがやはり最大縦線のうえにある一点を最深点として印しをつけた。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "横線が細くて縦線が太いといふ点だけは、その必要がないから除外すれば、おほよそ理想的な形体といつてよい。",
              "citation": {
                "source": "秋艸道人の書について",
                "author": "吉野秀雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それぞれの頁の左に、見出しを書くためだろう、牡丹色の縦線がひかれている。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伏テ望ムラクハ陛下深仁深慈、臣ガ狂愚ヲ憐レミテ、少シク乙夜ノ覧ヲ垂レ給ワン事ヲ」　正造はここで「狂愚」の「狂」に縦線を引いて傍に「至」と書き入れ、捺印して次へ移った。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "古徳と同じゅうせんと欲するは、是れ仮にして、淮楚浙東に往来せるも、修行の為なりしや游覧の為なりしや知る可からず。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "久七峠の上の、茶店に、七八人の若者が――それは、脱藩をして、江戸へ、益満等と共に、行を同じゅうせんとする人と、京師へ出て、諸国有志と、提携しようとする人と、そうして、見送りに来た人と――「爺は、いつも変らぬのう」「はい――」「婆は、何うした？",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
