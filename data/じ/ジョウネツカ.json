        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自分たち詩人の仲間は、すべてが單純な情熱家であり、客觀的な觀照眼を殆んどもたない。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "實に芥川君が、それほど眞の詩人的な情熱家であることを、かつて私は氣がつかなかつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一たい、おまえは私に似て情熱家肌の純情屋さんなのに、よくも、そこを矯め堪えて、現実に生きる歩調に性情を鍛え直そうとした。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷笑癖のある友人と連れ立った情熱家。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら彼は、極めて詩人的なるロマンチックの情熱家で、生涯を通じて夢を追い、或る異端的なる美のユートピアを求めていたから。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに彼の兄｜行平に至っては、一層詩人的な情熱家であったにかかわらず、詩人としては殆ど無能で、漸く末流の才能しか持ってなかった。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏蘭西啓蒙期の詩人ウォルテルの如きも、非常に実利的で利殖に抜け目のない人物でありながら、しかも当時一流の人間的情熱家だった。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父のあの負けず嫌いな情熱家の筋をひいているためでしょうか、それとも母の老獪に籠っている執拗さが伝わっているためでしょうか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なるほど、貴女は情熱家だ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬は青いものがみんな雪の下に隠れてしまふので、情熱家達はその憂鬱な感情の捨場に苦るしんだ。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "感激というようなものは、生まれる時に母親の腹の中に忘れてきたような顔をしている、それでいて非常に熱心で、現代には稀に見る情熱家で、凝り性であるらしい。",
              "citation": {
                "source": "江戸川乱歩",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、われわれの前兆の悪い馴れそめの第一日から、私はアグネスという女は非常な情熱家で、男まさりで――まあ、しいて言うなら――私よりも純な感情を持っているのを知った。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりおせつかい好きな小動物達の見込違ひであるのみならず、また偉大な情熱家であるあの太陽の意図違ひでもあるのだ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ一途なる情熱家である自分自身に、あはれみ以外のものを感じたくない――のは人情であらうよ。",
              "citation": {
                "source": "Ｒ漁場と都の酒場で",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはそれとして、あゝ私は、常に、何といふ哀れな情熱家であることよ！",
              "citation": {
                "source": "Ｒ漁場と都の酒場で",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの男、情熱家のようだね。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は仁田さんが天真な情熱家で、そして自由な人であることを知って段々敬愛を増して行った。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは僕に親切だった友人の死んだ為と言うよりも、況や僕に寛大だった編輯者の死んだ為と言うよりも、寧ろ唯あの滝田君と言う、大きい情熱家の死んだ為だった。",
              "citation": {
                "source": "滝田哲太郎氏",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの情熱家が冷たくなるのは難しいよ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方三之丞は情熱家、家庭の風儀が厳しかったので、悪所へ通ったことがない。",
              "citation": {
                "source": "柳営秘録かつえ蔵",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この二人の病人、この二人の純潔な情熱家、この二人のいたるところを漂泊する孤獨者の間には、魂の血縁といふやうなものがありさうである。",
              "citation": {
                "source": "Ombra di Venezia",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは真に価値のあるものを作り出す情熱家。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "和泉式部の様な情熱家の作物は、さすがに不純を一挙に捲き飛した佳作が尠くない。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、院ほど情熱家ではない。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "情熱家ではあり正義派ではあり、才気煥発でもあったけれど、若いだけに性急であり、これが唯一の欠点であった。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三郎兵衛は正雪の股肱として、思慮深遠智謀衆秀と、こう称されていた人物であったが、一角はむしろ情熱家で、実行力には富んでいたが、思慮にはむしろ欠けていた。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の独身の情熱家であった。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシヤ人のやうに粗暴きはまる情熱家で、のんだくれで、それゆえ単純な、子供つぽい男であつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
