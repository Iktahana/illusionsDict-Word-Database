    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gill (unit of volume)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "英国人のオージルヴィ君や、ルーマニアのギリッチ君などとよく教室入口の廊下で立話をした。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年の八月にはスコットランドに旅してアルジル公の客となり、ヨットに乗って「長湖」に浮んだり、公爵の子供の時に見たという狐火（will-o'-the-wisp）の話に興味をもったりした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジル・マルシエツクスの告別演奏會が公會堂にあるので皆で出掛け、其處で外山楢夫先生、外村完二氏にお會ひした。",
              "citation": {
                "source": "講演會　其他（大正十五年二月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒い晩でジル・マル氏の鼻が赤くなつてゐた。",
              "citation": {
                "source": "講演會　其他（大正十五年二月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラジルへでも行ってみせる。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべはジルヴェスターアーベンドというので、またバウムに蝋燭をともしました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、珈琲といえば、今日の大阪の盛り場（というのは、既にして闇市場のことだが）には、銀座と同じように、昔の香とすこしも変らぬモカやブラジルの珈琲を飲ませる店が随分出来ている。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "別府じゃろくな店もおまへんが、まあ『ブラジル』やったら、ちょっとはましでっしゃろか」　土地の女の顔を見て、通らしく言った。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなりあたりが明るくなり、ブラジルの前まで来た。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "本物のブラジル珈琲やぞ」　豹吉が言うと、ブラジル珈琲とはどんなものか、二人にはまるで判らなかったが、びっくりしたような眼を、一層くるくるさせて、「ほんまか、大将！",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人はポオの『アッシュル館の没落』や、メーテルリンクの『タンタージルの死』を読む時に、小説や戯曲を読むというよりは、むしろ全くの純粋の詩を読んでいるような感がする。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼女が裸に矢飛白の金泥を塗って、ラパン・ア・ジルの酒場で踊り狂ったのは新吉の逢った二回目の巴里祭の夜であった。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラジル、アルゼンチン等に到りし話も聞きたれば、斯く思はるゝ也。",
              "citation": {
                "source": "秘魯國に漂著せる日本人",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで巨大な地下シェルター作りを試みて失敗し、それにもめげず妻子から複数の妾総ぐるみで最も安全性の高いと信じるブラジルへの移住計画を腕力で推し進める。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでこれはもう、オレもブラジルにでも逃げるしかないかなと思ったのだが、いつかあの国でマッキントッシュの互換機を作った連中がいてアップルコンピュータが血相を変えたという話があったよな。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "シカシナガラ、我輩ハ君ヲ深ク信ジル。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（私は一五四八年の復活祭の前夜バジル神学校の寄宿舎で彼と食卓を囲んだ。",
              "citation": {
                "source": "痴酔記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "（神が、悪魔の屍を上向きに置かざらしめぬのは、神が、吾らをしてメフィストの奴僕たらざらしめんが為の誡めなり――と神学者ヨハンガストが、バジル神学校でファウスタスに会見後、悪魔に絞殺された彼の屍の位置を指して、その談話録の中に述べてゐる。",
              "citation": {
                "source": "痴酔記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらいずれも大河に住んでよほど大きな爬虫らしいからは只今アリガトル・シネンシスとクロコジルス・ポロススと二種知れいるが、地方により、多少の変種もあるべく、また古ありて今絶えたもあろう。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも虚譚らしいが、これにやや似て実際今もあるはブラジルのカンジル魚だ。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど我自ら三千以上のを混じたようだが、本コッカトリセなる語はクロコジル（の顔至って醜きより生じたのであろう。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "この話はその後ルサージュの『ジル・ブラース』などにも採用されおり、これに類した驢が人に遺産した話は十三世紀の欧州既にこれあったとアクソンの説だ（『ノーツ・エンド・キーリス』十輯十一巻五〇一頁）。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "またロージル村に夥しく鼠生じて、穀物、牛乳、牛酪、乾酪口当り次第平らげたので、住民途方に暮れ猫を多く育てたが、猫一疋に鼠二十疋という多数の敵を持ちあぐんで気絶せんばかりに弱り込んだ。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはアメリカからブラジル、それから大陸にわたつて、イギリス、フランスと浮浪して歩いたやうな人であつた。",
              "citation": {
                "source": "夏",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "私ノ山ハ私ガ実際ニ感ジルヨリモアマリ平面ノヨウデス。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "□幹彦氏の見た祇園はジルエットのやうにたよりないものだと京都児は云ふ。",
              "citation": {
                "source": "TZSCHALLAPPOKO",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ラディックのスネアと、ジルジャンの一八か二〇インチ、それにハイハットぐらいは買おうと思ってさ」　服部は、慶一の嫌みには気づかなかったように、すましていう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラディックのスネアに、ジルジャンのシンバル！",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
