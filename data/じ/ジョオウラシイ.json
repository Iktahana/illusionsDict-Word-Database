        "examples": {
          "standard": [
            {
              "text": "彼女の落ち着いた物腰と威厳は、まさに女王らしい佇まいでした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "そのドレスは、女王らしい華やかさと上品さを兼ね備えています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この子、お人形遊びでもいつも女王様役なんだ。仕草が女王らしいね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "まったく姐御らしい、女王らしい性格であった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "津田の不在から起るこの変化が、女王らしい気持を新らしく彼女に与えると共に、毎日の習慣に反して貪ぼり得たこの自由が、いつもよりはかえって彼女を囚えた。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
