        "examples": {
          "standard": [
            {
              "text": "ダムの建設によってできた人工湖（じんこうこ）は、地域の水源として重要な役割を果たしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "人工湖の周辺は、美しい景観から観光地としても人気がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この人工湖（じんこうこ）でボートに乗ると、とても気持ちがいいよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ダムによって出来た人工湖も、観光地になっている。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "人工湖の、深く濃いブルーの水面が、じっと動かずに冬のはじまりの陽をうけ、山影を映している。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
