        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼の別の句愚に耐えよと窓を暗くす竹の雪　もこれとやや同想であり、生活の不遇から多少ニヒリスチックになった、悲壮な自嘲的感慨を汲むべきである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっはっはは」　話し手の男は自分の話に昂奮を持ちながらも、今度は自嘲的なそして悪魔的といえるかも知れない挑んだ表情を眼に浮かべながら、相手の顔を見ていた。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、刺青にものを云わせて生きて行く生活しか、あたしに残らなかったのさ」　兵古帯のお加代の眼はまたうるみ、声もうるんだが、あわてて自嘲的な笑い声を立てて、「――あら、随分喋っちゃったわね。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "李徴の聲は併し忽ち又先刻の自嘲的な調子に戻つて、言つた。",
              "citation": {
                "source": "山月記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "李徴の声はしかし忽ち又先刻の自嘲的な調子に戻って、言った。",
              "citation": {
                "source": "山月記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ女房を探して……」　町という町からア、丘という丘を、あちらをも、こちらをも、探すは上海リル……という唄の文句を、自嘲的に口ずさみかけた途端、「あッ！",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふとした拍子に豹一が自嘲的に思い泛べた表現を借りていえば、そんな風に多鶴子の「食客」となって、二週間経った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "自嘲的な思いに眠りなどにははいりきれなかった源氏は物音にすぐ目をさまして人の近づいて来るのを知ったのである。",
              "citation": {
                "source": "源氏物語",
                "author": "紅葉賀",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが……」というと自嘲的になった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と彼は半ば自嘲的に云つてゐるが、ただそれだけのものであらうか？",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、今日を明日へ押しすすめるべき未熟な、酸苦くはあるがそれが核であることだけは確であった世界観のよりどころを、自分の手で文学から追放してしまった人々は、自嘲的になった自己の内部に十九世紀のリアリストたちの情熱すら抱き得ない有様である。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」たえ子は躊躇気味で自嘲的に言つた。",
              "citation": {
                "source": "復讐",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点での現代の若い女のひとの自嘲的な賢さというものを、それらの人たちは何と見ているだろう。",
              "citation": {
                "source": "新しい船出",
                "author": "――女らしさの昨日、今日、明日――",
                "note": "青空文庫"
              }
            },
            {
              "text": "サラリーマンの生活の下らない、希望のなさ、その日暮しの味気なさについて流行歌まであるのだが、若いサラリーマンたちが、自分たちの生活の無意味さを自嘲的に喋るところだけに、自分のインテリゲンツィアである微かな誇りをもっていることが、私には本当に口惜しい気がする。",
              "citation": {
                "source": "若き時代の道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "安重根　（自嘲的に）ふん、おれは家族を迎えにハルビンへ行くんだ。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（自嘲的に）祖国の恨みを霽らして独立を計るため――ふふん、第一、国家より先に、まずこの安重根という存在を考えてみる。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃の社会の事情は女としての困難解決の方向を知っているひとでも目前に方法がつかないような特殊の苦痛がありますが、どうかその苦痛にまけたことを一つの自嘲的なポーズとせず日々の努力をのぞみます。",
              "citation": {
                "source": "現代女性に就いて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝、箪笥を売払つてさつぱりしたところなのです」　女は自嘲的な調子で狭い部屋を見廻した。",
              "citation": {
                "source": "災厄の日",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉本は自嘲的に自分の職業を三つの単語で合唱する――「べからず、いけない、なりません」そいつにぐわんと抗議して川上忠一は教室をとびだして行った。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何んの馬鹿らしい、考えてみれば、せっかく昆虫館をさがし中てた結果、いったい何を得たかというに、あの『騎士よ』という言葉だけだったってものさ」　自嘲的にならざるを得なかった。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうもこいつは驚いたなあ」心が静まるに従って、弓之助の心は自嘲的になった。",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その側で私は、もしあなたと結婚したら……などと自嘲的に考えながら、ともすると暗い気持に沈むのだった。",
              "citation": {
                "source": "常識",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのお兄さん……」　こんな話をするにしても、或は、真面目に訴へる如く、或は、自嘲的に戯談めかして、或は、快活にうれしさを包まず、同じことを、同じ心持で云へるのである。",
              "citation": {
                "source": "言葉の魅力［第一稿］",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人生にも、シャレたことがあるものだ」　いさゝか自嘲的ではあつたが、さして不快といふわけでもない。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の一生なんか、どうにでも、勝手になるがいいや」　女は遊びのあとには、特別自嘲的になることが多かつた。",
              "citation": {
                "source": "私は海をだきしめてゐたい",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、ほとんど誰でもが云はれてみれば気がつくやうに、「花より団子」とは、一種の自嘲的諷刺であり、少くとも、花見といふのに、花はそつちのけで、食ひ意地ばかり張つてゐる人間を軽く嗤つた、庶民の気取らない自己批判であります。",
              "citation": {
                "source": "青年の矜りと嗜み",
                "author": "――力としての文化　第四話",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一変して、半ば皮肉な半ば自嘲的な調子になった。",
              "citation": {
                "source": "野ざらし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の一生なんか、どうにでも、勝手になるがいいや」　女は遊びのあとには、特別｜自嘲的になることが多かった。",
              "citation": {
                "source": "私は海をだきしめていたい",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫　　（突然自嘲的に笑ふ）妻　　（夫の顔を見る）夫　　あれで、あの男、おれをどう思つたらうね。",
              "citation": {
                "source": "明日は天気（二場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（自嘲的に）「とまあいった次第で、つまりそのありまして、そのう、ええと……」といったざまでな、なんとか締めくくりをつけよう、つけようとして、大汗かいたものさ。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
