  {
    "uuid": "e98958aa-db1e-5ef4-b710-4e3d29faf34e",
    "entry": "女皇",
    "reading": {
      "primary": "じょこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
