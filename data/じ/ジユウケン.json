        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "就中儂の、最も感情を惹起せしは、新聞、集会、言論の条例を設け、天賦の三大自由権を剥奪し、剰え儂らの生来かつて聞かざる諸税を課せし事なり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、諾、否を与えるのは、最後の女性の自由権です。",
              "citation": {
                "source": "男女交際より家庭生活へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな意味で、われわれフアンテエジストのためには、釣りが何よりの自由権であり、夢想郷への形影問答でもある。",
              "citation": {
                "source": "釣れない時",
                "author": "君は何を考へるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを「自由権」というのです。",
              "citation": {
                "source": "あたらしい憲法のはなし",
                "author": "文部省",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし基本的人権は、こゝにいった自由権だけではありません。",
              "citation": {
                "source": "あたらしい憲法のはなし",
                "author": "文部省",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由権だけで、人間の國の中での生活がすむものではありません。",
              "citation": {
                "source": "あたらしい憲法のはなし",
                "author": "文部省",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
