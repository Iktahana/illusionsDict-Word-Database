    "definitions": [
      {
        "index": 1,
        "gloss": "room with a raised floor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
