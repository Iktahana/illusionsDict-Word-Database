[
  {
    "uuid": "2a4e1406-1f6a-5571-afc3-3235cc35039f",
    "entry": "持久",
    "reading": {
      "primary": "じきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
