        "examples": {
          "standard": [
            {
              "text": "彼の言動には、根深い女性嫌悪が垣間見え、周囲を不快にさせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "私たちは、社会に蔓延る女性嫌悪に対して、断固として反対の意を表明すべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このドキュメンタリーは、歴史的背景や心理的要因から女性嫌悪を分析している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "――彼は大体に於いて、女性嫌悪症の患者であると自覚してゐるのみであつた。",
              "citation": {
                "source": "茜蜻蛉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストリンドベルヒのような女性嫌悪を装った人にもなおつつみ切れぬものは、女性へのこの種の徳の要請である。",
              "citation": {
                "source": "学生と生活",
                "author": "――恋愛――",
                "note": "青空文庫"
              }
            }
          ]
        }
