    "definitions": [
      {
        "index": 1,
        "gloss": "sizzling (of cooking meat, fat, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "残らず、薄樺色の笠を逆に、白い軸を立てて、真中ごろのが、じいじい音を立てると、……青い錆が茸の声のように浮いて動く。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "じいじい蝉がまたそこらの木立に熬りつき出した。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "じいじい蝉の声も時には雲と梢を閑かにする。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋燈が、じいじいと鳴る。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "木立のところどころで、じいじいという声がする。",
              "citation": {
                "source": "杯",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝉はじいじいと鳴いている。",
              "citation": {
                "source": "杯",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁の下でじいじいと刻んでゆくような虫の声が又もや耳についた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "じいじいと怪しく灯ざしが鳴いたかと見るまに、またパッと灯りが消えた。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとともに、暗かったへやの中には、けはいを知った娘の手によって、あわただしく短檠がともされ、じいじいと陰に悲しく明滅するあかりのもとに、その姿のすべてがパッと浮かび上がりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "じいじいじいと、放電のような音もきこえる。",
              "citation": {
                "source": "宇宙女囚第一号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙管の針の先きで、飴のような阿片の丸が慄えながらじいじいと音を立てた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然、頭の上でじいじいと油蝉が鳴き出した。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "互に視線を避け合っている笑顔の間で、ランプのホヤがじいじい静かに蝉のように音を立てた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になってじいじいとやかれた時には、くろだいのはだからおいしそうなあぶらが出ていました。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんはみかけによらぬ料理好きで、ちょいちょいと短時間にうまいものをつくる才能があって、火鉢でじいじいと炒ためてくれるハムの味、卵子のむし方、香のもの、思い出して涎が出るのだから、よっぽど美味かったのに違いない。",
              "citation": {
                "source": "朝御飯",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "炉の上へ雪が降つて居るのではなくて、是れは暖炉の縁などへ雪の塊りが置かれて居て、じいじいと音がして解けて行く趣きである。",
              "citation": {
                "source": "註釈與謝野寛全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうあと一週間で、この地球が粉々にとびちってしまうというのに、博士は何をそんなに熱心に研究しておられるのですか」　博士はしきりに電気火花をじいじい言わせて、ガラス管の中にある青黒い紐のようなものにあてていた。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしの研究の、じゃまをしてはいかん」　博士は、目盛を直しては、またじいじいと電気火花をとばし、ガラス管の中をのぞきこんでいる。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにかじいじいじいと妙な音がしている。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、部屋の中から、じいじいじい、じいじいじいというかなり高い物音がひびいてきた。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ扉の向うでは、あいかわらずじいじいじいと奇妙な物音がしつづけであった。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫色の電灯がかすかな光をだしているだけで、どこかでしきりにじいじいじいと変な音がしていた。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそ、あまりふしぎで、気もちがわるくて仕方がないよ」　そういっているとき、小食堂の天井にとりつけてあるブザー（じいじいと蜂のなくような音――を出す一種の呼鈴）が鳴りだした。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
