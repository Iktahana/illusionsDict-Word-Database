    "definitions": [
      {
        "index": 1,
        "gloss": "Buddhist temple within a Shinto shrine",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "延寿王院（神宮寺といふ）に入りて菅公真蹟を拝観す。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "……とにかくもう少し西南寄り、神宮寺の方で潜って見やしょう」「そうか。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若殿のご座船を先頭にして神宮寺の方へ進んで行く。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「神宮寺の方へ行くようだね」「これはどうも物騒千万、死地へ乗り入ると同じようなものだ」「死地に乗り入るは大袈裟だが、どうも少々心なしだな」「水狐部落の巫女どもに悪い悪戯でもされなければよいが」「あいつらと来たら無鉄砲だからな。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一七　若殿のご座船を先頭に、二十隻の船は駸々と、湖水の波を左右に分け、神宮寺の方へ進んで行ったが、やがて目的の地点まで来ると、頼正は扇で合図をした。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "向かう行手は神宮寺であろう。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポンと潜った葉之助は、昼間あらかじめ調べて置いた、野良の細道をサッサッと神宮寺村の方へ歩いて行く。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「生れは神宮寺、名は久田……」「え？",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖水に添って田圃路を神宮寺村の方へ歩いて行く。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "身毒は、住吉の神宮寺に附属してゐる田楽法師の瓜生野といふ座に養はれた子方で、遠里小野の部領の家に寝起きした。",
              "citation": {
                "source": "身毒丸",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "源内法師はこれまで走り使ひにやり慣れた神宮寺法印の処へさへも、身毒を出すことを躊躇した。",
              "citation": {
                "source": "身毒丸",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "神宮寺の道心達の修業も、こちとらの修業も理は一つだ。",
              "citation": {
                "source": "身毒丸",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは、今度こそ帰つたら、お師匠さんに願うて、神宮寺か、家原寺へ入れて貰はうと思うてる。",
              "citation": {
                "source": "身毒丸",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にしても「曲舞」の寺出自なるに対して、多くは社及び神宮寺を仰いだ一流である様である。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "八幡の神宮寺などにも、童子村の大きいのがあつた。",
              "citation": {
                "source": "信太妻の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其寺は、大方四天王寺であらうが、ひよつとすれば、住吉の神宮寺かも知れない。",
              "citation": {
                "source": "信太妻の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この説は眉ツバモノだと他のチベット学者の説もあって真偽は知らないが、高千穂神楽の日の舞いにはシバ荒神などというのが現れてなんとなく印度の荒れ神様との関連などを感じさせるものがあり、むかし神宮寺のあった地名をセ別当と云いならわしており、セの字に当る漢字は古老も知らない。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とまた半蔵の声で、「まあ、諸国の神宮寺なぞをのぞいてごらんなさい。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "神前に誦経が行われ、神社の境内に神宮寺が建てられたのも、皆神が悦んで仏法の供養を受け納めるという考からであったことは前述の通りである。",
              "citation": {
                "source": "山の今昔",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして延暦三年の五月、この勝地に神宮寺が建てられたのであった。",
              "citation": {
                "source": "山の今昔",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは人から伝え聞いた話で、どれほど確実であるかはわからないが、もとこの像は三輪山の神宮寺の本尊であって、明治維新の神仏分離の際に、古神道の権威におされて、路傍に放棄せられるという悲運に逢った。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽後の神宮寺町の附近に細く高い二坐の岩山が孤立するのを、男ツクシ山・女ツクシ山という。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋田から横手に繋がる線路の中頃に神宮寺という小駅がある。",
              "citation": {
                "source": "現在の日本民窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この口よせのいうことは、一向とりとまりはないが、その文句のうちに、「口惜しい悲しいで気がとりつめ」とか、「この魂が跡を追いかけて引き戻してくる」とか、「東は神宮寺、西は阿礼の社より向うへは通さぬ」とか、髪をふり乱し、五体をわななかせ、油汗を流して、呪わしい言葉を口走っている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "神宮寺という駅から少し南に行ったところに楢岡と呼ぶ村があります。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小田内通敏君が聴いてきて教えてくれた話には、秋田市楢山に住む丹生某氏、狩が好きで方々をあるき、或る年仙北郡神宮寺山の麓の村で、人の家に一泊したところ、一つの紙袋に少しの砂を入れたのが、神棚に載せてあった。",
              "citation": {
                "source": "山の人生",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽後の神宮寺の道祖神を始とし、祭の日に神体に米の粉をふりかけるというなども、乾いた粉の得にくかった時代には、やはりこのオノリを注いだものと思う。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほどなく、他の一族たちも遠地の――和田、橋本、神宮寺――などを除くほか続々この夜の“御本屋会議”に参集してきた。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこまでもお連れください」「おう正季たちか」　正成のそばには、松尾刑部、神宮寺正師、安間了現など六、七人の同族がかこんでいた。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "正成の弟正季、一族の神宮寺正師、佐備正安らの河内きッての精鋭は、「今ぞ」　という正季の一令をべつな所で受けていた。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
