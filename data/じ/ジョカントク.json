    "definitions": [
      {
        "index": 1,
        "gloss": "assistant director (in taking professional movies)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
