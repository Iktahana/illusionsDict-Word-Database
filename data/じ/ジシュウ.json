  {
    "uuid": "85b741b6-e564-5b09-8295-1a0b39cfc5ae",
    "entry": "自宗",
    "reading": {
      "primary": "じしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "one's religious sect",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "当時の仏教は倶舎、律、真言、法相、三論、華厳、浄土、禅等と、八宗、九宗に分裂して各々自宗を最勝でありと自賛して、互いに相｜排擠していた。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一切経を披き閲すること数遍に及び、自宗他宗の書物眼に当てないというものはなかった。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "他宗の者から聴かされた智恵が、自宗で習い伝えた義理に立ち越えている」といって随喜感歎甚だしく、法談数刻の後、法然は特に乞うて華厳宗の血脉並に華厳宗の書籍などを渡された。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
