[
  {
    "uuid": "290f5272-9386-50ad-8c64-71fbca6a4acf",
    "entry": "自習",
    "reading": {
      "primary": "じしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "self-study",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "而も学生は皆登校し、自学自習すること常のごとし。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "人数に比べて部屋の数が多過ぎるので、寄宿舎は階上を自習室にあて、階下を寝室にあててあった。",
              "citation": {
                "source": "死屍を食う男",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "安岡は前夜の睡眠不足でひどく疲れていたので、自習をいいかげんに切り上げて早く床に入った。",
              "citation": {
                "source": "死屍を食う男",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私が、自習室へ入つて行つた時に恰度其処では斯んな相談が可決されたところだつた。",
              "citation": {
                "source": "塚越の話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自習時間は七時から九時五〇分までで、あいだに三〇分の休憩がある。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ自習時間だっていうのに。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつらは、「特別クラブ活動」と称して、自習時間中に、堂々とロックンロールを聴いている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "学園祭まえの一週間は、自習時間なしだ」「そうなの！",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ自習時間中に部屋にいたとしても、掃除の時間になると、ギター・ケースをもって、どこかへ消えていく。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そろそろ、自習時間です。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になればなったで、こんどは自習時間というやつがあるので、夕食後の三〇分と、八時半からの休憩の三〇分しか、自由になる時間はない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この曹長はよく妙な手帳をひろげては、自習室を廻ってみんなの顔とそれを見くらべていた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ターニャはその時、おかっぱを活溌にふりながら、自習時間がやかましいことや、自治に対してみんなが無責任だ。",
              "citation": {
                "source": "ワーニカとターニャ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その目的ゆゑに親から強請した小遣銭で室長に絶えず気を附けて甘いものをご馳走し、又言ひなり通り夜の自習時間に下町のミルクホールに行き熱い牛乳を何杯も飲まし板垣を乗り越えて帰つて来る危険を犯すことを辞しなかつた。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちやうど顔ぢゆうに面皰が生じ、自習室の机に向いても指で潰してばかりゐて、気を奪はれ全然勉強が手につかなくなつた。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "週三回、専門学校で学ぶことをフォローしていくには、家でかなり自習する必要がある。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは「けふの自習課題」と申すものに之有候。",
              "citation": {
                "source": "伊東から",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "小生、今朝ふと応接室へ参り候所、この影の薄き少女、籐のテエブルの上へのしかかり、熱心に「けふの自習課題」を読み居り候。",
              "citation": {
                "source": "伊東から",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "小生は勿論「けふの自習課題」の作者に芸術的｜嫉妬を感じ候。",
              "citation": {
                "source": "伊東から",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の字引は、学生自習辞典と云うので、これは、私が四国の高松をうろうろしていた時に七拾五銭で買ったもの、もう、ぼろぼろになってしまっている。",
              "citation": {
                "source": "生活",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自習にして下さいって」「じゃ、いよいよ本当なんだわ、まア！",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "教室には自習を始める気分など無かった。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "予科では、三田の出る筈だった時間に、カキがやって来て、三田先生は一身上の都合で地方へ転任するのだから、いろんな噂を信じないようにと云って、自習を暫く監督して行った。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓｜硝子の破れた自習室には生憎誰も居合せなかった。",
              "citation": {
                "source": "彼",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は山田には内密でこつそりフランス語の自習をしてゐたので、特に耳を澄ませてそれを理解しようと骨を折つた。",
              "citation": {
                "source": "道化芝居",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は鎌倉へ行ってから水泳を自習し始めて、今では背の立たない所まで行くのが楽みだと云った。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云つて、先生が二年生の前の教壇に立つた時には、もう一年生は読方の自習か、書取をさせられてゐるのでした。",
              "citation": {
                "source": "先生と生徒",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る時などは、先生が病気のために一日中自習をさせられ、また或る時などは、何年生は一体に字が下手だからと云ふので、毎日々々習字ばかりさせられたりしました。",
              "citation": {
                "source": "先生と生徒",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、友人達が出かけていった後、がらんとした広い自習室に一人残って、ぼんやり考えるのであるが、それが変に頼り無いので、のこのこ寝室に上っていって、自分の寝室に寝そべってみたり、窓縁にもたれてみたりして、とりとめもない夢想のうちに坐り通すのである。",
              "citation": {
                "source": "春",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼にとっては、夜分寝室が息苦しいと同じ程度に、昼間は自習室が変に威嚇的に感じられるのである。",
              "citation": {
                "source": "春",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "studying by oneself (at school) while the teacher is absent",
