        "examples": {
          "standard": [
            {
              "text": "その現象は、現代科学では説明できない、まさに人知を超えた出来事だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "広大な宇宙には、私たちの想像をはるかに超える、人知を超えた存在がいるのかもしれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の芸術作品は、人間の感性や思考の限界を押し広げ、人知を超えた領域に到達している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その源は、時の彼方の、人知を超えた、光なき複数の部屋。",
              "citation": {
                "source": "ニャルラトホテプ",
                "author": "NYARLATHOTEP",
                "note": "青空文庫"
              }
            },
            {
              "text": "喉から出かかった苦痛をぐっとこらえたが、人知を超えた。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
