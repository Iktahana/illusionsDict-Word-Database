    "definitions": [
      {
        "index": 1,
        "gloss": "Festival of Emperor Jimmu (formerly held annually on April 3, the supposed day of his death)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "例へば紀元節、神武天皇祭等時日一定せる者は論を俟たず、氷店を夏とし焼芋を冬とするも可なり。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "神武天皇祭、日本的！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年から新たに祝日と定められた四月三日は、木曾路で初めて迎える神武天皇祭である。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日（神武天皇祭）、雨終日やまず、かつ寒し。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、堅実なる第二国民の養成を天職とする全国二十五万の小学校教員は、三万六千余名の代表者を送って、昭和聖代の御慶事　皇太子殿下の御降誕を奉祝し併せて忠君愛国の日本精神を昂揚して教育報国の誠を示す処の小学教員精神作興大会をば、神武天皇祭（四月三日午後二時）を期して宮城二重橋前広場で持つことになった。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "（神武天皇祭の日）けさ起きて雨戸をくれば朝日照り連翹の花ひらきそめたりいつの間にか連翹の花さきにけり莟みおそしとかこちたりしをわがめづる連翹の花さきにけり五日六日の旅ゆかへれば留守のまを連翹の花さきにけりきけばきのふの朝ゆさきぬと",
              "citation": {
                "source": "連翹の花",
                "author": "新村出",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
