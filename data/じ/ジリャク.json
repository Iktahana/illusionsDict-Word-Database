          "standard": [
            {
              "text": "治暦年間は、平安時代後期に存在した日本の元号です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この時代には、数々の出来事が起こり、歴史書に治暦の記録が残されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「治暦の時代背景を理解すると、当時の社会情勢がより鮮明に見えてくる」と、歴史学者は語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "又革卦に於て初九に黄牛之革といひ、九五、上六に、大人虎變、君子豹變といふ辭のあるのは、明らかに皮革の革の義であるらしく見えるが、彖傳では天地革而四時成、湯武革命などゝいひ、象傳で治暦明時の義に解釋するのは、いづれも元來の意義でないやうに考へられる。",
              "citation": {
                "source": "易疑",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            }
          ]
        }
