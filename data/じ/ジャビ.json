        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "永禄あるいは文禄年間に琉球から伝わった蛇皮線を日本人の手で作りかえた、それがだんだんポピュラーになったものらしい。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは蛇皮を脱ぐの類で、一旦はあれ丈の自己革命をやつて見ないと収まらなかつたのである。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "何處やらで單調な琉球蛇皮線の音がする。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベコンベコンといふ間ののびた蛇皮線の音は相變らず聞えるが、何處の家で鳴らしてゐるのか、一向に判らぬ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "出た角の所に劇場があつて、其の中から頻りに蛇皮線の音が響いて來る。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処やらで単調な琉球蛇皮線の音がする。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベコンベコンという間ののびた蛇皮線の音は相変らず聞えるが、何処の家で鳴らしているのか、一向に判らぬ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "出た角の所に劇場があって、その中から頻りに蛇皮線の音が響いて来る。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私達は並ひの蛇皮の腹帯を絞め直して、何故かまた今日に限つて、妾をかくまつて呉れ、そして出立の時に伴にして呉れ！",
              "citation": {
                "source": "武者窓日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "大道芸人の笙を吹くもの、蛇皮線をひく者、四つ竹を鳴らす者なども集まっている。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤマアラシの針の模様のように見えたし、あるときは蛇皮の筒のようであった。",
              "citation": {
                "source": "死生に関するいくつかの断想",
                "author": "BITS OF LIFE AND DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "男達は彼の家の前にある、大きな榕樹の蔭の広場に集って昼から泡盛を飲んだり、蛇皮線を弾いたりして騒いだ。",
              "citation": {
                "source": "奥間巡査",
                "author": "池宮城積宝",
                "note": "青空文庫"
              }
            },
            {
              "text": "男達が、肌を抜いて歌ったり、踊ったり、蛇皮線を弾いたりして居る周囲には、女達が集って来て、それを面白さうに眺めて居た。",
              "citation": {
                "source": "奥間巡査",
                "author": "池宮城積宝",
                "note": "青空文庫"
              }
            },
            {
              "text": "静かな夜の部落の森に、歌声、蛇皮線の響、人々のさざめき合ふ声が反響して、何時までも止まなかった。",
              "citation": {
                "source": "奥間巡査",
                "author": "池宮城積宝",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の辺の人のやうに蛇皮線を弾いたり、琉球歌を歌ったりするのでなしに、茶腕や皿を叩いて、何やら訳の解らぬ鹿児島の歌を歌ったり、詩吟をしたり、いきなり立ち上って、棒を振り廻して剣舞をする者もあった。",
              "citation": {
                "source": "奥間巡査",
                "author": "池宮城積宝",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中から蛇皮線の音、鼓の響、若い女の甲高い声が洩れて来た。",
              "citation": {
                "source": "奥間巡査",
                "author": "池宮城積宝",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が酒を酌み交して居る間、女達は蛇皮線を弾いたり、歌を歌ったりした。",
              "citation": {
                "source": "奥間巡査",
                "author": "池宮城積宝",
                "note": "青空文庫"
              }
            },
            {
              "text": "和田は、自分がとがめられているように感じて、面を伏せると「この品々を、拾って――」　玄白斎は、岩の上の木片、蛇皮を頤で差した。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "壇上の品々――人髪、人骨、人血、蛇皮、肝、鼠の毛、猪の糞、牛の頭、牛の血、丁香、白檀、蘇合香、毒薬などというものは、人を呪い殺すために、火に投じる生犠の形であった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲太郎は、静かに手を延して、蛇皮を取って、火の中へ投じた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡弓は竹のずんど切りの胴に、蛇皮を張ったのが多かった。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二階に寝ころびながら、康白情氏の詩を読んでいると、潯陽江に泊した支那の船から、蛇皮線だか何かの音がして来る。",
              "citation": {
                "source": "長江游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛇皮線を愉しむだけの余裕すら失つた彼らは、唯二人三人相寄つて、ひそかに指拳を遊んだと言ふ。",
              "citation": {
                "source": "沖縄を憶ふ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の為さうなことで、之に手をふれるのを厭うて居るのは、楽器類殊に三味線――所謂蛇皮線である。",
              "citation": {
                "source": "沖縄を憶ふ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ蛇皮線の糸の途絶え――。",
              "citation": {
                "source": "沖縄を憶ふ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は鶴さんに踊りを所望すると、他の老妓の蛇皮線に合せて、彼女は例の紺ガスリ、前結びの帶、櫛髮風の姿で、いろ／＼の踊を舞ふ。",
              "citation": {
                "source": "沖繩の旅",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「糀街」と唐文字を刺繍した唐幡と青龍幡を先にたて、胡弓、蛇皮線、杖鼓、磬、チャルメラ、鉄鼓と、無闇に吹きたて叩きたて、耳も劈けるような異様な音でけたたましく囃してゆく。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "山王祭の大象",
                "note": "青空文庫"
              }
            },
            {
              "text": "と女が言つたさて　僕の國はどこなんだか　とにかく僕は煙草に火をつけるんだが　刺青と蛇皮線などの聯想を染めて　圖案のやうな風俗をしてゐるあの僕の國か！",
              "citation": {
                "source": "山之口貘詩集",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "三味線とはいっても、東京あたりで俗にいっているところの蛇皮線の音である。",
              "citation": {
                "source": "池袋の店",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛇皮線というのは、三味線の元祖で、もともと琉球でも三味線と呼ばれているのである。",
              "citation": {
                "source": "池袋の店",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
