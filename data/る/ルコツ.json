    "definitions": [
      {
        "index": 1,
        "gloss": "painstaking efforts",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
