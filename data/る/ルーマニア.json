  {
    "uuid": "a038cfce-0f41-5ec0-9ecb-8ea1f59fbb29",
    "entry": "羅馬尼亜",
    "reading": {
      "primary": "ルーマニア",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
