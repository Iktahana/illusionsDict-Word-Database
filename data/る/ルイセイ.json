    "definitions": [
      {
        "index": 1,
        "gloss": "successive generations",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人類は累世の發展（excursus）を以て神の國に接近する。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは鑑三郎に問うて、池田宗家累世の墓が儼存してゐることを知つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて蘭軒の「賑※郷隣経奕葉」と云ふは、五山の所謂「累世好施」である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "嶺松寺の廃せらるるに当つて、二世全安は祖父京水の卑属たる池田分家並に又分家の両家の諸墓を処分せしめ、一石を巣鴨共同墓地に立てゝ「池田家累世之墓」と題した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは此に由つて痘科池田氏累世の事蹟を覆検し、錦橋初代瑞仙の死に至つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "柏軒は一面多紀氏累世の余沢を被り、一面※庭歿後多紀両家の当主が皆弱冠であつたために群を抜いて立身する便を得たのだと云つてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此人は増田氏累世中で、最も學殖あり最も文事ある人であつた。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "附記　伊賀越の仇討は、荒木方四人、又五郎方士分、小者ともで、合せて十一人と、藤堂家の公文書「累世記事」にも残っているし、その外俗書にも、同じであるが、一竜斎貞山（二代目）が、附人を三十六人にして、これが当って以来、すっかり、この方が一般的になってしまった。",
              "citation": {
                "source": "寛永武道鑑",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "河野系圖、豫章記、越智氏累世居伊豫、支族蕃滋云々、而河野氏尤著河野系圖」トアルニ由リテ、ソノ子致命ヲ子致彦トシテ、狗古智卑狗ニ附會シタルナリ。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は累世田安藩の臣、大坪流直傳の騎射指南役として重きをなした。",
              "citation": {
                "source": "桜もち",
                "author": "心猿",
                "note": "青空文庫"
              }
            },
            {
              "text": "丹羽郡｜爾波神社及び中島郡太神社の神体なる仲臣子上命をその始祖となし、子孫連綿として累世丹羽郡の領司または大領となった。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソノ間累世二主、遷館三所、連綿トシテ絶エズ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "）その「累世二主」というのは享和元年六月二十九日に平洲が寿七十四歳で没し養子徳昌が家を継いで嚶鳴館の新主となった事を言ったのであろう。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような河野磐州の不羈奔放と思想的発展転化の基底にいきづくものは、はたして俗論史家の論断のごとき河野氏累世の尊王精神であったか。",
              "citation": {
                "source": "加波山",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "従う紀清両党の兵は、宇都宮累世養うところのもの、戦場に於て命を棄つること、塵埃の如く思いおる輩じゃ。",
              "citation": {
                "source": "赤坂城の謀略",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちその思想は純然たる古流にして、三河武士一片の精神、ただ徳川｜累世の恩義に報ゆるの外｜他志あることなし。",
              "citation": {
                "source": "瘠我慢の説",
                "author": "瘠我慢の説に対する評論について",
                "note": "青空文庫"
              }
            },
            {
              "text": "大江｜家は　菅原家と倶に　朝廷に累世する儒臣なり。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "曹操は相国曹参の後胤で、累世四百年も漢室に仕えてその禄を食みながら、いま漢室の衰えるを見るや、その恩を報ぜんとはせず、かえって、乱世の奸雄たる本質をあらわして簒虐をたくらむ。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "（略）――是より子孫蜂須賀氏を襲ふて、累世氏名となしぬ。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、万一、あの人のかえりがおくれたとしたら、それは、彼のわるいせいではなく、やむをえない不意の出来ごとが妨げをしたのである。",
              "citation": {
                "source": "デイモンとピシアス",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "などとそんなことを真剣に考えて読んだものだが――どんな本を読んでみても自分の頭がわるいせいか結局、なんにもわからないということだけしきゃわからなかった。",
              "citation": {
                "source": "自分だけの世界",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "この子の眼は大たい胃腸のわるいせいなのだから。",
              "citation": {
                "source": "祖母",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもカンジンの共産党の主義の話になると、ウルフの頭がわるいせいか、まるっきりチンプンカンプンなので困ってしまった。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンクリーの四壁の音響反射のわるいせいか、天井の高いせいか、どのグループの人声も宙に消えて、ただ、饒舌ってる人のゼスチュアーだけがあとに残る。",
              "citation": {
                "source": "蛸の如きもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに育ちだなアと全然斜陽族にきめこんでしまった次第ですが、オレの若いころはそんなことはできなかったものだというのがトオサンの述懐で、そう云われてみると、ぼくなぞもできない方かも知れませんが、しかしこれは日野がずるいせいなんです。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中でも殊に灯のあかるいせいでもあるか、薬屋の店が幾軒もあるように思われた。",
              "citation": {
                "source": "寺じまの記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソーンダイクは、財布以外の持物を、一つ一つ嗅いでみたあとで、「おなじ包みのなかにあったんだから、多少匂いがうつっていると思うんですが、私の鼻がわるいせいか、ほかの物は匂わないようです。",
              "citation": {
                "source": "予謀殺人",
                "author": "A CASE OF PREMEDITATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そうだ、白藤か淡紫かあの花の咲くまで見ていよう」　陽あたりのわるいせいか、房は垂れているが花の咲くのは遅かった。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "森の中に、一けんのふるいせいようかんがたっていました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　森の中の、ふるいせいようかんのまどから、小さい女の子が、たすけをもとめてなきさけんでいた、そのあくる日のこと。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
