        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "買ひものばかりしてゐる、ふしぎな状態である、靴下、靴などまで買ふのだから呆れる、曰く、多情物資、カヒモノスケベエとルビを振るなり。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時には秋吉に着いて行乞、さらに近在行乞、財布（ナイフとルビをふるべし）を忘れてきてゐる。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢字を五字覚えるよりも、いと楽に覚えられ、そしてこれらの用法は我々の慣用の文章に我々を悩ますものではなく、ただ名詞や形容詞のふだん漢字で書いてゐるのにルビをふるやうな場合にだけ困却するだけの話、「ヲンナ」か「オンナ」か、こんな区別はどうだつていゝ。",
              "citation": {
                "source": "新カナヅカヒの問題",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
