    "definitions": [
      {
        "index": 1,
        "gloss": "lux (unit of illuminance)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
