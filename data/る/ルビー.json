          "standard": [],
          "literary": [
            {
              "text": "こんな事を始めて気づいて驚いている私の鼻の先に突き出た楓の小枝の一つ一つの先端には、ルビーやガーネットのように輝く新芽がもうだいぶ芽らしい形をしてふくらんでいた。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルビーと紫水晶のかけらのスイートピー。",
              "citation": {
                "source": "五月の朝の花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルビーよりも赤くすきとほりリチウムよりもうつくしく酔ったやうになってその火は燃えてゐるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "血の色には汚れがあり、焔の色には苦熱があり、ルビーの色は硬くて脆い。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "血の汚れを去り、焔の熱を奪い、ルビーを霊泉の水に溶かしでもしたら彼の円山の緋鶏頭の色に似た色になるであろうか。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば眼の辺には紺青色と真珠色の光を放ち、腹部にはルビー色、雪白色および空色の光斑を具えている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちこの鉱石の砕片をラジウムと一緒に一ケ月も管に入れておけば、あるいは黄色なトッパズになり、あるいはルビー、サッファヤ等種々の宝石に変るそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "船はルビー色の飾をつけて静かに横わっていたが突然黄色い声で外国詩の慟哭する金切声が聞えた。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "新型式中でも最も思い切った新型式としては、モザイックのような表象を漢字交じりで並べたテキストに、そのテキストとはだいぶかけ離れたルビーを並立させたものがある。",
              "citation": {
                "source": "俳句の型式とその進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルビーよりも赤くすきとおりリチウムよりもうつくしく酔ったようになってその火は燃えているのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルビーよりも赤くすきとおり、リチウムよりもうつくしく酔ったようになって、その火は燃えているのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルビーよりも赤くすきとほり、リチウムよりも、うつくしく醉つたやうになつてその火は燃えてゐるのでした。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新古御時計」と書いた看板の蔭に、怪しげな色の金銀細工、マガイ金剛石、猫目石、ルビー、サファイヤの類が、塵に蔽われたまま並んで光っている。",
              "citation": {
                "source": "塵",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "三面記事が少しもなくて、うるさいルビーがなかった。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルビーと紫水晶のかけらのスウィートピー。",
              "citation": {
                "source": "五月の朝の花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕のもってるルビーの壺やなんかより、もっといい宝石は、どっちへ行ったらあるだろうね」　大臣の子が申しました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「虹の脚もとにルビーの絵の具皿があるそうです」　王子が口早に言いました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ルビーよりは金剛石の方がいいよ。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く行ってルビーの皿を取ろう。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルビーのお皿が落ちてないか知らん」　二人は足でけむりのような茶色の草穂をかきわけて見ましたが、ルビーの絵の具皿はそこに落ちていませんでした。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ね、虹は向こうへ逃げるときルビーの皿もひきずって行ったんだね」「そうだろうと思います」「虹はいったいどこへ行ったろうね」「さあ」「あ、あすこにいる。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野ばらの枝は茶色の琥珀や紫がかった霰石でみがきあげられ、その実はまっかなルビーでした。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうえ、からだじゅうに、ダイヤモンドや、ルビーや、サファイヤがちりばめてありました。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姫さまはと見れば、ダイヤモンドとルビーで、キラキラとかざりたてた、雪のようにまっ白なウマに乗っていました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "切られた金魚の首は電燈の光に明るく透けてルビーのように光る目を見開き、口を思い出したように時々開閉していた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓際＝如輪木の胴に赤銅の箍を嵌めた酒筒から、大小二本の蔓の根が窓框を捲いて延び上り、緊密な濃緑色の葉立ちの陰に、練絹へルビーを包んだやうな小花を綴るびなんかつら。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "必要によって当時の図書館長バルビールに命じて製らせました、函入新装の、一千巻、一架の内容は、宗教四十巻、叙事詩四十巻、戯曲四十巻、その他の詩篇六十巻。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白砂の上にお嬢様のルビー入りの胸留が落ちていますよ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
