    "definitions": [
      {
        "index": 1,
        "gloss": "(an) exile",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あれは、古來、私たち風流人の美しい夢、あこがれ、と言つてもいいでせう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたに助けられたから好きといふわけでも無いし、あなたが風流人だから好きといふのでも無い。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたたち風流人には、もつて來いの國です。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "實行しないで、ただ、あこがれて溜息をついてゐるのが風流人ですか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもまた、見渡す限り、ただ薄みどり色の茫洋乎たる大空洞の片隅に、幽かな黒一點をとどめてゐるものが、たとひそれは嘘にしても月の影法師だと云はれて見ると、鯛の大群や火事だと思つて眺めるよりは、風流人の浦島にとつて、はるかに趣きがあり、郷愁をそそるに足るものがあつた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつとも丹後の荒磯の風流人ぢや無理もないがね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "正統の風流人とはよくも言つた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "海月なす漂へる天蓋、とでも言つたら、あなたたち風流人は喜びますかね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "風流人の浦島にも、何だか見當のつかぬ可憐な、たよりない、けれども陸上では聞く事の出來ぬ氣高い淒しさが、その底に流れてゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と風流人の浦島も、ついたしなみを忘れて、もつと掬つて食べようといふ氣勢を示した。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、ちやんと胸を張つて、おれは日本一の好男子で、さうして、最上級の風流人だといふやうな顏をして威張つて歩くのですよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生犀星は、自ら風流人を以て任じ、且つ風流の幽玄な哲理をよく説いてる。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先祖は十八大通といわれた江戸の富豪で、また風流人の家筋に当り、三月の雛祭りには昔の遺物の象牙作りの雛人形が並べられた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋がしらは風流人で、かむりづけ、ものはづくしなどと云ふのを遣ります。",
              "citation": {
                "source": "片しぐれ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時第一に堪難く感じて來たのは渇の苦、茲だ禍變じて幸となると言つたのは、普通ならば、漂流人が、第一に困窮するのは淡水を得られぬ事で、其爲に十｜中八九は斃れてしまうのだが、吾等は其難丈けは免かれた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "風流人だと、鶯を覗くにも行儀があらう。",
              "citation": {
                "source": "湯どうふ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一夜作りの風流人はそれだからうるさい。",
              "citation": {
                "source": "河鹿",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは、古来、私たち風流人の美しい夢、あこがれ、と言つてもいいでせう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたたち風流人には、もつて来いの国です。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実行しないで、ただ、あこがれて溜息をついてゐるのが風流人ですか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもまた、見渡す限り、ただ薄みどり色の茫洋乎たる大空洞の片隅に、幽かな黒一点をとどめてゐるものが、たとひそれは嘘にしても月の影法師だと云はれて見ると、鯛の大群や火事だと思つて眺めるよりは、風流人の浦島にとつて、はるかに趣きがあり、郷愁をそそるに足るものがあつた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "風流人の浦島にも、何だか見当のつかぬ可憐な、たよりない、けれども陸上では聞く事の出来ぬ気高い凄しさが、その底に流れてゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と風流人の浦島も、ついたしなみを忘れて、もつと掬つて食べようといふ気勢を示した。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、ちやんと胸を張つて、おれは日本一の好男子で、さうして、最上級の風流人だといふやうな顔をして威張つて歩くのですよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "畢竟上述のような俗解は、風流人の対語として考えられている観念である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のようなものにはこの劇中でいちばんかわいそうなは干物になった心臓の持ち主すなわちにんじんのおかあさんであり、いちばん幸福なのは動物にまでも同情されるにんじんである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "立っているにんじんを突き倒す。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "頓首ルピック氏よりの返事親愛なるにんじん殿其許は目前に初の聖体拝受を控え、しかも教理問答にも通いおることなれば、人類が「釘」に悩まされた事実は其許に始まらざること承知の筈だ。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "頓首ルピック氏の返事親愛なるにんじん殿ちょうど其許の歯が生えようとしつつある時、余の歯は一本ぐらつきはじめた。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルピック氏の返事親愛なるにんじん殿其許が他日代議士にでもなればわかることだ。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
