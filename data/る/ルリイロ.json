        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "瑠璃色の松虫草と、大原の水分を一杯に吸い込んで、ふくらんだような桔梗のつぼみからは、秋が立ち初めている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、愛鷹山は洗われたような瑠璃色になって現われる。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上へ、真白な形で、瑠璃色の透くのに薄い黄金の輪郭した、さげ結びの帯の見える、うしろ向きで、雲のような女の姿が、すっと立って、するすると月の前を歩行いて消えた。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "綺麗に掃除されたラムプの油壷は瑠璃色のガラスで、その下には乳色のガラスの台がついていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありきたりの品物だけれども、大事に取り扱われているためか、その瑠璃色の部分が透明で、美しい光沢を持っていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かすかな瑠璃色がようやく空一面と空間の或る部分にまで行きわたり、下界にまでは光がとどかなかった。",
              "citation": {
                "source": "窓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほのかな瑠璃色の落着きが却って下界のひとところの――真黒な森の狂異を気味悪く見せる。",
              "citation": {
                "source": "窓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の樹の蔭から、すらりと向うへ、隈なき白銀の夜に、雪のやうな橋が、瑠璃色の流の上を、恰も月を投掛けた長き玉章の風情に架る。",
              "citation": {
                "source": "月夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白菊の咲く頃、大屋根へ出て、棟瓦をひらりと跨いで、高く、高く、雲の白きが、微に動いて、瑠璃色に澄渡つた空を仰ぐ時は、あの、夕立の夜を思出す……そして、美しく清らかな母の懷にある幼兒の身にあこがれた。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "折々の空の瑠璃色は、玲瓏たる影と成りて、玉章の手函の裡、櫛笥の奧、紅猪口の底にも宿る。",
              "citation": {
                "source": "五月より",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は朝顏の瑠璃色であつた。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺さぬまでに現責に苦しめ呪うがゆえ、生命を縮めては相成らぬで、毎夜少年の気着かぬ間に、振袖に緋の扱帯した、面が狗の、召使に持たせて、われら秘蔵の濃緑の酒を、瑠璃色の瑪瑙の壺から、回生剤として、その水にしたたらして置くが習じゃ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺絞りの首抜きの浴衣を着て、赤｜毛布を引き絡い、身を持て余したるがごとくに歩みを運び、下駄の爪頭に戞々と礫を蹴遣りつつ、流れに沿いて逍遥いたりしが、瑠璃色に澄み渡れる空を打ち仰ぎて、「ああ、いいお月夜だ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その丘からは港の瑠璃色の海や、船着場の黄色い旗や、また彼女の家や青年の邸も悉く手に取るように一眸の中におさめられた。",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "港の海は瑠璃色に輝き、船着場には新しい黄色い旗が上がっていた。",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "もろもろの陰は深い瑠璃色に、もろもろの明るみはうっとりした琥珀色の二つに統制されて来ると、道路側の瓦屋根の一角がたちまち灼熱して、紫白の光芒を撥開し、そこから縒り出す閃光のテープを谷窪のそれを望むものものに投げかけた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを仰いでいると、情熱の藍壺に面を浸し、瑠璃色の接吻で苦しく唇を閉じられているようである。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが水天一枚の瑠璃色の面でしばしば断ち切れて、だんだん淡く、蜃気楼の島のように中空に映り霞んで行く。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠い水は瑠璃色にのして、表面はにこ毛が密生しているように白っぽくさえ見える。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御覧あそばせな、今朝は紅が九つ、紫が六つ、絞りが四つと白が七つ、それから瑠璃色が……」　老女が小女によく磨いた真鍮の耳盥を竹椽へ運ばせた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うてなからちぎり取られた紅、紫、瑠璃色、白、絞り咲きなどの朝顔の花が、幾十となく柄を抜いた小傘のやうに、たつぷり張つた耳盥の水面に浮んでゐる。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きつと美しい瑠璃色をしてゐて、薔薇の花みたいによい匂がしますよ。",
              "citation": {
                "source": "お母さん達",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "美女　でも、貴方、雲が見えます、雪のような、空が見えます、瑠璃色の。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何日も見て居乍ら、何時見ても目さむる様の心地せらるゝは、朝顔形に瑠璃色の模様したる鉢に植ゑし大輪の白薔薇なり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、日向で汗ばむくらいだと言った処で、雑樹一株隔てた中には、草の枯れたのに、日が映すかと見れば、何、瑠璃色に小さく凝った竜胆が、日中も冷い白い霜を噛んでいます。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はるかに瑠璃色の空を刻み取って雪山の雪が王城の二つ櫓を門歯にして夕栄えに燦めいて居た。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを海老屋の裏二階から見渡すと、宛で瑠璃色の海だ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "青焔に揺れる大海原が瑠璃色の空と続くあたりは、金粉を交えた水蒸気にぼかされて白く霞んで見えた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に驚くべきは、碧い珊瑚礁魚よりも更に幾倍か碧い・想像し得る限りの最も明るい瑠璃色をした・長さ二寸許りの小魚の群であつた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度朝日の射して來た水の中に彼等の群がヒラ／＼と搖れ動けば、其の鮮やかな瑠璃色は、忽ちにして濃紺となり、紫藍となり、緑金となり、玉蟲色と輝いて、全く目も眩むばかり。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
