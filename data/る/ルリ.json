    "definitions": [
      {
        "index": 1,
        "gloss": "lapis lazuli",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "雲消えて皹も亦拭ひ去らる、山色何の瑠璃ぞ、只だ赭丹赭黄なる熔岩の、奇醜大塊を、至つて無器用に束ねて嶄立せるのみ、その肩を怒らし胸を張れるを見て、淑美なる女性的崇高を知らず。",
              "citation": {
                "source": "霧の不二、月の不二",
                "author": "――明治三十六年八月七日御殿場口にて観察――",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の面には、生の動揺といった象が見えている中に、これはまた青嵐も吹かば吹け、碧瑠璃のさざれ石の間に介まって、黙んまりとした｜死の静粛！",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑠璃色の松虫草と、大原の水分を一杯に吸い込んで、ふくらんだような桔梗のつぼみからは、秋が立ち初めている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、愛鷹山は洗われたような瑠璃色になって現われる。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は気がついてすぐ頭の上を仰ぐと、昼間は真っ白に立ちのぼる噴煙が月の光を受けて灰色に染まって碧瑠璃の大空を衝いているさまが、いかにもすさまじくまた美しかった。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居や浄瑠璃にあるように、わたしを誰かの身代りにして首でも打って渡すのではあるまいか、とお蝶はまた疑った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　深い鋼青から柔らかな桔梗、それからうるはしい天の瑠璃、それからけむりに目を瞑るとな、やはりはがねの空が眼の前一面にこめてその中にるりいろのくの字が沢山沢山光ってうごいてゐるよ。",
              "citation": {
                "source": "柳沢",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番はしの家はよそから流れて来た浄瑠璃語りの家である。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「宗さん」という按摩は浄瑠璃屋の常連の一人で、尺八も吹く。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の窓の前の溪には瑠璃がいつも一羽啼いてゐる。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうだのに、この瑠璃は終日溪を飛去らず、自ら自らの聲をたのしんでゐるやうに永い午後の倦怠を歌つてゐる。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "渓向うの木立のなかでは瑠璃が美しく囀っていた。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑠璃は河鹿と同じくそのころの渓間をいかにも楽しいものに思わせる鳥だった。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして他の瑠璃がそのホラへはいって行くと喧嘩をして追い出してしまうと云う。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は瑠璃の鳴き声を聞くといつもその話を思い出しそれをもっともだと思った。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ニシビラへ行けばニシビラの瑠璃、セコノタキへ来ればセコノタキの瑠璃。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　そして私の下りて来た瀬の近くにも同じような瑠璃が一羽いたのである。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上へ、真白な形で、瑠璃色の透くのに薄い黄金の輪郭した、さげ結びの帯の見える、うしろ向きで、雲のような女の姿が、すっと立って、するすると月の前を歩行いて消えた。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "予が文章の音律と云ふのは、何も五七調とか七語調とか、馬琴流の文章や淨瑠璃の文章のやうなのをいふのでは無い。",
              "citation": {
                "source": "文章の音律",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は温かき瑠璃である。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体、箱根でも、塩原でも、或は木曾の桟橋でも、実際にしろ、絵にせよ、瑠璃を灌ぎ、水銀を流す渓流を、駕籠、車で見て行くのは、樵路、桟道、高い処で、景色は低く下に臨むものと思つて居たのに、繰返していふが、此の密林の間は、さながら流に浮んで飛ぶのである。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし僧正｜遍照は天狗を金網の中へ籠めて焼いて灰にしたというが、我らにはなかなかそのような道力はないから、平生いろいろな天狗に脅されて弱っている、俳句天狗や歌天狗、書天狗画天狗｜浄瑠璃天狗、その上に本物の天狗に出られて叱られでもしたら堪らないから筆を擱く。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯願ふらくはかの如来大慈大悲我が小願の中に於て大神力を現じ給ひ妄言綺語の淤泥を化して光明｜顕色の浄瑠璃となし、浮華の中より清浄の青蓮華を開かしめ給はんことを。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯願うらくはかの如来大慈大悲我が小願の中に於て大神力を現じ給い妄言綺語の淤泥を化して光明｜顕色の浄瑠璃となし、浮華の中より清浄の青蓮華を開かしめ給わんことを。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の役者の扮した松王丸の中には、どうしても、その役者が隠れていて、しかも大いにのさばっているために、われわれは浄瑠璃の松王丸を見るかわりに俳優何某の松王丸しか見ることができないのであるが、この人形の松王丸となると、それが正真正銘の浄瑠璃の世界から抜けだして来た本物の松王丸そのものになっている。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "百年の後には「金色夜叉」でも「不如帰」でもやはり古典になってしまうであろう、義太夫音楽でも時とともに少しずつその形式を進化させて行けば「モロッコ」や「街の灯」の浄瑠璃化も必ずしも不可能ではないであろう。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "綺麗に掃除されたラムプの油壷は瑠璃色のガラスで、その下には乳色のガラスの台がついていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありきたりの品物だけれども、大事に取り扱われているためか、その瑠璃色の部分が透明で、美しい光沢を持っていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日劇を、ぐるりと取り巻いている入場者の長蛇の列を見ると、私は、ひどく重い気持になるのである。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争中に、あんなにグロテスクな嘘をさかんに書き並べて、こんどはくるりと裏がえしの同様の嘘をまた書き並べています。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
