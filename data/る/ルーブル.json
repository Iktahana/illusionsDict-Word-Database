    "definitions": [
      {
        "index": 1,
        "gloss": "Louvre (museum)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
