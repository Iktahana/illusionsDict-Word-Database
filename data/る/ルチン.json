    },
    "definitions": [
      {
        "index": 1,
        "gloss": "detailed explanation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "わたしは何故久しく筐底の旧稿に筆をつぐ事ができなかったかを縷陳して、纔に一時の責を塞ぐこととした。",
              "citation": {
                "source": "十日の菊",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "外門を入ろうとすると、ちょうど中から出て来るちんちくりんな男にぶっつかった。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもすりへったぺしゃんこの下駄で、それも片方がよけいへってるちんばだ。",
              "citation": {
                "source": "花ふぶき",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大空にちんくるちんくるとまたたく星の光を見て――人間が笑い得るには、幼な児といえども相当の余裕を持っていなければ笑えない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきほどは、星を数え、ちんくるちんくると微笑みをしていたのですが、この時はゲラゲラと笑い出しました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――世の中にゃ見えるちんばもあれば見えねえちんばもあるさ。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲州者はおれが捕まえているから、あの老婆を労って来い」　半瓦は、そういうと、逃げかけるちんばの襟がみを抓んで、螽でも叩きつけるように、空地の方へ抛り出した。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "人夫達から日頃、憎悪の的になっているちんばの鬼武者黒田官兵衛は、すこし離れた所に、竹の杖をついて立っている。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
