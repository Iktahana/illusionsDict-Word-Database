    "definitions": [
      {
        "index": 1,
        "gloss": "Luna (goddess)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いずれモンパルナスあたりの新進美術家のプランと見える。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢張りモンパルナス裏のしょんぼりした寄席のボビノで開くべきであろう。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時誰かの万年筆のインキがほんの少しばかり卓布を汚したのに対して、オーバーケルナーが五マルクとかの賠償金を請求した。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女優と無線電信　有名な仏の女優サラ・ベルナールは近頃北米と欧洲との間に開通された無線電信について次のような事を云っている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またマヤコフスキーとレーニンとピリニヤーク、パステルナックの、新刊書で埋れた。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくあの映畫ではムルナウの監督による撮影技巧も全く申し分なかつた。",
              "citation": {
                "source": "文藝作品の映畫化",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而シテ諸君ハ、支那ノ労働者、農民、兵士達ト手ヲ握レ、諸君ガ革命的連帯ノ固キ握手ニ達スルタメニハ、如何ナル犠牲ヲモ辞スルナ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "法科のベルナー君や理科のデフレッガア君などは目下郷里へ帰ってたいへん静かであります。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしベルナールに言わせると彼の理論と目的とが矛盾していたために生涯仕上げができなかったというのである。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お隣のアメリカでも、たまには相当な大地震があり、大山火事があるし、時にまた日本にはあまり無い「熱波」「寒波」の襲来を受けるほかに、かなりしばしば猛烈な大旋風トルナドーに引っかき回される。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば一九三四年の統計によると総計百十四回のトルナドーに見舞われ、その損害額三百八十三万三千ドル、死者四十名であったそうである。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかおおぜいで先生を引っぱって浅草へ行ってルナパークのメリーゴーラウンドに乗せたこともあったが、いかにも迷惑そうではあったが若い者の言うなりになって木馬にのっかってぐるぐる回っていた。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "末の妹のカロラインが、つきまとわるサン・ベルナール種のレックスを押しのけながら、逸早く戸を開けると、石油ランプの琥珀色の光が焔の剣のような一筋のまぶしさを広縁に投げた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一たいにそういった純下町風の老舗気質を愛してサラ・ベルナールはこの店を贔屓にした。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「シカシキヅカイスルナ。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで先生の草がきを見ると「ヰルナラタヅネル」一字のことだ。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヰルナラサガス」此れなら、局待の二字分がきちんと入る、うまいでせう。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十八年（乙巳）　一九〇五○一月、明治座にてユーゴーの「エルナニ」五幕を上演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "戯曲ではチェーホフ、ルナアル、ボルトリッシュ、ヴィルドラック、岸田国士などが好きで、殆んど心酔したが、しかし、同じクラスに白崎礼三という詩人がいて、これと仲が良く、下宿も同じにしていたくらいだったから、その感化でランボオやヴァレリーやマラルメを読み、その雰囲気から戯曲を書いた。",
              "citation": {
                "source": "わが文学修業",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あんまり長すぎる」　というルナアルの「博物誌」の中の言葉を想い出した。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三回は今撮影中ですが、ジャン・ジャック・ベルナアルの「旅の誘い」を僕が書きなおしたものです。",
              "citation": {
                "source": "十年後の映画界",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　――何と云ってもムルナウは豪勢な男だ。",
              "citation": {
                "source": "牛込館",
                "author": "映画館めぐり（十）",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白くないのはムルナウの罪ではない。",
              "citation": {
                "source": "牛込館",
                "author": "映画館めぐり（十）",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚劣な筋をこれだけに生かしたのがムルナウだからね。",
              "citation": {
                "source": "牛込館",
                "author": "映画館めぐり（十）",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分たちの少年の頃には、日本ではフランスの所謂印象派の画が大流行していて、洋画鑑賞の第一歩を、たいていこのあたりからはじめたもので、ゴッホ、ゴーギャン、セザンヌ、ルナアルなどというひとの絵は、田舎の中学生でも、たいていその写真版を見て知っていたのでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若シ書ケルナラ僕ノ目ノ明イテル内ニ今一便ヨコシテクレヌカ（無理ナ注文ダガ）　画ハガキモ慥ニ受取タ。",
              "citation": {
                "source": "『我輩は猫である』中篇自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "君ニ逢ウタラ鰹節一本贈ルナドトイウテ居タガ、モーソンナ者ハ食ウテシマッテアルマイ。",
              "citation": {
                "source": "『我輩は猫である』中篇自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
