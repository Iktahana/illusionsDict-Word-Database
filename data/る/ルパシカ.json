        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ルパシカというものが流行して、カチュウシャ可愛いや、という歌がはやって、ひどく、きざになってしまった。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯その首の処をルパシカの白い紐で縛って、高い処に打ち込んだ銃剣に引っかけてあるだけでしたが、そのままにリヤトニコフは、左右の手足を正しくブラ下げて、両眼を大きく見開きながら、まともに私の顔を見下しているのです。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "案外な健康體で、ルパシカなどを着込んでゐた。",
              "citation": {
                "source": "鳳來寺紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルパシカを着る息子　たとえば息子がルパシカを着て喜んでいるとする。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎を嫌って、東京の新知識にカブレて、ルパシカを着て、カフェーで威張っている連中のアタマは、いつの時代にもある文化カブレのなまけ者だよ。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒ビロードのルパシカを着たジェルテルスキーは、最も窓に近い卓子で露字新聞を読んでいた。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――恐らく彼が、片手でルパシカの胸を抱え、右手で頻りに金髪を撫でつつ、決心しかねている今の瞬間、若いダーシェンカは、手ミシンを廻しながら、子供服の袖でもつけているであろう。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青ペンキのはげた校舎裏の土俵の日溜りでは、ルパシカの紐の長い画学生達が、これは又野放図もなく長閑な角力遊びだ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルパシカを着て、紐を前で長く結んでいる艶歌師の四角い顔が、文章｜倶楽部の写真で見た、室生犀星と云うひとに似ている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "壺井繁治が黒いルパシカ姿で、うなぎの寝床のような下宿住い、これも善良ムヒな詩人。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒いルパシカを着た壺井繁治と、角帯を締めた片岡鉄兵がにやにや笑っている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青ペンキのはげた校舎裏の土俵の日溜りでは、ルパシカの紐の長い画学生達が、之は又｜野方図もなく長閑なすもうの遊び。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかげで高価え銭を払ったルパシカが台なしだ。",
              "citation": {
                "source": "支那米の袋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれはロシアの百姓が着るというルパシカに大きな縁のあるビロードの帽子をかぶっていた。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍服の下に現われたものは、焦茶色のルパシカだった。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれが、道々｜執って来たと同じ方法により、主義反対の者の解消を要求する」　キラリと、ルパシカ男の手に、短銃が光った。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "はッはッはッ」　ルパシカ男は、短銃をポケットに収めた。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "同盟の一員として判らなければ、物を云わせるぞ、君」　ルパシカ男は、頑強に反対する一局員の胸元に、短銃の口を、圧しつけた。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーテンの蔭から、ルパシカ姿の巨漢が現れた。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルパシカ男は、いつの間にか局舎から姿を消していた塩原参謀の仮装だった。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「う、ううっ」　と、呻っている敵方の面々は、黒人があるかと思うと、ロシヤ人がよく着ているルパシカという妙な上衣をきている者もあります。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "このルパシカをきているのは、白人のようでありました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルパシカ男も黒人も、地上に匐って、うんうんうなっています。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、中から、四五人の黒人や、ルパシカを着た東洋人らしい男が出て来ましたが、兵曹長を見ると、びっくりした様子で、腰のピストルをとりだそうといたしました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　やがて、黒人やルパシカを着た団員が、たくさん集ってきました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっと至急、おいでをねがいます」　とつぜん耳もとで、ルパシカ男の声がしました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョーヌはよれよれのブルーズをすてて、赤いルパシカを手に入れた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そして赤いルパシカを着るものなんだわ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのルパシカをごらんなさい。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
