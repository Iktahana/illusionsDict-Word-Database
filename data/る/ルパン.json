          "standard": [],
          "literary": [
            {
              "text": "（昭和七年四月『セルパン』）",
              "citation": {
                "source": "千人針",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和九年七月『セルパン』）",
              "citation": {
                "source": "山中常盤双紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十年八月、セルパン）",
              "citation": {
                "source": "映画と生理",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『セルパン』1931年５月号）-----------------------------------------------------------------　詩人の死ぬや悲し　ある日の芥川龍之介が、救ひのない絶望に沈みながら、死の暗黒と生の無意義について私に語つた。",
              "citation": {
                "source": "散文詩集『田舎の時計　他十二篇』",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥棒　アルセーヌ・ルパン。",
              "citation": {
                "source": "ラムプの夜",
                "author": "――学芸会のための一幕劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリスマスのお祭りの、紙の三角帽をかぶり、ルパンのように顔の上半分を覆いかくしている黒の仮面をつけた男と、それから三十四、五の痩せ型の綺麗な奥さんと二人連れの客が見えまして、男のひとは、私どもには後向きに、土間の隅の椅子に腰を下しましたが、私はその人がお店にはいってくると直ぐに、誰だか解りました。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は目下上京中で、銀座裏の宿舎でこの原稿を書きはじめる数時間前は、銀座のルパンという酒場で太宰治、坂口安吾の二人と酒を飲んでいた――というより、太宰治はビールを飲み、坂口安吾はウイスキーを飲み、私は今夜この原稿のために徹夜のカンヅメになるので、珈琲を飲んでいた。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい、君たちこの煙草をやるよ、女がくれたんだよ、と彼はハイカラな煙草をくれたが、私たちは彼がその煙草をルパンの親爺から貰っていたのを目撃していた。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルパンでもホルムズでも要するに大人のミッキーマウスであり凸凹黒兵衛に外ならないんだよ。",
              "citation": {
                "source": "探偵小説の正体",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "明智小五郎、手塚竜太、帆村荘六、俵巌、シャアロック・ホルムズ、アルセーヌ・ルパン、ルコック、ソーンダイク、エラリー・クイーン等々の名前は、単にその名前が紙面に顔を出しただけでも読者の血を湧かす。",
              "citation": {
                "source": "創作人物の名前について",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホームス、ルパン、ミッキーマウス、ノラクロ何とかいったような名前は、要するに創作人物の名前の持つ魅力を百パーセントに利用したもので、そんなダシの利く名前を発見した人の喜びは考えるさえ嬉しくてならない。",
              "citation": {
                "source": "創作人物の名前について",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が古今無双のシャーロック・ホームズであると同時に、前代未聞のアルセーヌ・ルパンである事を君は知らないのだ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "故人はアメリカの紳士で、数週間この街に滞在しており、キャンバウェル、トーキィ・テラスにあるシャルパンティエイ夫人の旅籠を宿としていた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「アーサ・シャルパンティエイ、海軍中尉ですな。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "帽子はドレッバー氏へ、トーキィ・テラスのシャルパンティエイ旅館宛で配送したとのことです。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そこでシャルパンティエイ夫人を訪ねました。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "』とシャルパンティエイ夫人は手をかざしましたが、すぐに椅子に戻って、『あんたは自分の兄を殺したのよ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　この吾輩の質問は的を射たものでして、シャルパンティエイ夫人も顔を赤くしました。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　シャルパンティエイ夫人の口から出た証言は、息も切れ切れ、途切れ途切れで、小さな声で話すもんですから、言葉のよくわからんところもありましたが、吾輩、夫人の発言を逐一速記しておりましたので、これに間違いはありません。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「シャルパンティエイ夫人が言葉を切ったとき、吾輩はわかりました。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩はシャルパンティエイ中尉の居所を見つけだし、二名の警官を連れていって、青年を逮捕したのです。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでシャルパンティエイは被害者の死体を空き家に引きずり込んだわけです。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャルパンティエイ青年はふたつめの事件には関われませんからな。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "終りに述べ置くは、インドとシャムで象厩に猴を畜えば、象を息災にすと信ずる由書いたが、近日一七七一年パリ板ツルパンの『暹羅史』に、シャムの象厩に猴を飼い、邪気が厩を襲えば猴これを引き受け象害を免がる。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「カフェー・ルパン」の広告ビラ。",
              "citation": {
                "source": "石塀幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルセーヌ・ルパンなどとは正に正反対な人格です。",
              "citation": {
                "source": "愛読作家についての断片",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反してルブランの「ルパン」物などになると、材料の真実性は希薄だし、描写の迫真性も乏しく、読んで私たちの魂の奥底にふれるようなところは滅多にないが、それでいて探偵小説としては実に面白い。",
              "citation": {
                "source": "現下文壇と探偵小説",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと探偵小説の映画化は、困難であると見えて、シャーロック・ホームズ物にしても、ルパン物にしても、かつて成功したためしがない。",
              "citation": {
                "source": "ヴアン・ダインの作風",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルパンなどは理知と感情とが並行していて、恋人に対する情熱などは、彼の驚くべき理知力を生むかまどのように思われるが、ホームズになると、恋愛やその他の感情は、推理を狂わせる邪魔者になっているようである。",
              "citation": {
                "source": "ホオムズの探偵法",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "デュパンは、ホームズやルパンなどの紳士とは非常に変わった探偵である。",
              "citation": {
                "source": "ヂユパンの癖とヴァンスの癖",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
