          "literary": [
            {
              "text": "伊東さんが送つてくれた中外日報を読む、年来の愛読誌であるが、涙骨老に改めて敬意を表する。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰊屋で昼飯を食べ、そして中外社に寄つた、涙骨先生にお目にかゝることができたのはうれしかつた。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊田君に対してすまない、涙骨先生に対してすまない、私自身に対してもすまないではないか。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おつかあ、それはわるいこつたがなあ。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
