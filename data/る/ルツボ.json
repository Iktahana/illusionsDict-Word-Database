    },
    "definitions": [
      {
        "index": 1,
        "gloss": "The Crucible (play by Arthur Miller)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それからにせ金製造場へ自分で降りて行って、ばらの実をるつぼに入れました。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "るつぼの中にすきとほったものが出来てゐました。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが丁度そのばんの八時半ごろ、るつぼの中にできたすきとほったものは、実は昇汞といふいちばんひどい毒薬でした。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "地獄へ飛ぶやうに辷り込むと、青い火鉢が金色に光つて、座布團一枚、ありのまゝに、萌黄を細く覆輪に取つて、朱とも、血とも、るつぼのたゞれた如くにとろけて、燃拔けた中心が、藥研に窪んで、天井へ崩れて、底の眞黒な板には、ちら／＼と火の粉がからんで、ぱち／＼と煤を燒く、炎で舐める、と一目見た。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻の真紀子が姦通していることを、たった今はじめて知ったという苦悩が、小郷をやぶれかぶれの情欲のるつぼへ陥し入れてしまったのだろう。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋳物師のところで、強盗と忠犬ナハトは、一つのるつぼの中にたたきこまれて、一つにとけあってしまいました。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の発見した方法によると、一ポンド金貨をるつぼに入れて溶かしそれに特種の薬品を加えると三倍量の黄金を得るというのであった。",
              "citation": {
                "source": "錬金詐欺",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は五個の一ポンド金貨をるつぼの中へ入れ実験を終って、其処に発生した金塊を手渡し、「ストリーターさん、この金塊を冶金師のところへ持って行って分析して貰って下さい」と言った。",
              "citation": {
                "source": "錬金詐欺",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方法は彼のストリーターに示したと同じであって、最初に実験して見せるとき、るつぼの中へ特種の粉を投じて濛々たる煙を発生せしめ、その間に助手をして、金を投ぜしめ、金が殖えたように思わせるのである。",
              "citation": {
                "source": "錬金詐欺",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューターを核にしてさまざまな人が出会い、マシンを支配の道具とする者の手から解放して一人ひとりの人間の可能性を伸ばす知の翼とするためのアイディアが、るつぼと化したダイマックスからつぎつぎと生まれていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊ひとひら、またひとひら、ふくらみかけるつぼみのばらのはな、そのままに、ゆふべのこゑをにほはせるばらのかなしみ、ただ、まぼろしのなかへながれてゆくわたしのしろばらの花よ、おまへのまつしろいほほに、わたしはさびしいこほろぎのなくのをききます。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "×摘め、摘め、誰れも春の薔薇、今日の盛りの紅い薔薇、今日に倦いたら明日の薔薇、とがるつぼみの青い薔薇、摘め、摘め、誰れも春の薔薇。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "印象は重んずるが、その表現は物象に直接ではなくて、幻想のるつぼを通して来たものである。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その興奮のるつぼの真っ只中を、早間に刻む拍子木の音いろとともにスルスルと御簾が下りていった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月になると、街路といはず横町といはず、台北の町はたちまち凄まじい爆音のるつぼと化してしまつた。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "契冲は竹から童子の生まれる話が『大宝広博楼閣経』と『後漢書西南夷伝』とに存するのを指摘して、その影響を推測しているが、たといその影響があったとしても、それは古来の竹取の翁の物語に結びつき、そうして平安朝の詩人の空想のるつぼに鎔かされたものであったろう。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分をこの迷信のるつぼから救い出してくれるのは、佐久間の倅の伊太郎か、手代の与三郎の外には無いような気がしましたが、この二人のうちには不思議な不純さを感じて、考えただけでもゾッと身内を顫わせるものがあったのです。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "お竹大日如来",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十分ほどのあいだに、安物のハンドバッグ、画家の使う黒塗りの刷毛箱、三つ角のあるやすり、にかわの棒、るつぼ用の一本の金属をまげて物がつかめるようになった火箸なぞを買いあさった。",
              "citation": {
                "source": "予謀殺人",
                "author": "A CASE OF PREMEDITATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "という間もなく、地獄のるつぼに投げ込まれる理由が、我々共にはわかりません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "弁信の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍えにあればあるものを取って抑えて、むちゃくちゃにその興奮のるつぼへ投げ込むよりほかはない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならば、その人間に、あきらかに、そうした素質があることを、あのるつぼの試練が、実証してみせるからだ。",
              "citation": {
                "source": "競馬",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "競馬場のるつぼほど、自分の脆弱な意志の面と、いろいろな自己の短所がはっきり、心の表に、あらわれてくるものはない。",
              "citation": {
                "source": "競馬",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもうに、スリも、あの他愛なきるつぼに立ち交じっては、ただ単に、人のポケットの物を、自分の懐中へ移転させるだけでは、彼のほんとうの欲望が満足できなくなるにちがいない。",
              "citation": {
                "source": "俗即菩提",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならば、その人間に、あきらかに、さうした素質があることを、あのるつぼの試練が、實證してみせるからだ。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "競馬場のるつぼほど、自分の脆弱な意志の面と、いろ／＼な自己の短所がはつきり、心の表に、あらはれてくるものはない。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもふに、スリも、あの他愛なきるつぼに立ち交じつては、たゞ單に、人のポケツトの物を、自分の懷中へ移轉させるだけでは、彼のほんたうの慾望が滿足できなくなるにちがひない。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八角形の鏡のへやは、いまや沸きたぎる人肉のるつぼと化した。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "炭火の中央に金属るつぼがあり、まばゆく白熱して、肉眼で凝視できないほどだ。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて職長が合図をすると、長い「やっとこ」で、白熱したるつぼを炭火から引き上げた。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "――若い女性の身そらで、あんな乱世の中心、有為転変のるつぼへ、何で好んで飛びこんで行こうとなさるか。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
