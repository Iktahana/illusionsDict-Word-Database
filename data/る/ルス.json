    "definitions": [
      {
        "index": 1,
        "gloss": "absence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼がいかにその妻を熱愛していたかは、焼津の旅先から、留守居の妻に送った手紙によく現われている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの留守、この家私の家ではありません。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お留守のあいだは、いやよ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母をも誘ったのであるが、母は、おなかの工合い悪く留守。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "交通の便利な今のわれわれにはちょっと想像し難いほどの長い留守を明けたものであるが、若い時から半分以上は他国を奔走してばかりいた父には五年くらいの留守は何でもないことであり、留守を守る祖母や母も当り前の事と思っていたものらしい。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の長い留守の間に祖母と母と三人きりで割合に広い屋敷の中でのつつましい生活は子供心にもかなり淋しいものであったに相違ないので、この広くて淋しい家と、重兵衛さんの狭くて賑やかな家との対照が幼い頭に何かしら深い印象を刻んだのではないかと想像される。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の五歳の頃から五年ほどの間熊本｜鎮台に赴任したきり一度も帰らなかった父の留守の淋しさ、おそらくその当時は自覚しなかった淋しさが、不思議にもこの燈下の寒竹の記憶と共に、はっきりした意識となって甦って来るのである。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日南洋から手紙が來て「東京の家にはお前の唯一人の叔母たる小生の母と、小生の妹と家内と三人で侘しく留守をしてゐるから一度訪ねて行きなさい」とそれに書かれてありましたが、私はそれに返事して「僕にはとても行けない。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母をも誘つたのであるが、母は、おなかの工合ひ惡く留守。",
              "citation": {
                "source": "春晝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺さんの留守をねらつて、あの婆さんを、えい、とばかりにやつつけて逃げて來た。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　Ａでも、Ｍでも、私でも、借家争議といふ事になると、いつも、このＮ君を留守番に頼んで、闘つてもらふのが常であつた。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち私一家は、一時田舎に落ちのびて、留守は、Ｎ君とＨ君とに委せて置いた。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ちのびた私たちも、留守の両君も、現在の失業者のなめるのと、同じ悩みを味つたのはいふ迄も無い。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、こんな事は云えた義理ではないんだが、僕の留守の者たちの事も気にかかる。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｅ君に青山の小宮君の留守宅の様子を見に行ってもらった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年十七の春父が急いで国元へ引返す際、彼はすぐに騒ぎを打ち鎮めて京へ帰れる見込みで、留守の館には姫の従者として男女一人ずつ残しておきました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "町内一の財産家といふに、家内は祖母と此子二人、萬の鍵に下腹冷えて留守は見渡しの總長屋、流石に錠前くだくもあらざりき、正太は先へあがりて風入りのよき塲處を見たてゝ、此處へ來ぬかと團扇の氣あつかひ、十三の子供にはませ過ぎてをかし。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "左りながら折ふし地方遊説などゝて三｜月半年のお留守もあり、湯治塲あるきの夫れと異なれば、此時には甘ゆる事もならで、唯徒らの御文通、互ひの封のうち人には見せられぬ事多かるべし。",
              "citation": {
                "source": "われから",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はかねて用意の水筒を持って、「民さん、僕は水を汲んで来ますから、留守番を頼みます。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄さん、七五郎さんよ」　七五郎、表から覗いて、　「とっつあん、留守か」　「え、おはいんなさいよ」　「大変だったッてねお静坊、吃驚しただろう」　「ええ、とても怖かったわ」　石松、奥より出て来る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いらっしゃいませ」　「御免なすって……石松つあんのお宅はこちらで御座いますか」　「あの……兄さん今一寸留守なんですけど」　「へえ儂は駿河の清水港の次郎長の身内、大瀬半五郎と申します」　「お父っつあん、お父っつあん」　とお静、奥へ呼ぶ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「留守らしい」と思った時、　雪枝が吾が家から飛び出して来た。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、襖慌ただしく開いて留守番の児分、Ｔ「大変だ！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺の留守の下宿へまたセンティメンタルな手紙がきているにちがいない、早く返事をかいてやらねば可哀そうだ。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分で買いに行くと、留守に来られるかも知れない。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一人｜留守番のときの用心に、いつものように入口に鍵をかけ、電燈を消して、蚊帳の中に這入り、万一｜忍び込むものがあるときの脅しに使う薄荷入りの水ピストルを枕元へ置いた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ミサコは歳入のたらない夫の沈黙からはなれると、階下に彼女をおとずれた人々に居留守をつかって裏口から銀座にあらわれた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "武井さんが草花を買ひに行つた留守に、私は一人寢臺を靜に降りて、椅子に凭りながら烟るやうな雨脚を通して見える、向う側の病室をぢつと眺めてゐた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえ彼には対象を名命し形容するすべての言葉と、その正確な眼との間の隙ばかりが気になる。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生の詩に就いて、特に私の敬服に耐えないものは、その独創あるすばらしい表現である。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
