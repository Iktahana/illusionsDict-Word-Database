    },
    "definitions": [
      {
        "index": 1,
        "gloss": "specific volume",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
