  {
    "uuid": "a9dfead1-ed4e-5dcc-abca-410369ae9cb4",
    "entry": "比容",
    "reading": {
      "primary": "ひよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
