  {
    "uuid": "00670e23-6e12-53b7-86cb-977a8f085d62",
    "entry": "匹婦",
    "reading": {
      "primary": "ひっぷ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
