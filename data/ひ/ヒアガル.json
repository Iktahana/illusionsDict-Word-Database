    "definitions": [
      {
        "index": 1,
        "gloss": "to dry up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大きくなるに従って物を知りたがり、卓布にこぼれた水が干上がるとどうなるかなどと聞いた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "粉の輪で思い出すのは、蒸発皿である種の塩類の溶液を煮詰めて蒸発させる時に、溶液の干上がるに従って、液面が周囲の器壁に接する境界線の所に、粉状の塩の土手ができる。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことがあったら、その道の刑事の鼻の下が干上がるじゃないか？",
              "citation": {
                "source": "五階の窓",
                "author": "合作の二",
                "note": "青空文庫"
              }
            },
            {
              "text": "正体もなく考へに疲れきって、汗を流し、いびきをかいて昼寝してゐるまだ若い男の口からは黄色い歯が見え、硝子越しの夏の日が毛脛を照し、その上に蚤が這ひあがる。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "其すつぱいことといつたら顫ひあがるやうだ。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "衝突して舞ひあがる自然現象の美は描かれて、なまじつか日蓮が立つてゐるのが俗物的に見える位である。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "広場に立てならべた銃は天に舞ひあがるだらう。",
              "citation": {
                "source": "小熊秀雄全集-2",
                "author": "詩集（１）初期詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚く間もなく蝶はひらひらと小生の腕を離れて舞ひあがるのです。",
              "citation": {
                "source": "女優",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、パラパラと向方の楯が舞ひあがる。",
              "citation": {
                "source": "鱗雲",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄ばんだ熱い砂、短い草、さうしたさびしい眺めにも沙漠の中の緑土のやうに松林の見られるところもあつて、炎天に高く舞ひあがる一羽の鳶が私達の眼に入つた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "上水道水源地散歩、蛇が落ちこんで泳ぎまはつてゐる、多分這ひあがることは出来まい、まいまいはいういうと泳いでゐる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞ひあがる犬その鼻をそろへ、その肩をそろへ、おうおうとひくいうなりごゑに身をしづませる二｜疋の犬。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "沼のぬくみのうちにほころびる水草の肌のやうに、なんといふなめらかさを持つてゐることだらう、つやつやと月夜のやうにあかるい毛なみよ、さびしさにくひしばる犬はおうおうとをののきなきさけんで、ほの黄色い夕闇のなかをまひあがるのだ。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "しろい爪をそろへて、ふたつの犬はよぢのぼる蔓草のやうにほのきいろい夕闇の無言のなかへまひあがるのだ。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "煤によごれた煙突からまつすぐに煙がたち昇つて、帽子がおつこちさうになるくらゐ仰むかなくては見えぬほど高く高く舞ひあがるとな、真赤な燠になつて曠野ぢゆうに散らばつて落ちたものぢや。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその悪魔はな――あん畜生のことなど思ひ出すのも忌々しいけれど……その自分の棲家で、世にも哀れな声をあげて号泣しをるものぢやから、それに驚ろいた鴉の群れが、近所の樫の森から、これもまた奇怪な叫び声をあげて舞ひあがると、はたはたと翼さを鳴らしながら、空中へ乱れ飛ぶのぢやつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "考へがうまくまとまらないので．押入れにはいつて蒲團の上へ這ひあがると、暫く横になつてみた。",
              "citation": {
                "source": "婚期",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "指を触れたか触れぬ間に石から虹が舞ひあがる。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノルゲ号は再び空高くまひあがる。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠く山腹を這ひあがる姿は、奇観でないこともないが、私の眼は、もうさういふものにいつか慣れてしまつた。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "歓迎の熱意は舞台の上へ、絶え間なく花びらのやうに舞ひあがるのも道理ではないか。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が恐らく全身のエネルギーを使ひきつた証拠には、漸く岸へ這ひあがると、這ひあがつたなりの腹這ひの恰好のまま、だらしなくのびてしまつて這ひづることもできなかつた。",
              "citation": {
                "source": "禅僧",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ひあがるのも人柄で、高貴な風をして生れた美女であるなら時に思ひあがるのも取柄であらうが、赤い縮れ毛をふりみだした蟷螂のやうな痩せこけた女が女王のやうに思ひあがつてゐることは、概念だけでも醜悪だ。",
              "citation": {
                "source": "老嫗面",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ひあがるのもいい加減にするといいわ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴎の群れが、舞ひさがり、舞ひあがる、そのあとの岩と岩との間へ、忽然として、浦島太郎の姿が浮び出る。",
              "citation": {
                "source": "虹色の幻想（シナリオ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、頭がかうへんにしびれて来やがつて、ひとりでに天空へ舞ひあがるやうな、一種なんともいへない荘厳な感動で、全身がぶるぶるふるへる始末さ。",
              "citation": {
                "source": "道遠からん　四幕",
                "author": "――または　海女の女王はかうして選ばれた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大うなばらがひあがるなんぞ、めったにない。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとには例の白い幟が、これまた地上を離れて、ふはりふはりと空へ舞ひあがる。",
              "citation": {
                "source": "ハビアン説法",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して、黒岩万五が、その場所へ行きついたかどうかといふ瞬間、眼の前にぱつと火花が散つたと思ふと、物凄い爆音が地をふるはせ、一団の黒煙が高く舞ひあがると同時に、飛散する岩の破片が、綾をなして附近の土をまくし立てた。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕日が原のむかふに沈んでそのあとにゆらゆらと月がのぼりはじめると花畑の葉にかくれてた小さな蛾が灰白の翅をふるつてちりちりと舞ひあがる。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
