        "examples": {
          "standard": [
            {
              "text": "彼は生涯をかけて、被圧迫民族の権利向上と独立のために戦い続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "国際社会は、現在も不当な扱いを受けている被圧迫民族への支援を強化すべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歴史の教科書には、かつて帝国主義の支配下に置かれた被圧迫民族の苦難が記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ポーランドのプロレタリアートは被圧迫民族として、乏しい中で生きる道をみつけなければならなかったから、従って鷹揚な気分でいるはずはない。",
              "citation": {
                "source": "ワルシャワのメーデー",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人委員会の一般的任務、組織活動、創作活動について報告し、議案としては、満蒙における日本帝国主義侵略戦争以来激化したファッシズム、社会ファッシズム文化・文学に対する、婦人の独自的抗争の問題、植民地被圧迫民族婦人に向っての積極的働きかけの問題などが課題とされた。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳田球一はかれの思想の動機を問われると、「俺は被圧迫民族だから」と答えたとか人づてにぼくは聞いたことがあったが、そのことは沖縄の歴史がすでに証明していて、言わばこの被圧迫民族としての劣等感を刺激されたのであった。",
              "citation": {
                "source": "私の青年時代",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
