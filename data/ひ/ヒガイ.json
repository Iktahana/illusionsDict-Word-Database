  {
    "uuid": "fcd8e322-627f-52e1-9569-6054e0679618",
    "entry": "被蓋",
    "reading": {
      "primary": "ひがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
