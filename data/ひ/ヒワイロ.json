        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "眞赤であつた西の空は、だん／＼と桃色に薄れて、それがまた鶸色に變つて行くまで、二人は眺め入つてゐた。",
              "citation": {
                "source": "東光院",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう今は世間並みに唯水々しい鶸色です。",
              "citation": {
                "source": "新緑の庭",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう今は世間並みに唯水水しい鶸色です。",
              "citation": {
                "source": "続野人生計事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶸色の紋織の羽織に、鶴の模様が一面に絞り染めになっていた。",
              "citation": {
                "source": "橋",
                "author": "池谷信三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　竜之助の前には、宇津木の妹という、島田に振袖を着て、緋縮緬の間着、鶸色繻子の帯、引締まった着こなしで、年は十八九の、やや才気ばしった美人が、しおらしげに坐っています。",
              "citation": {
                "source": "大菩薩峠",
                "author": "甲源一刀流の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "頸すじの真紅なのや、鶸色なのや、見たこともない綺麗な鴨のなかに白鳥もまじっていた。",
              "citation": {
                "source": "島守",
                "author": "中勘助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
