[
  {
    "uuid": "be3469a6-e6ab-5153-b8d9-80f18c07f07d",
    "entry": "氷原",
    "reading": {
      "primary": "ひょうげん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ice field",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "白き熊、凍え立ち、氷原にひとり在り。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷原や、涯知らず、　　夢は飛ぶ、白く飛ぶ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "依然、われわれは壮大な氷原の真っただ中に停船す。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの北方に拡がっている一氷原に、われわれは氷錨をおろしているのであるが、この氷原たるや、実にわが英国の一郡にも相当するほどのものである。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれが船首にたたずんでいると、月の光りが雲間を洩れて来て、二人はさっき泣き声を聞いた方向に、なにか白いものが氷原を横切って動いているのを見た。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "見渡すかぎり白皚皚、まれに見る氷の裂け目か、氷丘の黒い影のほかには、一点のさえぎるものなき一大氷原である。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩くに疲れて、わたしは舷檣に倚りかかりながら、周囲にひろがっている大氷原に、今しも沈もうとしている太陽の投げる澄明な光りを心から感歎して眺めていると、その夢幻の状態から、わたしは間近にきこえる嗄れ声のために突然われにかえった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪しげな氷丘と、奇妙な頂端を持って動かない一大氷原が、吾人の周囲につらなるのみである。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "かがやく日没の光りが、大氷原を血の湖のように彩った。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "この後、彼は私の存在を忘れたように、黙って船尾の手摺りによりかかって、一部分は暗く、一部分は月の光りにおぼろに輝いている大氷原のあなたを、まじろぎもせずに見詰めていたのである。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その瞬間に月は雲のあいだから皎こうと輝き出て、大氷原の上を照らしたので、わたしは氷原を横切って非常の速力で走ってゆく彼の黒影を、遙かに遠いあなたに認めた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷原の南端は狭い岬のように、その尖端が細まって海中に突出している。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの帰路は平穏無事であり、大氷原もやがては単に過去の思い出となるであろう。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "北極に近い氷原に於て農耕民族の社会ができることも不可能だし、アフリカの砂漠の中に工業文明が栄えるといふことも等しく不可能であるが如くである。",
              "citation": {
                "source": "文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけの圧縮に平気なら、氷原でも何でもどんどん乗り切って行くだろう」　と、ドレゴは羨しそうな顔をする。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "大凡一望平坦の氷原にあつて、空は手の届くやうな低さを感ずる。",
              "citation": {
                "source": "諏訪湖畔冬の生活",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が漸く更けて、寒さが益々加はると、氷原の所々に亀裂の音が起る。",
              "citation": {
                "source": "諏訪湖畔冬の生活",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀裂の音は、所謂氷を裂くの音であつて、氷原を越えて四周の陸地山地まで響きわたる。",
              "citation": {
                "source": "諏訪湖畔冬の生活",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために恐ろしいフィムブルの冬（Fimbul-Winter）が襲来して、氷河と氷原がそれまでは人の住んでいた土地を覆い、氷を免れた部分では収穫はだんだんに乏しくなった。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "この北極風が労農共和国の氷原を撫でて来るために現在の寒さであると。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷原の上を、タンクのようなものや何かが通る、停車場のようなところに自分、多勢の白衣の少女と居る。",
              "citation": {
                "source": "一九二五年より一九二七年一月まで",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の初め、北極洋の氷帯に罅が入って、島のような大きな氷原が、その氷の大陸を離れて南へ泳ぎ出す。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "檻の戸をあけてそっと内部にはいると、見かけは鈍重そうな氷原の豹どもも、たちまち牙を露きだし、野獣の本性をあらわしてくる。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "「父は、ご存知のとおりの造船工学家でしたが、極地の大氷原を氷甲板として、そこに新ドイツ領をつくろうという、夢想に燃えていたのです。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "新極北島――と、父は氷原上の都市をこう呼んでいましたよ。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然への反抗とともに、ルチアノ一派との闘い、氷原の道には、ますます難苦が想像されてくる。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "風雲も死闘もそのうえの事と、いよいよ二十台の犬橇が氷原を走りはじめたのである。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
