    "definitions": [
      {
        "index": 1,
        "gloss": "spreadsheet program",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
