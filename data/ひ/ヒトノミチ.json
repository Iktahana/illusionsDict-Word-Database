[
  {
    "uuid": "69c60f9b-bf73-590c-8d3b-e137feee43fc",
    "entry": "人の道",
    "reading": {
      "primary": "ひとのみち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
