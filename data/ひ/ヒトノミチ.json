    },
    "definitions": [
      {
        "index": 1,
        "gloss": "moral way of life",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "衣食足った人の道楽に画いたものは下手でも自然の気品があって尊いものだ。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お爺さんの瘤が一夜のうちに消失してゐるのを見てとつて、さすがの聖人も、内心すこしく驚いたのであるが、しかし、父母の容貌に就いてとやかくの批評がましい事を言ふのは、聖人の道にそむくと思ひ、氣附かぬ振りして默つて別れたのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と龜はまた噴き出し、「その先人の道こそ、冐險の道ぢやありませんか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑人の道楽ならばいいが、仕事のあるお神さんやおばさん達にはあまり楽な仕事ではなさそうである。",
              "citation": {
                "source": "千人針",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "古いものを新しい目で見るのや、新しいものを古い目で見るような暇つぶしの仕事は、忙しい今の時代には、暇人の道楽でなければ、能率の少ない事業として捨てられなければならないと見える。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう考えから、素人の道楽半分に少しばかり調べてみた結果をこの昭和三年の初春のにぎわいまでに書いてみる。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの楽屋で始終影のようにつきまとう一人の道化師がある。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "くめ子は、女学校を出たのを機会に、家出同様にして、職業婦人の道を辿った。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　但し、松崎は、男女、その二人の道ずれでも何でもない。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お爺さんの瘤が一夜のうちに消失してゐるのを見てとつて、さすがの聖人も、内心すこしく驚いたのであるが、しかし、父母の容貌に就いてとやかくの批評がましい事を言ふのは、聖人の道にそむくと思ひ、気附かぬ振りして黙つて別れたのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と亀はまた噴き出し、「その先人の道こそ、冒険の道ぢやありませんか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "終始一貫して善い人生などというものは、西洋人の工夫した社会にもなく、東洋人の道徳する社会にもない。",
              "citation": {
                "source": "老年と人生",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が、五歳、六歳になって、ほかの女中に甘えたりすると、まじめに心配して、あの女中は善い、あの女中は悪い、なぜ善いかというと、なぜ悪いかというと、と、いちいち私に大人の道徳を、きちんと坐って教えてくれたのを、私は、未だに忘れずに居る。",
              "citation": {
                "source": "新樹の言葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御武家には人質を取るとか申して、約束｜変改を防ぐ道があると承わり居りまするが、其様なことを致すようでは、商人の道は一日も立たぬのでござりまする。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局は矢つ張り私一人の道だ。",
              "citation": {
                "source": "「白秋詩集」序",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "病なき人の道に入ることの難きは、富めるものゝ道に入り難きに比しからむ。",
              "citation": {
                "source": "秋窓雑記",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人びとの間に交って一人の道人が薬を売り符水を施していた。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが獨逸人の道義心が日本人より薄い爲めであるなら、日本人は大いに誇つて好からう。",
              "citation": {
                "source": "當流比較言語學",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "身なりはもちろん粗末であったが、その顔立ちといい姿といい、この毛皮売の老人の道連れにはなにぶん不似合いに見えたので、三人の眼は一度にかれの上にそそがれた。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「如何に家の頭領であろうとも、人の道にはずれたことがあってはならん、人の家来となって、その君が不義に陥るのを諌めもせずに、却てその不義を助けるとは、言語道断の所業じゃ」　左京之進は親信の顔を睨みつけた。",
              "citation": {
                "source": "八人みさきの話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何が不孝じゃ、不義に陥ろうとしているところを、陥らせまいと思うて諌めておるのじゃ、其処許のような無道人に阿諛を云われて、人の道を踏はずそうとしているところを、はずさせまいとするに何が不孝じゃ」「もう、よし、云うな」　不快な顔をして坐っていた元親は、急に立ちあがって奥の間へ入ってしまった。",
              "citation": {
                "source": "八人みさきの話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな庵があって、一人の道士が机によって坐っていたが、張を見ると、「死んで体が腐りかかっているものが、なにしにここへ来た」　と言って叱った。",
              "citation": {
                "source": "賭博の負債",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると袁氏は既にそれを悟って、「郎君はもと貧しかったのを、私が憐んで夫婦となり、交情も日ましに厚くなっているにかかわらず、その恩義をわすれて、私を棄てようとするのは、人の道にはずれたしうちだ」　と言って泣いた。",
              "citation": {
                "source": "碧玉の環飾",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時は支那かぶれの荻生徂徠が、日本を東夷と称してゐた時代だが、春満の「ふみ分けよ、大和にはあらぬから鳥の、跡を見るのみ人の道かは」の一首は、実に彼の一生の抱負であるばかりでなく、門下から門下へと伝承して行くべき建学の根本精神であつた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "破れた頭巾をかむり、破れた綿入をきた一人の道士が有って、その梨を積んでいる車の前へ来て、「一つおくれ」　と言った。",
              "citation": {
                "source": "種梨",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "細い道と、折れた草とは、彼女の弱い足をなやましたけれども、緑のひろ野を求める心が、二人の道をいそがした。",
              "citation": {
                "source": "幸福への道",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "組織の機械は個人の道具に完敗した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＤＯＳとＷｉｎｄｏｗｓ、マッキントッシュ上に積み重ねられた、この個人の道具としての使用経験とアプリケーションの幅は、もはや小錦と曙と武蔵丸が束になってかかったとしても到底動かしがたい。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "人妻ゆゑにひとのみち汚しはてたるわれなればとめてとまらぬ煩悶の罪のやみぢにふみまよふ。",
              "citation": {
                "source": "雪と花火余言",
                "author": "東京景物詩改題に就て",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでない思想信頼は、「ひとのみち」的現象でしかないだろう。",
              "citation": {
                "source": "哲学の現代的意義",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
