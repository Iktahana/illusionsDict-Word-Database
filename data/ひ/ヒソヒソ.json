        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あの……蔵元屋の……アノ博多小町……」　そんなヒソヒソ話が急に途切れて皆、一時にバラバラと逃出しそうな身構えになった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、奥の部屋で何やらヒソヒソ言っているらしかったが、やがて戻って来ると、「折角ですけど……」　お貸し出来ませんわと、悲しそうな表情を唇に見せながら、その唇をキッと噛んだ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまま未亡人は二分か三分の間ヒソヒソと咽び泣いたが、やがてハンカチの下から乱れた眉と睫を見せた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頭の上からサアベルのガチャガチャ言う音と、二人の男のヒソヒソした会話が聞えて来た。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方なぞ見窶らしい平服で散歩するふりをして駐在所を出ると、わざと人目を忍んだ裏山伝いに、丘の上の深良屋敷の近くに忍び寄って、木蔭の暗がりに身を潜めつつ、新夫婦の仲のよい生活ぶりをコッソリと覗いている……といったような噂がいつとなく村中のヒソヒソ話に伝わり拡がった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤガテ　オドロキガ　トマルト、「イマノ　フトイ　コヱハ　ダレデセウ」「キツト　オソロシイ　モノニ　チガヒナイネ」ト　ヒソヒソ　イヒアヒマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが中野学士の背後から覗き込むようにして、何かヒソヒソ囁やいている様子であったが、やがて返事を催促するかのように中野学士の肩に両手をかけてゆすぶった。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "分隊の仲間がいつになくまじめになって、何かヒソヒソと話をし合っているようですから、何事かと思って、耳を引っ立ててみますと、それは僕の両親や同胞たちが、過激派のために銃殺されたという噂だったのです。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉歯という産婆学校長が、この頃よく内科の医局へ遊びに来て、早川とヒソヒソ話をする。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして四人は、何かヒソヒソと重大な相談でもするように首を集めていた。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒソヒソ話をする、馬鹿口をたたく、悪戯をする、便所に行く、放屁をする、鼻唄を歌う、逆立ちをする、それはそれは様々なことで日を暮す。",
              "citation": {
                "source": "獄中生活",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階と違って階下は、破れたなりに硝子戸と雨戸が二重に閉まっているのですから、すこしくらい大きな声でも滅多に外へ洩れませんが、その代りに、大抵のヒソヒソ話でも、二階で息を殺している私の耳へ筒抜けに聞こえて来るのでした。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに引き続いて今度は、私の口を塞ぐ方法に就いてヒソヒソと話し合っておられたようでした。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにはよく若い男女が同席してヒソヒソやっている。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――又、長げえことくたばるめに合わされるんだ」　こっちに背を見せている同じ処から来ているらしい男が、それに何かヒソヒソ云っていた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処かで、ヒソヒソ声がする。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでこの頃巴御殿では、天草時行同志をはべらせ、一本の巻軸を前に拡げ、陰湿たる奥の小座敷で、ヒソヒソ謀議にふけっていた。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奥坐舗は」と聞耳を引立てれば、ヒソヒソと私語く声が聞える。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしあっちで一団、こっちで一団と、彼等はなにかヒソヒソと話しあっていた。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、一々きいているのは、演劇サークル員たちがぎっしりつまって、ヒソヒソと大熱心に、これもまた何かアッと云わせる趣向最中らしい室だ。",
              "citation": {
                "source": "ソヴェト同盟の三月八日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして一わたりすむと中入りには菓弁寿の御馳走、娘達はお世辞の言いくらやら、申訳のしあいやらで、小鳥の百々囀り、良時はただ喧ましく賑わしく、さて再び柝を入れると俄に鎮まりかえって満場ただ水を打ったよう……と見るもほんの一時すぐに又どこやらでヒソヒソ話が始まって、それが彼方此方へと移ってゆく。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議に思ったか船中では、何かヒソヒソ話し合っていたが代って一人船首へ出ると、「鳥刺殿、鳥刺殿」　言葉を改めて呼んだものである。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　三人の船頭は顔を集め何やらヒソヒソ話し出した。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……昔の面影はなくなった」「役ノ行者様よ、役ノ行者様よ、優婆塞様をお守りくだされ」　家の中でも、天幕の中でも、また往来でも「聖壇」でも、信者たちはヒソヒソと噂し合った。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――三人の男達は大分酔ひがまはつたらしく、時々直子の方を向いては何かヒソヒソと語りあつてゐる。",
              "citation": {
                "source": "「リラ」の女達",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だかわからない秋の草花が闇の中に行儀よく列を作って、一パイに露を含んでいる中を、マキリを啣えた囚人姿の虎蔵が、ヒソヒソと匐い進んで行くのであったが、そのうちに闇夜の草花の水っぽい、清新な芳香が、生娘の体臭のように、彼の空腹に泓み透って来た。",
              "citation": {
                "source": "白菊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀次が仏の顔を見て又もサメザメと泣いている間に、皆ヒソヒソと耳打ちし合って、いくらかのお鳥目を出し合って包んだりした。",
              "citation": {
                "source": "骸骨の黒穂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "序にヒソヒソと女達へお説教をしている声がハッキリと聞えて来る。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コンナ大層な病人に、屍体を見せてええか悪いか」「知らせたら病気に障りはせんか」　といったような事を、土間の暗い処でヒソヒソと相談している事実や何かまでも、慥かに察しているにはいた。",
              "citation": {
                "source": "木魂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
