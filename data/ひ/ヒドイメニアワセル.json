    "definitions": [
      {
        "index": 1,
        "gloss": "to bring someone to grief",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
