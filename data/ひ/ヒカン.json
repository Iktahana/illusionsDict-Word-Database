    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pessimism",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "太郎が、いまにいくら美しい恋人を持つとしても、マヽが汚なくては悲観するでせう。",
              "citation": {
                "source": "愚なる（?!）母の散文詩",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまに美くしい恋人を持つても、つひ傍のマヽが汚なくては太郎も悲観せざるを得ないでせう。",
              "citation": {
                "source": "愚なる（?!）母の散文詩",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とお光も悲観した。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "又拍子木チョンと鳴れば、　半次悲観して五郎蔵に、Ｔ「酔っぱらって　来ないのじゃ、ないかな？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿様が嬉しそうに、Ｔ「女の仇討は　珍しいぞ」　老臣がイヤイヤ、Ｔ「御免蒙ります」　断わられて、お殿様、悲観した。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "持主は自分の犬が勝つと喜び、負けると悲観する。",
              "citation": {
                "source": "戦争について",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「しかし生島屋は金持だぜ」Ｔ「嫌ね此の人は」Ｔ「あたし金持は大嫌い」　と言って、Ｔ「それでね兄さんとても悲観していたわ」　そうだろうと伝六。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「南無大慈大悲観世音菩薩。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし考巧忠実な店員に接し掌をさすように求める品物に関する光明を授けられると悲観が楽観に早変わりをする。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「六国史」を読んでいると現代に起こっていると全く同じことがただ少しばかりちがった名前の着物を着て古い昔に起こっていたことを知ってあるいは悲観しあるいは楽観するのである。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲観せざるを得ないじゃないか。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀬古　　僕もすっかり悲観したよ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和九年十一月岡本かの子第一課　悲観と楽観　悲観も突き詰めて行って、この上悲観のしようもなくなると楽観に代ります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲観の極の楽観と同様、せっぱつまった時の落ちつきです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲観の極は例の弾機仕掛けに弾ね上げられ、人生を見直し出した従容たる態度の歌であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「首の座に直る」ということは悲観の極を一度味わったことのある人ということでありましょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲観を突き詰めて行かなければならない事件やら境遇やらには誰しも出会いたくありません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、私たち人間には悲観の際、悲観の原因や感情の由来をたださずに、ただ理由もなく悲観の感慨に耽る傾向のあるのは気を付けねばなりません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、家へ帰つて調書を翻へすと、何たる恐ろしき罪案ぞ、之れでは到底助からないと悲観しなければならなくなる。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "その悲観が事実となつてしまつて、被告等の予期は全く外れた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、道子は思って、悲観した。",
              "citation": {
                "source": "眼鏡",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "揚句に草臥れて了ツて、悲観の嘆息だ。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　飯を喰べながら、そんな話をしているうちに、銀子は気分が釈れ、それほど悲観したことでもないと、希望を取り返すのだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともそのおかげで、私は汚ない二階に寝ころんだまま、煙草と、弁当と、書物の三道楽に浮き身をやつし得るありがたい身分になったわけであるが、同時にその道楽の結果として、自分の頭と、胃袋と、肉体とが日に日に頽廃して行く有様を自分でジッと凝視めていなければならなくなったのには少々悲観させられた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（馬をひかんとすれど動かず。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "金魚はハダカでいても風邪ひかんもんやよって、着物ぬがしておやり」　私は動かなくなった金魚を掌にのせて当惑しながら、母の言葉にうなずいた。",
              "citation": {
                "source": "棲霞軒雑記",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕もよく話してあげるけれど、何しろふみちゃんの家の人は皆、言い出したら最後、後へはひかんという質だから始末がわるいよ。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その約束を堅めて、「あんたはんもまた風邪ひかんように早う往んでお休みやす」「お母はんもあまり心配せんと。",
              "citation": {
                "source": "狂乱",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚きて振りかえる他の一人を今一発、短銃の弾機をひかんとせる時、まっしぐらに馳せつきたる武男は拳をあげて折れよと彼が右腕をたたきつ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "君、若いくせに、そんなにひかんすることはない。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
