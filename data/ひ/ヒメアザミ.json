        "examples": {
          "standard": [
            {
              "text": "薬草として利用される姫薊は、山野に自生していることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "散歩中に、可憐な紫色の花を咲かせた姫薊を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "姫薊のトゲは小さいが、不用意に触ると痛い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "此の時の旅に、色彩を刻んで忘れないのは、武庫川を過ぎた生瀬の停車場近く、向う上りの徑に、じり／＼と蕊に香を立てて咲揃つた眞晝の芍藥と、横雲を眞黒に、嶺が颯と暗かつた、夜久野の山の薄墨の窓近く、草に咲いた姫薊の紅と、――此の菖蒲の紫であつた。",
              "citation": {
                "source": "城崎を憶ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
