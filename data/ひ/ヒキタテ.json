[
  {
    "uuid": "78a2c675-82e7-52ed-a572-ff58e3b07bad",
    "entry": "引き立て",
    "reading": {
      "primary": "ひきたて",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
