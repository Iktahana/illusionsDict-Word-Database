      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "favor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "口で求めず手で引き立てる奈々子の要求に少しもさからうことはできない。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "――然し、然し、今夜はほんとに愉快だつたよ……」と、水島君は互にふと滅入りかけた氣持を引き立てるやうに、元氣作つた聲で云つた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに答える七之助の声も低いので、どっちの話も半七の耳には聴き取れなかったが、それでも壁越しに耳を引き立てていると、七之助は泣いているらしく、時々は洟をすするような声が洩れた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ一緒に來いと、襟髪を取らぬばかりにして妹を引き立てようとした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどそこへ山本氏の著書が現われて自分の手をとって引き立てるのであった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば友だちの名をかたってパリへ出かけるいたずら者が、自分の引き立て役に純ドイツ型の椋鳥を連れて行く、その椋鳥のタイプとか、パリ遊覧自動車の運転手とか案内者とか、ベデカと首っ引きで、シャンゼリゼーをシャンセライズと発音する英国老人とかいうのがそれである。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生徒の生涯を貫ぬいてその魂を導き引き立てるような貴いありがたい影響はどこにもなくなるだろう。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の目から見るとただ自分の心の中へ中へと引っ込んで行く亮を、どうでも引き立てて外側へ向け直してやる事が自分の務めのように思っていたので、機会あるごとに口をすくして説法のような事を聞かせた。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家に著くや無理に、気持を引き立てて、腰の痛みをみせまいやうに一心に姿勢を作つて、『ただ今』といと冷然と云つた。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか私もよろしくお引き立てをねがいます。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "門前の溝が空溝であることを知っている彼は、狗のように腹這いながらそっとその溝へもぐり込んで、駒寄せの石のかげに顔をかくして、二人の立談に耳を引き立てていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝石屋の店を出ると、うなだれがちな私を引き立てるように、晴々とした調子で彼は云った。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　春次が引き立てるので、銀子もどうせ暴露ついでだと思い、「帰れ、帰れ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼女は新吉の腕を引き立てゝ人を掻き分けながらルュ・ド・ラップの横町へ入って行った。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父さんは自分を何とかして引き立て大いに人気を取りたいものだから、僕を此の頃ばか扱いにしているんだ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして予を引き立てゝ神樣の前へ伴れて行つた。",
              "citation": {
                "source": "郁雨に與ふ",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、長屋の者や消火夫仲間が心配して小八の気を引き立ててやろうとした。",
              "citation": {
                "source": "立山の亡者宿",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「詐りを云うな、そのほうがいくら詐っても、その衣服と扇子が確な証拠だ、それでも家内がくれたと云うなら、家内を伴れてくる、どこにおる」「家内は吉利橋の王主人の家におります」「よし、そうか」　府尹は捕卒に許宣を引き立てさせて王主人の家へ往かした。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "家にいた王主人は、許宣が捕卒に引き立てられて入って来たのを見てびっくりした。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは皆権十郎を引き立てるためであった。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴫蔵竹助の妓夫が東栄を引き立てて暖簾の奥に入る。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐佐は、そんなら菓子でもやって、すかして帰せ、それでもきかぬなら引き立てて帰せと命じた。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう願書をふところへ押し込みまして、引き立てて帰しました。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "P. R. B. を Ruskin が引き立てたやうに、所謂自然派を引き立てた島村抱月君も、蒲團を評して、醜のことを書かないで、醜の心を書いたと云つてゐる。",
              "citation": {
                "source": "當流比較言語學",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新子は、唇のあたりに、ちょっと悲しい影を漂わせて、しかし眼は前川の気を、引き立てるように笑いながら、微かに首を振って、席に着いた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「詐りを言うな、その方がいくら詐っても、その衣服と扇子が確かな証拠だ、それでも家内がくれたというなら、家内を伴れてくる、どこにおる」「家内は吉利橋の王主人の家におります」「よし、そうか」　府尹は捕卒に許宣を引き立てて王主人の家へ往かした。",
              "citation": {
                "source": "雷峯塔物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家にいた王主人は、許宣が捕卒に引き立てられて入ってきたのを見てびっくりした。",
              "citation": {
                "source": "雷峯塔物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで穴穂王は囲みを解いて、ひきあげて待っておいでになりますと、二人の宿禰は、ちゃんと軽皇子をおひきたて申してまいりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしてだんだんと深く親密になって、隔てなく彼の心の奥へ入れば入るほど、痛ましくも彼の心をひきたてようとする企てのすべてが無駄であることがわかった。",
              "citation": {
                "source": "アッシャー家の崩壊",
                "author": "THE FALL OF HOUSE OF USHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょんぼりとして、警官にひきたてられてゆく彼の姿を見ると誰の眼にも、すっかり恐れ入ってひきさがってゆく罪人とかわりはなかった。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
