    "definitions": [
      {
        "index": 1,
        "gloss": "competitive show",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "品評会へも出せぁしない。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "育てた美魚を競って品評会や、美魚の番附を作ったりした。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄弟が無かつたので、正月の書初めは母屋の胴の間の鴨居から、品評会のやうに貼り下げられた。",
              "citation": {
                "source": "私の書に就ての追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其上に自転車と写真とは大の御自慢で自転車競争会や写真品評会の賛成員となつて居らるゝ。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆるおめかしの大品評会場である。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る呉服屋が一流どころの画家を集めて裾模様の展覧会を遣ると、一方では西陣の腕ッコキ連を呼び出して友禅染の品評会をやるといった調子である。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "農学校の農産物品評会、満蒙展覧会見物。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝの村長さんは大酒飲みで、馬の品評会でぶつたふれたといふ酒豪です。",
              "citation": {
                "source": "谷間からの手紙",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "神社を正面に、郷土先輩の立像と詩碑、学校、体育場、博物館、図書館、動植物園、露天劇場、農産物品評会場、青少年学芸展覧会場などが整然として一廓を成してゐます。",
              "citation": {
                "source": "青年の夢と憂欝",
                "author": "――力としての文化　第五話",
                "note": "青空文庫"
              }
            },
            {
              "text": "品評会場・人事相談所・嬰児委托所などには、どうやら使はれ相な気運に向いて来た。",
              "citation": {
                "source": "神道の史的価値",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日、品評会で一等の牛を殺したのです。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして秋田犬にも小型、中型、大型と三種あることになっており、犬の品評会にも三種の秋田犬がそれぞれ出品されて、別々に審査をうけるのである。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "品評会の一等賞と云っても、小型秋田、中型秋田とあって、これがホンモノの秋田ではないから、要するに秋田犬のホンモノは東京では見られない。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中で、品評会の賞をもらった犬に、左様、十頭以上、十五頭ぐらいに刺を通じ、拝謁を願ったのである。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "花馬車品評会とは謝肉祭中の大呼物、贅沢中の贅沢、粋と流行の親玉。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "南風吹かば　――モンテ・カルロの巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この品評会は土曜日の午下半日の閑を消するの意で半閑社と名けられ、その雅約は毅堂がこれを草した。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の品評会には、お蔭で一等を取りましてな。",
              "citation": {
                "source": "運を主義にまかす男",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い時分には、あくせく稼いで一と身代｜拵えたこともあったが、邑内に品評会のあった年｜大尽遊びをしたり博打をうったりして、三日三晩ですっからかんになってしまった。",
              "citation": {
                "source": "蕎麦の花の頃",
                "author": "李孝石",
                "note": "青空文庫"
              }
            },
            {
              "text": "六八　葬儀場の品評会　安治川の葬式に、市会議員の八、九分通りが集まった。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "花の品評会の賞品を競う園芸家は、おそらく、しばしば強い肥料を使って、しかも失敗するということがあろう。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "床下三尺くらいの高さで、砂を敷き、品評会へ出せるくらいのブラマ種の鶏が十五、六羽いたが、よそから猫がはいる、鼬がくる、鼠が出る。",
              "citation": {
                "source": "犬",
                "author": "三代目　三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の徴兵適齢者たちは、報告書と照らしあわされて、品評会の菜っ葉や大根のようにその場で兵種がきめられ、やがて年の瀬がせまるころ、カンコの声におくられて入営するのが古いころからの慣わしであった。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛犬品評会　こうした事情を知ってか知らずにか、この頃私に対するマジャルドーの忠告はますます手厳しさを加えてきたのであった。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、上流貴婦人たちの血を沸き立たせていたものに、毎春一回国都マドリイドにおいて開かれる全｜西班牙名家の愛犬品評会というのがあった。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "途端に召使たちの改革も家柄も家格もマジャルドーの問題なぞもたちまち消し飛んで、妻の心は来春の品評会と犬の変り種とで一杯を占めてしまったのであった。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし犬屋で売ってくれましたら、二人で同じものを手に入れて品評会へ出して、ソレルの夫人を吃驚させてやりましょうって……」と妻はショコラの茶碗を措いて、細巻きの煙草に火を点けた。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわんや妻は移り気な性分であったし、来年の品評会までにはまだ八、九カ月ばかりの間もあったし……しかも妻の一日の生活は必ずしも悲哀だけを対象としたものではなかった。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でもほんとうにお上手よ、見わたしたところ、男で一番巧いのは浜さん、女では綺羅子さん………」「まあ」「何だい、ダンスの品評会かい？",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは私が十四歳だった時――ロッホのある例の野原で問題の光景を見てからおよそ一年後のことです――ある夜のこと、私たちは家で、品評会のためにキラローに行った父の帰りを待っていました。",
              "citation": {
                "source": "ドラムガニョールの白い猫",
                "author": "Ｊ. Ｓ. レ・ファニュ　J.S.Le Fanu",
                "note": "青空文庫"
              }
            },
            {
              "text": "農場の使用人たちも、品評会から牛を連れ帰る男たちを除いて寝ていたのです。",
              "citation": {
                "source": "ドラムガニョールの白い猫",
                "author": "Ｊ. Ｓ. レ・ファニュ　J.S.Le Fanu",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
