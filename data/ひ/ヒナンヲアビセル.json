        "examples": {
          "standard": [
            {
              "text": "逆転負けを喫した試合の後、球場の外に集まった過激なファンたちが、球場から出てきたバスに向かって激しい非難を浴びせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "謝罪会見の席で、次々と矛盾を指摘する記者たちの容赦ない非難を浴びせられ、社長は次第に顔を青ざめさせていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は怒りに任せて、かつての恩師に対してもトゲのある言葉で一方的な非難を浴びせてしまい、そのことを深く後悔している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これを見た反長老派の連中は、さまざまに非難を浴びせると共に、ここでは懺悔の神秘が専断軽率に貶し卑しめられていると告発した。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
