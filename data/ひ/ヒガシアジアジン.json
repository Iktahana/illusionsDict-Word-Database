        "examples": {
          "standard": [
            {
              "text": "多様な文化が混在するニューヨークには、多くの東アジア人が暮らしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は東アジア人として、自国の文化を世界に紹介することに情熱を燃やしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "東アジア人のルーツを持つ友人と、互いの国の伝統について語り合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "次には（六）シュリア人、その他近東アジア人。",
