    "definitions": [
      {
        "index": 1,
        "gloss": "stinging (pain)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……額と、頬と、鼻の頭に受けた軽い火傷に、冷たい空気がヒリヒリと沁みるのを感じていた……そうして工場全体の物音が一つ一つに嘲笑しているのを聴いていた……。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に左右の踵に処々靴ズレが出来たらしくヒリヒリと痛みだしたのを感じた。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "脳味噌の中心にヒリヒリと焦げ付く位である。",
              "citation": {
                "source": "ナンセンス",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月の薄ら甘い朝の陽が、爽やかな感触で、さつき剃刀をあてたばかしの彼の頬にヒリヒリと、光るやうに沁みた。",
              "citation": {
                "source": "或る五月の朝の話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「焼酎がヒリヒリと泌みていい心持がいたしやす。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「焼酎がヒリヒリと沁みていい心持がいたしやす。",
              "citation": {
                "source": "旗本退屈男",
                "author": "第十一話　千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼吸がきれて咽喉がヒリヒリした。",
              "citation": {
                "source": "焔",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒリヒリと神経のなかに破り裂けようとするものを抑えながら、彼は快活そうに振舞っていた。",
              "citation": {
                "source": "遥かな旅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがここでは、そとに居た時のように人の皮膚の上っ面がヒリヒリするくらいでなく、肉の中までも、骨髄の中までもえぐられるような痛みなのだ。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "膝からモモにかけての肉がヒリヒリ痛む。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、二度目にひとりで、その同じ場所を訪れた時の記憶もヒリヒリと眼のまえに彷徨っていた。",
              "citation": {
                "source": "秋日記",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな姪たちは耳や指を火傷してゐたし、次兄の肩の傷もヒリヒリと痛むらしかつた。",
              "citation": {
                "source": "星のわななき",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「砂が目に入ったので御座ろう」「いや、虫の群をなしたのが、あの風に巻込まれて、運悪くも眼の中に」「それならば未だ宜しいが、曲者有って、一時に目潰しでも投げたのでは御座るまいか、ヒリヒリ致してどうも成り申さぬ」　大名行列の大勢ことごとくが、一時｜盲目になって立往生をしたのであった。",
              "citation": {
                "source": "怪異黒姫おろし",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い事クリームを顔へ塗らないので、顔の皮膚がヒリヒリしている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い事クリームを塗らないので、顔が、ヒリヒリする。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "別段に痛い処も痒い処もないが……併し眼と口の中が砂ホコリで一パイになっているらしく、瞼がヒリヒリして歯の間がガリガリするその不愉快さ……。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそれは現実世界でいう一瞬間と殆んど同じ程度に感じられた一瞬間で、その次の瞬間に意識を恢復した時に福太郎はヒリヒリと痛む眼を一パイに見開いて、唇をアーンと開いたまま、落盤に蓋をされた炭車の空隙に、消えもやらぬ安全燈の光りに照し出されている、自分自身を発見したのであった。",
              "citation": {
                "source": "斜坑",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その新しく辷り落ちて来た軽い、深い粉末の堆積の中に落ち込み落ち込み、掻き分け掻き分け進んで行くうちに瞼がヒリヒリと痛くなり、鼻の穴がシクシクと疼き出し、息も絶え絶えになって一と休みすると、忽ち零下何度の酷寒を感じ初めるので、又も匐うようにして歩き出す苦しみは、経験のある人でなければわからない。",
              "citation": {
                "source": "眼を開く",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この臂はヤングが「｜猫の臂」って名をつけて、紐育婦人の臂くらべに出すって云っていたくらい柔らかくてスンナリしていたのが、知らないうちに擦り破れてしまって、動くたんびにヒリヒリと痛み出して来たんですもの。",
              "citation": {
                "source": "支那米の袋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "触覚のモティフはまず大体凸凹、ブツブツ、クシャクシャ、ザラザラ、ガタガタ、ゴツゴツ、コツコツ、カチカチ、ヘナヘナ、ヒリヒリ、サラサラ、ヌラヌラ、スベスベ、カサカサ、フワフワ、ネバネバ、ニチャニチャ、張力、弾力、円錐球楕円三角鋭角鈍角平面四角八角ギザギザ階段その他いろいろの複雑な立体などである。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "「傷がヒリヒリ痛むから飲むのさ。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭のシンも、電気のようにヒリヒリする。",
              "citation": {
                "source": "不良少年とキリスト",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "日はますます強く照って、二日の山登りに頬がヒリヒリする。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお痛いこと、ヒリヒリと痛みます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本で昔単にヒル（その鱗茎を食うと口がヒリヒリするのでいう）と呼んだのは、実際はニンニクをいったものだが、書物の上ではこのニンニクのオオビルとコビルすなわちメビルとの二つを指して、かくヒルというとなっている。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれは乾質でけっして生で食べるべきものではなく、強いてこれを食ってみると山椒の実のように口内がヒリヒリする。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に書いたように茱萸はすなわち呉茱萸で、その実の味はヒリヒリするものであって、薬にはするが、敢て果のように嘗め啖うべきものではない。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、トウガラシのヒリヒリとした刺激性の性質は上にのべた物質で色をつけるとブランディおよびラム酒の香りを高めていたことを知らなかった。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ痛、ヒリヒリするわ。",
              "citation": {
                "source": "猫と庄造と二人のおんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗が顎を伝わって胸のほうへ流れ込み、咽喉がカラカラに乾いて呼吸をするたびにヒリヒリと痛んだ。",
              "citation": {
                "source": "キャラコさん",
                "author": "雪の山小屋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
