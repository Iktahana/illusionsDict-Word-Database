[
  {
    "uuid": "2070da72-8dba-531b-a825-ef36a029ff89",
    "entry": "皮膚",
    "reading": {
      "primary": "ひふ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
