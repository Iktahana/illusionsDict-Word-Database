    },
    "definitions": [
      {
        "index": 1,
        "gloss": "skin",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その志明かなれば冬の夜を、われは嘆かず、人々の憔燥のみの悲しみや憧れに引廻される女等の鼻唄を、我が瑣細なる罰と感じそが、わが皮膚を刺すにまかす。",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "言はば室生は文明人の繊細な皮膚と野蛮人の強健な心臓とをもつて生れた、近代世紀の幸福なる予言者である。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "理性や知性の純粋性など、とうに見失っているらしく、ただくらげのように自分の皮膚感触だけを信じて生きている人間たちにとっては、なかなか有り難い認識論である。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮膚は、大仰な言いかたをすれば、鶯の羽のような汚い青さで、まったく光沢がなかった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮膚にべとつくようでかなわんのだ」私もそれは同じ思いであった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年は、竹村書房から「皮膚と心」京都の人文書院から「思い出」河出書房から「女の決闘」が出ました。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを心臓の方へ導かうとする、つまりより流動的にしようとして、十九世紀末葉は「暗示」といふ言葉を新しく発見したのだつたが、それはやがて皮膚感覚ばかりの、現に見る文明と堕してしまつた。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "中で一番威張れる者が、その赤らんだ薄い皮膚の眼蓋の上にロイド眼鏡を掛けて、彼女が襖を開くや愛相よく「今晩は」と言つた時、彼女は漸く何だか嬉しくなつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人はもう五十を越した、人の好さそうな男であるが、主婦はこれも五十近所で、皮膚の蒼黄色い何処となく険のあるいやな顔だと始め見た時から思った。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱を注いだような裸の皮膚には汗が水銀のように光っている。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥えて居た方はことに衰へて、あのはち切れさうだつた血色のいゝ皮膚が、今はもうタブタブして居て、ガサガサした感じさへ与へて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年は、竹村書房から「皮膚と心」京都の人文書院から「思ひ出」河出書房から「女の決鬪」が出ました。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮膚感覺が倫理を覆つてゐる状態、これを低能あるひは惡魔といふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひところ世界中に流行したアメリカ映畫、あれには、こんな所謂「純眞」な雄や雌がたくさん出て來て、皮膚感觸をもてあまして擽つたげにちよこまか、バネ仕掛けの如く動きまはつてゐた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その志明らかなれば冬の夜を我は嘆かず人々の憔懆のみの愁しみや憧れに引廻される女等の鼻唄をわが瑣細なる罰と感じそが、わが皮膚を刺すにまかす。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "白花という名を冠らせるくらいだから白くはあるが、花冠の脊には、岩魚の皮膚のような、薄紅の曇りが潮し、花柱を取り巻いた五裂した花冠が、十個の雄蕊を抱き合うようにして漏斗の鉢のように開いている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、山体の完備を欠損するかの如くに見える放射状の側火山も、同心円の御中道も、輻射状の谷沢も、レイニーア山や、フッド山が、氷河を山頂、または山側から放流して、山の皮膚ともなり、山それ自体の一部ともなってしまうように、かえって創造的合成の効果を献げている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "火山の中は凡べてが「大きな単純」であるから、注意して観察すれば、風の描いた紋も解るのである、もっともこういう現象は、火山とのみ限られることではないが、火山のような柔らかい印象を受けやすい皮膚であればこそ、それを劃然と、鮮明に残しているのである。",
              "citation": {
                "source": "日本山岳景の特色",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "六合五勺にして、頬は皮膚病患者のように黄色になった、弟はと見れば、唇は茄子のように、うす紫になっている。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほど、彼女の皮膚は腐っていたのだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "掘鑿の中は、雪の皮膚を蹴破って大地がその黒い、岩の大腸を露出していた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る町の角をまがつて左側に蝋細工の皮膚病の模型を並べた店が眼についた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その皮膚は丁度せんざんこうの鱗片を剥がした跡に酷似しているという。",
              "citation": {
                "source": "「万年筆」欄より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちルプスという皮膚病は弧灯の強い光で長く照らすとだんだんに治癒するそうである。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一たいが、小づくりで、薄皮膚の色の白いやはらかに素直な毛をそつとわけて声もほそぼそと、歴史といふ遠い昔の夢をロマンチツクにおどおどと語る――ただ、すこしほんのすこしではあるけれども、見栄坊に気どつて年頃の女生徒への多少の対感意識はあつたやうでした。",
              "citation": {
                "source": "ある男の死",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに距離の間隔はあれども無きが如く、翁の擬して撫で来る指の腹に地平の林は皮膚のうぶ毛のように触れられた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "柚木にそうさせて置いてから、老妓はその反対側の腕の皮膚を自分の右の二本の指で抓って引くと、柚木の指に挾まっていた皮膚はじいわり滑り抜けて、もとの腕の形に納まるのである。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の陽ざしが麗らかに拡がった空のような色をした竹の皮膚にのんきに据っているこの意味の判らない書体を不機嫌な私は憎らしく思った。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの媚めいた青白くも亦とき色の神秘が、着物も皮膚も透して味覚に快い冷たさを与えた。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と彼女は云つた、奴はもうあのことを修道院の中に云ひふらしてゐる！",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
