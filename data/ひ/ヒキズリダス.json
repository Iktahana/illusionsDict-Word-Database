        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「いくら、ビラを取りあげて、やかましく云ったって、俺等の脳味噌まで引きずり出す訳には行かねえんだぞ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若くてか弱きお方に、そのような場所へ踏み込み、ごろつき連中を尻目に夫を捜して引きずり出すなど、どうしてできようか。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "（兄の襟筋を掴み引きずり出す）甚兵衛　（やや愚鈍らしく）われこそ何するだ！",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（甚兵衛の手を掴んで引きずり出す）おきん　さあ！",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さんには自分の獲ものを引きずり出すことも出来ない。",
              "citation": {
                "source": "一人舞台",
                "author": "ストリンドベルヒ　August Strindberg",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は箪笥の抽出から、むちゃくちゃに着物を引きずり出す。",
              "citation": {
                "source": "理想の女",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、火と煙の渦巻いている室に手拭いでしっかり鼻と口とを押さえて這い込み、傷者を引きずり出すのが、今はなによりも楽しくうれしかった。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　エゴール・サヴィチは寝台の後ろにもぐりこんで、顔を真赤にしながらやっとのことで框にはまった画布を引きずり出す。",
              "citation": {
                "source": "天才",
                "author": "ТАЛАНТ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルピック夫人は、敷布を引きずり出す。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒岩万五は、さういふ呼吸を実に見事に心得てゐて、難なく、片つぱしから引きずり出す。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "また索溝の具合を見ると、顎の下から斜上に耳の下のところまで残っているが、その上はなくなっている、これによってもその繩は頸を締めるためではなくて、死骸を現場から引きずり出すためだったということがわかる。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして瞬く間に六七人の仲間を引きつれて来ると、一人が納屋から古俵を持ち出す、他の者が細引きを引きずり出す、枯木を集めるもの、火打石をさがすもの、見る見るうちに、何だかものものしい仕度が出来上った。",
              "citation": {
                "source": "三郎爺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたが無理やり引きずり出すようなことさえなさらなきゃあ、めったなことで、自分からおんでるような、気のきいた女ではありませんのでな。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを思うと、物置きの奥から一年間の埃のたまった幾つもの箱を引きずり出す面倒は忍ぶとしても、又この間の弁天座の時のような窮屈な場面が想像せられて気が重くなって来るのであった。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "引きずり出すぞ、襟がみ取ッて」「ぜひもない」　やっと、机を離れて、ふとんの中の命松丸と、台所の媼へ、「行って来るよ。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは薄っぺらなその教科書をひきずりだす。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
