          "standard": [
            {
              "text": "小学校で実施された避難訓練では、「おさない・はしらない・しゃべらない」という約束を全員が守り、スムーズに運動場へ集合できた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "抜き打ちで行われた会社の避難訓練により、非常用持ち出し袋の場所を把握していない社員が予想以上に多いことが判明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "避難訓練の締めくくりとして、消防署の方から消火器の正しい使い方と、初期消火の重要性について実演を交えた講習を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "九月十日（火曜）　夜中に女中たちは避難訓練で近くの小学校迄逃げさせられたり、女房も朝迄起きてゐた、そのさわぎの中をオールドオークニーの酔心地、朝一度、便所に起きたが、又ねて、十二時半迄ねてしまった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
