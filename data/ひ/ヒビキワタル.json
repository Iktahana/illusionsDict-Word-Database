        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "見よ　穹窿に煤煙ながれ工場區街の屋根屋根より悲しき汽笛は響き渡る。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その声が思ったより高く一間の中に響き渡ると、返事をするようにどの隅からもうめきや、寝返りの音や、長椅子のぎいぎい鳴る音や、たわいもない囈語が聞える。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "機関銃の音が静寂を破って響き渡るたびに人々は黙々として家屋の囲壁のなかに自己を守護するのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と上田が目を丸くしますと、「お玉さん、……樋口さん……お玉さん……樋口さん……」と響き渡る高い調子で鸚鵡は続けざま叫び出したので、政法も木村も私もあっけに取られていますと、駆けこんで来たのが四郎という十五になるこの家の子です。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、子供らしい笑いが洞窟のような宿舎に響き渡る。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』アグリパイナの必死の抗議の声は、天来のそれの如く厳粛に響き渡る。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまざまのこと聞えて、ものの音響き渡る。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "陰鬱な死の節奏は絶えず快く響き渡る……と神経は一斉に不思議の舞踏をはじめる。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は笑つてこんなことを云はせて置き、やがて、響き渡るほどのどら聲で、「默れ！",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "棍棒が倒れるとカランカランという音がして、それが小屋の中から静かな園内へ響き渡る。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "槌の音が向こうの丘に反響して静かな村里に響き渡る。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ヒルトン・キューピット夫人は、瀕死の重傷を負うているのだよ」　その男は嗄れた声で、家中に響き渡るように、悲叫を上げた。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その男はしわがれ声で、家中に響き渡るような、悲しみの叫びを上げた。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "澄み切った空に、大勢の人間から発せられる混沌とした騒音や、車輪のきしみ、馬のいななきなどが響き渡る。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ＤＯＳ／Ｖ万歳」の雄叫びはなぜかマッキントッシュの博覧会に響き渡る　地の果ての幕張メッセで開かれたマッキントッシュの博覧会、マックワールド・エキスポの会場で、マック使いのライターのＴ田とバッタリ会った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、再び飛び散り、再び相寄り、床に伏して、キヤプテンの脚にふまへられる颯爽たる様がある、あしのうらの音が、ヒタヒタと床に、物凄まじく、拍手の音のやうに響き渡る、――また、三十人？",
              "citation": {
                "source": "舞踏学校見物",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "重砲学校から響き渡るラツパの音を聞きながら間もなく走水に達すると、日本武尊を御祭神と祀る走水神社に参拝した。",
              "citation": {
                "source": "或るハイカーの記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は手の平にウンと力をこめると、その痛さが全身に響き渡る程強くピシリ／＼と臀を引ツぱたいた。",
              "citation": {
                "source": "鞭撻",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、最も早く啼くのが郭公である、くわつくわう／＼と啼く、鋭くして澄み、而もその間に何とも言ひ難い寂を持つたこの聲が山から溪の冷たい肌を刺す樣にして響き渡るのは大抵午前の四時前後である。",
              "citation": {
                "source": "山寺",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "……キ……貴様は、よくもよくもこの永い間俺に恥をかかせおったナ」　こうした声が響き渡るうちにお父様は片方の手を私の頭から離されましたので、私はやっと眼を開くことが出来ました。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "座敷中に響き渡る野天声を出した。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらも何うせ新吉には解りもしなかつたが、浦賀のお爺さんの声が響き渡ると家ぢうが滝に打たれるやうに颯々として、雷音の半鐘のやうな騒々しさとは比べものにならなかつた。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　水車小屋に住み慣れてからは、小屋の外で使ふ自分の音声が、あたり前の会話の場合でも恰も参四郎の声のやうに太く調子高いのに僕はあきれてゐるのだが、斯んな長閑な会話をとり交して歩いてゐても、それらが次々にあざやかな山彦となつて響き渡るせゐか、沼のまはりでは寧ろ会話のやりとりは困難であつた。",
              "citation": {
                "source": "沼辺より",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　男共がワツと叫んで僕とミツキイに飛びかゝつた時、ミツキイは手早く引金を引いたのだ――無論空砲なのだが、銃声が響き渡ると、奴等は忽ちワーツといふ悲鳴をあげて戸外へ転げ出た。",
              "citation": {
                "source": "山男と男装の美女",
                "author": "ミツキイのジヨンニイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて浴室の煙突からは白い煙が立上り、薪を割る斧の音が辺の樹海に冴え冴えと響き渡る。",
              "citation": {
                "source": "闖入者",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "樽野の部屋から朝夕朗らかな喇叭の音が響き渡るのを知つた青年代表が彼を訪れて管楽に関する教へを乞ふた。",
              "citation": {
                "source": "村のストア派",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その室に、今、垂死の兵士の叫喚が響き渡る。",
              "citation": {
                "source": "一兵卒",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳町から餌差町、この辺は広い往来で、両側に家々がビッシリと並び、いらかが薄白く陽に光り、地面からほこりが立ち、物売りの声、下駄の音、行き来の人の話し声、文字通りの雑沓であったが、その騒音を貫いて、ジャラーンと響き渡る物の音、修験者の持っている鉄杖だ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの青空高くひびきわたるかたつむりのメガホーンの声でした。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "行いが証明となり、考えは言葉となって、その言葉は、広く世の中にひびきわたるのです。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
