    "definitions": [
      {
        "index": 1,
        "gloss": "(someone's) child",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なにせ相手は槍の名人の子孫である。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "槍の名人の子孫に対して私は極度に用心し、かじかんでしまったのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯殿でまだ沸き切らぬ湯をチヤブチヤブさせて遊んでゐる四人の小さな子供等こそは、実は一番喧しかつたのだが、長男に就いての一件の起こつてる時なので、他の四人の子供は何だか可愛い気がして、何時ものやうにとても「やめろ！",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はそれが羨しくて、母に名刺を呉れといふのであつたが「あれはお葬式のお供に行く人の子供だけが貰へるのです」つまり名刺を持つて行つたからとて菓子が貰へるわけはないといふのであつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど、人の子の側より考へて罪悪は犯すべからざるものなり。",
              "citation": {
                "source": "地上組織",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮りに神の御旨を人の子の側にも当篏めんか、最初に神の脳裡に構へられし静止せる理想郷に逆源するのみ。",
              "citation": {
                "source": "地上組織",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに神人の子に未来を知るの力を与へ給はず。",
              "citation": {
                "source": "地上組織",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、人の子の謂ふ奇蹟も容易きことなれど、人の子を遣りたる相対の世界には神自らも相対性以外を行ふとも見せられず。",
              "citation": {
                "source": "地上組織",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "白人の子供も黒人の子供も、すべての人間の子供は、本來フアンタスチツクな夢の宮殿に住んでゐるのだ。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし思ふに、さうした話は事實でなく、事實であらせたいと望むところの、大人の子供に對する――特に教育者の子供に對する――意志表示を語るのだらう。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日だけの休暇を楽しむ、可憐な奉公人の子供は、何の夢を見ていることやら、と言う意味である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然は地にみつ光なりや今日はめぐりて山に入れど見よかの大空姿｜優に夜の守月姫宮をいでて唱ふをきかずや人の子等は。",
              "citation": {
                "source": "感謝",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "板垣退助を戴いた自由党が全盛の時代であったので、軍人の子供である自分は、「官権党の子」だという理由でいじめられた。",
              "citation": {
                "source": "鷹を貰い損なった話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、私の今云はうとしてゐる井戸は、一方には夫婦と三人の子供、もう一方には夫婦と二人の子供が、現在住んでゐる、その共通の井戸の事なのである。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "五人の子供等と、四人の大人にとつて、二ヶ月以上も、井戸から水を取り上げた事実は、この二人の借家人の、左まで鋭からざる神経にも相当な影響を及ぼした。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の子供は、コムプレッサー、鍛冶場、変電所、見張り、修繕工場、などを見て歩いたが、その親たちは見当らなかった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の子供たちは、今まで、方々の仕事場で、幾つも幾つも、惨死した屍体を見るのに馴れていた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "同君の二人の子供も一緒に居た。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家は小田原在に在る穀物商で、妻も娶り兄妹三四人の子供もできたのだが、三十四の歳にふと商用で東海道へ足を踏み出したのが病みつきであった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その背後に立っていたのは、この未亡人の二人の娘で、とうに他家に嫁いで二人ともに数人の子供の母となっているのであるが、その二人が何か小声で話しながら前に腰かけている老母の鬢の毛のほつれをかわるがわるとりあげて繕ってやっている。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "只予の性質として人の子とあるものが只自己一身の功業にのみ腐心するは不都合である、両親を見送っての後ならば、如何なることを為すとも自己の一身は自己の随意に任せてよいが、父母猶存する間は父母と自分との関係を忘れてはならぬ。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の子として私心的態度と云わねばならぬ。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅子が餌を持ち出してきて鶏にやるので再び四人の子どもは追い込みの前に立った。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かしら人の子ではなくて何かの菩薩のような気がする。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の子供に五六人の子供がかかっている。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　彼女の二人の子供、十歳になった三郎と、まだ七歳の四郎は、その日昼飯が済んでから、戸外へ遊びに出たまま帰って来ないのであった。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女のひとのことも聞かれた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひとのことかよ、おめえさんこそ」と婆やは、ひょいとおどけた眼付をして笑った。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども堕ちるひとのことや又溺れながらその苦い鹹水を一心に呑みほさうとするひとたちのはなしを聞いても今のあなたにはたゞある愚かな人たちのあはれなはなし或は少しめづらしいことにだけ聞くでせう。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あのひとのことで。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            }
          ]
        }
