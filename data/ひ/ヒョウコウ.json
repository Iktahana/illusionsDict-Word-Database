          "standard": [],
          "literary": [
            {
              "text": "それから日本全国中、富士山に次いでの標高を有する、私共のいわゆる日本南アルプスの第一高峰｜白峰（三一九二米突）がそれである。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士山は日本では三千七百七十八米突という抜群の標高を有しているが、太平洋方面は黒潮が流れるほどの暖かさで、かつ冬季は霽れて雨量が少なく、山腹以上の傾斜が急峻であるから、これも氷河を作る資格がない。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して日本海方面の北アルプスは、冬季氷雪の多いこと無双であるが、山の標高は辛うじて三千米突を出入するに過ぎない。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "まア暑さを避けるのなら、何と言つても、標高の大きい山岳地方に行くに限ると思ひますね。",
              "citation": {
                "source": "談片",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "標高といっても、一五〇メートルもないくらいで、ほんの十数キロほど北東には、繁華な市街がひろがっているはずだが、そんなことは想像もつかない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "地球が発狂したのでもなければ、この一万数千トンもある巨船が、標高五千十七メートルのヘルナー山頂に噴きあげられた理由が説明できんじゃないか。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸からサルジニアに進入するためにはサボナから西北方アルタールを越える道路（峠の標高約五百メートル）が最良で、少し修理すれば車を通し得る状態であった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "実にこの頂上こそ海抜一三四四メートル六の標高を有し、兵庫アルプス南方の重鎮兵庫御嶽の絶頂であります。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この独立標高点から右尾根を下り一〇一〇メートルくらいの山へ登ります。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "標高も七百米の小杉谷斫伐所附近では、年平均氣温が十六度に下り、十二月降雪を見、翌年の三月まで、積雪してゐるといふことである。",
              "citation": {
                "source": "屋久島紀行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "標高七百米の小杉谷の斫伐所附近では、平均気温が、十六度に下り、十二月から、春三月頃までは、積雪してゐるところである。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷点下何度といふ代りに標高一万米突の崑崙山を持つて来たわけもあるが、「病めば我がある」といふ件、重態に落ちた体験の持主なら容易に同感出来る境地である。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "道路は幅広く、よく舗装されて、諸所に地名と標高が記されてあった。",
              "citation": {
                "source": "エトナ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでに研究せられたところでは、火星の空気の濃さは地球で一番高いといわれる標高八千八百八十二メートルのエベレスト峯頂上の空気よりももっと稀薄であろうといわれていた。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは標高はわりに低いから、真夏の今頃よりは、もっと涼風立って、農村の忙しくなった時分に、静かに入湯に来たいものと考える。",
              "citation": {
                "source": "山の湯雑記",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルンの標高は約六〇〇米で、インターラーケンも大体似たもので、少し高いが一〇〇呎と差はない。",
              "citation": {
                "source": "吹雪のユンクフラウ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラトンとダンテとを読むと読まないとではその人の理念の世界の登攀の標高がきっと非常に相違するであろう。",
              "citation": {
                "source": "学生と読書",
                "author": "――いかに書を読むべきか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "標高があるだけに天気の悪いときはずいぶん寒い。",
              "citation": {
                "source": "涸沢の岩小屋のある夜のこと",
                "author": "大島亮吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は小槍の標高より少し上まで行ったが、それで考えると登り二時間は大丈夫かかると思う。",
              "citation": {
                "source": "春の槍から帰って",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに峙っている鷲峰山は標高はようやく三千尺に過ぎないが、巉岩絶壁をもって削り立っているので、昔、役の小角が開創したといわれている近畿の霊場の一つである。",
              "citation": {
                "source": "狂乱",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "名づけてホテル・ユンクフラウヨッホは少々大袈裟な名前で、寝室は二室しかない、寝台が三つずつ、先ず小屋が正直な命名であるが、海抜一万一千三百余呎、しかも冬の真中のことであるから、高くて（標高ではない）まずくとも、あえて食事に不足を云うべきではない。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "標高四千百六十七米突の氷の上で、天気はよし風はなし、何しろうれしくってうれしくってたまらない。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "二日の登山に百六十円は、成るほど高いのは、標高ばかりではないと思った。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "標高七千四百尺、線路はここで、始めて、ティラノからポスキヤーヴォを通って、サン・モリッツへぬける街道へ出会うのであるが、ボネッティの小村に面した、東側の斜面に、春先きの今は雪崩が多くて、非常に危険だと云う話しだ。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "備えつけの、毛の上靴に履きかえて、壁にかけたジークフリトの大きな地図など見ているうちに、たちまち御茶の用意が出来る、簡単な食事でも、適度の運動と、標高も少しは手伝って、なかなか甘く味わせる。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢の川峠は、紀伊と伊勢と大和の三国の境をなす大台ヶ原山を主峯とした台高山脈が南に走って高峯山となり、その裾を熊野灘に浸そうとする肩の辺にあってなお標高二千五百尺。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "標高僅かに三百尺位の牡丹台であるが、一番高いところに登ると、四方へ闊達に開けた大同江平野が一眸のもとにあった。",
              "citation": {
                "source": "淡紫裳",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "越後側に聳える兎岳、越後沢山、八海山、越後駒ヶ岳などを合わせた山々は、標高僅かに七、八千尺に過ぎないけれど、人里遠いことにおいては日本一である。",
              "citation": {
                "source": "利根の尺鮎",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ標高の山に積もった雪ならば、裏日本に面した土地が早く解ける。",
              "citation": {
                "source": "水と骨",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
