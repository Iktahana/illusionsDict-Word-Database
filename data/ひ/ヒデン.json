[
  {
    "uuid": "3451ca9b-6fe8-5800-9c9f-f6e434f68597",
    "entry": "秘伝",
    "reading": {
      "primary": "ひでん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "secret (recipe, medicine, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "家康は「上を見な」「身の程を知れ」の「五字七字」を秘伝とまで考えたから、家臣の美服を戒め鹵簿の倹素を命じた。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬草の混ぜ合せに秘伝がある。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "撫子　それはね、南京流の秘伝なの。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂しいところへ物を隠すなどは素人のすることで、なるたけ人目の多い賑かいところへ隠して置くのがわたくし共の秘伝です。",
              "citation": {
                "source": "自来也の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その必ずという文字は、利休の「客之次第」の秘伝にさえなっているのである。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か、秘伝でもあるのかね。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅田はもっともらしい顔をして、「なあに、秘伝というほどの事でもないが、問題は足の指だよ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜がふけると、一層身に染みて、惚込んだ本は抱いて寝るといふ騒ぎ、頑固な家扶、嫉妬な旦那に中をせかれていらつしやる貴夫人令嬢方は、すべて此の秘伝であひゞきをなすつたらよからうと思ふ。",
              "citation": {
                "source": "いろ扱ひ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、直ちに射術の奥儀秘伝を剰すところなく紀昌に授け始めた。",
              "citation": {
                "source": "名人伝",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、親譲りの秘伝ものだ、はツはツはツ、」と浮世を忘れた笑ひを行る。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お待ち、親譲りの秘伝と言ふと……」と言ひ方は迫つたが、声の調子は大分静まる。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アバタの穴が消せないままに、極意の秘伝でこの身を消して、雲の上より未練の一声、立つな、叫ぶな、探すな、坐れ。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "即刻、私と同伴して、程近い中庄の老先生の枕頭に来られて、出来るだけ大きな声で、私にはチンプンカンプンわからない謡曲の秘伝らしい事を繰返し繰返し質問されたが、私の推察通り意識不明の御容態の事とて、老先生が御返事をなさる筈がない。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に藩公の御所望で、物習能（普通の能ではない、達人でなければ舞えない秘伝の曲目）を仰付られた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "又来なさい」　　　　　　　　　　◇　只圓翁は重い曲を容易に弟子に教えなかったばかりでなく、謡の中の秘伝、口伝はもとより、稽古の時に叱って直した理由なぞは滅多に説明しなかったらしい。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚籠を担いで川までお供して行く途中の長い長い田圃道の徒然なままに翁と雑談をしながら何気なく質問をすると、翁は上機嫌なままに大事な口伝や秘伝を不用意に洩らすことがあった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは斎田氏の稽古の秘伝で、後にその心持ちで謡ったり舞ったりして翁から賞められた事が度々あったので、とうとうこの斎田氏の秘伝のお稽古法が露見してしまった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "斎田氏の不漁は秘伝口伝の不漁であった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その際、秘伝書を手に入れようという、深き慮があるものなら、もっと辛抱をしたでしょう。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人は「水だま」の黄金の花粉を空間に射る物のやうな力強い弾機をば、花弁の絹のやうなあんなに繊弱な織物の中へ切り込む秘伝を何時になれば発見することか。",
              "citation": {
                "source": "卓上演説",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し吾人は、この力の見えざる原動力の秘伝を発見し得ぬのである。",
              "citation": {
                "source": "卓上演説",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本に於ける望軍気の術は支那からの伝来であるか邦人の発明であるか知らないが、いわゆる兵法家達の秘伝として珍重されたもので、何れも板本（木版本）ではないが、その稀有奇怪な気の象を描いた着色図、及びその講説を記録したものを目にした人は少なくないだろう。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本にも佐藤氏の『山相秘録』のような書があって、鉱山を鑑定するのに望気の法ですることを説いたものもあり、また実験を重んじて学説を軽んじる実際家の鉱山師等は今｜尚望気の秘伝に拠って山を判断しているのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "『弓馬秘伝聞書』に祝言の供に猿皮の空穂を忌む。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともこれは私の秘伝でございますが……。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "秘伝と聞けば、なお更それを聞きたいものだて。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "せがれに譲りたい、譲るには弥七郎がおってはじゃまじゃ、なんぞ罪着せて破門するが第一と、もともとありもしない秘伝書を盗んだであろう、かすめたであろうと責めたてたのがこんなことになりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
