        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "スープの次には、ひき肉を入れて煮たジャガ薯が出ました。",
              "citation": {
                "source": "従妹への手紙",
                "author": "――「子供の家」の物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはかたい肉ではなく、煮たものをひき肉にしてあって、おまけに味もつけてあります。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ネズミの　ひき肉と　ベーコンの　パイ、　とろけるように　やわらかく　肉じる　たっぷり。",
              "citation": {
                "source": "パイとやきがたのはなし",
                "author": "THE TALE OF THE PIE AND THE PATTY-PAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "素子は、伸子の正餐のためにルケアーノフのところから鶏のスープと鶏のひき肉の料理とキセリ（果汁で味をつけた薄いジェリーのようなもの）を運ばせる許可を得た。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひき肉をつめた鯉であって、彼は自分で ｜Carpes au gras（鯉の肉料理）と称していた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "外出の暇なし、ふた葉のひき肉親子。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い魚のムニエルと、スプリングチキンのひき肉詰を食ってみる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "輝国が絵――人物や背景を描くと、その人は、軒だとか窓だとか、縁側だとか、襖とかいったものの、模様や線をひきにくる。",
              "citation": {
                "source": "大門通り界隈一束",
                "author": "続旧聞日本橋・その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大日様のおみくじは大層よくあたるといふ評判で遠方からわざわざひきにくる人さへあつた。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
