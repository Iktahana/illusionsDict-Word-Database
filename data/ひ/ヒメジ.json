        "examples": {
          "standard": [
            {
              "text": "瀬戸内海では、非売知（ヒメジ）が高級魚として珍重される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新鮮な非売知は、塩焼きにすると身がふっくらして美味しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text_content": "市場で、ピチピチ跳ねる非売知が並べられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "きんたけに、大はぎ小はぎ、ひめじ、かのこ――これは何という茸だろうね」「木の葉かずきと言うんですよ」　と私は口を出した。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時ごろひめじ釣りに行く英吉利人が二人出て行っただけでした」　少女がこのホテルに泊っているのでないらしいことは、竜太郎はうすうす知っている。",
              "citation": {
                "source": "墓地展望亭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひめじ釣りにしては時間がおそすぎるし、鮎子さんのいう通り水脈筋からもはずれている。",
              "citation": {
                "source": "キャラコさん",
                "author": "海の刷画",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
