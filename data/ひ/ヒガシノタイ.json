[
  {
    "uuid": "b13c4d06-c232-587a-a6a2-659f24970ae6",
    "entry": "東の対",
    "reading": {
      "primary": "ひがしのたい",
      "alternatives": [
        "ひんがしのたい"
      ],
      "is_heteronym": false
    },
    "grammar": {
