    "definitions": [
      {
        "index": 1,
        "gloss": "clearing out people (from a room, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "慎重に人払いをした上での此の密談が其の儘太子の耳に入った。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は車も簡素なのにして目だたせない用意がしてあって、前駆の者にも人払いの声を立てさせなかったから、源氏は自分のだれであるかに町の人も気はつくまいという気楽な心持ちで、その家を少し深くのぞこうとした。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "前駆がたてる人払いの声のぎょうさんなのに、はじめて女房たちはこの時間までも大臣がここに留まっていたことを知ったのである。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "座敷には灯がともされて、門前からは大臣の前駆の者が大仰に立てる人払いの声が聞こえてきた。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、ちとご内聞に申し上げとうござりますので、そちらのかたをお人払いを願いとうござりまするが、いかがなものでござりましょう」「だいじょうぶ、ご心配無用じゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつは、ちとその――」「なんだというんだよ」「ひとに聞かれますると人命にかかわりますることでござりますゆえ、できますことならお人払いを――」「ぜいたくいうねえ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん、伊豆守はことごとくお待ちかねでしたので、右門参着と聞くやただちにご寝所へ通して、刻下に人払いを命ずると、すわるもおそしと声をかけました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "お人払いが願いたい」「お人払い？",
              "citation": {
                "source": "特許多腕人間方式",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうの接待に疲れたといって、彼は人払いをしてひと間に引き籠っていたが、点燈ごろになって少納言信西を召された。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しょうさい、しょうさい」　と両手をすりすり賽を撒く時の呪文を早口に唱えているのに悪感を覚えながらも大臣は従って来た人たちの人払いの声を手で制して、なおも妻戸の細目に開いた隙から、障子の向こうを大臣はのぞいていた。",
              "citation": {
                "source": "源氏物語",
                "author": "常夏",
                "note": "青空文庫"
              }
            },
            {
              "text": "物哀れな気持ちになっていて明石は十三｜絃の琴を弾きながら縁に近い所へ出ていたが、人払いの声がしたので、平常着の上へ棹からおろした小袿を掛けて出迎えた。",
              "citation": {
                "source": "源氏物語",
                "author": "野分",
                "note": "青空文庫"
              }
            },
            {
              "text": "山おろしに堪へぬ木の葉の露よりもあやなく脆きわが涙かな　村の者を驚かせないために随身に人払いの声も立てさせないのである。",
              "citation": {
                "source": "源氏物語",
                "author": "橋姫",
                "note": "青空文庫"
              }
            },
            {
              "text": "前駆の人払いの声の遠くなるとともに涙は海人も釣り糸を垂れんばかりに流れるのを、われながらあさましいことであると思いつつ中の君は寝ていた。",
              "citation": {
                "source": "源氏物語",
                "author": "宿り木",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな方だって宮様にお勝ちになる美貌を持っておいでになるはずはございませんもの」　などと言うころ、客は今下車するのであるらしく、前駆の人払いの声がやかましく立てられていたが、急には薫の姿がここへ現われては来なかった。",
              "citation": {
                "source": "源氏物語",
                "author": "東屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥書院にて人払いの上、密談の最中。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "修理は突然宇左衛門をよびよせて、人払いの上、陰気な顔をしながら、こんな事を云った。",
              "citation": {
                "source": "忠義",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　人払いをした居間には、彼と宇左衛門のほかに誰もいない。",
              "citation": {
                "source": "忠義",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「仇は、両国――もっと、近う」「はっ」「ただ今、唄の稽古じゃ」　小藤次が、口三味線のまま一寸振向いて、二人を見て、すぐ「うかりうかりと――」「うかり――」　仙波が「ちと、内談を――」「ひやかせば――内談か、聞こう」「申しかねまするが、御人払いを――」「人払い？",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "調所は、それに答えないで、静かな足取りで、斉興の前へ来て「御人払いを――」　その眼の中にも、言葉の中にも、いつもの調所に無かったものが感じられた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人払いか」　と、斉興は、軽い不安を感じながら「皆、退れっ、遠慮致せ」　と、手を振った。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "道場にて、この者と、用事あるによって、人払いをいたすがよい」　内弟子は、かしこまって去った。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あッしが自分で蓋を払いますが、御隠居、人ばらいをお願い申してえんで――」「ナニ、人払い？",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小切手は持参人払いに振出したもので、ある名前が署名してありました。",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから暫時人払いをした上、その席上で内蔵助から最後の打合せがあった。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人払いだ」　醤は、目が覚めるや、大声を発した。",
              "citation": {
                "source": "大使館の始末機関",
                "author": "――金博士シリーズ・７――",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこへ行かれる」「人払いじゃ」「ああ、王老師はここに居て頂かねばなりません。",
              "citation": {
                "source": "大使館の始末機関",
                "author": "――金博士シリーズ・７――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとばらいをしたのだろう、原が去るとそこには誰もいなかった。",
              "citation": {
                "source": "桑の木物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
