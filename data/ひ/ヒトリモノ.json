[
  {
    "uuid": "d481894e-26a8-5ce1-9880-9e6c388e4f57",
    "entry": "独り者",
    "reading": {
      "primary": "ひとりもの",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
