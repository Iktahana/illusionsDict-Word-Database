        "examples": {
          "standard": [
            {
              "text": "避妊薬の使用にあたっては、副作用についても十分に知っておくべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "薬局の棚には、多種多様な避妊薬が並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は定期的に産婦人科に通い、避妊薬を処方してもらっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "狭小な耕地面積と乏しい天然資源、おまけに人口は八千万を越して、避妊薬の流行にもかかわらず、一億を越すに長い年月を要せずという盛大な繁殖率を示している。",
              "citation": {
                "source": "安吾巷談",
                "author": "野坂中尉と中西伍長",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども避妊薬を国禁しても、戦争を国禁したがらない政治家や軍人が多いから、庶民どもは助からない。",
              "citation": {
                "source": "武者ぶるい論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
