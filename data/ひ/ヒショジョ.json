        "examples": {
          "standard": [
            {
              "text": "古い価値観では、非処女であることが結婚において不利になると考えられていた時代もあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "現代社会では、個人の経験は尊重されるべきであり、非処女であること自体にネガティブな意味はない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「彼女、非処女らしいよ。」「そんなこと、本人にしか分からないし、どうでもよくない？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "処女と非処女の肢体は服装に包まれたまゝ、ほゞ見分けがつくものであるが、信子は処女のやうでもあり、さうでないやうでもあつた。",
              "citation": {
                "source": "恋をしに行く（「女体」につゞく）",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は実際はあやか夫人の非処女性に圧倒され徹底的に降伏状態にあるんで、ちッとはムホン気も出したいからな。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
