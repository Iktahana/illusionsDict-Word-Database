        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祖父は火叩きを使って、キセルの灰を静かに落としていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "骨董市で、珍しい模様が彫られた火叩きを見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "茶室の道具の中に、使い込まれた風情のある火叩きが置かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "亀井さんの門の前には、火叩きやら、なんだか奇怪な熊手のようなものやら、すっかりととのえて用意されてある。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "街路樹は薪に切られ、家々の軒先きには、トビ口や、火叩きや、砂袋がかならず置いてあつたものだ。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "火叩き、鳶口、スコップ、鍬、いざといえば焼夷弾ぐらいはとばかり揃っている。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
