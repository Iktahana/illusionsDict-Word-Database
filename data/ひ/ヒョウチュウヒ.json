          "literary": [
            {
              "text": "……　両国橋の袂にある表忠碑も昔に変らなかつた。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "表忠碑を書いたのは日露役の陸軍総司令官｜大山巖侯爵である。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は大きい表忠碑を眺め、今更のやうに二十年｜前の日本を考へずにはゐられなかつた。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に又ちよつと表忠碑にも時代錯誤に近いものを感じない訣には行かなかつた。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この表忠碑の後には確か両国劇場といふ芝居小屋の出来る筈になつてゐた。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　両国橋の袂にある表忠碑も昔に変らなかった。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "表忠碑を書いたのは日露役の陸軍総司令官大山巌公爵である。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は大きい表忠碑を眺め、今更のように二十年前の日本を考えずにはいられなかった。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に又ちょっと表忠碑にも時代錯誤に近いものを感じない訳には行かなかった。",
              "citation": {
