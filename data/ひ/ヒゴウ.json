[
  {
    "uuid": "b7244a8b-d742-595d-b51f-5a41319505d8",
    "entry": "非業",
    "reading": {
      "primary": "ひごう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "形容動詞"
      ],
      "ctype": null,
