          "standard": [
            {
              "text": "「開けゴマ！」と叫ぶと、岩戸がスッと開いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "隠された宝箱を見つけ、「開けゴマ！」と唱えてみたが、何も起こらなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "どんな難問でも、適切なキーワードを見つければ「開けゴマ」のように解決できることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "むかし、岩の前に立って、“開けゴマ”とさけぶと、岩が二つにわれて、その間から入口があらわれるという話があるが、今はそれと同じことをやって、スイッチを切りかえられるのだった。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
