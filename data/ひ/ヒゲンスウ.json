        "examples": {
          "standard": [
            {
              "text": "引き算において、引かれる方の数を被減数と呼びます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "テストで「被減数と減数を入れ替えて計算しなさい」という問題が出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "算数の授業で、被減数が減数より小さい場合の計算方法を習った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "次は百位だが、被減数の５は、先に１を右へ貸したから４となっている。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "万の位では、被減数の８は下へ１を貸したので、実は７である。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            }
          ]
        }
