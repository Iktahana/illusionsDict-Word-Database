    "definitions": [
      {
        "index": 1,
        "gloss": "Emperor (of Japan)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "剣大刀　利毛、鈍母、術二依許曾三種神宝――内、一首夜のまもり　ひるの守りと、日の御子のかしこみませる　草なぎの剣（山田秋甫氏編、橘曙覧全集拾遺）剣に関する歌を、かうして並べると、何の底意もないやうに見える。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の前夜になつて、新しい日の御子誕生して、禊ぎをして後、宮廷に入る。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "即位式が、先帝崩御と共に行はれる様になり、大・新嘗祭りは、仲冬の刈り上げ直後の行事と変り、日の御子甦生の産湯なる禊ぎは道教化して、意義を転じ、元旦の拝賀は詔旨よりも、賀を受ける方を主とせられる様になつて行つた。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の天子が日の神・御祖・ひるめの頃から、いつも血族的にはにゝぎの命と同格のすめみまであり、信仰的には忍穂耳命同様日の御子であつた。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "天子のみ代替りを以て、日の御子の断えざる復活の現象と考へ、其を促す力を水にあるものと見たのである。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "「品陀の日の御子　大雀おほさゞき、佩かせる大刀。",
              "citation": {
                "source": "熟語構成法から観察した語根論の断簡",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、正確に信仰上の事実として云へば、春｜天降られた日の御子が、初春のみことをみこともつて、扨、秋に至つて、みこともつた事の結果の覆奏をなされる。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の御子が代り替りに此土に下られるのも、実は、食国政を行はれる為に過ぎないのであつた。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚、日の御子の御職分としては、色々の聖なる行事のあつたことは考へられるが、其すべてをこめて、食国政と云ふ立場から解決してゐたのは、事実だ。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうした錯誤の第一義的なのは、日の御子のみこともたれた詞章に依つて、天上・地上一つと信仰した所から起る。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "此臣は、天子を補佐すると共に、若い日の御子の育ての親となる資格を持つてゐる。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "天子には「日の御子」なる信仰上の別称があつた。",
              "citation": {
                "source": "小栗外伝（餓鬼阿弥蘇生譚の二）",
                "author": "魂と姿との関係",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の御子として、生れ変る期間の名が、天つ日高・虚つ日高の対句で表されて居たらしく、所謂｜真床覆衾（神代紀）を被つて、外気に触れない物忌みを経て、血統以外の継承条件をも獲られたものであらう。",
              "citation": {
                "source": "小栗外伝（餓鬼阿弥蘇生譚の二）",
                "author": "魂と姿との関係",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一代の日の御子降臨の時に、祖母神の寄与せられた物は、鏡と稲穂（紀）とで、古事記では其外に二神器及び、智恵の魂・力の魂・門神の魂をば添へられてゐる。",
              "citation": {
                "source": "小栗外伝（餓鬼阿弥蘇生譚の二）",
                "author": "魂と姿との関係",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は、御代毎に新しく御母神から日の御子が受けるもの、と解した外来魂の象徴と見るのが、古義に叶ふらしい。",
              "citation": {
                "source": "小栗外伝（餓鬼阿弥蘇生譚の二）",
                "author": "魂と姿との関係",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はやはり、鏡の象徴する魂・穀物の象徴する魂が、外来魂として代々の日の御子に寄り来るものと見てゐる。",
              "citation": {
                "source": "小栗外伝（餓鬼阿弥蘇生譚の二）",
                "author": "魂と姿との関係",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時期は、日本に於ては、日つぎのみこの中のお一方が、日の御子（天子様）となる為の資格を完成する時、と見る事が出来る。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、奈良の宮におざります　日の御子さま。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、奈良の宮におざります日の御子さま。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈良の宮に御座ります　日の御子さま、其前は藤原の宮の　日のみ子さま、其又前は飛鳥の宮の　日のみ子さま、大和の国中に宮遷し宮｜奠め遊した代々の　日のみ子さま、長く久しいみ代々々に仕へた中臣の家の神わざ、お姫様、お聞き及びかえ。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "申すもかしこけれど、お婿様は百｜代に一人と言われる、すぐれた御器量の日の御子、又お妃は、しとやかなお姿の中に凛々しい御気性をつつまれた絶世の佳人、このお二人が一と目見てお互にお気に召さぬようなことがあったら、それこそ不思議でございます。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『日本一の日の御子から又なきものに愛しまれる……。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その国はもっと力強い日の御子に侵略された、と語った。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "（歌謠番號二八）　ここに美夜受比賣、御歌に答へて歌よみして曰ひしく、高光る　日の御子やすみしし　吾が大君二六、あら玉の二七　年が來經れば、あら玉の　月は來經往く。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔國主歌〕　また、吉野の國主一ども、大雀の命の佩かせる御刀を見て、歌ひて曰ひしく、品陀の　日の御子二、大雀　大雀。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "（歌謠番號七二）　ここに建内の宿禰、歌もちて語りて白さく、高光る　日の御子、諾しこそ六　問ひたまへ。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに大后一八の歌よみしたまへる、その御歌、倭の　この高市一九に小高る　市の高處二〇、新嘗屋に　生ひ立てる葉廣　ゆつま椿、そが葉の　廣りいまし、その花の　照りいます高光る　日の御子に、豐御酒　獻らせ二一。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　また、吉野のクズどもがオホサザキの命の佩びておいでになるお刀を見て歌いました歌は、天子樣の日の御子であるオホサザキ樣、オホサザキ樣のお佩きになつている大刀は、本は鋭く、切先は魂あり、冬木のすがれの下の木のようにさやさやと鳴り渡る。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田博士は其舊作『日韓古史斷』第三編に於いて、卑彌呼は「日子」「ひのみこ」の義、姫子にあらずと云ひて、亦本居氏の説に贊成を表せざりき。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すさのをのみことが、青山を枯山なす迄慕ひ歎き、いなひのみことが、波の穂を踏んで渡られた「妣が国」は、われ／＼の祖たちの恋慕した魂のふる郷であつたのであらう。",
              "citation": {
                "source": "妣が国へ・常世へ",
                "author": "異郷意識の起伏",
                "note": "青空文庫"
              }
            }
          ]
        }
