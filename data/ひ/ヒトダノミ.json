        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――知合の墓地近くの花屋から、とに角、監督だけにと云って、ほか仕事で忙しい石屋の親方を一人頼みました。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "『いや、可い処に気が着いた、……何にせい、此の上は各々我を張らずに人頼みぢや。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり人頼みじゃあいけねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "河豚太鼓",
                "note": "青空文庫"
              }
            },
            {
              "text": "けど、そんな人頼みをするより、いっそ誰にでも出来る氷屋でも出せアいいに。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろあんな大きいボタモチのような字は自分ですかしすかし書けるけれど、縫物の方はそれも出来ず人頼みの哀れさです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジル・ド・レェヌは律気な男だったので、ひとだのみをせずに、一人ずつ自分の手で絞り殺したのである。",
              "citation": {
                "source": "青髯二百八十三人の妻",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
