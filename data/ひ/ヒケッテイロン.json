        "examples": {
          "standard": [
            {
              "text": "量子力学における非決定論は、多くの哲学者を悩ませてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の思想は、未来は予測不可能であるという非決定論に基づいている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "非決定論的なアプローチは、AIの研究において新たな可能性を開いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "決定論と非決定論との囂しい論争は、よき生活を実際に生きた人の体験においてはなんら疑うべき余地もないほど明瞭にまた容易に解決されておるのである。",
              "citation": {
                "source": "語られざる哲学",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "リップスもいうように、非決定論の自由は意欲が因果律に従うことをこばむものである。",
              "citation": {
                "source": "学生と教養",
                "author": "――教養と倫理学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "詮ずるところ、われわれは決定論によっても、非決定論によっても、自由の満足なる説明を今のところ見出し得ない。",
              "citation": {
                "source": "学生と教養",
                "author": "――教養と倫理学――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
