    "definitions": [
      {
        "index": 1,
        "gloss": "with an extreme cold (i.e. temperature)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "華々しいもの、潔いもの、勇壮なるもの、さう云つたものから、子供の家へ帰ると、ひつそりと沈んだ冷え冷えとしたものが、両親の体臭のやうに、家中を靄のやうに立ちこめてゐた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関からまっすぐに長い廊下が通じていて、廊下の板は、お寺の床板みたいに黒く冷え冷えと光って、その廊下の尽きるところ、トンネルの向う側のように青いスポット・ライトを受けて、ぱっと庭園のその大滝が望見される。",
              "citation": {
                "source": "デカダン抗議",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "焦慮と反側とに心を噛ましているのが、却ってしまいには冷え冷えとした楽しみになった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山が高まって来て、明るく晴れたままで、うす霧が千歳の肩や頬に触れて冷え冷えとする。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、十三湖が冷え冷えと白く目前に展開する。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四辺の空気が、冷え冷えとして来て墓地に近づいた。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして煙草を吸うと、冷え冷えとした空気が煙といっしょに、口のなかにはいって行った。",
              "citation": {
                "source": "秋の暈",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の冷え冷えした空気がしみじみと肌に触れた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（貴様なんかに殺されてたまるか、這入つてみろ俺が殺してやる、）　それは朝から雨の降つてゐる冷え冷えとして気持の好い日であつた。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「冷え冷えして来ました。",
              "citation": {
                "source": "草藪の中",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして爽かな夜気が冷え冷えと、濁って沈澱した昼の空気を澄まして行った。",
              "citation": {
                "source": "指",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、「東京駅の屋根のなくなった歩廊に立っていると、風はなかったが、冷え冷えとし、着て来た一重｜外套で丁度よかった。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷え冷えとし、だからふるえているのかと思うと、着て来た一重外套で丁度よかった、これはどういうことだろう。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "米国に近づくにつれて緯度はだんだん下がって行ったので、寒気も薄らいでいたけれども、なんといっても秋立った空気は朝ごとに冷え冷えと引きしまっていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして夜着にかけた洗い立てのキャリコの裏の冷え冷えするのをふくよかな頤に感じながら心の中で独語ちた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしむしする昼間の暑さは急に冷え冷えとなって、にわかに暗くなった部屋の中に、雨から逃げ延びて来たらしい蚊がぶーんと長く引いた声を立てて飛び回った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりのものかげから冷え冷えと流れて来る山気をかき乱すともないつつましやかさを背に感じながら、落葉の径をそことしもなく辿っていると、ふとだしぬけに生きた山の匂をまざまざと鼻さきに嗅ぎつけることがよくある。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は水仙の冷え冷えとした高い芬香に、行ひ澄ました若い尼僧の清らかな生涯を感じる。",
              "citation": {
                "source": "水仙の幻想",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しばかり冷え冷えとする寒さは、部屋の中の薄闇に解けあつて、そろ／＼と彼女を現な心持ちに導いて行く。",
              "citation": {
                "source": "悔",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち汽車に附着いて来た新らしい野菜の匂が新聞やサンドウヰツチの呼声に交つてプラツトホームの冷え冷えした空気に満ちわたつてゐる。",
              "citation": {
                "source": "新橋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "中年の猫背の紳士が時雨に濡れて枯芝のなかを散歩してゐる――冷え冷えする絵だ。",
              "citation": {
                "source": "温度",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくその音楽室が冷え冷えしてゐたためでもあらうか。",
              "citation": {
                "source": "温度",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月の夜は、冷え冷えと水気を含んで、冷たかった。",
              "citation": {
                "source": "二人の盲人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "時国と私とは、橋の上に立って、冷え冷えする夜風で涼をとっていた。",
              "citation": {
                "source": "夏の夜の冒険",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼間の暑さと雑踏とにひきかえて夜の動物園は静かで、さわやかな風が冷え冷えと肌に感じられる。",
              "citation": {
                "source": "動物園の一夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰度朝の事で、冷え冷えとした陸橋の上にも、露に濡れた線路の上にも、もう附近の弥次馬達が、夥しい黒山を作っていました。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮寝鳥　冷え冷えとしたなかに横はつて、まだはつきりと目のさめきらないこのかなしさ。",
              "citation": {
                "source": "ある時刻",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼は冷え冷えする孤絶感の底で、いつもかすかに夢をみていた。",
              "citation": {
                "source": "遥かな旅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔の中は冷え冷えとしていた。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソロソロと横に匍ってゆくと、掌は鉄管のために冷え冷えと熱をとられ、そして靴が管壁に当ってたてる音がワンワンと反響して、まるで鬼が咆哮している洞穴に入りこんだような気がした。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
