    "definitions": [
      {
        "index": 1,
        "gloss": "farmer's home",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこには屋根の低い、木造の百姓家が不規則に建ち並んでいた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ眼のさきの傾斜の上にある小高い百姓家の窓から、ロシア人が、こっちをねらって射撃していた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾草を積重ねてあるところと、それから、百姓家と、二カ所から紫色の煙が上って、そこらへんに蠢めき騒いでいる兵たいや、百姓や、女や子供達を包んでしまった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の入口には二軒の百姓家が向い合って立っている。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし向かいの百姓家はそれにひきかえなんとなしに陰気臭い。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの百姓家の二男は東京へ出て新聞配達になった。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっしりした百姓家を彼は愛した。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚く雪を被った百姓家の茅屋根からは蒸気が濛々とあがっていた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど近所の百姓家が昼寝の時だったので、自分がその時起きてゆかなければどんなに危険だったかとも言った。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "農揚げといって、この秋のとり入れと、お米ごしらえがすっかり終わったお祝いに、どこの百姓家でもそうするのです。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "恭一君の家は、小さい百姓家でしたが、まわりに、松や、つばきや、かきや、とちなど、いろんな木がいっぱいありました。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそのみちは向ふの林のかげの一軒の百姓家へ入るらしいのでした。",
              "citation": {
                "source": "車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家は普通の百姓家を、モウ一つ凝って更に百姓家らしく造作したもの。",
              "citation": {
                "source": "お茶の湯満腹談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸数五百に足らぬ一筋町の東の外れに石橋あり、それを渡れば商家でもなく百姓家でもない藁葺き屋根の左右｜両側に建ち並ぶこと一丁ばかり、そこに八幡宮ありて、その鳥居の前からが片側町、三角餅の茶店はこの外れにあるなり。",
              "citation": {
                "source": "置土産",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　時田はほとんど一口も入れないで黙って聴いていたが、江藤がやっとやめたので、『その百姓家に娘はいなかったか、』と真顔で問うた。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "行きつまる所には支流に小さな柴橋が渡してあつて、その側に小ざつぱりした百姓家が立つてゐた。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の下の百姓家からはいくすぢとなく煙があがつてゐる。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に、廂に唐辛子、軒に橙の皮を干した、……百姓家の片商売。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして急いで松林を出ると、とっつきの百姓家の納屋に忍び込んで、有り合せた井戸綱を一束抱えてとって返した。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はそれから、綱をもとの百姓家へこっそりと返して置いて、すぐに汽車に乗って家へ帰った。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方ごろ、とあるみすぼらしい、小さな百姓家にたどりつきました。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "その出外れの裏表｜二間をあけ放した百姓家の土間に、一人の眼のわるい乞食爺が突立って、見る人も無く、聞く人も無いのにアヤツリ人形を踊らせている。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで鳥右ヱ門は、百姓家で剃刀をかりてひげをそりました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして手伝ひといつても鳥右さんは、唐臼をまはすとか、田を耕すとか、俵をかつぐとか、いちばん力のいる仕事をしてくれたので、百姓家ではたいへんたすかりました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、近くの百姓家にいつてかういひました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏谷にいきつくと、はたしてそこの一軒の百姓家では、おいしい酒を樽から一升枡についで来て、御馳走してくれました。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "恭一君の家は小さい百姓家でしたが、まはりに、松や椿や柿や橡などいろんな木がいつぱいありました。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "農揚げといつて、この秋のとり入れとお米ごしらへがすつかり終つたお祝ひに、どこの百姓家でもさうするのです。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "がちょうの　たんじょうび新美南吉　ある　おひゃくしょうやの　うらにわに　あひるや、がちょうや、もるもっとや、うさぎや、いたちなどが　すんで　おりました。",
              "citation": {
                "source": "がちょうの　たんじょうび",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "士族はもちろん、ひゃくしょうや町人の子どもでも、すこしばかり文字がわかるやつは、みんな役人になりたがっている。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
