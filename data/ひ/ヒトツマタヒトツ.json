        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――銃声は、一つまた一つ、またまた一つと、つづけてパチパチ鳴りひびいた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見渡せば、ざあと一つまた一つ押し寄せて来る小浪が、皆火のように燦めいている。",
              "citation": {
                "source": "夜光虫",
                "author": "NOCTILUCAE",
                "note": "青空文庫"
              }
            },
            {
              "text": "見渡せば、ざあと一つまた一つ押し寄せ來る小浪の、皆火のやふに燦めきぬ。",
              "citation": {
                "source": "夜光蟲",
                "author": "NOCTILUCAE",
                "note": "青空文庫"
              }
            },
            {
              "text": "類まれな握力でつかみ取った種子に、揺りかごの中で子守歌のように聞き覚えた老人たちの知恵の言葉を吹きかけると、一つまた一つと芽がのぞきはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前方には、防堤が黒いリボンのように見えて、その上に、星が一つまた一つとあらわれてくる。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "機の前面には、今にもぶつかりそうな峰々が、一つまた一つ、ヤヨイ号をおどかすようにあらわれる。",
              "citation": {
                "source": "氷河期の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐ろしい巨きな波のうねりは規則正しく西の方から寄せて來て、一つまた一つ、休みなく、小止みなく、その無益な努力を新たにして、同じ岩の上に打つかり、同じ場處で泡沫となつて碎け、そして同じ水際を洗つてゐた。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸の總ての突端は、遠くの方までも、一つまた一つととめて見ることが出來た。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は王※を見ると、一つまた一つ、二つ三つと口の中に抛り込んでピチピチパチパチと噛み潰した。",
              "citation": {
                "source": "阿Ｑ正伝",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "――と思うまに、伊織の前へ、朱にまみれた死骸が、一つまた一つ――と続けさまに蹴落されて来て、彼の顔へ、しぶきを浴びせかけた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつまたひとつ数字が減っていったが、まだ来る気配すらない。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「仕事が終わったらここへ来てね、ウイスキーの炭酸割りを飲んで、油で揚げたグリーン・ピーズを摘んでるとね、ひとつまたひとつと、いつのまにか歳を取るんだ。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまはここにいない美代子という女性について、日比谷や恵子が取材を続けていくと、美代子の過去の断片が、ひとつまたひとつと、読者に提供される。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
