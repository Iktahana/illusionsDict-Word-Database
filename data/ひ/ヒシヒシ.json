    "definitions": [
      {
        "index": 1,
        "gloss": "acutely (feel)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
