[
  {
    "uuid": "7a295711-d738-5238-80d2-c368fe230874",
    "entry": "秘儀",
    "reading": {
      "primary": "ひぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "secret ceremony",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "古伝にこの神インドを征服したというから虎を愛するはずだ、インドへ出立前に秘儀を女神キベレーより授かる、キベレーは獅を使い物とす、生まれて棄てられ豹に哺まれて育ったという。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに明なる矛盾があると共に、またここに霊界の秘儀がある。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは芸術および秘儀として別格として認められることを強く要求しているようである。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "調査による警戒を避けて税務官吏の詮索に打ち勝ち、これらの秘儀を秘密にするために、この過程は全く個々の技術者のあいだで巧みに分業および再分業され、生産はわざわざ違う事業所で行われる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "秘儀やタブー・秘伝・階級的科学（例えばバラモン教）・倚らしむべし知らしむべからずの政治方針・等々。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くその先には丘々があり、菫色の秘儀が赤や金や紫や不思議な緑に輝く黙示録的な夕陽を背景にしていた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "メモ帳の文字を読んだとウィレットから聞くと、当惑の色が顔に広がり、そのメモは古いもので、魔術の歴史に深く秘儀参入していないものには何らの重要性もないものだと、穏当な説明を行った。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "錬金術の秘儀が明かされたと理解できないのか。",
              "citation": {
                "source": "錬金術師",
                "author": "THE ALCHEMIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "バビロニアの宗教において睡眠の秘儀および夢の解釈は重要であった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "時がたち、白人とはほとんどつきあわず、ヒンズー行者とか、尊者とかの類と仲間になり、奴らの秘儀を学びました。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、ケエに人ば迎ひぎや行つた。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は心の弱き者の爲めに力を願ひ、檻からさまよひ出た者に導きを、また現世と肉の誘惑が狹い路から誘つてゐる者の爲めに、しまひぎはにさへ歸つて來ることを願つた。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな日にはどうかして言葉をかける者があつても不仕合せな一徳の気のよささうな笑ひ顔もせず　ひぎやあ　と鸚鵡みたいな声を出して相手を追ひはらふのが常であつた。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、やがてのことに奥の手をだして　ひぎやあ　と見事な一喝をくはした。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
