        "examples": {
          "standard": [
            {
              "text": "皮膚科学の進歩は、多くの皮膚病治療に貢献している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は皮膚科学の研究者として、新しい治療法の開発に取り組んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "美容皮膚科学は、肌の美しさを追求する分野だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ようやく1842年になってウィーンの有名な皮膚科学者ヘブラはこのことを試みることができた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "シュコダの弟子の１人ヘブラは病理解剖学的皮膚科学の創立者であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "慢性の湿疹で殆ど気が狂うほどになった非常に高名な皮膚科学者を思い出す。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
