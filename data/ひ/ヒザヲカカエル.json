        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "冷たい夜風に吹かれながら、彼女は体育座りで膝を抱えて夜空を見上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "部屋の隅で膝を抱えて座り込んでいる姿は、ひどく寂しそうに見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子供の頃、よくこうして膝を抱えて波の音を聞いていたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "振り返った目には、燃ゆる火の向こうで膝を抱える老人と少女、裏には動かずじっとしている三匹の獣。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "スリッパを穿いたまま椅子の上に乗って、両膝を抱えるとクルリと南側を向いて、頭の中を整理するように眼を半開にして窓の光りを透かしながら、ホッカリと青い煙を吐いた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "膝を抱えると杢之進、日向思案に落ちこんで、山目付とは、何たる御苦労なしな役目だろうと、今さららしく、退屈の不平を数えた。",
              "citation": {
                "source": "増長天王",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さ、寛ごう」　食後の茶になると、四高弟は、円座を思い思いの居心地へ移して、膝を抱えるのもある。",
              "citation": {
                "source": "宮本武蔵",
                "author": "水の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
