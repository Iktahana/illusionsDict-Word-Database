[
  {
    "uuid": "5609ccc0-3c46-57d9-94ed-f6e8b8e6488e",
    "entry": "冷や冷や",
    "reading": {
      "primary": "ひやひや",
      "alternatives": [
        "ヒヤヒヤ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変",
        "動詞-自動詞",
        "副詞",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to feel chilly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "心細く感じながらも、ひとりでそっと床から脱け出しまして、てらてら黒光りのする欅普請の長い廊下をこわごわお厠のほうへ、足の裏だけは、いやに冷や冷やして居りましたけれど、なにさま眠くって、まるで深い霧のなかをゆらりゆらり泳いでいるような気持ち、そのときです。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早朝、練兵場の草原を踏みわけて行くと、草の香も新鮮で、朝露が足をぬらして冷や冷やして、心が豁然とひらけ、ひとりで笑い出したくなるくらいである、という家内の話であった。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでなくても、子供が障子を破り、カーテンを引きちぎり、壁に落書などして、私はいつも冷や冷やしているのだ。",
              "citation": {
                "source": "親友交歓",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」かえって私のほうが、腫物にでも触るような、冷や冷やした気持で聞いてみた。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは海の中にある極楽の様に冷や冷やとした画であるが、見ていると記憶が乱れ切って了う様に、四ツの焦点が注意を掻きむしる。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "足の裏の冷や冷やする心持は、なまゆるい湯婆へ冷たい足の裏をおっつけて寒がっていた時とは大違いだ。",
              "citation": {
                "source": "初夢",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ灯も点さない家のなかは、空気が冷や冷やして薄暗かった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "板戸をしめた薄暗い寝室は、どうかすると蒸し暑いくらいで、笹村は綿の厚い蒲団から、時々冷や冷やした畳へ熱る体をすべりだした。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜も冷や冷やする寝床のなかで、やっとうとうとしかけた眼がふと覚めると、痛いほど疲れた頭が興奮して来た。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "木蓮や石榴の葉がじきに繁って、蒼い外の影が明るすぎた部屋の壁にも冷や冷やと差して来た。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "白地の多いだけに秋も初めとは云いながら、冷や冷やと見すぼらしく。",
              "citation": {
                "source": "死剣と生縄",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も石谷先生は、たいそう褒めてくれましたが、――」　私は正直な煙客翁が、有体な返事をしはしないかと、内心｜冷や冷やしていました。",
              "citation": {
                "source": "秋山図",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "世子と共に私も下りて見たが、上下周囲凡て石造で暗黒な上に身も冷や冷やする。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も今日とて裏庭へ出て、目指す的と捲藁を狙ッて矢数幾十本かを試したので、少し疲れを覚えて来たゆえ、しばし一息を入れていると冷や冷やとして心地よい朝風が汗ばんで来た貌や、体や、力の張ッて来た右の腕へひやりひやりと当るのが実に心持のよいことであッた。",
              "citation": {
                "source": "初恋",
                "author": "矢崎嵯峨の舎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の夜更けの、外は露気を含んで冷や冷やと好い肌触りだけれど部屋の中は締め込んでいるのでむうっと寝臭い蚊帳の臭いに混ってお前臭いにおいが、夜道に歩き疲れた私の肉体を浸すようにそこらに籠もっていた。",
              "citation": {
                "source": "うつり香",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩餐のあいだに、日はとっぷり暮れて、静かな山の空気が冷や冷やと膚にせまる。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩の石の上に腰を下ろすと、雨にぬれた外套が冷や冷やして薄ら寒い、山入り前だし、風邪でもひくと大変だから、先きに別れて宿に帰ると、近藤君から電報が届いていた、倫敦からかけたんで、明日の昼に着くとしてある。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、あとは予定通り、オーベルラントの四千米突を、片っぱしから平らげて、それから、ウァリスの山へ這入ろうと云うことに評議一決した頃には、往来の人通りもちらほらになって、山に近い町は、プラタヌスの上葉を甜める夜の風が、明け放した玻璃扉から冷や冷や吹き込んで、酔いざめの身体は、ぶるぶるするくらいであった。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来が妙にしーんとして気になるから、窓をあけると、街灯の二列に行儀よく並んだ大通りは、人っ気もなく寝静まって、空はまっ暗に曇って、南の風が冷や冷やする、もう十二時を過ぎていた。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストーヴはいつの間にか消えてしまって、気息が冷や冷や感ぜられる、備付けの毛布が充分あるから、気温の冷えてゆくのを、厚い毛織りに遮ぎって、スウェターをぬいだままの旅姿で、海老のように丸まって寝た、さんざん寝返えりうって、とろとろと寝ついたのは、無論真夜中過ぎであったろう。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いはば静かさの内蔵する均斉の意志の重さを苦痛に感じ、その裏にある不均斉の危なさにいくらか冷や冷やするのです。",
              "citation": {
                "source": "女占師の前にて",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前が、そんな顔をして、恐ろしい秘密をもつてゐようとは思はないが、それでも、何か、おれが知らずにゐるやうなことを口走りやしないかと、いつでも冷や冷やしてるんだ。",
              "citation": {
                "source": "傀儡の夢（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩を越して、その裏に脈々として続く道を見るまでは、随分冷や冷やすることもある。",
              "citation": {
                "source": "由布院行",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いらぬ事だと冷や冷やしているうちに、一カ所路の悪い所へ出た。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでなくてせえ、危なっかしくて、冷や冷やしているんだ」「まア」　とお静。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "血潮と糠",
                "note": "青空文庫"
              }
            },
            {
              "text": "シイツの冷や冷やすること！",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には、指の先まで冷や冷やになり、気でも遠くなるのではあるまいかと思うことさえある、と云う。",
              "citation": {
                "source": "加護",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し実のところ、ほんとにヤッちゃったのかと思って、話の途中じゃちょッと冷や冷やしたね」「そんな風に言ってくれると、僕も救われるがね。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "と内心ひやひやしていた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みな寝しずまったころ、三十歳くらいのヘロインは、ランタアンさげて腐りかけた廊下の板をぱたぱた歩きまわるのであるが、私は、いまに、また、どこか思わざる重い扉が、ばたあん、と一つ、とてつもない大きい音をたてて閉じるのではなかろうかと、ひやひやしながら、読んでいった。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
