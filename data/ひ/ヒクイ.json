    "definitions": [
      {
        "index": 1,
        "gloss": "low (rank, degree, value, content, quality, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
