    "definitions": [
      {
        "index": 1,
        "gloss": "one hundred years ago",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
