        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ようがす、じゃ、ひとっ走り今から呼びに行ってきますからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘のお糸に用があるから、ひとっ走りいって、ちょっくら借りてこい！",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと、おふくろに何か家へ帰りたくねえようないわくがあるにちげえねえから、ひとっ走り行ってかぎ出してこい」「なるほどね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとっ走り行ってくるから、お待ちなせえよ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝六、おめえひとっ走りいって、あのしょぼしょぼおやじの顔のしわをのばしてきてやんな！",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうひとっ走り――、参りました！",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、すぐにひとっ走り出かけましょうが、方角はどっちですかい」「まあ、そうせくなよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "神さまにしたって、だんなほど目はきかねえや、あそこの係りの非人どもは、日本橋のさらし場にいるはずだから、じゃ、ひとっ走り行ってきますからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとっ走り行って引きぬいてこい！",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ご不審はあとでわかりますから、ひとっ走りお宅へ帰って、早いところおしたくしてくださいましよ」　くし巻きお由、今こそ堅気のあだ者お由でしたが、一年まえまでは生き馬の目を抜いたはやぶさお由です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "何宗であるにせよ、仏にかしずいている身で、生臭なんぞ用いるやつにろくなものはねえや、ひとっ走りいってしょっぴいてこい！",
              "citation": {
                "source": "右門捕物帖",
                "author": "耳のない浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そこの片町を本通りへ出ると、越前さまのお屋敷があるからな、ちょっとひとっ走り行って、こういってきな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "村正騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "今からすぐお奉行所までひとっ走り行ってこい！",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとっ走り、伝六、寺社奉行さまのところへ行ってきな」「フェ……？",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいらもう尾っぽを巻いて小さくなっているから、ひとっ走りにやってくんな」　走らせて景気よく永住町のその大園寺へ乗りつけると、ものごし態度の鷹揚さ、あいさつ口上のあざやかさ、まことにみずぎわだった男ぶりです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご苦労だが、きさまひとっ走り柳原までいって、もっと詳しいことをあげてきてくれ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "真物が姿を見せたら、うわさを聞いて女どももひとりでににょきにょきと姿を見せるにちげえねえから、ひとっ走りいって洗ってきな」「え……？",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ、だんな、このとおりにわか天気じゃござんすが、きのうまでの梅雨で往来はまだぬかるみだから、ひとっ走りまたつじ駕籠でも仕立てますかね」　けれども、右門の行動のうちに、伝六のそのひとりよがりを、しだいしだいにぬか喜びとさせるがごとき節が見えだしましたものでしたから、少々不思議でありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、ひとっ走り行ってきますからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、お城へひとっ走り行ってこいといってるんだよ」「まあま、待ってください。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとっ走り様子見にいってきなよ」　促して、伝六を走らせようとしているところへ、雪の表の道をこちらに、トウトウ、トウトウとひづめの響きも高く駆け迫ってきたのは、まさしく早馬の音でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "用があるならひとっ走りいってめえりますが、にんにく灸の百両ほども買ってくるんですかい」「能書きを聞いてくるんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かあな（事件）が降ってわいて、その大役仰せつけられたにちげえねえから、とち狂っていずと、ひとっ走りお番所へいってきな」　まことに、名人の目のつけどころ、その眼のさえはこわいくらいです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりかふたりか、おおぜいの目を借りたら正体もわかるにちげえねえから、ひとっ走りいって洗ってきな」「よしきた。",
              "citation": {
                "source": "右門捕物帖",
                "author": "やまがら美人影絵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あば敬の親方、へまをやって、女も野郎もいっしょに取り逃がしたかもしれねえから、むだ鳴りするひまがあったら、ひとっ走り川を渡って様子を見にでもいってきなよ」「ちぇッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひとっ走り、行きましょうかい。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "のう、江戸のあにい、伝六親方、おめえだいぶべっぴんにご執心のようだったから、ひとっ走り駒形河岸へいって、気に入るように締めあげてきなよ」「え……？",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、これあげるから、ふたりでどっかいって、コソコソ食べればいいでしょ」「おまえ、この雨のなかを出ていけっていうのか」「ひとっ走りすれば、すぐ校舎でしょうが。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これから、また、ひとっ走りして、運び出しに立会わなけあ」　窓硝子ごしに覗いて見て、「よく、降りやがる」　そして、濡れたレインコートをまたひっかけた。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひとっ走り家へ行つて、橇を取つて来て、橇に積んで運びませうよ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
