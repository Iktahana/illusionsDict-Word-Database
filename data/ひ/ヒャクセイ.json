[
  {
    "uuid": "faabe746-9263-5fbe-a6d1-7b146298785a",
    "entry": "百世",
    "reading": {
      "primary": "ひゃくせい",
      "alternatives": [
        "ひゃくだい",
        "はくたい",
        "ももよ"
      ],
      "is_heteronym": true
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "long era",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蓋し乱国を刑するの典にして、百世通行の道にあらざる也。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "言ふ勿れ、豊公の武威、幾百世を蓋ふと。",
              "citation": {
                "source": "富嶽の詩神を思ふ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁百世の後、翁の像を仰いで襟を正す人在りや無しや。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう云う名前は、映画や大衆小説の俄作りの英雄豪傑とは又別に、百世に伝えたいものである。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、尊氏｜丈が、どうして百世の下、なお憎まれ者になっているか。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼朝が、その武家政治に依つて、天下を統一し、国民生活を安定せしめた功績は、武家嫌ひの北畠親房さへ、之を認めてゐるくらゐだが、朝廷に対する尊崇の念を多少とも有してゐた彼が、日本の国体とは相容れざる武家政治を開始したことは、百世の下、やはりその責任は問はれなければならぬと思はれるのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その因縁で五百世中常に乞食となるがその改過と誓願に由って今我に遭うて羅漢となった。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その遺風は、死後間もなく第二の宗吾を出だし、百世の下なほ懦夫をして起たしむるに足る。",
              "citation": {
                "source": "宗吾靈堂",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに口碑に残る「石の俎」の言い伝えは、百世の後なお人に面を背けさせるものである。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史は意味なきペーヂの堆積にあらず、幾百世の国民は其が上に心血を印して去れり、骨は朽つべし、肉は爛るべし、然れども人間の心血が捺印したる跡は、之を抹すべからず。",
              "citation": {
                "source": "国民と思想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "この会戦は三万五千をもって墺軍の六万五千に徹底的打撃を与えた、大王の会戦中の最高作品であり、大王のほとんど全会戦を批難したナポレオンさえ百世の模範なりとして極力賞讃したのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京、大阪が最も密度濃いのは当然として、百世帯加入数辛うじて六以下という、ブランクによって示されている地方は、日本に於て、東北では青森、岩手の二県と、九州の突端の二つの県宮崎、鹿児島、琉球等のみである。",
              "citation": {
                "source": "「ラジオ黄金時代」の底潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時この二論派は実に日本の政界を支配したるものにして、百世の下、史乗にその跡を留む。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "創建清眞寺碑記賜進士及第戸部員外郎兼侍御史王※撰篆竊聞俟百世而不惑者道也。",
              "citation": {
                "source": "創建清眞寺碑",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "曠百世而相感者心也。",
              "citation": {
                "source": "創建清眞寺碑",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂百世相感而不惑者足徴矣。",
              "citation": {
                "source": "創建清眞寺碑",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "故内田魯庵が『此兩作を書いた露伴は只に明治文壇とのみ曰はず、世界文學界の珍である、眞に百世稀に出づる天才の面影は此作に最もよく現はれてをる』と激賞した。",
              "citation": {
                "source": "新詩發生時代の思ひ出",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人たとひ現時に於て骨を溝中に暴すとも百世の後、我日本の精神界、道徳界に大造あるの名を遺さば亦以て怨みなかるべし。",
              "citation": {
                "source": "信仰個条なかるべからず",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、本名で、詩を投稿し、その一つは「百世」、その一つは「文章倶楽部」に、送ったものは必ず残るといった調子で、本屋の店頭に、わが名を見出したこともあったのだ。",
              "citation": {
                "source": "久坂葉子の誕生と死亡",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、うちの先生に惜しいことは、お酒を召上ることでございます、梵網経の中にも飲酒戒第二とございまして、酒は過失を生ずること無量なり、もし自身の手より酒の器を過ごして、人に与えて酒を飲ましめば五百世までも手無からん、況んや自ら飲まんをや、とございます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "有善察百世之後憂国家之憂者。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "有歴記百世之事以伝于将来者。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "動けばどう変化するか、風雲か雷霆か、見わけのつかぬところに余韻が縹緲と存するから含蓄の趣を百世の後に伝うるのであろう。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "百世の後より百世の王を等するに、これに能く違うこと莫し。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "百世の語、あるいは為政篇の子張の問いに答えた「百世といえども知るべきなり」という孔子の語に連関するかも知れぬが、子貢はかかることに興味を持つ人ではなかった。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其或周に継がんものは、百世といえども知るべきなり。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シューベルトこそは真に人間の母の生んだもののうち、最もよき魂であり、百世変ることなき、人類の友であると言えるだろう。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "求めるのは一時の風潮や流行が求めるので、之を百世に保存するはずもなし、市塵の流れに任せてゆくのである。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
