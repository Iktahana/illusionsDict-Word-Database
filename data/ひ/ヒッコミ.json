[
  {
    "uuid": "484f77e0-6f1b-5984-b87a-e8d80ad9463d",
    "entry": "引っ込み",
    "reading": {
      "primary": "ひっこみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
