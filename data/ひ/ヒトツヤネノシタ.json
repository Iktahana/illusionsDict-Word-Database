        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただ、心のただしい人びととひとつ屋根の下でくらさせていただきたいのです。",
              "citation": {
                "source": "赤いくつ",
                "author": "DE RODE SKO",
                "note": "青空文庫"
              }
            },
            {
              "text": "仇敵同士でも、ひとつ屋根の下に起き臥ししていれば、いつしかそこに、情がわく。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩乃とは、ひとつ屋根の下に起き臥ししているというだけで、今もこの深夜に、萩乃は、長い廊下の奥の自分の部屋に、ただ一人、どんな夢を見てか――。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "足曳や、われとおらあながいあいだ、ひとつ屋根の下に暮らして、たがいに気心も知り合ったなかだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一ト晩は、お身の上からこっちの素姓もかたりあって、ひとつ屋根の下で寝ているんだ」「しまった」　と、穆の息子はひっさげていた枇杷の木の木剣をなげだして、その兄なる者とともに、地に平伏した。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
