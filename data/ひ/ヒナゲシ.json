    "definitions": [
      {
        "index": 1,
        "gloss": "common poppy (Papaver rhoeas)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
