    },
    "definitions": [
      {
        "index": 1,
        "gloss": "item of expenditure",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "規定以外の村の費目の割当などに、最先に苦情を言出すのは此人に限る。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "規定以外の村の費目の割當などに、最先に苦情を言ひ出すのは此人に限る。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月廿四日の予算会議、農商務省費目の議事に於て田中代議士は始めて農商務大臣陸奥宗光と顔を合はせた。",
              "citation": {
                "source": "政治の破産者・田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日此項の費目にかゝらぬ前に御答弁があるだらうと信じて居りましたが、何か御差支があるものと見えて御答弁がありませぬ。",
              "citation": {
                "source": "政治の破産者・田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "七日経て答弁が出来なければ出来ないと云ふことを、本費目に掛る前に、大臣御出席であるから、一応申されて然るべしと思ふ。",
              "citation": {
                "source": "政治の破産者・田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "都て帝室の費用は一種特別のものにして、其公然たるものある可きは無論なれども、或は自由自在に費して殆ど帳簿にも記す可らざる程の費目もある可し。",
              "citation": {
                "source": "帝室論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "然かも此財を費して、其費目は帳簿にも記す可らざるものならん。",
              "citation": {
                "source": "帝室論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本の用役で直接的利用を有するものは、消費的用役（services consommables）と称せられ、消費目的物に結合する。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "反対にもし、右の区別と分類とを承認すれば、交換の理論によって消費目的物及び消費的用役の価格決定を、次に資本化の理論によって固定資本の価格の決定を、流通の理論によって流動資本の価格の決定を、することが出来る。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず消費目的物と消費的用役とのみが売買せられる市場、換言すればそれらのもののみが交換せられる市場を想像し、かつそこでは用役の販売が資本の賃貸によって行われると想像する。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本化の問題を解くには、貯蓄をする地主、労働者、資本家すなわち自ら供給する用役の価値の全部をあげて消費的用役及び消費目的物を需要することなく、この価値の一部をもって新資本を需要する換言すれば貯蓄する地主、労働者、資本家の存在を仮定せねばならない。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "小麦、麦粉、パン、肉類、葡萄酒、ビール、野菜、果実、消費者の用に供する加熱用・灯用の燃料等の消費目的物、再び肥料、種子、原料となる金属、木材、加工せられる繊維、布、生産の用に供せられる加熱用・灯用の燃料、その他生産物となって現われるために原料としては消失すべきすべての物すなわち原料品がこれである。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "（８）　消費目的物。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "一七九　消費目的物。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "収入としては、　８　消費者の手中にある消費目的物から成る収入の貯蔵。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "10　生産物となって、生産者の手によって売られる消費目的物及び原料から成る新収入。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に消費目的物及び原料は、生産せられると同時に直ちに消費せられる（貯蔵をしないとすれば）ものと仮定して、第八及び第九項目を捨象することが出来よう。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ちに消費せられる消費目的物及び原料のほかに、長い間に消費せられる狭義の資本がある。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしても家賃だけのものは要るのであるから、私は借家であると持家であるとによらず、商店経営の中のかなり重要な部分を占めるこの費目を等しく家賃として計上することにしている。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "選良連をみるがいい、なんの費目にも口をだす。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "まつたく脅迫で、一度でも借金したら、必ずさう言明しろ、借金の支払はれるまでお前の食事を半分に減らせとか、お風呂へ行く小遣ひもくれない。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
