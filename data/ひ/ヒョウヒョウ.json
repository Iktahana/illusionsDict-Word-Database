[
  {
    "uuid": "fc6779d0-5661-53cc-b7de-bab0d63a2985",
    "entry": "飄々",
    "reading": {
      "primary": "ひょうひょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-たる",
        "副詞-と"
      ],
