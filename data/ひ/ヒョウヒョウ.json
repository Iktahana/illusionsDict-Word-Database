      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "whistling (wind)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "飄々として唸りながら、無限に高く、穹窿の上で悲しみながら、いつも一つの遠い追憶が漂っている！",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現世とはただわずかな糸でつながって、飄々として風に吹かれているような趣があったかもしれない。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼空に人の點あり、飄々として風に吹かる。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然うした身にも、生命の惜さに、言はれた通りに目を瞑ぎました後は、裾が渦のやうに足に煽つて搦みつきますのと、兩方の耳が風に當つて、飄々と鳴りましたのばかりを覺えて居ります。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "飄々とカンのまま雲に上り空に架することができた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "風貌も、その時はちゃんとネクタイをしておられたし、飄々などという仙人じみた印象は微塵も無く、お顔は黒く骨張って謹直な感じで、鉄縁の眼鏡の奥のお眼は油断なく四方を睥睨し、なつかしいどころか、私にはどの先生よりも手剛いお方のように見受けられた。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上甲板の欄干に凭りて秋天一碧のあなた、遠く日本海の西の波に沈まむとする落日を眺めつゝ、悵然たる愁懐を蓬々一陣の天風に吹かせ、飄々何所似、天地一沙鴎と杜甫が句を誦し且つ誦したる時、その船の機関長とか云ふ赭髯緑眼の男来つて、キヤン、ユウ、スペーク、エングリツシ？",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女の引締まって居た気持を、急に飄々とさせるような空漠とした音であった。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「花田さん、そっちは本堂ですよ」と世話役の人に注意されると、「はッ」と言いながら、こんどは間違って便所の方へ行ってしまうという放心振りがめずらしくなく、飄々とした脱俗のその風格から、どうしてあの「寄せの花田」の鋭い攻めが出るのかと思われるくらいである。",
              "citation": {
                "source": "勝負師",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくまでも飄々としていたものだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、飄々として下の関の車輛会社の中爺さんが来る。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "清閑にしてまた飄々としている。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "哲学に迷い、イデオロギイに中毒して、神経衰弱を生命の綱にしている現代の青年が、百年考えても実践出来ない人生の千山万岳をサッサと踏破り、飄々乎として徹底して行くのだから手が附けられない。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "話しっ振りの飄々たるに似合わぬ、なにか苛々とした焦燥がその吸い方に現われていたのである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓦斯が籠ると一緒に飄々として地を離れ、全速力の飛行を得て、新しい旅の首途に向へるのだ。",
              "citation": {
                "source": "途上日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はある夜、寺の西の軒から一つの物が雲に乗るように飄々と飛び去って、渭水の方角へむかったかと思うと、その夜半に再び帰って来たのを見たので、翌日それを寺僧に語ると、僧もすこぶる不思議に思っていた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "また彼の歩き振りは飄々たる抜きあしの態で、爪先から先へひよい／＼と脚を運びますが、上体はやはり長閑なヘチマのやうにぶらついてゐるのに斜めに頤を伸した伏目をもつて、油断なく前後左右を警戒してゐます。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "天王寺墓域内、「吉梵法師」と勒された墓石は今なお飄々たる洒脱の風※を語っておる。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつのまにか新春の日も昼をすぎて、行きついたその四ツ谷ご門あたりは飄々、颯々とめでためでたの正月風が、あわただしげに行きかわす中間小者折り助たちのすそを巻いて、御慶の声をのせながら吹き通りました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに飄々乎として、所もあろうにこんな山路の奥の身延街道に姿を現すとは、いっそもう小気味のいい位ですが、しかし、当の本人はそれ程でもないと見えて、相変らず言う事が退屈そうでした。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "颯々として背を吹きなでるその初秋のわびしい街風をあびながら、風来坊の退屈男は飄々乎としてどこというあてもなくさ迷いました。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことにその飄々悠々泰然とした落ち付きぶりというものは、何ともかとも言いようがないのです。",
              "citation": {
                "source": "旗本退屈男",
                "author": "第七話　仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　飄々として立ち上がると、けろりとしているのです。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "清閑にしてまた飄々としてゐる。",
              "citation": {
                "source": "日本ライン",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤグラ峠の唐松の下で私の祖父は頻りと狐に化されて幾多の滑稽や悲惨なる挿話を今も尚ほ人々の口に残してゐたが、恰度私達の行手には例の唐松が踊りあがつたやうな枝を空へ張り、飄々と風を呼んでゐる風情は、まさしく神経病患者の独り路であるならば容易く山霊の催眠術を吹き込むにふさはしかつた。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が只今用意いたして居ります少しばかりの瓦斯が出来次第に私達は飄々とこの地上を離れます。",
              "citation": {
                "source": "変装綺譚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "飄々と現われる傀儡師が、いわば手引きをしたようなもので」広太郎、ちっとも威張らない。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょうひょうふりょう、りょうふりょう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥沼の作業が続く中で、狼狽する私を笑顔で元気づけながら、野口さんは腹の底に諦観を呑んだようなひょうひょうとした調子で作業を続けてくれました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "覆面の小がらなそれなる怪人は、岸へ泳ぎつくと、ぐっしょりぬれた着物からぽたぽたと水玉をおとしながら、まるで何かの物の化につかれてでもいるかのごとく、ひょうひょうふらふらと歩きだしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
