        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一例として桜狩美人の腹や減却す人間に鶯鳴くや山桜　人里離れた深山の奥、春昼の光を浴びて、山桜が咲いているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら蕪村の場合は、侘びが生活の中から泌み出し、葱の煮える臭いのように、人里恋しい情緒の中に浸み出している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なるほど、この辺は人里離れて、猪の遊ぶのに持って来いだ」　翁はそういって、傍の保与（寄生木）のついている山松を見上げた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は腑甲斐ない一人の私を、人里離れた山中へ遺棄してしまったことに、気味のいい嘲笑を感じていた。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬が居るようではともかくも人里に縁があると、これがために気が勇んで、ええやっと今｜一揉。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "水源は秋の日など隅田堤より遠く西の方に青み渡りて見ゆる秩父郡の山※の間にて、大滝村といへるがこの川の最上流に位する人里なれば、それより奥は詳しく知れねど、おもふに甲斐境の高山幽谷より出で来るなるべし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "野も人里も深い雪をかむって、息さえ詰まるようでありました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "姥は影に添って、見送ってお上げ――人里まで。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩原｜古町から一里ほど人里放れた山の中を行くと新湯に出る。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃駅の陣屋跡に、石垣の草に埋もれたのや、形の殆んど崩れてしまった石の地蔵尊が、尾花の中にボンヤリ立っているのも、人里離れたこの山上にはことに趣が深かった。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨は相変らずショボショボと降り、風は雑草を揺がして泣くように吹く、人里離れし山巓の寂莫はまた格別である。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、人里を離れました山懷で、仙人が立直つて申しました。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一里といえば人里から左のみ遠からぬ処であるにも拘らず、ここは殆ど通路の無いほどに岩石｜嶮しく峭り立っているのと、昔から此辺は魔所と唱えられているのとで、猟夫も樵夫も滅多に通わなかった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も人里の方へ逃げるのは危険だと悟ったので、彼は案内知ったる山の方へ逃げ込んだ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この道を奥の方へと荷馬車の通うのにも出逢ったが、人里がありそうにも思えない荒寥たる感じで、陰鬱な樹木の姿も粗野であった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "人里はなれた山の奧にも夜ふけてかがやく弧燈をゆめむ。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或いはあの歌の主は、かねがねあまりに自分が歌が下手なので、思いあまって、こんな人里はなれた山奥でひそかに歌の修行をしているのかも知れない、と思ったら、同様に歌の下手な私には、そぞろその歌の主がなつかしくなって来て、ひとめそのお姿を拝見したいという慾望が涌然と起って来た。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうせ乞食坊主じゃ、この山の上に、人里でもあると思うて来たろう」と、顎髯の男が面倒くさそうに云った。",
              "citation": {
                "source": "岩魚の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嬉しや人里も近いと思う、月が落ちて明方の闇を、向うから、洶々と四、五人｜連、松明を挙げて近寄った。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにも拘らず、常に遠く人里から離れて居る彼等の生活が夫婦間の愛情を濃かにする。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シルレル、若うして一友と共に潜かに郷関を脱走するや、途中一片の銅銭もなく一ヶのパンもなく飢と労れに如何ともすることなく人里遠き林中に倒れむとしたり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬が居るやうでは左も右も人里に縁があると、之がために気が勇んで、えゝやつと今一｜揉。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "城趾の此の辺は、人里に遠いから、鶏の声、鴉の声より、先づ五位鷺の色に夜が明けやう。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……さて、日も当れば、北国の山中ながら、人里の背戸垣根に、神が咲かせた桃桜が、何処とも無く空に映らう。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人里を少しでも離れると、けつく気楽なと思はぬでもないが、さりとて、人に逢はねばやつぱし寂しいものだ。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに人里の遠いところに育ったので、非常に人を恋しがる方であった。",
              "citation": {
                "source": "木曽の旅人",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び人里へ歸らうと思つては出かけるけれども、行つても、行つても、同じ樣な曠野の草、涯しがないので復此處に歸つて來る。",
              "citation": {
                "source": "散文詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて其夜は人里遠き山中に笹原の露を片敷きて、憐れなる初花の面影と共寐しつ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
