[
  {
    "uuid": "bc8fac37-9ddd-5f29-b7d9-439351f29e64",
    "entry": "悲報",
    "reading": {
      "primary": "ひほう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
