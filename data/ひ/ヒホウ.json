    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sad news",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "四時すぎ、案の如く樹明君がやつてきてくれた、そして驚くべき悲報をもたらした。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "北畠親房は常陸関城にあって此の悲報を聞き、「八月の十日あまり六日にや、秋露に侵されさせ給ひて崩れましましぬと聞えし。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけに此の悲報は南朝にとっては大打撃であった。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――勿論、知己と迄言う程の深いものではなかったが、身寄のない直介の財産の良き相談相手であり同窓の友であると言う意外に於て、だから大月は、夫人から悲報を真っ先に受けたわけである。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "崩落に瀕した廃坑に、再び重い鉄扉を鎖した係長は、慌しく電話室に駈けつけると、立山坑の地上事務所と札幌の本社へ、海水浸入の悲報を齎した。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはれな朱紫国へ、怖ろしい悲報が達した。",
              "citation": {
                "source": "闘戦勝仏",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "電光の如く速かに悲報が伝へられた。",
              "citation": {
                "source": "クサンチス",
                "author": "XANTHIS",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、かの闖賊は勢いますます猖獗になって、都もやがて危いという悲報が続々来るので、忠節のあつい将軍は都へむけて一部隊の援兵を送ることになった。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "月日は能く覚えていないが、今年になってから、同君が出版延引した言訳を、金城朝永君を通して私に伝言した後約一時間にして、執務中急死されたとの悲報に接した時、少からず驚かされた。",
              "citation": {
                "source": "「古琉球」改版に際して",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "この愕くべき悲報に、僕は帆村探偵について、現場を覗きに来たというわけだった。",
              "citation": {
                "source": "街の探偵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おぢいさんの悲報をきいて、僕は早速帰り仕度にとりかゝつたが、或る事柄の為に当分帰国しないで、こちらで務めることになりました。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに夜が明けてホッと一息ついたとき、そこへ電話が掛って来て、ゆうべ西風の妖魔が、空気工場から若き珠江夫人を奪っていったという悲報を伝えた。",
              "citation": {
                "source": "人間灰",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "然も今また新らしき悲報を耳に致しまする。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ熊城君、津多子夫人の恢復で、この事件のどこかに明るみが差すかもしれないぜ」「なるほど、薬物室の調査は無駄じゃなかったろうがね」と熊城は苦いものに触れたような顔になって、「だが、おかげさまで、とんだ悲報を聴かされてしまったよ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月四日（日曜）晴　暖〔摘要〕三越行　松野夫婦来訪　　　　「青い鳥」を読む、細井氏令嬢の悲報をうける、女鴨の死　眼覚めるとすぐ私はめすの鴨の死んだのを知った。",
              "citation": {
                "source": "日記",
                "author": "一九一四年（大正三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの疎開地でサイパンの悲報を聞きて胸つまり、声が出なくなって、如何にしても常に自信のあったピアニシモが出来なくなって一夜泣き明かしたが、これでは自分自身まで敵にやられたと同じと思って、一生懸命に練習して遂にまたピアニシモの声を美しく出すことが出来て、先ず胸をなでおろした。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "田沼意次は将軍の薨去の、一大悲報を耳にするや、即夜参殿しようとした。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲報のみ、つゞいて至る。",
              "citation": {
                "source": "本因坊・呉清源十番碁観戦記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻頭随筆坂口安吾　山本元帥の戦死とアッツ島の玉砕と悲報つづいてあり、国の興亡を担ふ者あに軍人のみならんや、一億総力をあげて国難に赴くときになつた。",
              "citation": {
                "source": "巻頭随筆",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、一足名護屋へ立戻ると、こゝは戦況日夜到り、苦戦悲報、かうなると忽ちムズムズ気負ひ立たずにはゐられぬ如水。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この悲報は、全世界を打震わせた。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、今日は、今日はと延ばしてゐるうちに、田口君急逝の悲報が私を見舞つた。",
              "citation": {
                "source": "田口竹男君のこと",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "主家悲報大變到來・太守父子一病一死・怒髮冠を衝く・不動祠祈願・奸女を倒す・身命塵埃・死の妙所・生の苦尚々御賢父樣御元氣の筈、宜しく御傳へ可被下候。",
              "citation": {
                "source": "遺牘",
                "author": "西郷隆盛",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正五年七月九日先生の訃いまだ公にせられざるに先立ち馬場孤蝶君悲報を二、三の親友に伝ふ。",
              "citation": {
                "source": "書かでもの記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "２．彼はその病める母にこの悲報を告げる決心がつかなかつた。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "其後今日まで一度びも消息なき故不思議の事と思ひゐたりしに、突然悲報に接したり。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛兒の悲報を淡々として語る彼の態度は、けだし驚異の至りである。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "この悲報に接し、各新聞は例により特集。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "大石君は兄戦死の公報が来てちょうど八月九日に郷里へ帰っていたのだが、大学潰滅の悲報を聞くや、教室員を救護しようと北松浦から駆けつけてくれたのだった。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "子規居士は広島に在ってこの悲報に接したのであった。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
