    "definitions": [
      {
        "index": 1,
        "gloss": "a step",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（男一足下つて首をクネクネ廻して、頸の凝りを直す）夢だ…………常識主義者だ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺がみんなと、もう一足といふ所で捏造になる所まで喋舌ることを耕二は知つてゐるからだ」と兄はさう考へると今暗い部屋の中に、小さな蒲団にくるまつて寝てゐるであらう耕二がとてつもなく気味の悪いものに思へた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この男は甞て心的活動の出発点に際し、純粋に自己自身の即ち魂の興味よりもヴァニティの方を一足先に出したのです。",
              "citation": {
                "source": "小林秀雄小論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "清らかになまめかしい白足袋も一足落ちている。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風起る、駆け戻って朝飯を済まし、善作が後始末をしている間、一足先へ出立する、奥常念に向おうとて。",
              "citation": {
                "source": "奥常念岳の絶巓に立つ記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヘッ、俺より一足だって先にゃ行かねえや。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「せっかく、救けて頂いたようなものの、行先の覚束なさ、途中の難儀、もう一足も踏み出す勇気はございません。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、また、汽車で品川へ戻り、そこから道中｜双六のように一足一足、上りに向って足を踏み出すのである。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いえ、氷山にぶっつかって船が沈みましてね、わたしたちはこちらのお父さんが急な用で二ヶ月前一足さきに本国へお帰りになったのであとから発ったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは堪へかねて一足そっちへ進んで叫んだ。",
              "citation": {
                "source": "圖書館幻想",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただそのおしまいの一足だけがあぶないぞ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎が帰ってから一足後れて敏子も帰っていった。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "村のものらもかれこれいうと聞いてるので、二人揃うてゆくも人前恥かしく、急いで村を通抜けようとの考えから、僕は一足先になって出掛ける。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の奴らに逢うのがいやだから、僕は一足先に出て銀杏の下で民さんを待っていたんでさア。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が居なくなってから二十日許り経って十一月の月初めの頃、民子も外の者と野へ出ることとなって、母が民子にお前は一足跡になって、座敷のまわりを雑巾掛してそれから庭に広げてある蓆を倉へ片づけてから野へゆけと言いつけた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その意味は、僕がだれより早く、一足先に登つて行つては、また砂の山をすべり落ち、いつも最初の同じ地位から進むことのできない人間だといふのである。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一足遅れて来た七五郎。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "儂ァたった一人の伜をやくざ渡世にしたくねえからな……」　凝ッと聴いていた次郎長、　「爺っつあん、草鞋を一足頂けませんか」Ｓ＝表　石松、隣りから薬持って帰って来る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「あっしが盲目で唖で聾になったら知ら無え事」　「なにッ」と鉄五郎が気色ばむのを三次一足退って又「へ……」　と笑って粉かした。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一足退いて武蔵、其奴を叩ッ斬る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "アレッと団九郎一足退る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一足の絹の靴下に五ルーブルから、八ルーブルの金を取って帰って行く。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一時間ばかり、さらに談じかつ飲み、中倉翁は一足お先に、「加と男」閣下はグウグウ卓にもたれて寝てしまったので、自分はホールを出た。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "一足二足進み寄るのを見ると足も片方不随であるらしい。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まであの店の部屋の古風な装飾なり、また燕尾服を着たボーイなりが、すべて前の世紀の残りものであったのが、火事で焼けたこの機会に、一足飛びに現代式に変ってしまったのだというような気がした。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "莫大ナル出兵費ハ誰カラ出ルカ、諸君ガ一本ノ煙草ヲ喫ンデモ、半斤ノ砂糖ヲ使ッテモ、一足ノサル又ヲ買ッテモ、必ズ間接ニ徴収セラレル税金カラ出テイルノダ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、洋車を呼ぶと、一足とびにとび乗った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩掛け、洋傘、手袋、足袋、――足袋も一足や二足では足りない。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あした雨が晴れるか晴れないかよりも、今夜ぼくが…………を一足つくれることのほうがよっぽどたしかなんだから。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、歩けば、ひとあしごとに、するどいナイフをふんで、血が出るような思いをするだろうよ。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
