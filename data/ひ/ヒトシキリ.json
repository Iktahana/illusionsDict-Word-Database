        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その翌日は夕方から暴風雨になつて一頻り荒れたが十時過ぎになつてばつたり止んだ。",
              "citation": {
                "source": "牡蠣船",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々空が暗くなって雲が濃くなると一頻りずつ必ず雨を降らせる。",
              "citation": {
                "source": "大雨の前日",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "風に煽られた大雨が一頻り沛然として降り注いで来た。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "美奈子が、玄関から上って、奥の離れへ行こうとして客間の前を通ったとき、一頻り賑かな笑い声が、美奈子の耳を衝いて起った。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "便所の手拭ひ掛けがこと／＼と、戸袋に当つて搖れるのがやむと、一頻りひつそりと静かになつて、弱り切つた虫の音が、歯※にしみるやうに啼いてるのが耳だつて来る。",
              "citation": {
                "source": "散歩",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また私の胸に和ぎの芽を植ゑそめたものは、一頻り私の膓を噛み刻んでゐたところの苦惱が生んだ、ある犧牲的な心でした。",
              "citation": {
                "source": "冬を迎へようとして",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌日は夕方から暴風雨になって一頻り荒れたが十時過ぎになってぱったり止んだ。",
              "citation": {
                "source": "牡蠣船",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一頻り合戦が続いた後、一匹の馬が飛び出して来た。",
              "citation": {
                "source": "童話",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がやって来ると、この露次は急に賑やかになり、細君や子供たちが一頻り陽気に騒ぐのであったが、ふと、その騒ぎも少し鎮まった頃、窓の方から向を見ると、魚芳は木箱の中から魚の頭を取出して犬に与えているのであった。",
              "citation": {
                "source": "翳",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "美奈子が、玄関から上つて、奥の離れへ行かうとして客間の前を通つたとき、一頻り賑かな笑ひ声が、美奈子の耳を衝いて起つた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一頻り喋舌り疲れた連中がどしんと一つ卓子を叩いて、「△△君、君のお考へは何うだね。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩野泡鳴氏は文士や画家が片手間の生産｜事業としては養蜂ほど好いものは無いといつて、一頻りせつせと蜜蜂の世話を焼いてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　多分｜一頻り噂のあつた岩野清子女史との結婚問題を気にして、それで一寸｜拗ね出したものらしい。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一頻り戯書が済むだ頃、信常氏は「さうだすつかり忘れてゐたつけ、親爺から委託り物があつたんだ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　一頻り病人の咳きあげるのを、爺さんは後方から背を撫でてやつたりした。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔雀女８・８（夕）　女流声楽家三浦｜環と今は故人の千葉｜秀浦との関係は一頻り喧しい取沙汰になつたので、世間には今だにそれを覚えてゐる人も鮮くあるまい。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "トーマス・リイドといへば、米国では一頻り鳴らした弁護士出の政治家で、共和党の弁士として議院で随分雄弁を揮つたものだ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸妓連が一頻り雀のやうにぺちやくつて、さつと引き揚げて往くと、後に残つた一人の相客は溜息を吐きながら言つた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体髯を生やしたり、剃つたりするのは、何かの機会がないと一寸｜行り難くいもので、米国でも南北戦争以前までは、今の米国人のやうに、顔を綺麗に剃つたものだが、戦争後は顎髯を伸ばす事が流行つて、一頻りそれが無いものは肩身の狭いやうな思ひをする事さへあつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒が一頻りまはると、お上手ものの鴈治郎は髪の長い雲右衛門を振りかへつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い士官は蛙のやうに霊魂まで吐き出しさうに、また一頻り身悶えした。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして口に残つた核子は一頻りしやぶり通した後で、猿のやうな口もとをして床の上に吐き出して素知らぬ顔をしてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一頻り吹いて静かになった。",
              "citation": {
                "source": "氷蔵の二階",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの晩、電車ぎりぎりだったでしょう」「ええもう青でした――でも、おそいのはいくらでも馴れてるから……」　手芸の話などが一頻り弾んだ。",
              "citation": {
                "source": "斯ういう気持",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がさびしく同意すると、妻は寝たままで、一頻り彼の無能を云うのであった。",
              "citation": {
                "source": "秋日記",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の日の夕暮れ、バグダツドの一つの井戸は、町の女達の水汲みで一頻り賑つてゐました。",
              "citation": {
                "source": "三つの指環",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "流浪直前、バンヂャマン・コンスタンの「アドルフ」について、一頻り私は君と語り明かした幾夜をもつたが、あの頃の考へは今も尚変らないばかりでなく、芭蕉の風流を憎む気持は愈々熾烈の度を加へるばかりのやうです。",
              "citation": {
                "source": "無題",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "繁吹をあげてザザザザーッ……と頭を揺すぶる竹藪の音が、激浪のやうに荒れ狂ふ裏手一帯の劇しい起伏を未だ一杯に温気の籠めた朝の部屋に歴々と描き出して見せてしまふ、かと思ふと、突然硝子を射抜くやうな太く真つ直な雨脚がヂヂヂヂヂイーと一頻り窓に噛みつくのであつた。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々、舞ひ狂ふ嵐の腹が絶叫に似た唸りをたてて棟を打ち飄と戸外を噛み狂ふ度に、一頻り重苦しげに軋みたつ鈍い家鳴に打ち雑つて、絶え入るやうな与里の愁訴は忍び泣きの心細さに吹き千切られ、縷々と這ひ又やや高く蹌踉して遣瀬なく物凄いものに聴きとれてきた。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一時頃、やっとお目ざめになり、新聞ないかあと言い、寝床に腹這いになりながら、ひとしきり朝刊の検閲をして、それから縁側に出て支那の煙草をくゆらす。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
