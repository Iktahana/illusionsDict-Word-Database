        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "四壁庵の『忘れ残り』上巻に、吉原江戸町三丁目佐野槌屋の抱え遊女｜黛、美貌無双孝心篤く、父母の年忌に廓中そのほか出入りの者まで行平鍋を一つずつ施したり、「わがかづく多くの鍋を施して、万治この方にる者ぞなき」とほめある。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "行平鍋に入れて『それを裏の井戸へ行つて洗うて来なはれ』と渡して呉れた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな長火鉢に平鍋がかかって、白い豆腐が煙りを吐いて、ぷるぷる顫えている。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪平鍋とコショウ瓶を持ったコックとチェシア猫も出てくる。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
