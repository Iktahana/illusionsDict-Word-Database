    "definitions": [
      {
        "index": 1,
        "gloss": "to cheer up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たちまち姉は優しく妹の耳に口寄せて何事かささやきしが、その手をとりて引き立つれば妹はわれを見て笑みつ、さて二人は唄うこともとのごとくにしてかなたに去りぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し主人公が田舍言葉でやつつけたら下女や何かの田舍言葉が引き立つまい。",
              "citation": {
                "source": "鈴木三重吉宛書簡―明治三十九年",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の中に二足の女下駄の、一つは葡萄茶、一つは橄欖色の緒の色が引き立つてゐた。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "方面は違いますけれど踊りの花柳登美さんなんか、舞台衣裳に、お金を糸目なくおかけになるので、あの方の芸が、それだけ引き立つんですわねえ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お早うございますが各自に交換され、昨日のこと天気のよいことなど喃々と交換されて、気の引き立つほどにぎやかになった。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもと違つて、何となく気が引き立つてゐる。",
              "citation": {
                "source": "追儺",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "もろもろの病いはおのれの心からいずるともいえば、其方たちも常に気を配って、父上の弱った心を引き立つるように努めねばならぬぞ。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かうして見ますと画がまた引き立つて来たやうな気がいたしますね。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろ出来たばかりの、新しい半コートや、襟捲きに引き立つその姿が、おりおり人を振り顧らせていた。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ字引と首引きで讀んで行くうちに、無性に自分の精神が引き立つて來て、もう、絶望と死の苦みとを感得したと思つて居る自分に取つては、句々節々があらたの悲愁を養つて呉れるやうで、それがたゞ愉快であつたのだ。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論極端にじみなのではない、相当の飾りもあつてその調和の工合は何ともいはれん味があるが、それにもかかはらず余は今少しはでに修飾したらば一層も二層も引き立つて見えるであらうと思ふ。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯だ一人あの若い詩人がゐて今日の会は引き立つ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪人の女を含まぬ歌舞妓芝居も、ずつと昔からある悪女を改めて善人にして出すといふことは出来ないことであるし、又さういふ妬婦のあることによつて善人の女が更に引き立つのである。",
              "citation": {
                "source": "役者の一生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくこの敗軍の体を見ればいとど心も引き立つわ」「引き立つわ、引き立つわ、糸のように引き立つわ。",
              "citation": {
                "source": "武蔵野",
                "author": "山田美妙",
                "note": "青空文庫"
              }
            },
            {
              "text": "たったそれだけで引き立つのだから、ほかの裸体はみんな死んでるということで、芸なし猿だということだ。",
              "citation": {
                "source": "安吾巷談",
                "author": "ストリップ罵倒",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちその意見と言うのは第一は先輩は後輩を引き立つべき義務のある事、第二は今日植物学者は極めて寡いから一人でもそれを排斥すれば学界が損をし植物学の進歩を弱める事、第三はやはり相変らず書物標本を見せて貰い度き事、この三つを以て折衝して見たが氏は強情にも頑としてそれを聴き入れなかった。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちその意見というのは第一は先輩は後輩を引き立つべき義務のある事、第二は今日植物学者は極めて寡いから一人でもそれを排斥すれば学界が損をし植物学の進歩を弱める事、第三は矢張り相変らず書物標本を見せて貰いたき事、この三つを以て折衝してみたが氏は強情にも頑としてそれを聴き入れなかった。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第一部　牧野富太郎自叙伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の引き立つようなことを云っておくれ、ジェコブよ。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊らせる方がよほど引き立つ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十五　赤罠",
                "note": "青空文庫"
              }
            },
            {
              "text": "髮にも亦｜琥珀色の花をつけてゐらつしやいましたが、それが捲毛の眞黒な房によく引き立つてゐました。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は濃い栗色の髪の背の低い女で、ぽってりと肥満し、眼がぎろりとして、マルセイユ風の強い調子でいっそう引き立つ快弁をそなえていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと反対に一つの独立した作品としては大した傑作でもないような書画が、茶の間の床に掛けてみると、非常にその部屋との調和がよく、軸も座敷も俄かに引き立つ場合がある。",
              "citation": {
                "source": "陰翳礼讃",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、もともと私は自分が踊りたいのではなく、こう云う場所でナオミがどれほど引き立つか、どう云う踊りッ振りをするか、それを見たいのが主でしたから、結局この方が気楽でした。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじおかね出して服を買っても、二倍にも三倍にも引き立つから」　そう言いながらヨシオのかたわらまで歩いて来たジョイスリンは、英語で次のように続けた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝気な人なのですが、私の愚図なのがただいとしまれるのでしょうか、いつも私の気の引き立つように仕向けてくれます。",
              "citation": {
                "source": "聖アンデルセン",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらかでも踊りがうまいと、裸体もひきたつ。",
              "citation": {
                "source": "安吾巷談",
                "author": "ストリップ罵倒",
                "note": "青空文庫"
              }
            },
            {
              "text": "服でひきたつようなご面相でもあるまいし。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんと、じみすぎておかしいかと思うたら、赤いはっかけでひきたつこと。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなり肥ったし、日にやけて、すっかり逞しくなったが、月代も髭もきれいに剃っているので、もちまえの人品のよさが、却ってひきたつくらいだった。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
