[
  {
    "uuid": "d9831504-0f12-55e7-8c29-86b2c89cccda",
    "entry": "引っ叩く",
    "reading": {
      "primary": "ひっぱたく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
