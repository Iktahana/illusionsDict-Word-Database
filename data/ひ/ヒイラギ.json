    "definitions": [
      {
        "index": 1,
        "gloss": "holly olive (Osmanthus heterophyllus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "庭の柊が鋭いトゲのある葉を茂らせ、防犯用の生垣として役立っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "冬の寒い朝、柊の葉に霜が降りて白く輝いている様子はとても美しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "柊は魔除けの力があると信じられ、古くから家の北東に植えられることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ファニーとカロラインが体を二つに折って笑いこけているのをいまいましくにらみつけながら足許を見ると、紫の花をつけた一茎の大薊が柊のような葉を拡げて立っていた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "片手でも押し倒せそうな小さい仮家で、柊や柘植などの下枝に掩われながら、南向きに寂しく立っていた。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　みちばたの土手の上に、柊の木が一本植わつてゐました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちぢかめてゐる坊さんのひざの上に、柊の花がほろほろとこぼれて米粒のやうに見えました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そして、踵をかへして、柊の木の方へむかひました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "柊の木のそばまで、ものの半町あるか無しでした。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "つひに鳥右さんは、柊の木の下の岐れ路につきました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "年とったお母さんは隣の鶏が今日はじめて卵をうんだが、それはおかしいくらい小さかったこと、背戸の柊の木に蜂が巣をかけるつもりか、昨日も今日も様子を見に来たが、あんなところに蜂の巣をかけられては、味噌部屋へ味噌をとりにゆくときにあぶなくてしようがないということを話しました。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "柊のいわれを知っているか」「知らない」「知らないのか？",
              "citation": {
                "source": "親友交歓",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "柊のいわれ」ともったい振る。",
              "citation": {
                "source": "親友交歓",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも鬼が来て覗くか、楽書で捏ちたような雨戸の、節穴の下に柊の枝が落ちていた……鬼も屈まねばなるまい、いとど低い屋根が崩れかかって、一目見ても空家である――またどうして住まれよう――お札もかかる家に在っては、軒を伝って狗の通るように見えて物凄い。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "姓は源、氏は細木、定紋は柊であるが、店の暖簾には一文字の下に三角の鱗形を染めさせるので、一鱗堂と号し、書を作るときは竜池と署し、俳句を吟じては仙塢と云い、狂歌を詠じては桃江園また鶴の門雛亀、後に源僊と云った。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "其夜はまだ各が一つ加はつた年齡の數程の熬豆を噛つて鬼をやらうた夜から、幾らも隔たらないので、鹽鰮の頭と共に戸口に※した柊の葉も一向に乾いた容子の見えない程のことであつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "門口の柊の株を右に曲って、二人の姿が見えなくなると、母親は、わあっ！",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『郷土研究』四巻二九六頁、尾佐竹猛氏、伊豆｜新島の話に、正月二十四日は、大島の泉津村｜利島神津島とともに日忌で、この日海難坊（またカンナンボウシ）が来るといい、夜は門戸を閉じ、柊またトベラの枝を入口に挿し、その上に笊を被せ、一切外を覗かず物音せず、外の見えぬようにして夜明けを待つ。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "柊は刺で、トベラは臭気で悪霊を禦ぐは分りやすいが、笊を何故用いるか。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲府駅から汽車、小淵沢駅下車、改札口を出ようとすると、これは早や、かねて打合せてあつた事ではあるが信州松代在から来た中村柊花君が宿屋の寝衣を着て其処に立つてゐた。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和三年三月薄田淳介「こもり唄」より（明治四十一年）冬の鳥雪の降る日に柊のあかい木の實がたべたさに、柊の葉ではじかれて、ひよんな顏する冬の鳥、泣くにや泣かれず、笑ふにも、ええなんとせう、冬の鳥。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "柊の匂、苔の匂、垣根の下に實が割れた朽葉色の萎れた雜草の匂がする。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "柊冬青シモオヌよ、柊冬青に日が照つて、四月は遊にやつて來た。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつと灌木の高さしか無い柊よ、僞善の尻を刺す鑿、愛着の背を刻む鏨、鞭の柄、手燭の取手。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼を赤くした柊よ、おまへの爪の下に迸る血でもつて兄弟の契を結ばせる藥が出來さうだ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつと灌木の高さしか無い柊よ、小さい※手、わたしの悲しい心の悦。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "門のわきには大きな柊の木が、青い空にそヽりたつてゐた。",
              "citation": {
                "source": "桜さく島",
                "author": "見知らぬ世界",
                "note": "青空文庫"
              }
            },
            {
              "text": "忍冬、柊、木犀、そんなひつそりとした樹木が白い径に並んでゐて、その径を歩いてゐるとき、野薔薇の花蔭から幻の少女はこちらを覗いてゐた。",
              "citation": {
                "source": "画集",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年この同じ道を歩いたとき、花を密集させていた椿や柊はもうなくなって家が建っている。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "柊の葉のやうに薄つ片で、そして又柊の葉のやうに触つた人を刺さないでは置かない雑誌だが、市へ出す数も極少いので知らぬ人が多いやうだ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つは藍、紫の実を垂らしたひいらぎなんてんの葉と茎とである。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると天皇は、またすぐにひき続いて、命に、東の方の十二か国の悪い神々や、おおせに従わない悪者どもを説き従えてまいれとおおせになって、ひいらぎの矛をお授けになり、御※友耳建日子という者をおつけ添えになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひいらぎバーベリ等の極寒地方に生ずる灌木は、いやがうえに密生して、荊棘路をふさいでは、うさぎの足もいれまじく、腐草山をなしては、しかのすねも没すべく思われた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
