    "definitions": [
      {
        "index": 1,
        "gloss": "red imported fire ant (Solenopsis invicta)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
