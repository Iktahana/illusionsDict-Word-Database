        "examples": {
          "standard": [
            {
              "text": "長時間のデスクワークで疲れないよう、肘当て付きの椅子を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この車椅子には、利用者の快適性を高めるための調節可能な肘当てが装備されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このアームレスト、肘当てとしても使えるんだね。」「そうだよ。ちょっとした休憩に便利だね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "フィールデンの座っていた椅子の肘当てに、腰を下ろした。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
