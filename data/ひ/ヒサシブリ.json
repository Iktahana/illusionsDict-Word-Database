    "definitions": [
      {
        "index": 1,
        "gloss": "a long time (since the last time)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "熊本へ出張して一と晩久しぶりで旅人の気分で歩いたが、熊本といふ所はいい所です　火山地方特有の落付がありますとも書いてゐた。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と山田君は久しぶりに私の寓居を訪れて、頗る緊張しておっしゃるのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、私は久しぶりで先生のお宅へお伺いして、大隅君の縁談を報告し、ついては一つ先生に媒妁の労をとっていただきたいという事を頗る無遠慮な口調でお願いした。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪入の夢や小豆の煮えるうち　藪入で休暇をもらった小僧が、田舎の実家へ帰り、久しぶりで両親に逢ったのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局まあ、損も得も無く、一長一短といふやうなところか、久しぶりで思ふぞんぶん歌つたり踊つたりしただけが得、といふ事になるかな？",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "横浜の波止場で、家族と友人の出迎えを受け、久しぶりで逢いたい顔に逢ったが、ただ一つ逢えない顔があった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者はそのとき偶然老妓が以前、和歌の指導の礼に作者に拵えてくれた中庭の池の噴水を眺める縁側で食後の涼を納れていたので、そこで取次ぎから詠草を受取って、池の水音を聴きながら、非常な好奇心をもって久しぶりの老妓の詠草を調べてみた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕等もその好意が嬉しく、久しぶりで逢ひたいと思つたけれども、何分多勢のことであり、且つ無理な旅行で疲れ切つてゐた爲に、折角の機會を失して、そのまま東京へ歸つて來た。",
              "citation": {
                "source": "追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「内地の札を見るんは久しぶりだぞ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツイ近ごろのことです、私は校友会の席で、久しぶりで鷹見や上田に会いました。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々なことを考へて久しぶりで自己の存在を自覺したやうな氣がする。",
              "citation": {
                "source": "都の友へ、Ｂ生より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "處が自分の二十の時であつた、久しぶりで故郷の村落に歸つた。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は久しぶりで畫板と鉛筆を提げて家を出た。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが自分の二十の時であった、久しぶりで故郷の村落に帰った。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は久しぶりで画板と鉛筆を提げて家を出た。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "……先祖代々の墓詣は昨日済ますし、久しぶりで見たかった公園もその帰りに廻る。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "機会もなくつて、それから久しぶりの旅に、はじめてバスケツトに納めたのである。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むすこはエーベルフェルドの電気工場に勤めているそうで、それがワイナハトには久しぶりで帰るというので、この間じゅうから妹娘が贈物する襟飾を編んでいました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "別にどういう本を買うあてがあるわけではないが、ただ何かしら久しぶりで仲のいい友だちを尋ねて行く時のような漠然とした期待をいだいて正面の扉を押しあける。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気のために一年以上全くコーヒーを口にしないでいて、そうしてある秋の日の午後久しぶりで銀座へ行ってそのただ一杯を味わった。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして久しぶりに下駄をはいて四五町も歩くと、足一面が妙にひきつれたようになって歩けなくなる。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは単に久しぶりに耳にした方言のよび起こした錯覚であったかもしれない。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜｜星野温泉へ帰って戸外へ出て空を仰いだら久しぶりで天頂に星がきらきら輝いているのが見えた。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼すこし過ぎにやっと書き終えて、ほっとしていたところへ、実に久しぶりの友人が、ひょっこり訪ねて来た。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜はずゐぶん久しぶりで、愉快な露天に寝るんだな。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜はずいぶん久しぶりで、愉快な露天に寝るんだな。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十八年三月の末お絹が親もとより二日ばかり暇をもろうて帰り来よとの手紙あり、珍しき事と叔父幸衛門も怪しみたれどともかくも帰って見るがよかろうと三里離れし在所の自宅へお絹は三角餅を土産に久しぶりにて帰りゆきぬ。",
              "citation": {
                "source": "置土産",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊吉は柳の陰に腰掛けて久しぶりにその影を昔の流れに映した。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日もちょうどそのころのことを久しぶりで思い出しました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶりで戸外に出た父は、むだ話の材料をしこたま持って帰っているに違いない。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
