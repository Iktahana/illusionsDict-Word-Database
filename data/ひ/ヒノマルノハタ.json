    "definitions": [
      {
        "index": 1,
        "gloss": "flag with a red circle on a white background",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
