[
  {
    "uuid": "38a86595-6886-5693-ab80-264f1ee5faa1",
    "entry": "人寄せ",
    "reading": {
      "primary": "ひとよせ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
