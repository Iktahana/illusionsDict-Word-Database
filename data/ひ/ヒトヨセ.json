    "definitions": [
      {
        "index": 1,
        "gloss": "attraction (of people)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "店先きに備え付けて人寄せの広告などに使ったら妙だろう。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "編輯後記（大正十五年四月號）『青空』記事梶井基次郎　忽那が三人寄せ書きの後記を書かうと云つて、よしとは云つたもののこれと云つて書く程のことも見付からない。",
              "citation": {
                "source": "編輯後記（大正十五年四月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ宵のうちは帳場の蓄音機が人寄せの佐渡おけさを繰り返していると、ぽつぽつ付近の丘の上から別荘の人たちが見物に出かけて来る。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "キ……貴様は誰にことわって俺の家へ這入った……こんな人寄せをした……」　爺さんは白い眼を一パイに見開いた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "アトフキといふのは、この津軽地方に於いて、祝言か何か家に人寄せがあつた場合、お客が皆かへつた後で、身内の少数の者だけが、その残肴を集めてささやかにひらく慰労の宴の事であつて、或いは「後引き」の訛かも知れない。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ははあ、和尚さん、娑婆気だな、人寄せに、黒枠で……と身を投げた人だから、薄彩色水絵具の立看板。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲板での活動写真の催しも、いたずらに人寄せの技師が不馴れで、ただ急造の白幕に白い円ばかりを出して、そのままコチコチコチコチで中止になってしまった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それもだが、君が校正を済まさないと、僕は鉄雄さんに申訳がないがね、昼間中は勉強してくれたまえよ、上ったらすぐ旅館に鎮座さして、誰一人寄せつけないことにするからね。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "醤油のエッセンスにて火を灯し、草と砂糖を調じて鉱山用のドンドロを合せたなどは、ほんの人寄せの前芸に過ぎない。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ために勢が挫けたそうで、また胡坐で、「これでも人寄せの看板になるんですから、出迎やなんか、その支度もあったんだろうが、……そのくらいなら、先生を誘っちゃあ来ないんですよ。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "電灯や瓦斯灯の使用も、官省、銀行、会社、工場、商店、その他の人寄せ場に限られて、一般の住宅ではまだランプをとぼしていた時代である。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつらの楽隊を人寄せに利用するのだ。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "人寄せの呪文であろう。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "盆踊の人寄せの太鼓の音を聞いて、キツと成り。",
              "citation": {
                "source": "硯友社と文士劇",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "『アリヤあれ踊の、人寄せなるか。",
              "citation": {
                "source": "硯友社と文士劇",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "人寄せの口上さえうまければ相応に売れるものだそうで、毎晩夕方から例の塗柄の馬乗提灯を点けて出かけて、十時ごろには少なくとも五六十銭、多い時には一円近くも握って帰ってくる。",
              "citation": {
                "source": "世間師",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっし等が人寄せをやっている台湾館の中には六人の台湾娘が居て、お茶の給仕をしておりました。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "人寄せには決して出ん人だが……。",
              "citation": {
                "source": "かへらじと",
                "author": "日本移動演劇連盟のために",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体日本人は、景色景色って景色を人寄せに使うつもりなら、木なんかあまり切らないがいいし、それとも正直に告白するつもりなら、どこの人間にでっかしても、年中桜が咲いて、何処からでも不二山が見えて、いつでも陽気のいいような、見え透いた虚言はつかないがいい。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "陰惨な奇蹟劇の気分の陳い纏はりから、朗らかで闊達な新浄瑠璃や芝居に移つて行つたのが、元禄の「人寄せ芸」の特徴であつた。",
              "citation": {
                "source": "餓鬼阿弥蘇生譚",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それですから総ての人寄せの中で、私に云はせれば一番競馬クラブと云ふものは横暴でせうね、矢張社団法人と云ふのを鼻に掛けて威張つて居るのでせう。",
              "citation": {
                "source": "競馬興行と競馬狂の話",
                "author": "初代　桂小南",
                "note": "青空文庫"
              }
            },
            {
              "text": "人寄せの符号に相違ねえ。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲間へ知らせる人寄せ符号だ。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「御嶽冠者の使う術はいわゆる南蛮伴天連の秘法、到底日本の忍術家なんど、十人百人寄せたとて断じて足もとにも寄りつけますまい！",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　声に応じて左右から、ムラムラと数人寄せて来た。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉凶いずれの場合でも、人寄せのときには、不知火銭にまじえて、ただ一つ、自分が御礼と書いた包みを投げ、それを拾った者はたとえ足軽でも、樽ひろいでも、その座に招じて自分のつぎにすわらせる例。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り口数からいうと、父と私を二人寄せてもなかなか敵うどころではなかった。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれの仕事にはにぎやかな人寄せの音楽がなければならなかった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「近頃何んかかううるさい泥棒が無かつたか、妙な人寄せは無かつたか、謀反の匂ひでもなかつたか――そんな事を念入に調べて貰つたんだ」「？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "母娘巡禮",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで人間の顔や形を何百人寄せ集めたところがエクレシヤにはなりません。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
