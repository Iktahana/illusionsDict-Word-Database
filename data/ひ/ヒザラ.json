    "definitions": [
      {
        "index": 1,
        "gloss": "bowl (of a pipe)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
