[
  {
    "uuid": "86fb187e-56b7-575a-b1c6-ba2f972a080b",
    "entry": "剽悍",
    "reading": {
      "primary": "ひょうかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
