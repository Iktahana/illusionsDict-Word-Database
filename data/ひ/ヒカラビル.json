    "definitions": [
      {
        "index": 1,
        "gloss": "to dry up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "真夏のベランダに置き忘れた洗濯物が、数時間でカサカサに干からびてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長い間雨が降らなかったせいで、庭の池は底の泥まで干からびてひび割れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "冷蔵庫の奥に眠っていたレモンが、いつの間にか干からびて小さくなっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "よく探して見たら直ぐ出て来るだろうと初めの中は思って、それほど心配はしなかったけれども、いくらそこいらを探しても、どうしても出て来ようとはしないので、だんだん心配になって来て、しまいには喉が干からびるほど心配になってしまいました。",
              "citation": {
                "source": "僕の帽子のお話",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この塩が干からびるように干からびてしまえ。",
              "citation": {
                "source": "春山秋山",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところどころ肉をむきだしにして転がるレモンは痛々しく、これを冷蔵庫に放置したなら、干からびるうち凄惨の気を帯びたりもして、正視に耐えない。",
              "citation": {
                "source": "鉄道模型の夜",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "残しておくと、日に当たって腐るか干からびるか分からないし、腹は減っていなくとも全部食べてしまったほうがいいな。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "水玉という草に水をうって、涼しくかけたものだが、みんな一時のもので、赤くひからびるまではかけていない。",
              "citation": {
                "source": "大門通り界隈一束",
                "author": "続旧聞日本橋・その一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
