          "literary": [
            {
              "text": "否か応か、孰らかの返事をして下さればいゝのです。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "否か応か、返事せい」といった。",
              "citation": {
                "source": "三浦右衛門の最後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "太刀取りは、「否か応か」と聞いた。",
              "citation": {
                "source": "三浦右衛門の最後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "否か応か御返答いかがでおじゃる」「なるほど、事の仔細も御所望の筋もしかと分り申した。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだ大将、否か応か！",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "否か応か、一こと返事してくださればいいんです。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "否か応かただ一言、どうぞ頼みます、云うてくだされ！",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二年間東京の英語学校で正則に仕上げてきた良吉にしばしば「田舎で語学を勉強したって骨折損だ、それより早く正教員の試験を受けた方がいいぜ」と忠告されて、父や兄からもそれを最も賢い方法として説勧められたが、彼れは馬の耳に風で聞流して、否か応かの返事をさえしなかった。",
              "citation": {
                "source": "入江のほとり",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "否か応かは、よう御存じ、申し訳は致しませねど。",
              "citation": {
                "source": "したゆく水",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "否か応か」　と、いった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "否か応か、それだけ聞こう。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこし酔うと、「妻になれ、否か応か」　※覧は、本性をあらわして、徐氏の胸へ、剣を擬して強迫した。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
