  {
    "uuid": "ba5970dc-d70e-5ea1-a929-7dee386597e9",
    "entry": "皹",
    "reading": {
      "primary": "ひび",
      "alternatives": [
        "あかぎれ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "chaps (in the skin)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "雲消えて皹も亦拭ひ去らる、山色何の瑠璃ぞ、只だ赭丹赭黄なる熔岩の、奇醜大塊を、至つて無器用に束ねて嶄立せるのみ、その肩を怒らし胸を張れるを見て、淑美なる女性的崇高を知らず。",
              "citation": {
                "source": "霧の不二、月の不二",
                "author": "――明治三十六年八月七日御殿場口にて観察――",
                "note": "青空文庫"
              }
            },
            {
              "text": "リー・シー・ツワンの綺麗に埃のぬぐわれたエナメルの靴に皹が入った。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の膩を吹き荒す風で手足の皹が痛いと云つて、夕方になると、子供がしくしくぢくね出す。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "皹なんどにや、よく利いた。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兩手共荒れて皹の切たやうになツて、そしてカサ／＼してゐた。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄ばみ黒ずんで居た人の顏は、紅色を帶びて來て、漸く鮮やかに美しくなり、悴け萎びて、硬ばつたり龜裂したりして居た人の皮膚は、※らぎ潤ひて生氣を増し、瑞々しく若くなつて、皹凍傷なども治り、筋肉は緊張し、血量は増加したるが如く見える。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "奧さんは乾からびて皹の入つた唇を固く結んで、博士の顏をじつと見てゐる。",
              "citation": {
                "source": "半日",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "奧さんの唇はいつも乾からびて皹が入つてゐる。",
              "citation": {
                "source": "半日",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれがおはまに負けたら何でも買ってやるけれど、お前がおれに負けたらどうする」「わたしも負けたら何かきっとあげるから、省さんの方からきめておいてください」「そうさなア、おれが負けたら、皹の膏薬をおまえにやろう」「あらア人をばかにして、……そんならわたしが負けたら一文膏薬を省さんにあげべい。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "皹がぴり／＼と痛んだ。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "足袋も穿かぬ足の甲が鮫の皮のやうにばり／＼と皹だらけに成つて居る。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "指の太い、皹だらけの、赤黒い不恰好な手が、忙がしさうに、細い眞鍮の火箸を動す。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "發病した最初の日に見た、老いた母の、洗濯に濡れた、赤い、皹割れた手が何かにつけて目先きにちらついてならなかつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これほど親しいお牧では有りましたが、しかし彼女の皹の切れた指の皮の裂けたやうな手を食事の時に見るほど、可厭はしいものも有りませんでした。",
              "citation": {
                "source": "幼き日",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "序に、太助が小屋から里芋の子を母屋の方へ運んで行きますと、お牧がそれに蕎麥粉を混ぜて、爐の大鍋で煮て、あの皹の切れた手で芋燒餅といふものを造へて呉れたことも書いて置きませう。",
              "citation": {
                "source": "幼き日",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、上眼を使って、弟子の僧の足に皹のきれているのを眺めながら、腹を立てたような声で、――痛うはないて。",
              "citation": {
                "source": "鼻",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は皹だらけな大きい手で、一つ一つ撫で廻して見た。",
              "citation": {
                "source": "母親",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――まア、先生、政治家、……まだ、ええやないか、もうちよつとつきあひなはれ」　狐つかひは、皹だらけの両手をあげて、彼を押しとめた。",
              "citation": {
                "source": "大凶の籤",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "観念して云うがままに成りおれぇ」と、武道者の声は太く濁って、皹入りの竹法螺を吹くに似通った。",
              "citation": {
                "source": "怪異黒姫おろし",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "土質の酸に沁み込まれた皹やひびが眼についた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "男「へえー芝居にありさうですな、河竹新七さんでも書きさうな狂言だ、亀裂皹を隠さう為めに亭主は熊の膏薬売り、イヤもう何処で何う云ふ方にお目にかゝるか知れません。",
              "citation": {
                "source": "鰍沢雪の夜噺（小室山の御封、玉子酒、熊の膏薬）",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲｜舂けば、皹る我が手を。",
              "citation": {
                "source": "古代生活に見えた恋愛",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、苦痛とは何か、われわれの精神を虐げ、われわれの観念に皹を入れるこの苦痛とはそもそも何か。",
              "citation": {
                "source": "井の中の正月の感想",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○稲舂けば皹る我が手を今宵もか殿の稚子が取りて嘆かむ　〔巻十四・三四五九〕　東歌「皹る」は、皹のきれることで、アカガリ、アカギレともいう。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一首の意は、稲を舂いてこんなに皹の切れた私の手をば、今夜も殿の若君が取られて、可哀そうだとおっしゃることでしょう、御一しょになる時にお恥しい心持もするという余情がこもっている。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "霜と風とで、人間の手足も、土の皮膚も、悉く皹赤ぎれになる。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それが解らぬのじゃ」　この時、庭の方から、轍でも軋るような、キリキリという音が、深夜の静寂に皹でも入れるかのように聞こえて来た。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この侘しく灰色なる空の下に私たちの心はまづしく語り　孤獨になやみて重たくよりそふ少女よあの遠い空の雷鳴をあなたは聽くかかしこの空にひるがへる浪浪の高いひびきをあなたは聽くか。",
              "citation": {
                "source": "眺望する",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の新らしい詩の表現は、丁度、愛する妻と共に日暮れの街を歩きながら、楽しい買物の話をするやうな、平易な親しさの中に、力強い情熱のひびきをこもらせたものであつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの山の裾へひろがるところの、違い棚のように段を作っている水田からは、稲の青葉を振り分けて、田から田へと落ちる水が、折からの旱天にも滅げず、満々たる豊かさをひびかせて、富士の裾野のいかにも水々しい若さを鮮やかに印象している。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
