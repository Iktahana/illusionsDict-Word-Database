    "definitions": [
      {
        "index": 1,
        "gloss": "always hitting the bull's-eye",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "例えば今月中少なくも各一回の雨天と微震あるべしというごとき予報は何人も百発百中の成効を期して宣言するを得べし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまは百発百中である。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢継早の名人で、機関銃のように数百本の矢をまたたく間にひゅうひゅうと敵陣に射込み、しかも百発百中、というと講談のようになってしまうが、しかし源氏には、不思議なくらい弓馬の天才が続々とあらわれた事だけは本当である。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大の男が、あんな小さい弓を、ふしくれ立った手でひねくりまわし、百発百中の腕前になってみたところで、どろぼうに襲われて射ようとしても、どろぼうが笑い出しますし、さかなを引く猫にあてても描はかゆいとも思やしません。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "百歩を隔てて柳葉を射るに百発百中するという達人だそうである。",
              "citation": {
                "source": "名人伝",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥儀伝授が始まってから十日の後、試みに紀昌が百歩を隔てて柳葉を射るに、既に百発百中である。",
              "citation": {
                "source": "名人伝",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで百発百中だから驚くさ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "百発百中と云ってもいい位おそろしい効果を以て、ジフテリヤの病源体をヤッツケてしまうらしい。",
              "citation": {
                "source": "探偵小説の正体",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこれが百発百中｜※粉細工のように人間の鼻を改造し得る迄に発達致しましたならば、それこそ副産物どころでない、仁術中の仁術と推賞しても差し支えないであろうと考えられます。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "三会村の百姓金作は針を遠くに懸けて置いて、百発百中と云う程で、人呼んで懸針金作と称した位である。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "百発百中の推理というのは、時折ホームズの心を支配する詩的で瞑想的な気分に対する反動ではなかろうか。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十年も前の話、戸川残花がヒヨツコリやつて来て曰く、数寄屋橋外に頗る上手な人相見がある、百発百中で数寄屋橋教会の会員は皆信じてゐるんで坪内君と一緒に実験に出掛ける筈になつてるが、君も一緒に行かないかといふ話で、約束の日を打合はして当日三人して出掛けた。",
              "citation": {
                "source": "人相見",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、百発百中だ」「ほう、おどろきましたな。",
              "citation": {
                "source": "のろのろ砲弾の驚異",
                "author": "――金博士シリーズ・１――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（百発百中に予言をする、巫女の千賀子が茅野雄に向かって、「山岳へおいでなさりませ、何か得られるでござりましょう」と、こう予言をしたからには、間違いなく茅野雄はその何かを、手に入れるものとみなさなければならない。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は来る道々｜験して見たが、百発百中はずれた事がない。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "百発百中と称されていた。",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "准南子ニ曰ク「養由基楊葉ヲ射ル、百発百中、楚ノ恭王猟シテ白猿ヲ見ル、樹ヲ遶ッテ箭ヲ避ク、王、由基ニ命ジ之ヲ射シム、由基始メ弓ヲ調ベ矢ヲ矯ム、猿｜乃チ樹ヲ抱イテ号ブ」　それ程までに秀でた漢土弓道の大家、その養由基の射法の極意を、完全に記した『養由基』一巻、手写した人は大楠公であった。",
              "citation": {
                "source": "弓道中祖伝",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、……オイコラオイコラで引張って来るんだがね、それがもうほとんど百発百中だった」「……フム、そうかな。",
              "citation": {
                "source": "子をつれて",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "左衛門はその頃の人相見としては、江戸で一番といわれている人で、百発百中のほまれがありました。",
              "citation": {
                "source": "真間の手古奈",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "百発百中で、見てゐる多くの仏人たちはその見事さに手を拍つて悦んだ。",
              "citation": {
                "source": "風変りな決闘",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャックった道糸が再び海底へ沈んでいく途中、まだ海面に出ている部分の糸が僅かに異状を示したとき合わせれば、百発百中である。",
              "citation": {
                "source": "鯛釣り素人咄",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてや、良寛の真贋を百発百中、一刀両断的に鑑定する具現者はどれだけあろうか。",
              "citation": {
                "source": "愛陶語録",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず親鳥が一匹の魚を捕え、半殺しにして雛の頭より一二尺隔たったところへ放し、これを捕えさせ、幾度も同じことをやらせて一二尺のところならば百発百中必ず餌を捕えることができるというまでに雛の技術が熟練すると、次にはなお一尺も隔たったやや遠いところへ魚をおいてこれを捕えさせる。",
              "citation": {
                "source": "生物学より見たる教育",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "へえ、百発百中で、それこそ今日まで、一度だって、外れたことはございません」「おおそうか、それは偉いな」　こういうと周作は立ち上がった。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夷船は大的なれば、大砲の百発百中｜固より疑いなし〔大いに然り〕。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "にんじんの告白によれば、この方法も百発百中というわけにはいかぬ。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "百発百中ではないのだから、たまに巧く雨が降っても、それは丁度雨が降る時であったのだといわれれば、反駁のしようがない。",
              "citation": {
                "source": "雨を降らす話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、もちろん百発百中というのではない、統計学で計算した偶然の暗合よりも適中率が多いという意味と思われる。",
              "citation": {
                "source": "心霊現象と科学",
                "author": "――『心の領域』について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もし本当ならば」の意味を、少し詳しくいうと、それはその予感の的中が、百発百中であるということを意味している。",
              "citation": {
                "source": "吉右衛門と神鳴",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "予感の的中というようなものは、それが百発百中であるか、百発八十中くらいであるかによって、その意味が大いに異なってくる。",
              "citation": {
                "source": "吉右衛門と神鳴",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
