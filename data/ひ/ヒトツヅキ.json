    "definitions": [
      {
        "index": 1,
        "gloss": "chain (of)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "窓の外の暗黒と一続きのままシンシンと夜半に近づいて行った。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、私が九州を出て来て以来の出来事は何もかも一続きの悪夢の連続ではないか知らん。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "頤のすぐ下にはいくつかの深い掻き傷があって、明らかに指の痕である鉛色の斑点が一続きに並んでいた。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに、一続きの文章を頁単位で見せていく、より適切な表示の仕組みに基づいている。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻の下から頤まで一続きにノッペラボーになっているのです。",
              "citation": {
                "source": "オシャベリ姫",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間が実践的なるものとして把握されるとは、一面に於て単なる行動の主体としてであるが、併し、それがやがて一続きに、政治的行動の主体として、その両面の連続に於て把握される、ということである。",
              "citation": {
                "source": "再び「科学の歴史的社会的制約」に就いて",
                "author": "――岡邦雄氏に答える――",
                "note": "青空文庫"
              }
            },
            {
              "text": "印象からは一続きには行かない。",
              "citation": {
                "source": "所謂批評の「科学性」についての考察",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番最初の第一行が……ブウウ――ンンン……ンンンン……という片仮名の行列から初まっているようであるが、最終の一行が、やはり……ブウウ――ンンン……ンンンン……という同じ片仮名の行列で終っているところを見ると、全部一続きの小説みたような物ではないかと思われる。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その顔は、電燈の逆光線を受けて、髪毛や着物と一続きの影絵になっていて、恰も大きな紫色の花が、屹と空を仰いでいるように見える。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「東作が晦日の夜に見た満月です」　その翌日は二百十日前の曇天で、外海も内海も一続きのトロ凪ぎであった。",
              "citation": {
                "source": "Ｓ岬西洋婦人絞殺事件",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「阿須波山に住みける頃」の歌の一続きと見るべき「汐ならで」の歌の詞書きの「世を遁れて後は、それとたのむべき生業もなく、貧しうものしければ、人も養はず、何わざも自らうちしつゝ、辛きめのみ見つゝ過ぎにけるを……。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大石うき作となつてゐるのは、前歌の方であるが、一続きになつてゐるものとすると、全部さう言ふ事にならう。",
              "citation": {
                "source": "地唄",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其と一続きに、きつと浮んで来るのは、浄瑠璃から出た「夏祭浪花鑑」といふ芝居である。",
              "citation": {
                "source": "辻の立ち咄",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう山もここまで来ると、余程開けて、阪町までは、一続きと言う気がする。",
              "citation": {
                "source": "山の湯雑記",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此一続きの組唄の謡はれてゐる間に、其気分表現を主とする踊りが、はやり出したのである。",
              "citation": {
                "source": "組踊り以前",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも時には、秋祭りの意義の冬祭りと、春祭りの条件なる冬祭りとが、一続きの儀礼らしくも見える。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝗の害と流行病とを一続きに見てゐた平安時代の農民信仰が「花を鎮む」と書く鎮花祭によく似てゐる。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、祭りの時間が長びき、又一続きの儀式の部分に、大切な意義を考へる様になると、段々日を別けてする様になるのは、当りまへであつた。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一続きの行事である。",
              "citation": {
                "source": "たなばたと盆祭りと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "又更に我々は、藪入りと、奉公人出替りとにも、一続きの聯絡を見る事が出来るのである。",
              "citation": {
                "source": "たなばたと盆祭りと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この条は、この本のあちこちに散らばったあぢすき神の事蹟と、一続きの呪詞的叙事詩であったようだ。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "事は、一続きの事実であった。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、農村の生活に於ては、稲虫――其他、田の凶害――と怨念、或は刑罰とは、常に一続きに、聯想せられたのである。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（中臣寿詞）とある文によると、太祝詞とまちとは一続きの現象なのである。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局「承徳三年書写古謡集」に並記せられた介比乃神楽（気比神楽）と一続きのものであるまいか。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "畢竟霊魂の遊離を防いで、斎ひ鎮めるのだから、怒り・嫉みを静平にし、病気を癒し鬱悒を霽らす――霊魂を鎮めることゝ、呪ひを行ふことゝが、一続きの呪術だつたのである。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "野山の精霊が米を悦ぶと言ふ信仰と、現にとり斂められずに在る行路死人とを一続きに考へると、其死因が専ら飢渇の為であり、此原因に迫つて行くのが、其魂魄を和める最上の手段とする事になる訣である。",
              "citation": {
                "source": "餓鬼阿弥蘇生譚",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此等の話が、結婚と悪身解脱を一続きにしてゐるのも「蛇子型」のあつたことを見せてゐる。",
              "citation": {
                "source": "小栗外伝（餓鬼阿弥蘇生譚の二）",
                "author": "魂と姿との関係",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろはひとつづきの小説を数人の作者が書き続けて行くのもあるようである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うわなりうち、めがたきうち、かたきうちと三つ並べると、ずっとひとつづきである。",
              "citation": {
                "source": "嫉みの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
