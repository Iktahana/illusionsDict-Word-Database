        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」もひとりがいいました。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子も可哀そうだし、近所も迷惑だ」　長屋のひとりが堪忍袋の緒を切ってこう云い出すと、長屋一同もすぐに同意した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、村の若者のひとりが、私を無視して、ご自分で演説をはじめ、甚だ座が白け、對馬さんは、その若者に演説をやめさせようとして大苦心の態でした。",
              "citation": {
                "source": "黒石の人たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、誰かひとりが考える。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿蘭陀語ではパッスルと申し、イタリヤ語ではコンパスと申すもののことである、と通事のひとりが教えた。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女のうちでも、私という女ひとりが、だめなのかも知れませんけれども、つくづく私は、自分を駄目だと思います。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "トランプの札をいちまい伏せて、さあ、これはなんだ、とひとりが言ふ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、もひとりが、くやしそうに、あたまをまげて言いました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこそこそこそこそ、逃げるようにおもてに出てひとりが三十三本三分三厘強ずつという見当で、一生けん命いい木をさがしましたが、大体もう前々からさがす位さがしてしまっていたのですから、いくらそこらをみんながひょいひょいかけまわっても、夕方までにたった九本しか見つかりませんでした。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、もひとりが、くやしさうに、あたまをまげて言ひました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの家の女中のひとりが午後十時ごろに外から帰って来る途中、横町の暗いところで例の痴漢に襲われかかったが、折よく巡査が巡回して来たので救われた。",
              "citation": {
                "source": "郊外生活の一年",
                "author": "大久保にて",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「その首はどんな顔をしていた」と、友達のひとりが訊いた。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒いおじさんだって、女ひとりが斯うして駆け込んで来た以上、いざ縄打って代官所へなんて、野暮なことを云やあしないでしょう。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "新兵衛夫婦は奥で夜食の膳に向つてゐて店には今年十八歳の善吉ひとりが坐つてゐると、若い侍風の男ふたりが這入つて来て、ひとりは銀一｜歩を銭に換へてくれと云ふので、善吉は、その云ふがまゝに両替へをして遣ると、男は他のひとりを見かへつて、笑ひながら云つた。",
              "citation": {
                "source": "赤膏薬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、ひとりが言いました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、もうひとりが答えました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『ええ』と、ひとりが言いました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、見ろよ」と、ひとりが言いました。",
              "citation": {
                "source": "すずの兵隊さん",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "とつぜん、小さな男の子のひとりが、すずの兵隊さんをつかんだかと思うと、いきなり、ストーブの中へ投げこみました。",
              "citation": {
                "source": "すずの兵隊さん",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "中のひとりが、ほかのものよりもじょうずにうたいました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "お日さまののぼらないうちに、王子かあなたか、どちらかひとりが死ななければならないのよ。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうすると、三百年たったら、あたしたちも、神さまのお国へ浮んでいけますのね」「でも、もっと早く行けるかもしれませんよ」と、空気の娘のひとりが、ささやきました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりの人が、道で出会うと、きまって、そのひとりが、「ナイチン――」と言いました。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしはトルコの神さまを見ました」と、ひとりが言いました。",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりが、なにか言いだすと、そのたびに、だんだん大げさになっていきました。",
              "citation": {
                "source": "ブタ飼い",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ、あそこへ行って、あの楽器のおねだんをきいてきてちょうだい」　こういうわけで、侍女のひとりが、その中へはいっていかなければならないことになりました。",
              "citation": {
                "source": "ブタ飼い",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "このエンドウマメには、家族の中のひとりが、花嫁と花婿の名前を歯でかみつけておきました。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんともおっしゃっていただけませんが」と、織っていたひとりが言いました。",
              "citation": {
                "source": "はだかの王さま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間をだまして、「尊敬され」ても、誰かひとりが知っている、そうして、人間たちも、やがて、そのひとりから教えられて、だまされた事に気づいた時、その時の人間たちの怒り、復讐は、いったい、まあ、どんなでしょうか。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
