        "examples": {
          "standard": [
            {
              "text": "ヒラコテリウムは、馬の祖先にあたる小型の動物として知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "化石から、ヒラコテリウムは森林に生息し、木の葉を食べていたと考えられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ヒラコテリウムの発見は、馬の進化の過程を解明する重要な手がかりとなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "第二図ヒラコテリウムは、欧州と北米に、遺骨の化石を留むる下エオシーン期の馬で、前足に四、後足に三の趾ある事、大いに現存馬属諸種の足の端に、趾一つのみあると差う。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "第２図　馬の先祖ヒラコテリウム　現存する馬と同属ながら、過去世に栄えた現世化石となりおわったもの数あり。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
