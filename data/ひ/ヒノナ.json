    "definitions": [
      {
        "index": 1,
        "gloss": "hinona (Japanese variety of long-rooted pickling turnip, Brassica rapa var. akana)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "千葉へ一晩かえり、明日野菜もって来てくれる由。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私共は毎日野菜で暮して居る。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年亡くなつた水野葉舟君からもらつた田口菜、キサラギナ、日野菜、セリフオンも立派に出来た。",
              "citation": {
                "source": "開墾",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日野菜が食べられるぞ」　けれど、男は土地を探すことをしなかった。",
              "citation": {
                "source": "料理の第一歩",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も、庭の真中の、陽当の一番良ささうな所を彼らしくだだ広く掘返して、葱一株、玉葱一株、花の咲いた日野菜一本、小さな蜜柑、梅、枇杷、団栗の木が一本づつ植つてゐる。",
              "citation": {
                "source": "打出の小槌",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばこの日は一日野菜畠へ入ってはならぬ。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜なくやと試みたれど、さらに声の聞えねば、俄かに露の身に寒く、鳴くべき勢ひのなくなりしかと憐れみ合ひし、そのとし暮れて兄は空しき数に入りつ。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴嬢は何をおつしやいます今まで彼れ程お待遊ばしたのに又そんなことをヱお心持がおわるひのならお薬をめしあがれ阿母さまですか阿母さまはうしろに。",
              "citation": {
                "source": "闇桜",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはまちがひのないことである。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉の根方には藪柑子、匂ひのないのぎ蘭、すぎごけ、……數々の矮小な自然が生えてゐた。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の時御新造は日が短い時分の事、縁の端近へ出て、御前が誕生日には着換へて出ようと云ふ、紋服を、又然うでもない、しつけの絲一筋も間違ひのないやうに、箪笥から出して、目を通して、更めて疊み直して居る處。",
              "citation": {
                "source": "二た面",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――此のくらゐの間違ひのない事を、人に教へた事はないと思つた。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんといふいたましい風物だらうどこにもくびのながい花が咲いてそれがゆらゆらと動いてゐるのだ考へることもない　かうして暮れ方がちかづくのだらう戀や孤獨やの一生からはりあひのない心像も消えてしまつて　ほのかに幽靈のやうに見えるばかりだ。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戀や孤獨やの一生からはりあひのない心像も消えてしまつて　ほのかに幽靈のやうに見えるばかりだ。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人の死ぬや悲し　ある日の芥川龍之介が、救ひのない絶望に沈みながら、死の暗黒と生の無意義について私に語つた。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『セルパン』1931年５月号）-----------------------------------------------------------------　詩人の死ぬや悲し　ある日の芥川龍之介が、救ひのない絶望に沈みながら、死の暗黒と生の無意義について私に語つた。",
              "citation": {
                "source": "散文詩集『田舎の時計　他十二篇』",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "知り合ひのなかから相談相手として、三四人の男女も出て来たのであるが、成績は面白くなかつた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがその無心の振舞ひのなかに、もう、これだけの種が仕込まれてゐるのだ。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "間違ひのないやう、出来るだけ気をつけてお話申し上げるつもりではございますが、それでも万一、年代の記憶ちがひ或いはお人のお名前など失念いたして居るやうな事があるかも知れませぬが、それは私の人並はづれて頭の悪いところと軽くお笑ひになつて、どうか、お見のがし下さいまし。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴下、生効ひのない私、罰も当れ、死んでも構はん。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はた思ふ、晩夏の生あつきにほひのなかに、倦みしごと縺れ入るいと冷やき風の吐息を。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さはあれど、珠のいくつはなやましき夕暮のにほひのなかにゆらゆらと円みつつ、ほつと消えたる。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "海辺の墓われは見き、いつとは知らね、薄あかるにほひのなかに夢ならずわかれし一人、ものみなは涙のいろに消えぬとも。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "平家が勝たうが、源氏が勝たうが、北條が勝たうが、われ／＼にかゝり合ひのないことぢや。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しこれの談判が作者のゐない爲め、また他の理由で、手間取つては困ることになると思つて、別にあひま／＼に書いた雜誌向きの短篇も、既に東京へ郵送されてゐるが、ぐれ違ひのない爲め、なほ二三の小論文も書くつもりでゐる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "）世界ともなり得るし、又同じ一ひねりで、荒冷たる救ひのないものともなる。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことにこの峠で嬉しかつたのは、尾根から見下す四方の澤の、他にたぐひのないまでに深く且つ大きなことであつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "草鞋の話旅の話",
                "note": "青空文庫"
              }
            },
            {
              "text": "仍て愚生達も少年時代迄は、此地津輕公の、現に公園と成居る鷹場園の壕や、市内革秀寺池の蓮花の開くを見、且つ聞きに、早朝夜も碌に明ぬ内から出掛て往た者で、目下はどうかよく知ませぬが、愚生の幼時迄は、其を視聽する人達で、濠も池も一抔だつた事は、絶對間違ひのない事實で有ました。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "お釈迦様より間違ひのない事を云ふわ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしや餘儀なき理は存するとも、理りに思ひのなぐべくは吾とて物を思はぬものを、何というて帶を返すべきか、何というて歌を返すべきか。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
