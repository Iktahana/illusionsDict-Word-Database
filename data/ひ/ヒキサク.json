[
  {
    "uuid": "07cc60d6-28c3-5b46-b82b-5ce63f9a1ed2",
    "entry": "引き裂く",
    "reading": {
      "primary": "ひきさく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
