    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese bindweed (Calystegia japonica)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから昼顔の花もかすかにこれに反映するものである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは川面の漣波に、蘆荻のそよぎに、昼顔の花に、鳥のさえずりに、ボロ服とボロ靴にあるのではないか。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人通りが少いで、露にひろがりました浜昼顔の、ちらちらと咲いた上を、ぐいと曳出して、それから、がたがた。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "島野二三夫は林檎の唄がすんでから、文若を相手に、ケッセルの「昼顔」という小説の話をしていたが、途中で話を打ち切ると、君勇をつかまえて、「君、一緒に歌うたおうか」「へえ、歌いまひょ」「何うたおう。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　菅子はもうそこに、袖を軽く坐っていたが、露の汗の悩ましげに、朱鷺色縮緬の上〆の端を寛めた、辺は昼顔の盛りのようで、明い部屋に白々地な、衣ばかりが冷しい蔭。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さん、昼顔を読んだことが無いはずなのに、それでも勘で、わかるらしいのだ。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "月見草や昼顔が咲いているそうですね。",
              "citation": {
                "source": "提灯",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "売卜者算木をさめて、昼顔の香は蒸しにけり。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "綿の木と椰子との密林を行けば、地上に淡紅色の昼顔が点々として可憐だ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内に半里くらゐも行つたんでせうか、松原の松が飛び飛びになつて路の左側に砂山のある所がありますね月見草や昼顔が咲いてゐるさうですね、彼所へ行つたところで向ふの方に薄赤い火の光が見えるぢやありませんか。",
              "citation": {
                "source": "提燈",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一面の砂地に雑草が所まだらにおい茂りところどころ昼顔が咲いていた。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "くやしいので懸命に登りかけると、砂は足もとからくずれ、力草と頼む昼顔はもろくちぎれてすべりおちる。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "執着のない子供心には故郷の事は次第に消えて昼顔の咲く天文台もただ夢のような影をとどめるばかりであった。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ昔のままをとどめてなつかしいのは放課後の庭に遊んでいる子供らの勇ましさと、柵の根もとにかれがれに咲いた昼顔の花である。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "巣立の鶴の翼を傷めて、雲井の空から落ちざまに、さながら、昼顔の花に縋ったようなのは、――島田髭に結って、二つばかり年は長けたが、それだけになお女らしい影を籠め、色香を湛え、情を含んだ、……浴衣は、しかし帯さえその時のをそのままで、見紛う方なき、雲井桜の娘である。",
              "citation": {
                "source": "瓜の涙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小松原には、昼顔の花が一面に咲いて、渚の浪の千種の貝に飜るのが、彩色した胡蝶の群がる風情。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら俳諧師だといって、昼顔の露は吸えず、切ない息を吐いて、ぐったりした坊さんが、辛うじて……赤住まで来ると、村は山際にあるのですが、藁葺の小家が一つ。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は浅瀬の多い河に添つて、昼顔が咲いてゐる堤を遡つて行つた。",
              "citation": {
                "source": "川を遡りて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "草木は性質の差によって朝顔の花のように暁にその気の張るものもある、昼顔のように日中に張るものもある。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は又、日本趣味を多分に持っていて、色の殆どない様な朝顔、昼顔、芍薬、実につまらない断腸花、合歓、日々艸なぞを大層崇め奉って、その花や葉っぱを甞めて渋い顔をしたりする。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "おたよゆうべ厨の　　　水甕に小首かたむけ　　　聞きほれたおたよは背戸の　　　きりぎりす月の夜なれば　　　昼顔の蔓の葉に啼く　　　虫の音をおたよ十六　　　なんと聞くをとめの胸を　　　をどらせし同じ夢見た　　　そのあした逃げて失せたも　　　きりぎりす。",
              "citation": {
                "source": "別後",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後は散歩、三時間あまり、新町から椹野川土手へ、途中、Ｓ老人の店で一杯借りる、月草を折つて戻る、昼顔は見つからなかつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――午後、泳ぐ、昼顔一茎を摘んで戻る。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "好きな昼顔を活けて自から慰める。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのふ夕顔もよかつたが、けさの昼顔もわるくない、活けてしみ／″＼観賞する。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の古い石の上を白い蝶の飛びたわむれている午後の日ざし、――昼顔の伸び悪い垣の愁い。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "海は鳴り人間の子は歎けども瞬きもせぬ沙の昼顔　晶子中年の近代調を代表するものの一つで、この頃から晶子歌の世間性がなくなり、其の傾向は年を追ひて甚しくしまひには時代と詩人とは全くの他人となり終つたのである。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "沙の上に昼顔が咲いてゐるが何の表情も示さない。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕顔、朝顔、昼顔とは誰が呼び出した名か知らないが、それはさも涼しそうな朝を代表する顔である。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀧子は、昼顔の花の咲いている四つ目垣のところへ張板をよせかけ、袷の赤い裏地をはっていた。",
              "citation": {
                "source": "鏡の中の月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
