        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一人として王を恐れ且つ憎まぬ者はないやうになつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "講中でこそないが、私も富士崇拝者の一人として、黙礼をして、浅間本社へと足を運んだ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな議論が実用上どういう価値があるかは分りにくいが、ただ生物界の現象を説明するに力学を応用するようになった率先者の一人としてここに御紹介するその学者の名はダルシー・ウェントウォース・トムソンという。",
              "citation": {
                "source": "卵の形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正七年三菱研究所の創立に際してその所長となったが、その設立については末広君が主要な中心人物の一人として活動した事は明白な事実である。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう民衆批評家の一人として何か云う前に自分の芸術観を内省してみた。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、その男も、帰還者の一人として、はっきり記されてあった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人として、一言も発する者がなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が村会へ頸を出すのは、ほかの議員達は一人として喜ばなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡邏隊の一人として呼ばれた男だ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "××と雖も、××の前には人間一人としての価値しかなかった。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何に貧窮なものも、誰一人としてこの逮捕から逃げることは出来ない。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして国民の選良たる代議士でだれ一人として山火事に関する問題を口にする人はないようである。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを知りたいと望む多数の人の一人として私もそれから多分の示唆を受けうるであろうから。",
              "citation": {
                "source": "想片",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人として彼女からコップを奪はうとするものはなかつた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私なんかゞホイットマン研究者の代表的な一人として見られるという事などは、日本の思想界の軽佻さを裏書きしたものと云はなければなりません。",
              "citation": {
                "source": "●「或る女」巻頭のホイットマンの詩",
                "author": "\"Not till the sun excludes you, do I exclude you;",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその人々は努力や工夫することについては、あらゆる難儀を重ねているけれど目的の悟りというものの存在については誰一人として疑っていない。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰一人として表へ出るものはない。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "禅師もその一人として如何に稀有な奇抜な卓説を持ち帰られるかと人々は待ち構えていたものです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、人はどうだか私一人としてはなんだ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "といえども一人として応ずる者無し。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "座敷々々のお客人も一時に湧きましてな、一人として静となすっていらっしゃったお方はないので、手前どもにゃ僥倖と、怪我をなすった方もござりませんが。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、万綱はじめ、手下の誰彼幾十人、一人として影を見せず、あとは通魔の鳴を鎮めて、日金颪の凪ぎたるよう。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人として他樣の娘などに、こだはるものはなかつたのである。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己の功名の犠牲として、罪のない藤戸の漁民を惨殺した佐々木盛綱は、忠勇なる鎌倉武士の一人として歴史家に讃美されている。",
              "citation": {
                "source": "磯部の若葉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "復讐の同盟に加わることを避けて、先君の追福と陰徳とに余生を送った大野九郎兵衛は、不忠なる元禄武士の一人として浄瑠璃の作者にまで筆誅されてしまった。",
              "citation": {
                "source": "磯部の若葉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその最後の一人として生き残っているのだから……。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "国々から集まつた大名や殿様は皆其の儀式の華やかなのに驚いて只もう感心してしまひましたが其中でも金銀の衣裳を着たお玉の美くしさは唯一人として頭を上げて真面に見る事が出来た者はありませんでした。",
              "citation": {
                "source": "金銀の衣裳",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私の張りさけるやうな苦痛の絶叫をたれ一人として聞いてくれたものは此の地上にない。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（日本人の仲間には一人として私の友人を求めることは出來ない、彼等は私とは全然ちがつた肉體をもつてゐるやうな氣がする）。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、私は大ドストヱフスキイ先生もかうした仲間の一人として發見した。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
