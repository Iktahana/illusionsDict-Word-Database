    "definitions": [
      {
        "index": 1,
        "gloss": "same hole (in which to live)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もう一人の車掌もやって来て、同じ切符にもう一つ穴をあけた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ穴のお螻どもが、反対に鴨にくわれて、でんぐりかえしを打ったんですね。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "筍は伸びて軒端に届き、そこにもう一つ穴をあけて貰ひ、悠々と屋根の上に、頭を出してゐたからである。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "細かい所に気を附けて、塵紙を二つに切って置いて使ったり、用事を葉書で済ますために、顕微鏡がなくては読まれぬような字を書いたりするのは、どの人にも共通している性質だろうが、それを絶待的に自己の生活の全範囲に及ぼして、真に爪に火を点す人と、どこかに一つ穴を開けて、息を抜くようにしている人とがある。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロイドと毎月頭を絞るのだが、一つ穴を埋めれば、外に無理が出来てくる。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩故障を容れしに、氏子総代、神主と一つ穴で※言揚々として、むかしよりかかる英断の神官を見ず、老樹を伐り倒さば跡地を桑畑とする利益おびただしとて、その時伐採り見て哭きし村民を嘲ること限りなし。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういういかさま師どもと一緒に、習慣は幾分異にしているが、やはり一つ穴の貉といったような種の連中を、私はしばしば認めた。",
              "citation": {
                "source": "群集の人",
                "author": "THE MAN OF THE CROWD",
                "note": "青空文庫"
              }
            },
            {
              "text": "儲かっている人はどうせ儲けている金だから、最後は一つ穴を狙ってやれと云う気持も起し勝ちだし、損している人は今更本命をとって少しばかりの配当を貰ったって仕ようがない。",
              "citation": {
                "source": "競馬の一日に就いて",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "采女の亡骸をしっかりと抱えて、自分も生きながらに一つ穴へ葬られることを願ったに相違ない。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では、きさまらも一つ穴の浪人上がりじゃな」「今はじめて知ったかッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "耳のない浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに今の口振りで、兄も半九郎もどうやら一つ穴の貉であるらしいことを発見した彼は、日ごろ親しい半九郎に対して、俄かに憎悪と軽蔑との念が湧いて来た。",
              "citation": {
                "source": "鳥辺山心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ穴のむじなどもが安受け合いを、真にうけて帰らりょうか。",
              "citation": {
                "source": "鳥辺山心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生も拙者も一つ穴の貉だと御承知くださればよいのでござる。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちが古狸で、相手が狐、一つ穴だからな」「洒落ちゃあいけません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "小女郎狐",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生も自分もぐずぐずすると一つ穴へはまって、影のように消えて行きそうだ。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは艇長と一つ穴の貍みたいなものだ。",
              "citation": {
                "source": "宇宙尖兵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "城上郡に穴師坐兵主神社といふのと、も一つ穴師大兵主神社といふのがあります。",
              "citation": {
                "source": "近畿地方に於ける神社",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "その源右衛門がこのごろすこし忙しがっているというのは、急に自分の家のとなりにいた浪人者が引越して、長屋に一つ穴があいたためだった。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "浮世芝居女看板",
                "note": "青空文庫"
              }
            },
            {
              "text": "この坑夫だって、ほかの坑夫だって、人相にこそ少しの変化はあれ、やっぱり一つ穴でこつこつ鉱塊を欠いている分の事だろう。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "競争の念、勝とう勝とうの心は彼等が日常の談笑中にもちらちらとほのめいて、一歩進めば彼等が平常｜罵倒している俗骨共と一つ穴の動物になるのは猫より見て気の毒の至りである。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから偕老同穴とか号して、死んでも一つ穴の狸に化ける。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗盛親子のなきがらは、宗盛の生前の望み通り、一つ穴に葬られた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さん達だって一つ穴だ。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、持ちあわせた氷用の鏨でその真上にもう一つ穴を掘り、小刀で近所に見あたったいちばん長い樺の木を切りたおし、また、引き輪索をつくってそのはじに取付け、注意ぶかくそれをおろして斧の柄のにぎりにかぶせ、樺の木に沿うた紐でそれを引っぱり、かくしてふたたび斧を引きあげたのであった。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一つ穴だ、當になるものか」「三輪の、あつしが嘘をついたつて言ふのかえ」「誰もそんな事は言はねえよ」「お町は此間からお樂の阿魔を殺すんだつて威張つて居たが、もう少し訊いてみちや何うです、え、親分」「こんな醉つ拂ひに人間一人殺せるわけはねえ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "平次女難",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一つ穴だ、当てになるものか」「三輪の、あっしが嘘をついたって言うのかえ」「誰もそんな事は言わねえよ」「お町はこの間からお楽の阿魔を殺すんだって威張っていたが、もう少し訊いてみちゃどうです、え、親分」「こんな酔っ払いに人間一人殺せるわけはねえ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "平次女難",
                "note": "青空文庫"
              }
            },
            {
              "text": "五「御主人の氣のつかないうちに、これだけの細工をしたのは、餘つ程のワケがある筈です、――例へば、下手人が、何んかの都合で、雨戸に一つ穴をあけた」「？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美少年國",
                "note": "青空文庫"
              }
            },
            {
              "text": "シートンが、バルザックの「沙漠の情熱」アラビアの守備兵のフランス人が沙漠で一匹の牝豹と一つ穴にくらし牝豹が彼を恋す。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば芥川は谷崎に向つて、「それは佐藤の芸術はいいにはいいけれども、要するに一つ穴の笛なのだから心細い」　と、云つたと聞いた自分が、その後の機会に芥川のその説に賛成して、「全く今のままではいけないのだ、どうかしなければ。",
              "citation": {
                "source": "芥川龍之介を憶ふ",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつあなたに、いかにも如來らしい退去のすがたをおめにかけませう。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
