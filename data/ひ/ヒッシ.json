      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "frantic",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "芥川君のあの論文、及び最近における彼の多くの感想をよんだ人は、いかに彼が純粹な詩の憧憬者であり、ただ詩的なものの中にのみ、眞の意味の文學があり得ることを、必死に力説してゐるかを知るだらう。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてそれらの自由にまで、いかに必死的な熱情をもつて過去を一貫したかといふこと。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とお旦那も、ここは必死で追ひすがり、「お願ひがございます。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆汁なんかをたくらんだのは大いに惡いが、しかし、このごろの繪本のやうに、逃げるついでに婆さんを引掻いて怪我させたくらゐの事は、狸もその時は必死の努力で、謂はば正當防衞のために無我夢中であがいて、意識せずに婆さんに怪我を與へたのかも知れないし、それはそんなに憎むべき罪でも無いやうに思はれる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "非情の自然が、自らその頑な固定性に飽いて、抗い出た自己嫌悪の旗印か、または非生の自然に却って生けるものより以上の意志があって、それを生けるものに告げようとする必死の象徴ででもあるのであろうか。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘇っては必死に美しさに盛返そうとするちから。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の心の中に、表現し得ずして表現し度い必死の気持が、歯噛みをした。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうそのうちにも船は沈みますし、私は必死となって、どうか小さな人たちを乗せて下さいと叫びました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして不幸にも既に言語の通貨となりすましてしまったならば贋金を根絶することに必死の努力を払うべきである。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は冷えたわが子を素肌に押し当て、聞き覚えのおぼつかなき人工呼吸を必死と試みた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も種類によっては雄の足を脱離しなくってその代り雄は六本の足で相手を押さえ二本の足を外套膜の中に挿し込む、その時雌は呼吸を止められるから必死になって逃げ出そうと藻掻くそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すくなくとも僕にとつては、日本に生れた自分のライフを決定すべき、必死の宿命的の爭鬪である。",
              "citation": {
                "source": "悲しき決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕と室生犀星とは、いつも必死の捨身になつて、刀のツバをせり合はせてゐる。",
              "citation": {
                "source": "悲しき決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその必死の場合に、刀の合せたツバの下から、二人は顏を見合せて笑つてゐるのだ。",
              "citation": {
                "source": "悲しき決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たれか必死の覺悟なしに、この決心が出來るだらうか。",
              "citation": {
                "source": "室生犀星君の飛躍",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は悪夢の中で夢を意識し、目ざめようとして努力しながら、必死に※いている人のように、おそろしい予感の中で焦燥した。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あッ」Ｓ＝向いの屋根　必死で屋根瓦を掴んで匍い上ろうとしている石松。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝棚倉宅　お絹必死の叫び。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　仲蔵仰天した「そんな、無理な事」　大吉「あかんちゅうたら、駄目だ」　仲蔵「そう仰言らずに……」と必死に謝り頼む。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲蔵が尚も必死に頼むのを、大吉ニタニタ笑い乍ら聞き流して居たが暫時して、Ｔ「汝　それ程　舞台へ出たいか？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と大吉、雪枝必死に声を絞って、Ｔ「タッ、タッ頼みます！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚愕して飛びあがつたやうな町は、かかる苦悶そのもののアトモスフェアを突き破らうとでもするかのやうに必死となつてゐます。",
              "citation": {
                "source": "トレドの風景",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "その必死な母親の怒りに対して父親は張合いもなくうす苦く黙笑してばかりいる。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし父親にとってこの方法の鰻取りは単なる娯しみに過ぎなかったが、今は必死の副業である。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち必死で都会を取り返さなけりゃならないのよ」小初はきつい眼をしながら云い続けた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議な顫動が何か必死的な感じで二三｜分間つづくと、蜂はやがて穴のそとへ出て來た。",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくその初めは切｜實な人間生｜活の慰樂として遊びとして創り成された將棋に違ひないと思ふが、それを慰樂や遊びの域を遙に越えて、正に骨味を削るが如くあれほど必死に眞劍に爭ひ戰はなければならないとは！",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "必死の、鋭い、号泣と叫喚が同時に、老人の全身から溢れた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、必死に力いっぱいに、狭い穴の中でのたうちまわった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭い穴の中で、必死に、力いっぱいにのたうちまわっている、老人が、まだ、目に見えるようだった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
