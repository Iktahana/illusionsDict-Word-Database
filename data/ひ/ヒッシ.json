[
  {
    "uuid": "bf7d0a3a-b242-5f4f-b5fd-3c1e17d4404a",
    "entry": "必死",
    "reading": {
      "primary": "ひっし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
