    "definitions": [
      {
        "index": 1,
        "gloss": "to have a bad time",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "このやうなひどい目にあうて、何悪いことしたむくいぢゃと、恨むやうなことがあってはならぬ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、昔話のまね爺と同様によほどひどい目にあうのが落ちであろう。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざわざ、もっとひどい目にあうために、この島へ来たようなものだ。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は人ごみの中でつかまったすりのように、大勢の中へ曳きずり出されて、ひどい目にあうにきまっている。",
              "citation": {
                "source": "動物園の一夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっとつかまってひどい目にあうにきまっています。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時、下手まごつくと首が飛ぶし、それかというて、後込みしとると一揆からひどい目にあうしのう。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし今度この指輪を取ると、ひどい目にあうのだぞ』　僕は、お主婦が何か畏っていっているのを聞き流して、梯子段を降りたのです。",
              "citation": {
                "source": "島原心中",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも君等が日本に挑戦したら、それこそひどい目にあうぞ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私は千葉秀甫がドイツまで私を追いかけて行ったなんてことは知らない、うっかり東京に帰ったら、今度はどんなひどい目にあうかわからない。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、そんなことをいつまでも胸の中においていると、また督働委員から、ひどい目にあうぜ。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "見当をまちがって、鬼河原さんの家の下を掘ると、ひどい目にあうぞ。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "地図など持ってるところを見つかると、探偵とまちがわれて、ひどい目にあうことがありますよ」　太郎はうれしくてたまりませんでした。",
              "citation": {
                "source": "金の目銀の目",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "よほど綺麗な人でも、人は誰でも好意をもってくれるのが当り前のように思っているとひどい目にあうことがある。",
              "citation": {
                "source": "女性の諸問題",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ瀕死の戸倉老人が彼に残していったことばによると、黄金メダルの件は、非常な機密であって、うっかりこれに関係していることを洩らしたが最後、思いがけないひどい目にあうにちがいないと思われた。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘をつくのはいやだし、それかといって本当のことをいえば、怪しき曲者めというので、ひどい目にあうにちがいない。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は見つかると、ひどい目にあうでしょうか」「それはもちろんですわ」　女史は急にこわい顔になって肩をそびやかした。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどい目にあうもんだなあ。",
              "citation": {
                "source": "宇宙尖兵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "つつしみのないたった一人の失敗のために、我々全人類が、火星人から、ひどい目にあうとすれば、ばかばかしいことだ。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれが熊蜂であったなら、鱒の奴、ひどい目にあうのだ。",
              "citation": {
                "source": "魔味洗心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどい目にあうほど不敵になるのが彼の持ち前であった。",
              "citation": {
                "source": "女剣士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪物のワナにかかってひどい目にあうところなの。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "長崎の彼や彼女をあまく見ると、ひどい目にあうよ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "長崎チャンポン――九州の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって、どうせひどい目にあうものね！",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "かあさんでも生きててごらん、どうして言うことをきかないような子供は、よっぽどひどい目にあうんだぜ――あのかあさんは気が短かかったからね。",
              "citation": {
                "source": "嵐",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある程度の経験を積んだ職員は、いやそうじゃない、近ごろの孤児はなかなかすれてるから、うっかりすると大人がだまされて、ひどい目にあう、と言うかもしれない。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "罪はないけれども、やられたほうはひどい目にあう。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "山で酒がなくて困ったなど云っていると今に本当にひどい目にあうかも知れぬが、こんな風な山歩きも思出の一つになっている。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "御殿には近づかないように、そうすればひどい目にあうことはありません」　修道士たちが御殿でたくさんのお金をもらったと聞いた司祭さまたちはうらやましくなり、修道士たちのようにお金がもらえはしないかと、三人で御殿に行った。",
              "citation": {
                "source": "クリナーンの御殿",
                "author": "THE COURT OF CRINNAWN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何にもいえないんだからね――大きくなったら、こんな事どこじゃない、まだまだひどい目にあうかも知れないんだよ。",
              "citation": {
                "source": "身体検査",
                "author": "ソログーブ・フョードル",
                "note": "青空文庫"
              }
            },
            {
              "text": "少数ではやった者がひどいめにあうばかりだ。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
