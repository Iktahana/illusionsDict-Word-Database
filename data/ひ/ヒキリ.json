    "definitions": [
      {
        "index": 1,
        "gloss": "hand drilling (to start a fire)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
