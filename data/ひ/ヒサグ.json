        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "茶めし餡掛、一品料理、一番高い中空の赤行燈は、牛鍋の看板で、一山三銭二銭に鬻ぐ。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　さてここに、膃肭臍を鬻ぐ一漢子！",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋し神州の臣民にして情を醜虜に鬻ぐもの、俗に洋妾と称うるはこれなり。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二時さがりに松葉こぼれて、夢覺めて蜻蛉の羽の輝く時、心太賣る翁の聲は、市に名劍を鬻ぐに似て、打水に胡蝶驚く。",
              "citation": {
                "source": "五月より",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍女一　近頃は、かんてらの灯の露店に、紅宝玉、緑宝玉と申して、貝を鬻ぐと承ります。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮の入口に、新しい石の鳥居の前に立った、白い幟の下に店を出して、そこに鬻ぐは何等のものぞ。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺や茶屋は、翁ひとり居て、燒酎、油、蚊遣の類を鬻ぐ、故に云ふ。",
              "citation": {
                "source": "逗子だより",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚蝋の烟を風のまにまに吹き靡かせて、前に木机を据ゑ、そが上に月桂の青枝もて編みたる籠に貨物を載せたるを飾りたるは、肉｜鬻ぐ男、果賣る女などなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "我駒の行くところは、古かなもの、古畫を鬻ぐ露肆の間にて、目も當てられず穢れたる泥※の裡にぞありける。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬に跨れる人あり、車を驅れる人あり、燒酎｜鬻ぐ露肆を圍みて喧譟せる農夫の群あり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "城下金沢より約三里、第一の建場にて、両側の茶店軒を並べ、件のあんころ餅を鬻ぐ……伊勢に名高き、赤福餅、草津のおなじ姥ヶ餅、相似たる類のものなり。",
              "citation": {
                "source": "一景話題",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は竹の皮づつみにして汽車の窓に売子出でて旅客に鬻ぐ、不思議の商標つけたるが彼の何某屋なり。",
              "citation": {
                "source": "一景話題",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その建築物の往来に接した部分は幾棟かに仕切られて、雑貨を鬻ぐ店がそこにある。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "相摸國三浦郡蘆名村に生れ、江戸に入つて品川町に居り、魚を鬻ぐを業とした。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那に路上春を鬻ぐの女を野雉と云ふ。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "前いへる場所などに鬻ぐは江戸市中に遠ざかりし所ゆゑ残れる也。",
              "citation": {
                "source": "江戸の玩具",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀戸天神様宮前の町にて今も鬻ぐ。",
              "citation": {
                "source": "江戸の玩具",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "炎熱焼くが如くにして、沿道たま／＼瓜を鬻ぐ。",
              "citation": {
                "source": "臨終の田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ一椀の羹に、長子の権を鬻ぐものなり。",
              "citation": {
                "source": "我が教育の欠陥",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "懸茶屋には絹被の芋｜慈姑の串団子を陳ね栄螺の壼焼などをも鬻ぐ。",
              "citation": {
                "source": "向嶋",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時都下に洋酒と洋食とを鬻ぐ店舗はいくらもあった。",
              "citation": {
                "source": "申訳",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "傀儡子という漢字をあてられた我が本来のクグツは、平安朝大江匡房の頃には、一定の居なく水草を逐うて移徙し、男は狩猟を主として傍ら各種の遊芸に従事し、女は美粧して婬を鬻ぐを業としていたらしい。",
              "citation": {
                "source": "くぐつ名義考",
                "author": "古代社会組織の研究",
                "note": "青空文庫"
              }
            },
            {
              "text": "耕作をせぬ女が生活して行く為には、自然と婬を鬻ぐことになるのは、やむをえなかった事でありましょう。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局彼らは人形を舞わすとか、手品を使うとか、婬を鬻ぐとかいう様な、身分相当の方法によって、生活の資を求めねばならぬ。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその婦女は、粉粧をこらして淫を鬻ぐ。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで気の利いたものは、遊芸を演じて米銭を貰う、あるいは婦人は婬を鬻ぐ、この輩が遊芸者や遊女などになるのです。",
              "citation": {
                "source": "融和問題に関する歴史的考察",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しわたくしがわざわざ廻り道までして、この店をたずねるのは古本の為ではなく、古本を鬻ぐ亭主の人柄と、廓外の裏町という情味との為である。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "アヲヤ　栽培する蔬菜にも青物といふ名を延長し、之を鬻ぐ店を青物屋といふことは、東日本一般の風であつたが、東京などはいつの間にか之をヤホヤといふやうになつた。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "アオヤ　栽培する蔬菜にも青物という名を延長し、これを鬻ぐ店を青物屋ということは、東日本一般の風であったが、東京などはいつの間にかこれをヤオヤというようになった。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も北京の路上でわずか数銭を以て鬻ぐあの簡素な磁州窯の美しい器を見よ。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
