    "definitions": [
      {
        "index": 1,
        "gloss": "human sacrifice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "Ｔ「嫁入前の庄屋の　娘が可哀そうに　人身御供に」Ｓ＝元の茶店　亭主が話す。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの中間はとんだ人身御供だったな」「そうでしょうか」「一朱や二朱は惜しくねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "通貨が無いからそれを曲入て、人身御供を下げておいで、仁三が何か言句をいおう。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あけては夫にも告げられねば、病氣の介抱を斷ると云ふわけに行かないので、あい／＼と、内に殘る事に成つたのは、俎のない人身御供も同じ事で。",
              "citation": {
                "source": "一席話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "上前の摺下る……腰帯の弛んだのを、気にしいしい、片手でほつれ毛を掻きながら、少しあとへ退ってついて来る小春の姿は、道行から遁げたとよりは、山奥の人身御供から助出されたもののようであった。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時です、……洗いざらい、お雪さんの、蹴出しと、数珠と、短刀の人身御供は――　まだその上に、無慙なのは、四歳になる男の児があったんですが、口癖に――おなかがすいた――おなかがすいた――と唱歌のように唱うんです。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝまで来てわたくしは大体池上の話の落ちつきどころが判った気がしましたので、「じゃ、その月光とかいうものの一人として今度、あたしがあなたの人身御供に上ったわけなのね」　だが、池上は首を振りました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺商主祀天喩一隊商が曠野で颶風に遇った時、野神に供うる人身御供として案内人を殺した。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその叢書の中の『幽怪録』には、岩見重太郎の緋狒退治というような人身御供の原話になっているものがある。",
              "citation": {
                "source": "怪譚小説の話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お見かけすると、隣の室に酒宴の準備をしてあるようですが、全体どういう事情で、貴女は泣いていらっしゃるのです」「私は今晩、神様の人身御供になりますから、それが悲しゅうございます」　元振は驚いた。",
              "citation": {
                "source": "殺神記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人身御供をとるような神は邪神だ、天地に容れられない大罪だ、その道理が判らないとは、なさけない奴等だ」　村の人も元振の道理ある詞に怒りを収めた。",
              "citation": {
                "source": "殺神記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の取引きのために、他人を人身御供にするようなものではないか？",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人身御供に出会せば、屹と男が助けると極つたものなの……又、助けられる事に成つて居るんですもの。",
              "citation": {
                "source": "貴婦人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お慈悲に早く出牢が出来たので助かりましたが、あれが長くつづいたら、人身御供にあがった二十五人の人たちは、みんな責め殺されてしまったかも知れません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に出てみたのは、番頭ふたりと小僧一人だったんですが、ひとりの番頭だけは運よく助かったとみえて、今になんにも祟りがなく、ほかの二人が人身御供にあがった訳なんですが、妙なこともあるじゃありませんか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "あま酒売",
                "note": "青空文庫"
              }
            },
            {
              "text": "取り巻きのおめえ達はそれでよかろうが、姐さんはいい人身御供だ。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その身上を立直す為に、妾はとうとう人身御供にあげられて忌な婿を取らなければならないことになった。",
              "citation": {
                "source": "黄八丈の小袖",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の代りにあの美しい娘を人身御供にして置きながら、平気で面白そうに唄っているが、娘の家では今ごろ大騒ぎをしているだろう。",
              "citation": {
                "source": "蟹満寺縁起",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしにはどうしてもあきらめられない、十七のとしまで大事に育てた、かけがえの無いひとり娘を、おそろしい蛇の人身御供にするのを黙ってあきらめていられるお前さんは、ほんとうに羨ましい。",
              "citation": {
                "source": "蟹満寺縁起",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "人身御供にしてしまおう。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "美奈子は、人身御供にでもなったような心持で、たゞ母の意志に従っていると云うのに過ぎなかった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは霊験あらたかな神の前に捧げられた人身御供のように、純な犠牲的な感情をもって忠直卿に対していた。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「人身御供におシャブリ遊ばした女子が都合十一人に及んだと申すのじゃ。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "權三　たうとうおれが人身御供にあげられてしまつたか。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次に人身御供にあがったのは、番太郎の女房のお倉であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半鐘の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "お由ひとりが人身御供になって、それでかむろ蛇の祟りが消えるのか、三人ながら同じ祟りを受けるのか、そんなことは誰にも判らない秘密である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "かむろ蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄五郎が一旦引っ返して来たなんて云うと、その詮議がまた面倒になると思って、実は自分が庄五郎の声色を使ったのだといい加減の出たらめを云って、なるべくこの一件の埒を早くあけて、罪もねえ平七を人身御供にあげてしまう積りだったのだろう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三つの声",
                "note": "青空文庫"
              }
            },
            {
              "text": "美奈子は、人身御供にでもなつたやうな心持で、たゞ母の意志に従つてゐると云ふのに過ぎなかつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
