    "definitions": [
      {
        "index": 1,
        "gloss": "to be caught in",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "待ちに待った朝は来た、朝がいかなる方面から、いかに忍び足に寄って来て、一秒ずつ額を白くしたかは徹夜凝視しても解らない、夜と朝の筋目が判然と目立つほどなら、地球の緯度線が草鞋の爪先に引っかかるわけである、しかも争う可らざるは朝の神秘なり、一たび臨むとき、木偶には魂を、大理石には血を与る。",
              "citation": {
                "source": "奥常念岳の絶巓に立つ記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "実験室ばかりで仕事をしている学者達はめったに引っかかる危険のないようなこうした種類の係蹄が時々「天然」の研究者の行手に待伏せしているのである。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、拡声器の調節が悪いためか、歌がちょうど咽喉にでも引っかかるようにひっかかってぷつりぷつりと中断する。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲はうっかりにせ物に引っかかるような心配はほとんどない代わりに、どうかするとほんとうに価値のある新しいいいものを見のがす恐れがある。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると、非常に大きい鱸が引っかかることもあるんですが……」「すずきが相変らず釣れますか。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつが心臓の出口の大動脈の附根に引っかかると二年か三年か経つうちにそこいらの血管がブヨブヨに弱くなって来る。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "独博奕の雁木鑢という奴で行き戻り引っかかるのがこの市場商売の正体で、それでもノホホンで通って行くところが沽券と申しますか、顔と申しますか。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "草の根方に引っかかるたんびに、眼も眩むほどズキズキと高潮する股の痛みを、一生懸命に我慢しいしい森の方へ近づいて行きました。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一重の網をのがれた魚でも三十六重の網には引っかかるのである。",
              "citation": {
                "source": "俳諧瑣談",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　ぼくはその大きな本を小脇に抱えてホテルに戻ったんですけれど、胸のなかでは気持ちがぶつかりあってて、一方では内定確実、懐に一〇〇ポンド、もう一方には事務所の見た目、壁にない表札、実業家として引っかかる点からして雇い主の姿勢に対する悪印象。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういう手があるのか知りませんが、この『男女』に引っかかると、女はみんな夢中になること不思議で、小三津も文字吉に魂を奪われてしまって、持っている金も着物も片っ端から入れ揚げる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの辺へ行って網を張っていたら、なにか引っかかる鴨があるかも知れねえ」「そうしましょう」　二人は怱々に飯を食ってここを出た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "引っかかる位の奴は別の口から、中へ入れるが、お前は、その縄の下を通らされるぜ。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤原はボイラーの上に上がって、鉤が当然引っかかるような状態になって来るのを待っていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "野々宮君の先生のなんとかいう人が、学生の時分馬に乗って、ここを乗り回すうち、馬がいうことを聞かないで、意地を悪くわざと木の下を通るので、帽子が松の枝に引っかかる。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かもしれない」　きのうから、手塚がおそろしく元気がいいのが引っかかる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生は、こいつのタイプじゃないと思いますけど、試すのは自由ですから」「残念ながら、年齢制限と職業倫理に引っかかるね。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、それから、法律にも引っかかる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫は喜んで、すぐにその中に這入ろうとしましたが、その時にヒョイと気が付きますと、その入り口一パイに網を張って、一匹の大きな蜘蛛が餌の引っかかるのを待っています。",
              "citation": {
                "source": "オシャベリ姫",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間見ずの令息令嬢が引っかかるのも無理はない。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで脅迫して、金や時計をふんだくっただけで帰せば、大抵の坊ちゃんは秘密を守るそうであるが、タチの悪いのに引っかかると、自宅に電話をかけて金を持って来させる。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにか引っかかる物はないかと、幾たびか引っ掻きまわしているうちに、小さい割には重いものが熊手にかかって引揚げられたので、明るい日光の下で大勢が眼をあつめて見ると、それは小さい鏡であった。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "出ぬ乳をあてがって、畳の足に引っかかる一間の中をあっちこっちと動物園の虎のようにして揺って歩くが、どうしても泣きやまぬ時などは、いっそ放り出してしまおうかと思うほどだ。",
              "citation": {
                "source": "ネギ一束",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふむ、そんな物に引っかかるものか！",
              "citation": {
                "source": "奥さんの家出",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "爪磨きとしての効用　爪を鋏で切りっぱなせば角があって方々へ引っかかる。",
              "citation": {
                "source": "白銅貨の効用",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、さようなら」『引っかかるもんか』と、わたしは思った。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな男に引っかかるお嬢さんがあるのかと思うと、気の毒のような気がするわ。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰が、あんなお爺さんに引っかかるものか。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはいつものんきね」「のんきでも勉強はしてるよ」「あたしは鶏小屋の掃除やら、お洗濯やら、いそがしいのよ」　私は安子と遊びたくても、いつも用事が引っかかるので物足りなかったが、しかし段々と自分がぶらぶらしてるのが気がさすようになった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに先方が職業的に誘拐者であってみれば、そんな作戦は百も承知していて、いかに巧妙に網を伏せたところで、間違ってもそいつに引っかかるようなだらしのないことはしない。",
              "citation": {
                "source": "チャアリイは何処にいる",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            }
          ]
        }
