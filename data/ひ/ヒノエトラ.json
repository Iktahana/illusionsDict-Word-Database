        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "十五日、丙寅、未剋地震。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿五日、丙寅、和田平太胤長の屋地、荏柄の前に在り、御所の東隣たるに依りて、昵近の士、面々に頻りに之を望み申す、而るに今日、左衛門尉義盛、女房五条局に属して、愁へ申して云ふ、彼地は適宿直祗候の便有り、之を拝領せしむ可きかと云々、忽ち之を達せしむ、殊に喜悦の思を成すと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四日、丙寅、広元朝臣、今月一日大江姓に遷り訖んぬ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丙寅、諸王及び文武の臣、燕王に位に即かんことを請う。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正一五、三、集古、丙寅ノ二）",
              "citation": {
                "source": "毘沙門の名號に就いて",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「文化三、丙寅年の正月の末頃から江戸では槍突きという悪いことが流行りました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "槍突き",
                "note": "青空文庫"
              }
            },
            {
              "text": "本朝にも弥勒の平等世界を唱えて衆を乱した事歴史に見ゆとは何を指すのかちょっと分らぬが、『甲斐国妙法寺記』に、永正三｜丙寅、この年春は売買去年冬よりもなお高直なり。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "永正三丙寅と承安元辛卯、いずれも弥勒元年とするもその十年は乙亥か庚子で辰の歳じゃない。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "丙寅二號の拙文は、先づクベラ、又クビラが毘沙門だ。",
              "citation": {
                "source": "再び毘沙門に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "因て丙寅二號五葉裏の上段十三四行で此話は何の經に出て居るか識者の高教をまつと、明かに自分の無智無識を告白した。",
              "citation": {
                "source": "再び毘沙門に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正十五年九月、集古、丙寅第四號）",
              "citation": {
                "source": "再び毘沙門に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「文化丙寅五月十九日、長崎｜撫院和泉守曲淵公に従て東都を発す。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭軒の釈奠の詩は二首あつて、丙寅の冬「聞雪」の作と、丁卯の春徳見※堂に訪はれた作との間に介まつてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」第七の下に「甲子蒙典謁之命、丙寅兼領祠曹、丁丑陞相位、通前後廿年」と註してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "書牘は文化丙寅六月十九日に茶山が蘭軒の父｜信階に与へたもので、文淵堂の花天月地中に収められてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "丙寅は蘭軒の長崎に往つた年である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭軒は文化丙寅に長崎に往く途次、神辺を過つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶山は丙寅六月十七日尾道油屋の夜宴の後、十八日には油屋で「すこし休息」した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "良子刀自所蔵の「丙寅三次集」は棠軒が自ら此年の詩歌を編したものである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年丙寅　平八郎十四歳。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿九日　上関十月三宮　市別巻丙寅正月大　　　　　慶応二年十日　下ヲ発。",
              "citation": {
                "source": "坂本龍馬手帳摘要",
                "author": "坂本龍馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "丙寅五月二日ワイルウヱフ破船五島塩屋崎ニ於テ死者十二人。",
              "citation": {
                "source": "坂本龍馬手帳摘要",
                "author": "坂本龍馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十五年｜丙寅初春永井荷風識。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "余が蔵する画幅に延享三年丙寅仲春夢中庵笠翁八十有四｜筆とあり。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、私の運勢をみていただけましょうか」「まず、お生れ年と、月日を」「本年三十二歳、甲子ノ年、乙丑ノ月、丙寅ノ日、丁卯ノ時刻に生れました。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丙寅八月、宇右衛門殿物語り。",
              "citation": {
                "source": "山の人生",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "春三月、丙寅の日、いよいよ発向と令せられた。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
