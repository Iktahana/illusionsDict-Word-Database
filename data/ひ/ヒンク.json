    "definitions": [
      {
        "index": 1,
        "gloss": "hardships of poverty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
