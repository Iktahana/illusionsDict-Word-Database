        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一八七八ー七九年には王立研究所の評議員を務めた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八八四年にレーリーは王立協会の評議員をつとめたことがあった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "協会幹事として彼はウィラード・ギブスの酬われざる貢献を認めこれを表彰したいと望んだが、化学方面の評議員が「あれは化学じゃない」と云って承知せず、ケルヴィン卿までも反対した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「主に於いて眠り給へる帝室評議員アントン・フオン・ヰツク殿の為めに祈祷せしめ給へ。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉良の父親も、義光ちゃんの父親も学園の評議員なので、校長先生も割合に話をさくゝ打割って茲まで話したものと見えます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私の兄弟のハリー・ピナーは発企人なんですが、選挙の結果、専務取締として評議員に加わっています。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "議事堂には市の評議員達がゐる。",
              "citation": {
                "source": "十三時",
                "author": "THE DEVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "己がこの市に来て住むことになつてから、評議員達は二度特別会議を開いて、左の重大な決議をした。",
              "citation": {
                "source": "十三時",
                "author": "THE DEVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "市の評議員達は塔の番人を一人雇つて、大時計の番をさせてゐる。",
              "citation": {
                "source": "十三時",
                "author": "THE DEVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、会を起すについては、会則を作り、会頭、理事、評議員というようなものの必要を生じて来る。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "彫工会の成り立ちについて",
                "note": "青空文庫"
              }
            },
            {
              "text": "関氏は福地桜痴居士の後をうけて日日新聞を経営していた関係上、すこぶる桜痴居士に私淑していたばかりでなく、かの“演劇改良会”の幹事か評議員かを勤めていたので、劇というものについて多大の趣味を有していたらしく、わたしが劇作家になるということを非常に賛成してくれたのであった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十一年には保が八月三十日に羽嶽の義道館の講師になり、十二月十七日にその評議員になった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌十一日、自由進歩両党、各自評議員会に於て、合同を決議。",
              "citation": {
                "source": "政治の破産者・田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "「噂」及び「夢がたり評議員會」はまことに噂と夢がたりに過ぎず、敢て説明を要せざるべし。",
              "citation": {
                "source": "貝殼追放",
                "author": "「その春の頃」の序",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　アムステルダムの国立博物館では「夜警」（一六四二年）と「織物商組合評議員」（一六六一年）が有名であるが、そのほかに「エリザベト・バース」（老婦人の像）と「或る婦人の像」（中年の婦人の像）と火事で焼け残った「解剖講義」（一六五六年）の断片も忘られないものである。",
              "citation": {
                "source": "レンブラントの国",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行くと「評議員」の方はよくわかる。",
              "citation": {
                "source": "レンブラントの国",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アムステルダムの織物商組合の五人の評議員が、ペルシア風の緋のテイブルクロスで蔽われた一つのテイブルの上に書類を置いて商議していると、後の羽目板に倚つかかるようにして一人の召使の男が無帽で立っている。",
              "citation": {
                "source": "レンブラントの国",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央に片手を上向けて話してる男は恐らく組合の評議員長であろう。",
              "citation": {
                "source": "レンブラントの国",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に毛織類の取引はオランダが世界で優位を占めていたから、その評議員たちは、取りも直さず、オランダの実業界を代表する名士たちでなければならなかった。",
              "citation": {
                "source": "レンブラントの国",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "全教組のスト問題と学校の寄付金問題につき明日学校にて理事評議員会あるとかにて伝えに来られしもの。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大會の決議は折衷的な評議員案が成立して無事終了しましたが、黨そのものが禁止されたので、いささかとびに油揚をさらはれた形になりました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月十日（土）　昨夜、国民学術協会評議員会あり。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、東洋経済の評議員会に出席。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月二十日（土）　午後、経済倶樂部中央会の評議員会に赴く。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "この会は東洋経済の別働隊だが、かつて評議員の名を情報局に提出した。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月二十八日（月）　東洋経済の評議員会に赴く。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "平貞藏君（評論家）、岸本誠二郎君、本日より評議員会に來る。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月十一日（日）　東洋経済の評議員会に出る。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月八日（月）　東洋経済の評議員会あり。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "東洋経済の評議員会に出席。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
