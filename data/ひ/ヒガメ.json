        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "感じのわるくない町だ、金本屋といふ安宿へ泊る、木賃三十銭、上の下といふところ、主人は少し調子はづれと見たは僻目か。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "それともそう見えたのは家康の僻目であったか。",
              "citation": {
                "source": "佐橋甚五郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十川さんなぞはなんでも物を僻目で見るから僕はいやなんです。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そう見えたのは気のせいだったか、僻目だったか、番頭は人のよさそうな顔つきでにこにこしながら退屈男の傍へ近づいて来ると、物軟かに言いました。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "三浦の娘などと思うたら大きな僻目じゃ」と、泰親は意味ありげにほほえんだ。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "車のぬしを衣笠と見たのは自分の僻目で、彼女はやはり玉藻であったに相違ない。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かわる心と子や思うらん」といいますが、それはつまり子供の僻目です。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "理窟と見るは所詮僻目です。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "骸骨のお化けだ、何が美しかろうというのは僻目です。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸久食堂の隣席はきつと結婚見合、この結婚不成立と観たは僻目か、女の方が男よりもづう／＼しかつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "左様見えたつて仕方がないが、それは僻目だ」　代助の方は通例よりも熱心に判然した声で自己を弁護する如くに云つた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僻目でも何でも可くつてよ」　代助は黙つて三千代の様子を窺つた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから僻目かも知れないが、先生を訪問しても、先生によっては閾が高いように思われた。",
              "citation": {
                "source": "明治二十四、五年頃の東京文科大学選科",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思ったのは、決して僻目ではない。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを互に取組んでるかのように云うのは、批評家の僻目である。",
              "citation": {
                "source": "作者の住む世界",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう見えたって仕方がないが、それは僻目だ」　代助の方は通例よりも熱心に判然した声で自己を弁護する如くに云った。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僻目でも何でも可くってよ」　代助は黙って三千代の様子を窺った。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "僻目であろうかと恐れたが、それかといって、その疑を払拭する反証をも捉え得なかった。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "堂守の老人の見たのが僻目ではなく、或る時は、さやけき月の光を白衣に受けて、それが銀のようにかがやき、或る時は、木の下暗に葉影を宿してそれが鱗のようにうつります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて、いったん、破れた夢が、またあけ方まで無事に結び直されましたが、日の光、鶏の声が戸の隙から洩るるを見て、兵馬は立って、一枚の雨戸を繰ると、満山の雪と見たのは僻目、白いというよりは痛いほどの月の光で、まだあけたのではありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一　文壇の治郎左衛門やはり田舎の人に多きやうなるはわが僻目か。",
              "citation": {
                "source": "小説作法",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」お豊は首を長く延して、「私の僻目かも知れないが、実はどうも長吉の様子が心配でならないのさ。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉置の荘司殿と見たは僻目か！",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、この事あつて以来、細君同士の近所つきあひがめつきりよくなり、隣組の土台が自然に出来上つたといふ事実は、偶然も手伝つてはゐようが、死んだ妻の功績だと彼は信じてゐる。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは近世の語りひがめもあったかと思うが、ここでは七夕様は一人娘、犬飼さんは養子であったなどといっている。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
