    "definitions": [
      {
        "index": 1,
        "gloss": "tightness (of money, financial conditions, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "奥穂高といっても、岩石の逼迫した凸った地点に、棒杭一本を打ち込んであるだけのことであった。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは畢竟運動の速度、従ってエネルギーの差から起るものかもしれないが、そればかりでなく、この舞人の挙動自身に何かしらある感情の逼迫を暗示するものがあるのかもしれない。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地の豪農何某が、内證の逼迫した華族の令孃を金子にかへて娶つたと言ひます。",
              "citation": {
                "source": "人魚の祠",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "世のありさま、三四年このかた金融の逼迫より、種々の転変を見しが、別して其日かせぎの商人の上には軽からぬ不幸を生ぜしも多かり。",
              "citation": {
                "source": "鬼心非鬼心",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "二百俵取りでは、もとより裕福という身分でもなかったが、和田の家は代々こころがけのいい主人がつづいたので、その勝手元はあまり逼迫していなかった。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "――思い出せば、その酒と鮪の最中、いや、灘の生一本を樽からでなくっちゃ飲めない、といった一時代もあったが、事、志と違って、当分かくの通り逼迫だ。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日が日の糧にも困った、あの逼迫やよってに、すぐに口を見つけて、にい、わすれもせんぞに――あんたはその千駄木へ。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はその隣り屋敷へ出入りしているが、池田の屋敷は当主のほかに大勢の厄介があって、その内証はよほど逼迫しているらしい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩一緒に出て行ったという池田の次男……喜平次という奴も手伝ったのだろう」「そいつも伊太郎に抱き込まれたのかね」「池田の屋敷はひどく逼迫していると云うじゃあねえか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼吸が逼迫して苦んだ。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "物質上にも次第に逼迫して来たからであろうが、自暴自棄の気味で夜泊が激しくなった。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりわけ毎日新聞社は最も逼迫して社員の給料が極めて少かった。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにまた一方には物質上の逼迫がヒシヒシと日に益々加わって来た。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "気楽どころかむしろ逼迫していた。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "金に逼迫していたから金も儲けたかったろうが、金を儲ける以外に大なる経綸があった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしと違って、そのころの諸大名はいずれも内証が逼迫しているので、新規召抱えなどということはめったにない。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "飢は頬に、逼迫は眼に、侮辱貧窮は背に懸ってある。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に、現実の生活の逼迫をどうしてくれるのだ、と彼女は激昂のあまり私に挑みかかつて来るのであつた。",
              "citation": {
                "source": "かげろふ断章",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小説の時期は敗戦翌年の春で、場所は福岡県の片田舎の疎開地、瀕死の病害と幼ない子供を抱へて、日ごと逼迫してゆく「私」の生活はどうみても暗澹としてゐる筈です。",
              "citation": {
                "source": "檀一雄「リツ子・その死」",
                "author": "――創芸社刊――",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡洋爆撃への驚嘆、快速戦車部隊への刮目、敵の空襲や迫撃砲や機関銃に対する悲憤、それからまた軍需品製造への緊張、科学戦時代を迎えて青少年といわず老幼男女を問わず国民全体を科学教育することへの逼迫などと、あらゆる材料が読書界を科学小説時代へ持ってゆくための好条件であったのだ。",
              "citation": {
                "source": "『十八時の音楽浴』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "時勢の逼迫が私の主張に耳を藉す人も生じさせていたが、事変勃発後、私の「戦争史大観」が謄写刷りにされて若干の人々の手に配られた。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その天才的直感力に依りて大体の大方針を確立し、その目的達成のために現実の逼迫を巧みに利用して勇猛果敢に建設事業に邁進する。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "日常の経済生活の逼迫とそのような精神的よりどころなさとは、落付いて本を読む気持さえも削いで行くかに見えたのである。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "作家の経済生活は、一般に益々逼迫して来つつあるし、これから先まだまだそれが切りつまって来ることは明瞭であろう。",
              "citation": {
                "source": "おのずから低きに",
                "author": "――今日の新聞小説と文学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "明け暮れのたつきは小役人として過しており、芸術に向う心では釣月軒として自分と周囲の生活とを眺めている宗房の目に映る寛永年代の江戸は、家光の治世で、貿易のことがはじまり、大名旗本の経済は一面の逸遊の風潮とともに益々逼迫しつつあった。",
              "citation": {
                "source": "芭蕉について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには頑固親父のために心ならずわかれている素一とゆり子との心持もからみあいつつすべての個人生活の懊悩も経済上の逼迫も、その組合の工場で稼ぐことで解決の方向におかれたことが物語られているのである。",
              "citation": {
                "source": "「建設の明暗」の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化、文学を発展させる自主的な精神力の喪失、経済事情の今日の小市民層らしい逼迫などが、微妙にからみあっているのである。",
              "citation": {
                "source": "「大人の文学」論の現実性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学青年と一括して呼ばれる若い時代の社会的・経済的支持の力は、彼等の苦しく逼迫する現実生活の必然から、従来の所謂文壇人の生活を負担しがたくなって来ている。",
              "citation": {
                "source": "文学における今日の日本的なるもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦線のひっぱくは、彼をして内部に思いなやんでいることを打ちあけるひまを与えなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃、食糧がなかなかひっぱくして来た。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
