        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "風までひゅうひゅう吹きだした。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにせいが高いので、教室でもいちばん火に遠いこわれた戸のすきまから風のひゅうひゅう入って来る北東の隅だったのです。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "風がひゅうと鳴って雪がぱっとつめたいけむりをあげますと、一郎は少し立ちどまるやうにし楢夫は小刻みに走って兄に追ひすがりました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "別当がこんどは、革鞭を二三べん、ひゅうぱちっ、ひゅう、ぱちっと鳴らしました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　別当がむちをひゅうぱちっとならしましたのでどんぐりどもは、やっとしずまりました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　別当が、むちをひゅうぱちっと鳴らしました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　別当が、むちをひゅうぱちっと鳴らし、どんぐりはみんなしずまりました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "別当も大よろこびで、五六ぺん、鞭をひゅうぱちっ、ひゅうぱちっ、ひゅうひゅうぱちっと鳴らしました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪童子はわらって革むちを一つひゅうと鳴らしました。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その裂くような吼えるような風の音の中から、「ひゅう、なにをぐずぐずしているの。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひゅうひゅうひゅう、ひゅひゅう、降らすんだよ、飛ばすんだよ、なにをぐずぐずしているの。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひゅう、ひゅう、向うからさえわざと三人連れてきたじゃないか。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひゅう、ひゅう、さあしっかりやるんだよ。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひゅう、ひゅう、なまけちゃ承知しないよ。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひゅう、ひゅう、ひゅう、ひゅうひゅう。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
