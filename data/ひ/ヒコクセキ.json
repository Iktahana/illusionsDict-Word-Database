    "definitions": [
      {
        "index": 1,
        "gloss": "defendant's seat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」裁判長は書類と被告席とを等分に見てから名前を呼んだ。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が法廷に立つてこの状況を語つたとき、被告席から涕泣の声がした。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "後の方を振り返へると、看守長の宮部と云ふ人が、被告席の一番後の片隅に椅子に凭つてゐるのを見付けた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い弁護人は自分の席を起つて、被告席の方へ足を運んだ。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "被告席は四列になつてゐて、彼の担任せる被告等は第三列目の中程に居た。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすればもちろん、僕は被告席に立たなければならないことはきまった話だ。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今更恐れをなして、はいつくばるのもたいへん結構、だが少しでも考えたことがあるか、覚えのない罪のために、哀れホーナは被告席に立つのだと。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「キミこそ被告席に引きずり出されるべきだ。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "よって当然の選択として、そのミスＭを訪ね、本人にあなたが真実を握っていると踏んでいるのだと打ち明け、友人のバークリ夫人はこの件が片づかない限り、被告席で殺人の罪に問われるおそれがあるのだと説いた。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴殿は予を被告席に据えたい。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "」（被告席失笑）　裁判長「飯田被告と他人と共謀の上とあるが、起訴当時ははっきりしていなかったかどうか。",
              "citation": {
                "source": "それに偽りがないならば",
                "author": "――憲法の規定により国民の名において裁判する――鈴木裁判長",
                "note": "青空文庫"
              }
            },
            {
              "text": "（被告席身体をゆすって笑い出す）（以下略）」　裁判長「いつ、どこで、だれとだれとが会ったということは分っていないようだ。",
              "citation": {
                "source": "それに偽りがないならば",
                "author": "――憲法の規定により国民の名において裁判する――鈴木裁判長",
                "note": "青空文庫"
              }
            },
            {
              "text": "被告席に着いた彼の姿は一言で云えば、獰猛な鷲のような印象を人々に与えた。",
              "citation": {
                "source": "殺人狂の話",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かくの如き恐るべき犯人は未だかつて被告席にあらわれたる事なし」　検事総長はこう結んだ。",
              "citation": {
                "source": "殺人狂の話",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が法廷に立って女のために放免を哀願ったときは、女は被告席にうずくまったっきり泣き咽んでいて、彼の顔を見上げる勇気もなかったが、今目のあたりにこの物すごい形相を見ると、堪らなく厭な気持がするのだ。",
              "citation": {
                "source": "暗中の接吻",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて順番が来ると、彼女はふらふらする歩調で、法廷の証人席へ入って行ったが、暗い控室から急に明るみへ出たので、眼をパチクリさせながらも、すぐに被告席にいるわが子の姿を認めた。",
              "citation": {
                "source": "情状酌量",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の姿を見ると、廷丁は私のために被告席を用意し始めた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて私は被告席につかされた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "法官席の下の巖丈な柵の前の被告席には、こはれかゝつた銀杏返しに結つた女があらい紺がすりの洗ひさらした単衣を着てうつむきながら立つてゐてその後ろの弁護士席には二人の弁護士が控へてゐました。",
              "citation": {
                "source": "ある女の裁判",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく見ると被告席に立つてゐる其の女は、生れてからまだ間もないやうな赤ん坊を抱いてゐるのです。",
              "citation": {
                "source": "ある女の裁判",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "支倉喜平は見るから不敵の面魂で、臆する色もなく被告席に控えていた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は例の自ら筆記した大部の書類を携えて被告席に控えていた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "満廷色を失って声のする方を見ると、被告席にいた支倉が満面朱を注ぎ、無念の形相凄じく、両手に自記の書類を打ち振りながら証人席目がけて突進するのだった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その疾病は囚人と共に法廷へ入り込んで、時としては被告席から裁判所長閣下にさえ真直に突き進んで、閣下を裁判官席からひきずり下すこともあった。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほどなく、被告席が興味の中心点となった。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までそこに立っていた二人の看守が出て行き、やがて囚人が連れ込まれて、被告席に入れられた。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物人たちは飲食しにぽつりぽつりと去り、囚人も被告席の後の方へ引下って、腰を下した。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "被告席に立った冷静な態度の質素な彼の姿。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "関係書類は六千通を越え、判検事の控室は、法廷へもちだす証拠物件で百貨店の倉庫のようになり、被告席のランドリュの禿頭が黄色くなり、一回ごとに力なく萎びていくように見えた。",
              "citation": {
                "source": "青髯二百八十三人の妻",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "検事は被告席に坐るわれわれ一同を指さして、鋭くこういった。",
              "citation": {
                "source": "戦争医学の汚辱にふれて",
                "author": "――生体解剖事件始末記――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
