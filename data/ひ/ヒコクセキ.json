[
  {
    "uuid": "b0bf9e04-d63e-50f9-a256-ceb527865661",
    "entry": "被告席",
    "reading": {
      "primary": "ひこくせき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
