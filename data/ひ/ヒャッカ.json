[
  {
    "uuid": "1d82fa6a-ed28-56dd-8639-4fd9d72e0486",
    "entry": "百科",
    "reading": {
      "primary": "ひゃっか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "many objects (for study)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この頃『大英百科全書』の第九版の編輯が進行していた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後日彼は、あるアメリカの農夫が『百科全書』を買ってＡからＺまで通読しているという噂をして「私の波動論をどう片付けるか見ものだ」と云った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "恩給のことなら百科辞典以上に知りぬいていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして同時に博物館であり、百科辞典であり、また一種のユニヴァーシティであるのである。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またそれらのはなしが金字の厚い何｜冊もの百科辞典にあるようなしっかりしたつかまえどこのあるものかそれとも風や波といっしょに次から次と移って消えて行くものかそれも私にはわかりません。",
              "citation": {
                "source": "サガレンと八月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きなお世話でサア……文科の生徒さんなんかは、試験前にチョイチョイ来て、アノ棚の上の大きなウエブスターの辞書だの大英百科全書を抱え下して、入り用な字を引いちゃってから、そのまま置きっ放しぐらいは構いませんが、ノートに控えるのが面倒臭いんでしょう。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "復一はそのバロック時代なるものを知らないので、試験所の図書室で百科辞典を調べて見た。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（以上、日本百科大辞典に拠る）　津軽の歴史は、あまり人に知られてゐない。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを簡明直截に疑はず規定してゐるのは、日本百科大辞典だけであつたから、一つの参考としてこの章のはじめに載せて置いた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その連署者には大英百科全書に執筆せる諸學者も總て之に加はり、日本で熟知せらるるスペンサー、ユーゴーなども特に數行を書添へて署名しました。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くとも大隈重信の法螺は、百科辞典の範疇を出でないのに対して、法螺丸の法螺はたしかに百科辞典を超越した一種の洒落気と魔力とを兼ね備えている。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことは、現代の無償教育・百科事典においてさえ、いくぶん稀にしか為しえない。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "全米百科全書のＫの巻を渡してくれたまえ。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『大英百科事典を書き写すのです。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいたい、どこのどいつがそんな遺言を書いて、大英百科事典を書き写す、そんなつまらない仕事にこんな金を払うんでしょうか。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "百科事典を筆写した赤毛の男の異常な話。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "百科事典を筆写させる。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本百科大辭典を見るに、同じ犬張子の名で異製異用の者が種々有たらしい。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は『大英百科全書』のしるすところである。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時、私はよく百科事典などを調べて、わからない言葉に自分なりの注を付けていきます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅行者が必要とするあらゆる知識と知恵の宝庫として評判の高い『ガイド』の本文には、百科事典流の項目別記述が採用されています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「銀河の知識を集成した百科事典」といえば、ＳＦファンの脳裏にはもう一つの大著が、即座に浮かぶでしょう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある条件を与えたら人はどう振る舞うだろうかを詰めていく、心理シミュレーション小説の傑作、アイザック・アシモフのファウンデーション・シリーズに登場する、『銀河百科大事典』です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『銀河ヒッチハイカーズ・ガイド』の冒頭で彼は『銀河百科大事典』にも触れていて、遺漏やかなりいい加減な記述があるにも関わらず、『ガイド』が『事典』をしのぐ人気を集め始めた理由を挙げています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "刊行作業の中心となっているテルミナスの百科事典ビルには、植字部という活字を並べていく部門があるのですから、銀河帝国においても、本作りの技術はグーテンベルクの確立した手法からたいして進歩していないものと思われます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＳＦの中に登場した二つの巨大な百科事典は、紙の本から電子本へと移行することで大きく変わりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "文章をまとめる際は、『岩波国語辞典』から始まって、『広辞苑』や講談社の『大字典』、平凡社の『大百科事典』、岩波書店の『近代日本総合年表』などを引きづめです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "念の入ったことに平凡社の百科事典は旧版の『世界大百科事典』まで並んでおり、この二つだけでかなりのスペースを食っています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
