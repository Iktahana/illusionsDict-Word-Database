        "examples": {
          "standard": [
            {
              "text": "彼はその大きな肥満体を揺らしながら、ゆっくりとした足取りでこちらへ歩いてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "相撲取りは土俵で当たり負けしないよう、稽古と食事で立派な肥満体を作り上げる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あんなにスリムだった彼が、数年でこんな肥満体になっていて驚いたよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "体重だけを問題にするなら、福山俊樹は誰の目にも肥満体だった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "分かってるのか、ついさっきまで、あの肥満体の資本家を凶悪犯のように見ていたな。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
