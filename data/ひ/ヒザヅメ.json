        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "膝詰めで買収にかかってみた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして、今日は伯母様が膝詰めの掛合いである。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとみそのが膝詰めで教育論を弁じることがあつた。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、それが悪ければどうともしてくれと膝詰めで談判したんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "春の雪解",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言って、膝詰めで来たものもあれば、ビタちゃんのお袖にすがって、ぜっぴ、お刺身のツマになりともありつきたい、と歎願に及んで来た奴もある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "大挙して、具足屋東兵衛に膝詰め談判をした。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはお前が帰ったあと、おせい様の家へ出かけて行って、膝詰め談判をしてみた。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しそれが實行されないならわたくしはこの屋敷から出て行かないと、かんさんはななえに膝詰めで言ひ寄つた。",
              "citation": {
                "source": "渚",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉三郎は河豚で死んだんぢやねえ、立派に毒害されたんだ」　通夜の人數を追つ拂つて、八五郎に見張らせた平次は、吉三郎の死骸を中に、お由と膝詰め談判を始めたのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鉄砲汁",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉三郎は河豚で死んだんじゃねえ、立派に毒害されたんだ」　通夜の人数を追っ払って、八五郎に見張らせた平次は、吉三郎の死骸を中に、お由と膝詰め談判を始めたのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "鉄砲汁",
                "note": "青空文庫"
              }
            },
            {
              "text": "膝詰めである、うっかりすれば腋の下を擽りかねない。",
              "citation": {
                "source": "百足ちがい",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みつ枝のように含みやほのめかしぬきの、いってみれば膝詰め談判であった。",
              "citation": {
                "source": "百足ちがい",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "選挙事務長の大石が、金五郎の前に正坐して、悲憤の面持で、膝詰めしているだけだ。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は米谷（柴田外記）どのから事情を聞いたのだが、年が明けると一ノ関が帰国する、そのとき大学は、一ノ関に膝詰めで六カ条の申しいれをするといきまいているそうだ」「六カ条とは」甲斐が眼をあげた。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその沢庵は、武蔵の処置をしてから姫路藩の家来たちと何か客間で膝詰めの相談事をしていた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪しからん」　と丞相府へやってきて、孔明に膝詰めで談じつけたのである。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
