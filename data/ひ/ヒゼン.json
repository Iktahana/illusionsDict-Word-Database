  {
    "uuid": "2d2fed75-c4a5-54bd-8ba9-9ae6bfe13984",
    "entry": "肥前",
    "reading": {
      "primary": "ひぜん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Hizen (former province located in present-day Saga and Nagasaki prefectures, excluding Tsushima and Oki Islands)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "肥前長崎から、東の方へゆく街道の上だつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋で使を肥前名護屋に遣はし、秀吉の陣を犒ひ、三年正月には従四位下右京大夫となり、慶長五年関ヶ原の役には、兵を出して徳川家康の軍に従ひ、西上して大垣に戦ひ、上野国大館二千石を加増す。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥前名護屋に在って太閤に侍して居た頃、太閤が朝鮮陣の思うようにならぬを悦ばずして、我みずから中軍を率い、前田利家を右軍、蒲生氏郷を左軍にして渡海しようと云った時、氏郷が大に悦んで、人生は草葉の露、願わくは思うさま働きて、と云ったことは名高い談である。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時氏郷邸で雁の汁の会食があって、前田肥前守、細川越中守、上田主水、戸田武蔵守など参会したことがあった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時氏郷は、あれあれ、あの親父、と云って肥前守利長を指さした。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "東　亭主の好きな赤烏帽子西　寺から里へ　松浦肥前守、赤き烏帽子を戴きしといふ奇解の塩尻に出でしより、人皆之に従ひて怪まず、多くの画にも、人の赤き烏帽子冠れるさまを描きたれど、土地によりては、赤烏帽子と云はずして、「亭主の好きな赤鰯」といふもあるなり。",
              "citation": {
                "source": "東西伊呂波短歌評釈",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛政四年一月には、肥前温泉岳の普智山の噴火があった。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ここ肥前長崎港のただなかは長雨ぞらの幽闇に海づら鈍み、悶々と檣けぶるたたずまひ、鎖のむせび、帆のうなり、伝馬のさけび、あるはまた阿蘭船なる黒奴が気も狂ほしき諸ごゑに、硝子切る音、うち湿り――嗚呼午後七時――ひとしきり、落居ぬ騒擾。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥前の呼子ち知っとんなはろが。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｏ氏は日露戦役の志士沖禎介氏のお父さんで、肥前は有田の弁護士である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、皇后はご出征のまえに、肥前の玉島というところにおいでになって、そこの川のほとりでお食事をなさったことがありました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "加賀家は肥前守斉広卿の代が斉泰卿の代に改まる直前である。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝賀野次郎兵衛には、土居肥前勝行をやった。",
              "citation": {
                "source": "八人みさきの話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは肥前唐津の者。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その喜多流を酌んだ由来も、もとより詳でないが、元亀天正の乱世に、肥前に似我という忠勇無双の士が居た。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵器船舶の整備を急がせると共に、黒田長政、小西行長、加藤清正をして、肥前松浦郡｜名護屋に築城せしめ、更に松浦｜鎮信をして壱岐｜風本（今勝本）に築かしめた。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "立花宗茂島原戦之覚書　　肥前国有馬古老物語　　原城紀事　　徳川実記　　其他",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は佐賀縣の或る金滿家の息子で、急に學校が厭になると郷里に歸つて、以後一切關係を斷つ約束のもとに家から數萬圓の金を分けて貰ひ、肥前の平戸沖あたりの小さな島を全部買ひ切つて一人して其處へ移り牛や鷄を放し飼にして樂しんでゐた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "島三題",
                "note": "青空文庫"
              }
            },
            {
              "text": "英人リチャード・コックス『江戸日本日記』一六二二年（元和八年）二月二十一日の条、コックス江戸にあり芝居に之く途上オランダ館に入り肥後か肥前の王に邂逅す、武勇な若い人で年々五十万石を領す、今蘭人に事え居る僕一人、先にかの王に事えた縁によりオランダ館を訪ねたのだ。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとには男子に、短い運命を持った棟蔵と謙助との二人、女子に、秋元家の用人の倅田中鉄之助に嫁して不縁になり、ついで塩谷の媒介で、肥前国島原産の志士中村｜貞太郎、仮名北有馬太郎に嫁した須磨子と、病身な四女歌子との二人が残った。",
              "citation": {
                "source": "安井夫人",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この少弐一家のいる所は肥前の国なのである。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを聞くと監は不安がって、自身で肥前へ出て来た。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私たちも初めは不似合いな求婚者だ、お気の毒だと姫君のことを思ってましたが、考えてみると、自分たちの後ろ立てにするのには最も都合のいい有力な男ですから、この人に敵対をされては肥前あたりで何をすることも不可能だということがわかってきました。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "大夫の監はいったん肥後へ帰って四月二十日ごろに吉日を選んで新婦を迎えに来ようとしているうちに、こうして肥前を脱出するのである。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "今さら肥前へ帰るのも恥ずかしくてできないことであった。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて人間に催姙の薬あらば、畜類にもそんな物あるべしとの想像から出たものか、肥前平戸より三里ほどなる生月島に、古来牧馬場あり、かつて頼朝の名乗｜生嘱を出すという。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "成田肥前守、城代たり。",
              "citation": {
                "source": "石田堤",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗り手は先ず第一に肥前家の臣で、大坪流の古高新兵衛。",
              "citation": {
                "source": "旗本退屈男　第三話",
                "author": "後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷たい楓の肌を見ていると、ひぜんのようについている蘚の模様が美しく見えた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
