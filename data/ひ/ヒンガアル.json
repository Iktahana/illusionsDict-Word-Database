    "definitions": [
      {
        "index": 1,
        "gloss": "to be refined (character, manners)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かなりな作品があるのに観覧者の印象が空虚だとすれば罪は展覧会という無理な制度にあるのだろう。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして最も純潔な尼僧の生活から、一朝つまらぬ悪漢に欺かれて最も悲惨な暗黒の生涯に転落する、というような実験を、忠実に行なった作品があるとする。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "りんとして、この世のものとも思えぬ気品がある。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はね、お爺さん、宵からお目に掛っていた客が、帰りがけにこの橋から放生会をなすった品があるんです。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことの貴族には、このやうな無邪気なつくろはぬ気品があるものだ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "純粋に日本の寂びと気品がある。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "性格的｜乃至心理的小説と誇称する作品がある。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な『夢魔』の他、シェークスピア・ギャラリー、ミルトン・ギャラリーなどにその作品がある。",
              "citation": {
                "source": "アッシャー家の崩壊",
                "author": "THE FALL OF HOUSE OF USHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "小倉氏は『静思』などといふ作品もあつて、婦人が端然と坐つて、右の手を机の上におき、左り手を袖の下にをいた作品があるが、かういふ形態のもつ計画的な良さは、一般に理解されることがなくして通りすぎたのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで化けかたの点で、もつと驚ろくべき作品がある。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "「胡馬」といふ作品がある。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "『漣』といふ作品がある、この作品は一言で言へば奇怪な作品なのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも島崎藤村氏の「食後」の中に、一寸此の時の心持に似たやうな心持を書いた小品がある。",
              "citation": {
                "source": "学生時代の久米正雄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はね、是非お受取申す品があるので、それを持つて帰りませんと都合が悪いのですから、幾日でもお待ち申しますよ」　彼は戸口に蹲りて動かず。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この老和尚を描いたものに、渡辺崋山の作品がある。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ第一に一つの時代は常に異つた、対立する階級を含んでゐるから「同時代人一般に亘つて享受せられる」作品があるとするのは、その作品の価値が階級を超越してゐることの証明になつて氏の期待とは全く反対の結論を生むことになるであらう。",
              "citation": {
                "source": "諸家の芸術価値理論の批判",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "御馳走してつかわす品があるゆえ、早速｜曳いて参れ」　すぐに走り出していった様子でしたが、程経て下僕が、一匹の見るからに剽悍無比などら猫を曳いて帰ったので、退屈男は手ずからそれなる不審の鯛をとりあげると、笹折ごとに投げ与えました。",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "御馳走してつかわす品があるゆえ、早速曳いて参れ」　すぐに走り出していった様子でしたが、程経て下僕が、一匹の見るからに剽悍無比などら猫を曳いて帰ったので、退屈男は手ずからそれなる不審の鯛をとりあげると、笹折ごとに投げ与えました。",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あがりぎわに何心なくひょいとその船の中をのぞいてみると、いともなまめかしい品がある。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、ひとつ、肝心のその話にうつるまえに、ぜひにだんなにお目にかけたい珍品があるんだがね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、目を射た品がある。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お多根どのは、あなたさまがだいぶおほめのようでござりましたが、このふしだらはどうしたのでござります」「いえ、これはほんの先ほど兄の敬之丞が参って、なにやらお多根に預けた品があるとか申し、捜して持ち帰ったようでおじゃりますゆえ、そのためこのように散らかしたのでおじゃりましょうよ」「なに！",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小娘の右手にはいぶかしいひと品がある。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツンとすましたようなところがあるのをいつも不愉快に思っていたが、今宵はそれがかえって品があるかのように見えた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも私の読んでいない作家にすぐれた作品があるかも知れぬが、探偵小説はやはり英米仏にとどめを刺すようである。",
              "citation": {
                "source": "ポオとルヴェル",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた達の心に氣品があると、この通り自分までが嬉しくなるのだ。",
              "citation": {
                "source": "悲しみの代價",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、お前はそうしていると、蒼ざめていて、気品がある。",
              "citation": {
                "source": "春は馬車に乗って",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "新村教授は本を読む画家の代表として富岡鉄斎をあげて、あの人の画には気品があるといつたさうだが、よしんば気品はあるにしても、鉄斎の画には画家の敏感が少しも出てゐない。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗く厚い壁にぶつかって撥ねかえった文学の姿において、深田久彌氏の「鎌倉夫人」があり、阿部知二氏の「幸福」があり、石坂洋次郎氏「若い人」、舟橋聖一、伊藤整等の諸氏の作品がある。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
