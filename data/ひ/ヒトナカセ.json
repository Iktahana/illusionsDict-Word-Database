        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "重兵衛　飛んでもねえ主人泣かせだな。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "李中行　今もそれを云っていたのだが、だんだん貧乏人泣かせの世の中になるばかりだ。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく人泣かせだ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃんとした名まえがあるのに、わざとこんな人泣かせをしなくたってもいいじゃござんせんか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "女も何人泣かせたかわかりやしねえ。",
              "citation": {
                "source": "ある僧の奇蹟",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうに人泣かせだ」　この北風にさからって江戸川橋の方角から、押し合うように身を摺り付けて歩いて来たのは、二人の中間である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私のような商売をしている人間には、雨位、人泣かせのものはありません。",
              "citation": {
                "source": "仙人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "開基は伝教大師さ」「あんな所へ寺を建てたって、人泣かせだ、不便で仕方がありゃしない。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ実に、人泣かせの退屈きはまる本ですよ。",
              "citation": {
                "source": "余はベンメイす",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "★　あとで聞いたところでは、ペルメルは生糸商人泣かせの札つきの悪者だったそうだ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "十本物だが、磨きは、自慢じゃあねえが、蘭法でも、ちょいと新しい式でね、いや、職人泣かせでしたよ、まったく。",
              "citation": {
                "source": "元禄十三年",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "草加屋は実に非道を極めた、貧乏人泣かせの高息の金貸しであった。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "無明の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなチヤラチヤラして居るくせに、恐ろしく勘定高くて握りつ拳で口やかましくて奉公人泣かせですよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "凧の詭計",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの男は親や兄を殺すやうな大それた人間ぢやない」「でも、親父が骨董に凝るのを苦々しがつて、あの人泣かせな道具を一つ殘らず叩き割つてやり度いと言つて居たさうですよ」「それとこれとは別だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "茶碗割り",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの男は親や兄を殺すような大それた人間じゃない」「でも、親父が骨董に凝るのを苦々しがって、あの人泣かせな道具を一つ残らず叩き割ってやりたいと言っていたそうですよ」「それとこれとは別だ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "茶碗割り",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ実に、人泣かせの退屈きわまる本ですよ。",
              "citation": {
                "source": "余はベンメイす",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ころがり出ろ」と洋先生は人泣かせ棒を振上げた。",
              "citation": {
                "source": "阿Ｑ正伝",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "「待て、主人、どこへ行く」　竜之助は呼び止めると、「このごろは諸国の浪人や無頼漢が入り込んで、商売人泣かせを働いて困るじゃ、見せしめのため、お代官へ行き申す」「待ってくれ」　竜之助はこの時、腰に差していた刀を鞘のまま抜き取って、亭主の前に置き、「では此刀を取ってくれ」「この刀を？",
              "citation": {
                "source": "大菩薩峠",
                "author": "壬生と島原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お金を貸して利息を取る商売なの」「そうだよ」「金貸しは貧乏人泣かせで、罪な商売だというじゃないか」「罪な商売かも知れねえが、俺らがそれをやるわけじゃない、俺らはただ奉公人なんだから」「そりゃそうさ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "女子と小人の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにもそんな人泣かせをしないでも」「いやこの女には、あっしはもう一ト目惚れだ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
