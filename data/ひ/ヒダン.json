    "entry": "匪団",
    "reading": {
      "primary": "ひだん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bandit gang",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "フランスではじまったマキ匪団の抵抗が一しきり華やかな話題となっていたのだ。",
              "citation": {
                "source": "美しき死の岸に",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも寺内はんだけは嫌ひだんね。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんで、そない鹿児島がお嫌ひだんね。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたへ、タバコ嫌ひだんがな、臭うて臭うて胸がわるうなる。",
              "citation": {
                "source": "兵隊の宿",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸福はとらへるのが難しいとらへても手の中で暖みを失ひだんだん啼かなくなつて死んでしまふ。",
              "citation": {
                "source": "自分は見た",
                "author": "千家元麿",
                "note": "青空文庫"
              }
            },
            {
              "text": "篠子　　それに、こなひだんとこは、おいしくないから、今日は何処か、ほかにしませうね。",
              "citation": {
                "source": "ママ先生とその夫",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
