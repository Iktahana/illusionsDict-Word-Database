        "examples": {
          "standard": [
            {
              "text": "寒い日に熱湯を注いだら、ガラスのコップがひび割れてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い家の土壁は、乾燥が進むとひび割れることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "強い衝撃でスマートフォンの画面がひび割れてしまい、修理に出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "白い毛の外套に身を包んだ彼女は、自分の足の下で、凍えた草のひび割れる音をきくような事もあった。",
              "citation": {
                "source": "菜穂子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "白昼の日光も井戸の中にはとどかず、周囲の地面は、庭のほかの場所が熱さのためにひび割れるときでさえ、じめじめしていて、いつも緑色であった。",
              "citation": {
                "source": "井戸",
                "author": "Ｗ・Ｗ・ジェイコブズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "二軒長屋になった隣との境の壁がぬき板に沿うてひびわれるのが見えた。",
              "citation": {
                "source": "変災序記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
