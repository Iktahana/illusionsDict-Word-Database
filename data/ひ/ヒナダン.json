        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "テレビ番組の収録スタジオには、ゲストが座るためのひな壇が用意されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "集合写真を撮影するために、全員の顔が見えるようひな壇を設置した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ひな壇の二列目に並んでください」とスタッフが声を張り上げている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
