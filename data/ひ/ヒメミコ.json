        "examples": {
          "standard": [
            {
              "text": "皇室の儀式では、次期皇太子となるであろう姫御子への期待が寄せられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "姫御子は、国民からの温かい祝福を受け、静かに微笑んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「将来、この姫御子が国を導くことになるのですね。」と、側近が静かに呟いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "先に生まれた三人の姫御子はあなたの身につけたものによつてあらわれたのですから、やはりあなたの子です」と仰せられました。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            }
          ]
        }
