        "examples": {
          "standard": [
            {
              "text": "この障子は、和紙が貼ってあるので柔らかく光を通す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "特殊なガラスは、紫外線をほとんど通さずに可視光だけを光を通す性質がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "薄い布地は、空気だけでなく光も通すので、涼しげに見える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それから谷の深い処には細かなうすぐろい灌木がぎっしり生えて光を通すことさえも慳貪そうに見えました。",
              "citation": {
                "source": "マグノリアの木",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おくみはその光を通す葉の色に、濃くうすく蔭が出来てゐるのを見入つてゐた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うん、その火精だが……かつて、水罎に日光を通すという技巧を、ルブランが用いた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど、澄んだ水が輝く陽の光を通すように。",
              "citation": {
                "source": "夕映えのむこうの国",
                "author": "時代を超えた童話",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
