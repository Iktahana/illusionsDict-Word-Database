[
  {
    "uuid": "4b7aa388-4e13-5004-9323-27f68630a301",
    "entry": "品性",
    "reading": {
      "primary": "ひんせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "character",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それで例へば欧羅巴の如きレリジョンの確立してゐる所では、それに批評の発達した所では、批評家は個人的に言葉を使用しないで社交的圏を相手に話すので、言葉は専ら比較によつて成立つ品性についての言葉が人の頭に滲みきつて、そのため驚きはその滲みきつた言葉で片附られ勝になるといふことは想像出来るでせう。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "独り蕪村がこの点で独歩であり、多くの秀れた句を書いているのは、彼の気質が若々しく、枯淡や洒脱を本領とする一般俳人の中にあって、範疇を逸する青春性を持っていたのと、かつ卑俗に堕さない精神のロマネスクとを品性に支持していたためである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の君は、もはや何人の眼に於ても、森林から出てきた原人ではなく、却つて教養あり、禮節あり、そして典雅の趣味を愛する所の、一個品性高き風韻の好人物である。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となれば、死生の際が人を詩化せしむる如く、戦争は、国民を詩化せしむるものにして、死生の際が人情の極致を発露する如く、戦争は実に、国民品性の極致を発露すべきものなれば也。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "独り国民を挙つて詩化し満目詩料ならざるなく、国民品性の極致を発露し口を開いて賛すべく、嘆すべく、歌ふべく、賦すべきの事に満つる戦時に於て、文士或は却て筆を収めむとするは何ぞや。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれの心の変わりゆきし跡を見たもうてあきれたもうとも笑いたもうとも泣きたもうとも、そは貴嬢が自由なり、されどあきるるも笑うも泣くもみな貴嬢が品性によりてのことなれば、あながち貴嬢が自由ともいい難し。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の日本が言う「紳士」とは、気概なく品性なき、成金的醜劣の人物の称呼であって、西洋のゼントルマンと根本的に別種である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "品性が、それから書物の品位が、幾らか卑しくなり勝ちである。",
              "citation": {
                "source": "文士の生活",
                "author": "夏目漱石氏−収入−衣食住−娯楽−趣味−愛憎−日常生活−執筆の前後",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに、短冊としては、詩歌に俳句に、繍口錦心の節を持すべきが、かくて、品性を堕落し、威容を失墜したのである。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし梅子｜嬢の欠点を言えば剛という分子が少ない事であろう、しかし完全無欠の人間を求めるのは求める方が愚である、女子としては梅子｜嬢の如き寧ろ完全に近いと言って宜しい、或は剛の分子の少ないところが却て梅子｜嬢の品性に一段の奥ゆかしさを加えておるのかとも自分は思う。",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕府のみ然るにあらず、その高等種族（武士）は、文芸を容れて大に品性を発揚したり、当時非凡なる学士の、彼等の社界に厚遇せられたる事実は、少しく徳川時代を知るものゝ共に認むるところなり。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のシバルリイは「我」を重んじて、軽々しく死し軽々しく生きず、我がシバルリイは生命を先づ献じて、然る後にシバルリイを成さんとするものゝ如かりし、己れの品性は磨くこと多からずして、他の儀式礼法多き武門に対敵して、反動的に放縦素朴に走りたり。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "各流の家元の中には、芸が下手なばかりでなく、品性や品行の点にも大きな欠陥を持った人も随分あった。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の茶と学問の奨励は、元亀天正の荒武者たちの品性を高めるためであり、同時に、幼時から粗暴と云はれる自らの性行の反省修養のためであつたとも考へられる。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈何といふにサンタもアヌンチヤタが品性の高尚なると才藝の人に優れたるとをば一々認むといひたればなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわんや、国民の気質品性を幾千年養成し来たれる宗教においてをや。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "」五「考えて見たまえな、名誉だの、品性だの、上流の婦人の亀鑑だのと、体の可い名は附けるものの、何がなし見得坊なんじゃあないか。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にものいいの判然として訛のないのは明にその品性を語り得た。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりの低額予算にお得意さんの頭の中身を疑い、やなことはみんな押しつける出版社の社員の品性を奥歯でなじり、こんな額で仕事を請けてくる親父の卑屈を呪った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "品性と共に教養を欠くオレは、後になってからマッキントッシュを支えたアイデアが一九七〇年代にゼロックスのパロアルト研究所でアラン・ケイらによって育まれていたことを知った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ＶＰｉ３８６は、ＣＰＵとしてインテル製３８６ＳＸあるいはＡＭＤの３８６ＳＸＬ―25のどちらでも採用可能だが、製品性能と電池寿命を特徴とするためには、ＡＭＤの製品が最適である」リリースはエデン・グループの技術部長ニール・フリントの発言をこう引いている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば無智蒙昧の監守どもが、妾の品性を認め得ず、純潔なる慈しみの振舞を以て、直ちに破倫非道の罪悪と速断しけるもまた強ちに無理ならねど、さりとては余りに可笑しく、腹立たしくて、今もなお忘れがたき記念の一つぞこれなる。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京在住中、妾は数たる口気に接して自ずから野鄙の情も失せ、心ざま俄に高く品性も勝れたるよう覚えつつ、公判も楽しき夢の間に閉じられ、妾は一年有余の軽禁錮を申し渡されたり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に監獄の改良を計らんとせば、相当の給料を仕払いて、品性高き人物をば、女監取締りとなすに勉むべし。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のような者には、とても理解できぬくらいに貴い品性を有っていた人ではなかったろうかと思った。",
              "citation": {
                "source": "散華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹さんの品性の光が、竹さんを美しく見せているだけの話だ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土牛、桂華二人展のときも、ある批評家が土牛の神品性を直ちに唱へたが、桂華の作品は常識的で新味工夫を欠くと批評した。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそろしいのは商品性である。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人ガ妻タリ母タル勞働ノミトナラバ、夫タル勞働者ノ品性ヲ向上セシメ、次代ノ國民タル子女ヲ益々優秀ナラシメ、各家庭ノ集合タル國家ハ百花爛漫春光駘蕩タルベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
