        "examples": {
          "standard": [
            {
              "text": "昔ながらの挽き臼で、ゆっくりと豆を挽いて粉にした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "博物館には、古い時代の挽き臼が展示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地方では、今でも挽き臼を使って蕎麦粉を作っている家庭がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "パチパチいって破れる殻から、薄黄色い果を出しては、挽き臼でつぶすのである。",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "風よ、ふけ、ふけ風よ、ふけ、ふけ、ひきうすまわせ、粉屋粉ひき、パンやさんがこねて、朝はほやほやふかしたて。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            }
          ]
        }
