[
  {
    "uuid": "4b8f77da-1b56-526f-93b7-83acbe604869",
    "entry": "人目につく",
    "reading": {
      "primary": "ひとめにつく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
