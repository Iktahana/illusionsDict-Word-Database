        "examples": {
          "standard": [
            {
              "text": "子供たちは裏山に自分たちだけの秘密基地を作って遊んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このアジトは、かつてレジスタンスの秘密基地として使われていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "僕らは夏のあいだ、毎日秘密基地に集まって作戦会議を開いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "考えれば考えるほど、たいへんな秘密基地です。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに　こびとたちに　よれば、　そのおおきな　いきものに　けちらされたところは　ここから　ほんのすぐそば、　ぶさいくな　いぬころの　あんないで　まっすぐ　このサンタの　ひみつきちに　むかっているとのこと。",
              "citation": {
                "source": "ババールとサンタのおじさん",
                "author": "BABAR ET LE PERE NOEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "でしたら　むしろ　それまで　このひみつきちから　はなれて、　そとの　くうきを　すって、　しっかり　おやすみしては　いかがでしょう。",
              "citation": {
                "source": "ババールとサンタのおじさん",
                "author": "BABAR ET LE PERE NOEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくるひには、　サンタの　おじさんも　また　マシンで　とびたって、　じぶんの　ひみつきちへ　こびとさんのところへ　もどります。",
              "citation": {
                "source": "ババールとサンタのおじさん",
                "author": "BABAR ET LE PERE NOEL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
