    "definitions": [
      {
        "index": 1,
        "gloss": "running swiftly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大谷川がもう恐ろしく發達して大きな河原になつてゐるのを越して、車はひた走りに大桑といふを過ぎると、頓て稀有なる好景に出會した。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はすぐに料亭から走り出て、夕闇の道をひた走りに走り、ただいまここに参りました。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「両人とも早いぞ早いぞ」と声をかけて置いて、ひた走りに馳けて熱田の宮前に着いた時は、その数千八百となって居た。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "マンチェスター駅まではひた走りに走ることが出来るはずだった。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "……震え、震え、段を戻って、もう一度巻込んで、それから、ひた走りに、駆出しましたが。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一頭はひた走りに先に進む。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "田甫を渡って文造はひた走りに走った。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところは寂びたり、人里は遠し、雨の小止をまたんよすがもなければ、しとど降る中をひた走りに走らす。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "家を出ずる時は甲斐に越えんと思いしものを口惜とはおもいながら、尊の雄々しくましませしには及ぶべくもあらねば、雁坂を過ぎんことは思い断えつ、さればとて大日向の太陽寺へ廻らん心も起さず、ひた走りに走り下りて大宮に午餉す。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "いでやと毛布深くかぶりて、えいさえいさと高城にさしかかれば早や海原も見ゆるに、ひた走りして、ついに五大堂｜瑞岩寺渡月橋等うちめぐりぬ。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗黒の中を少年は、ひた走りに仄明るい夜空をめがけて走りだした。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "取りにがしてなるものかと、葉子はひた走りに走ろうとした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "４あな額白きわが友が、ひた走り入る湊江よ、朝潮はやく打よせて浪の音どよむ紀伊の海。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、さっと息づえをあげると、早い早い、よくよく伝六がせきたてて迎えによこしたとみえて、柳橋を渡り越えるとひた走りに浅草目ざしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　なだめすかしても聞かばこそ、くろは必死にしがみついている伝六を背中に乗せて、ひた走りに走りつづけました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "気をつけろッ」　わけもなくただふきげんにどなりつけて、ひた走りに神田へ駕籠を急がせました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "振り返ってみる勇気もなくて、ただひた走りに走りつづけた挙句、ようよう遥か遠くに、蛍火の光っているように見える提灯を見つけて、その方に向って行った。",
              "citation": {
                "source": "貉",
                "author": "MUJINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "止まるべき家もないので、馬車は雨を衝いてひた走りに走る。",
              "citation": {
                "source": "木曾御嶽の両面",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈結局は何だったんだろう〉　成功のレールに乗ってひた走りはじめたＰＣ―８００１を前に、松本は自分自身をマイクロコンピューターに向かわせたものはなんだったのかを、繰り返し問いなおすようになっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェレ※ークはといふと、まるで熱湯でもぶつかけられたもののやうに、帽子の代りに甕を頭にかぶつて、戸口へ駈け出すなり、狂人のやうに、ろくろく足もとも見ずに往来をひた走りに走つたが、やうやく疲労のために駈ける足の速力がゆるんで来た。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼芋屋で温かい芋を風呂敷に包んでもらって、再びまたもとの森の下を何物かに追っかけられるような気に追い立てられながら、ひた走りに走って家の中に飛び込んだ。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、彼は、事によったら、犬が追いあぐんで、どこかに逃げ場ができるかもしれないという、一縷の望みにたよりながら、打ちはずした太刀を引いて、おりから足をねらった犬の背を危うく向こうへとび越えると、月の光をたよりにして、ひた走りに走り出した。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、表通を曲って、柳の植わっている見とおしのいい小路へ出ると、忽ち彼等はひた走りに走りだしたいような衝動に駆られる。",
              "citation": {
                "source": "昔の店",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "友木は譫言のように口の中でブツブツ呟きながら、ひた走りに走っていた。",
              "citation": {
                "source": "罠に掛った人",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "極度の緊張から驚駭へ、驚駭から失望へ、失望から弛緩へ、私は恐ろしい夢と、金を取戻した儚い喜びの夢を、夢現の境に夢みながら、琵琶湖の畔をひた走りしていた。",
              "citation": {
                "source": "急行十三時間",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、何うにか抜けてひた走りに、一刻でも早くお新に、それからお俊に――そう思ってもう大丈夫と信じていても猶走っていた。",
              "citation": {
                "source": "新訂雲母阪",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "何處へか、誰も知らず、まつ暗な野原の眞ん中をひた走りに走つてゐる夜汽車のなかに、一人目覺めて、哲學の本を讀んでゐる、或者の姿！",
              "citation": {
                "source": "二三の追憶",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし時刻が切れるので、高い駕籠を雇うか、さなくば猿若から屋敷までひた走りに走りつづけた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "妬心の花嫁このこころ、つばさのはえた、角の生えたわたしの心は、かぎりなくも温熱の胸牆をもとめて、ひたはしりにまよなかの闇をかける。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
