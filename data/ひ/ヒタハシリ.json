[
  {
    "uuid": "c9b82dd4-b0c9-543e-8a47-2c9b5a3e8248",
    "entry": "ひた走り",
    "reading": {
      "primary": "ひたはしり",
      "alternatives": [
        "ひたばしり"
      ],
