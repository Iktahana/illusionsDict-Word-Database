[
  {
    "uuid": "d694cb1c-42c7-59d2-9a4c-3d4175c9d9f5",
    "entry": "妃殿下",
    "reading": {
      "primary": "ひでんか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
