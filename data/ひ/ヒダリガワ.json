    "definitions": [
      {
        "index": 1,
        "gloss": "left side",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "左側壁に一つの大きい窓。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学の玄関の左側にはちょっとした売店があって文具や、それから牛乳パンくらいを売っていたような気がする。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを這入って黒板塀と竹藪の狭い間を二十｜間ばかり行くと左側に正岡｜常規とかなり新しい門札がある。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "左側に机があって俳書らしいものが積んである。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "左側の柵の中で子供が四、五人石炭車に乗ったり押したりしている。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "左側の水楼に坐して此方を見る老人のあればきっと中風よとはよき見立てと竹村はやせば皆々笑う。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある横町を這入って行くと左側にシャボテンを売る店があった。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷のことだから、水を横に切っては、右側へ移ったり、左側へ寄ったりする、私の前には、猟師が、鍋や米袋をしょって行く。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る町の角をまがつて左側に蝋細工の皮膚病の模型を並べた店が眼についた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その三つならんだ入口の一番左側には空箱に紫いろのケールやアスパラガスが植えてあって小さな二つの窓には日覆ひが下りたまゝになってゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに出した地図で左側の陸地が阿波、右側の陸地が淡路です。",
              "citation": {
                "source": "瀬戸内海の潮と潮流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷中の台地から田端の谷へ面した傾斜地の中腹に沿う彎曲した小路をはいって行って左側に、小さな荒物屋だか、駄菓子屋だかがあって、そこの二階が当時の氏の仮寓になっていた。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもは左側にある街路の町家が、逆に右側の方へ移ってしまった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ今まで、左側にあった往来が右側になり、北に向って歩いた自分が、南に向って歩いていることを発見した。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにはいつもの理髪店が、客の来ない椅子を並べて、白昼の往来を眺めているし、さびれた町の左側には、売れない時計屋が欠伸をして、いつものように戸を閉めている。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の小止みなき生のかたはらには、右側にも左側にも、有力な證人が控へて居つたとは云へ。",
              "citation": {
                "source": "モオリス・ド・ゲラン",
                "author": "「そしてこの稀有で、偉大で、しかも果敢ないもの、一個の詩人」",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の左側にゐる中根二｜等卒はもう一｜時間も前から半分口をダラリと開けて、眠つたまま歩いてゐた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　丘の左側には汽車が通っていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに立って左側の窓をあけたが風を引きかえしてはいけないと思ってすぐにまた締め切った。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっすぐにはいると、左側に大きい井戸があった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし長屋は右側ばかりで、左側の空地は紺屋の干場にでもなっているらしく、所まだらに生えている低い秋草が雨にぬれて、一匹の野良犬が寒そうな顔をして餌をあさっていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "門をくぐると左側に花屋があった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "左側の樅やえぞ松がある山の間にパルチザンが動いているのが兵士達の眼に映じた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らく、市三の脇から鉱車を押す手ごをしたが、やがて、左側の支坑へそれてしまった。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その稲光りのそらぞらしい明りの中で、ガドルフは巨きなまっ黒な家が、道の左側に建っているのを見ました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道の左側が細い谷になっていてその下で誰かが屈んで何かしていた。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その三つならんだ入口の一番左側には空箱に紫いろのケールやアスパラガスが植えてあって小さな二つの窓には日覆いが下りたままになっていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の影は左側から右側に移しただけでやはり自分の前にあった。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だナ、と鈍い声をして、土間の左側の茶の間から首を出したのは、六十か七十か知れぬ白髪の油気のない、火を付けたら心よく燃えそうに乱れ立ったモヤモヤ頭な婆さんで、皺だらけの黄色い顔の婆さんだった。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果から、「左側通行」の規則が、どの程度まで市民の頭にしみ込んでいるかを判断する一つの目安を定めることも可能である。",
              "citation": {
                "source": "物質群として見た動物群",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
