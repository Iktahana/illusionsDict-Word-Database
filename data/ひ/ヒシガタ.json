        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "どれもこれも白い菱形の小さな凧で、僕の魂の如くはかなく風に浮揚してゐる。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "うらやましくて、私のこしらへたのはしかし、さすがに墨色では粋すぎるので薄紫で菱形を大きく出して見ました。",
              "citation": {
                "source": "縮緬のこころ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一輪車は菱形の帆をふくらましたまゝ貧民窟から、その兵営の土煉瓦のかげへかくれて行った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「菱形の脚」「砂埃」「花」の三つの「支那風景」は「光について」などと竝行して書かれたものである。",
              "citation": {
                "source": "詩集『戰爭』",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "菱形の脚の間に見えてゐる風景、女の姿をかくしてしまふ砂埃、心憎いことである。",
              "citation": {
                "source": "詩集『戰爭』",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と見ると、処々に筵を敷き、藁を束ね、あるいは紙を伸べ、布を拡げて仕切った上へ、四角、三角、菱形のもの、丸いもの。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……頬骨の張った菱形の面に、窪んだ目を細く、小鼻をしかめて、「くすくす。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その船は舷側に菱形の桟を嵌めた船板を使ったので、菱垣船と云った。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもこの辺の田野の名物である榛の木立が畦道の碁盤目や綾菱形の上に立ち並び、その梢には乾びた実が房になって懸かり、吹きすさぶ夜風に絶えず鳴るのでその音からしてだけでも、微塵の玉屑が空に立ち昇るように感じられるそのためにか月下の世界は白檀の燻気ほどにはほのかな色に染められているように思われます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "賭博場を取巻く角や菱形に区切られた花園は夜露に濡れ、窓から射す燈に照らされ、ゴムを塗った造花の様に煌ついて居る。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に装飾風の尾鰭を大切そうに静かに動かして泳いでいる菱形の魚。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "形は小さいが、三十枚ばかりずつ幾山にも並べた、あの暗灰色の菱形の魚を三角形に積んで、下積になったのは軒下の石に藍を流して、上の方は浜の砂をざらざらとそのままだから、海の底のピラミッドを影で覗く鮮しさがある。",
              "citation": {
                "source": "鏡花氏の文章",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、博士の頭を巻いていたあやかしが動き始め、髪の毛の中からずんぐりと太い菱形の頭を持った忌まわしい蛇が、ぬっと鎌首をもたげたではないか。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "またたくまに部屋はその形をかえて菱形となった。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていまや菱形は、なにも考えるひまを与えないくらいの速さでますます平たくなってきた。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "――希代なのは、その隙間形に、怪しい顔が、細くもなれば、長くもなり、菱形にも円くもなる。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "形は小さいが、三十枚ばかりずつ幾山にも並べた、あの暗灰色の菱形の魚を、三角形に積んで、下積になったのは、軒下の石に藍を流して、上の方は、浜の砂をざらざらとそのままだから、海の底のピラミッドを影で覗く鮮さがある。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖は一帶に唯拭つた如く平らで踏ん込んだ山の脚近くには丁度建て干した網の目のやうな菱形がほのかに水面に現はれて居る。",
              "citation": {
                "source": "彌彦山",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "※銚子出るときゃ涙で出たが……　小声で唄いながら、お絹は片手で膝をたたいて拍子を取ると、蛇はなめらかな膚に菱形の尖った鱗を立てて、まぶたのない眼を眠るようにとじた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず第一は菱形屋でしょ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより、早く駕籠を呼んできな」　命じて息づえをあげさせながら、ゆうぜんと深川さして駕籠をうたせていくと、乗りつけたところは伝六のいったその菱形屋でありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は菱形の盆を大きくしたような寝台に平臥して、金縁の附いた天鵝絨の布団を鼻の下迄引張るのである。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "菱形の西洋凧を飛ばし、朱色の面（朱色人面の凧、Tonka John の持つてゐたのは直徑一間半ほどあつた。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他は概ね和風凧の菱形のものを用ゆ。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしの郷里の方で普通に取れます蟹は、俗にいばら蟹といいまして、甲の形がやや三角形になっていて、その甲や足に茨のような棘がたくさん生えているのでございますが、今晩のは俗にかざみといいまして、甲の形がやや菱形になっていて、その色は赤黒い上に白い斑のようなものがあります。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "天井に薄い布を張った菱形の非常口があるからだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは十字架を花の環の形に、あるいは菱形に、あるいは円形に意匠したその窓々の尖端、あるいは緑と紅との色の中心に描かれてある聖者の立像、それらが皆夕日に輝いた。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "手の込んだ細工の銀台といい、立派な菱形に截った石の大きさ、艶といい、調和のよい上衣の色を背景に、非常に美しく見える。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し夫れ臨檢警官の差押へたる書中、其録する所全く社會主義に關せざるも猶題號に「社會」の二字あるが爲に累を受けたるものありしといふに至りては、殆ど一笑にも値ひしがたし。",
              "citation": {
                "source": "日本無政府主義者陰謀事件經過及び附帶現象",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
