        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "堀に沿うて牛が淵まで行って道端で憩うていると前を避難者が引切りなしに通る。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方に駒込の通りへ出て見ると、避難者の群が陸続と滝野川の方へ流れて行く。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはもちろん、避難者の荷物が豊富な焚付けを供給したためである。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場は、持てるだけ荷物をかゝえこんだ青島への避難者でごった返した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "避難者は、そのあとから、まだ、まだ押しよせて来た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＫＳ倶楽部へは、あとから、あとからといくらでも避難者が押しよせて来た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、やつと佛壇へ納めたばかりの位牌を、内中で、此ばかりは金色に、キラリと風呂敷に包む時、毛布を撥ねてむつくり起上つた――下宿を燒かれた避難者の濱野君が、「逃げると極めたら落着きませう。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "街路の左右には避難者の人浪が打っていた。",
              "citation": {
                "source": "変災序記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人の細君も避難者の中に交って筵の上に坐り、洋傘を日覆いにして、生れたばかりの嬰児を抱いていた。",
              "citation": {
                "source": "死体の匂い",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸川の方から入って来る避難者の中には、おりおり振り返ってその雲を悲しそうな眼で見る者があった。",
              "citation": {
                "source": "死体の匂い",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京駅の構内にも避難者が入っていた。",
              "citation": {
                "source": "死体の匂い",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉伝寺の竹林の中では既に避難者等の交交にあらゆる賤卑な物慾の争ひが起つてゐた。",
              "citation": {
                "source": "竹林生活",
                "author": "――震災手記断片――",
                "note": "青空文庫"
              }
            },
            {
              "text": "われに等しき避難者は、男女老幼、雨具も無きが多く、陸続として、約二十町の間を引ききりなしに渡り行くのである。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局避難者を乗せる為に列車が来るから、帰ってからでなくてはいけないということであった。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "我に等しき避難者は、男女老幼、雨具も無きが多く、陸續として、約二十町の間を引きゝりなしに渡り行くのである。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局避難者を乘せる爲に列車が來るから、それが歸つてからでなくてはいけないと云ふことであつた。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は到るところに船が焼けてその上に二三人の避難者の黒焦げになつて焼死してゐるのを眼にした。",
              "citation": {
                "source": "地震の時",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "道では、折々避難者の馬車に会った。",
              "citation": {
                "source": "勲章を貰う話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国大使館まえの千鳥ヶ淵公園附近に逃げあつまっていた番町方面の避難者は、そこも火の粉がふりかかって来るのにうろたえて、さらに一方口の四谷方面にその逃げ路を求めようとするらしく、人なだれを打って押し寄せてくる。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここらは震災の被害も少なく、もちろん火災にも逢わなかったのであるから、この頃は私たちのような避難者がおびただしく流れ込んで来て、平常よりも更に幾層の繁昌をましている。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "移転以来、花を生けて眺めるという気分にもなれず、花を生けるような物も具えていないので、さきごろの天長祝日に町内の青年団から避難者に対して戸毎に菊の花を分配してくれた時にも、その厚意を感謝しながらも、花束のままで庭の土に挿し込んで置くに過ぎなかった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここらにも避難者がたくさん集まっているので、どこの湯屋も少しおくれて行くと、芋を洗うような雑沓で、入浴する方が却って不潔ではないかと思われるくらいであったが、わたしはやはり毎日かかさずに入浴した。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここらにも避難者が沢山あつまっているので、どこの湯屋も少しおくれて行くと、芋を洗うような雑沓で、入浴する方がかえって不潔ではないかと思われるくらいであったが、わたしはやはり毎日かかさずに入浴した。",
              "citation": {
                "source": "風呂を買うまで",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国大使館まえの千鳥ヶ淵公園附近に逃げあつまっていた番町方面の避難者は、そこにも火の粉がふりかかって来るのにうろたえて、更に一方口の四谷方面にその逃げ路を求めようとするらしく、人なだれを打って押寄せてくる。",
              "citation": {
                "source": "火に追われて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途中で避難者を乗せているらしい支那人の荷車に出逢った。",
              "citation": {
                "source": "二階から",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここらは震災の被害も少く、勿論火災にも逢わなかったのであるから、この頃は私たちのような避難者がおびただしく流れ込んで来て、平常よりも更に幾層の繁昌をましている。",
              "citation": {
                "source": "十番雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "移転以来、花を生けて眺めるという気分にもなれず、花を生けるような物も具えていないので、先ごろの天長祝日に町内の青年団から避難者に対して戸ごとに菊の花を分配してくれた時にも、その厚意を感謝しながらも、花束のままで庭の土に挿し込んでおくに過ぎなかった。",
              "citation": {
                "source": "十番雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼は、たいへん夥しい避難者の列にぶつかってしまった。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "避難者等ハ恐怖シテ悲鳴ノ聲、題目ノ聲ガ各所ニ起ツタ。",
              "citation": {
                "source": "寺田先生と僕",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこここの樹蔭には、不幸な避難者の仮小屋も取払われずにある。",
              "citation": {
                "source": "食堂",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
