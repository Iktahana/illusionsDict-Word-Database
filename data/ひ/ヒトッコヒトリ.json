[
  {
    "uuid": "d52de6c1-21c2-5725-b5ac-ab2a85b51474",
    "entry": "人っ子ひとり",
    "reading": {
      "primary": "ひとっこひとり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(not) a soul",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "深夜、人っ子ひとり通らぬ街路を、吹雪だけが轟々の音を立て白く渦巻き荒れ狂い、私は肩をすぼめ、からだを斜めにして停車場へ急いだ。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右は麦畑のひくい岡で、人っ子ひとりおりません。",
              "citation": {
                "source": "のら犬",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで僕は二階に上ってみましたが、ひとけのない空っぽの部屋がふたつあるだけで、家じゅうどこにも、人っ子ひとりいません。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき見に来たときゃ、たしかに人っ子ひとりいなかったのに、変な虫けらが降ってきやがったんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらぬつじ切りのうわさは、城下の町のもののおびえやすい心をいよいよおびえさせたとみえて、行く道はげに死せるがごとく、人っ子ひとり見かけない寂しさでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこへ行っても人っ子ひとり会わなかった。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "木造の家や垣根がつづくだけで、どこにも人っ子ひとり見かけるではなく街路にはただ雪が光っているだけで、鎧扉をしめて寝しずまった、軒の低い陋屋がしょんぼりと黒ずんで見えていた。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "車道は、自動車がぎっしりつまって流れるように動いているが、歩道には人っ子ひとり影を見せない。",
              "citation": {
                "source": "字で書いた漫画",
                "author": "谷譲次",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく寝るのが惜しくなって、わたくしはよくその光にぬれて深夜まで人っ子ひとり居ない野や山を歩いたものだ。",
              "citation": {
                "source": "山の秋",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして今の私がそれならば書いてもみたいと思うものは、たとえどんなに平凡なものでもいいから、これから私の暮らそうとしているようなこんな季節はずれの田舎の、人っ子ひとりいない、しかし花だらけの額縁の中へすっぽりと嵌まり込むような、古い絵のような物語であった。",
              "citation": {
                "source": "美しい村",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋常ならば、たとえ牛であっても、こんな際に、房総第一の高山の上で、人っ子ひとりいないと信じていたところへ、不意にのっそりと現われて、体をこすりつけられるようなことをされては、大抵の子供は驚愕のあまり、悲鳴を上げて逃げ出すのがあたりまえですけれども、茂太郎は驚きません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "Ocean の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、胆吹の女傑のあとをたずねて見ましたが、館はあるが、人がいませんでした、人っ子ひとりおりませんでしたよ、解散したのでしょう。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラネーフスカヤ　わたしたちが行ってしまうと、ここには人っ子ひとり残らないのねえ……ロパーヒン　春が来るまではね。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこもかしこもシンとして人っ子ひとりいはしない。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "人っ子ひとりいないので安心しきった七、八人、すぐ仕事にとりかかればいいのに――。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまでたっても、人っ子ひとり出てこない。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "階下で宙に垂れ下っている死体を見て、それから階段を一足踏びに上って来る時、この部屋を開けて出る物音もせず、長い廊下に人っ子ひとりいなかった一事は、初太郎も宇之吉も、太鼓のような判を押すことができる。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "宙に浮く屍骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかあらぬか、お告者らしい白衣の女が夜な夜な磯屋の戸口を訪れるなぞという噂の尾に尾が生えて、神隠し事件と言い何といい、いつもならそぞろ歩きに賑わうはずのこの町筋も、一刻千金の涼味を捨てて商家は早くも鎧戸を閉て初め、人っ子ひとり影を見せない。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "巷説蒲鉾供養",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまた町家が、いずれも熟睡時間だから、戸を閉しきって人っ子ひとり通るのではないから、みようによっては、薄野原の無人境よりはいっそう荒涼たるものに見える。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうような空気であったのに、今日は――ではない、もう今宵と言っていい時刻なのに、人っ子ひとり来ない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――が、人っ子ひとりいなかった。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が暮れだすと、通りには、人っ子ひとりいなくなって、みんなが、うちにとじこもったあとには、なん百｜匹、なん千匹という犬のむれが、一｜晩じゅう、うなったり、ほえたりしていたものだ。",
              "citation": {
                "source": "キリストのヨルカに召された少年",
                "author": "フョードル・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "人っ子ひとりいなかったからである。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって、通りには、人っ子ひとり見えませんから。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "船の中に賊の部下がのこっているかもしれないと、用心しながら近づいてみますと、客室も機関室も、まったくからっぽで、人っ子ひとりいないことがわかりました。",
              "citation": {
                "source": "大金塊",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべでお祭りはすんだので、林の中はまっくらで、人っ子ひとりいません。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "林のむこうの原っぱには、人っ子ひとり見えません。",
              "citation": {
                "source": "塔上の奇術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼間はにぎやかな商店街も、廃墟のように静まりかえり、光といってはまばらに立ちならぶ街燈ばかり、人っ子ひとり通らないアスファルト道が、はるかにやみの中へ消えています。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "人っ子ひとりいないうす暗がりの中で、おいてけぼりにでもあったように、さも、さびしそうに泣いている女の子を見ますと、なんだかかわいそうでたまりませんでした。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その大通りには、人っ子ひとり通っていません。",
              "citation": {
                "source": "青銅の魔人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
