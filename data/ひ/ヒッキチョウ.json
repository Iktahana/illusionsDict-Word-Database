        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "机の上のラテンの筆記帳の上には、小さい手紙が一本ある。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の上にあつた筆記帳は部屋の隅へ投げた。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "四、フウケーボー大｜博士はあくびといっしょにノルデの筆記帳をすぽりとのみ込んでしまった。",
              "citation": {
                "source": "ペンネンノルデはいまはいないよ　太陽にできた黒い棘をとりに行ったよ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆記帳には組と名前を楷書で書いてしまったの。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔キッコは筆記帳をもってはねあがりました。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "も一つは新らしい筆記帳の使いはじめ字を書き損ねたときのことです。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆記帳を捨ててしまいたくなるのです。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "科目は教師が黒板に書いて教授するのを、筆記帳へ書取って、事は足りたのであるが、皆が持ってるから欲しくてならぬ。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "生徒はみんな大急ぎで筆記帳に黄という字を一杯書きましたがとても先生のようにうまくは出来ません。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはフウフィーヴオ博士の弟子　博士はおれの出した筆記帳を　あくびと一しょにスポリと呑みこんだ。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "読めない字があつても、考へたり、筆記帳をみたりするのが面倒なので、でたらめのことをいつて読んでいつた。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の言は、あたかも学舎にて学びし既成の教理をその筆記帳を見て繰返すが如くである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも大切に筆記帳にしるしておいた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "シュポーニカの筆記帳はいつもきれいで、いつぱいに罫がひいてあつて、どこを開いて見ても斑点一つついてゐなかつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "書籍ならば好いが、そんな筆記帳などをいつまでもそんな風に飾りたてゝおくことに自分は、自分にはそんなものは一切無かつたからさういふものに対する他人の保存癖も解らないわけだが、何だか妙な気がしたので一度彼に訊ねたら、彼はムツとして、「君は、実に他人に対して無礼な、卑俗な憶測をする奴だ。",
              "citation": {
                "source": "夏ちかきころ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今朝は、何故か大変に慌てゝ本箱の中の筆記帳みたいなものばかりをすつかり抱へて参りました。",
              "citation": {
                "source": "夏ちかきころ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よせよ」　人々を押しわけて光一が進みでた、かれは手に代数の筆記帳を持っていた。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「逃げるかッ」　木俣は光一の手首をたたいた、筆記帳は地上に落ちて、さっとページをひるがえした。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづれも大切に筆記帳に記して置いた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたの随意に、筆記帳でも控え帳でもお使いなすってよろしい」　証人はその意を諒して、胸のポケットから原稿をとり出した。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "妖物",
                "note": "青空文庫"
              }
            },
            {
              "text": "道也先生はやがて懐から例の筆記帳を出して、原稿紙の上へ写し始めた。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなた」　道也先生は、いつの間にやら、筆記帳を閉じて、今度はまた別の紙へ、何か熱心に認めている。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "和服の者は懐中へ筆記帳を四五冊無理やりに拈じ込み、右の手の人差指一本だけ袖口からちょいと出して、それへインキ壺を引っ懸けて行く。",
              "citation": {
                "source": "The Affair of Two Watches",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸此の中から筆記帳とインキを買わして呉れや。",
              "citation": {
                "source": "The Affair of Two Watches",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ある先生の授業のおりなどは、その時間じゅう、小学校の教室で権田原先生に教わっていた頃のことを思いうかべて、筆記帳にその似顔をいくつも書き並べていたことさえあった。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は郷土誌の記録や、筆記帳を取り出し、一冊ずつ入念にめくっていった。",
              "citation": {
                "source": "艶書",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
