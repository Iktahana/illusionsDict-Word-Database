        "examples": {
          "standard": [
            {
              "text": "古い城壁には、強固な控え壁がいくつも取り付けられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "建築家は、建物の安定性を高めるために、控え壁のデザインを工夫した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "大地震にも耐えられるよう、寺院の本堂には太い控え壁が設置されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "入り口には、いくらかの彫刻が施してあるが、荒彫りの砂岩石の柱が二、三本と、またその柱と同じ石の控え壁をもっている瓦ぶきの屋根があるばかり、ただそれだけのことでした。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "クラリモンド",
                "note": "青空文庫"
              }
            },
            {
              "text": "その音は控え壁から控え壁へとひびきわたり、廻廊にこだました。",
              "citation": {
                "source": "ウェストミンスター寺院",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "背の高い控え壁の中には崩落したものもあり、繊細な頂華の幾つかは茶色の雑草の中に半ば隠れていた。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "尖塔、控え壁、棟飾タイルが水鏡に浮かび上がった。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
