        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そしてそんな時、人のいい※の弱い奧さんは何の詞もなくたゞまぶたをうるませてゐるばかりだつた。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹太郎は王の眼から、眉間を打たれた瞬間の屠殺される去勢牛のように、人のいい、無抵抗なものを感じた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　山崎は、自分の支那服を忘れて、すっかり日本人のいい気持になっていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人のいい驢馬の稚気に富んだ尾籠、そしてその尾籠の犠牲になった子供の可愛い困惑。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが平二は人のいい虔十などにばかにされたと思ったので急に怒り出して肩を張ったと思うといきなり虔十の頬をなぐりつけました。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『おもしろいぞ、連れて行こうか、』人のいい叔父はにこにこしながら勧めた。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "人のいい優しい、そして勇気のある剛胆な、義理の堅い情け深い、そして気の毒な義父が亡くなってから十三年忌に今年が当たる、由って紀念のために少年の時の鹿狩りの物語をしました。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまがえるなんというものは人のいいものですからすぐとのさまがえるのけらいになりました。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい夏の取着きに、御主人のいいつけで、清酒をの、お前様、沢山でもござりませぬ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "約束すらあ」と、そのひどい男たちは言って、ヨハンネスの出したお金をうけとると、こいつは、なんて人のいいこぞうだ、と、笑いながら、行ってしまいました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の小さい、赤ら顔のデップリとした小男で、額の上に禿げ残った毛を真中からテイネイに二つに分けて、詰襟の白い洋服を着ていたが、トテモ人のいい親切らしい風付きで、悪魔らしいところはミジンも見えなかったのでガッカリしてしまった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、ものの言いぶりと人のいい顔色が、気を隔かせなければ、遠慮もさせなかった。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人のいいお豊も少しく腹立たしくなったらしく、眼をふきながら向き直った。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな風で義雄はこれまでにも老人のいい話し相手になつて來たのだ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故※を私などへ贈るように遺言したのだろうかと聞いても、若者はブッキラボウに、知らぬ、自分は唯故人のいいつけ通りに事を運んだ迄だ、と答えて、さっさと帰って行った。",
              "citation": {
                "source": "南島譚",
                "author": "※",
                "note": "青空文庫"
              }
            },
            {
              "text": "親切で人のいいあの親父が――あんな悪党に捕まるなんて。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "この野ネズミは人のいいおばあさんネズミでした。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "髮も頬鬚も半分白くなつた頑丈な大男で、一口二口話し合つてゐるうちにいかにも人のいい老爺であることを私は感じた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "青年僧と叡山の老爺",
                "note": "青空文庫"
              }
            },
            {
              "text": "人のいい車掌でした。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある人のいいまするに、デンマーク人はたぶん世界のなかでもっとも富んだる民であるだろうとのことであります。",
              "citation": {
                "source": "デンマルク国の話",
                "author": "信仰と樹木とをもって国を救いし話",
                "note": "青空文庫"
              }
            },
            {
              "text": "監督も懐旧の情を催すらしく、人のいい微笑を口のはたに浮かべて、「ほんとにそうでした」　と気のなさそうな合槌を打っていた。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "髮も頬鬚も殆んど白くなつた頑丈な大男で、一口二口話し合つてゐるうちにいかにも人のいい老爺である事を私は感じた。",
              "citation": {
                "source": "比叡山",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪も頬鬚も半分白くなった頑丈な大男で、一口二口話し合っているうちにいかにも人のいい老爺であることを私は感じた。",
              "citation": {
                "source": "青年僧と叡山の老爺",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "人のいいばかりが能じゃねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "人のいい、実に和やかな笑顔が彼を見た。",
              "citation": {
                "source": "夢",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "人のいい小作達は、そう云われて、今迄あんなに気儘に借金をさせて貰ったのに、それは本当に忘恩なことだ、と思った。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "男のひとのいい分とすれば、その外見的な粗暴のかげに日本の亭主ほど女房を立てているものはないと説明される。",
              "citation": {
                "source": "異性の友情",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことじゃ困りますね」　と、私は大袈裟に呆れてみせて、ひとのいい博士の、急所に一槍突込んだ。",
              "citation": {
                "source": "今昔ばなし抱合兵団",
                "author": "――金博士シリーズ・４――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（このひとのいい右衛門を、殺すことはさて置いて、怪我をさせても気の毒だ。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ひとのいいオトッツァンには相違ないんだからなあ）　ひどく気の毒になって来た。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
