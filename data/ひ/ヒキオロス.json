          "literary": [
            {
              "text": "レスパネエ嬢の体は、四、五人が力を合わせなければ引き下ろすことができなかったほど、煙突のなかに強く押しこんであった。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づあれを引き下ろすことから始めにや。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓場のみならず未知の場所からも、「もの」――何らかの存在なり声なり――を引き下ろすことができるが、この過程においてもまた注意が必要だ。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それはともかく、さしあたって分担金を都合しなくてはならないのだが」　恥を忍んで、パアトナーの救援隊に便乗するとしても、谷川岳では、遭難者を一人ひきおろすのに、最低、五万円はかかる。",
              "citation": {
                "source": "一の倉沢",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
