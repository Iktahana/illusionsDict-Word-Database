          "standard": [
            {
              "text": "パーカーのフードには、サイズを調整できる引き紐が付いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "浴衣の帯を結ぶのが難しいので、引き紐付きの簡単なタイプを選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "袋の口をしっかりと引き紐で縛った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼女は、呼鈴の引き紐を出して、たった一度、第四等名誉賞状を得たきりである。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
