[
  {
    "uuid": "3c0adbae-89be-54ca-8a31-21e8104ea433",
    "entry": "延いては",
    "reading": {
      "primary": "ひいては",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
