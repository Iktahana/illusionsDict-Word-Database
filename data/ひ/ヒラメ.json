    "definitions": [
      {
        "index": 1,
        "gloss": "flounder (esp. the large-tooth flounders of family Paralichthyidae, but also lefteye flounders of family Bothidae)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "左手には、大きい平目二まい縄でくくってぶらさげている。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "（野中）（その襖の外の節子に平目を手渡しながら）たったいま、浜からあがった平目だ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "平目一まいの値段が、僕たちの一箇月分の給料とほぼ相似たるものだからな。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "（矢庭に食卓をひっくりかえす）久しぶりの平目じゃないか。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　相変らずでっぷりして、平目のような頬ぶくれした顔は、六年会わぬが、隣家に住んでいる〆団治だと、一眼でわかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは今六十五になるが、鯛平目の料理で御馳走になった事もあるけれど、松尾の百合餅程にうまいと思った事はない。",
              "citation": {
                "source": "姪子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればカレイも邪視する魚と嫌うた物か［延享二年大阪竹本座初演、千柳、松洛、小出雲合作『夏祭浪花鑑』義平治殺しの場に、三河屋義平治その婿団七九郎兵衛を罵る詞に、おのれは親を睨めおるか、親を睨むと平目になるぞよ、とある。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから今でも、親をにらめると、平目になるといっているのです。",
              "citation": {
                "source": "物のいわれ",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枚切りですが、滅法威勢が好いので……それから石鰈が二枚に、舌平目の小さなのが一枚。",
              "citation": {
                "source": "悪因縁の怨",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "波の花が有るなら石鰈と舌平目は、塩焼にして、海※と鰕を洗いというところだが、水が悪いからブツブツ切りにして、刺身で行くとして、紫は有るまいねえ」「別当さんのところへ御無心に行って参りましょう」「そうして貰おう。",
              "citation": {
                "source": "悪因縁の怨",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "打水で湿した平目の石に夕闇が降りていた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その溝板の上を彼女は足袋跣足で、髪をぼうぼうと乱し、平目に似た眼を吊り上げて、平然と歩いてゆく。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "川では鮎、鱒、鯉、鮒、ニゴヒ、ハヤ、モロコ、ヤマベ、イハナ、ヤマメ、タナゴ、鰻、鯰、鰌、ハゼ、イナ、などが釣れ、海では、鯛、鱸、鯒、鰈、鰺、鱚、烏賊、蛸、カサゴ、アイナメ、ソイ、平目、小松魚、サバ、ボラ、メナダ、太刀魚、ベラ、イシモチ、その他所によつて、百種以上のものが釣れる。",
              "citation": {
                "source": "日本の釣技",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "平目のように潰されなければならない。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「太郎さんの白猫に、御馳走してやろう」　そして大きな鯛や平目を、持って来てくれました。",
              "citation": {
                "source": "金の目銀の目",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊東温泉には海も川もあり、鱸も平目も、鮎も山女魚もいる。",
              "citation": {
                "source": "水の遍路",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "永井柳太郎はのっぺらとして舌平目の感じがある。",
              "citation": {
                "source": "議会見物",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "このサメ肌の平目ツ面！",
              "citation": {
                "source": "道遠からん　四幕",
                "author": "――または　海女の女王はかうして選ばれた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二見　　人のうちの犬のことは、平気でそんなことがおつしやれるでせうけれど、お宅の犬が、先達、これの晩のおかずにわざわざ買つといた平目の切身を、うつかりしてる間に銜へてつたことは御存じございますまい。",
              "citation": {
                "source": "犬は鎖に繋ぐべからず",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右の腕へ上り龍下り龍の刺青をした見るから喧嘩早そうな見てくれで、どこでも喧嘩をしなかったときは血が騒いでならないとて手鉤を持ってきては商売物の大鮪や大平目の胴体へ、所｜嫌わず滅多やたらにそいつをぶち込んだ。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈は一尺ほどで、形はやや平目。",
              "citation": {
                "source": "呂宋の壺",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "次ぎに掲げるのは日高国沙流郡平取村字｜荷菜の平目カレピア婆さんが久保寺逸彦氏に伝えたもので、訳文も同氏の手になる。",
              "citation": {
                "source": "あの世の入口",
                "author": "――いわゆる地獄穴について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊勢海老でない時は、そうだ、平目のノルマンディー風、なんてのもあったっけ。",
              "citation": {
                "source": "想い出",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の上にじかに魚を並べて、ときどき大きい平目だの鱈だのを、手鉤でひっかけてぶら下げては、客に見せていた。",
              "citation": {
                "source": "北海道開発に消えた八百億円",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「舌平目をご賞味あれ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "平目、穴子など食う。",
              "citation": {
                "source": "このたび大阪",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポタアジュ、舌平目グラタン、スコットライス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三すしで平目を七八つ食ひ、コロンバンで菓子と紅茶をやり、流石に腹はって、座へ帰る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "七時すぎに終り名物食堂の金ずしで、平目を食ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "王の御座船「長蛇」のまわりには敵の小船が蝗のごとく群がって、投げ槍や矢が飛びちがい、青い刃がひらめいた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
