        "examples": {
          "standard": [
            {
              "text": "飲酒運転で人をひき殺すという悲惨な事故が起きた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "高速道路で飛び出してきた動物を、不運にもひき殺してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "警察は、ひき殺された被害者の身元確認を急いでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「やい、そこの泥棒猫」と運転手はクラクションを鳴らしながらどなる、「どかねえとひき殺すぞ」　とらは走りだすだろうか、否、彼は逆に立停ってしまい、ゆっくりとトラックのほうへ振返る。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手もまさかひき殺すわけにはいかないから、慌てて急ブレーキをかけ、トラックを停める。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "市電には正規のレール上を運行するという、一種の特権を与えられているから、そんなことはないだろうと思われるが、運転手には感情があるので、やはり承知しながらひき殺す気にはなれない。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
