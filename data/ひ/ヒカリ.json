  {
    "uuid": "77678357-3b70-5a25-9e4e-dba1cd7b2603",
    "entry": "光",
    "reading": {
      "primary": "ひかり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
