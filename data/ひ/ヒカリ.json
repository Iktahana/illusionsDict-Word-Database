    },
    "definitions": [
      {
        "index": 1,
        "gloss": "light",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "へい、――それには全く気が付きませんでした、自転車は月の光を浴びながら、ガタ／＼といつて引揚げられた。",
              "citation": {
                "source": "（七銭でバットを買つて）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は煙草に火を点けて、去りゆく光を眺めてゐた。",
              "citation": {
                "source": "（七銭でバットを買つて）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ神よ、私が先づ、自分自身であれるやう日光と仕事とをお与へ下さい！",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処に月光的な悲哀が漂つてゐた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで音楽批評家はといふと、「どうだ、夜の絵は――さう日光の御厄介ばかりならんで」なぞと画家に云ふ画家の叔父さんみたいな思ひ付きを並べるか、（まあその叔父さんなんざあ甥に親愛を感じて云つたのだからまあまんざら空無ではないがね。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "横光氏が此の詩集の序に「惑乱を防ぐ克己」を以て此の詩人の特質としてをられることには意義がある。",
              "citation": {
                "source": "菊岡久利著「貧時交」",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "真昼の光はあつても少しくであり、それもやがて暮れるとしてのことのやうであり、此処では、紅の花も、やがて萎れて黝ずんだ色になるとしてのことである。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しその海の上にも星変り、月変つて、――と茲で、私の目は漸く海を去つて、なんだか海と空との中間の奥といつた感じの方角に、過ぎ逝ける諸世紀が、黒光りする中世の武具の色をして、堵をなして潜んでゐるやうに感じられる。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "うすやみ萩原朔太郎うすやみに光れる皿あり皿の底に蟲かくれ居て啜り鳴く晝はさびしく居間にひそみて鉛筆の心をけづるに疲れ夜は酒場の椅子にもたれて想ひにひたせる我が身の上こそ悲しけれ",
              "citation": {
                "source": "うすやみ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "麥萩原朔太郎麥はさ青に延び行けり遠き畑の田作りの白き襦袢にえんえんと眞晝の光ふりそそぐ九月はじめの旅立ちに汽車の窓より眺むれば麥の青きに驚きて疲れし心が泣き出せり",
              "citation": {
                "source": "麥",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくばかり我に信なきともがらに、なにのかかはりあるべしやは、空しく坐して祈り、遠き遍路に消え殘る雪を光らしむ、いのちはひとりのもの、ただ我が信願をかくるにより、木ぬれにかかり、有明の月もしらみてふるへ悲しめり。",
              "citation": {
                "source": "黎明と樹木",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま初夏きたる、野に山に、榮光榮光、榮光いんよくの主とその僕にあれ。",
              "citation": {
                "source": "初夏の祈祷",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "友よ、やさしく胡弓を摩り、遠くよりしも光を送れ。",
              "citation": {
                "source": "立秋",
                "author": "――大沼竹太郎氏ニ捧グル詩――",
                "note": "青空文庫"
              }
            },
            {
              "text": "感傷の塔萩原朔太郎塔は額にきづかる、螢をもつて窓をあかるくし、塔はするどく青らみ空に立つ、ああ我が塔をきづくの額は血みどろ、肉やぶれいたみふんすゐすれども、なやましき感傷の塔は光に向ひて伸長す、いやさらに伸長し、その愁も青空にとがりたり。",
              "citation": {
                "source": "感傷の塔",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みよ空にまぼろしの島うかびて、樹木いつさいに峯にかがやき、憂愁の瀑ながれもやまず、われけふのおとろへし手を伸べ、しきりに齒がみをなし、光る無禮の風景をにくむ。",
              "citation": {
                "source": "光る風景",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ汝の肖像、われらおよばぬ至上にあり、金屬の中にそが性の祕密はかくさる、よしわれ祈らば、よしやきみを殺さんとても、つねにねがはくば、われが樂欲の墓場をうかがふなかれ、手はましろき死體にのび、光る風景のそがひにかくる。",
              "citation": {
                "source": "光る風景",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みよわが光は空にあり、空は白金、ふきあげのみづちりこぼれて、わが賽は魚となり、卓上の手はみどりをくむ。",
              "citation": {
                "source": "純銀の賽",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああくらき緑をやぶり、天上よりきたるの光、いま秋ふかみ、あふげば、一脈の金は空にあり。",
              "citation": {
                "source": "鑛夫の歌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは利根川、その氾濫のながめいちじるく、青空に桑の葉光り、さんらんとして遠き山里に愁をひたす、あはれ、あはれ、われの故郷にあなれば、この眺望のいたましさ。",
              "citation": {
                "source": "厩",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "村落の光る厩のうへに、かがやく愛の手は伸びゆきて、われの身は銀の一脈、ひそかに息づき生命はや絶えなんとする。",
              "citation": {
                "source": "厩",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空もいんいん、地もいんいん、肢體に青き血ながれ、するどくしたたり、電光したたり、身肉ちぎれやぶれむとす、いま裸形を恥ぢず、十字架のうへ、齒がみをなしてわれいのる。",
              "citation": {
                "source": "情慾",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青いゆき萩原朔太郎青いぞ、ゆきはまつさを、もも、さくらぎに花咲かず、青いこなゆき、光る山路に泣きくらす。",
              "citation": {
                "source": "青いゆき",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "靈智萩原朔太郎ふるへる、微光のよるに、いつぱつ、ぴすとるを撃つ、遠方に、金の山脈、かすかな、黒曜石の發光。",
              "citation": {
                "source": "靈智",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ　いのちの孤獨、われより出でて徘徊し、歩道に種を蒔きてゆく、種を蒔くひと、みづを撒くひと、光るしやつぽのひと、そのこども、しぬびあるきのたそがれに、眼もおよばぬ東京の、いはんかたなきはるけさおぼえ、ぎたる彈く、ぎたる彈く。",
              "citation": {
                "source": "ぎたる彈くひと",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕さむしい Hotel の臺所で、のすたるぢやのメリイが泣いて居る、ほんのり光る玉菜のかげから、ぜんまい仕かけで、鼠がひよつくり顏を出した。",
              "citation": {
                "source": "玩具箱",
                "author": "―人形及び動物のいろいろとその生活―",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ尾ばな藤ばかますでに色あせ、手にも料紙はおもたくさげられ、夏はやおとろへ、山頂は風に光る。",
              "citation": {
                "source": "山頂",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝろ宮沢賢治曇りてとざし風にゆるそれみづからぞ樹のこゝろ光にぬるみ気に析くるそのこと巌のこゝろなり樹の一本は一つの木規矩なき巌はたゞ巌",
              "citation": {
                "source": "こゝろ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔鷺はひかりのそらに餓ゑ〕宮沢賢治鷺はひかりのそらに餓ゑ羊歯にはそゝぐきりさめをあしきテノールうちなして二人の紳士　森を来る",
              "citation": {
                "source": "〔鷺はひかりのそらに餓ゑ〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
