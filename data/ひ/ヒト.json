    "definitions": [
      {
        "index": 1,
        "gloss": "person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "名詞の換言で日が暮れようアスファルトの上は凡人がゆく顔　顔　顔石版刷のポスターに木履の音は這ひ込まう",
              "citation": {
                "source": "春の日の怒",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖書の綱が性慾のコマを廻す原始人の礼儀は外界物に目も呉れないで目前のものだけを見ることでしただがだが現代文明が筆を生みました筆は外界物です現代人は目前のものに対するにその筆を用ひました発明して出来たものが不可なかつたのですだが好いとも言へますから――僕は筆を折りませうか？",
              "citation": {
                "source": "迷つてゐます",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "煉瓦塀に春を発見した福助人形の影法師孤児の下駄が置き忘れてありました公園の入口ペンキのはげた立札心よ！",
              "citation": {
                "source": "（風船玉の衝突）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人は着物のスソを狂犬病にクヒチギられたが……！",
              "citation": {
                "source": "（風船玉の衝突）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつぱり形式に於ても経験世界を肯定しなきや万人の芸術品とは言へないのでせうか？",
              "citation": {
                "source": "（最も純粋に意地悪い奴）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自棄のない詩は神の詩か凡人の詩かそのどつちかと僕が決めたげます",
              "citation": {
                "source": "（テンピにかけて）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人となつた今日でさへ、さうした悲運はやみはせぬ。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて俺は人生が、すつかり自然と遊離してゐるやうに感じだす。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "格別俺は人生がどうのかうのと云ふのではない、理想派でも虚無派でもあるわけではない。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――記憶も、去るにあらずや……湧き起る歓喜のためには　人の情けも、小さきものとみゆるにあらずやああ、神様、これがすべてでございます、　尽すなく尽さるるなく、心のままにうたへる心こそ　これがすべてでございます！",
              "citation": {
                "source": "夏は青い空に……",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の日は、干物の匂ひがするよ干物の、匂ひを嗅いで、うとうとと秋蝉の鳴く声聞いて、われ睡る人の世の、もの事すべて患らはし匂を嗅いで睡ります、ひとびとよ、秋の日は、干物の匂ひがするよ",
              "citation": {
                "source": "干物",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "５向ふに、水車が、見えてゐます、　　苔むした、小屋の傍、ではもう、此処からお帰りなさい、お帰りなさい　　僕は一人で、行けます、行けます、僕は、何を云つてるのでせう　　いいえ、僕とて文明人らしくもつと、他の話も、すれば出来た　　いいえ、やつぱり、出来ません出来ません。",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "神よ、私は人の世の事象がいかに微細に織られるかを心理的にも知つてをります。",
              "citation": {
                "source": "我が祈り",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "野望の上に造花は咲いて迷つた人心は造花に凭る。",
              "citation": {
                "source": "（辛いこつた辛いこつた！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫くゆくと自転車を坂の下に落として、自分一人は草を掴めば上れるが、自転車を置いとくわけにもいかずといふ災難者にあつた。",
              "citation": {
                "source": "（七銭でバットを買つて）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その志明かなれば冬の夜を、われは嘆かず、人々の憔燥のみの悲しみや憧れに引廻される女等の鼻唄を、我が瑣細なる罰と感じそが、わが皮膚を刺すにまかす。",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "……２恋人よ、その哀しげな歌をやめてよ、おまへの魂がいらいらするので、そんな歌をうたひだすのだ。",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもおまへはわがままに親しい人だと歌つてきかせる。",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧野さんといふ人は、恋愛に殉じる態の純情家といふものとは遙かに縁遠いと思はれるからだ。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が自殺した時、それも作家が自殺した時、その原因を簡単に云つてしまふなぞはよくないことである。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく、人が、思はず云ひ過ぎをしてしまふやうに、自殺も、思はずしてしまふやうなものに相違ない。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「西部劇通信」にも無論個性は十分に現はれてゐるのであるが、人物をギリシャ人に仕立てたりするあの仮構は、作者自身にしつくりしたことではなかつたと思ふ。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜我々は新しく始める同人雑誌の相談で、同人二十人ばかりで其処へ集つてゐた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "同人中の谷丹三が牧野さんを知つてゐたので、その夜来て貰ふやう頼んでおいたのであつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大変元気で粗忽が自慢でもある、甚だ罪のない男がその夜の進行係をやつてゐて、一人で大声で喋舌つてゐたが、大部分の者は聴いてもゐなかつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "便なき幼兒のうたへる歌萩原朔太郎うすらさびしき我が身こそ利根の河原の石ひろひひとり岸邊をさまよひて今日も小石をひろふほど七つ八つとなりにけり",
              "citation": {
                "source": "便なき幼兒のうたへる歌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋日行語〔菊もうららに〕萩原朔太郎菊もうららに咲きいでたれど我身は砂丘に寄りて悲しめりさびしや海邊のおくつきに路傍の草を手向くることこのわびしきたはむれにひとり樹木にすがりつきたましひも消えよとむせびなく。",
              "citation": {
                "source": "秋日行語",
                "author": "〔菊もうららに〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の降る日（兄のうたへる）萩原朔太郎雨の降る日の縁端にわが弟はめんこ打つめんこの繪具うす青くいつもにじめる指のさき兄も哀しくなりにけり雨の降る日のつれづれに客間の隅でひそひそとわが妹のひとり言なにが悲しく羽根ぶとん力いつぱい抱きしめる兄も泣きたくなりにけり",
              "citation": {
                "source": "雨の降る日",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくばかり我に信なきともがらに、なにのかかはりあるべしやは、空しく坐して祈り、遠き遍路に消え殘る雪を光らしむ、いのちはひとりのもの、ただ我が信願をかくるにより、木ぬれにかかり、有明の月もしらみてふるへ悲しめり。",
              "citation": {
                "source": "黎明と樹木",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ舟にのりて行かば、くるほしきなみの亂れもここちよく、ちのみごの夜びえする、あやしきこゑもきかであるべきに、ふるとせひとにかくれて、わがはぐくみしいろぐさのはや涸れぬとぞ、けふきけば薄葉に涙しをるる、よしゑやし、悲しきものはあだがたき、君ならなくに、はやも我が世をのがれいでばや。",
              "citation": {
                "source": "浮名",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
