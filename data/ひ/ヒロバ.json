        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "王宮と河一つ隔てた広場に面した四角な煉瓦造りの建物で、これは有名なシンケルの建てた特色のある様式の建築として聞こえたものだそうである。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴船神社の森影の広場にほんの五六人の影が踊っていた。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝はすべてが領事館旗のもとに従順で、私は錫と広場と天鼓のほかのなんにも知らない。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "フー、だが、全く暑いよ」　彼は、待合室から、駅前の広場を眺めた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "池が消えて夜の街の広場が現われる。",
              "citation": {
                "source": "御返事（石原純君へ）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は、停車場の前の、水晶細工のやうに見える銀杏の木に囲まれた、小さな広場に出ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処は多分は、野馬の集まり場所であったでしょう、霧の中に円い広場のように見えたのです。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて広場に出ると囃子のやぐらや周囲の踊場が提燈や幕で美しく飾られていた。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "枝垂桜の前の広場のやぐらからレコードが鳴り響いて、下には二十人ばかり円を描いて踊っている。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は坂を降りてようやく窮屈な場所から広場へ出た気になった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "千箇の焼夷弾の中で路面や広場に落ちたり河に落ちたりして無効になるものが仮りに半分だとすると五百箇所に火災が起る。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大火が起れば旋風を誘致して焔の海となるべきはずの広場に集まっていれば焼け死ぬのも当然であった。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場の広場は空虚である。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "フリツツは踵を旋らして、ポツケツトに両手を入れた儘、ぶら／＼広場へ戻つて来た。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "４　一刻後、太田ミサコはタクシーのクッションにもたれて官省広場の並木道を疾走していた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この界隈の連合委員会の事業振興の決議案にもかかわらず、閑散とした取引市場をとりまいて、日一日と失業者と、彼らの飢えが生産余剰と反比例して街の広場に堆積して行った。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　隣部落の寺の広場へ、田舎廻りの角力が来た。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ何となく軒端に菖蒲を葺いた郷国の古俗を想い浮べて、何かしら東西両洋をつなぐ縁の糸のようなものを想像したのであったが、後にまたウィーンの歳の暮に寺の広場で門松によく似た樅の枝を売る歳の市の光景を見て、同じような空想を逞しゅうしたこともあった。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は自分が子供の時に九段上の広場で見た、手拭を撚ってこしらえた蛇を地上において、それが今に本当の蛇になると云って、その周囲に円を描いて歩きながら、笛を吹いて往来の暇人を釣っていた妙な男の事を思い出した。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋草などのある広場へ出てみると、カンナや朝貌が咲きそろって綺麗だった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "草花のある広場へはいってみるといよいよ失望しなければならなかった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯磨｜楊枝をくわえた人、犬をひっぱっている人、写真機をあちらこちらに持ち廻って勝手に苦しんでいる人、それらの人の観察を享楽しているらしい人、そういう人達でこの美しい朝の広場はすっかり占領されていた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅前の広場には、また別の、もっと／＼数多い真黒な群集の山が待ちかまえて、うごめいていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士達は、駅前の広場で叉銃して背嚢をおろした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四人が、汗のにじんだ手拭をさげ、石鹸は一ツも持たずに、マッチ工場から、貧民窟とは反対側の雑草が青濃く茂っている広場を横ぎった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、通ってきた雑草の広場を眺めかえした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは、彼が知らないうちに子供が嬉しがってどっかへ持って行ったのかもしれない、彼女は、子供達が寺の広場で遊んでいるのを呼びに行った。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の娘は、広場を振りかえって見ながら渋々母のあとからついて来た。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔老いては冬の孔雀守る〕老いては冬の孔雀守る、　　　　蒲の脛巾とかはごろも、園の広場の午后二時は、　　　　湯｜管のむせびたゞほのか。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "風ふきて広場広場のたまり水、　　いちめんゆれてさゞめきにけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
