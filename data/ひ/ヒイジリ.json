        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「火いじりをするとおねしょするよ」と昔から子供に言い聞かせてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "庭で焚き火を始めた父の隣で、息子が楽しそうに火いじりをしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "乾燥した時期の不用意な火いじりは、大火事に繋がる恐れがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "女になってみること、泥酔してみること、ポン引の真似をしてみること、火気厳禁の場所で火いじりをすること……表れかたはそれぞれちがいますが、禁止に抵抗するという点で、通じあうものがあるのですね……本人には、なにか煩悶があるのではないでしょうか。",
              "citation": {
                "source": "母子像",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな日の続いて行く中で、座敷牢にいる人が火いじりの危さを考えると、炬燵一つ入れてやって凍えたからだを温めさせる術もないとしたら。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "自在に鍋をかけて、何か朝の仕度をしながら、お雪ちゃんはやつれた面に乱れた髪を少しかき上げて、火箸で暫く火いじりしながら、物を考え込んでおりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれも火いじり商売だ。",
              "citation": {
                "source": "銀河まつり",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
