[
  {
    "uuid": "e362c5e4-f0a5-5c32-a332-e3a3bb5a3ee6",
    "entry": "ヒ素",
    "reading": {
      "primary": "ひそ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
