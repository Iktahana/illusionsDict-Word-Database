          "literary": [
            {
              "text": "年寄りの冷や水も夏は涼しい。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　男の襟を外して冷や水を頬に注ぎかけ、腕を上下させていると、とうとう長く自然な息をするようになった。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時に、母は冷や水でも浴びせられたようにぞっとした。",
              "citation": {
                "source": "父の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "六三郎は惣身に冷や水でも浴びせられたように感じて、息ももう詰まってしまいました。",
              "citation": {
                "source": "子供役者の死",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "年寄りの冷や水はどこにでもある。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の年寄りの冷や水は、いつも、君の顔の中に点滅する「ともすれば涙ぐもうとする、ひ弱い、良家の子供」の、幸せな将来を祈っていたのだ。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドレントン・デンは不意に冷や水を浴びせられたようだった。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「年よりの冷や水」　あざ笑いながら、張飛は、丈八の矛も用いず、片手をのばして、厳顔の上帯をつかみよせてしまった。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそ年寄りの冷や水といわないばかりに。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
