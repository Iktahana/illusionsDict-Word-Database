[
  {
    "uuid": "499c50ac-ea6c-53f5-b291-c9033680e7b0",
    "entry": "火種",
    "reading": {
      "primary": "ひだね",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
