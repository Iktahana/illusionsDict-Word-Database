        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その縁側にかけてある干鱈をむしつて、待て、それは金槌でたたいてやはらかくしてから、むしらなくちや駄目なものなんだ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "干鱈をたたくには、こんな工合ひに、こんな工合ひに、あ、痛え、まあ、こんな工合ひだ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "干鱈には醤油をつけなくちや駄目だ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云えば灰吹と、諸礼｜躾方第一義に有るけれども、何にも御馳走をしない人に、たとい※が葱臭かろうが、干鱈の繊維が挟っていそうであろうが、お楊枝を、と云うは無礼に当る。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは紙をもっていないから、干鱈のうえに、てがみをかいてあげよう。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてゲルダのからだもあたたまり、たべものやのみものでげんきをつけてもらったとき、ラップランドの女は、干鱈に、ふたことみこと、もんくをかきつけて、それをたいせつにもっていくように、といってだしました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か肴なかるべからずとて、目を兩側に注ぎつゝ行きしに、一店に小さき干鱈あるを見付く。",
              "citation": {
                "source": "新武藏野の櫻",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一錢足して、干鱈と佃※とを買へり。",
              "citation": {
                "source": "新武藏野の櫻",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いてその複雑なるものを求めんか、鶯や柳のうしろ藪の前つゝじ活けて其陰に干鱈さく女隠れ家や月と菊とに田三反等の数句に過ぎざるべし。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "強ひてその複雑なる者を求めんか鶯や柳のうしろ藪の前つゝじ活けて其陰に干鱈さく女隠れ家や月と菊とに田三反等の数句に過ぎざるべし。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "母上、三越へゆくところで、しきりに干鱈のうまにを食べて居られる。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪ホテルのシャトウブリヤンを塩からいと思っていた舌は、半煮えの飯を食道へ押し込み、固い干鱈の一片を奥歯の方へ押してやる。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで又この境地はひっそりとなり、鋭い切先の一所を、ギラギラ月光に光らせた抜身を、いまだにしっかり握っている主税が、干鱈のように仆れているばかりであった。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも干鱈を作る話なんだが、肉を繊維の集りとしてその中を毛管現象で水分が上って行って、表面から蒸発するというのを、何十頁か長い数式ばかりで埋めたんだから、水産講習所の連中を煙に巻いたわけさ。",
              "citation": {
                "source": "先生を囲る話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "干鱈のやうに乾涸びた男まさり、朝つぱらから女中を打ちどほしだ、嫉けるのだらう、徳利は手を離さない、好きだから。",
              "citation": {
                "source": "五本の指",
                "author": "LES CINQ DOIGTS DE LA MAIN",
                "note": "青空文庫"
              }
            },
            {
              "text": "お副食は干鱈と昆布の煮〆だったが、お浜はそれには箸をつけないで沢庵ばかりかじっていた。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "米はなく、麦、稗、粟、もろこしなどの雑穀に、塩引の鮭、干鱈、煮干、そして乾した野菜などであるが、鮭や干鱈はたいてい木戸で取りあげてしまうようであった。",
              "citation": {
                "source": "ちくしょう谷",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと、独活及びウト蕗の味噌汁と、干鱈の焼いた奴とで晩飯にする。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "味噌汁、干鱈、それ以外には何の御馳走もなかったが、三人は野獣のようによく喰った。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪ホテルのシャトウブリヤンを塩からいと思っていた舌は、半煮えの飯を食道に押し込み、固い干鱈の一片を奥歯の方へ押してやる。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "罐詰類は重いので、せいぜい福神漬か大和煮を、それもたくさんは持っていかず、動物性｜蛋白質は干鱈だった。",
              "citation": {
                "source": "飢えは最善のソースか",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯をたき味噌汁をつくった焚火のおきに、縦半分にさいた干鱈をのせ、アッチアッチと言いながら指でちぎって食うのである。",
              "citation": {
                "source": "飢えは最善のソースか",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "『どうだ、やつぱりやまなしだよ、よく熟してゐる、いい匂ひだらう。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家人の方では、そんな買物をした覺えがなく、よその間ちがひだらうといふのである。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはカマイタチの間違ひだらう。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ひだらにかきつけてあるもんくを、三べんもくりかえしてよみました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君は洋酒は嫌ひだらう。",
              "citation": {
                "source": "素書",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "『わたしの皮膚の匂ひを、かいでごらんよ、唖娘、なんといゝ匂ひだらうね。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「解つてゐるさ、お前は怠惰で、そしておべつかつかひだらう。",
              "citation": {
                "source": "或る五月の朝の話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことはお前は嫌ひだらうが、近いうちに……」「近いうちに僕、役場へ――」「えゝ、行つて貰はなければならないでせう、御苦労だけれど――」「いゝえ、それは……」　そのうちに東京行の時間が迫つて芝居見へ行く人達は慌てゝ出かけた。",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
