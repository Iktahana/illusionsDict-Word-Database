        "examples": {
          "standard": [
            {
              "text": "青空にまっすぐ伸びる飛行機雲を見て、明日は天気が崩れるだろうと予報した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子供たちが指を差して、消えかかった飛行機雲を追いかけて走っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夕焼けに染まった飛行機雲が、まるで一筋の光の帯のように見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "翌日、新聞に飛行機雲の写真が出ていた。",
              "citation": {
                "source": "忘れがたみ",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては昨日見た雲は飛行機雲というものなのかとひとり頷いたが、仮りにこれを妻に語るならば「漸くあなたはそんなことを知ったのですか」と、病床にいても新知識の獲得の速かった彼女はあべこべに私を笑ったかもしれないのだ。",
              "citation": {
                "source": "忘れがたみ",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "森製作所の縫工場にいた学徒たちは、一斉に窓からのぞき、屋根の方へ匐い出し、空に残る飛行機雲をみとれた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂ29も、飛行機雲も、この街に姿を現したのはこれがはじめてであった。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "――昨年来、東京で見なれていた正三には久し振りに見る飛行機雲であった。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "森製作所の縫工場にゐた学徒たちは、一斉に窓からのぞき、屋根の方へ匐ひ出し、空に残る飛行機雲をみとれた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂ29も、飛行機雲も、この街に姿を現はしたのはこれがはじめてであつた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "――昨年来、東京で見なれてゐた正三には久振りに見る飛行機雲であつた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "上空に見えました飛行機雲は友軍キによるものでありますから、念のため」　けさの新聞に曰ク「敵機は東海道を一時間に亙って十分に偵察してトン走しました」　鈴木先生のところへベルモットもって行く。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
