          "literary": [
            {
              "text": "教科書、ノート、辞書、筆記具をもって、ヴェランダのドアをあける。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆記具も普通の鉛筆であり――疑いなくメモ帳の横に転がっていたものだ。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前がわしから筆記具を取り上げることを忘れたものだから、わしがあの男に手紙を書いてやったんだ。",
              "citation": {
                "source": "判決",
                "author": "DAS URTEIL",
                "note": "青空文庫"
              }
            }
          ]
        }
