[
  {
    "uuid": "36686ad2-d3e6-5278-9d04-eb09053e4e27",
    "entry": "未",
    "reading": {
      "primary": "ひつじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
