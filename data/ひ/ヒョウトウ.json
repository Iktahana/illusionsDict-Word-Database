[
  {
    "uuid": "d57ce689-5912-5c27-91a7-c1fb1e85ef61",
    "entry": "剽盗",
    "reading": {
      "primary": "ひょうとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "highwayman",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まして敗軍の将士が他領を通過しようという時などは、恩も仇もある訳は無い無関係の将士に対して、民衆は剽盗的の行為に出ずることさえある。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "北方の山地に住む三十人の剽盗の話や、森の夜の怪物の話や、草原の若い牡牛の話などを。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の生死不明の噂は彼の養っていた畜群が剽盗どものために一匹残らずさらわれてしまったことの訛伝らしい。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "剽盗か、それとも追手か。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一群の剽盗が馬車を取り巻いた。",
              "citation": {
                "source": "復讐",
                "author": "BALTHASAR ALDRAMIN. KURZE LEBENSGESCHICHTE AUS DEM ALTEN VENEDIG.",
                "note": "青空文庫"
              }
            },
            {
              "text": "至る所に猛獣毒蛇｜魑魅魍魎が横行｜跋扈し、野武士邪教徒｜剽盗の類が巣を構えて住んでいた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時代の裾野と来ては、猛獣毒蛇｜魑魅魍魎剽盗殺人鬼の住家だのに。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ家中にいた頃は、身分の相違で圧迫され、同じ剽盗になってからも、技倆の違いで威圧された、その鬱憤を晴らすのが、何んとも云えず楽しいらしい。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "魑魅魍魎猛獣毒蛇、剽盗の巣食っている富士の裾野を、どうしてこんなちっぽけな子が、無事に旅して来られたのだろう？",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "魑魅魍魎猛獣毒蛇、剽盗の巣食っている富士の裾野に、どうしてこんな若い女が、無事に住んでいられるのだろう。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「富士の裾野の三合目に、一人の剽盗がございます。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "韓退之所謂務去陳言戞々乎其難哉とは正に此謂いなり、若し古人の意を※襲して即ち古人の田地の種獲せば是れ剽盗のみ。",
              "citation": {
                "source": "文士としての兆民先生",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに、青い背縞のある豺の新種を、まだ外国人のゆかぬ東北チベットの鎖境――剽盗 Hsiancheng 族がはびこる一帯から持ちかえったのも彼だ。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、京から大津へ出る美濃路の口にあたる栗田口や逢坂｜越には、兇悪無慙な剽盗がたむろしていて、昼でも一人旅はなりかねる時世だったが、泰文は蝦夷拵え柄曲の一尺ばかりの腰刀を差し、伴も連れずに馬で膳所の遊女宿へ通った。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅逓馬車★が七人の剽盗に待伏せされ、車掌がその中の三人を射殺したが、「弾薬が欠乏したために」自分も残りの四人に射殺された。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "天智天皇の七年、高麗国の滅亡するや、その遺民唐の粟を食むことを潔しとせず、相率いて我が国に帰化し、その数数千に及び、武蔵その他の東国に住んだが、それらの者の長、剽盗に家財を奪われるを恐れ、塚を造り、神を祭ると称し、塚の下に穴倉を設け、財宝を隠匿した。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "剽盗に成ったのは夫れからである。",
              "citation": {
                "source": "五右衛門と新左",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　剽盗になってからの五右衛門は、文字通り自由の人間であった。",
              "citation": {
                "source": "五右衛門と新左",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたたび剽盗の群へ這入った。",
              "citation": {
                "source": "五右衛門と新左",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、粟田口や逢坂越に兇悪無慙な剽盗が屯していて、昼でも一人旅はなりかねる時世だったが、泰文は蝦夷拵え柄曲の一尺ばかりの腰刀を差し、伴も連れずに馬で膳所の遊女宿へ通った。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "現にちょうどあの頃、狸穴の骨董屋の手代で、五十両｜剽盗に取られたという訴えが出ている」「ヘエ――」「でも、俺はそこまで詮索する気がなかったよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "井戸の茶碗",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛出そうか、飛出そうかと潮時を見て居た足の勇も、妙に悩ましい丹波高一の眼に射すくめられて、剽盗退治の一役を買って出る出鼻を挫かれます。",
              "citation": {
                "source": "踊る美人像",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これこれ町人」「ヘエ、ヘエ」「先ほどから拙者の後を跟けているようだが、何か用事でもあるのかな」「とんでもない」「剽盗泥棒ならあきらめて帰るがよかろう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "鈴を慕う女",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょいと摘んで、お引渡し下されば、有難うございますが――」「黙れ」「ヘエ――」「この小田巻直次郎が、辻斬や剽盗をかくまっているとでも言うのか」「とんでもない、先生」「そう申すなら、如何にも家捜しでも何でもさしてやる。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "辻斬綺談",
                "note": "青空文庫"
              }
            },
            {
              "text": "辻斬や剽盗に朋友も知己もない、――さア、踏込んで見ぬか。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "辻斬綺談",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの腕は武士も武士、よっぽど使える人間と思ったのが間違いの基さ、――俺の見当では、小田巻直次郎にそそのかされて、辻斬の味を覚えた武家が、今度は小田巻直次郎に強請られて、剽盗まで働いて金を貢がなければならなかった――と思い込んだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "辻斬綺談",
                "note": "青空文庫"
              }
            },
            {
              "text": "流しの剽盗や、あまり口をきいた事もないような人間のしたことじゃねえ」「その通りだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "玉の輿の呪い",
                "note": "青空文庫"
              }
            },
            {
              "text": "おせんは身を起こした、たぶん後架だろうと考え、そちらへ耳を澄ましていると、戸外のひどい風の音に気がついた、いつ吹きはじめたものかひじょうな烈風で、露次ぐちにある棗の枯枝や庇さきがひょうひょうとうめき、地震でゆるんだ雨戸や障子はもちろん、柱や梁までがみじめなほどきいきいと悲鳴をあげていた。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
