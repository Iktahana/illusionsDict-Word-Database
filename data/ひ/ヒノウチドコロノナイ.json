        "examples": {
          "standard": [
            {
              "text": "会場に現れた彼女は、非の打ち所のないイブニングドレス姿で全出席者の視線を釘付けにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "職人が丹精込めて作り上げた刀は、非の打ち所のない美しさと鋭さを兼ね備えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は非の打ち所のない経歴を持っており、どの企業からも引く手あまたの状態だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし、整然とした威儀を正した食卓で、紳士淑女がなに一つ非の打ち所のない典雅さでフォークを使っている真最中に於てでも、いきなりパンだけは手掴みだ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一通は自分の弟宛で、お別れのためのものであり、もう一通は、首都にいる高官宛で、非の打ち所のない嘆願状である。",
              "citation": {
                "source": "勇子",
                "author": "一つの追憶",
                "note": "青空文庫"
              }
            },
            {
              "text": "「北部の部族が盛んになるに伴ってこのアスクレピオス神はホオメロス（紀元前８世紀）の詩においては非の打ち所のない医師からもっと堂々たるものになり、陸上でエピダウロスに来て海上を東に向ってコス島に運ばれた。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "非の打ち所のない品だ。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            }
          ]
        }
