    "definitions": [
      {
        "index": 1,
        "gloss": "being trapped (and having no way out)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "日本当面の非常時、政治的不安や経済的行き詰まりにいよいよ恐慌を増して来ましたこの頃では、金融は全く逼塞してしまいましたので、日本の大多数の人々は、その命つなぎの金にさえ不自由する有様に立ち至っております。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "品子は小さい時分から、松島の第二の妻の姉に愛され、踊りや長唄を、そのころ愛人の鹿島と一緒に、本郷の講釈場の路次に逼塞し、辛うじて芸で口を凌いでいた、かつての新橋の名妓ぽん太についてみっちり仕込まれたものだったが、商売に出すつもりはなく、芸者屋の娘としては、おっとり育っていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "小菊は親たちが微禄して、本所のさる裏町の長屋に逼塞していた時分、ようよう十二か三で、安房の那古に売られ、そこで下地ッ児として踊りや三味線を仕込まれ、それが彼女の生涯の運命を決定してしまった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんの繁劇な都会の濠川の人為的生活が、雪という天然の威力に押えつけられ、逼塞した隙間から、ふだんは聞取れない人間の哀切な囁きがかすかに漏れるのを感ずるからであった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れも旧南部藩の武家、廃藩置県の大変遷、六十余州を一度に洗つた浮世の波のどさくさに、相前後して盛岡の城下から、この農村に逼塞したのだ。",
              "citation": {
                "source": "刑余の叔父",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一年ほどの後に、甚五郎は身持｜放埒の廉を以って留守居役を免ぜられ、国許逼塞を申付けられた。",
              "citation": {
                "source": "恨みの蠑螺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "食うや食わずで逼塞している俺の両親は、俺の成業を首を長くして待っているのだ。",
              "citation": {
                "source": "青木の出京",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、株家督があるというでは無し、芳町のうら店に逼塞して、おふくろは針仕事や洗濯物をして、細々にその日を送っているという始末ですから、久松は九つの年から近所の糸屋へ奉公にやられ、姉は十三の年から芝口の酒屋へ子守奉公に出ることになって、親子三人が分れ／＼に暮していました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その以前の浪花節は専ら場末の寄席に逼塞して、聴衆も下層の人々が多かったのであるが、次第に勢力を増して来て、市内で相当の地位を占めている席亭も「御座敷浄瑠璃、浪花節」のビラを懸けるようになった。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は六条に住んでいる与兵衛という米屋の娘で、商売の手違いから父母はことし十五の妹娘を連れて、裏家へ逼塞するようになり下がった。",
              "citation": {
                "source": "鳥辺山心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしも年々逼塞して行く。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "逼塞した身には三十両といふ纏まつた金は有難かつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十六　お庄らが母子の仕事として、ひっそりした下宿を出そうと思いついたのは、この事務所を畳んでから、一家が丸山の隣の小さい借家へ逼塞してからであった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前はかなりの船持ちであったという磯野の叔父はもと妾であった女と一緒に、そのころそこに逼塞していた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅井は商業に失敗して、深川の方に逼塞しているその伯父と一度会見すると、こっちから逆捻じを喰わして、少しの金で、事件の片がぴたりついてしまった。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の結果、親店とも相談のうへ、彼は店を畳んで、当分仕舞うた家へ逼塞することになつた。",
              "citation": {
                "source": "のらもの",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "綱宗は不行迹の廉を以て、七月十三日にに逼塞を命ぜられて、芝浜の屋敷から品川に遷つた。",
              "citation": {
                "source": "椙原品",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "逼塞した息はお腹の上へ墓標をたてようとする。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "教師は自棄になって酒を飲みだしたが、とうとうしまいには、飲代もなくなってしまい、おまけに病気になって、一片の麺麭もなければ、頼る人もなく、どこか場末の、犬小屋のような火の気もない荒ら家に逼塞していた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "連合は開港場の横浜で手びろくやっていた、派手な商館相手の商人だったが、おしょさんのために逼塞したということだった。",
              "citation": {
                "source": "神田附木店",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "天理教の踊りがピッタリ逼塞してしまうと、勝川おばさんの逼塞も本ものになって、手も足も出なくなってしまった。",
              "citation": {
                "source": "勝川花菊の一生",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしの方こそ、あんたたちに相談をしようと思つた位だぜ‥‥千圓はおろか、百圓だつて都合はつくまい」　末弟は、小さい材木商をやつてゐたが、このごろは建築の方もおもはしくなくて、臺所向きも白々と逼塞してゐる風である。",
              "citation": {
                "source": "濡れた葦",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三田は別段平生と變つた事も無かつたが、新聞社から受取つた長編小説の原稿料も夙につかひ果し、月末に賞與金を貰ふのを樂しみにしながら、逼塞してゐた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしなければ、その土地の住民は胸を割ってみせないであろうし、むろん事あれかしと覗っていたオロシャは逼塞しないであろう。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "今回紀州より江戸へ出られたも、一つはその金の保管の場所を、拙者に告げようためだった筈じゃ……あの人物を抑えられては、経済方面にて忽ち逼塞。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、苦々しい憤りに胸が逼塞して、廊下に籠めた静かな薄闇を大きな息で吸ひ込み乍ら、部屋へ戻つて来るのであつた。",
              "citation": {
                "source": "蝉",
                "author": "――あるミザントロープの話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活の逼塞　幸徳は死刑になる直前に端書をよこして支那の同志張繼の所在を問うて來ました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時はひっそくしかけていた鉄工所も事変以来殷賑を極めて、いまはこんな身分だと、坂田を苛めてやりたかったのである。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと金使いが荒かったところへ、商売の呉服物が統制にひっ掛り、だんだんひっそくして来た矢先き、大阪の空襲で店も家も商品も焼かれて、裸一貫になってしまった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "相模屋は江戸時代から四代も続いた古い暖簾で五六人の職人を使っていたが、末娘の安子が生れた頃は、そろそろひっそくしかけていた。",
              "citation": {
                "source": "妖婦",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
