    },
    "definitions": [
      {
        "index": 1,
        "gloss": "obesity",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「アムボンポアン」は肥胖、「ベルラ、ナポリ」は美しき拿破里といふ程の事なり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にも良三の父は神田｜松枝町に開業して、市人に頓才のある、見立の上手な医者と称せられ、その肥胖のために瞽者と看錯らるる面をば汎く識られて、家は富み栄えていた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "楊庵は肥胖漢で、其大食は師友を驚かしたものである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二十六囘には張青夫婦が行人を殺害して、その肉にて肉饅頭を作つて販賣することを記して、這等肥胖。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人は晩年｜肥胖と老齢のために、ヴァイオリンの演奏不能に陥り、指揮者として更生し、シンシナチー管弦団を率いて、米国楽壇に重きをなしたことは、これまた一般好楽者の忘れ得ない記憶である。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
