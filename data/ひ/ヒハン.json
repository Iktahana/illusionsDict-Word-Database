[
  {
    "uuid": "034fdc0a-c2ee-52ea-a080-3ea1c7e4b0d0",
    "entry": "批判",
    "reading": {
      "primary": "ひはん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "criticism",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やがてＢは、其の場の空気を批判しだす。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくＢとしたことが、眼前に起つたことは何にもあれ批判するのがその生来なのだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "友達が前にゐるから、その批判を話し出しただけだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、尠くも批判が発展する限りに於て、彼は生甲斐を感ずる次第だ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（文壇で我々の自由詩が解る人は、室生犀星、佐藤春夫の詩人小説家を除いて、實に芥川龍之介一人あるのみだつた）概ねの場合に於て、彼の詩の批判は正しかつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はその「批判」に敬服してゐた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども彼の批判態度は、常に著るしく客觀的だつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度小説の價値批判が、描寫（表現）の巧拙にかかるやうに、詩についても同じ描寫の效果性（即ち表現技巧）について求めた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち彼の批判態度は、純粹に鑑賞的であり、理智的であり、主觀を混じない美學的觀照主義のものであつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれが善き詩であり、どれが惡しき詩であるかについて、彼は正しく判別批判する。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "故にすべての詩は、彼にとつて單に「批判さるべきもの」であり、何等「感動さるべきもの」でない。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度あの所謂劇通が、劇に對してもつ興味のやうに、單にその藝術を「批判する」のであつて、一般觀客の如く、眞にそれを樂んだり、感激したりするのではない。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日の感激に燃えた芥川君は、平常の鑑賞的な美學者ではなく、そんな批判的の態度を忘れてしまつた所の、眞の「詩に溺れてゐる詩人」であつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "世のおとなたちは、織田君の死に就いて、自重が足りなかったとか何とか、したり顔の批判を与えるかも知れないが、そんな恥知らずの事はもう言うな！",
              "citation": {
                "source": "織田君の死",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚作だの、傑作だのと、そんな批判の余裕を持った事が無い。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に蕪村の俳句にいたっては、子規以来単なる写生主義ということで定評づけられ、一もその真の詩的精神――俳句のエスプリする哲学原理――を批判されてない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村の価値が、初めて正しく評価され、その俳句が再批判されたのは、彼の死後百数十年を経た後世、最近明治になってからのことであった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々の蕪村について、批判し定評するところのものは、かつて子規一派の俳人らが、その独自の文学観から鑑賞批判したところを、無批判に伝授している以外、さらに一歩も出ていないのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてしかも、蕪村を讃して芭蕉と比肩し、無批判に俳聖と称している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）こうした文学論が如何に浅薄皮相であり、特に詩に関して邪説であるかは、ここで論ずべき限りでないが、とにかくにも子規一派は、この文学的イデオロギーによって蕪村を批判し、かつそれによって鑑賞したため、自然蕪村の本質が、彼らのいわゆる写生主義の規範的俳人と目されたのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や蕪村の俳句は、改めてまた鑑賞され、新しくまた再批判されねばならない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国人が賞讚するほどの訳を、日本人の分際で非難するのは怪しからんといふのは、語学としての出来の批判を言つてるのだらうが、小宮氏の所論では、語学としての問題ではなく、詩の翻訳の可能についての議論なのである。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "却つてこの種の詩は、今日の批判で素朴的なものに考へられ、詩の原始形態の部に範疇づけられて居る。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この詩集の正しい批判は、おそらく藝術品であるよりも、著者の實生活の記録であり、切實に書かれた心の日記であるのだらう。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し簡単に言へば、常識的の批判からみて好い温泉である。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその蔵する体験と批判的知見とは、個人的に獲得したものであるよりは社会的に継承したものである場合が多いかもしれない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "独断の「甘い」夢が破られて批判的知見に富んだ「いき」が目醒めることは、「いき」の内包的構造のところで述べた。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
