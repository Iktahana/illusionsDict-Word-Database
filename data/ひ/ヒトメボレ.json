[
  {
    "uuid": "6642426e-76ae-5b25-9dab-6d0734a0ba82",
    "entry": "一目惚れ",
    "reading": {
      "primary": "ひとめぼれ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "love at first sight",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "学生時代に、友人に連れられて祇園のお茶屋に行ったときなど、彼はそこに来た二十四五になる美しい名妓から、一目惚れされた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は一目惚れしたのであった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "里見君の所謂一目惚れとは、こんな心もちを云ふのかも知れない。",
              "citation": {
                "source": "点心",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "一目惚れというかなんて早いやつだと、暫く二人を見くらべながら呻っていたのだ。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "其は何だか一目惚れの女の哭き聲だつた氣がする。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "其は何だか、一目惚れの女の哭き声だつた気がする。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "其は何だか一目惚れの女の哭き声だつた気がする。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其は何だか一目惚れの女の哭き声だった気がする。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "元禄髷というのは一種いうべからざる懐古的情趣があって、いわば一目惚れというやつでしょう。",
              "citation": {
                "source": "ヒウザン会とパンの会",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり彼女は銀之丞に、一目惚れをしたのであった。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一目惚れ浜路宗三郎　恋は不思議でも神秘でもない。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これすなわち一目惚れである。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前も気を付けてご介抱するよう」　こう云って紹介された時、パッと浜路が顔を赫めたのは、恋が、一目惚れが、掠めたのである。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり情が深いから身が持てないつてね、一目惚れのより子さん。",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一目惚れのより公たあ誰の事だい？",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長五　実は今の娘に一目惚れというのだろう。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長五　実は今の娘に一目惚れと言うのだろう。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はまずその見かけに一目惚れをした。",
              "citation": {
                "source": "おじさんの話",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "単なる可能性のひとつさ」「後悔はしない」「ふん」「去年の夏、俺のカワサキに一目惚れをしたようだ」「運のつきだな」「きめつけるのは、よせ」　小川敬一との会話は、きりあげどきが大切だ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の心持を地下の初代さんは恨むだろうか、それとも、このめぐり合わせは、凡て初代さんの霊の導きであって、彼女は私をこの孤島に渡らせ、蔵の窓の秀ちゃんを見せて、私に一目惚れをさせたのではないだろうか。",
              "citation": {
                "source": "孤島の鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみに一目惚れした。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "一目惚れって信じますか」　メアリが赤面した。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが一目惚れしたのが、あのエルシ・ゴードンだ。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "出会いは全くの偶然で、一目惚れでした。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてさいごに、王子さまは、そのガラスのくつのおひめさまに、ひとめぼれしたにちがいないわ、とつけくわえました。",
              "citation": {
                "source": "シンデレラ",
                "author": "CINDERELLA, OR THE LITTLE GLASS SLIPPER",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
