[
  {
    "uuid": "d591c09d-f952-528b-a8ec-255968b6e6f6",
    "entry": "暇を出す",
    "reading": {
      "primary": "ひまをだす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
