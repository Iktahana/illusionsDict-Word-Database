    "definitions": [
      {
        "index": 1,
        "gloss": "to scream",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おふくろの方では、水を飲ませといてから殴るのであるから、充分に思ひやりのある処置と信じてゐるのだらうが、殴られる子供の側になつて考へると、何のために、母親が自分を殴るのか、見当がつかないものだから、その抗議として、死にもの狂ひに、あらん限りの悲鳴を上げるのである。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような夜に沖で死んだ人々の魂が風に乗り波に漂うて来て悲鳴を上げるかと、さきの燐火の話を思い出し、しっかりと夜衣の袖の中に潜む。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そこまでは存じませんが、折節女の、ひい、ひい、と悲鳴を上げる声が聞えたり、男がげらげらと笑う声がしたり、や、も、散々な妖原だといいますで。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "御殿づくりでかしづいた、が、其の姫君は可恐い蚤嫌ひで、唯一｜匹にも、夜も晝も悲鳴を上げる。",
              "citation": {
                "source": "人魚の祠",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒイと之が悲鳴を上げるやうで、家内が絞殺される叫びに聞こえる、最う堪りません。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間が何か泣きごとでもいっているかと思うような声を出すかと思うと、首でも締めて殺されかかっているのかと思うような悲鳴を上げる。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウーウーウーという続けさまのは、厭な内にもまだしも穏かな方で、時々、ヒイッと悲鳴を上げる、キャッと叫ぶ、ダァーと云う。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と蝶吉は半狂乱で悲鳴を上げる。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどホームページ行脚に悲鳴を上げる視神経を前にしては、ここで長文を読んでいくことなど想像もしたくなかったからです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は、大きな意思を構成する膨大なアトムの一個なんだな」　悲鳴を上げる視神経をなだめてえんえんとサーフィンを続けていたある夜、私の胸に、ふとそんな思いが芽生えました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本語を使用する極東の島国の民として生まれた筆者は、英和辞典を引きひき Alice の注釈に悲鳴を上げる程度の英語力しか持ち合わせていない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞬間、声を潜めた群衆の頭は、突如として悲鳴を上げると、両側の壁へ向って捻じ込んだ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、手術し損なって、アイネは大声に悲鳴を上げる。",
              "citation": {
                "source": "土から手が",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝彼はやはりいつものように穴部屋の中で、苦しそうに悲鳴を上げると共に目を覚した。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "結果的に、行間の詰まった文字を読まされて、目玉が悲鳴を上げる。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "久慈はその女が小憎らしくて突きかかったが、その度びにも女は喜びの悲鳴を上げるのだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "久慈はいら立たしくなると悲鳴を上げる女へぶっつけたり、千鶴子の体へ捻じ込んだり、衝るを幸いに衝り散らして運転をつづけてみた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼ぶと云ひ、悲鳴を上げると云つても他の世界へ向つてして居るのではなく、二人だけの世界に於てであることは云ふまでもない。",
              "citation": {
                "source": "註釈與謝野寛全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "右腕を肩から落とされて、悲鳴を上げるとキリキリキリと、独楽のように二、三度廻わったが、まずグンニャリと腰を砕き、すぐに横倒しに倒れてしまった。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、すぐにも後悔しよう、顫え上がるに相違ない、悲鳴を上げるに相違ない、そうして許しを乞うだろう、見たようなものだ、見たようなものだ！",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにはホーキン氏も驚いたが、一層驚いたのは土人達で、ワッという悲鳴を上げると共に十間余りも逃げ延びた。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "早「あゝ」　と悲鳴を上げるのを、ウヽーンと※りました。",
              "citation": {
                "source": "菊模様皿山奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は二人に散々やつつけられて悲鳴を上げる根気も失つてゐたが、辛うじて僕達の手を振り切ると這這の体で死者狂ひに丸まり乍ら、ひた走りに森の中へ駈け込んで行つた。",
              "citation": {
                "source": "霓博士の廃頽",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "騒ぎに目をさました長屋の人たちが一人一人、戸のはずれている真っ暗がりの家の中へ入っていって籠の中へ手を突っ込んでは「フワッ、お長屋の衆」と悲鳴を上げる。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "「キャッ」　と悲鳴を上げると共に岩から下へ転がり落ちる。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "疼痛と、睡眠不足と、暑熱とで、再度の手術にも弱音を吐かなかった素子も遂に悲鳴を上げる。",
              "citation": {
                "source": "日を愛しむ",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中の一枚の写真の、髪を洗うポーズを取った女の胸に、二つの大きな乳房がぶら下がっているのを見た瞬間、私は危く悲鳴を上げるほどの衝撃を受けた。",
              "citation": {
                "source": "落日の光景",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、一歩を電車に乗り入れた途端に、私は心の中で悲鳴を上げる。",
              "citation": {
                "source": "落日の光景",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "ころんで、泣きさけぶ子ども、ひめいをあげる若い女の人、おしつぶされそうになって、入口をめざす人のむれ、わきかえるようなさわぎです。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
